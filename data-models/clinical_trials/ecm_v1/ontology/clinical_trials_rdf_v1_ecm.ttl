# RDFS Schema for Business: Clinical Trials

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/clinical_trials#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Clinical Trials ---
ind:ClinicalTrials rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Clinical Trials' ;
    rdfs:comment 'Clinical Trials is a specialized industry that designs, manages, and monitors clinical research studies for pharmaceutical and biotech sponsors, providing data analytics, regulatory expertise, and patient recruitment to accelerate drug development.' .

# --- Domain Classes ---
ind:Study rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ClinicalTrials ;
    rdfs:label 'Study' ;
    rdfs:comment 'Core operational domain managing clinical study protocols, design, phases, objectives, endpoints, inclusion/exclusion criteria, visit schedules, and study lifecycle from protocol development through database lock. Serves as the foundational blueprint for all trial activities and the authoritative source for study identifiers, timelines, amendments, and study-specific procedures.' .

ind:Site rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ClinicalTrials ;
    rdfs:label 'Site' ;
    rdfs:comment 'Manages investigational sites including feasibility assessment, site selection, activation, PI qualifications, CRC assignments, IRB/IEC approval records, site performance metrics, monitoring visit scheduling, and close-out. Tracks site capacity, enrollment performance, and GCP compliance status via CTMS.' .

ind:Subject rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ClinicalTrials ;
    rdfs:label 'Subject' ;
    rdfs:comment 'SSOT for trial participants (subjects/patients) across all studies. Owns subject enrollment, demographics, randomization assignments via IRT/RTSM, treatment arms, visit compliance, protocol deviations, and subject disposition from screening through study completion or withdrawal.' .

ind:Safety rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ClinicalTrials ;
    rdfs:label 'Safety' ;
    rdfs:comment 'Manages adverse events (AE), serious adverse events (SAE), suspected unexpected serious adverse reactions (SUSAR), and safety signal detection. Owns MedDRA coding (SOC/PT/LLT), CTCAE severity grading, causality assessments, expedited regulatory reporting timelines, and DSMB/DMC safety reviews processed through Oracle Argus Safety.' .

ind:Data rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ClinicalTrials ;
    rdfs:label 'Data' ;
    rdfs:comment 'Governs clinical data collection, validation, and lock processes. Owns EDC/eCRF design and build (Medidata Rave), data validation rules, query management, discrepancy resolution, medical coding (MedDRA, WHO-DD), database lock (DBL) workflows, DMP, CDISC SDTM transformations, and ALCOA+ compliance tracking.' .

ind:Laboratory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ClinicalTrials ;
    rdfs:label 'Laboratory' ;
    rdfs:comment 'Manages central and local laboratory operations for clinical trials. Owns lab panel definitions, specimen collection and processing workflows, lab results (including PK/PD and DMPK data), reference ranges, critical values, sample chain of custody, bioanalytical assays, and lab certification/accreditation status.' .

ind:Supply rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ClinicalTrials ;
    rdfs:label 'Supply' ;
    rdfs:comment 'Manages investigational medicinal product (IMP) and clinical supply chain operations. Owns drug supply planning, depot and site inventory, randomization kits, dispensing records via RTSM (Medidata Rave), expiry management, returns and destruction, cold-chain logistics, and accountability reconciliation.' .

ind:Monitoring rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ClinicalTrials ;
    rdfs:label 'Monitoring' ;
    rdfs:comment 'Manages CRA monitoring activities including risk-based monitoring (RBM) strategies, on-site and remote monitoring visits (initiation, interim, close-out), source data verification (SDV), monitoring visit reports, query management, protocol deviation tracking, CAPA workflows, and action item escalation via Oracle Siebel CTMS.' .

ind:Biostatistics rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ClinicalTrials ;
    rdfs:label 'Biostatistics' ;
    rdfs:comment 'Owns the statistical planning and analysis lifecycle for clinical trials. Manages SAP authoring and versioning, randomization scheme design, sample size calculations, ADaM dataset specifications, TLF production, interim and final analyses, blinding/unblinding records, and CSR statistical sections processed through SAS Drug Development.' .

ind:Consent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ClinicalTrials ;
    rdfs:label 'Consent' ;
    rdfs:comment 'Manages the informed consent lifecycle for trial subjects. Owns ICF versions and amendments, eConsent workflows (Clinpal), subject consent status, re-consent triggers, capacity assessments, withdrawal tracking, consent audit trails, and IRB/IEC-approved consent documentation ensuring GCP and GDPR/HIPAA compliance.' .

ind:Randomization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ClinicalTrials ;
    rdfs:label 'Randomization' ;
    rdfs:comment 'Manages subject allocation algorithms, stratification factors, randomization codes, blinding integrity, and unblinding procedures. Integrated with eCRF and supply domains for kit assignment and treatment arm allocation via IRT/IVRS/RTSM systems.' .

ind:Sponsor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ClinicalTrials ;
    rdfs:label 'Sponsor' ;
    rdfs:comment 'SSOT for pharmaceutical and biotech sponsor organizations that fund and own clinical trials. Manages sponsor organization profiles, contracted study portfolios, therapeutic areas, pipeline products, regulatory strategies, commercial relationships, contact hierarchies, and engagement terms across all studies.' .

ind:Agreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ClinicalTrials ;
    rdfs:label 'Agreement' ;
    rdfs:comment 'Stores study contracts, master service agreements, amendments, scope of work documents, change orders, and service-level agreements. Governs the legal and commercial relationship between sponsor and CRO including billing milestones and deliverable schedules.' .

ind:Regulatory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ClinicalTrials ;
    rdfs:label 'Regulatory' ;
    rdfs:comment 'Manages regulatory submissions, approvals, and agency interactions across global health authorities (FDA, EMA, PMDA, MHRA, Health Canada). Owns IND/NDA/BLA/MAA applications, clinical trial authorizations, protocol amendments, regulatory correspondence, inspection readiness, and CTD/eCTD dossier management via Veeva Vault.' .

ind:Document rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ClinicalTrials ;
    rdfs:label 'Document' ;
    rdfs:comment 'SSOT for Trial Master File (TMF/eTMF) essential documents, SOP library, regulatory binders, site files, controlled document versioning, document workflows, DIA TMF Reference Model compliance, inspection readiness, and archival per ICH GCP requirements. Managed through Veeva Vault.' .

ind:Compliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ClinicalTrials ;
    rdfs:label 'Compliance' ;
    rdfs:comment 'Manages GCP quality assurance (QA), quality control (QC), internal and external audits, regulatory inspections, CAPA lifecycle, protocol deviation classifications, SOP compliance tracking, and audit readiness. Ensures adherence to ICH GCP, FDA, EMA, and sponsor quality standards via MasterControl.' .

ind:Finance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ClinicalTrials ;
    rdfs:label 'Finance' ;
    rdfs:comment 'Manages clinical trial financial operations including study budgets, investigator grants, site payment milestones, patient stipends, pass-through cost tracking, sponsor invoicing, accounts payable/receivable, accruals, financial forecasting, and project accounting processed through SAP S/4HANA. Supports SOX financial reporting controls.' .

ind:Workforce rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ClinicalTrials ;
    rdfs:label 'Workforce' ;
    rdfs:comment 'Manages the clinical research workforce including CRAs, CRCs, biostatisticians, data managers, medical monitors, and regulatory specialists. Owns employee profiles, GCP training and certification records, delegation logs, resource allocation to studies, capacity planning, and payroll managed through Workday HCM.' .

ind:Program rdf:type rdfs:Class ;
    rdfs:subClassOf ind:ClinicalTrials ;
    rdfs:label 'Program' ;
    rdfs:comment 'Manages clinical development programs spanning multiple studies for a therapeutic indication or pipeline asset. Owns program-level planning, portfolio governance, milestone tracking, and cross-study coordination.' .

# --- Data Product Classes (Tables) ---
ind:InvestigationalSite rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Investigational Site' ;
    rdfs:comment 'Master record for each investigational site participating in clinical trials. Captures site identity, physical address, facility type, therapeutic area specializations, GCP certification status, regulatory registration numbers (e.g., FDA FEI, DUNS), site tier classification, and operational status. This is the SSOT for site identity and profile across the clinical research enterprise, referenced by all study-site associations, feasibility assessments, and capacity records.' .

ind:SiteContact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Site Contact' ;
    rdfs:comment 'Tracks all personnel contacts associated with an investigational site, including Principal Investigators (PI), Sub-Investigators, Clinical Research Coordinators (CRC), pharmacists, and lab contacts. Captures role, contact details, GCP training status, delegation log reference, and active/inactive status. Supports site staff roster management within CTMS.' .

ind:PrincipalInvestigator rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Principal Investigator' ;
    rdfs:comment 'Master record for Principal Investigators (PIs) conducting clinical trials. Captures PI credentials, medical license numbers, specialty, board certifications, GCP training history, FDA Form 1572 submission status, financial disclosure status, debarment check results, and professional affiliations. Distinct from site_contact as PIs have regulatory accountability and their own lifecycle across multiple studies and sites.' .

ind:FeasibilityAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Feasibility Assessment' ;
    rdfs:comment 'Records the site feasibility evaluation conducted prior to site selection for a specific study. Captures feasibility questionnaire responses, estimated enrollment capacity, patient population availability, competing trial load, infrastructure readiness (EDC access, lab capabilities, pharmacy), therapeutic area experience, and feasibility score. Sourced from Oracle Clinical One and CTMS feasibility workflows.' .

ind:Selection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Selection' ;
    rdfs:comment 'Records the formal site selection decision for a study-site pairing, including selection rationale, selection committee approval, selection date, rejection reasons (if applicable), and the transition from feasibility to activation. Captures the business decision event that moves a site from candidate to selected status for a given protocol.' .

ind:StudySite rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Study Site' ;
    rdfs:comment 'Association entity representing the full lifecycle relationship between a specific study (protocol) and an investigational site, from selection through activation to closeout. Captures site selection decision (rationale, committee approval, rejection reasons), activation workflow milestones (CDA execution, IRB submission, SIV scheduling, drug shipment authorization, EDC provisioning), site number assignment, enrollment targets, enrollment open/close dates, site status (candidate, selected, initiated, enrolling, enrollment complete, closed), and FPFV date. This is the operational hub for all study-site activity and the primary entity for site lifecycle management.' .

ind:Activation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Activation' ;
    rdfs:comment 'Tracks the end-to-end site activation workflow milestones from site selection through first patient first visit (FPFV). Captures completion dates and status for each activation task: confidentiality agreement execution, protocol receipt, IRB/IEC submission, regulatory package submission, site initiation visit (SIV) scheduling, investigator agreement execution, drug shipment authorization, and EDC access provisioning. Sourced from Oracle Siebel CTMS activation tracker.' .

ind:IrbIecApproval rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Irb Iec Approval' ;
    rdfs:comment 'Records IRB (Institutional Review Board) and IEC (Independent Ethics Committee) approvals for a study-site combination. Captures submission date, approval date, approval number, expiration date, continuing review due date, approved protocol version, approved ICF version, approval conditions, and the approving ethics committee identity. Tracks the full approval lifecycle including amendments and renewals. Distinct from the ethics domain which owns the committee master data.' .

ind:RegulatorySubmissionSite rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Regulatory Submission Site' ;
    rdfs:comment 'Tracks site-level regulatory submissions required for trial conduct, including FDA Form 1572 (Statement of Investigator), financial disclosure forms (FDA Form 3454/3455), local health authority notifications, and country-specific site authorization documents. Captures submission date, submission type, regulatory authority, submission status, and approval reference. Complements the regulatory domain which owns IND/NDA-level submissions.' .

ind:InitiationVisit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Initiation Visit' ;
    rdfs:comment 'Records the Site Initiation Visit (SIV) event conducted by the CRA prior to first patient enrollment. Captures visit date, CRA assigned, attendees, training topics covered (protocol, EDC, RTSM, safety reporting, ICF process), action items identified, visit report completion date, and SIV sign-off status. Distinct from ongoing monitoring visits tracked in the monitoring domain.' .

ind:EnrollmentPerformance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Enrollment Performance' ;
    rdfs:comment 'Tracks actual vs. planned enrollment performance at the study-site level over time. Captures reporting period, planned enrollment target, actual subjects screened, subjects enrolled, screen failure count, screen failure rate, dropout count, and cumulative enrollment to date. Enables site-level enrollment forecasting and performance management. Sourced from CTMS enrollment tracking integrated with EDC subject data.' .

ind:Capacity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Capacity' ;
    rdfs:comment 'Captures the declared and assessed operational capacity of an investigational site for concurrent trial participation. Tracks maximum concurrent subjects, available examination rooms, dedicated research staff FTE, pharmacy storage capacity, lab processing capability, competing protocol load, and capacity utilization percentage. Used for site selection scoring, enrollment planning, and workload balancing across the site portfolio.' .

ind:SiteAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Site Agreement' ;
    rdfs:comment 'Tracks site-level contractual agreements including Clinical Trial Agreements (CTA), Confidential Disclosure Agreements (CDA), and site-specific budget agreements. Captures agreement type, execution date, effective date, expiration date, contracting parties, negotiation status, and key financial terms (overhead rate, per-patient fee structure). Complements the agreement domain which owns master service agreements at the sponsor level.' .

ind:SiteCraAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Site Cra Assignment' ;
    rdfs:comment 'Records the assignment of Clinical Research Associates (CRAs) to study-site combinations for monitoring coverage. Captures CRA identity reference (FK to workforce domain), assignment start/end dates, assignment type (primary, backup, co-monitor), geographic territory, workload allocation percentage, and assignment status. Enables monitoring coverage planning, workload balancing, and visit scheduling within CTMS.' .

ind:Closeout rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Closeout' ;
    rdfs:comment 'Records the formal site close-out process for a study-site upon completion or early termination. Captures close-out visit date, last subject last visit (LSLV) date, database lock contribution date, drug accountability reconciliation status, essential document archival status, site file transfer status, final payment status, and regulatory notification completion. Sourced from CTMS close-out workflow.' .

ind:AdverseEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Adverse Event' ;
    rdfs:comment 'Core master record for every adverse event (AE) reported during a clinical trial, capturing onset date, resolution date, severity grade per CTCAE, seriousness flag, expectedness, relationship to investigational product, action taken, outcome, and follow-up version history. Each AE may progress through multiple follow-up updates as clinical picture evolves, with version tracking for each update. Sourced from Oracle Argus Safety and EDC (Medidata Rave). This is the SSOT for all AE occurrences and their temporal evolution across studies and subjects.' .

ind:SeriousAdverseEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Serious Adverse Event' ;
    rdfs:comment 'Transactional record for Serious Adverse Events (SAEs) that meet regulatory seriousness criteria (death, life-threatening, hospitalization, disability, congenital anomaly, or other medically important condition). Captures SAE narrative, seriousness criteria met, initial and follow-up report dates, blinded/unblinded status, and regulatory reporting obligations. Linked to the parent adverse_event record. Sourced from Oracle Argus Safety.' .

ind:Susar rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Susar' ;
    rdfs:comment 'Transactional record for Suspected Unexpected Serious Adverse Reactions (SUSARs) — SAEs that are both unexpected (not in the Investigator Brochure) and causally related to the investigational product. Captures expectedness assessment, causality determination, expedited reporting clock start date, 7-day and 15-day reporting deadlines, submission status to FDA/EMA/PMDA, and blind-break details. Sourced from Oracle Argus Safety.' .

ind:AeMeddraCoding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Ae Meddra Coding' ;
    rdfs:comment 'Stores the MedDRA coding assignment for each adverse event, capturing the verbatim term reported, the coded Lowest Level Term (LLT), Preferred Term (PT), High Level Term (HLT), High Level Group Term (HLGT), and System Organ Class (SOC). Tracks coding version, coder identity, coding date, and auto-code vs. manual-code flag. Enables standardized MedDRA-based safety queries and regulatory submissions. Sourced from Oracle Argus Safety.' .

ind:CausalityAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Causality Assessment' ;
    rdfs:comment 'Records the investigator and sponsor medical monitor causality assessments for each adverse event relative to the investigational product and concomitant medications. Captures assessor role, assessment date, causality category (unrelated, unlikely, possible, probable, definite), rationale narrative, and whether the assessment was revised. Supports regulatory reporting and signal detection workflows in Oracle Argus Safety.' .

ind:Narrative rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Narrative' ;
    rdfs:comment 'Stores the structured clinical narrative for SAEs and SUSARs, including case summary, patient description, event description, treatment details, outcome, and medical monitor commentary. Tracks narrative version, authoring date, review status, and approval by the medical monitor. Used in expedited regulatory reports (ICSRs) submitted via Oracle Argus Safety in eCTD/E2B(R3) format.' .

ind:Icsr rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Icsr' ;
    rdfs:comment 'Individual Case Safety Report (ICSR) — the formal regulatory submission record for expedited safety reporting to health authorities (FDA, EMA, PMDA, MHRA). Captures report type (initial, follow-up, nullification), submission date, acknowledgement receipt, regulatory agency, submission method (E2B XML, MedWatch, CIOMS), report version, submission status, clock start date (date of first awareness), calculated 7-day and 15-day deadline dates, actual submission date, days-to-submission, on-time compliance flag, and reason for delay if late. Enables compliance monitoring against ICH E2A and regional reporting requirements. Sourced from Oracle Argus Safety case submission module.' .

ind:Signal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Signal' ;
    rdfs:comment 'Master record for identified safety signals and their full evaluation lifecycle. Captures signal description, detection method (disproportionality analysis, PRR, ROR, BCPNN, clinical review, literature), detection date, data source, signal strength metrics, assigned medical monitor, evaluation plan, data reviewed, benefit-risk assessment summary, regulatory action recommended (label update, DHPC, study suspension, protocol amendment), evaluation completion date, DSMB/DMC referral flag, current status (new, under evaluation, validated, refuted, ongoing monitoring), and final disposition. Supports multiple evaluation cycles as new data emerges. Managed in Oracle Argus Safety signal detection and evaluation modules.' .

ind:SignalEvaluation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Signal Evaluation' ;
    rdfs:comment 'Transactional record capturing the formal evaluation workflow for a safety signal, including evaluation plan, data reviewed, benefit-risk assessment, regulatory action recommended (label update, DHPC, study suspension, protocol amendment), evaluation completion date, and DSMB/DMC referral flag. Each signal may have multiple evaluation cycles as new data emerges.' .

ind:DsmbReview rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Dsmb Review' ;
    rdfs:comment 'Master record for Data Safety Monitoring Board (DSMB) / Data Monitoring Committee (DMC) safety governance, covering both committee definition and individual review meetings. Captures committee name, type (DSMB, DMC, IDMC, internal SRC), charter version, member roster, independence status, meeting date, meeting type (scheduled, ad hoc, emergency), study phase reviewed, unblinded data package version, interim analysis reference, formal recommendations issued (continue, modify, suspend, terminate), recommendation rationale, sponsor response, implementation date, and regulatory notification requirements. This is the SSOT for safety oversight committee governance and their formal outputs.' .

ind:DsmbRecommendation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Dsmb Recommendation' ;
    rdfs:comment 'Transactional record for formal DSMB/DMC recommendations issued following a safety review meeting. Captures recommendation type (continue unchanged, protocol amendment required, dose modification, study suspension, early termination), rationale, sponsor response, implementation date, and regulatory notification requirement. Each DSMB review may produce one or more recommendations.' .

ind:ReportingObligation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Reporting Obligation' ;
    rdfs:comment 'Reference master defining regulatory reporting timelines and obligations for each study-country-agency combination. Captures event type (SUSAR fatal, SUSAR non-fatal, SAE, annual DSUR, IND safety report), reporting clock duration (7-day, 15-day, 30-day, annual), applicable regulation (21 CFR 312.32, EU CTR Art. 42, ICH E2A), agency recipient, submission format (E2B R3, MedWatch 3500A, CIOMS I), and whether expedited or periodic reporting applies. Drives automated deadline calculation in Oracle Argus Safety and enables compliance monitoring dashboards.' .

ind:ExpeditedReportDeadline rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Expedited Report Deadline' ;
    rdfs:comment 'Transactional record tracking the calculated and actual submission deadlines for each expedited safety report (ICSR/SUSAR). Captures clock start date (date of first awareness), 7-day and 15-day deadline dates, actual submission date, days-to-submission, on-time flag, reason for delay if late, and regulatory agency. Enables compliance monitoring against ICH E2A and regional reporting requirements.' .

ind:Dsur rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Dsur' ;
    rdfs:comment 'Development Safety Update Report (DSUR) — the annual periodic safety report submitted to health authorities summarizing cumulative safety data for an investigational product across all ongoing studies. Captures reporting period, data lock date, cumulative subject exposure, SAE line listing summary, benefit-risk conclusion, and submission dates per agency. Sourced from Oracle Argus Safety periodic reporting module.' .

ind:CtcaeGrade rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Ctcae Grade' ;
    rdfs:comment 'Reference table for CTCAE (Common Terminology Criteria for Adverse Events) severity grading definitions. Captures CTCAE version, SOC category, adverse event term, grade (1–5), grade description, and clinical criteria. Used to standardize severity grading across all AE records. Infrequently updated when new CTCAE versions are released by NCI.' .

ind:MeddraTerm rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Meddra Term' ;
    rdfs:comment 'Reference master for the MedDRA (Medical Dictionary for Regulatory Activities) terminology hierarchy, storing all active terms across all five levels: LLT (Lowest Level Term), PT (Preferred Term), HLT (High Level Term), HLGT (High Level Group Term), and SOC (System Organ Class). Captures term code, term name, level, primary SOC flag, MedDRA version, and active/retired status. Updated with each biannual MedDRA release.' .

ind:ReviewCommittee rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Review Committee' ;
    rdfs:comment 'Master record for internal sponsor Safety Review Committees (SRCs) and external Data Monitoring Committees (DMCs) overseeing study safety. Captures committee name, type (internal SRC, DSMB, DMC, IDMC), charter version, meeting frequency, member roster, independence status, and associated studies. Distinct from the dsmb_review entity which captures individual meeting records.' .

ind:InvestigatorBrochureSafety rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Investigator Brochure Safety' ;
    rdfs:comment 'Master record tracking the safety-relevant sections of the Investigator Brochure (IB) for each investigational product, including the Reference Safety Information (RSI) used to assess expectedness of adverse reactions. Captures IB version, RSI section content, listed adverse reactions, update date, and whether a SUSAR triggered an IB amendment. Drives expectedness determination in Oracle Argus Safety.' .

ind:SafetyCommunication rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Safety Communication' ;
    rdfs:comment 'Transactional record for formal safety communications issued to investigators, IRBs/IECs, and health authorities, including urgent safety measures, Dear Healthcare Professional Communications (DHPCs), and safety letters. Captures communication type, trigger event (SUSAR, signal, DSMB recommendation), recipient type, issue date, distribution method, and acknowledgement tracking. Sourced from Oracle Argus Safety and Veeva Vault.' .

ind:AeFollowUp rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Ae Follow Up' ;
    rdfs:comment 'Transactional record capturing follow-up information updates for an adverse event after the initial report, including updated severity grade, new causality assessment, additional clinical details, outcome update, and resolution date. Each AE may have multiple follow-up records as the clinical picture evolves. Drives follow-up ICSR submissions in Oracle Argus Safety.' .

ind:BenefitRiskAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Benefit Risk Assessment' ;
    rdfs:comment 'Master record for formal benefit-risk assessments conducted at the study or program level, capturing assessment date, trigger (DSMB recommendation, signal validation, regulatory request, periodic review), benefit summary, risk summary, overall benefit-risk conclusion, recommended risk minimization measures, and approval by the sponsor medical officer. Supports regulatory submissions and DSUR benefit-risk sections.' .

ind:MonitoringPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Monitoring ;
    rdfs:label 'Monitoring Plan' ;
    rdfs:comment 'Master entity defining the risk-based monitoring (RBM) strategy for a clinical study. Specifies monitoring approach (on-site, remote, centralized), SDV scope and percentage thresholds, visit frequency rules, critical data/process definitions per ICH E6(R2), KRI tolerance limits, site risk tiers, and trigger-based escalation criteria. One plan per study with versioned amendments. Sourced from Oracle Siebel CTMS.' .

ind:MonitoringVisit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Monitoring ;
    rdfs:label 'Monitoring Visit' ;
    rdfs:comment 'Transactional record of each CRA monitoring visit to an investigational site. Captures visit type (SIV, IMV, COV, RMV, FUV), visit mode (on-site, remote), scheduled/actual dates, assigned CRA, status, and outcome. Visit type classification attributes (standard objectives, expected duration, required TMF documents) are embedded. Primary operational entity in Oracle Siebel CTMS.' .

ind:VisitReport rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Monitoring ;
    rdfs:label 'Visit Report' ;
    rdfs:comment 'Formal monitoring visit report authored by the CRA following each on-site or remote monitoring visit. Captures visit summary narrative, findings, SDV results, protocol deviations identified, outstanding issues, action items raised, and CRA/supervisor sign-off. Stored in Veeva Vault eTMF as an essential TMF document (reference: TMF Reference Model Zone 11).' .

ind:SdvRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Monitoring ;
    rdfs:label 'Sdv Record' ;
    rdfs:comment 'Source Data Verification (SDV) record capturing the verification of individual eCRF data points against source documents at the site. Tracks subject visit, eCRF field or data point verified, SDV outcome (verified, discrepancy found, not verifiable), discrepancy description, resolution status, and CRA performing SDV. Supports ALCOA+ compliance and audit trail requirements under 21 CFR Part 11.' .

ind:VisitDeviationFinding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Monitoring ;
    rdfs:label 'Visit Deviation Finding' ;
    rdfs:comment 'Record of each protocol deviation identified at a site during monitoring or data review. Captures deviation category and severity (major, minor, important), description, root cause, affected subject, dates of occurrence and identification, IRB/IEC and sponsor reporting status, and classification attributes (prospective/retrospective). Linked to CAPA workflow when required. Now includes deviation classification taxonomy as embedded attributes.' .

ind:VisitFinding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Monitoring ;
    rdfs:label 'Visit Finding' ;
    rdfs:comment 'Individual finding or observation recorded by a CRA during a monitoring visit or remote review. Captures finding category (data integrity, consent, IP accountability, safety reporting, regulatory compliance), severity, description, site response, resolution status, and due date. Findings are aggregated into the visit report and may trigger action items or CAPAs.' .

ind:MonitoringActionItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Monitoring ;
    rdfs:label 'Monitoring Action Item' ;
    rdfs:comment 'Formal action item raised as a result of a monitoring finding, protocol deviation, or escalation trigger. Tracks action description, responsible party (site staff, CRA, or sponsor), due date, priority level, current status (open, in-progress, overdue, closed), escalation flag, and closure confirmation with evidence. Managed in Oracle Siebel CTMS with automated escalation workflows for overdue items. Primary operational entity for site performance management, regulatory inspection readiness, and GCP compliance tracking.' .

ind:RiskIndicator rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Monitoring ;
    rdfs:label 'Risk Indicator' ;
    rdfs:comment 'Centralized monitoring risk indicator (also known as Key Risk Indicator or KRI) defined within the RBM monitoring plan. Captures indicator name, category (enrollment, data quality, safety, protocol compliance, IP accountability), calculation method, threshold values (amber/red), data source, and current computed value per site. Supports centralized statistical monitoring (CSM) and site risk scoring in the RBM framework.' .

ind:SiteRiskAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Monitoring ;
    rdfs:label 'Site Risk Assessment' ;
    rdfs:comment 'Periodic risk assessment of an investigational site within the RBM framework. Captures overall site risk score, individual KRI values and threshold breaches, risk tier classification (low, medium, high), assessment date, assessor, recommended monitoring intensity adjustment, and approval status. Drives adaptive monitoring visit frequency and SDV scope decisions in Oracle Siebel CTMS.' .

ind:MonitoringCraAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Monitoring ;
    rdfs:label 'Monitoring Cra Assignment' ;
    rdfs:comment 'Assignment record linking a CRA to a specific site and study for monitoring responsibilities. Captures assignment dates, type (primary, backup, lead CRA), territory, workload allocation percentage, and status. Drives visit authorization, workload planning, and site coverage in Oracle Siebel CTMS.' .

ind:MonitoringVisitSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Monitoring ;
    rdfs:label 'Monitoring Visit Schedule' ;
    rdfs:comment 'Planned monitoring visit schedule for a site within a study, derived from the monitoring plan. Captures planned visit type, planned visit window (earliest and latest acceptable dates), visit frequency interval, basis for scheduling (risk-based trigger, calendar-based, milestone-based), and schedule status. Used in Oracle Siebel CTMS for visit planning and CRA workload forecasting.' .

ind:IpAccountabilityLog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Monitoring ;
    rdfs:label 'Ip Accountability Log' ;
    rdfs:comment 'Investigational Product (IP) accountability verification record captured during monitoring visits. Records CRA verification of IP receipt, dispensing, return, and destruction records at the site level. Captures IP batch/lot number, quantity reconciliation (received vs dispensed vs returned vs destroyed), reconciliation status, temperature excursion checks, discrepancy notes, and CRA verification date. Supports GCP compliance for IP accountability under ICH E6(R2) Section 5.18.3 and 21 CFR 312.62.' .

ind:EscalationRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Monitoring ;
    rdfs:label 'Escalation Record' ;
    rdfs:comment 'Formal escalation record raised when action items, protocol deviations, or CAPAs are not resolved within defined timelines or when critical GCP findings require sponsor or management intervention. Captures escalation trigger, escalation level (CRA to Lead CRA, Lead CRA to Sponsor Medical Monitor, Sponsor to IRB/IEC), escalation date, responsible parties notified, and resolution outcome. Managed in Oracle Siebel CTMS.' .

ind:VisitChecklist rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Monitoring ;
    rdfs:label 'Visit Checklist' ;
    rdfs:comment 'Monitoring checklist template and completion record used by CRAs during visits. Defines checklist items (regulatory binder, ICF, IP accountability, eCRF, safety reporting), item categories, mandatory/optional flags, and captures per-item completion status and CRA sign-off. Versioned per SOP updates. Supports consistent monitoring execution and inspection readiness.' .

ind:CentralMonitoringAlert rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Monitoring ;
    rdfs:label 'Central Monitoring Alert' ;
    rdfs:comment 'Automated or manually triggered alert generated by the centralized statistical monitoring (CSM) system when a KRI threshold breach or data anomaly is detected at a site. Captures alert type, triggering KRI or data signal, site and study context, alert severity, alert generation date, assigned reviewer, review outcome, and disposition (escalated to on-site visit, remote follow-up, no action required). Supports proactive risk management in the RBM framework.' .

ind:Audit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Audit' ;
    rdfs:comment 'Master record for all internal and external GCP audits conducted across studies, sites, systems, and vendors. Captures audit type (system, process, vendor, site, TMF), scope, lead auditor, planned and actual dates, audit status, sponsoring organization, and overall audit outcome (satisfactory, needs improvement, unsatisfactory). Includes risk-based audit prioritization score. Sourced from MasterControl audit management module. SSOT for audit identity and lifecycle within the compliance domain.' .

ind:AuditFinding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Audit Finding' ;
    rdfs:comment 'Transactional record of individual findings identified during an internal or sponsor-initiated GCP audit. Captures finding reference number, finding category (critical, major, minor, observation), finding description, ICH GCP clause reference, regulatory citation, affected process area, site or system implicated, management response, response due date, and finding status. Each finding is linked to a parent audit record and may trigger a CAPA. Distinct from inspection_finding: audit findings are internally generated, managed through internal quality processes, and do not carry formal regulatory response obligations. Sourced from MasterControl.' .

ind:ComplianceInspection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Compliance Inspection' ;
    rdfs:comment 'Master record for regulatory authority inspections conducted by agencies such as FDA, EMA, PMDA, MHRA, or Health Canada at sponsor, CRO, or investigational site level. Captures inspection type (routine, for-cause, pre-approval), inspecting agency, inspection scope (study-specific or systems), lead inspector name, notification date, inspection window, and final classification (no action indicated, voluntary action indicated, official action indicated). Distinct from internal audits — inspections are externally initiated by health authorities.' .

ind:InspectionFinding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Inspection Finding' ;
    rdfs:comment 'Transactional record of individual findings issued by a regulatory authority during a formal inspection. Captures finding number, regulatory citation (e.g., FDA Form 483 observation, EMA GCP non-compliance), finding classification (critical, major, other), detailed description, affected study or site, formal response deadline, and resolution status. Linked to the parent inspection record. Distinct from audit_finding: inspection findings are issued by external health authorities, carry formal legal response obligations (e.g., FDA 483 response within 15 business days), and may escalate to warning letters or consent decrees. Regulatory inspection findings require executive-level response and are tracked separately for regulatory commitment management.' .

ind:ComplianceCapa rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Compliance Capa' ;
    rdfs:comment 'Master record for Corrective and Preventive Actions (CAPA) initiated in response to audit findings, inspection findings, protocol deviations, QC failures, or self-identified quality issues. Captures CAPA reference number, root cause category, root cause description, corrective action plan, preventive action plan, responsible owner, target completion date, actual completion date, effectiveness check date, and CAPA status (open, in-progress, closed, overdue). Sourced from MasterControl CAPA module. SSOT for CAPA lifecycle.' .

ind:CapaActionItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Capa Action Item' ;
    rdfs:comment 'Transactional record of individual action items within a CAPA plan. Each CAPA may have multiple discrete action items assigned to different owners with independent due dates and completion statuses. Captures action item description, assigned owner, planned completion date, actual completion date, evidence of completion, and action item status. Enables granular tracking of CAPA execution progress within MasterControl.' .

ind:ProtocolDeviation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Protocol Deviation' ;
    rdfs:comment 'Transactional record of protocol deviations identified during study conduct. Captures deviation reference number, study and site identifiers, subject identifier (if applicable), deviation category (major, minor, important), deviation type (eligibility, dosing, visit window, prohibited medication, consent), description of the deviation, date of occurrence, date of discovery, reporting obligation (IRB/IEC, sponsor, regulatory), and deviation status. Distinct from safety events — deviations are GCP compliance events. Sourced from CTMS and EDC systems.' .

ind:DeviationClassification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Deviation Classification' ;
    rdfs:comment 'Reference master defining the standardized classification taxonomy for protocol deviations used across all studies. Captures deviation category (major, minor, important protocol deviation), deviation type code, regulatory reporting threshold, standard description template, applicable ICH or FDA guidance reference, and whether the deviation type requires IRB/IEC notification. Enables consistent deviation categorization across studies and sponsors. Managed in MasterControl.' .

ind:ComplianceSop rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Compliance Sop' ;
    rdfs:comment 'Master record for Standard Operating Procedures (SOPs) managed within the quality management system. Captures SOP number, title, version, effective date, expiry date, SOP owner (department/role), applicable process area, regulatory basis (GCP, GLP, GMP), training requirement flag, document status (draft, under review, approved, retired), and superseded version reference. Sourced from MasterControl document control module. SSOT for SOP identity — distinct from the document domain which manages TMF and regulatory binders.' .

ind:SopTrainingRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Sop Training Record' ;
    rdfs:comment 'Transactional record capturing individual staff training completions against required SOPs. Captures staff member identifier, SOP version trained on, training method (read-and-understand, classroom, e-learning, OJT), training completion date, assessment score (if applicable), trainer identifier, and training status (completed, overdue, waived). Enables SOP compliance tracking and training currency verification for GCP inspections. Sourced from MasterControl training management module.' .

ind:SopTrainingRequirement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Sop Training Requirement' ;
    rdfs:comment 'Master record defining which SOPs are required training for which roles, departments, or study assignments. Captures role or job function, SOP identifier, training frequency (initial, annual, on-change), grace period days, and whether training is mandatory for study participation. Drives automated training assignment and compliance gap identification in MasterControl. Distinct from the training record (which captures completion) — this defines the obligation.' .

ind:QualityEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Quality Event' ;
    rdfs:comment 'Transactional record capturing quality events identified through QC reviews, self-inspections, routine quality monitoring, or proactive quality surveillance activities. Captures event reference number, event type (data quality issue, process non-compliance, system failure, vendor quality issue, QC review finding), severity classification, affected study or site, description, date identified, source of identification, error metrics (sample size, error count, error rate where applicable), QC outcome, escalation decision (CAPA required yes/no), and event status. Quality events are the primary intake mechanism for all quality signals before formal CAPA determination — they serve as the triage point between routine quality monitoring and formal corrective action. Sourced from MasterControl quality management module.' .

ind:RiskAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Risk Assessment' ;
    rdfs:comment 'Master record for quality risk assessments conducted at study, site, process, system, or inspection-readiness level to support risk-based quality management (RBQM). Captures risk assessment reference, scope (study-level, site-level, process-level, inspection-readiness), risk category (data integrity, patient safety, regulatory compliance, operational), risk description, inherent risk score, control measures, residual risk score, risk owner, assessment date, review frequency, identified gaps, and remediation tracking. Supports ICH Q9 risk-based approaches, FDA RBQM guidance, and proactive inspection preparation. Sourced from MasterControl.' .

ind:RegulatoryCommitment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Commitment' ;
    rdfs:comment 'Master record tracking formal commitments made to regulatory authorities (FDA, EMA, PMDA) in response to inspection findings, warning letters, or agency queries. Captures commitment reference, originating regulatory action (inspection finding, warning letter, complete response letter), commitment description, committed action, responsible owner, committed completion date, actual completion date, and commitment status. Enables tracking of post-inspection regulatory obligations distinct from internal CAPA actions.' .

ind:Obligation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Obligation' ;
    rdfs:comment 'Reference master defining the regulatory and contractual compliance obligations applicable to the organization across jurisdictions and study types. Captures obligation reference, obligation source (ICH GCP, FDA 21 CFR Part 11, EU CTR 536/2014, GDPR, HIPAA, PMDA, sponsor contract), obligation description, applicable study phase or type, responsible function, monitoring frequency, and obligation status (active, superseded). Distinct from regulatory_commitment (which tracks specific promises made to agencies in response to findings) — this product defines the standing regulatory framework that drives audit scope, inspection readiness, and compliance monitoring activities.' .

ind:TmfDocument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Tmf Document' ;
    rdfs:comment 'Core master entity representing an essential document within the Trial Master File (TMF/eTMF) as defined by the DIA TMF Reference Model. Captures document identity, TMF zone/section/artifact classification, title, version, lifecycle status (draft, approved, effective, superseded, archived), document type, language, originating system (Veeva Vault), confidentiality classification, retention period, and GCP compliance flags. SSOT for all TMF essential documents. Each record represents one logical document (not a version — see document_version for version history).' .

ind:TmfArtifact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Tmf Artifact' ;
    rdfs:comment 'Reference entity defining the DIA TMF Reference Model artifact taxonomy — the standardized classification of document types by Zone, Section, and Artifact number (e.g., Zone 1 Section 1.1 Artifact 01 - Protocol). Stores artifact code, artifact name, zone number, zone name, section number, section name, required/recommended/optional classification, applicable trial phase, and ICH GCP reference. Drives TMF completeness metrics and inspection readiness assessments.' .

ind:Version rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Version' ;
    rdfs:comment 'Tracks the full version history of every controlled document in the TMF and SOP library. Each record represents a discrete version of a document, capturing version number, effective date, expiry date, version status (draft, in-review, approved, superseded, obsolete), change summary, author, approver, and the Veeva Vault document version ID. Supports 21 CFR Part 11 and EU CTR audit trail requirements for controlled document versioning.' .

ind:DocumentSop rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Document Sop' ;
    rdfs:comment 'Master entity for Standard Operating Procedures (SOPs) in the controlled document library (MasterControl). Each record represents one SOP with: SOP number, title, current version, effective/expiry dates, category (clinical operations, data management, safety, regulatory, quality), owning department, applicable regulatory framework (FDA, EMA, ICH GCP), training requirement flag, and superseded SOP cross-reference. SSOT for the SOP library — distinct from TMF essential documents which are study-specific. SOPs are organization-level controlled documents that govern how clinical trial activities are performed.' .

ind:Workflow rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Workflow' ;
    rdfs:comment 'Tracks the lifecycle workflow state of a document through its review, approval, and distribution process within Veeva Vault. Captures workflow instance ID, workflow template name, current workflow step, step assignee role, step due date, step completion date, workflow status (initiated, in-review, pending-approval, approved, rejected, cancelled), escalation flag, and SLA breach indicator. Supports GCP-compliant document control workflows.' .

ind:Signature rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Signature' ;
    rdfs:comment 'Records electronic signatures applied to controlled documents per 21 CFR Part 11 requirements. Captures signer identity, signer role (author, reviewer, approver, sponsor representative), signature date and timestamp, signature meaning (reviewed, approved, acknowledged), signature method (username/password, biometric), IP address, and audit hash. Provides the legally binding e-signature audit trail for regulatory submissions and inspections.' .

ind:SiteFile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Site File' ;
    rdfs:comment 'Master entity representing the Investigator Site File (ISF) or Regulatory Binder maintained at each investigational site. Captures site file ID, associated study, associated site, file type (ISF, regulatory binder, pharmacy binder), physical or electronic location, custodian (PI or CRC), completeness status, last review date, and inspection readiness status. Tracks the site-level essential document collection required by ICH GCP Section 8.' .

ind:SiteFileDocument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Site File Document' ;
    rdfs:comment 'Association entity linking specific TMF documents to their corresponding Investigator Site File (ISF). Captures the site file, the document, the ISF section/tab, filing date, filing status (filed, missing, not-applicable), source (original, certified copy, scanned), and the CRA who verified the filing during SDV. Enables per-site document completeness tracking and supports monitoring visit preparation.' .

ind:TmfCompleteness rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Tmf Completeness' ;
    rdfs:comment 'Transactional record capturing a point-in-time TMF completeness assessment for a study, capturing the assessment date, assessed by (QA or TMF manager), overall completeness percentage, number of expected artifacts, number of filed artifacts, number of missing artifacts, number of overdue artifacts, and completeness by TMF zone. Supports ongoing inspection readiness monitoring and DIA TMF Reference Model compliance reporting.' .

ind:InspectionReadiness rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Inspection Readiness' ;
    rdfs:comment 'Master record tracking the inspection readiness status of a study\'s TMF for regulatory authority inspections (FDA, EMA, MHRA, PMDA). Captures study reference, inspection type (GCP, TMF, sponsor), target inspection date, readiness status (not-started, in-preparation, ready, under-inspection, closed), readiness score, number of open findings, number of critical gaps, responsible TMF manager, and last readiness review date. Distinct from compliance domain inspection records — this entity is document-centric.' .

ind:Distribution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Distribution' ;
    rdfs:comment 'Tracks the controlled distribution of approved documents (SOPs, protocols, amendments, ICFs) to recipients. Captures distribution date, document version distributed, recipient name, recipient role, recipient organization (site, sponsor, CRO), distribution method (Veeva Vault notification, email, physical), acknowledgement required flag, acknowledgement date, and distribution status. Supports GCP-compliant controlled distribution and training acknowledgement tracking.' .

ind:RegulatoryBinder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Regulatory Binder' ;
    rdfs:comment 'Master entity representing a regulatory submission binder or eCTD sequence package assembled for health authority submissions (IND, NDA, BLA, MAA, CTA). Captures binder ID, binder type (IND, NDA, BLA, MAA, CTA, annual report), submission sequence number, target agency (FDA, EMA, PMDA, MHRA), submission date, eCTD format flag, binder status (in-preparation, submitted, under-review, approved, withdrawn), and Veeva Vault regulatory binder reference. Distinct from the regulatory domain submission record — this entity owns the document collection.' .

ind:BinderDocument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Binder Document' ;
    rdfs:comment 'Association entity linking individual documents to a regulatory binder or eCTD sequence. Captures the binder, the document version included, the CTD section (e.g., Module 1.2, Module 5.3.5.1), sequence order, inclusion rationale, QC review status, and the date the document was added to the binder. Enables complete traceability of which document versions were submitted in each regulatory package.' .

ind:ArchivalRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Archival Record' ;
    rdfs:comment 'Master entity tracking the archival disposition of TMF documents and study files at study close-out per ICH GCP requirements. Captures archival date, archival location (physical archive, long-term electronic archive), archive reference number, retention period (years), retention basis (ICH GCP 15 years, FDA 21 CFR 312.62, sponsor requirement), archival status (pending, archived, retrieved, destroyed), destruction date, and destruction authorization. Ensures compliance with post-study document retention obligations.' .

ind:AccessLog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Access Log' ;
    rdfs:comment 'Business compliance audit trail recording access events to controlled documents in Veeva Vault per 21 CFR Part 11 requirements. Each record captures: user identity, user role, access action (view, download, print, edit, delete), document version accessed, timestamp, access justification (when required by document confidentiality level), and source IP. This is a regulatory-mandated business record for GCP inspection readiness — not an IT infrastructure log. Retention aligned with parent document retention period.' .

ind:EtmfExchange rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Etmf Exchange' ;
    rdfs:comment 'Tracks eTMF document exchange transactions between CRO and sponsor organizations per the DIA eTMF Exchange Mechanism Standard. Each record represents a discrete transfer event: exchange direction (CRO-to-sponsor, sponsor-to-CRO), document package contents, exchange date, protocol version, transfer method (Veeva Vault cross-account, SFTP, API), transfer status (initiated, in-transit, received, acknowledged, rejected), and sponsor acknowledgement timestamp. Critical for demonstrating sponsor oversight obligations under ICH GCP 5.0.' .

ind:DocumentIcfVersion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Document Icf Version' ;
    rdfs:comment 'Master entity for Informed Consent Form (ICF) document versions managed within the TMF and document control system. Captures ICF version number, version date, IRB/IEC approval date, applicable subject population (adult, pediatric, LAR), language, amendment reason, protocol version alignment, ICF type (main consent, assent, HIPAA authorization, optional procedures), and Veeva Vault document reference. Distinct from the consent domain\'s subject-level consent records — this entity owns the ICF document master.' .

ind:Template rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Template' ;
    rdfs:comment 'Master entity for approved document templates used to create standardized clinical trial documents (protocol templates, ICF templates, CSR shells, SAP templates, CRF annotation templates). Captures template name, template type, applicable document category, version, effective date, owning department, mandatory/optional classification, and Veeva Vault template reference. Ensures consistency and GCP compliance across document creation.' .

ind:Organization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsor ;
    rdfs:label 'Organization' ;
    rdfs:comment 'Master record for pharmaceutical and biotech sponsor organizations that fund and own clinical trials. Captures the authoritative profile of each sponsor entity including legal name, organization type (pharma, biotech, academic, government), headquarters location, regulatory agency identifiers (FDA sponsor ID, EMA organization ID), DUNS number, tax ID, corporate tier (Big Pharma, mid-size, emerging biotech), public/private status, stock ticker, founding year, and operational status. This is the SSOT for sponsor identity across the entire clinical research enterprise.' .

ind:OrgHierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsor ;
    rdfs:label 'Org Hierarchy' ;
    rdfs:comment 'Defines parent-child corporate hierarchy relationships among sponsor organizations, capturing subsidiary, affiliate, and division structures. Tracks relationship type (parent, subsidiary, affiliate, division, joint-venture), effective dates, ownership percentage, controlling entity flag, and hierarchy depth level. Enables roll-up reporting across sponsor corporate families and supports multi-national sponsor structures where regional entities contract independently.' .

ind:SponsorContact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsor ;
    rdfs:label 'Sponsor Contact' ;
    rdfs:comment 'Master record for individual sponsor contacts including medical monitors, project managers, regulatory affairs leads, clinical operations directors, and business development representatives. Captures full name, title, department, role type, primary and secondary email, phone numbers, preferred communication channel, LinkedIn profile, contact status (active, inactive, departed), and the sponsor organization they represent. SSOT for sponsor personnel identity within the CRO relationship.' .

ind:PipelineAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsor ;
    rdfs:label 'Pipeline Asset' ;
    rdfs:comment 'Master record for investigational drug, biologic, or device assets in a sponsor\'s development pipeline. Captures compound/molecule name, INN (International Nonproprietary Name), brand name candidate, drug class, mechanism of action, modality (small molecule, biologic, gene therapy, cell therapy, medical device), development phase (preclinical, Phase I-IV), therapeutic area, target indication, IND/CTA number, NDA/BLA/MAA filing status, patent expiry date, and orphan drug designation. Enables pipeline portfolio management and study-to-asset linkage.' .

ind:PipelineAssetPhase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsor ;
    rdfs:label 'Pipeline Asset Phase' ;
    rdfs:comment 'Tracks the development phase history and transitions of a pipeline asset across its lifecycle. Captures phase (preclinical, Phase I, Phase Ib, Phase II, Phase IIa, Phase IIb, Phase III, Phase IV, NDA/BLA submission, approved), phase start date, phase end date, phase status (active, completed, on-hold, terminated), regulatory milestone achieved, and reason for phase transition or termination. Provides a longitudinal view of asset progression through the clinical development continuum.' .

ind:StudyPortfolio rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsor ;
    rdfs:label 'Study Portfolio' ;
    rdfs:comment 'Represents the contracted study portfolio relationship between a sponsor organization and the CRO, linking sponsor organizations to the clinical studies they have commissioned. Captures portfolio name, therapeutic area focus, total study count, active study count, portfolio status (active, wind-down, completed), strategic priority tier, and portfolio-level KPI targets. Serves as the business grouping layer above individual study contracts, enabling sponsor-level portfolio performance tracking.' .

ind:SponsorEngagement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsor ;
    rdfs:label 'Sponsor Engagement' ;
    rdfs:comment 'Master record for the commercial engagement relationship between a sponsor and the CRO, representing the overarching business relationship spanning multiple studies and contracts. Captures engagement name, type (full-service CRO, FSP, co-development, preferred provider), start/end dates, strategic account tier, total contracted value, relationship health score, assigned CRO account manager, and comprehensive strategic account planning attributes including annual/multi-year objectives, revenue targets by service line, pipeline opportunities identified, relationship development goals, competitive threats, key sponsor stakeholders to engage, planned governance touchpoints, plan period, and plan status (draft, approved, active, closed). This is the top-level commercial relationship entity that anchors portfolio performance, governance cadence, business development strategy, and proactive account management.' .

ind:MasterAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsor ;
    rdfs:label 'Master Agreement' ;
    rdfs:comment 'Captures the terms and conditions of preferred provider or master service framework agreements between a sponsor and the CRO at the enterprise level, distinct from individual study contracts (which live in the agreement domain). Tracks agreement name, agreement type (MSA framework, preferred provider, FSP master agreement, alliance agreement), effective date, expiration date, auto-renewal flag, volume commitment tiers, preferred pricing terms, governance structure, and strategic partnership level. Provides the commercial framework under which individual study agreements are executed.' .

ind:RegulatoryStrategy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsor ;
    rdfs:label 'Regulatory Strategy' ;
    rdfs:comment 'Documents the regulatory strategy and submission pathway planned by a sponsor for a pipeline asset or study program. Captures target health authority (FDA, EMA, PMDA, MHRA, Health Canada), submission pathway (IND, NDA, BLA, MAA, 505(b)(2), biosimilar), regulatory designation sought (Fast Track, Breakthrough Therapy, Accelerated Approval, Priority Review, Orphan Drug), global harmonization approach (ICH CTD/eCTD), planned submission dates, pre-submission meeting history, and regulatory risk assessment. Enables CRO regulatory teams to align services with sponsor regulatory objectives.' .

ind:DeliveryPreference rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsor ;
    rdfs:label 'Delivery Preference' ;
    rdfs:comment 'Captures sponsor-specific operational preferences, standards, and requirements that govern how the CRO delivers services for that sponsor. Includes EDC system preference (Medidata Rave, Oracle Clinical One, other), eTMF platform preference (Veeva Vault, other), safety reporting system (Oracle Argus, other), CDISC standards version requirements (SDTM, ADaM), coding dictionary preferences (MedDRA version, WHO-DD version), data transfer format requirements, monitoring strategy preference (on-site, remote, hybrid, RBM), and reporting cadence requirements. Ensures CRO delivery is aligned with sponsor SOPs and system standards.' .

ind:Interaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsor ;
    rdfs:label 'Interaction' ;
    rdfs:comment 'Transactional record of all business interactions and touchpoints between CRO personnel and sponsor contacts, encompassing informal touchpoints, formal governance meetings (JSC, JOC, EBR, QBR), business reviews, bid defenses, and regulatory strategy calls. Captures interaction date, type (governance meeting, business review, proposal presentation, bid defense, regulatory strategy call, escalation call), participants from both sponsor and CRO sides, agenda items, decisions made, action items with owners and due dates, meeting cadence compliance, governance tier, meeting minutes reference, and interaction outcome. Provides a complete engagement history for relationship management, governance compliance, and account planning.' .

ind:ReviewMeeting rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsor ;
    rdfs:label 'Review Meeting' ;
    rdfs:comment 'Tracks formal governance meetings between sponsor and CRO organizations including Joint Steering Committee (JSC), Joint Operations Committee (JOC), Executive Business Reviews (EBR), and Quality Business Reviews (QBR). Captures meeting type, scheduled date, actual date, attendees (sponsor and CRO), agenda items, meeting minutes reference, decisions made, escalations raised, action items with owners and due dates, and meeting status (scheduled, completed, cancelled). Supports the formal governance cadence required under preferred provider and FSP agreements.' .

ind:BidRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsor ;
    rdfs:label 'Bid Request' ;
    rdfs:comment 'Captures sponsor requests for proposal (RFP) and bid requests submitted to the CRO for new study work. Tracks RFP reference number, sponsor name, study description, therapeutic area, indication, study phase, estimated subject count, site count, country scope, requested services (full-service, FSP, specific modules), RFP receipt date, bid defense date, proposal due date, bid status (received, in-progress, submitted, awarded, lost, no-bid), and competitive context. Drives the business development and proposal pipeline.' .

ind:Proposal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsor ;
    rdfs:label 'Proposal' ;
    rdfs:comment 'Master record for CRO proposals submitted in response to sponsor bid requests, including full line-item cost and scope detail. Captures proposal number, version, type (full-service, FSP, change order), submission date, total proposed budget, proposed timeline (FPI, LPO, DBL, CSR), team structure, key assumptions, exclusions, risk factors, win probability, status (draft, submitted, under review, awarded, lost, withdrawn), and award date. Contains granular line-item breakdown by service category (project management, monitoring, data management, biostatistics, regulatory, medical writing, laboratory, supply chain) with unit of measure, unit price, estimated quantity, total line amount, pass-through vs. direct cost flag, and line-level assumptions. Links to bid_request and drives contract execution.' .

ind:ProposalLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsor ;
    rdfs:label 'Proposal Line' ;
    rdfs:comment 'Line-item detail of a CRO proposal, capturing the granular cost and scope breakdown by service category. Each line captures service category (project management, clinical monitoring, data management, biostatistics, regulatory, medical writing, laboratory, supply chain), unit of measure, unit price, estimated quantity, total line amount, pass-through vs. direct cost flag, and assumptions specific to that line. Enables detailed budget negotiation and scope-of-work alignment with sponsors.' .

ind:Escalation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsor ;
    rdfs:label 'Escalation' ;
    rdfs:comment 'Tracks formal escalations raised by or to sponsor organizations during study execution. Captures escalation date, escalation type (quality issue, timeline delay, budget overrun, safety concern, resource issue, regulatory risk, relationship issue), severity level (critical, high, medium), description, sponsor contact who raised or received the escalation, CRO escalation owner, target resolution date, actual resolution date, resolution description, and escalation status (open, in-progress, resolved, closed). Provides an audit trail of sponsor-facing issues and their resolution.' .

ind:AccountPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsor ;
    rdfs:label 'Account Plan' ;
    rdfs:comment 'Strategic account plan developed by the CRO for key sponsor accounts, capturing the annual or multi-year relationship strategy. Tracks plan period, strategic objectives, revenue targets by service line, pipeline opportunities identified, relationship development goals, competitive threats, key sponsor stakeholders to engage, planned governance touchpoints, and plan status (draft, approved, active, closed). Drives proactive account management and business development activities for strategic sponsor relationships.' .

ind:Submission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Submission' ;
    rdfs:comment 'Master record for regulatory submissions and eCTD sequences sent to health authorities (FDA, EMA, PMDA, MHRA, Health Canada). Each record represents a discrete submission event with sequence number, submission type (original, amendment, supplement, response, withdrawal), eCTD lifecycle operation (new, replace, append, delete), CTD module scope, submission category, regulatory procedure type, submission date, target agency, validation status, dossier format (eCTD/NeeS/paper), and submission reason. Enables granular tracking of dossier evolution over time. SSOT for all regulatory submission events managed via Veeva Vault.' .

ind:Application rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Application' ;
    rdfs:comment 'Master record for regulatory applications (IND, NDA, BLA, MAA, CTA, IMPD) filed with health authorities. Tracks application number, application type and subtype, therapeutic area, indication, sponsor reference, lead agency, application status (active, approved, withdrawn, refused), initial filing date, approval date, lifecycle phase, and type-specific attributes including IND number/type/annual report dates for investigational applications and PDUFA goal date/priority review/breakthrough therapy/orphan drug designations for marketing applications. Parent entity for all submissions, correspondence, approvals, and commitments under a given regulatory dossier. SSOT for the complete regulatory application lifecycle.' .

ind:HealthAuthority rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Health Authority' ;
    rdfs:comment 'Reference master for global health authority organizations (FDA, EMA, PMDA, MHRA, Health Canada, TGA, ANVISA, NMPA, etc.). Stores agency code, full name, country/region, regulatory framework, submission portal URL, eCTD gateway identifier, contact division, applicable regulatory procedures, and fee schedules. Used as a foreign key lookup across all submission, application, correspondence, and authorization records in the regulatory domain.' .

ind:SubmissionSequence rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Submission Sequence' ;
    rdfs:comment 'Tracks individual eCTD submission sequences within a regulatory application. Each sequence has a sequence number, submission type (original, amendment, supplement, response, withdrawal), sequence date, eCTD lifecycle operation (new, replace, append, delete), CTD module scope, submission reason, and validation status (eCTD technical validation result). Enables granular tracking of dossier evolution over time.' .

ind:RegulatoryProtocolAmendment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Regulatory Protocol Amendment' ;
    rdfs:comment 'Tracks protocol amendments submitted to health authorities and ethics committees. Captures amendment number, amendment type (substantial/non-substantial), amendment rationale, affected study sections, submission date to each agency, agency acknowledgment date, approval date, implementation date, and impact on ongoing subjects. Links to the parent application and study protocol. Managed via Veeva Vault regulatory binder.' .

ind:Correspondence rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Correspondence' ;
    rdfs:comment 'Records all formal communications between the sponsor/CRO and health authorities. Includes correspondence type (information request, complete response letter, refuse-to-file, meeting minutes, agency query, label negotiation), direction (inbound/outbound), agency reference number, correspondence date, response due date, response date, subject matter, and associated submission or application. Supports inspection readiness and regulatory intelligence.' .

ind:AgencyMeeting rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Agency Meeting' ;
    rdfs:comment 'Master record for formal meetings with health authorities (FDA Type A/B/C meetings, EMA scientific advice, PMDA consultations). Tracks meeting type, request date, agency-confirmed date, meeting format (face-to-face, teleconference, written response), meeting objectives, briefing document submission date, meeting minutes finalization date, and action items arising. Critical for regulatory strategy planning.' .

ind:CtdDossier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Ctd Dossier' ;
    rdfs:comment 'Master record for the Common Technical Document (CTD) dossier structure and content inventory associated with a regulatory application. Tracks CTD format (eCTD/NeeS/paper), dossier version, completeness status, module-level readiness (Modules 1-5), last compiled date, validation report status, publishing tool used, and archival location in Veeva Vault. Also manages individual content units (documents, datasets, study reports) with CTD section references (e.g., Module 2.7.3, Module 5.3.5.1), document metadata, file format, lifecycle operations, and Veeva Vault document IDs. Serves as the structural backbone for all submission content and enables dossier gap analysis.' .

ind:Approval rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Approval' ;
    rdfs:comment 'Records regulatory approvals, authorizations, and decisions received from health authorities. Captures approval type (IND allowance, NDA approval, MAA approval, CTA authorization, label approval), approval date, effective date, approved indication, approved population, conditions of approval, post-marketing commitments, approval letter reference, and agency decision rationale. SSOT for all positive regulatory decisions.' .

ind:IndApplication rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Ind Application' ;
    rdfs:comment 'Specialized master record for Investigational New Drug (IND) applications filed with the FDA (or equivalent CTAs with EMA/MHRA). Tracks IND number, IND type (commercial, research, emergency), sponsor name, investigational product name, phase coverage, initial IND submission date, IND status (active, inactive, withdrawn), annual report due dates, safety reporting obligations, and cross-reference to the parent application record.' .

ind:NdaBlaApplication rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Nda Bla Application' ;
    rdfs:comment 'Specialized master record for New Drug Applications (NDA), Biologics License Applications (BLA), and equivalent marketing authorization applications (MAA). Tracks application number, application type (NDA/BLA/MAA/sNDA/sBLA), PDUFA goal date, priority review designation, breakthrough therapy designation, orphan drug designation, rolling review status, advisory committee meeting date, and approval pathway.' .

ind:RegulatoryMilestone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Regulatory Milestone' ;
    rdfs:comment 'Tracks key regulatory milestones and planned vs. actual dates for each application and submission. Includes milestone type (IND filing, Phase I start, Phase III start, NDA submission, PDUFA date, approval, label finalization), planned date, actual date, milestone status, variance in days, responsible regulatory lead, and dependency on upstream milestones. Enables regulatory timeline management and scenario planning.' .

ind:LabelingDocument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Labeling Document' ;
    rdfs:comment 'Manages investigational and approved product labeling documents including Investigator Brochure (IB), Package Insert (PI/SmPC), Patient Information Leaflet (PIL), and Reference Safety Information (RSI). Tracks document type, version number, effective date, superseded date, language, market/region applicability, approval status, and Veeva Vault document ID. SSOT for product labeling lifecycle within the regulatory domain.' .

ind:SafetyReportSubmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Safety Report Submission' ;
    rdfs:comment 'Tracks regulatory safety report submissions including IND Annual Reports, Development Safety Update Reports (DSURs), Periodic Safety Update Reports (PSURs/PBRERs), and expedited SUSAR/IND safety reports. Captures report type, reporting period, submission due date, actual submission date, agency acknowledgment, report version, and link to the source safety data. Distinct from individual AE/SAE records owned by the safety domain.' .

ind:ClinicalTrialAuthorization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Clinical Trial Authorization' ;
    rdfs:comment 'Master record for Clinical Trial Authorizations (CTAs) issued by national competent authorities under EU CTR 536/2014, national regulations, and equivalent non-US frameworks. Tracks CTA reference number, member state, competent authority, trial phase, authorization date, expiry date, conditions attached, substantial modification history, and current authorization status. Complements IND records for non-US regulatory coverage and enables multi-country trial authorization tracking across EU CTIS and national portals.' .

ind:Strategy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Strategy' ;
    rdfs:comment 'Documents the regulatory strategy plan for a development program or individual study. Captures target indication, development phase, global regulatory pathway (standard, accelerated, adaptive), key agency interactions planned, submission sequence strategy, risk assessment, regulatory precedents, competitive landscape notes, strategy version, approval date of strategy, and responsible regulatory affairs lead. Supports long-range regulatory planning.' .

ind:RegulatoryInspection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Regulatory Inspection' ;
    rdfs:comment 'Tracks regulatory inspection readiness activities and inspection events for studies and sites. Captures inspection type (GCP, GMP, GLP, pharmacovigilance), inspecting authority, inspection scope (study, site, sponsor), scheduled date, actual date, inspection outcome (satisfactory, voluntary action indicated, official action indicated), critical/major/minor findings count, CAPA linkage, and inspection report receipt date. Supports proactive inspection preparation.' .

ind:Commitment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Commitment' ;
    rdfs:comment 'Tracks post-approval regulatory commitments and post-marketing requirements imposed by health authorities as conditions of approval. Captures commitment type (post-marketing study, label update, REMS, risk minimization measure), commitment description, due date, completion date, status (pending, in progress, fulfilled, overdue), agency-assigned commitment number, and reporting frequency. Ensures compliance with approval conditions.' .

ind:SpecialDesignation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Special Designation' ;
    rdfs:comment 'Tracks special regulatory designations granted to investigational products by health authorities. Includes designation type (Breakthrough Therapy, Fast Track, Accelerated Approval, Priority Review, Orphan Drug, PRIME, Adaptive Pathways, SAKIGAKE), granting agency, request date, grant date, expiry date, designation conditions, and associated application. Enables tracking of expedited development pathways and associated obligations.' .

ind:RegulatoryActionItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Regulatory Action Item' ;
    rdfs:comment 'Tracks action items arising from agency meetings, correspondence, inspection findings, and internal regulatory reviews. Captures action item description, source event (meeting, inspection, correspondence), assigned owner, due date, completion date, priority level, status (open, in progress, closed, overdue), and escalation flag. Provides an operational task register for the regulatory affairs team.' .

ind:CountryRegistration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Country Registration' ;
    rdfs:comment 'Tracks product registration status and requirements across individual countries and jurisdictions. Captures country, registration number, registration type (national, mutual recognition, decentralized, centralized), registration date, expiry date, renewal due date, local agent name, registered indication, registered dosage form, and current registration status. Supports global regulatory intelligence and market access planning.' .

ind:Procedure rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Procedure' ;
    rdfs:comment 'Reference data defining regulatory procedures and pathways available across health authorities. Captures procedure type (centralized, decentralized, mutual recognition, national, abbreviated, hybrid), applicable agency, procedure code, standard review timeline (days), expedited review timeline, applicable product types, and procedural requirements. Used to classify submissions and plan timelines.' .

ind:SubmissionContentUnit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Submission Content Unit' ;
    rdfs:comment 'Tracks individual content units (documents, datasets, study reports) included within a CTD/eCTD submission sequence. Captures CTD section reference (e.g., Module 2.7.3, Module 5.3.5.1), document title, document type, document version, file format, file size, checksum, lifecycle operation (new/replace/append/delete), and Veeva Vault document ID. Enables granular dossier content management and gap analysis.' .

ind:RemsProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Rems Program' ;
    rdfs:comment 'Manages Risk Evaluation and Mitigation Strategy (REMS) programs required by FDA as a condition of approval for certain high-risk products. Tracks REMS program name, product covered, REMS elements (medication guide, communication plan, ETASU), program approval date, assessment schedule, assessment submission dates, enrollment numbers, and compliance metrics. Equivalent EU risk minimization measures are also captured.' .

ind:Intelligence rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Intelligence' ;
    rdfs:comment 'Captures regulatory intelligence records tracking changes in health authority guidelines, regulations, and policies that may impact ongoing or planned submissions. Includes intelligence source (agency website, Federal Register, EMA news, industry publication), publication date, effective date, impacted therapeutic area, impacted submission types, assessment of impact on portfolio, and recommended actions. Supports proactive regulatory strategy adaptation.' .

ind:Protocol rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Study ;
    rdfs:label 'Protocol' ;
    rdfs:comment 'Master record for the clinical study protocol including all formal amendments (version history). Captures protocol number, version, title, phase, therapeutic area, indication, investigational product, study design parameters (allocation method, intervention model, masking details, primary purpose, number of arms, adaptive design flags), primary/secondary objectives summary, study population description, planned sample size, study duration, sponsor reference, IND/CTA number, protocol status (draft, approved, amended, final), amendment history (amendment number, date, type, rationale, regulatory submission status, IRB/IEC notification, impact assessment), and GCP/ICH compliance declarations. SSOT for protocol identity, design parameters, and amendment lifecycle. Sourced from Oracle Clinical One and Veeva Vault.' .

ind:StudyProtocolAmendment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Study ;
    rdfs:label 'Study Protocol Amendment' ;
    rdfs:comment 'Tracks all formal amendments to an approved clinical study protocol. Records amendment number, amendment date, amendment type (substantial/non-substantial), description of changes, rationale, regulatory submission status per health authority (FDA, EMA, PMDA), IRB/IEC notification status, effective date, and impact assessment on ongoing subjects. Supports the protocol lifecycle from initial approval through database lock. Sourced from Oracle Clinical One and Veeva Vault.' .

ind:Study rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Study ;
    rdfs:label 'Study Study' ;
    rdfs:comment 'Top-level master entity representing a clinical trial as a business and operational unit. Captures the unique study identifier (sponsor study number, ClinicalTrials.gov NCT number, EudraCT number), study title, acronym, therapeutic area, indication, development phase, study type (interventional/observational), blinding type, randomization flag, study status with full lifecycle history (planned, startup, active, on-hold, completed, terminated), planned and actual start/end dates, target enrollment, closure details (DBL date, CSR submission, TMF archival), sponsor reference, and CRO assignment. SSOT for study identity and lifecycle state across all domains. Sourced from Oracle Siebel CTMS.' .

ind:Arm rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Study ;
    rdfs:label 'Arm' ;
    rdfs:comment 'Defines each treatment arm or cohort within a clinical study. Records arm name, arm code, arm type (experimental, active comparator, placebo comparator, sham comparator, no intervention, other), description of intervention, planned number of subjects per arm, randomization ratio, arm status, and CDISC SDTM ARM domain mapping. Supports multi-arm and adaptive trial designs. Sourced from Oracle Clinical One.' .

ind:Endpoint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Study ;
    rdfs:label 'Endpoint' ;
    rdfs:comment 'Defines the formal objectives and their associated endpoints (primary, secondary, exploratory) for a clinical study. Captures objective text, objective type, endpoint name, endpoint type (primary, secondary, exploratory, safety, PK, PD, biomarker), endpoint category (efficacy, safety, tolerability, PK/PD, quality of life), measurement instrument or scale, timepoint of assessment, statistical hypothesis (superiority, non-inferiority, equivalence), estimand definition per ICH E9(R1), objective-to-endpoint traceability, and CDISC ADaM parameter mapping. Provides the scientific rationale chain from objective through endpoint to SAP. Directly referenced by the biostatistics domain for analysis planning.' .

ind:EligibilityCriterion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Study ;
    rdfs:label 'Eligibility Criterion' ;
    rdfs:comment 'Defines inclusion and exclusion criteria for subject enrollment in a clinical study. Records criterion number, criterion type (inclusion/exclusion), criterion text, criterion category (demographic, diagnosis, lab value, prior therapy, concomitant medication, reproductive status, other), protocol version applicability, amendment-driven change flag, CDISC SDTM IE domain mapping, and operational screening guidance notes. Authoritative source for site screening checklists and EDC eligibility modules.' .

ind:StudyVisitSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Study ;
    rdfs:label 'Study Visit Schedule' ;
    rdfs:comment 'Defines the planned Schedule of Events (SoE) for a clinical study including all visits and their required procedures. Captures visit name, visit number, visit type (screening, baseline, treatment, follow-up, unscheduled, end-of-study), planned study day/week, visit window tolerances, epoch association, and for each visit the specific procedures/assessments required (vital signs, lab draws, ECG, imaging, questionnaires, dosing, PK sampling, physical exam) with mandatory/optional flags, CDISC SDTM domain mappings, and eCRF form references. This is the master template for site operations, subject visit planning, and EDC configuration. Sourced from Oracle Clinical One and Medidata Rave.' .

ind:VisitProcedure rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Study ;
    rdfs:label 'Visit Procedure' ;
    rdfs:comment 'Defines the specific clinical procedures, assessments, and data collection activities required at each scheduled visit. Records procedure name, procedure category (vital signs, lab draw, ECG, imaging, questionnaire, dosing, PK sampling, physical exam, biopsy, ECOG assessment), visit association, whether the procedure is mandatory or optional, CDISC SDTM domain mapping for the procedure, and eCRF form reference in Medidata Rave. Enables the Schedule of Events matrix construction.' .

ind:Epoch rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Study ;
    rdfs:label 'Epoch' ;
    rdfs:comment 'Defines the temporal epochs (periods) of a clinical study such as Screening, Run-in, Treatment Period 1, Washout, Treatment Period 2, Follow-up, and Extension. Captures epoch name, epoch short name, epoch sequence number, epoch type, planned duration, and CDISC SDTM TE domain mapping. Epochs provide the temporal framework for visit scheduling, subject disposition, and SDTM dataset construction.' .

ind:StudyMilestone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Study ;
    rdfs:label 'Study Milestone' ;
    rdfs:comment 'Tracks key operational and regulatory milestones in the study lifecycle. Records milestone name, milestone type (protocol approval, first site activation, FPFV, LPLV, DBL, CSR submission, study close-out, regulatory submission, enrollment milestones), planned date, actual date, milestone status (pending, achieved, delayed, waived), responsible party, variance reason, and critical path flag. Supports CTMS timeline tracking, sponsor reporting, and study performance analytics in Oracle Siebel CTMS.' .

ind:Country rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Study ;
    rdfs:label 'Country' ;
    rdfs:comment 'Manages the countries in which a clinical study is conducted including country-level enrollment planning. Records country code (ISO 3166), country name, regulatory authority, CTA/IND submission and approval dates, approval status, first site activation date, planned and actual number of sites, planned and actual enrollment targets per country, enrollment rate assumptions, screen failure rate assumptions, country-level enrollment status, and regulatory hold flags. Supports global regulatory planning, enrollment forecasting, and country-level feasibility assessment.' .

ind:InvestigationalProduct rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Study ;
    rdfs:label 'Investigational Product' ;
    rdfs:comment 'Master record for the investigational medicinal product (IMP) or device used in a clinical study. Captures IMP name, INN (International Nonproprietary Name), drug code, formulation, dosage form, route of administration, strength, manufacturer, IND/IMPD reference number, ATC code, WHO-DD drug code, mechanism of action, therapeutic class, storage conditions, and shelf life. SSOT for IMP identity referenced by supply chain, safety, and data management domains.' .

ind:DosingRegimen rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Study ;
    rdfs:label 'Dosing Regimen' ;
    rdfs:comment 'Defines the dosing regimen for each investigational product within a study arm. Records regimen name, dose level, dose unit, dosing frequency, dosing route, dosing duration, dose escalation scheme (for dose-escalation studies), dose modification rules, maximum tolerated dose (MTD) flag, and CDISC SDTM EX (Exposure) domain mapping. Supports PK/PD modeling and safety dose-response analysis.' .

ind:Objective rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Study ;
    rdfs:label 'Objective' ;
    rdfs:comment 'Formally documents the primary, secondary, and exploratory objectives of a clinical study as stated in the protocol. Captures objective number, objective type (primary, secondary, exploratory), objective text, associated endpoint references, ICH E9(R1) estimand linkage, and protocol version in which the objective was introduced or modified. Provides the scientific rationale traceability from objective to endpoint to SAP.' .

ind:PkSamplingSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Study ;
    rdfs:label 'Pk Sampling Schedule' ;
    rdfs:comment 'Defines the pharmacokinetic (PK) and pharmacodynamic (PD) blood/urine/tissue sampling schedule for a clinical study. Records sample type, nominal sampling timepoint (pre-dose, 0.5h, 1h, 2h, 4h, 8h, 24h post-dose, etc.), sampling window, visit association, analyte to be measured, bioanalytical method reference, sample volume, sample handling instructions, and CDISC SDTM PC (Pharmacokinetics Concentrations) domain mapping. Critical for DMPK studies.' .

ind:EcrfForm rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Data ;
    rdfs:label 'Ecrf Form' ;
    rdfs:comment 'Master definition of Electronic Case Report Form (eCRF) designs built in Medidata Rave EDC. Captures form name, version, study association, form type (visit-based, unscheduled, log/repeating), completion rules, CDISC SDTM domain mapping, data entry mode (single/double entry), and activation status. Each form contains one or more ecrf_fields and is deployed via an edc_study_build. Serves as the authoritative catalog of all eCRF instruments deployed across studies.' .

ind:EcrfField rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Data ;
    rdfs:label 'Ecrf Field' ;
    rdfs:comment 'Master definition of individual data fields within eCRF forms in Medidata Rave. Captures field name, label, data type (text, numeric, date, codelist), CDISC variable mapping (SDTM variable, domain), validation rules, required flag, controlled terminology binding, and field-level audit configuration. Supports ALCOA+ compliance at the field level.' .

ind:SubjectVisitData rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Data ;
    rdfs:label 'Subject Visit Data' ;
    rdfs:comment 'Transactional record of all eCRF data collected for a subject at a specific study visit in Medidata Rave. Captures subject identifier, visit name/number, visit date, form completion status (incomplete, complete, frozen, locked), data completeness percentage, missing data flags, data entry timestamp, entered-by user, source data verification (SDV) status, and lock status. Represents the primary unit of clinical data collection linking subjects to their visit-level form submissions. Completion status subsumes missing data tracking previously handled separately.' .

ind:FieldEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Data ;
    rdfs:label 'Field Entry' ;
    rdfs:comment 'Atomic-level transactional record capturing a single field-level data entry in the EDC system (Medidata Rave). Stores the field value, entry timestamp, entered-by user, reason for change, previous value, audit trail reference, and ALCOA+ compliance flags (attributable, legible, contemporaneous, original, accurate). Supports full audit trail and source data verification (SDV) requirements.' .

ind:DiscrepancyQuery rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Data ;
    rdfs:label 'Discrepancy Query' ;
    rdfs:comment 'Transactional record of ALL data queries (discrepancies) raised against eCRF data entries in Medidata Rave, serving as the single source of truth for data quality issues regardless of origin. Captures query text, query type (manual CRA-raised, system-generated from edit checks, review-originated from medical/data review, reconciliation-originated from external data comparison), raised-by user, raised date, assigned-to site/user, response text, resolution status (open, answered, closed, cancelled), resolution date, query category, and escalation flag. Central to the data cleaning and discrepancy resolution workflow; all data quality findings from any source are consolidated here.' .

ind:ValidationRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Data ;
    rdfs:label 'Validation Rule' ;
    rdfs:comment 'Master definition of programmatic data validation rules (edit checks) configured in Medidata Rave EDC. Captures rule name, rule expression/logic, trigger condition, associated form and field, severity level (error, warning), rule category (range check, cross-form, date logic, required field), CDISC compliance flag, activation status, and version history. Governs automated query generation.' .

ind:Dmp rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Data ;
    rdfs:label 'Dmp' ;
    rdfs:comment 'Master record for the Data Management Plan (DMP) governing all data management activities for a clinical study. Captures DMP version, effective date, study phase, EDC system configuration, data collection strategy, coding dictionaries and versions (MedDRA, WHO-DD), database lock criteria and procedures, data review plan, query management conventions, external data transfer specifications, responsible data manager, and approval status. Serves as the single authoritative governance document referenced by all data management operations on a study.' .

ind:CodingAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Data ;
    rdfs:label 'Coding Assignment' ;
    rdfs:comment 'Transactional record of medical coding assignments applied to verbatim terms collected in eCRFs. Captures verbatim term, coding dictionary (MedDRA or WHO-DD), dictionary version, assigned code, preferred term (PT), system organ class (SOC), lowest level term (LLT), coding method (autocoding, manual), coder user ID, coding date, approval status, and coding flag. Supports regulatory-grade medical coding workflows.' .

ind:SdtmDataset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Data ;
    rdfs:label 'Sdtm Dataset' ;
    rdfs:comment 'Master record for CDISC SDTM (Study Data Tabulation Model) dataset definitions and their submission-ready outputs. Captures dataset name (e.g., AE, CM, DM, LB, VS), SDTM domain class (Events, Interventions, Findings), SDTM IG version, study identifier, submission version, generation date, record count, Pinnacle 21 validation status, define.xml reference, submission-ready flag, and responsible programmer. Each dataset contains one or more sdtm_mapping records that define the source-to-target transformation rules. Serves as the header record governing CDISC dataset generation and regulatory submission packaging.' .

ind:SdtmMapping rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Data ;
    rdfs:label 'Sdtm Mapping' ;
    rdfs:comment 'Detail-level record defining a single source-to-target transformation rule between a raw EDC eCRF field and a CDISC SDTM variable within a parent sdtm_dataset. Captures source form, source field, target SDTM domain, target variable name, transformation logic/derivation rule (including multi-source derivations), controlled terminology mapping, predecessor derivation dependencies, mapping version, validation status, and responsible programmer. Represents one variable-level mapping within the complete dataset specification. Supports reproducible, auditable, and version-controlled CDISC data transformation.' .

ind:ExternalTransfer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Data ;
    rdfs:label 'External Transfer' ;
    rdfs:comment 'Transactional record of external data transfers into or out of the clinical database, including central lab results (LabCorp, Covance), PK/PD concentration data, ePRO/eCOA data, ECG data, medical imaging, and wearable/device data. Captures transfer direction (inbound/outbound), source system, target system, transfer date, file format (SAS XPT, CSV, HL7), record count, validation status, reconciliation status, responsible data manager, and transfer specification reference. Governs third-party data integration and ensures all external data is traceable and reconciled.' .

ind:EdcStudyBuild rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Data ;
    rdfs:label 'Edc Study Build' ;
    rdfs:comment 'Master record for the EDC study build configuration in Medidata Rave. Captures study build version, build environment (development, UAT, production), build owner, build date, UAT completion status, go-live date, protocol version linked, amendment history, and build approval sign-off. Governs the lifecycle of the EDC system configuration for each study.' .

ind:Reconciliation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Data ;
    rdfs:label 'Reconciliation' ;
    rdfs:comment 'Transactional record of reconciliation activities performed between EDC data and external data sources (central lab, safety database, IRT/RTSM, ePRO). Captures reconciliation type, source system, target system, reconciliation date, discrepancy count, resolved count, outstanding count, responsible data manager, and reconciliation sign-off status. Ensures cross-system data consistency prior to database lock.' .

ind:AlcoaAuditEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Data ;
    rdfs:label 'Alcoa Audit Entry' ;
    rdfs:comment 'Transactional record capturing ALCOA+ compliance audit trail entries for every clinical data change in the EDC system. Captures original value, new value, change reason (protocol-specified categories), change timestamp (system-generated, non-editable), user identifier, user role, electronic signature reference, and ALCOA+ attribute compliance flags (Attributable, Legible, Contemporaneous, Original, Accurate, Complete, Consistent, Enduring, Available). Immutable once written. Supports 21 CFR Part 11 electronic records requirements and ICH E6(R2) GCP audit trail mandates.' .

ind:LabPanel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Laboratory ;
    rdfs:label 'Lab Panel' ;
    rdfs:comment 'Master definition of a laboratory test panel or battery used in clinical trials. Captures panel code, name, specimen type requirements, analyte list, applicable study phases, CDISC SDTM domain mapping (LB), turnaround time SLA, and whether the panel is central or local lab. Serves as the catalog of all lab assessments available for protocol inclusion.' .

ind:LabFacility rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Laboratory ;
    rdfs:label 'Lab Facility' ;
    rdfs:comment 'Master record for central and local laboratory facilities performing specimen analysis for clinical trials. Captures facility name, type (central/local/bioanalytical/PK), CLIA/CAP/ISO 15189 accreditation status, accreditation expiry, regulatory certifications, geographic location, contact details, LIMS system identifier, and operational status. SSOT for lab facility identity and certification.' .

ind:Specimen rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Laboratory ;
    rdfs:label 'Specimen' ;
    rdfs:comment 'Master record for each biological specimen collected from a trial subject, including collection event details. Captures specimen barcode/ID, subject ID, visit reference, collection date/time, specimen type (blood, urine, CSF, tissue), collection tube type, volume collected, collector ID, collection site (body location), collection method, collection kit lot, pre-analytical processing performed, collection deviations, primary/aliquot flag, parent specimen reference, receipt status, condition on arrival, LIMS accession number, and current disposition status. SSOT for specimen identity, collection event, receipt, and chain of custody.' .

ind:LabResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Laboratory ;
    rdfs:label 'Lab Result' ;
    rdfs:comment 'Transactional record of a laboratory test result for a specific analyte from a subject specimen. Captures analyte name, LOINC code, result value, result unit, normal range lower/upper bound, reference range source, result status (preliminary/final/corrected/cancelled), out-of-range flag, critical value flag, CTCAE grade, CDISC SDTM LBTESTCD/LBTEST mapping, and reporting lab. Core entity for clinical data review, safety monitoring, and SDTM LB dataset generation.' .

ind:SpecimenCollection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Laboratory ;
    rdfs:label 'Specimen Collection' ;
    rdfs:comment 'Transactional record of a scheduled or unscheduled specimen collection event at a clinical site or subject visit. Captures collection event date/time, study visit reference, protocol-scheduled vs. unscheduled flag, collector ID (CRC/phlebotomist), collection kit lot number, number of tubes/containers collected, collection deviations, and pre-analytical processing instructions followed. Links specimen collection to the study visit schedule.' .

ind:SpecimenShipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Laboratory ;
    rdfs:label 'Specimen Shipment' ;
    rdfs:comment 'Transactional record tracking the shipment of specimens from a clinical site to a central or reference laboratory. Captures shipment manifest ID, origin site, destination lab facility, courier name, tracking number, shipment date/time, expected arrival date, actual receipt date, temperature condition (ambient/refrigerated/frozen/dry ice), number of specimens, shipment status, and any temperature excursion flags. Supports chain of custody and specimen integrity tracking.' .

ind:ReferenceRange rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Laboratory ;
    rdfs:label 'Reference Range' ;
    rdfs:comment 'Master definition of laboratory reference ranges (normal ranges) for analytes, with full version history. Captures analyte/LOINC code, lower and upper normal limits, unit of measure, sex, age range, ethnicity applicability, specimen type, lab facility source, effective date range, version number, prior range values, reason for update (instrument change/reagent lot change/population recalibration), approval status, and whether the range is sponsor-defined or lab-standard. Used for out-of-range flagging and CTCAE grading in lab results. Maintains audit trail for reference range changes per GCP and regulatory requirements.' .

ind:CriticalValue rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Laboratory ;
    rdfs:label 'Critical Value' ;
    rdfs:comment 'Reference master defining critical (panic) value thresholds for laboratory analytes that require immediate clinical notification. Captures analyte, LOINC code, critical low threshold, critical high threshold, unit, notification SLA (minutes), escalation pathway, and lab facility applicability. Drives automated critical value alerting workflows and safety reporting integration with Oracle Argus Safety.' .

ind:PkSample rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Laboratory ;
    rdfs:label 'Pk Sample' ;
    rdfs:comment 'Master record for pharmacokinetic (PK) and pharmacodynamic (PD) samples collected per the study PK sampling schedule. Captures nominal and actual collection time relative to dose (pre-dose, post-dose hours), dose number, PK sampling window compliance, sample type (plasma/serum/whole blood/urine), volume collected, and DMPK assay assignment. Distinct from routine lab specimens due to time-critical nominal time point tracking required for PK analysis.' .

ind:BioanalyticalAssay rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Laboratory ;
    rdfs:label 'Bioanalytical Assay' ;
    rdfs:comment 'Master definition of a validated bioanalytical assay used to quantify drug concentrations, biomarkers, or immunogenicity in clinical trial samples. Captures assay name, analyte measured, assay type (LC-MS/MS, ELISA, ECL, PCR, flow cytometry), validation status (validated/qualified/exploratory), LLOQ, ULOQ, matrix type, regulatory submission reference, and responsible bioanalytical lab. Supports DMPK and PK/PD data generation.' .

ind:BioanalyticalResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Laboratory ;
    rdfs:label 'Bioanalytical Result' ;
    rdfs:comment 'Transactional record of a bioanalytical or biomarker assay result from a clinical trial PK/PD, DMPK, or exploratory biomarker sample. Captures assay run ID, sample ID, analyte/biomarker measured, concentration or categorical result value, unit/scale, assay platform (LC-MS/MS/ELISA/ECL/PCR/flow cytometry/NGS/IHC), calibration curve acceptance, QC sample performance, result status (reportable/non-reportable/repeat required), result category (PK concentration/biomarker/immunogenicity/exploratory), incurred sample reanalysis (ISR) flag, deviation from nominal time point, and data sharing consent flag. Feeds CDISC SDTM PC and PP domains. Consolidated SSOT for all specialized assay results beyond routine clinical lab testing.' .

ind:LabAccreditation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Laboratory ;
    rdfs:label 'Lab Accreditation' ;
    rdfs:comment 'Master record tracking laboratory facility accreditation and certification status. Captures accreditation body (CAP, CLIA, ISO 15189, UKAS, DAkkS), certificate number, accreditation scope (test menu), issue date, expiry date, renewal status, inspection date, findings summary, and corrective action status. Ensures only qualified labs are used in regulated clinical trials and supports regulatory submission documentation.' .

ind:LabKit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Laboratory ;
    rdfs:label 'Lab Kit' ;
    rdfs:comment 'Master record for laboratory collection kits supplied to clinical sites for specimen collection. Captures kit type, kit lot number, components list (tubes, containers, preservatives, requisition forms), storage requirements, expiry date, kit version, and associated lab panel. Supports kit inventory management at sites and ensures correct collection materials are used per protocol.' .

ind:LabQuery rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Laboratory ;
    rdfs:label 'Lab Query' ;
    rdfs:comment 'Transactional record of a data query raised against a laboratory result in the EDC (Medidata Rave) or LIMS. Captures query ID, query type (missing value/implausible result/unit mismatch/collection time deviation), query text, raised by (data manager/medical monitor), raised date, assigned to (site/lab), response text, resolution date, and query status (open/answered/closed/cancelled). Supports ALCOA+ data quality compliance for lab data.' .

ind:SpecimenAliquot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Laboratory ;
    rdfs:label 'Specimen Aliquot' ;
    rdfs:comment 'Master record for aliquots derived from a primary specimen for distribution to multiple testing labs or long-term storage, including storage placement tracking. Captures parent specimen ID, aliquot sequence number, volume, container type, storage unit (freezer/refrigerator/LN2 tank), rack/box/position coordinates, storage temperature, freeze-thaw cycle count, aliquot purpose (clinical testing/PK/biomarker/backup/archive), storage event history (placement/transfer/retrieval/destruction), and current status. Supports biorepository management, chain of custody, and long-term sample accountability.' .

ind:ProtocolLabSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Laboratory ;
    rdfs:label 'Protocol Lab Schedule' ;
    rdfs:comment 'Master definition of the protocol-mandated laboratory assessment schedule for a study, mapping each study visit to required lab panels. Captures study ID, visit name/number, visit window (day range), required lab panels, optional panels, fasting requirement, time-of-day constraints, and applicable subject populations (all subjects/subset/PK cohort). Drives specimen collection planning and EDC eCRF lab page configuration in Medidata Rave.' .

ind:LabCertification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Laboratory ;
    rdfs:label 'Lab Certification' ;
    rdfs:comment 'Reference master for laboratory regulatory certifications and qualifications required for clinical trial participation. Captures certification type (GLP, GCP lab qualification, CAP proficiency, CLIA specialty, EQA scheme participation), issuing authority, certificate number, scope, issue date, expiry date, and renewal workflow status. Distinct from accreditation (which covers facility-level quality systems) — certifications cover specific test competencies and regulatory compliance programs.' .

ind:LabAnalyte rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Laboratory ;
    rdfs:label 'Lab Analyte' ;
    rdfs:comment 'Reference master for individual laboratory analytes (measurable substances or properties) used across all lab panels and assays. Captures analyte name, LOINC code, MedDRA PT mapping, CDISC LBTESTCD/LBTEST standardized code and label, default unit of measure, specimen type compatibility, analyte category (hematology/chemistry/coagulation/urinalysis/immunology/PK/biomarker), and SDTM domain assignment. Serves as the controlled vocabulary for analyte standardization across the enterprise.' .

ind:TrialSubject rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subject ;
    rdfs:label 'Trial Subject' ;
    rdfs:comment 'Core master entity representing a unique trial participant (subject/patient) screened or enrolled in a clinical study. Serves as the SSOT for subject identity including screening number, subject number, randomization number, demographic profile (age, sex, race, ethnicity, date of birth, country), key eligibility flags, and current enrollment status. All subject-level transactional records in this domain reference this entity. Sourced from Oracle Clinical One and Medidata Rave EDC.' .

ind:Enrollment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subject ;
    rdfs:label 'Enrollment' ;
    rdfs:comment 'Transactional record capturing the formal enrollment event of a subject into a clinical study at a specific investigational site. Tracks screening date, enrollment date, randomization eligibility confirmation, enrollment status (screened, enrolled, randomized, withdrawn, completed), and the site and study context. Represents the lifecycle milestone from first contact through study entry. Sourced from Oracle Siebel CTMS and Oracle Clinical One.' .

ind:RandomizationAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subject ;
    rdfs:label 'Randomization Assignment' ;
    rdfs:comment 'Transactional record of a subject\'s randomization event, capturing the randomization code, treatment arm assignment, stratification factor values applied at randomization, randomization date and time, IRT/RTSM transaction reference, blinding status, and kit number assigned. Represents the authoritative allocation record produced by the RTSM system (Medidata Rave RTSM / Oracle Clinical One IRT). Distinct from the randomization scheme design owned by the randomization domain.' .

ind:SubjectVisit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subject ;
    rdfs:label 'Subject Visit' ;
    rdfs:comment 'Transactional record of each scheduled or unscheduled study visit performed by (or missed by) a subject, capturing visit name, visit code, planned visit date per schedule, actual visit date, visit window compliance status (early, within window, late, missed), visit type (screening, baseline, treatment, follow-up, unscheduled, early termination, end-of-study), investigational site where visit occurred, visit duration, and visit completion status. Serves as the backbone for visit compliance tracking, monitoring trigger logic, and SDTM SV domain generation. Sourced from Medidata Rave EDC and Oracle Siebel CTMS.' .

ind:SubjectDeviation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subject ;
    rdfs:label 'Subject Deviation' ;
    rdfs:comment 'Transactional record of a protocol deviation identified for a subject, capturing deviation category (major, minor, important), deviation type code, description, date of occurrence, date identified, root cause, impact on subject safety and data integrity, corrective action taken, CAPA reference, and regulatory reportability flag. Tracks deviations from the approved protocol per ICH E6(R2) GCP requirements. Sourced from Oracle Siebel CTMS and MasterControl.' .

ind:Disposition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subject ;
    rdfs:label 'Disposition' ;
    rdfs:comment 'Transactional record capturing each formal disposition milestone of a subject through the study lifecycle (screened, enrolled, randomized, completed, discontinued, withdrawn, lost to follow-up, death). Records disposition term per MedDRA or sponsor-specific coding, disposition date, reason for discontinuation or withdrawal (verbatim and coded), initiator (subject, investigator, sponsor), last dose date, last visit date, safety follow-up requirement, and last study contact date. Represents the SDTM DS domain SSOT and drives CONSORT flow diagrams and CSR disposition tables. Sourced from Medidata Rave EDC.' .

ind:EligibilityAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subject ;
    rdfs:label 'Eligibility Assessment' ;
    rdfs:comment 'Transactional record of the inclusion/exclusion criteria assessment performed for a subject during screening. Captures each criterion code, criterion text, assessment result (met/not met/not assessed), assessment date, assessor identity, and overall eligibility determination. Tracks waiver requests and protocol-specified exceptions. Provides the audit trail for subject eligibility decisions required by GCP. Sourced from Medidata Rave EDC and Oracle Clinical One.' .

ind:SubjectStatusHistory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subject ;
    rdfs:label 'Subject Status History' ;
    rdfs:comment 'Lifecycle history table tracking every status transition of a trial subject across the enrollment lifecycle (e.g., pre-screened → screened → screen-failed → enrolled → randomized → on-treatment → completed → withdrawn). Captures prior status, new status, transition date, transition reason, and the user/system that triggered the change. Enables longitudinal subject flow analysis and regulatory audit trails. Sourced from Oracle Clinical One and Medidata Rave.' .

ind:SubjectContact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subject ;
    rdfs:label 'Subject Contact' ;
    rdfs:comment 'Master entity storing contact and communication details for a trial subject, including primary phone, secondary phone, email address, preferred contact method, emergency contact name and relationship, home address (street, city, state, postal code, country), and privacy consent flags for contact. Supports patient recruitment follow-up, visit reminders, and safety follow-up communications. Governed by GDPR and HIPAA data privacy requirements. Sourced from Clinpal and Oracle Siebel CTMS.' .

ind:StipendPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subject ;
    rdfs:label 'Stipend Payment' ;
    rdfs:comment 'Transactional record of subject stipend and reimbursement payments issued to trial participants for visit attendance, travel expenses, and participation costs per IRB/IEC-approved payment schedule. Captures payment amount, currency, payment date, payment method (check, ACH, gift card, prepaid debit card), associated visit reference, payment status (pending, approved, issued, cleared, voided), tax reporting flags (1099 threshold tracking for US subjects), and receipt documentation. Distinct from investigator site payments owned by the finance domain. Sourced from Oracle Siebel CTMS and Greenphire ClinCard.' .

ind:StudyBudget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Study Budget' ;
    rdfs:comment 'Master record for the total approved financial budget allocated to a clinical study, including versioned amendments and granular line-item breakdown by cost category, WBS element, and fiscal period. Captures the overall budget envelope (direct costs, indirect costs, overhead, pass-through estimates), version history with amendment reasons and approval status, and line-level planned quantities and unit costs. Serves as the financial baseline for all study-level cost tracking, variance analysis, sponsor invoicing, and SOX-compliant budget change audit trails. Sourced from SAP S/4HANA project accounting module.' .

ind:CostCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Master reference for SAP S/4HANA cost centers used to allocate and track clinical trial expenditures by organizational unit, therapeutic area, or functional department. Captures cost center code, hierarchy level, responsible manager, valid-from/to dates, and currency. Serves as the organizational dimension for all financial postings and project accounting within the CRO.' .

ind:GlAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'Master reference for General Ledger accounts used in clinical trial financial postings. Captures account number, account type (P&L vs balance sheet), account group, description, currency, and controlling area assignment per SAP S/4HANA Chart of Accounts. Provides the financial classification backbone for all journal entries, accruals, and financial reporting across studies.' .

ind:JournalEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry' ;
    rdfs:comment 'Transactional record for every financial journal entry posted in SAP S/4HANA for clinical trial operations. Captures document number, posting date, fiscal period, document type (original, reversal, accrual), debit/credit line items, cost center, GL account, reference document, posting user, and approval status. Supports SOX financial controls, period-end close, and audit trail requirements.' .

ind:SponsorInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Sponsor Invoice' ;
    rdfs:comment 'Master record for invoices and credit memos issued to pharmaceutical and biotech sponsors for clinical trial services rendered. Captures document type (invoice, credit memo, debit memo), invoice number, sponsor reference, study association, billing period, invoice date, due date, total amount, currency, tax details, payment terms, payment status (draft, submitted, disputed, paid, partially paid), cash receipt details, and SAP AR document reference. Central to revenue recognition, accounts receivable management, and billing dispute resolution.' .

ind:InvoiceLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Invoice Line' ;
    rdfs:comment 'Line-item detail for each sponsor invoice, capturing the specific service, milestone, or pass-through cost being billed. Includes line number, service description, billing category (professional fees, pass-through, investigator grant reimbursement, lab fees), quantity, unit price, line amount, applicable study visit or milestone reference, and tax code. Enables granular billing reconciliation and sponsor audit support.' .

ind:SitePayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Site Payment' ;
    rdfs:comment 'Transactional record for payments disbursed to investigational sites against completed milestones, per-procedure fees, and per-visit fees as defined in the clinical trial agreement. Captures payment amount, currency, payment date, payment method (wire, check, ACH), SAP AP document reference, site bank account reference, withholding tax details, and reconciliation status. This is the actual financial disbursement record owned by finance — distinct from site-domain milestone tracking.' .

ind:PatientStipend rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Patient Stipend' ;
    rdfs:comment 'Transactional record for stipend and reimbursement payments made to trial subjects (patients) for study participation, travel, and incidental expenses. Captures subject reference, study visit association, stipend type (participation fee, travel reimbursement, meal allowance), payment amount, currency, payment method (prepaid card, check, bank transfer), payment date, tax reporting flag, and payment status. Supports subject retention programs and regulatory compliance with fair market value guidelines.' .

ind:PurchaseOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Purchase Order' ;
    rdfs:comment 'Master record for purchase orders issued to vendors and service providers supporting clinical trial operations (e.g., central labs, imaging CROs, specialty vendors, courier services). Captures PO number, vendor reference, study association, PO date, delivery terms, total PO value, currency, approval workflow status, SAP MM document reference, and goods/service receipt status. Governs procurement commitments and accounts payable obligations.' .

ind:VendorInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Vendor Invoice' ;
    rdfs:comment 'Transactional record for invoices received from external vendors and service providers for clinical trial-related goods and services, including pass-through costs billable to sponsors. Captures vendor invoice number, vendor reference, associated PO, invoice date, line items (with pass-through flag and sponsor reimbursement status), total amount, currency, tax details, three-way match status (PO/GR/invoice), payment terms, due date, and SAP FI-AP document reference. Drives accounts payable processing, pass-through cost recovery, and cash flow management.' .

ind:Accrual rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Accrual' ;
    rdfs:comment 'Transactional record for financial accruals posted at period-end to recognize clinical trial costs incurred but not yet invoiced. Captures accrual type (site services, CRA monitoring, lab fees, investigator grants), accrual basis (enrollment-based, visit-based, milestone-based), accrual amount, currency, GL account, cost center, accrual period, reversal date, and SAP FI document reference. Critical for accurate period-end financial reporting and SOX compliance.' .

ind:RevenueRecognition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Revenue Recognition' ;
    rdfs:comment 'Transactional record capturing the revenue recognition events for clinical trial services delivered to sponsors, aligned with ASC 606 / IFRS 15 percentage-of-completion methodology. Captures recognition period, study milestone or deliverable, recognized revenue amount, deferred revenue balance, cumulative recognized amount, recognition method, and SAP RAR (Revenue Accounting and Reporting) document reference. Supports SOX financial controls and sponsor contract revenue reporting.' .

ind:FinancialForecast rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Financial Forecast' ;
    rdfs:comment 'Master record for rolling financial forecasts at the study or portfolio level, projecting future revenues, costs, and cash flows based on current enrollment rates, site activation status, and milestone completion projections. Captures forecast period, forecast type (monthly, quarterly, annual), revenue forecast, cost forecast, gross margin projection, variance from budget, forecast confidence level, and preparer details. Supports sponsor financial reporting and internal management decision-making.' .

ind:FinanceBillingMilestone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Finance Billing Milestone' ;
    rdfs:comment 'Master record defining the contractual billing milestones agreed with sponsors for triggering invoice generation. Captures milestone name, milestone type (enrollment-based, visit-based, deliverable-based, time-based), trigger criteria, planned billing date, billing amount, currency, milestone status (pending, triggered, invoiced, paid), and linkage to the sponsor agreement. Distinct from site_payment_milestone (site domain) — this governs sponsor-facing billing events, not site disbursements.' .

ind:BudgetLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Budget Line' ;
    rdfs:comment 'Granular line-item breakdown of a study budget by WBS element, cost category, and time period. Captures budget line description, cost category (direct labor, pass-through, investigator grants, overhead), planned quantity, unit cost, total planned amount, currency, fiscal year, and budget version reference. Enables detailed cost tracking, variance analysis, and sponsor budget reporting at the activity level.' .

ind:RandScheme rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Randomization ;
    rdfs:label 'Rand Scheme' ;
    rdfs:comment 'Master definition of a randomization scheme for a clinical study. Captures the allocation algorithm type (simple, block, stratified, minimization, adaptive), block sizes, allocation ratio, seed values, and scheme version. Owned by the biostatistics/RTSM team and referenced by all randomization activities. Sourced from Oracle Clinical One and Medidata Rave RTSM module.' .

ind:RandList rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Randomization ;
    rdfs:label 'Rand List' ;
    rdfs:comment 'The generated randomization list produced from a randomization scheme. Stores the ordered sequence of treatment assignments, list version, generation timestamp, generation method, blinding level, and approval status. A rand_list is the authoritative artifact used by IRT/IVRS/RTSM to assign subjects to treatment arms. Sourced from Medidata Rave RTSM and Oracle Clinical One.' .

ind:RandCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Randomization ;
    rdfs:label 'Rand Code' ;
    rdfs:comment 'Individual randomization code (slot) within a randomization list. Each code represents a single subject allocation slot with its sequential position number, pre-assigned treatment arm, stratification cell membership, kit code linkage for IMP dispensing, blinded label visible to site staff, and assignment status (available, assigned, cancelled, replaced). The atomic unit consumed when a subject is randomized via IRT/RTSM — once assigned, the code is permanently linked to that subject. Sourced from Medidata Rave RTSM and Oracle Clinical One.' .

ind:TreatmentArm rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Randomization ;
    rdfs:label 'Treatment Arm' ;
    rdfs:comment 'Master definition of each treatment arm within a clinical study. Captures arm name, arm code, arm type (experimental, active comparator, placebo, open-label extension), blinding role, target allocation percentage, and arm status. SSOT for treatment arm definitions referenced by randomization codes, subject assignments, and supply domain kit assignments.' .

ind:StratificationFactor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Randomization ;
    rdfs:label 'Stratification Factor' ;
    rdfs:comment 'Defines the stratification factors used in a randomization scheme, including factor name, factor code, data source (eCRF field reference), factor type (categorical, continuous-binned), enumerated levels (level code, label, sort order, active status), and optional minimization parameters (weight value, algorithm variant such as Pocock-Simon or weighted minimization). Each factor belongs to one randomization scheme and its levels define the axes of the stratification matrix. Owned by the biostatistics/RTSM team as part of scheme design.' .

ind:StratificationCell rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Randomization ;
    rdfs:label 'Stratification Cell' ;
    rdfs:comment 'Represents the unique combination of stratification factor levels that defines a single stratum cell within a randomization scheme. Stores the cell identifier, composite cell label, target subject count per arm within the cell, actual enrolled count, and cell balance status. Used to monitor enrollment balance across strata.' .

ind:SubjectRandomization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Randomization ;
    rdfs:label 'Subject Randomization' ;
    rdfs:comment 'Transactional record of a subject\'s randomization or re-randomization event. Captures the subject identifier, study site, randomization number assigned, treatment arm allocated, stratification cell, randomization timestamp, IRT/IVRS transaction reference, randomizing user (CRC/IRT system), randomization status (randomized, cancelled, re-randomized), and for re-randomization events: original randomization reference, re-randomization reason (screen failure re-entry, protocol deviation, IRT error), and authorizing protocol amendment. This is the SSOT for all subject-to-treatment-arm allocation events including initial and subsequent randomizations. Sourced from Medidata Rave RTSM and Oracle Clinical One.' .

ind:IrtTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Randomization ;
    rdfs:label 'Irt Transaction' ;
    rdfs:comment 'Detailed log of all IRT/IVRS/RTSM system transactions related to randomization and kit dispensing. Captures transaction type (randomization, re-randomization, cancellation, kit assignment, dose change, titration), transaction timestamp, IRT system reference number, site identifier, subject identifier, operator ID, and transaction outcome. Provides the full audit trail of IRT interactions for GCP compliance and SDV. Sourced from Medidata Rave RTSM.' .

ind:KitAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Randomization ;
    rdfs:label 'Kit Assignment' ;
    rdfs:comment 'Records the assignment of an investigational medicinal product (IMP) kit to a subject at a specific visit, as triggered by the IRT/RTSM system following randomization or resupply. Captures kit number, kit type, dispensing site, dispensing visit, dispensing date, subject randomization reference, treatment arm, and kit return status. Links the randomization domain to the supply domain for IMP accountability.' .

ind:BlindingConfig rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Randomization ;
    rdfs:label 'Blinding Config' ;
    rdfs:comment 'Defines the blinding configuration for a randomization scheme, including blinding type (open-label, single-blind, double-blind, triple-blind), blinded roles (subject, investigator, sponsor, CRA, statistician), blinding method (identical packaging, dummy tablets, double-dummy), and the system-enforced access controls for unblinded data. Governs who can see treatment assignments and under what conditions.' .

ind:UnblindingRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Randomization ;
    rdfs:label 'Unblinding Request' ;
    rdfs:comment 'Transactional record of a request to unblind a subject\'s treatment assignment, encompassing the full request-through-resolution lifecycle including multi-level approval steps. Captures requestor identity, requestor role, clinical justification (SAE, medical emergency, regulatory requirement, planned DBL unblinding, interim analysis), urgency level, request timestamp, approval chain (approver identity, role, decision, rationale, conditions, timestamp per approval step), final outcome (approved/rejected/escalated), unblinding timestamp, and the unblinded treatment arm revealed. Covers both emergency single-subject unblinding and planned study-level unblinding events. Critical for GCP compliance, 21 CFR Part 11 audit trail, and DSMB/DMC oversight. Sourced from Oracle Clinical One and Medidata Rave RTSM.' .

ind:UnblindingApproval rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Randomization ;
    rdfs:label 'Unblinding Approval' ;
    rdfs:comment 'Records the approval or rejection decision for an unblinding request. Captures the approver role (medical monitor, PI, sponsor medical officer), decision (approved, rejected, escalated), decision rationale, decision timestamp, and any conditions attached to the approval. Maintains the multi-level approval audit trail required by GCP and 21 CFR Part 11 for emergency unblinding events.' .

ind:RandValidationRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Randomization ;
    rdfs:label 'Rand Validation Run' ;
    rdfs:comment 'Records the UAT and validation runs performed on a randomization scheme and IRT system prior to study go-live. Captures validation run type (UAT, dry run, parallel test), test scenario coverage, pass/fail status per scenario, tester identity, validation date, defects identified, and final sign-off status. Required for 21 CFR Part 11 and GCP compliance before first subject randomization.' .

ind:DsmbUnblindPackage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Randomization ;
    rdfs:label 'Dsmb Unblind Package' ;
    rdfs:comment 'Manages the preparation and delivery of unblinded data packages to the DSMB (Data Safety Monitoring Board) or DMC (Data Monitoring Committee). Captures package version, meeting date, unblinded statistician identity, data cut-off date, treatment arm labels included, delivery method, receipt confirmation, and destruction confirmation post-meeting. Ensures controlled unblinded data access for interim safety reviews.' .

ind:RandDeviation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Randomization ;
    rdfs:label 'Rand Deviation' ;
    rdfs:comment 'Documents randomization-related protocol deviations, including wrong treatment dispensed, randomization outside the protocol window, incorrect stratification factor captured, duplicate randomization, and IRT system errors leading to incorrect assignment. Captures deviation type, discovery date, subject impact, corrective action taken, CAPA reference, and regulatory reportability assessment. Links to the compliance domain for CAPA tracking.' .

ind:ImpMaster rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Imp Master' ;
    rdfs:comment 'Master record for all investigational and comparator products used in clinical trials, including sponsor IMPs, active comparators, and placebos. Captures product identity, product type (IMP/comparator/placebo), formulation details, dosage form, strength, storage conditions (including cold-chain requirements), shelf life, sourcing strategy (manufactured vs. commercially procured), regulatory classification, and IND/IMPD reference. Serves as the SSOT for all drug product definitions within the supply domain. Sourced from Medidata Rave RTSM and sponsor-provided specifications.' .

ind:KitDefinition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Kit Definition' ;
    rdfs:comment 'Defines randomization kit configurations used in RTSM (Medidata Rave). Captures kit type, treatment arm association, blinding level, component IMPs, pack size, label text, kit number range, and applicable study/protocol version. Serves as the template from which physical kits are manufactured and assigned. Distinct from kit_inventory which tracks physical instances.' .

ind:KitInventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Kit Inventory' ;
    rdfs:comment 'Tracks physical randomization kit instances across the supply chain — from manufacture through depot receipt, site shipment, dispensing, and destruction. Each record represents a unique kit number with current status (available, assigned, dispensed, expired, returned, destroyed), location (depot or site), expiry date, cold-chain compliance flag, and chain-of-custody timestamps. Sourced from Medidata Rave RTSM.' .

ind:Depot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Depot' ;
    rdfs:comment 'Master record for clinical supply depots (central and regional warehouses) that store and distribute IMPs. Captures depot name, geographic location, GMP certification status, temperature-controlled storage capabilities (ambient, refrigerated, frozen), qualified person details, regulatory licenses, and operational contact information. Depots are the primary nodes in the clinical supply logistics network.' .

ind:SiteInventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Site Inventory' ;
    rdfs:comment 'Tracks IMP and kit stock positions at supply chain nodes (investigational sites and depots). Each record represents current inventory levels by IMP/kit type at a specific location, including quantity on-hand, received, dispensed, allocated, quarantined, returned, and expired. Records storage condition compliance, last physical count date, and location type (site or depot). Enables accountability reconciliation, resupply trigger management, and regulatory inventory reporting. Linked to site or depot via location reference.' .

ind:SupplyPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Supply Plan' ;
    rdfs:comment 'Captures the drug supply planning record for a study, including forecasted demand by country/region and site tier, planned manufacturing batches, buffer stock targets, resupply trigger thresholds, overage assumptions, and planning horizon. Supports IMP demand forecasting driven by enrollment projections, protocol-defined dosing regimens, and dropout rates. Managed in coordination with sponsor supply teams and updated at defined planning cycles (typically monthly or per enrollment milestone).' .

ind:ManufactureBatch rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Manufacture Batch' ;
    rdfs:comment 'Records IMP manufacturing batch details including batch number, manufacturing date, batch size, manufacturing site, GMP certificate of analysis reference, release status (quarantine, released, rejected), expiry date, and storage conditions. Serves as the upstream traceability anchor for all kit and inventory records. Sourced from sponsor-provided batch release documentation.' .

ind:Shipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Shipment' ;
    rdfs:comment 'Transactional record of IMP/kit shipments between supply chain nodes (manufacturer to depot, depot to site, site to site, site to depot for returns). Captures shipment number, origin, destination, carrier, tracking number, shipment date, expected delivery date, actual delivery date, temperature excursion flag, cold-chain logger data reference, contents (kits/batches), and shipment status. Sourced from Medidata Rave RTSM and logistics provider integrations.' .

ind:ShipmentLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Shipment Line' ;
    rdfs:comment 'Line-level detail for each IMP shipment, capturing individual kit numbers or batch quantities included in a shipment. Each line records the IMP/kit reference, quantity shipped, unit of measure, lot/batch number, expiry date, and line-level receipt confirmation status. Enables granular kit-level traceability within a shipment transaction.' .

ind:DispensingRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Dispensing Record' ;
    rdfs:comment 'Captures each IMP dispensing event at an investigational site, recording the subject identifier, visit reference, kit number dispensed, IMP name, dose, quantity dispensed, dispensing date and time, dispensing staff, and RTSM confirmation number. Serves as the primary drug accountability record at the subject level. Sourced from Medidata Rave RTSM dispensing module. Critical for GCP compliance and accountability reconciliation.' .

ind:ReturnRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Return Record' ;
    rdfs:comment 'Documents IMP/kit returns from subjects to sites and from sites to depots. Captures return type (subject return, site-to-depot, expired stock), kit numbers or quantities returned, return date, condition on return (intact, partially used, damaged), reconciliation status, and destruction authorization reference. Essential for drug accountability reconciliation and regulatory compliance.' .

ind:DestructionRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Destruction Record' ;
    rdfs:comment 'Records the destruction of returned, expired, or rejected IMP/kits. Captures destruction authorization number, destruction date, destruction method (incineration, chemical neutralization), facility, quantity and kit numbers destroyed, witness details, and certificate of destruction reference. Required for GCP audit trails and regulatory inspection readiness.' .

ind:TemperatureExcursion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Temperature Excursion' ;
    rdfs:comment 'Records cold-chain temperature excursion events detected during IMP storage or transit. Captures excursion start and end timestamps, affected location (depot, site, in-transit), temperature range breached, duration, affected kit/batch numbers, impact assessment outcome (use/quarantine/destroy), and sponsor/QA disposition decision. Critical for cold-chain compliance and GCP audit readiness.' .

ind:AccountabilityReconciliation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Accountability Reconciliation' ;
    rdfs:comment 'Periodic drug accountability reconciliation record at the site level, capturing the reconciliation period, opening balance, receipts, dispensed quantities, returned quantities, destroyed quantities, closing balance, discrepancy count and detail, reconciliation status (open, reconciled, discrepancy-flagged), investigator sign-off, and CRA/monitor sign-off. Required at every monitoring visit and prior to database lock (DBL). Supports GCP §8.3.13 compliance, regulatory inspection readiness, and site close-out.' .

ind:ResupplyOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Resupply Order' ;
    rdfs:comment 'Captures resupply order requests triggered by RTSM resupply algorithms or manual supply manager intervention. Records the requesting site or depot, IMP/kit type requested, quantity requested, urgency level, order date, expected fulfillment date, fulfillment status, and linked shipment reference. Enables end-to-end resupply workflow tracking from trigger to delivery.' .

ind:ImportPermit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Import Permit' ;
    rdfs:comment 'Manages country-level import permits and licenses required for cross-border IMP shipments. Captures permit number, issuing authority, country, IMP reference, permitted quantity, permit validity dates, application date, approval date, and permit status. Enables regulatory compliance tracking for international clinical supply logistics and prevents shipment delays due to missing permits.' .

ind:ComparatorDrug rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Comparator Drug' ;
    rdfs:comment 'Master record for comparator drugs and placebo products used in controlled clinical trials. Captures comparator drug name, manufacturer, regulatory approval status in applicable countries, sourcing strategy (commercial purchase vs. sponsor-supplied), storage requirements, and blinding configuration. Distinct from IMP master as comparators are commercially sourced and subject to different procurement and regulatory rules.' .

ind:AncillarySupply rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Ancillary Supply' ;
    rdfs:comment 'Tracks non-IMP clinical supplies required at investigational sites, including syringes, diluents, infusion sets, patient diaries, lab kits, and other protocol-required materials. Captures supply type, unit of measure, site stock levels, reorder thresholds, and shipment history. Distinct from IMP/kit inventory as ancillary supplies follow different procurement, labeling, and accountability rules.' .

ind:DepotInventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Depot Inventory' ;
    rdfs:comment 'Tracks IMP and kit stock levels held at each depot, including quantities by batch, kit type, and storage condition zone. Records receipt date, current quantity on-hand, quantity allocated for pending shipments, quantity quarantined, quantity expired, and last physical inventory count. Distinct from site_inventory which tracks site-level stock; depot_inventory covers central and regional warehouse holdings.' .

ind:MasterServiceAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Agreement ;
    rdfs:label 'Master Service Agreement' ;
    rdfs:comment 'SSOT for Master Service Agreements (MSAs) between the CRO and pharmaceutical/biotech sponsors, including standalone NDAs/CDAs modeled as agreement_type=\'NDA\'. Captures the overarching contractual framework governing the commercial relationship: governing law, liability caps, confidentiality terms, IP ownership, indemnification clauses, payment terms, auto-renewal flags, and effective/expiry dates. Also tracks negotiation lifecycle (status, rounds, target execution date) for pre-execution MSAs. Sourced from Veeva Vault and SAP S/4HANA project accounting.' .

ind:StudyContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Agreement ;
    rdfs:label 'Study Contract' ;
    rdfs:comment 'Study-level contract (Clinical Trial Agreement / CTA) executed between the sponsor and CRO for a specific clinical study. Captures contract number, study reference, contract type (full-service, functional service, co-development), total contracted value, currency, execution date, contract status, governing MSA reference, and negotiation lifecycle attributes (status, rounds, target execution date, key open issues). Also records termination and renewal events as lifecycle state changes. Represents the primary commercial instrument for a single study engagement.' .

ind:ScopeOfWork rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Agreement ;
    rdfs:label 'Scope Of Work' ;
    rdfs:comment 'Formal Scope of Work (SOW) document attached to a study contract or MSA, defining the specific services, deliverables, timelines, and responsibilities the CRO will perform. Captures SOW version, effective date, service categories (monitoring, data management, biostatistics, regulatory), geographic scope, and approval status. Multiple SOW versions may exist per contract due to amendments.' .

ind:ChangeOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Agreement ;
    rdfs:label 'Change Order' ;
    rdfs:comment 'Formal Change Order (CO) or Contract Change Notice (CCN) issued to modify the scope, budget, or timeline of an existing SOW or study contract. Captures change order number, change type (scope increase, scope decrease, timeline extension, budget reallocation), reason for change, financial impact (delta value), approval workflow status, effective date, and impacted budget lines. Tracks the full lifecycle of contract modifications from initiation through sponsor approval.' .

ind:ContractAmendment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Agreement ;
    rdfs:label 'Contract Amendment' ;
    rdfs:comment 'Formal amendment to a master service agreement or study contract that modifies legal terms, commercial conditions, or governing clauses (as distinct from a Change Order which modifies scope/budget). Captures amendment number, amendment type (legal terms, payment terms, liability, confidentiality), description of changes, negotiation history, execution date, and the parties who signed. Maintains a versioned history of the legal contract.' .

ind:ServiceLevelAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Agreement ;
    rdfs:label 'Service Level Agreement' ;
    rdfs:comment 'Service Level Agreement (SLA) defining measurable performance commitments the CRO must meet for specific service categories (e.g., query resolution turnaround, SAE reporting timelines, monitoring visit frequency, data entry lag). Captures SLA code, service category, target metric, measurement unit, threshold value, penalty/credit terms, measurement frequency, and the contract or SOW it is attached to.' .

ind:AgreementBillingMilestone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Agreement ;
    rdfs:label 'Agreement Billing Milestone' ;
    rdfs:comment 'Contractually defined billing milestone tied to a study contract or SOW, representing a specific deliverable or event that triggers an invoice. Captures milestone name, milestone type (enrollment-based, visit-based, deliverable-based, time-based), planned trigger date, actual trigger date, milestone amount, currency, billing status (pending, triggered, invoiced, paid), and the deliverable or event that activates it. Sourced from SAP S/4HANA project accounting.' .

ind:Deliverable rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Agreement ;
    rdfs:label 'Deliverable' ;
    rdfs:comment 'Contractually committed deliverable defined within a SOW or study contract, representing a specific output the CRO must produce (e.g., Clinical Study Report, Statistical Analysis Plan, Data Management Plan, Monitoring Plan, Regulatory Submission Package). Captures deliverable name, deliverable type, planned delivery date, actual delivery date, acceptance criteria, delivery status, and the responsible CRO functional team.' .

ind:InvestigatorGrant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Agreement ;
    rdfs:label 'Investigator Grant' ;
    rdfs:comment 'Contractual grant agreement between the CRO (on behalf of the sponsor) and an investigational site or Principal Investigator (PI) defining per-procedure and per-visit payment rates for conducting the clinical trial. Captures grant version, effective date, per-visit rates, per-procedure rates, overhead percentage, currency, payment schedule type, and negotiation status. Distinct from the sponsor-CRO contract — this governs the CRO-site financial relationship.' .

ind:ContractNegotiation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Agreement ;
    rdfs:label 'Contract Negotiation' ;
    rdfs:comment 'Tracks the negotiation lifecycle of a contract or amendment from initial draft through final execution. Captures negotiation round number, negotiation status (draft, under review, redline, legal review, approved, executed), negotiation start date, target execution date, actual execution date, negotiating parties, key open issues, and escalation flags. Enables cycle time tracking and bottleneck identification in the contracting process.' .

ind:ContractObligation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Agreement ;
    rdfs:label 'Contract Obligation' ;
    rdfs:comment 'Specific contractual obligation or commitment extracted from a study contract, MSA, SOW, or subcontract that must be tracked for compliance. Captures obligation type (regulatory, financial, operational, reporting, dispute-related), obligation description, responsible party, due date, recurrence pattern (one-time, recurring), fulfillment status, evidence of fulfillment, and escalation triggers. Enables proactive obligation management, prevents contractual breaches, and supports dispute tracking as obligation items.' .

ind:PreferredProviderAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Agreement ;
    rdfs:label 'Preferred Provider Agreement' ;
    rdfs:comment 'Preferred Provider Agreement (PPA) or Framework Agreement establishing pre-negotiated terms, rates, and service standards with a CRO or vendor for a portfolio of studies. Captures agreement scope (therapeutic area, geography, service type), preferred rate card reference, volume commitment thresholds, governance structure, and the sponsor portfolio it covers. Distinct from individual study contracts — governs the strategic partnership level.' .

ind:ConfidentialityAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Agreement ;
    rdfs:label 'Confidentiality Agreement' ;
    rdfs:comment 'Non-Disclosure Agreement (NDA) or Confidentiality Disclosure Agreement (CDA) executed between the CRO and a sponsor or partner prior to or alongside a study contract. Captures NDA type (unilateral, bilateral, multilateral), effective date, expiry date, scope of confidential information, permitted disclosures, breach notification requirements, and execution status. Required before sharing proprietary compound or protocol information.' .

ind:Subcontract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Agreement ;
    rdfs:label 'Subcontract' ;
    rdfs:comment 'Subcontract or sub-CRO agreement executed by the CRO with a third-party vendor or sub-CRO to delegate specific services defined in the primary study contract. Captures subcontract type (laboratory services, imaging, eCOA, translation, monitoring), subcontractor name, subcontracted services, subcontract value, flow-down obligations from the primary contract, and sponsor approval status. Supports oversight of the CRO\'s vendor management obligations under GCP.' .

ind:RateCard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Agreement ;
    rdfs:label 'Rate Card' ;
    rdfs:comment 'Pre-negotiated rate card defining unit prices for specific CRO services, staff categories, and activities applicable to a sponsor relationship or preferred provider agreement. Captures service category, staff grade/role, unit of measure (per hour, per visit, per subject, per procedure), unit rate, currency, effective date range, and the MSA or PPA it is attached to. Serves as the pricing reference for SOW budget construction and change order valuation.' .

ind:Employee rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Employee' ;
    rdfs:comment 'Master record for every clinical research workforce member employed by or contracted to the CRO, sourced from Workday HCM. Captures full employee identity, job profile assignment, organizational unit, employment type (full-time, part-time, contractor), hire date, termination date, employment status, cost center, reporting manager, work location, and GCP role designation (CRA, CRC, Biostatistician, Data Manager, Medical Monitor, Regulatory Specialist). This is the SSOT for workforce identity — all training records, study assignments, delegation logs, and certifications reference this entity.' .

ind:JobProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Job Profile' ;
    rdfs:comment 'Reference master defining standardized job profiles and role classifications used across the clinical research workforce. Captures job family (Clinical Operations, Biostatistics, Data Management, Regulatory Affairs, Medical Affairs), job level (Associate, Senior, Principal, Director), required competencies, GCP role category, CDISC role alignment, and salary band. Sourced from Workday HCM job catalog. Enables workforce planning and competency gap analysis.' .

ind:GcpTrainingRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Gcp Training Record' ;
    rdfs:comment 'Transactional record of GCP (Good Clinical Practice) training completions for each workforce member, sourced from MasterControl training management module. Captures training course name, ICH E6(R2) GCP version, training type (initial, refresher, protocol-specific), completion date, expiry date, training provider, assessment score, pass/fail status, and certificate reference. Critical for regulatory compliance — GCP training currency is required for all trial personnel per FDA 21 CFR Part 312 and ICH E6.' .

ind:Certification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Certification' ;
    rdfs:comment 'Master record for professional certifications and credentials held by clinical research workforce members. Captures certification type (ACRP CCRC, ACRP CCRA, SOCRA CCRP, RAC, SAS Certified, etc.), issuing body, certification number, issue date, expiry date, renewal status, and continuing education credits earned. Distinct from GCP training records — these are externally awarded professional credentials with their own renewal lifecycle.' .

ind:StudyAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Study Assignment' ;
    rdfs:comment 'Transactional record capturing the formal assignment of a workforce member to a clinical study in a defined role, with FTE allocation percentage. Sourced from CTMS and Workday HCM project assignments. Captures employee, study reference, assigned role (CRA, CRC, Data Manager, Biostatistician, Medical Monitor, Regulatory Lead, Project Manager), assignment start and end dates, FTE allocation percentage, assignment status (active, on-hold, completed), and authorizing manager. This is the SSOT for study-level resource allocation and the primary input for capacity utilization calculations.' .

ind:WorkforceDelegationLog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Workforce Delegation Log' ;
    rdfs:comment 'Transactional record of the formal delegation of trial-related duties from the Principal Investigator (PI) to site staff and CRO personnel, as required by ICH E6(R2) Section 8.3.25. Captures delegating PI, delegatee employee, study, site, delegated task or responsibility, delegation start date, end date, PI signature date, and delegation log version. Regulatory artifact required in the Trial Master File (TMF). Distinct from study_assignment — this is a GCP-mandated legal document, not an operational resource record.' .

ind:WorkforceResourcePlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Workforce Resource Plan' ;
    rdfs:comment 'Master record for workforce resource planning at the study, program, or organizational unit level. Captures planned FTE demand by role and time period, planned vs. actual headcount, resource gap analysis, planning horizon (study phase, quarter, year), planning status (draft, approved, revised), capacity utilization targets, and owning resource manager. Sourced from Workday HCM workforce planning module. Enables proactive capacity management, hiring decisions, and workload balancing for clinical operations teams.' .

ind:TrainingRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Training Record' ;
    rdfs:comment 'Transactional record tracking the assignment and completion of SOP (Standard Operating Procedure) and controlled document training to workforce members, managed through MasterControl. Captures SOP document reference, SOP version, assigned employee, assignment date, due date, completion date, assessment score, pass/fail status, and training method (read-and-understand, instructor-led, e-learning). Distinct from gcp_training_record — this covers internal SOP compliance training, not external GCP certification.' .

ind:TrainingCurriculum rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Training Curriculum' ;
    rdfs:comment 'Master record defining structured training curricula assigned to job profiles or roles within the clinical research organization. Captures curriculum name, target job profile or role, list of required training courses (GCP, SOP, protocol-specific, system-specific), required completion timeline, regulatory basis (ICH E6, 21 CFR Part 312, EU CTR), curriculum version, and effective date. Managed in MasterControl. Enables systematic onboarding and ongoing compliance training management.' .

ind:PayrollRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Payroll Record' ;
    rdfs:comment 'Transactional record of payroll processing events for each employee, sourced from Workday HCM Payroll module. Captures pay period start and end dates, gross pay, net pay, pay components (base salary, overtime, bonus, allowances), deductions (tax, benefits, retirement), pay group, payment method, payment date, and payroll run reference. This is the SSOT for compensation disbursement history. Supports SOX financial reporting controls and workforce cost allocation to clinical studies.' .

ind:OrgUnit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Org Unit' ;
    rdfs:comment 'Reference master for the organizational hierarchy of the clinical research organization, sourced from Workday HCM. Captures organizational unit name, unit type (department, division, cost center, team), parent unit, unit head employee, cost center code, GL account mapping, and effective date. Supports workforce reporting, cost allocation to studies, and organizational change management. Enables hierarchical rollup of headcount, FTE, and training compliance by department.' .

ind:Position rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Position' ;
    rdfs:comment 'Master record for approved headcount positions within the clinical research organization, managed in Workday HCM. Captures position title, job profile, org unit, position type (permanent, fixed-term, contractor), budgeted FTE, current incumbency status (filled, vacant, frozen), hiring manager, and position effective dates. Distinct from employee — a position can be vacant or filled by multiple employees over time. Enables headcount management and workforce planning against approved budgets.' .

ind:ProtocolTrainingRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Protocol Training Record' ;
    rdfs:comment 'Transactional record capturing protocol-specific training completions for workforce members assigned to a clinical study. Captures study protocol number, protocol version trained on, employee, training date, training type (protocol overview, amendments, therapeutic area), trainer or training provider, assessment score, pass/fail status, and expiry (if applicable). Distinct from gcp_training_record (GCP certification) and sop_training_assignment (SOP compliance) — this is study-specific protocol training required before any trial activity.' .

ind:CraQualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Cra Qualification' ;
    rdfs:comment 'Master record capturing the qualification profile of a Clinical Research Associate (CRA), including therapeutic area experience, monitoring experience (years, visit count), geographic coverage regions, language proficiencies, sponsor-specific qualifications, and system proficiencies (Medidata Rave, Oracle Clinical One, Veeva Vault). Distinct from certification (external credentials) and gcp_training_record (GCP compliance) — this captures the operational qualification profile used for CRA-to-study matching and site assignment decisions.' .

ind:WorkforceCapa rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Workforce Capa' ;
    rdfs:comment 'Transactional record for Corrective and Preventive Actions (CAPAs) initiated against workforce members for GCP compliance failures, training non-compliance, or performance issues identified during audits or inspections. Managed through MasterControl. Captures CAPA type (corrective, preventive), root cause category, description of non-compliance, assigned employee, CAPA owner, due date, completion date, effectiveness check date, and closure status. Distinct from monitoring.capa_record (site-level CAPAs) — this is workforce-specific HR and compliance CAPA.' .

ind:Sap rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Biostatistics ;
    rdfs:label 'Sap' ;
    rdfs:comment 'Statistical Analysis Plan master record for a clinical study. Captures SAP version history (including amendments with rationale, sections modified, and regulatory impact), authoring status, approval workflow, blinding status, primary/secondary endpoint definitions, analysis populations (ITT, PP, safety), statistical methods, multiplicity adjustments, sensitivity analysis specifications, and regulatory submission alignment. Sourced from SAS Drug Development and Veeva Vault. SSOT for all statistical planning decisions for a study.' .

ind:SapAmendment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Biostatistics ;
    rdfs:label 'Sap Amendment' ;
    rdfs:comment 'Versioned amendment record for a Statistical Analysis Plan. Tracks each SAP revision including amendment number, rationale for change, sections modified, pre- or post-database-lock classification, author, approver, approval date, and regulatory impact assessment. Enables full audit trail of SAP evolution across the study lifecycle.' .

ind:AnalysisPopulation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Biostatistics ;
    rdfs:label 'Analysis Population' ;
    rdfs:comment 'Defines the analysis populations used in a study (e.g., Intent-to-Treat, Per Protocol, Safety, Modified ITT, Pharmacokinetic). Captures population name, acronym, inclusion/exclusion logic description, CDISC ADSL flag variable name, population size at DBL, and SAP reference. SSOT for population definitions consumed by ADaM datasets and TLF shells.' .

ind:SampleSizeCalc rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Biostatistics ;
    rdfs:label 'Sample Size Calc' ;
    rdfs:comment 'Records sample size calculations performed during study design and protocol development. Captures study phase, primary endpoint type, assumed effect size, standard deviation, alpha level, power, dropout rate, allocation ratio, calculated sample size per arm, total enrollment target, software used (e.g., PASS, nQuery), and version. Supports regulatory submission and protocol amendments.' .

ind:AdamDatasetSpec rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Biostatistics ;
    rdfs:label 'Adam Dataset Spec' ;
    rdfs:comment 'Specification record for each ADaM (Analysis Data Model) dataset produced for a study, including variable-level detail. Captures dataset name (e.g., ADSL, ADAE, ADTTE, ADLB), dataset class (ADSL, BDS, OCCDS, OTHER), purpose, key variables with derivation algorithms, variable types, lengths, controlled terminology references, CDISC ADaM core designations (Required/Expected/Permissible), source SDTM domains, programming language, SAS program reference, and approval status. SSOT for ADaM dataset and variable design consumed by SAS programmers.' .

ind:AdamVariableSpec rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Biostatistics ;
    rdfs:label 'Adam Variable Spec' ;
    rdfs:comment 'Detailed variable-level specification within an ADaM dataset. Captures variable name, label, type (character/numeric), length, derivation algorithm, controlled terminology reference, CDISC ADaM core designation (Required/Expected/Permissible/Conditionally Required), source variable(s), and QC status. Enables automated SAS program generation and reviewer validation.' .

ind:TlfShell rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Biostatistics ;
    rdfs:label 'Tlf Shell' ;
    rdfs:comment 'Table, Listing, and Figure (TLF) shell specification for a study. Captures output number, title, footnotes, display population, statistical method reference, program name, output type (table/listing/figure), SAP section reference, priority tier, and production status. SSOT for TLF catalog consumed by SAS programmers and medical writers during CSR production.' .

ind:TlfOutput rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Biostatistics ;
    rdfs:label 'Tlf Output' ;
    rdfs:comment 'Produced TLF output instance generated from a TLF shell specification. Captures output file reference, production run date, SAS program name and version, dataset version used, programmer, QC programmer, validation method (double programming, peer review), QC status, discrepancy count, final approval status, and delivery date. Tracks the production lifecycle of each statistical output from first run to final delivery, including full program traceability.' .

ind:InterimAnalysis rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Biostatistics ;
    rdfs:label 'Interim Analysis' ;
    rdfs:comment 'Records planned and executed interim analyses for a study. Captures interim analysis number, type (efficacy, futility, safety, adaptive), planned information fraction, actual analysis date, DSMB/DMC involvement flag, unblinding scope (full/partial/none), stopping rules triggered, outcome (continue/stop/adapt), alpha spending function parameters, and confidentiality controls. Critical for regulatory compliance and blinding integrity management.' .

ind:DatabaseLockEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Biostatistics ;
    rdfs:label 'Database Lock Event' ;
    rdfs:comment 'Database Lock (DBL) event record for a study or study part. Captures lock scope (full study, interim, partial), planned and actual lock date, pre-lock QC checklist completion status, outstanding query count at lock, lock authorization approvers (DM, biostatistics, medical monitor), lock type (hard/soft), and post-lock amendment records. SSOT for DBL milestone consumed by biostatistics, data management, and regulatory domains.' .

ind:StatisticalEndpoint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Biostatistics ;
    rdfs:label 'Statistical Endpoint' ;
    rdfs:comment 'Master record for each statistical endpoint defined in the SAP for a study. Captures endpoint name, classification (primary, secondary, exploratory, safety), endpoint type (efficacy, PK, PD, biomarker, PRO), measurement scale, analysis timepoint(s), statistical test method, null hypothesis, multiplicity adjustment method (Bonferroni, Hochberg, Holm), and regulatory designation. Enables endpoint-level traceability from SAP to TLF.' .

ind:PkAnalysisSpec rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Biostatistics ;
    rdfs:label 'Pk Analysis Spec' ;
    rdfs:comment 'Pharmacokinetic (PK) analysis specification record. Captures PK parameters to be estimated (AUC, Cmax, Tmax, t½, CL, Vd), compartmental model type, non-compartmental analysis (NCA) settings, software (Phoenix WinNonlin, SAS), dose normalization approach, bioequivalence criteria, confidence interval method, and DMPK collaboration reference. Supports PK/PD reporting in CSR and regulatory submissions.' .

ind:Estimand rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Biostatistics ;
    rdfs:label 'Estimand' ;
    rdfs:comment 'Estimand definition record per the ICH E9(R1) framework for a study endpoint. Captures treatment condition, target population, variable (endpoint), intercurrent event handling strategies (treatment policy, hypothetical, composite, while on treatment, principal stratum), population-level summary measure, associated sensitivity analyses, and SAP alignment status. SSOT for estimand framework documentation required by modern FDA/EMA regulatory submissions.' .

ind:DsmbCharter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Biostatistics ;
    rdfs:label 'Dsmb Charter' ;
    rdfs:comment 'Data Safety Monitoring Board (DSMB) / Data Monitoring Committee (DMC) charter record for a study. Captures committee composition, member roles (chair, statistician, clinician), meeting frequency, interim analysis schedule, stopping rules, unblinding procedures, confidentiality requirements, charter version, and approval date. Biostatistics owns the statistical stopping rule design and independent statistician coordination.' .

ind:DsmbMeeting rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Biostatistics ;
    rdfs:label 'Dsmb Meeting' ;
    rdfs:comment 'DSMB/DMC meeting record capturing each scheduled or ad hoc committee meeting. Captures meeting date, type (open/closed session), agenda items, interim analysis data package version, statistical report version, recommendations issued (continue/pause/stop/modify), action items, and minutes approval status. Provides audit trail of DSMB oversight activities required by regulatory agencies.' .

ind:ConsentIcfVersion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consent ;
    rdfs:label 'Consent Icf Version' ;
    rdfs:comment 'Master record for each version of an Informed Consent Form (ICF) used in a clinical trial, including language translations and amendment-derived versions. Tracks ICF document version number, effective date, IRB/IEC approval reference, language (ISO 639-1), consent type (initial, re-consent, assent, LAR), amendment details (amendment number, nature of change, regulatory basis, affected population, re-consent obligation flag), parent version reference for translations and amendments, translation metadata (translator, back-translation status), expiry date, and regulatory approval status. Serves as the authoritative catalog of all IRB/IEC-approved ICF versions, translations, and amendments per study and site. Source system: Veeva Vault (eTMF) and Clinpal (eConsent).' .

ind:SubjectConsent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consent ;
    rdfs:label 'Subject Consent' ;
    rdfs:comment 'Core transactional record capturing the consent event for a trial subject at a specific site and study. Records the date and time of consent, ICF version consented to, consent method (paper, eConsent via Clinpal), consenting staff (PI, CRC), witness details, subject capacity assessment outcome, LAR (Legally Authorized Representative) involvement flag, and consent status (consented, withdrawn, re-consent pending, expired). This is the SSOT for subject-level consent status across the trial lifecycle.' .

ind:EconsentSession rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consent ;
    rdfs:label 'Econsent Session' ;
    rdfs:comment 'Tracks each eConsent workflow session initiated in Clinpal for a subject, including both on-site and remote/decentralized consent sessions. Captures session start and end timestamps, device type, IP address, session modality (in-person, remote via teleconference/video), communication platform for remote sessions, session recording reference, subject location, session status (in-progress, completed, abandoned, timed-out), subject authentication method, number of review steps completed, comprehension check results (question set version, individual responses, pass/fail per question, overall score, attempts, remediation steps), electronic signature capture timestamp, technical issues encountered, and Clinpal session reference ID. Supports 21 CFR Part 11, FDA remote consent guidance, and GDPR audit requirements.' .

ind:ReconsentTrigger rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consent ;
    rdfs:label 'Reconsent Trigger' ;
    rdfs:comment 'Records events that necessitate re-consent of a subject, such as a protocol amendment, new safety information, ICF version update, or regulatory authority requirement. Captures trigger type, triggering event reference (e.g., protocol amendment ID, safety letter ID), trigger date, affected ICF version, re-consent deadline, responsible site staff, and resolution status (pending, completed, waived with justification). Drives re-consent workflow management across sites.' .

ind:CapacityAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consent ;
    rdfs:label 'Capacity Assessment' ;
    rdfs:comment 'Documents the formal assessment of a subject\'s mental capacity to provide informed consent, as required by GCP and applicable regulations (e.g., ICH E6, 21 CFR 50). Records assessment date, assessor identity and role, assessment tool or method used, outcome (capable, incapable, borderline), basis for determination, LAR requirement flag, re-assessment schedule, and supporting documentation reference. Critical for vulnerable population compliance and IRB/IEC reporting.' .

ind:Withdrawal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consent ;
    rdfs:label 'Withdrawal' ;
    rdfs:comment 'Records the formal withdrawal of informed consent by a subject or their LAR. Captures withdrawal date and time, withdrawal reason category (voluntary, AE-related, sponsor decision, lost to follow-up), subject-stated reason free text, withdrawal type (full withdrawal, withdrawal from treatment only, withdrawal from data use), post-withdrawal data handling instructions per protocol, notifying staff, and downstream impact flags (e.g., safety follow-up required, data retention status). SSOT for consent withdrawal events.' .

ind:AuditEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consent ;
    rdfs:label 'Audit Entry' ;
    rdfs:comment 'Immutable audit trail record for every create, update, or status change event on consent domain records (subject consent, ICF version, eConsent session, withdrawal, etc.). Captures event timestamp, event type (created, signed, amended, withdrawn, re-consented, voided, status_changed), actor user ID and role, source system (Clinpal, Veeva Vault, CTMS), previous and new field values, applicable ICF version at time of change, digital signature hash, and IP address. Provides complete chronological consent status history per subject-study-site combination. Supports ALCOA+ data integrity requirements, 21 CFR Part 11 electronic records compliance, GCP audit trail obligations, and regulatory inspection queries about subject consent history.' .

ind:LarRepresentative rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consent ;
    rdfs:label 'Lar Representative' ;
    rdfs:comment 'Master record for a Legally Authorized Representative (LAR) associated with a trial subject who lacks capacity to consent independently. Stores LAR full name, relationship to subject, contact details, legal authority documentation type and reference, jurisdiction of authority, authorization start and end dates, and verification status. Required for pediatric trials, cognitively impaired populations, and emergency research settings per 21 CFR 50.25 and ICH E6.' .

ind:IcfAmendment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consent ;
    rdfs:label 'Icf Amendment' ;
    rdfs:comment 'Tracks amendments to an approved ICF version, capturing the amendment number, amendment date, nature of change (safety update, protocol change, administrative correction), regulatory authority requiring the amendment, IRB/IEC submission date and approval date, affected subject population (all enrolled, newly enrolling only), and re-consent obligation flag. Links to the parent ICF version and the resulting new ICF version. Supports regulatory inspection readiness and TMF completeness.' .

ind:ConsentDelegationLog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consent ;
    rdfs:label 'Consent Delegation Log' ;
    rdfs:comment 'Records the delegation of consent-related responsibilities at a site, capturing which qualified staff members (PI, sub-investigator, CRC) are authorized to conduct the informed consent process for a given study. Stores delegated role, authorization start and end dates, training completion confirmation, PI signature of delegation, scope of delegation (initial consent, re-consent, assent), and applicable ICF versions. Supports GCP delegation of authority requirements (ICH E6 R2 Section 4.2) and site inspection readiness.' .

ind:AssentRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consent ;
    rdfs:label 'Assent Record' ;
    rdfs:comment 'Captures the formal assent obtained from a minor or cognitively limited subject who is capable of providing assent but not full legal consent. Records assent date, subject age at assent, assent form version used, assent method (verbal, written, eAssent), witness details, parental/guardian consent cross-reference, and assent status. Required for pediatric clinical trials per 21 CFR 50.55, ICH E11, and applicable national regulations.' .

ind:Waiver rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consent ;
    rdfs:label 'Waiver' ;
    rdfs:comment 'Documents instances where the requirement for informed consent has been formally waived by an IRB/IEC or regulatory authority. Captures waiver type (full waiver, waiver of documentation, waiver of some elements), regulatory basis for waiver (e.g., 21 CFR 50.24 emergency research, 45 CFR 46.116), IRB/IEC approval reference, applicable subject population, waiver effective date and expiry, and conditions attached to the waiver. Critical for emergency research and retrospective data use studies.' .

ind:GdprDataConsent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consent ;
    rdfs:label 'Gdpr Data Consent' ;
    rdfs:comment 'Manages GDPR and HIPAA-specific data processing consent and privacy notice records separate from clinical trial participation consent. Captures data processing purpose categories consented to (e.g., primary research, secondary research, biobanking, data sharing with third parties), legal basis for processing, consent granularity flags per purpose, privacy notice version delivered, notice delivery date and method (paper, electronic), subject acknowledgment date, notice language and applicable jurisdiction, data subject rights exercise history (access, erasure, restriction), consent withdrawal for data processing, and HIPAA authorization details. Required for EU CTR 536/2014, GDPR Articles 7 and 13/14, and HIPAA 45 CFR 164.508 compliance.' .

ind:Translation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consent ;
    rdfs:label 'Translation' ;
    rdfs:comment 'Manages translations of ICF documents for multilingual trial sites. Records the source ICF version, target language (ISO 639-1 code), translation vendor or translator identity, translation date, back-translation completion flag, IRB/IEC approval of translated version, country/region applicability, and translation status (draft, approved, superseded). Supports global multi-site trials where ICF must be provided in subjects\' native language per GCP ICH E6 requirements.' .

ind:ConsentDeviation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Consent ;
    rdfs:label 'Consent Deviation' ;
    rdfs:comment 'Records protocol deviations specifically related to the informed consent process, such as consent obtained after study procedures began, expired ICF version used, missing witness signature, or re-consent not completed within required timeframe. Captures deviation type, discovery date, subject and site reference, root cause, impact assessment, regulatory reportability flag, CAPA reference, and resolution status. Feeds into the compliance domain\'s CAPA process and regulatory inspection readiness.' .

ind:PopulationAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subject ;
    rdfs:label 'Population Assignment' ;
    rdfs:comment 'Transactional record assigning a trial subject to one or more analysis populations (Intent-to-Treat/ITT, modified ITT/mITT, Per-Protocol/PP, Safety/SAF, Pharmacokinetic/PK) as determined by the biostatistics team during database lock. Captures population code, inclusion flag, exclusion flag with coded reason, assignment date, protocol amendment version, and statistical reviewer identity. Critical for CONSORT flow diagrams, CSR disposition tables, and regulatory submission datasets (SDTM, ADaM). Sourced from biostatistics SAS programming outputs and Oracle Clinical One.' .

ind:Demographic rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subject ;
    rdfs:label 'Demographic' ;
    rdfs:comment 'Captures subject demographic data including age, sex, race, ethnicity, height, weight, and other baseline characteristics collected at screening per CDISC DM domain standards.' .

ind:MedicalHistory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subject ;
    rdfs:label 'Medical History' ;
    rdfs:comment 'Records subject medical history and pre-existing conditions collected during screening, coded to MedDRA terms, with onset dates, resolution status, and relevance to study eligibility.' .

ind:ConcomitantMedication rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subject ;
    rdfs:label 'Concomitant Medication' ;
    rdfs:comment 'Records medications taken by subjects before and during the trial, including drug name, indication, dose, route, start/stop dates, and WHO-DD coding.' .

ind:ClinicalProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Clinical Program' ;
    rdfs:comment 'Top-level master entity representing a clinical development program — a strategic grouping of one or more clinical studies targeting a specific therapeutic indication or pipeline asset. Captures program name, program code, therapeutic area, disease indication, development phase (Phase I–IV), program type (oncology, rare disease, CNS, etc.), program status (active, on-hold, completed, terminated), program start and projected end dates, regulatory strategy summary, and the owning sponsor organization reference. This is the SSOT for program identity across the enterprise.' .

ind:ProgramMilestone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Program Milestone' ;
    rdfs:comment 'Tracks key program-level milestones and their planned versus actual achievement dates across the clinical development lifecycle. Captures milestone name, milestone type (e.g., IND filing, Phase I start, Phase II start, Phase III start, NDA/BLA submission, regulatory approval, program go/no-go decision), planned date, actual date, milestone status (pending, achieved, delayed, cancelled), responsible function, and variance commentary. Supports portfolio governance and executive reporting on program progress.' .

ind:ProgramStudy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Program Study' ;
    rdfs:comment 'Association entity representing the formal relationship between a clinical development program and the individual clinical studies (protocols) that constitute it. Captures the program-study linkage, study role within the program (pivotal, supportive, exploratory, bridging, PK/PD), study sequence number within the program, contribution to regulatory dossier flag, and the date the study was added to or removed from the program. Enables cross-study coordination and program-level portfolio views.' .

ind:Indication rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Indication' ;
    rdfs:comment 'Reference master for therapeutic indications and disease areas targeted by clinical development programs. Captures indication name, ICD-10/ICD-11 code, MedDRA preferred term mapping, therapeutic area classification, disease category, orphan disease flag, pediatric indication flag, indication status (active, retired), and regulatory precedent notes. Serves as the SSOT for indication taxonomy used across program, study, and regulatory domains.' .

ind:TherapeuticArea rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Therapeutic Area' ;
    rdfs:comment 'Reference master defining the therapeutic area taxonomy used to classify clinical development programs and pipeline assets. Captures therapeutic area name, therapeutic area code, parent therapeutic area (for hierarchy), description, and alignment to sponsor portfolio categories. Examples include Oncology, Immunology, CNS, Cardiovascular, Infectious Disease, Rare Disease. Provides standardized classification for portfolio governance and cross-program analytics.' .

ind:ProgramPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Program Plan' ;
    rdfs:comment 'Master record for the integrated development plan (IDP) or clinical development plan (CDP) associated with a clinical program. Captures plan version, plan type (initial, revised, approved), planning horizon (years), overall program strategy narrative, target product profile (TPP) reference, regulatory pathway (standard, accelerated, breakthrough, orphan), planned number of studies, planned total subjects, planned program budget envelope, plan approval date, and plan author. Tracks the strategic blueprint governing all program activities.' .

ind:Amendment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Amendment' ;
    rdfs:comment 'Tracks formal amendments and revisions to the clinical development plan (CDP) for a program. Captures amendment number, amendment date, amendment type (scope change, timeline revision, budget revision, regulatory strategy update), description of changes, rationale, impact assessment, approval status, approver identity, and effective date. Maintains a complete version history of program plan evolution for governance and audit purposes.' .

ind:Governance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Governance' ;
    rdfs:comment 'Master record for program-level governance bodies and oversight committees established to manage a clinical development program. Captures governance body name, type (Joint Development Committee, Program Review Board, Portfolio Review Committee, Steering Committee), charter reference, meeting frequency, quorum requirements, decision authority scope, member composition summary, formation date, and dissolution date. Supports formal program oversight and sponsor-CRO governance structures.' .

ind:GovernanceMeeting rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Governance Meeting' ;
    rdfs:comment 'Transactional record for each formal program governance meeting held by a program oversight committee. Captures meeting date, meeting type (scheduled, ad hoc, emergency), agenda topics, attendees, quorum achieved flag, key decisions made, action items raised, minutes document reference, and next meeting date. Distinct from sponsor.governance_meeting which tracks sponsor-CRO commercial governance; this entity tracks internal program scientific and operational governance.' .

ind:Decision rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Decision' ;
    rdfs:comment 'Transactional record capturing formal go/no-go and key strategic decisions made at the program level, including portfolio investment decisions, phase transition approvals, and program termination decisions. Captures decision date, decision type (go/no-go, phase transition, indication expansion, program termination, regulatory strategy pivot), decision outcome, decision rationale, supporting data summary, decision authority (governance body or executive), and decision record reference. Critical for program lifecycle governance and regulatory dossier traceability.' .

ind:Timeline rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Timeline' ;
    rdfs:comment 'Master record for the integrated program-level timeline, capturing the overall schedule baseline and current forecast for a clinical development program. Captures timeline version, baseline start date, baseline end date, current forecast start date, current forecast end date, critical path summary, schedule variance (days), timeline status (on-track, at-risk, delayed), last updated date, and timeline owner. Provides the program-level scheduling backbone from which study-level timelines are derived.' .

ind:TimelineEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Timeline Event' ;
    rdfs:comment 'Transactional record for individual scheduled events and deliverables within a program timeline. Captures event name, event type (study start, database lock, regulatory submission, advisory committee meeting, approval decision, program review), planned date, forecast date, actual date, event status (planned, in-progress, completed, delayed, cancelled), predecessor event reference, and schedule variance in days. Enables granular tracking of program schedule performance and critical path management.' .

ind:Risk rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Risk' ;
    rdfs:comment 'Master record for program-level risks identified through risk management processes. Captures risk identifier, risk category (scientific, regulatory, operational, competitive, financial, safety), risk description, probability rating, impact rating, risk score, risk owner, mitigation strategy, contingency plan, risk status (open, mitigated, closed, accepted), identification date, and last review date. Supports proactive program risk management and portfolio governance reporting.' .

ind:RiskMitigation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Risk Mitigation' ;
    rdfs:comment 'Transactional record capturing individual risk mitigation actions and their execution status for program-level risks. Captures mitigation action description, action owner, planned completion date, actual completion date, action status (planned, in-progress, completed, overdue), effectiveness assessment, and residual risk level after mitigation. Enables tracking of risk response execution and effectiveness evaluation within the program risk management framework.' .

ind:Assumption rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Assumption' ;
    rdfs:comment 'Master record for key planning assumptions underlying the clinical development plan and program timeline. Captures assumption description, assumption category (enrollment rate, regulatory timeline, safety profile, competitive landscape, manufacturing readiness), assumption owner, confidence level, sensitivity to program outcome (high/medium/low), validation status, validation date, and assumption review frequency. Tracks the dependency assumptions that, if invalidated, would trigger program plan revisions.' .

ind:CrossStudyDependency rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Cross Study Dependency' ;
    rdfs:comment 'Association entity capturing formal dependencies between studies within a program or across programs where one study\'s outcome, data, or completion gates another study\'s initiation or design. Captures dependency type (data dependency, safety dependency, regulatory dependency, supply dependency, sequential design), predecessor study reference, successor study reference, dependency description, dependency status (active, resolved, waived), and impact if dependency is not met. Critical for integrated program planning and risk management.' .

ind:ProgramResourcePlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Program Resource Plan' ;
    rdfs:comment 'Master record for program-level resource planning, capturing the aggregate workforce and functional resource requirements across all studies in a program. Captures resource plan version, planning period, functional area (clinical operations, data management, biostatistics, regulatory affairs, medical monitoring), planned FTE count, forecasted FTE count, resource gap, resource plan status, and approval date. Distinct from workforce.resource_plan which is study-level; this entity manages cross-study program-level resource aggregation and planning.' .

ind:Budget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Budget' ;
    rdfs:comment 'Master record for the program-level budget envelope governing total financial investment across all studies and activities within a clinical development program. Captures budget version, total approved budget, budget by phase (Phase I, II, III), budget by functional area, currency, budget status (draft, approved, revised), approval date, and budget owner. Distinct from finance.study_budget which is study-level; this entity owns the program-level financial envelope and cross-study budget governance.' .

ind:ProgramStatusHistory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Program Status History' ;
    rdfs:comment 'Lifecycle history table tracking every formal status transition of a clinical development program from initiation through completion or termination. Captures previous status, new status, transition date, transition reason, triggering event (governance decision, regulatory action, sponsor directive), and the identity of the person or system that recorded the transition. Provides a complete audit trail of program lifecycle state changes for governance and regulatory inspection readiness.' .

ind:TeamMember rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Team Member' ;
    rdfs:comment 'Association entity capturing the assignment of key personnel to a clinical development program in defined program-level roles. Captures the workforce member reference, program role (Program Director, Medical Director, Regulatory Lead, Biostatistics Lead, Clinical Operations Lead, Data Management Lead), assignment start date, assignment end date, FTE allocation percentage, primary contact flag, and assignment status. Distinct from workforce.study_assignment which is study-level; this entity manages program-level leadership and cross-study team composition.' .

ind:ProgramCommunication rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Program Communication' ;
    rdfs:comment 'Transactional record for formal program-level communications issued to stakeholders including sponsors, health authorities, and internal leadership. Captures communication date, communication type (program update, milestone notification, risk escalation, regulatory intelligence update, program termination notice), recipient audience, communication channel (email, formal letter, governance meeting), subject summary, communication owner, and acknowledgement status. Supports program transparency and stakeholder management.' .

ind:CompetitiveIntelligence rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Competitive Intelligence' ;
    rdfs:comment 'Master record for competitive intelligence entries tracked at the program level, capturing the competitive landscape for the therapeutic indication being developed. Captures competitor company, competitor asset name, competitor development phase, indication overlap, mechanism of action, key differentiators, data readout dates, regulatory status, commercial threat level, intelligence source, and last updated date. Informs program strategy, TPP refinement, and go/no-go decision-making.' .

ind:Kri rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Kri' ;
    rdfs:comment 'Master record defining Key Risk Indicators (KRIs) and Key Performance Indicators (KPIs) monitored at the program level for portfolio governance. Captures indicator name, indicator type (KRI or KPI), metric definition, measurement unit, target threshold, warning threshold, critical threshold, measurement frequency, data source, responsible owner, and indicator status. Provides the program-level performance monitoring framework used in governance meetings and portfolio reviews. NOTE: This is the DEFINITION of the indicator, not the computed value — no analytics or aggregations are stored here.' .

ind:KriReading rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Program ;
    rdfs:label 'Kri Reading' ;
    rdfs:comment 'Transactional record capturing periodic observed readings of program-level KRIs and KPIs against their defined thresholds. Captures the KRI reference, reading date, observed value, threshold status (green/amber/red), trend direction, data source snapshot reference, and any commentary on the reading. Stores the raw operational measurement events — not aggregated analytics — enabling governance committees to review program health at each review cycle.' .

ind:EthicsCommittee rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Ethics Committee' ;
    rdfs:comment 'Master record for each IRB or IEC body providing ethical oversight for clinical trials, capturing committee name, type, jurisdiction, and accreditation status' .

ind:EthicsSubmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Ethics Submission' ;
    rdfs:comment 'Tracks each formal submission package sent to an IRB or IEC for a specific study, including initial review, amendments, and continuing review submissions' .

ind:EthicsApproval rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Ethics Approval' ;
    rdfs:comment 'Records the formal approval decision issued by an IRB or IEC for a study protocol, ICF, or amendment including approval conditions and expiry dates' .

ind:ContinuingReview rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Continuing Review' ;
    rdfs:comment 'Manages the periodic continuing review process required by IRBs/IECs to ensure ongoing ethical conduct of a study' .

ind:EthicsCorrespondence rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Ethics Correspondence' ;
    rdfs:comment 'Captures all formal written communications between the sponsor/CRO and ethics committees including queries, clarifications, and notifications' .

ind:VulnerablePopulation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Vulnerable Population' ;
    rdfs:comment 'Tracks special ethical protections and safeguards applied to studies enrolling vulnerable populations including pediatric, pregnant, and cognitively impaired subjects' .

ind:IrbReliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Irb Reliance' ;
    rdfs:comment 'Records single-IRB reliance agreements and authorization agreements between reviewing IRBs and relying institutions under the Common Rule' .

ind:ProgramTeamMember rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Program Team Member' ;
    rdfs:comment 'This association product represents the Role-based assignment between an employee and a clinical_program. It captures the operational team membership record that the CRO actively manages for each employee-program pairing, including the employee\'s functional GCP role on the program, FTE allocation, delegation authority, GCP certification status at assignment time, and the full lifecycle of the assignment. Each record links one employee to one clinical_program with attributes that exist only in the context of this specific assignment relationship. This is the SSOT for program team composition and workforce allocation across the clinical development portfolio.. Existence Justification: In clinical research operations, employees (CRAs, Medical Monitors, Data Managers, etc.) are actively assigned to multiple clinical programs simultaneously, and each clinical program has a team of many employees in distinct functional roles. This is a core operational reality in CROs — a Medical Monitor may oversee 3 oncology programs concurrently, while a single program may have 15+ staff across CRA, CRC, biostatistics, and regulatory functions. The business actively manages these assignments with role designations, FTE allocations, delegation authority levels, and GCP certification status per assignment — this is not derivable from transactional data but is an explicitly managed operational record.' .

ind:AmendmentSiteImplementation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Study ;
    rdfs:label 'Amendment Site Implementation' ;
    rdfs:comment 'This association product represents the Event between study_protocol_amendment and study_site. It captures the formal process by which each protocol amendment is communicated to, acknowledged by, and operationally implemented at a specific investigational site. Each record links one protocol amendment to one study site and carries implementation-specific attributes — status, dates, reconsent completion, and EDC update confirmation — that exist only in the context of this amendment-site pairing and belong to neither entity alone.. Existence Justification: In clinical trials, every protocol amendment must be formally implemented at each active investigational site — a site receives multiple amendments over a study\'s lifecycle, and each amendment must be tracked for implementation status, notification, and reconsent completion at every site independently. This is an operationally managed process: CRAs actively create, update, and close out amendment implementation records per site, making \'AmendmentSiteImplementation\' a genuine business entity that clinical operations teams manage daily. The relationship carries its own rich data (implementation_status, implementation_date, notification_date, reconsent_completed_flag, edc_configuration_updated_flag, implementation_deadline) that belongs to neither the amendment nor the site alone.' .

ind:IbSiteDistribution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Ib Site Distribution' ;
    rdfs:comment 'This association product represents the IB Distribution Log event between investigational_site and investigator_brochure_safety. It captures the GCP-mandated record of each Investigator Brochure version distributed to each investigational site, including receipt confirmation, distribution method, and IRB/IEC notification tracking. Each record links one investigational_site to one investigator_brochure_safety version and carries attributes that exist only in the context of this site-specific distribution event.. Existence Justification: In clinical trials, an Investigator Brochure (IB) version is distributed to every active investigational site participating in the relevant study — one IB version goes to many sites. Simultaneously, a single site receives multiple IB versions over the lifecycle of a study (initial version, safety amendments, annual updates). The business actively manages this distribution as a GCP-mandated essential document process called the \'IB Distribution Log\', tracking per-site receipt confirmation, distribution method, and IRB/IEC notification obligations for each IB version delivered to each site.' .

ind:RegulatoryEngagement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Regulatory Engagement' ;
    rdfs:comment 'This association product represents the Contract/Strategy between a clinical_program and a health_authority. It captures the agency-specific regulatory engagement plan for a given clinical development program — including submission strategy, target dates, regulatory pathway, and priority designations that are unique to each program-authority pairing. Each record links one health_authority to one clinical_program with attributes that exist only in the context of this relationship and cannot reside on either master entity alone.. Existence Justification: In clinical research, a single clinical program (e.g., an oncology asset targeting multiple markets) is actively submitted to multiple health authorities simultaneously — FDA, EMA, PMDA, MHRA — each with its own submission strategy, regulatory pathway, target dates, and interaction plan. Conversely, each health authority oversees many clinical programs from many sponsors. The business actively manages this relationship as a named operational concept: a \'Regulatory Submission Strategy\' or \'Program-Agency Engagement\', with agency-specific data (submission dates, pathways, priority designations) that belongs to neither entity alone.' .

ind:SponsorSiteQualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Sponsor Site Qualification' ;
    rdfs:comment 'This association product represents the formal qualification and relationship contract between an investigational_site and a sponsor organization. It captures the operational record of a sponsor\'s qualification, rating, and preferred-network designation of a specific site — data that exists only in the context of this sponsor-site pairing. Each record links one investigational_site to one organization and tracks the qualification status, performance history, and preferred-site designation that the sponsor actively manages as part of their site network strategy.. Existence Justification: In clinical trials operations, investigational sites actively work with multiple sponsor organizations simultaneously across different studies, and each sponsor organization maintains relationships with dozens to hundreds of sites across their trial portfolio. This is not an analytical correlation — sponsors actively manage a \'qualified site roster\' or \'preferred site network\' as an operational business concept, tracking each site\'s qualification status, performance rating, and preferred-site designation per sponsor. The relationship itself carries meaningful data (qualification status, performance rating, relationship start date, historical study count) that belongs to neither the site nor the sponsor alone.' .

ind:LabQualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Laboratory ;
    rdfs:label 'Lab Qualification' ;
    rdfs:comment 'This association product represents the formal qualification and engagement contract between a lab_facility and a clinical_program. It captures the sponsor-approved, program-specific qualification of a laboratory facility to perform defined specimen analyses for a clinical development program. Each record links one lab_facility to one clinical_program and carries attributes — qualification status, approval dates, scope of services, and contract reference — that exist only in the context of this program-facility relationship and cannot reside on either master entity alone.. Existence Justification: In clinical trials operations, a clinical program selects and qualifies multiple laboratory facilities (central lab, PK lab, biomarker lab, etc.) to support its studies, and each lab facility simultaneously serves multiple clinical programs across different sponsors and therapeutic areas. This is an actively managed vendor oversight relationship — sponsors and CROs formally qualify labs per program, track approval status, define scope of services, and maintain contract references for each program-facility pairing. The relationship is a recognized operational business concept in clinical procurement and vendor management.' .

ind:PanelComposition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Laboratory ;
    rdfs:label 'Panel Composition' ;
    rdfs:comment 'This association product represents the formal composition contract between a lab_panel and its constituent lab_analytes. It captures the version-controlled membership of each analyte within a panel as actively managed by lab directors and protocol teams. Each record links one lab_panel to one lab_analyte and carries attributes that exist only in the context of this panel-analyte relationship: the analyte\'s position in the panel, its required/optional status, its specimen volume contribution, its reporting inclusion, and the effective date range of its membership. This is the authoritative source for panel composition used in LIMS configuration, SDTM LB domain mapping, and protocol amendment tracking.. Existence Justification: In clinical laboratory operations, a test panel is formally defined as a named collection of specific analytes — a CBC panel contains hemoglobin, hematocrit, WBC, platelets, etc., while a CMP panel contains glucose, BUN, creatinine, electrolytes, etc. This composition is actively managed by lab directors and protocol teams, is version-controlled per protocol amendment, and is a recognized concept in LIMS systems and CDISC SDTM LB domain modeling. One panel contains many analytes, and one analyte (e.g., Sodium) appears in many panels (CMP, BMP, Electrolyte Panel) — this is a genuine operational M:N with full reciprocity. The relationship carries its own data: sequence order within the panel, whether the analyte is required vs. optional, minimum volume contribution, reporting flags, and effective dates for version control.' .

ind:SowLabPanelRequirement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Laboratory ;
    rdfs:label 'Sow Lab Panel Requirement' ;
    rdfs:comment 'This association product represents the Contract between scope_of_work and lab_panel in clinical research operations. It captures the formal contractual inclusion of a specific laboratory test panel within a Scope of Work, recording the negotiated terms (unit price, turnaround commitment, visit applicability) that govern how the CRO will deliver that panel for the study. Each record links one scope_of_work to one lab_panel with attributes that exist only in the context of this contractual relationship — they are neither properties of the panel catalog nor of the SOW document alone.. Existence Justification: In clinical research operations, a Scope of Work (SOW) contractually specifies which laboratory panels the CRO will perform for a given study, and a single lab panel (e.g., a CBC safety panel or PK panel) can appear across many different SOWs for different studies or sponsors. The business actively manages this relationship as a \'contracted lab panel requirement\' — negotiating unit pricing, turnaround commitments, and visit applicability per panel per SOW. This is not derivable from transactional data; it is a contractual record created during SOW authoring and updated during amendments.' .

ind:PiQualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Pi Qualification' ;
    rdfs:comment 'This association product represents the Qualification relationship between a Principal Investigator and a Sponsor Organization. It captures the formal regulatory approval process by which a sponsor certifies a PI as eligible to conduct studies under their IND portfolio. Each record links one Principal Investigator to one Sponsor Organization and carries attributes that exist only in the context of that specific sponsor-PI qualification relationship, including approval status, therapeutic area scope, performance history, and compliance verification dates.. Existence Justification: In clinical research, a Principal Investigator is formally qualified and approved by each sponsor organization independently before being permitted to conduct studies for that sponsor. A single PI may be qualified by multiple sponsors (e.g., Pfizer, Roche, Novartis) simultaneously, and each sponsor maintains a roster of many qualified PIs. This is an actively managed regulatory process — sponsors track debarment status, GCP compliance, therapeutic area approvals, and performance ratings per PI, and the qualification must be renewed or revoked independently per sponsor.' .

ind:CommitteeMembership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Committee Membership' ;
    rdfs:comment 'This association product represents the Role-based membership between safety_review_committee and employee. It captures the formal appointment of a workforce member to a safety oversight committee (SRC, DSMB, DMC, or IDMC), including their designated role, tenure, voting rights, independence attestation, and conflict-of-interest status. Each record links one safety_review_committee to one employee and carries attributes that exist only in the context of that specific appointment — required for regulatory charter compliance, audit trails, and ICH E6 GCP documentation.. Existence Justification: In clinical research, a Safety Review Committee (SRC/DSMB/DMC) is constituted by multiple employee members (chair, statistician, clinicians, medical monitors), and a single employee can serve on multiple committees across different studies simultaneously or sequentially. The business actively manages each membership as a distinct operational record — tracking the member\'s role, voting rights, independence status, conflict-of-interest declarations, and tenure dates — all of which are required for regulatory charter compliance and audit trails. This is a textbook operational M:N: humans create, update, and terminate membership records as part of committee governance processes.' .

ind:BudgetAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Budget Allocation' ;
    rdfs:comment 'This association product represents the Contract between supply_plan and budget_line. It captures the operational mapping maintained by clinical supply finance teams that links specific supply plan versions to granular budget line items, tracking the quantity, unit cost, cost category, time period, and variance for each allocation. Each record links one supply_plan to one budget_line with attributes that exist only in the context of this financial-operational reconciliation relationship.. Existence Justification: In clinical trial operations, a supply plan covers multiple cost categories (manufacturing, packaging, distribution, destruction) each represented as distinct budget lines, while a single budget line (e.g., IMP manufacturing) is informed by and allocated across multiple supply plan versions as the study evolves through amendments and planning cycles. Clinical supply finance teams actively maintain and manage this supply plan-to-budget line mapping as a recognized operational artifact, tracking quantity allocations, unit costs, and variances per pairing. This is not an analytical derivation — it is an actively managed financial-operational reconciliation record that bridges supply planning and study budgeting.' .

ind:SignalCaseContribution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Signal Case Contribution' ;
    rdfs:comment 'This association product represents the Signal Case Contribution event between adverse_event and safety_signal. It captures the formal pharmacovigilance process by which individual adverse event case reports are linked to safety signals as contributing evidence, tracking when each case was included, its statistical weight, and its inclusion status across evaluation cycles. Each record links one adverse_event to one safety_signal with attributes that exist only in the context of this case-to-signal contribution relationship, as governed by ICH E2E and implemented in Oracle Argus Safety.. Existence Justification: In clinical pharmacovigilance, safety signal detection is explicitly an aggregation process where multiple individual adverse event cases (ICSRs) contribute evidence to a single safety signal, and a single adverse event case can contribute to multiple signals (e.g., a hepatotoxicity AE may contribute to both a \'liver injury\' signal and a \'drug-induced liver disease\' signal). This is a formally recognized operational process governed by ICH E2E and implemented in Oracle Argus Safety, where pharmacovigilance teams actively manage which cases are included in each signal evaluation cycle. The relationship itself carries operationally meaningful data: when the case was included, whether it was flagged as contributing, which detection cycle it belongs to, and its statistical weight — none of which belong on the AE record or the signal record alone.' .

ind:DsurLineListing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Dsur Line Listing' ;
    rdfs:comment 'This association product represents the regulatory inclusion of a SUSAR within a specific Development Safety Update Report (DSUR). It captures the ICH E2F-mandated line listing relationship between a periodic safety report and individual SUSAR cases, recording whether each case is new in the reporting period or a cumulative carry-forward, which line listing section it appears in, and how it contributes to the DSUR\'s aggregate counts. Each record links one DSUR to one SUSAR with attributes that exist only in the context of this regulatory inclusion decision. Sourced from Oracle Argus Safety periodic reporting module line listing outputs.. Existence Justification: ICH E2F guidelines mandate that DSURs include explicit line listings of all SUSARs occurring during the reporting period AND cumulative summaries across all periods. A single DSUR covers multiple SUSARs (all cases in the reporting period), and a single SUSAR can appear in multiple DSURs (e.g., initial report in one DSUR, follow-up in the next annual period). This is an operationally managed regulatory artifact — safety teams actively curate which SUSARs are included in each DSUR, whether they are new in the period or carry over cumulatively, and in which line listing section they appear.' .

ind:ContractedSupplyItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Contracted Supply Item' ;
    rdfs:comment 'This association product represents the Contract between imp_master and study_contract. It captures the specific terms under which a given investigational medicinal product is included in the supply scope of a Clinical Trial Agreement — recording the supply role, contracted quantity, unit price, and validity window for each IMP-contract pairing. Each record links one imp_master to one study_contract with attributes that exist only in the context of this contractual supply relationship.. Existence Justification: In clinical trials, a single IMP (e.g., a novel oncology compound) is routinely supplied across multiple study contracts — different studies, different sponsors, different CROs — while a single study contract (CTA) almost always covers multiple IMPs: the investigational product, an active comparator, and a placebo. The business actively manages this relationship as a \'contracted supply item\' or \'IMP supply scope\' within each CTA, tracking contracted quantities, unit pricing, and the supply role (IMP vs. comparator vs. placebo) per IMP per contract. This is not derivable from transactional data; it is an operational record that procurement and supply chain teams create, negotiate, and update throughout the contract lifecycle.' .

ind:ImpAuthorization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Imp Authorization' ;
    rdfs:comment 'This association product represents the regulatory authorization contract between an investigational medicinal product (imp_master) and a Clinical Trial Authorization (clinical_trial_authorization). It captures the specific terms under which a given IMP is authorized for use within a given CTA in a given EU member state jurisdiction, including authorized quantities, effective dates, and authorization status at the IMP level. Each record links one imp_master to one clinical_trial_authorization with attributes that exist only in the context of this IMP-CTA regulatory pairing, supporting EU CTR 536/2014 compliance and multi-country supply planning.. Existence Justification: In EU clinical trial operations, a single IMP (e.g., a monoclonal antibody) requires separate CTAs filed in each EU member state where the trial runs, meaning one IMP is covered by many CTAs. Conversely, a single CTA for a combination product or multi-arm trial can authorize multiple IMPs simultaneously. The business actively manages this relationship as a regulatory compliance record — tracking authorized quantities, effective dates, and authorization status per IMP-per-CTA combination — which is a named concept in EU CTR 536/2014 regulatory practice.' .

ind:ProtocolEthicsCoverage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Protocol Ethics Coverage' ;
    rdfs:comment 'This association product represents the regulatory-compliance contract between an IND application and an ethics submission. It captures which specific protocol (by number and version) under a given IND application is covered by a given IRB/IEC ethics submission, including the IND serial number amendment referenced. Each record links one ind_application to one ethics_submission and carries attributes that exist only in the context of this protocol-level regulatory linkage — enabling sponsors and regulatory teams to answer \'which ethics submissions cover which IND protocols?\' and \'which IND serial numbers are referenced by this ethics submission?\'. Existence Justification: In clinical trials, a single IND application covers multiple protocols, each of which requires its own ethics submission to an IRB/IEC — so one IND application is associated with many ethics submissions. Conversely, a single ethics submission (particularly an amendment or continuing review) may reference multiple IND serial numbers or cover protocols under different IND applications, meaning one ethics submission can be associated with multiple IND applications. The business actively tracks which ethics submissions are linked to which IND protocols/serial numbers as part of regulatory compliance management, and this linkage carries its own data (protocol number, protocol version, IND serial number, submission date, ethics committee name).' .

ind:IpSiteAccountability rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Study ;
    rdfs:label 'Ip Site Accountability' ;
    rdfs:comment 'This association product represents the regulatory and operational contract between an investigational product and an investigational site. It captures the per-site authorization, storage compliance, dispensing status, and drug accountability obligations mandated by GCP and 21 CFR 312.62. Each record links one investigational_product to one investigational_site and carries attributes that exist only in the context of that specific IMP-site relationship — they cannot reside on the IMP master or site master alone.. Existence Justification: In clinical trials, an investigational product (IMP) is shipped to and stored at multiple investigational sites simultaneously across a study, and each site handles multiple IMPs across different studies. The business actively manages per-site IMP authorization, storage compliance, dispensing authorization, and accountability — all of which are GCP and regulatory requirements (21 CFR 312.62) that constitute a named, operationally managed relationship. This is not an analytical correlation; clinical operations teams create, update, and audit these records throughout the trial lifecycle.' .

ind:StaffRoster rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Staff Roster' ;
    rdfs:comment 'This association product represents the Role-based assignment between investigational_site and employee. It captures the operational record of each staff member assigned to an investigational site, including their functional role, assignment period, GCP compliance status for that site, and delegation of authority log reference. Each record links one investigational_site to one employee and carries attributes that exist only in the context of that specific staff-site assignment. This is the system of record for site staffing in clinical operations.. Existence Justification: In clinical research operations, an investigational site employs or hosts multiple staff members (CRAs, monitors, site coordinators) simultaneously, and each employee can be assigned to multiple investigational sites across different studies. The business actively manages this relationship as a \'site staff roster\' — a named operational concept in clinical operations — tracking each staff member\'s role at a site, their assignment dates, GCP training currency, and delegation log references, none of which belong to either the site or the employee record alone.' .

ind:Specialization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Specialization' ;
    rdfs:comment 'This association product represents the Specialization Role between investigational_site and therapeutic_area. It captures the operational qualification profile of an investigational site within a specific therapeutic area, as assessed and maintained by clinical operations teams for site feasibility and selection workflows. Each record links one investigational_site to one therapeutic_area and carries attributes — specialization level, certification status, years of experience, active study count, and last assessment date — that exist only in the context of this site-TA pairing and cannot reside on either master record alone.. Existence Justification: In clinical research operations, an investigational site genuinely specializes in multiple therapeutic areas simultaneously (e.g., a major academic medical center may be qualified in Oncology, Immunology, AND CNS), and each therapeutic area has many qualified sites across the network. Clinical operations teams actively manage site-TA specialization profiles as a distinct business concept used in site feasibility and selection workflows — this is not derivable from transactional data but is a maintained operational record. The relationship carries its own attributes (specialization level, certification status, years of experience, active study count in TA, last assessed date) that belong to neither the site nor the therapeutic area alone.' .

ind:ProgramSiteParticipation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Program Site Participation' ;
    rdfs:comment 'This association product represents the Program Site Participation between investigational_site and clinical_program. It captures the operational engagement of an investigational site within a clinical development program — a recognized portfolio strategy concept in sponsor and CRO operations used to manage preferred site lists, track historical enrollment performance by program, and plan future study activations. Each record links one investigational_site to one clinical_program and carries attributes that exist only in the context of that site-program relationship, such as participation status, preferred site designation, and cumulative enrollment history.. Existence Justification: In clinical research operations, an investigational site actively participates in multiple clinical programs over its lifetime (e.g., a major academic medical center may simultaneously run oncology, CNS, and rare disease programs for the same or different sponsors), and a clinical program engages multiple investigational sites across its constituent studies. Sponsors and CROs explicitly manage \'preferred site lists\' and \'site-program participation history\' as operational portfolio strategy concepts — this is not derivable from transactional joins but is actively curated. The relationship carries its own operational data (participation status, enrollment counts, preferred site flags, first study start dates) that belongs to neither the site master nor the program master alone.' .

ind:LabServiceContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Laboratory ;
    rdfs:label 'Lab Service Contract' ;
    rdfs:comment 'This association product represents the Contract between lab_facility and study_budget. It captures the facility-specific financial and operational terms under which a laboratory facility is engaged to perform specimen analysis services for a specific study budget. Each record links one lab_facility to one study_budget with attributes — contracted rate, service scope, effective dates, and amendment tracking — that exist only in the context of this study-facility contractual relationship. Serves as the operational record for lab vendor cost management, sponsor invoicing reconciliation, and budget variance analysis at the facility level.. Existence Justification: In clinical trials operations, a lab facility (e.g., a central lab or bioanalytical lab) is contracted to serve multiple studies — each with its own budget, contracted rates, service scope, and amendment history. Conversely, a single study budget allocates funds across multiple lab facilities (central lab, local labs, PK lab), each under distinct contractual terms. This relationship is actively managed by finance and lab operations teams as a \'Lab Service Contract\' or \'Lab Budget Allocation\', carrying facility-specific contracted rates, service scope, effective dates, and amendment numbers that belong to neither the facility master record nor the budget master record alone.' .

ind:LabelApproval rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Label Approval' ;
    rdfs:comment 'This association product represents the formal approval event between a labeling_document version and a country_registration. It captures the regulatory act by which a health authority approves a specific labeling document version as the valid label for a product registration in a given country. Each record links one labeling_document to one country_registration and carries the country-specific approval status, effective dates, and health authority decision data that exist only in the context of this country-level label approval — not on the document or registration alone.. Existence Justification: In global regulatory affairs, a single labeling document (e.g., a Core Company Data Sheet or SmPC) is formally approved and in effect across multiple country registrations simultaneously, each with its own approval date, effective date, and status. Conversely, a single country registration tracks multiple labeling document versions over its lifecycle as the label is updated through variations and renewals. The business actively manages which specific label version is approved in each country — this is a recognized operational process called \'label approval\' or \'labeling registration\' in global regulatory operations.' .

ind:BinderDocumentInclusion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Binder Document Inclusion' ;
    rdfs:comment 'This association product represents the inclusion contract between a labeling_document and a regulatory_binder. It captures the operational act of assembling a regulatory submission binder by including specific labeling document versions, recording where each document is filed within the CTD structure, whether inclusion is mandatory, and any submission-specific handling requirements such as redaction. Each record links one labeling_document to one regulatory_binder with attributes that exist only in the context of this inclusion relationship.. Existence Justification: In clinical regulatory operations, a labeling document (e.g., a USPI or SmPC) is genuinely included in multiple regulatory binders — the original NDA submission, subsequent supplements, annual reports, and amendments — while each binder contains multiple labeling documents covering different languages, CTD modules, and document types. This is an operationally managed relationship: regulatory affairs teams actively assemble binders by selecting and including specific labeling document versions, tracking which documents are mandatory, their CTD section placement, and whether redaction is required. The relationship is a recognized business concept in regulatory document management, commonly called a \'Binder Inclusion\' or \'Document Inclusion\'.' .

ind:DossierEthicsReference rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Dossier Ethics Reference' ;
    rdfs:comment 'This association product represents the formal inclusion of an ethics approval record within an NDA/BLA (or equivalent) application dossier. It captures the regulatory affairs act of citing a specific IRB/IEC ethics approval as supporting evidence within a marketing authorization application, including the CTD module where it is filed, the rationale for its inclusion, and the scope of the approval as it applies to the application. Each record links one nda_bla_application to one ethics_approval with attributes that exist only in the context of this dossier-level citation relationship.. Existence Justification: In clinical trials regulatory submissions, an NDA/BLA application dossier is built from evidence across multiple clinical studies, each of which has its own IRB/IEC ethics approval — so one application references many ethics approvals. Conversely, a pivotal study\'s ethics approval (e.g., a Phase III trial) can be cited in both an original NDA and a subsequent supplemental NDA (sNDA) or even a related BLA, meaning one ethics approval supports multiple applications. The business actively manages this linkage as part of dossier assembly, tracking which ethics approvals are included in which CTD module and why.' .

ind:SubstantialModificationSubmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Substantial Modification Submission' ;
    rdfs:comment 'This association product represents the regulatory submission event between a protocol_amendment and a clinical_trial_authorization. It captures the per-member-state, per-amendment submission workflow required under EU CTR 536/2014 and equivalent national frameworks, where each protocol amendment must be formally submitted to and approved by each national competent authority holding a CTA for the trial. Each record links one protocol_amendment to one clinical_trial_authorization and carries the country-specific submission date, approval date, decision outcome, and modification scope that exist only in the context of this specific amendment-to-authority submission.. Existence Justification: Under EU CTR 536/2014, every substantial protocol amendment must be submitted as a separate modification to each national competent authority\'s CTA in each member state where the trial is running. A single protocol amendment (e.g., AM-003) generates distinct CTA modification submissions to Germany, France, Spain, etc., each with its own submission date, approval date, decision outcome, and member-state-specific conditions. Conversely, a single CTA accumulates multiple substantial modifications over the trial lifecycle as successive protocol amendments are approved. This is a genuine operational M:N: the business actively creates, tracks, and queries each amendment-to-CTA submission as a named regulatory workflow record.' .

ind:SignalNotification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Signal Notification' ;
    rdfs:comment 'This association product represents the regulatory notification Event between a safety_signal and a health_authority. It captures the operational record of a specific safety signal being reported to a specific health authority, including submission details, authority-specific required actions, and response tracking. Each record links one safety_signal to one health_authority and carries attributes that exist only in the context of that specific notification — they cannot reside on the signal master record (which is authority-agnostic) nor on the health authority reference record (which is signal-agnostic).. Existence Justification: In clinical trials pharmacovigilance, a single safety signal (e.g., potential hepatotoxicity detected via disproportionality analysis) must be reported to multiple health authorities simultaneously — FDA, EMA, PMDA, MHRA — each with its own notification deadline, submission reference, and response tracking. Conversely, each health authority receives and tracks many safety signals across all studies and sponsors. The business actively manages these notifications as operational records: safety teams create them, update their status, record agency responses, and audit them for regulatory compliance. This is a textbook operational M:N with rich relationship-specific data.' .

ind:EngagementContactAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsor ;
    rdfs:label 'Engagement Contact Assignment' ;
    rdfs:comment 'This association product represents the formal Role assignment between a sponsor_contact and an engagement. It captures the operational record of which sponsor personnel are assigned to a CRO commercial engagement, in what functional capacity, and for what period. Each record links one sponsor_contact to one engagement with attributes — role, effective dates, primary flag, and status — that exist only in the context of this specific assignment and cannot correctly reside on either the contact or the engagement alone.. Existence Justification: In CRO operations, sponsor contacts are formally assigned to commercial engagements in specific roles (medical monitor, project manager, regulatory lead, financial approver). A single contact — such as a VP of Clinical Operations — routinely spans multiple engagements simultaneously, and each engagement requires multiple contacts across different functional roles. The business actively manages these assignments as named records with effective dates, role designations, and primary-contact flags that belong to neither the contact nor the engagement alone.' .

ind:CountrySubmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Study ;
    rdfs:label 'Country Submission' ;
    rdfs:comment 'This association product represents the regulatory filing event between a study_country and a regulatory submission. It captures the operational record of a specific submission being filed with or applicable to a specific country\'s regulatory authority within a clinical study. Each record links one study_country to one submission and carries attributes that exist only in the context of that country-submission pairing — such as the national sequence number, country-specific filing date, and national authority acknowledgement. Managed by regulatory affairs teams as part of the country-level dossier lifecycle.. Existence Justification: In clinical trials, a single regulatory submission (e.g., a CTA package) can cover multiple countries simultaneously, and a single country\'s study activation requires multiple discrete submissions over time (initial CTA filing, substantial amendments, annual safety reports, responses to agency queries). The business actively manages and tracks each country-submission pairing as an operational record — regulatory affairs teams create, update, and close these records as part of the regulatory lifecycle. This is not an analytical correlation derivable from joins; it is a first-class operational entity that regulatory operations teams manage daily.' .

ind:SignalReview rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Signal Review' ;
    rdfs:comment 'This association product represents the Site Signal Review event between study_site and safety_signal. It captures the operational process by which a medical monitor or safety team evaluates a specific safety signal in the context of a specific investigational site — recording site-level case counts, risk assessments, required actions, and review outcomes. Each record links one study_site to one safety_signal and carries attributes that exist only in the context of this site-specific signal evaluation. Supports regulatory traceability for site-level safety actions and DSMB/DMC reporting.. Existence Justification: In clinical trials, a safety signal is typically detected at the study level but must be evaluated across all participating sites — a single signal (e.g., hepatotoxicity) may implicate multiple study sites with differing case counts and require site-specific risk assessments and actions. Conversely, a single study site may be implicated in multiple safety signals over the course of a study\'s lifecycle. Medical monitors and safety teams actively manage per-site signal reviews, tracking site-specific case counts, risk assessments, and actions taken — this is an operational process, not an analytical derivation.' .

ind:VisitBillingReconciliation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subject ;
    rdfs:label 'Visit Billing Reconciliation' ;
    rdfs:comment 'This association product represents the billing reconciliation event between a subject_visit and an invoice_line in clinical trials sponsor invoicing. It captures the operational linkage used by finance teams to reconcile per-visit billing charges on sponsor invoices against actual subject visit completions. Each record links one subject_visit to one invoice_line and carries the billing period, quantity billed, completion date, and billing status that exist only in the context of this reconciliation relationship.. Existence Justification: In clinical trials sponsor billing, invoice lines are aggregated billing records that cover multiple subject visits of a given type (e.g., all Week 4 visits at a site in a billing period), meaning one invoice_line maps to many subject_visits. Conversely, a given subject_visit type can be billed across multiple invoice lines in different billing periods or contract amendments, meaning one subject_visit can be referenced by multiple invoice_lines. The clinical trials finance team actively manages this reconciliation — tracking which visits have been billed, in which period, at what quantity — as a core operational process for sponsor invoicing accuracy and audit support.' .

ind:SdvReview rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subject ;
    rdfs:label 'Sdv Review' ;
    rdfs:comment 'This association product represents the Source Data Verification (SDV) Review event between a subject_visit and a monitoring_visit. It captures the operational record of a CRA reviewing a specific subject visit during a specific monitoring visit, including SDV outcome, coverage percentage, review date, and review status. Each record links one subject_visit to one monitoring_visit and carries attributes that exist only in the context of this review pairing — a subject visit may be reviewed across multiple monitoring visits (re-SDV, follow-up), and a monitoring visit covers many subject visits.. Existence Justification: In clinical trials, a CRA monitoring visit (monitoring_visit) covers SDV across multiple enrolled subjects and their corresponding subject visits — a single monitoring visit reviews many subject visits. Conversely, a single subject visit can be reviewed across multiple monitoring visits over the study lifecycle (initial SDV, re-SDV, follow-up verification after queries). The business actively tracks SDV outcome, coverage percentage, and review status per subject-visit/monitoring-visit pair as an operational record, not a derived analytical correlation.' .

ind:BinderContentInclusion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Regulatory ;
    rdfs:label 'Binder Content Inclusion' ;
    rdfs:comment 'This association product represents the Inclusion relationship between a submission_content_unit and a regulatory_binder. It captures the operational record of a specific eCTD content unit (document, dataset, or study report) being included within a specific regulatory submission binder, along with the per-binder CTD section placement, sequence ordering, inclusion type, mandatory status, and QC review outcome. Each record links one submission_content_unit to one regulatory_binder with attributes that exist only in the context of that specific inclusion — the same document may be included in multiple binders with different section placements and QC statuses.. Existence Justification: In eCTD regulatory submissions, a single content unit (document/dataset) can legitimately appear across multiple regulatory binders — for example, a clinical study report submitted in an original NDA binder (sequence 0000) and then referenced again in a resubmission binder (sequence 0001) or a supplemental binder. Conversely, a regulatory binder contains many content units spanning CTD modules 1–5. The business actively manages this inclusion relationship, tracking per-binder CTD section placement, sequence order, inclusion type, and QC review status — data that belongs to neither the content unit nor the binder alone.' .

ind:SusarSubmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Susar Submission' ;
    rdfs:comment 'This association product represents the regulatory submission event between a SUSAR case and a specific health authority. It captures the per-authority expedited safety reporting lifecycle — including submission date, authority-specific deadline, submission status, and acknowledgement tracking — that exists only in the context of a specific SUSAR being reported to a specific regulatory body. Each record documents one submission event linking one SUSAR to one health authority, enabling pharmacovigilance teams to track multi-jurisdictional reporting compliance under ICH E2A/E2B obligations.. Existence Justification: In clinical trials, a single SUSAR must be reported simultaneously to multiple health authorities (e.g., FDA, EMA, PMDA, national competent authorities) under ICH E2A/E2B regulations, each with jurisdiction-specific deadlines, submission formats, and acknowledgement tracking. Conversely, each health authority receives SUSARs from many different studies and cases. The business actively manages each SUSAR-to-authority submission as a distinct operational record with its own submission date, deadline, status, and acknowledgement number — this is not derivable from either entity alone.' .

ind:SubjectConsent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subject ;
    rdfs:label 'Subject Subject Consent' ;
    rdfs:comment 'This association product represents the Informed Consent Event between a trial_subject and a document_icf_version. It captures the complete regulatory audit trail of every consent and re-consent signing event for each subject across all ICF versions applicable during their participation in the study. Each record links one trial_subject to one document_icf_version and carries attributes that exist only in the context of that specific signing event — including the date, method, status, and witness. Required for regulatory inspection readiness and TMF completeness.. Existence Justification: In clinical trials, a subject signs an ICF at initial enrollment and must re-consent whenever a protocol amendment produces a new ICF version — meaning one subject can sign multiple ICF versions over the life of a trial. Conversely, each ICF version is signed by many subjects (all those enrolled or re-consented under that version). The business actively manages these consent records as a regulatory and compliance obligation, tracking the date, method, and status of each individual consent event.' .

ind:AssessmentDatasetEvidence rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Assessment Dataset Evidence' ;
    rdfs:comment 'This association product represents the Evidence Role relationship between a benefit_risk_assessment and an sdtm_dataset. It captures the formal linkage of a specific SDTM dataset as an evidentiary source for a given benefit-risk assessment, recording the data cut date applied, the analysis population used, the evidentiary role the dataset played, and the rationale for its inclusion. Each record links one benefit_risk_assessment to one sdtm_dataset and carries attributes that exist only in the context of this specific assessment-dataset pairing.. Existence Justification: In clinical research, a formal benefit-risk assessment (BRA) draws on multiple SDTM datasets simultaneously — for example, a single BRA may reference the AE dataset for safety events, the EX dataset for exposure, and the ADRS/RS dataset for efficacy endpoints. Conversely, a single SDTM dataset (e.g., the AE dataset) will inform multiple BRAs across development phases, periodic reviews, and regulatory requests. The business actively manages which datasets were used in each assessment, including the specific data cut date applied and the role each dataset played (safety evidence, efficacy evidence, exposure quantification), making this a genuine operational M:N relationship with its own attributes.' .

ind:DrugLabInteraction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Subject ;
    rdfs:label 'Drug Lab Interaction' ;
    rdfs:comment 'This association product represents the clinical assessment event linking a concomitant medication record to a laboratory result that triggered or informed a medication decision. It captures the pharmacovigilance and drug-lab interaction relationship between a specific medication action (initiation, dose change, or discontinuation) and the laboratory finding(s) that drove that clinical decision. Each record links one concomitant_medication to one lab_result with attributes that exist only in the context of this assessed relationship, supporting safety monitoring, regulatory reporting, and SDTM CM-LB linkage.. Existence Justification: In clinical trials, concomitant medications are frequently initiated, modified, or discontinued in direct response to laboratory findings — a statin started after elevated LDL, a dose reduction triggered by elevated liver enzymes (ALT/AST), or a medication stopped due to a critical creatinine value. One abnormal lab result can trigger multiple medication adjustments (e.g., both a diuretic dose reduction AND a potassium supplement initiation), and one medication change can be supported by multiple lab results reviewed together (e.g., a series of rising LFT values). This is an operationally managed relationship in pharmacovigilance and drug-lab interaction safety review workflows.' .

ind:ObligationFulfillment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Agreement ;
    rdfs:label 'Obligation Fulfillment' ;
    rdfs:comment 'This association product represents the fulfillment event between a contractual deliverable and a contract obligation. It captures the operational record of how and to what degree a specific deliverable satisfies a specific contractual obligation, serving as the system of record for GCP audit trails, contract compliance reporting, and dispute resolution. Each record links one deliverable to one contract_obligation with attributes that exist only in the context of this fulfillment relationship.. Existence Justification: In clinical research contract management, a single deliverable (e.g., a Clinical Study Report) can fulfill multiple contractual obligations simultaneously (e.g., a regulatory reporting obligation AND a financial milestone obligation AND an operational reporting obligation), while a single contractual obligation (e.g., \'Submit all required regulatory documents\') can be satisfied by multiple deliverables. CROs actively manage this mapping as \'obligation fulfillment tracking\' — a recognized compliance and audit process where each deliverable-obligation link carries its own fulfillment status, evidence, and completion date. This is not an analytical correlation; it is an operationally managed record created, updated, and closed by contract managers and compliance teams during study execution.' .

ind:DepotSlaCoverage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Depot Sla Coverage' ;
    rdfs:comment 'This association product represents the Contract/Assignment between a clinical supply depot and a Service Level Agreement. It captures which SLAs are actively governing each depot in the supply network, along with the operational details of that coverage — effective date, scope of activities covered, current performance status, and last review date. Each record links one depot to one SLA and holds attributes that exist only in the context of that specific depot-SLA assignment, enabling supply chain managers to audit compliance and manage SLA coverage across the depot network.. Existence Justification: In clinical trial supply operations, a depot (warehouse node) can be governed by multiple SLAs simultaneously — e.g., a temperature monitoring SLA, a dispatch turnaround SLA, and a receipt confirmation SLA — while a single SLA (e.g., \'dispatch within 24 hours\') can apply to multiple depots across the supply network. This is an operationally managed relationship: supply chain managers actively assign, activate, and review which SLAs govern each depot, and the assignment itself carries meaningful data (effective date, scope, performance status, last review date) that belongs to neither the depot nor the SLA alone. Business stakeholders in clinical supply would recognize this as \'Depot SLA Coverage\' or a \'Depot SLA Assignment\' — a governed, auditable record of which performance commitments apply to which supply nodes.' .

ind:EngagementScope rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsor ;
    rdfs:label 'Engagement Scope' ;
    rdfs:comment 'This association product represents the Contract/Scope between a sponsor engagement and a health authority. It captures the formal designation of which health authorities are in scope for a given CRO-sponsor engagement, along with submission volume targets, regional scope, and designated regulatory contacts agreed for that pairing. Each record links one engagement to one health authority with attributes that exist only in the context of this specific engagement-HA relationship and cannot reside on either entity alone.. Existence Justification: In clinical research CRO operations, a single sponsor engagement spans multiple regulatory jurisdictions simultaneously — a global Phase III trial under one engagement may require FDA, EMA, PMDA, and MHRA submissions concurrently. Conversely, a major health authority like the FDA is relevant to dozens of active sponsor engagements at any given time. The CRO actively manages which health authorities are in scope per engagement, tracks submission volume targets per HA per engagement, and assigns primary regulatory contacts — this is an operationally managed relationship, not a derived analytical correlation.' .

ind:ImpIndicationTrack rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Imp Indication Track' ;
    rdfs:comment 'This association product represents the Development Track between imp_master and indication. It captures the operational record of a specific investigational medicinal product being developed for a specific therapeutic indication, including the development phase, regulatory filing status, line of therapy, and biomarker strategy applicable to that specific IMP-indication pairing. Each record links one imp_master to one indication with attributes that exist only in the context of this development relationship and cannot be attributed to either the IMP or the indication alone.. Existence Justification: In clinical drug development, a single IMP (investigational medicinal product) is routinely developed across multiple therapeutic indications simultaneously — e.g., a PD-1 inhibitor studied in NSCLC, breast cancer, and colorectal cancer at the same time. Conversely, a given indication (e.g., NSCLC) will have multiple IMPs under active development within a program, including combination regimens. The business actively manages each IMP-indication pairing as a distinct development program track, tracking its own development phase, regulatory status, line of therapy, and biomarker strategy — data that belongs to neither the IMP master nor the indication record alone.' .

ind:ImpSopApplicability rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Supply ;
    rdfs:label 'Imp Sop Applicability' ;
    rdfs:comment 'This association product represents the formal applicability relationship between an investigational medicinal product (IMP) and a Standard Operating Procedure (SOP) within the quality management system. It captures which SOPs govern each IMP, in what operational capacity (storage, dispensing, destruction, cold-chain), and for what period. Each record links one imp_master to one sop with attributes that exist only in the context of this IMP-SOP governance relationship, supporting GMP compliance, audit readiness, and training management.. Existence Justification: In clinical trials, a single IMP (e.g., a cold-chain biological IMP) is governed by multiple SOPs simultaneously — a storage SOP, a dispensing SOP, a destruction SOP, and a cold-chain SOP — each applying to that product in a distinct capacity. Conversely, a single SOP (e.g., a GMP dispensing SOP) applies to multiple IMPs across different studies. The business actively manages this applicability relationship through document control processes, tracking when each SOP became applicable to each IMP, in what role, and whether training is required for that specific IMP-SOP pairing.' .

ind:ProductDesignation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Study ;
    rdfs:label 'Product Designation' ;
    rdfs:comment 'This association product represents the regulatory designation grant relationship between an investigational_product and a special_designation. It captures the operational record of which special regulatory designation applies to which investigational product, under what indication scope, at what development phase, and as of what grant date. Each record links one investigational_product to one special_designation with attributes that exist only in the context of this product-designation pairing — such as the specific indication for which the designation was granted to that product and the applicable development phase.. Existence Justification: In clinical research, an investigational product (IMP) can receive multiple special regulatory designations simultaneously — e.g., a single drug may hold both Orphan Drug and Breakthrough Therapy designations from the FDA, plus a PRIME designation from the EMA, each for potentially different indications or scopes. Conversely, while a special designation is typically granted to a specific product-indication pair, a single designation record (e.g., an Orphan Drug designation for a rare disease) can in practice cover a product program that spans multiple formulations or related compounds. The business actively manages this relationship — regulatory affairs teams track which designations apply to which products, under what conditions, and for which indication scope, making this an operationally managed association with its own lifecycle data.' .

ind:DepotAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Depot Assignment' ;
    rdfs:comment 'This association product represents the supply assignment (role) between an investigational_site and a depot. It captures the formal clinical supply routing decision that designates which depot(s) serve each investigational site, including whether the depot is the primary or backup supply source, the logistics route type, and the effective date window of the assignment. Each record links one investigational_site to one depot and carries attributes that exist only in the context of this supply routing relationship. Clinical supply teams actively create, update, and close these records during study setup, supply chain re-routing, and site closeout.. Existence Justification: In clinical supply chain operations, an investigational site can receive IMPs from multiple depots (a primary depot plus one or more backup/regional depots), and a single depot services many investigational sites across multiple studies. This is a formally managed supply assignment relationship — clinical supply teams actively create, maintain, and expire these depot-to-site routing records as part of study setup and supply chain management. The relationship carries its own operational data (primary flag, route type, effective dates) that belongs to neither the site nor the depot alone.' .

ind:Authorization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Authorization' ;
    rdfs:comment 'This association product represents the Contract between investigational_site and clinical_trial_authorization. It captures the site-level regulatory authorization record that links a specific investigational site to a Clinical Trial Authorization issued by a national competent authority. Each record documents the authorization status, site-specific conditions, enrollment limits, and notification dates that apply uniquely to the site-CTA pairing — data that cannot reside on either the site master record or the CTA master record alone. Regulatory affairs teams create, update, and query these records throughout the trial lifecycle to demonstrate per-site regulatory compliance.. Existence Justification: In clinical research operations, a single Clinical Trial Authorization (CTA) issued by a national competent authority covers multiple investigational sites within that member state, and a given investigational site participates under multiple CTAs across different studies and countries. Regulatory operations teams actively manage site-specific CTA conditions, enrollment limits per site, and notification dates — data that belongs to the site-CTA pairing, not to either entity alone. This relationship is a recognized operational concept in EU CTR 536/2014 and national regulatory frameworks, where site-level authorization status must be tracked independently from the overall CTA.' .

ind:TrainingPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Training Plan' ;
    rdfs:comment 'Master reference table for training_plan. Referenced by training_plan_id.' .

ind:DataEntrySession rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Data ;
    rdfs:label 'Data Entry Session' ;
    rdfs:comment 'Master reference table for data_entry_session. Referenced by session_id.' .

ind:DelegationOfAuthority rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Document ;
    rdfs:label 'Delegation Of Authority' ;
    rdfs:comment 'Master reference table for delegation_of_authority. Referenced by delegation_of_authority_id.' .

ind:Vendor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Vendor' ;
    rdfs:comment 'Master reference table for vendor. Referenced by vendor_id.' .

ind:ShipmentManifest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Laboratory ;
    rdfs:label 'Shipment Manifest' ;
    rdfs:comment 'Master reference table for shipment_manifest. Referenced by manifest_id.' .

ind:ChecklistItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Monitoring ;
    rdfs:label 'Checklist Item' ;
    rdfs:comment 'Master reference table for checklist_item. Referenced by checklist_item_id.' .

ind:SiteSelectionCommittee rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Site Selection Committee' ;
    rdfs:comment 'Master reference table for site_selection_committee. Referenced by committee_id.' .

ind:TrainingCourse rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Training Course' ;
    rdfs:comment 'Master reference table for training_course. Referenced by training_course_id.' .

# --- Attribute Properties ---
ind:agreementBillingMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Agreement Billing Milestone Id' ;
    rdfs:comment 'Unique surrogate identifier for the billing milestone record in the agreement domain. Primary key for this entity.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AgreementBillingMilestone .

ind:approverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Billing milestone approvals require an auditable employee reference for financial controls, revenue recognition sign-off, and delegation-of-authority compliance. Clinical trials finance teams require ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:changeOrderId rdf:type rdf:Property ;
    rdfs:label 'Change Order Id' ;
    rdfs:comment 'Foreign key linking to agreement.change_order. Business justification: billing_milestone currently stores change_order_number as a STRING denormalized reference. Replacing this with a proper FK change_order_id → change_order.change_order_id normalizes the relationship, e' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChangeOrder .

ind:organizationId rdf:type rdf:Property ;
    rdfs:label 'Organization Id' ;
    rdfs:comment 'Reference to the pharmaceutical or biotech sponsor entity that is the billing counterparty for this milestone.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organization .

ind:regulatoryMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Milestone Id' ;
    rdfs:comment 'Foreign key linking to regulatory.regulatory_milestone. Business justification: CRO billing milestones are routinely triggered by regulatory milestones (IND submission, NDA filing, first approval). Payment processing depends on confirming the regulatory milestone was achieved. Th' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryMilestone .

ind:scopeOfWorkId rdf:type rdf:Property ;
    rdfs:label 'Scope Of Work Id' ;
    rdfs:comment 'Reference to the specific Statement of Work (SOW) or scope of work document that governs this billing milestone, if applicable.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScopeOfWork .

ind:studyContractId rdf:type rdf:Property ;
    rdfs:label 'Study Contract Id' ;
    rdfs:comment 'Reference to the parent study contract or master service agreement under which this billing milestone is defined.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudyContract .

ind:studyId rdf:type rdf:Property ;
    rdfs:label 'Study Id' ;
    rdfs:comment 'Reference to the clinical study or trial associated with this billing milestone, enabling study-level financial tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Study .

ind:submissionId rdf:type rdf:Property ;
    rdfs:label 'Submission Id' ;
    rdfs:comment 'Foreign key linking to regulatory.submission. Business justification: Specific billing milestones are triggered by regulatory submission events (e.g., payment upon IND submission, NDA filing). Linking billing_milestone to the specific submission that triggers payment en' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:actualTriggerDate rdf:type rdf:Property ;
    rdfs:label 'Actual Trigger Date' ;
    rdfs:comment 'Actual calendar date on which the qualifying trigger event occurred, confirming the milestone has been achieved. Null if the milestone has not yet been triggered.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adjustedAmount rdf:type rdf:Property ;
    rdfs:label 'Adjusted Amount' ;
    rdfs:comment 'Final invoiceable amount after applying any contractual adjustments, change orders, or amendments to the original milestone amount. May differ from milestone_amount when scope changes have been approved.' ;
    rdfs:domain ind:AgreementBillingMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date on which the billing milestone was formally approved for invoicing by the authorized approver.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Internal approval workflow status for the billing milestone before invoicing. Some milestones require sponsor sign-off or internal finance approval prior to invoice generation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Status' ;
    rdfs:comment 'Current lifecycle status of the billing milestone. Pending: milestone not yet triggered; Triggered: qualifying event has occurred; Invoiced: invoice has been issued to sponsor; Paid: payment received; Disputed: sponsor has raised a dispute; Cancelled: milestone voided by amendment.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'SAP S/4HANA cost center code to which the revenue and costs associated with this billing milestone are allocated for internal financial reporting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when this billing milestone record was first created in the system, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Supports audit trail and data lineage requirements.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the milestone amount (e.g., USD, EUR, GBP, JPY). Determines the currency in which the invoice will be issued.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableDescription rdf:type rdf:Property ;
    rdfs:label 'Deliverable Description' ;
    rdfs:comment 'Detailed description of the specific deliverable, event, or condition that activates this billing milestone (e.g., \'Submission of final Clinical Study Report (CSR) to sponsor\', \'Achievement of 50% patient enrollment target\').' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Description of the reason provided by the sponsor or CRO for disputing this billing milestone. Populated only when billing_status is \'disputed\'.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'Date on which a billing dispute for this milestone was formally resolved between the CRO and sponsor. Null if no dispute exists or dispute is still open.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentTargetCount rdf:type rdf:Property ;
    rdfs:label 'Enrollment Target Count' ;
    rdfs:comment 'For enrollment-based milestones, the number of patients enrolled that must be achieved to trigger this milestone. Null for non-enrollment-based milestone types.' ;
    rdfs:domain ind:AgreementBillingMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'Clinical trial functional area or service line to which this milestone belongs (e.g., Clinical Operations, Data Management, Biostatistics, Regulatory Affairs, Safety). Used for service-line revenue reporting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date on which the invoice was issued to the sponsor for this billing milestone. Null if the milestone has not yet been invoiced.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Reference number of the invoice issued to the sponsor for this billing milestone, as generated in SAP S/4HANA accounts receivable. Links to the sponsor invoice record.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPassThrough rdf:type rdf:Property ;
    rdfs:label 'Is Pass Through' ;
    rdfs:comment 'Indicates whether this milestone represents a pass-through cost (True) that is billed to the sponsor at cost without CRO margin, or a fee-for-service milestone (False) subject to standard markup.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneAmount rdf:type rdf:Property ;
    rdfs:label 'Milestone Amount' ;
    rdfs:comment 'Contractually agreed gross amount to be invoiced upon achievement of this milestone, expressed in the contract currency. This is the base billing amount before any adjustments.' ;
    rdfs:domain ind:AgreementBillingMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milestoneName rdf:type rdf:Property ;
    rdfs:label 'Milestone Name' ;
    rdfs:comment 'Human-readable name of the billing milestone as defined in the contract or SOW (e.g., \'First Patient First Visit\', \'Database Lock\', \'Final CSR Delivery\').' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneNumber rdf:type rdf:Property ;
    rdfs:label 'Milestone Number' ;
    rdfs:comment 'Externally-known unique alphanumeric identifier for the billing milestone as referenced in the contract, SOW, or SAP S/4HANA project accounting system (e.g., MS-2024-0042).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneSequence rdf:type rdf:Property ;
    rdfs:label 'Milestone Sequence' ;
    rdfs:comment 'Ordinal sequence number of this milestone within the contract or SOW, defining the chronological order in which milestones are expected to be achieved and billed.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'Classification of the billing milestone by the nature of its trigger mechanism. Enrollment-based milestones are triggered by patient enrollment counts; visit-based by clinical visit completion; deliverable-based by document or data deliverable submission; time-based by calendar date; safety-based by safety reporting events. [ENUM-REF-CANDIDATE: enrollment_based|visit_based|deliverable_based|time_based|safety_based|regulatory_based — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for capturing additional context, conditions, or commentary related to this billing milestone, such as special contractual conditions or sponsor-specific requirements.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Contractually defined date by which the sponsor must remit payment for the invoiced milestone amount, based on agreed payment terms.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'Date on which payment was received from the sponsor for this milestone. Null if payment has not yet been received.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Contractual payment terms specifying the number of days within which the sponsor must pay after invoice issuance (e.g., NET30, NET45, NET60). Sourced from the contract or SAP S/4HANA customer master.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:percentComplete rdf:type rdf:Property ;
    rdfs:label 'Percent Complete' ;
    rdfs:comment 'Percentage of the milestone completion criteria that have been satisfied as of the last assessment, ranging from 0.00 to 100.00. Used for revenue recognition and project progress tracking.' ;
    rdfs:domain ind:AgreementBillingMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedTriggerDate rdf:type rdf:Property ;
    rdfs:label 'Planned Trigger Date' ;
    rdfs:comment 'Contractually planned calendar date on which the milestone trigger event is expected to occur, as defined in the original SOW or project plan.' ;
    rdfs:domain ind:AgreementBillingMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'SAP S/4HANA project accounting code (WBS element or project number) under which this billing milestone is tracked for project cost and revenue management.' ;
    rdfs:domain ind:AgreementBillingMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Method' ;
    rdfs:comment 'Accounting method applied to recognize revenue for this milestone under IFRS 15 / ASC 606. Point-in-time recognition applies when control transfers at a single moment; over-time when performance obligations are satisfied continuously.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'Native identifier of this billing milestone record in the originating source system (e.g., SAP S/4HANA billing plan item ID or project milestone ID), enabling traceability back to the system of record.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Identifies the operational system of record from which this billing milestone record was sourced (e.g., SAP_S4HANA for project accounting, SIEBEL_CTMS for milestone event tracking, MANUAL for manually entered records).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerEventCode rdf:type rdf:Property ;
    rdfs:label 'Trigger Event Code' ;
    rdfs:comment 'Standardized code identifying the specific business event that triggers this milestone (e.g., FPFV for First Patient First Visit, DBL for Database Lock, CSR_FINAL for Final CSR Delivery). Aligns with CTMS event taxonomy.' ;
    rdfs:domain ind:AgreementBillingMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this billing milestone record, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Supports audit trail and change tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:visitCountTarget rdf:type rdf:Property ;
    rdfs:label 'Visit Count Target' ;
    rdfs:comment 'For visit-based milestones, the cumulative number of subject visits that must be completed to trigger this milestone. Null for non-visit-based milestone types.' ;
    rdfs:domain ind:AgreementBillingMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'Work Breakdown Structure (WBS) element code from SAP S/4HANA that maps this billing milestone to a specific deliverable or phase within the project hierarchy.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingId rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Id' ;
    rdfs:comment 'Foreign key linking to compliance.audit_finding. Business justification: Audit findings (e.g., inadequate monitoring coverage) can mandate scope changes executed via change orders. The regulatory_driven_flag and change_reason on change_order support this; linking to the or' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:initiatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Initiated By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Change orders are initiated by specific employees; tracking this supports change management audit trails, workload analysis by employee, and financial controls. In clinical trials, change order initia' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:regulatoryProtocolAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Protocol Amendment Id' ;
    rdfs:comment 'Foreign key linking to regulatory.protocol_amendment. Business justification: Protocol amendments are the primary driver of change orders in CRO contracts. Finance teams reconcile change order budget adjustments against the specific protocol amendment that triggered scope chang' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryProtocolAmendment .

ind:studyProtocolAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Study Protocol Amendment Id' ;
    rdfs:comment 'Foreign key linking to study.study_protocol_amendment. Business justification: Protocol amendments are the primary driver of CRO change orders. Regulatory and contracts teams must trace each change order back to the specific protocol amendment that caused it for audit, budget ju' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudyProtocolAmendment .

ind:supersededCoChangeOrderId rdf:type rdf:Property ;
    rdfs:label 'Superseded Co Change Order Id' ;
    rdfs:comment 'Reference to a prior Change Order that this record supersedes or replaces. Enables version chain traceability for contract modification history.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChangeOrder .

ind:tmfDocumentId rdf:type rdf:Property ;
    rdfs:label 'Tmf Document Id' ;
    rdfs:comment 'Foreign key linking to document.tmf_document. Business justification: Change orders are TMF-required documents (scope/budget amendments). This FK replaces the denormalized etmf_document_ref string, enabling TMF completeness tracking to verify each change order is proper' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TmfDocument .

ind:approvalWorkflowStep rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Step' ;
    rdfs:comment 'Current step in the multi-stage internal and external approval workflow for this Change Order, tracking progression from initiation through sponsor sign-off. [ENUM-REF-CANDIDATE: initiated|finance_review|legal_review|management_approval|sponsor_submission|sponsor_review|closed — promote to reference product]' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingMilestoneImpact rdf:type rdf:Property ;
    rdfs:label 'Billing Milestone Impact' ;
    rdfs:comment 'Description of how this Change Order affects existing billing milestones, including additions, removals, or modifications to milestone amounts and trigger events.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Structured business reason or justification for the contract modification, such as protocol amendment, site expansion, enrollment rate change, regulatory requirement, or sponsor-directed scope change.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonDetail rdf:type rdf:Property ;
    rdfs:label 'Change Reason Detail' ;
    rdfs:comment 'Free-text narrative providing additional context and detail for the change reason, including background, triggering events, and business impact rationale.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Classification of the nature of the contract modification: scope increase (additional services/sites/subjects), scope decrease (reduction), timeline extension, budget reallocation between lines, service-level change, or regulatory-driven amendment. [ENUM-REF-CANDIDATE: scope_increase|scope_decrease|timeline_extension|budget_reallocation|service_level_change|regulatory_driven — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coNumber rdf:type rdf:Property ;
    rdfs:label 'Co Number' ;
    rdfs:comment 'Externally-known, human-readable identifier for the Change Order or Contract Change Notice, used in sponsor communications, contract management systems, and audit trails. Follows the format CO-{YEAR}-{SEQUENCE}.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coStatus rdf:type rdf:Property ;
    rdfs:label 'Co Status' ;
    rdfs:comment 'Current lifecycle status of the Change Order within the approval workflow, from initial drafting through sponsor approval or rejection. [ENUM-REF-CANDIDATE: draft|pending_review|pending_sponsor_approval|approved|rejected|cancelled|superseded — promote to reference product]' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsCoReference rdf:type rdf:Property ;
    rdfs:label 'Ctms Co Reference' ;
    rdfs:comment 'Cross-reference identifier for this Change Order as recorded in Oracle Siebel CTMS, enabling reconciliation between the financial contract management system and the operational trial management system.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deltaValue rdf:type rdf:Property ;
    rdfs:label 'Delta Value' ;
    rdfs:comment 'The net financial impact of the Change Order expressed as a signed monetary amount. Positive values indicate a budget increase (scope increase); negative values indicate a budget decrease (scope decrease). Represents the gross change to the contract value.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The date on which the approved Change Order becomes contractually effective and the modified scope, budget, or timeline takes legal effect.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'The date by which the Change Order must receive sponsor approval before it lapses. Null if no expiry constraint applies.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financeReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Finance Review Required' ;
    rdfs:comment 'Indicates whether this Change Order requires formal finance department review and sign-off, typically triggered when the delta value exceeds a defined materiality threshold.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactedBudgetLines rdf:type rdf:Property ;
    rdfs:label 'Impacted Budget Lines' ;
    rdfs:comment 'Comma-separated list or structured reference to the budget line identifiers affected by this Change Order. Provides traceability between the CO and specific financial budget lines.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiationDate rdf:type rdf:Property ;
    rdfs:label 'Initiation Date' ;
    rdfs:comment 'The date on which the Change Order was formally initiated and submitted for internal review. Represents the principal real-world business event timestamp for this transaction.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internalApproverName rdf:type rdf:Property ;
    rdfs:label 'Internal Approver Name' ;
    rdfs:comment 'Name of the CRO-side authorized signatory (e.g., Finance Director, VP Contracts) who approved the Change Order internally before sponsor submission.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Legal Review Required' ;
    rdfs:comment 'Indicates whether this Change Order requires formal legal review before sponsor submission, typically triggered by changes to liability, IP, or regulatory terms.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passThroughDelta rdf:type rdf:Property ;
    rdfs:label 'Pass Through Delta' ;
    rdfs:comment 'The portion of the delta value attributable to pass-through costs (e.g., investigator grants, lab fees, travel) that are reimbursed at cost without CRO margin.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Business priority classification of the Change Order, used to triage the approval workflow and resource allocation for processing.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDrivenFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Driven Flag' ;
    rdfs:comment 'Indicates whether this Change Order was mandated by a regulatory authority (FDA, EMA, PMDA, etc.) or regulatory requirement, as opposed to being sponsor- or operationally-initiated.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Documented reason provided by the sponsor or internal reviewer when the Change Order is rejected. Null if the CO has not been rejected.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedContractValue rdf:type rdf:Property ;
    rdfs:label 'Revised Contract Value' ;
    rdfs:comment 'The total contract value after application of this Change Order, representing the updated financial commitment between sponsor and CRO.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisedStudyEndDate rdf:type rdf:Property ;
    rdfs:label 'Revised Study End Date' ;
    rdfs:comment 'The updated projected study or SOW completion date after application of any timeline extension specified in this Change Order.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Detailed narrative description of the scope changes introduced by this Change Order, including additions, removals, or modifications to services, deliverables, sites, or subject counts.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceFeeDelta rdf:type rdf:Property ;
    rdfs:label 'Service Fee Delta' ;
    rdfs:comment 'The portion of the delta value attributable to CRO service fees (professional services, management fees) as distinct from pass-through costs.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteCountDelta rdf:type rdf:Property ;
    rdfs:label 'Site Count Delta' ;
    rdfs:comment 'Net change in the number of investigative sites resulting from this Change Order. Positive for site additions, negative for site closures. Zero if site count is unaffected.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sponsorApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Sponsor Approval Date' ;
    rdfs:comment 'The date on which the sponsor formally approved the Change Order, completing the approval workflow. Null if not yet approved.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sponsorApproverName rdf:type rdf:Property ;
    rdfs:label 'Sponsor Approver Name' ;
    rdfs:comment 'Name of the authorized sponsor representative who approved or rejected the Change Order. Captured for audit and regulatory compliance purposes.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectCountDelta rdf:type rdf:Property ;
    rdfs:label 'Subject Count Delta' ;
    rdfs:comment 'Net change in the number of enrolled subjects (patients) resulting from this Change Order. Positive for enrollment increases, negative for decreases. Zero if subject count is unaffected.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timelineExtensionDays rdf:type rdf:Property ;
    rdfs:label 'Timeline Extension Days' ;
    rdfs:comment 'Number of calendar days by which the study or SOW timeline is extended as a result of this Change Order. Zero or null if the CO does not affect the timeline.' ;
    rdfs:domain ind:ChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Sequential version number of the Change Order document, incremented each time the CO is revised during the negotiation and approval process.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityAgreementId rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Agreement Id' ;
    rdfs:comment 'Unique surrogate identifier for the Non-Disclosure Agreement (NDA) or Confidentiality Disclosure Agreement (CDA) record in the lakehouse silver layer.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConfidentialityAgreement .

ind:labFacilityId rdf:type rdf:Property ;
    rdfs:label 'Lab Facility Id' ;
    rdfs:comment 'Foreign key linking to laboratory.lab_facility. Business justification: CDAs are executed with lab facilities before study initiation to protect confidential compound and protocol information. Legal/contracts teams must verify CDA execution status per lab facility before ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabFacility .

ind:masterServiceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Master Service Agreement Id' ;
    rdfs:comment 'Reference to the Master Service Agreement under which this NDA/CDA operates, if applicable. Links the confidentiality agreement to the broader commercial relationship framework between the CRO and sponsor.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MasterServiceAgreement .

ind:parentAgreementConfidentialityAgreementId rdf:type rdf:Property ;
    rdfs:label 'Parent Agreement Confidentiality Agreement Id' ;
    rdfs:comment 'Reference to the original NDA/CDA record that this amendment or superseding agreement is derived from. Enables version lineage tracking. Null for original agreements. Self-referencing within the confidentiality_agreement product.' ;
    rdfs:domain ind:ConfidentialityAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConfidentialityAgreement .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known business identifier for the NDA/CDA, typically assigned by the CRO legal department or sourced from Veeva Vault document numbering (e.g., NDA-2024-00123). Used for cross-referencing in contract management systems and regulatory correspondence.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the NDA/CDA. Tracks progression from draft through execution to expiry or termination. Only agreements in \'executed\' status permit sharing of proprietary compound or protocol information with the counterparty.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classifies the directionality of confidentiality obligations: unilateral (one party discloses to another), bilateral (mutual NDA between two parties), or multilateral (three or more parties). Determines which parties bear disclosure restrictions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Sequential amendment number indicating how many times this NDA/CDA has been formally amended. Zero for the original agreement. Incremented with each executed amendment that modifies scope, term, or parties.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether this NDA/CDA automatically renews upon expiry unless either party provides notice of termination. When True, triggers advance notification workflows in Veeva Vault prior to the renewal_notice_days threshold.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachNotificationDays rdf:type rdf:Property ;
    rdfs:label 'Breach Notification Days' ;
    rdfs:comment 'Number of calendar days within which a party must notify the other of a suspected or confirmed confidentiality breach. Aligns with GDPR 72-hour breach notification requirements and contractual obligations. Drives compliance monitoring workflows.' ;
    rdfs:domain ind:ConfidentialityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confidentialityTermYears rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Term Years' ;
    rdfs:comment 'Duration in years for which confidentiality obligations survive after the agreement expires or terminates. Commonly 2–10 years in clinical research. Drives data retention and destruction scheduling per GDPR and HIPAA requirements.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:croLegalEntity rdf:type rdf:Property ;
    rdfs:label 'Cro Legal Entity' ;
    rdfs:comment 'Full legal name of the CRO entity executing this NDA/CDA. Relevant when the CRO operates through multiple legal subsidiaries across jurisdictions. Must match the entity name on the executed document in Veeva Vault.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:croSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Cro Signatory Name' ;
    rdfs:comment 'Full name of the authorized CRO representative who executed this NDA/CDA on behalf of the CRO legal entity. Captured from Veeva Vault eSignature records for legal audit trail and 21 CFR Part 11 compliance.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Ctms Agreement Reference' ;
    rdfs:comment 'Cross-reference identifier for this NDA/CDA in Oracle Siebel CTMS. Enables traceability between the legal agreement record and the operational study management context in the CTMS.' ;
    rdfs:domain ind:ConfidentialityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyFramework rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Framework' ;
    rdfs:comment 'Primary data privacy regulatory framework applicable to personal data covered by this NDA/CDA. Determines data handling, retention, and breach notification obligations. Sourced from the agreement\'s jurisdiction and sponsor requirements.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataReturnDestructionClause rdf:type rdf:Property ;
    rdfs:label 'Data Return Destruction Clause' ;
    rdfs:comment 'Indicates whether this NDA/CDA includes a clause requiring the receiving party to return or destroy confidential information upon termination or expiry. When True, triggers data destruction workflows aligned with GDPR Article 17 and HIPAA requirements.' ;
    rdfs:domain ind:ConfidentialityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disclosingParty rdf:type rdf:Property ;
    rdfs:label 'Disclosing Party' ;
    rdfs:comment 'Identifies which party is the primary discloser of confidential information under this agreement. For unilateral NDAs, this is typically the sponsor sharing compound or protocol data. For bilateral agreements, both parties disclose.' ;
    rdfs:domain ind:ConfidentialityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Method agreed upon for resolving disputes arising from this NDA/CDA. Determines the legal pathway if a breach or disagreement occurs between the CRO and sponsor.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esignatureFlag rdf:type rdf:Property ;
    rdfs:label 'Esignature Flag' ;
    rdfs:comment 'Indicates whether this NDA/CDA was executed using electronic signatures compliant with 21 CFR Part 11 and/or eIDAS regulations. When True, the executed document is stored in Veeva Vault with a validated eSignature audit trail.' ;
    rdfs:domain ind:ConfidentialityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'Calendar date on which all required parties signed and the NDA/CDA was fully executed. May differ from effective_date when agreements are backdated or have a future effective date. Captured from Veeva Vault eSignature records.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:governingLawCountry rdf:type rdf:Property ;
    rdfs:label 'Governing Law Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction whose laws govern interpretation and enforcement of this NDA/CDA (e.g., USA, GBR, DEU). Determines applicable data privacy regulations and dispute resolution frameworks.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawState rdf:type rdf:Property ;
    rdfs:label 'Governing Law State' ;
    rdfs:comment 'State or province within the governing law country for sub-national jurisdiction specification (e.g., Delaware, New York, California). Relevant for U.S.-based agreements where state contract law applies.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReadyFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Ready Flag' ;
    rdfs:comment 'Indicates whether this NDA/CDA record and its associated executed document in Veeva Vault are confirmed as inspection-ready for regulatory authority review (FDA, EMA, MHRA). Set to True after QA review confirms completeness and accessibility.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipOwnershipClause rdf:type rdf:Property ;
    rdfs:label 'Ip Ownership Clause' ;
    rdfs:comment 'Indicates whether this NDA/CDA includes provisions addressing intellectual property ownership of any inventions or discoveries arising from the exchange of confidential information. When True, IP ownership terms are defined within the agreement.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permittedDisclosures rdf:type rdf:Property ;
    rdfs:label 'Permitted Disclosures' ;
    rdfs:comment 'Narrative description of circumstances under which confidential information may be disclosed without breach, such as disclosure to regulatory authorities (FDA, EMA), IRB/IEC, or as required by law. Critical for regulatory submission planning.' ;
    rdfs:domain ind:ConfidentialityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingParty rdf:type rdf:Property ;
    rdfs:label 'Receiving Party' ;
    rdfs:comment 'Identifies which party receives and is bound to protect confidential information under this agreement. For unilateral NDAs, this is typically the CRO receiving proprietary compound or protocol data from the sponsor.' ;
    rdfs:domain ind:ConfidentialityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of calendar days prior to expiry_date by which a party must provide written notice to prevent auto-renewal. Applicable only when auto_renewal_flag is True. Drives automated reminder workflows.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualKnowledgeClause rdf:type rdf:Property ;
    rdfs:label 'Residual Knowledge Clause' ;
    rdfs:comment 'Indicates whether this NDA/CDA includes a residual knowledge clause permitting the receiving party to use information retained in unaided memory after return or destruction of confidential materials. Relevant for CRO staff who may work on competing programs.' ;
    rdfs:domain ind:ConfidentialityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapContractReference rdf:type rdf:Property ;
    rdfs:label 'Sap Contract Reference' ;
    rdfs:comment 'Contract number or document reference in SAP S/4HANA linking this NDA/CDA to the financial and procurement records associated with the sponsor engagement. Supports SOX financial reporting controls.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeOfConfidentialInfo rdf:type rdf:Property ;
    rdfs:label 'Scope Of Confidential Info' ;
    rdfs:comment 'Narrative description of the categories of confidential information covered by this NDA/CDA, such as investigational compound data, clinical protocol, patient data, financial terms, or regulatory strategy. Defines the boundaries of protection.' ;
    rdfs:domain ind:ConfidentialityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorLegalEntity rdf:type rdf:Property ;
    rdfs:label 'Sponsor Legal Entity' ;
    rdfs:comment 'Full legal name of the pharmaceutical or biotech sponsor organization that is a party to this NDA/CDA. Used for legal correspondence, regulatory submissions, and contract management. Sourced from Veeva Vault counterparty records.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Sponsor Signatory Name' ;
    rdfs:comment 'Full name of the authorized representative of the sponsor organization who executed this NDA/CDA. Captured from Veeva Vault eSignature records for legal audit trail and 21 CFR Part 11 compliance.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyPhase rdf:type rdf:Property ;
    rdfs:label 'Study Phase' ;
    rdfs:comment 'Clinical development phase of the study or program for which this NDA/CDA is executed. Provides context for the sensitivity and regulatory significance of the confidential information being protected.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Calendar date on which the NDA/CDA was terminated prior to its scheduled expiry_date. Populated only when agreement_status is \'terminated\'. Triggers data destruction or return obligations per the agreement terms.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Reason for early termination of the NDA/CDA prior to its scheduled expiry. Captured for legal audit trail and regulatory compliance. Populated only when agreement_status is \'terminated\'.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyName rdf:type rdf:Property ;
    rdfs:label 'Third Party Name' ;
    rdfs:comment 'Name of any additional party (e.g., academic institution, sub-CRO, laboratory partner) included in a multilateral NDA/CDA. Populated only when agreement_type is \'multilateral\'. Nullable for unilateral and bilateral agreements.' ;
    rdfs:domain ind:ConfidentialityAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaVaultDocNumber rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Doc Number' ;
    rdfs:comment 'Unique document identifier assigned by Veeva Vault eTMF to the executed NDA/CDA document. Enables direct retrieval of the source document for audit, inspection readiness, and regulatory submission purposes.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Contract Amendment Id' ;
    rdfs:comment 'Unique system-generated identifier for the contract amendment record. Primary key for the contract_amendment data product.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractAmendment .

ind:inspectionFindingId rdf:type rdf:Property ;
    rdfs:label 'Inspection Finding Id' ;
    rdfs:comment 'Foreign key linking to compliance.inspection_finding. Business justification: Regulatory inspection findings (FDA Form 483, EMA findings) can mandate contract amendments to address systemic compliance gaps. Linking contract_amendment to the originating inspection_finding suppor' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionFinding .

ind:supersededByAmendmentContractAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Amendment Contract Amendment Id' ;
    rdfs:comment 'Reference to the subsequent amendment that supersedes this one, enabling a versioned chain of contract modifications. Null if this amendment is the current active version.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractAmendment .

ind:versionId rdf:type rdf:Property ;
    rdfs:label 'Version Id' ;
    rdfs:comment 'Foreign key linking to document.document_version. Business justification: Each contract amendment produces a specific document version in the eTMF. This FK links the amendment record to its executed document version, enabling regulatory audit trails showing which document v' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Version .

ind:amendmentDescription rdf:type rdf:Property ;
    rdfs:label 'Amendment Description' ;
    rdfs:comment 'Detailed narrative description of the changes introduced by this amendment, including the specific clauses modified, deleted, or added. Provides the business rationale and legal context for the modification.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentStatus rdf:type rdf:Property ;
    rdfs:label 'Amendment Status' ;
    rdfs:comment 'Current lifecycle state of the amendment. Tracks progression from initial drafting through negotiation, signature collection, execution, and potential supersession or voiding.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentTitle rdf:type rdf:Property ;
    rdfs:label 'Amendment Title' ;
    rdfs:comment 'Short descriptive title summarizing the primary purpose of the amendment (e.g., \'Payment Schedule Revision Q3 2024\'). Used for identification in contract management systems and legal registers.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'Classification of the legal or commercial area being modified by this amendment. Distinguishes amendments that change legal terms, payment terms, liability clauses, confidentiality provisions, termination conditions, or intellectual property rights. [ENUM-REF-CANDIDATE: legal_terms|payment_terms|liability|confidentiality|termination|intellectual_property — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentVersion rdf:type rdf:Property ;
    rdfs:label 'Amendment Version' ;
    rdfs:comment 'Monotonically increasing version number for this amendment, supporting versioned history of the legal contract. Increments when an amendment is revised prior to execution.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeRationale rdf:type rdf:Property ;
    rdfs:label 'Change Rationale' ;
    rdfs:comment 'Business or legal justification for why this amendment was initiated. Documents the triggering event or business need (e.g., regulatory requirement change, scope renegotiation, dispute resolution).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clausesModified rdf:type rdf:Property ;
    rdfs:label 'Clauses Modified' ;
    rdfs:comment 'Comma-separated list or narrative identifying the specific contract clause numbers or section references that are modified, added, or deleted by this amendment (e.g., \'Section 4.2, Section 7.1, Exhibit B\').' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Period Years' ;
    rdfs:comment 'Duration in years for which confidentiality obligations apply under the amended contract terms. Relevant when the amendment modifies the confidentiality clause of the master agreement.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractCurrency rdf:type rdf:Property ;
    rdfs:label 'Contract Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the contract and amendment financial values (e.g., USD, EUR, GBP). Ensures consistent financial reporting across multi-currency sponsor agreements.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:croSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Cro Signatory Title' ;
    rdfs:comment 'Job title or role of the CRO\'s authorized signatory (e.g., \'President\', \'VP Business Development\'). Validates signatory authority level for the CRO party.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financeReviewCompleted rdf:type rdf:Property ;
    rdfs:label 'Finance Review Completed' ;
    rdfs:comment 'Indicates whether the finance team has reviewed and approved the financial implications of the amendment, including impact on accruals, revenue recognition, and billing milestones.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Net monetary value change to the parent contract resulting from this amendment (positive for increases, negative for decreases). Expressed in the contract currency. Populated only when financial_impact_flag is True.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Flag' ;
    rdfs:comment 'Indicates whether this amendment has a direct financial impact on the contract value, payment schedule, or billing milestones. True triggers downstream finance accrual and revenue recognition review.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'The legal jurisdiction whose laws govern interpretation and enforcement of the amended contract terms (e.g., \'Delaware, USA\', \'England and Wales\'). Critical for dispute resolution.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indemnificationModified rdf:type rdf:Property ;
    rdfs:label 'Indemnification Modified' ;
    rdfs:comment 'Indicates whether this amendment modifies the indemnification provisions of the parent contract. Triggers legal and risk management review when True.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'The date on which the amendment process was formally initiated, typically when the first draft was created or the request was submitted. Supports negotiation cycle time analytics.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiatingParty rdf:type rdf:Property ;
    rdfs:label 'Initiating Party' ;
    rdfs:comment 'Identifies which party initiated the amendment request: the pharmaceutical/biotech sponsor, the CRO (Contract Research Organization), or mutually agreed. Supports contract governance analytics.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewCompleted rdf:type rdf:Property ;
    rdfs:label 'Legal Review Completed' ;
    rdfs:comment 'Indicates whether the internal legal team has completed their review and approved the amendment language prior to execution. Part of the amendment governance workflow.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Legal Review Date' ;
    rdfs:comment 'Date on which the internal legal review was completed and sign-off was granted. Populated when legal_review_completed is True.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liabilityCapAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Cap Amount' ;
    rdfs:comment 'Maximum monetary liability exposure agreed between parties as modified by this amendment. Expressed in contract_currency. Populated when amendment_type includes liability modifications.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiationEndDate rdf:type rdf:Property ;
    rdfs:label 'Negotiation End Date' ;
    rdfs:comment 'Date on which negotiation was concluded and terms were agreed upon by all parties, prior to formal execution. Enables measurement of negotiation duration as a KPI.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:negotiationRoundCount rdf:type rdf:Property ;
    rdfs:label 'Negotiation Round Count' ;
    rdfs:comment 'Number of negotiation rounds completed before the amendment was agreed. Supports KPI reporting on contract negotiation efficiency and legal resource consumption.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:negotiationStartDate rdf:type rdf:Property ;
    rdfs:label 'Negotiation Start Date' ;
    rdfs:comment 'Date on which active negotiation between the CRO and sponsor commenced for this amendment. Used to measure negotiation cycle time and track legal resource utilization.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:newPaymentTermsDescription rdf:type rdf:Property ;
    rdfs:label 'New Payment Terms Description' ;
    rdfs:comment 'Narrative description of the revised payment terms introduced by this amendment, including net payment days, milestone triggers, or revised billing schedule. Populated only when payment_terms_modified is True.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsModified rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Modified' ;
    rdfs:comment 'Indicates whether this amendment modifies the payment terms of the parent contract, including payment schedule, milestone definitions, or net payment days. Triggers finance team review.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'Date on which the required regulatory notification was submitted to the relevant authority (FDA, EMA, MHRA, etc.). Populated only when regulatory_notification_required is True.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'Indicates whether the amendment triggers a regulatory notification obligation to FDA, EMA, or other governing bodies (e.g., changes to sponsor responsibilities under ICH E6). Drives compliance workflow.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Sponsor Signatory Title' ;
    rdfs:comment 'Job title or role of the sponsor\'s authorized signatory (e.g., \'VP Clinical Operations\', \'Chief Medical Officer\'). Validates signatory authority level.' ;
    rdfs:domain ind:ContractAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaVaultDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Document Number' ;
    rdfs:comment 'System document identifier in Veeva Vault for the executed amendment document. Supports direct deep-linking from the data lakehouse to the source document management system.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNegotiationId rdf:type rdf:Property ;
    rdfs:label 'Contract Negotiation Id' ;
    rdfs:comment 'Unique surrogate identifier for each contract negotiation record in the Clinical Trials lakehouse silver layer.' ;
    rdfs:domain ind:ContractNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clinicalProgramId rdf:type rdf:Property ;
    rdfs:label 'Clinical Program Id' ;
    rdfs:comment 'Foreign key linking to program.clinical_program. Business justification: MSA-level contract negotiations (already linked via master_service_agreement_id) cover entire clinical programs. Linking contract_negotiation to clinical_program enables program-level negotiation stat' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClinicalProgram .

ind:complianceObligationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.obligation. Business justification: Contract negotiations must incorporate regulatory compliance obligations as non-negotiable terms. Linking contract_negotiation to the specific compliance obligation being negotiated supports open_issu' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:croLeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Cro Lead Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: The CRO lead on a contract negotiation is a specific internal employee. This FK supports negotiation team tracking, workload reporting across active negotiations, and key personnel identification requ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:regulatoryStrategyId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Strategy Id' ;
    rdfs:comment 'Foreign key linking to regulatory.strategy. Business justification: CRO contract negotiations are scoped and timed according to the regulatory strategy — planned IND/NDA submission dates drive contract execution deadlines. Linking contract_negotiation to the regulator' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Strategy .

ind:actualExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Execution Date' ;
    rdfs:comment 'Calendar date on which the contract was fully executed and signed by all required parties. Null until execution is complete. Compared against target_execution_date to measure negotiation cycle time variance.' ;
    rdfs:domain ind:ContractNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or user identifier of the individual who granted final internal approval for the negotiated contract terms. Supports audit trail and SOX compliance for contract authorization.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Data classification level assigned to this negotiation record per enterprise data governance policy. Drives access control and data handling requirements in the lakehouse.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsNegotiationReference rdf:type rdf:Property ;
    rdfs:label 'Ctms Negotiation Reference' ;
    rdfs:comment 'Cross-reference identifier for this negotiation record in Oracle Siebel CTMS, enabling reconciliation between the lakehouse silver layer and the operational CTMS system of record.' ;
    rdfs:domain ind:ContractNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentVersion rdf:type rdf:Property ;
    rdfs:label 'Document Version' ;
    rdfs:comment 'Version label of the contract document under negotiation in this round (e.g., v1.0, v2.3). Tracks document lineage across negotiation rounds and aligns with Veeva Vault version control.' ;
    rdfs:domain ind:ContractNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date on which the negotiation was formally escalated to senior management or executive leadership. Null if escalation_flag is False.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether this negotiation has been escalated to senior management or executive leadership due to stalled progress, unresolved issues, or timeline risk. True = escalated; False = normal track.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Categorized reason for escalation of the negotiation to senior leadership. Enables root cause analysis of contracting bottlenecks. [ENUM-REF-CANDIDATE: timeline_risk|unresolved_legal_terms|budget_disagreement|scope_dispute|executive_alignment|other — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalCounselCro rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Cro' ;
    rdfs:comment 'Name of the internal or external legal counsel representing the CRO during contract negotiation. Populated when legal review is engaged (negotiation_status = legal_review or later).' ;
    rdfs:domain ind:ContractNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalCounselSponsor rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Sponsor' ;
    rdfs:comment 'Name of the internal or external legal counsel representing the sponsor during contract negotiation. Populated when sponsor legal review is engaged.' ;
    rdfs:domain ind:ContractNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewEndDate rdf:type rdf:Property ;
    rdfs:label 'Legal Review End Date' ;
    rdfs:comment 'Date on which legal counsel completed their review and returned comments or approval for the current negotiation round. Null if legal review is still in progress.' ;
    rdfs:domain ind:ContractNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReviewStartDate rdf:type rdf:Property ;
    rdfs:label 'Legal Review Start Date' ;
    rdfs:comment 'Date on which the contract was formally submitted to legal counsel for review in this negotiation round. Enables measurement of legal review cycle time as a component of overall negotiation duration.' ;
    rdfs:domain ind:ContractNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:negotiatedContractValue rdf:type rdf:Property ;
    rdfs:label 'Negotiated Contract Value' ;
    rdfs:comment 'Total contract value as agreed or proposed in the current negotiation round, expressed in the billing currency. May differ from the final executed value if further rounds occur. Supports financial forecasting and budget alignment.' ;
    rdfs:domain ind:ContractNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiationChannel rdf:type rdf:Property ;
    rdfs:label 'Negotiation Channel' ;
    rdfs:comment 'Primary communication and document exchange channel used during this negotiation round (e.g., Veeva Vault for document redlining, DocuSign for execution, email for correspondence). [ENUM-REF-CANDIDATE: email|veeva_vault|docusign|in_person|video_conference|legal_portal — promote to reference product]' ;
    rdfs:domain ind:ContractNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationNumber rdf:type rdf:Property ;
    rdfs:label 'Negotiation Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for this negotiation instance, used in correspondence and CTMS tracking (e.g., NEG-ONCOL-002341). Unique across the enterprise.' ;
    rdfs:domain ind:ContractNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationRound rdf:type rdf:Property ;
    rdfs:label 'Negotiation Round' ;
    rdfs:comment 'Sequential integer indicating which round of negotiation this record represents (e.g., 1 = initial draft exchange, 2 = first redline response). Enables cycle time analysis per round.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:negotiationStatus rdf:type rdf:Property ;
    rdfs:label 'Negotiation Status' ;
    rdfs:comment 'Current workflow state of the contract negotiation lifecycle. Tracks progression from initial draft through final execution: draft (initial version created), under_review (circulated for internal review), redline (counterparty markup received), legal_review (legal counsel engaged), approved (all parties approved), executed (fully signed and binding).' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationType rdf:type rdf:Property ;
    rdfs:label 'Negotiation Type' ;
    rdfs:comment 'Classification of the contract instrument being negotiated. Distinguishes between Master Service Agreements (MSA), Scope of Work (SOW) documents, Change Orders (CO), Amendments, Confidentiality Agreements (CDA/NDA), and Service Level Agreements (SLA). [ENUM-REF-CANDIDATE: master_service_agreement|scope_of_work|change_order|amendment|confidentiality_agreement|service_level_agreement — promote to reference product]' ;
    rdfs:domain ind:ContractNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openIssueCount rdf:type rdf:Property ;
    rdfs:label 'Open Issue Count' ;
    rdfs:comment 'Number of distinct unresolved contractual issues or redline items outstanding at the time of the current negotiation round. Used as a KPI for negotiation complexity and progress tracking.' ;
    rdfs:domain ind:ContractNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openIssuesSummary rdf:type rdf:Property ;
    rdfs:label 'Open Issues Summary' ;
    rdfs:comment 'Free-text summary of the key unresolved issues or points of contention remaining in the current negotiation round (e.g., indemnification clauses, IP ownership, payment terms, liability caps). Supports bottleneck identification and escalation decisions.' ;
    rdfs:domain ind:ContractNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passThroughValue rdf:type rdf:Property ;
    rdfs:label 'Pass Through Value' ;
    rdfs:comment 'Portion of the negotiated contract value designated as pass-through costs (e.g., investigator grants, lab fees, travel) as proposed in the current negotiation round. Distinct from service fee budget.' ;
    rdfs:domain ind:ContractNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentModel rdf:type rdf:Property ;
    rdfs:label 'Payment Model' ;
    rdfs:comment 'Commercial payment structure being negotiated for this contract (e.g., milestone_based = payments tied to deliverable completion, time_and_materials = resource-rate billing, fixed_fee = lump sum, unit_based = per-patient or per-site pricing, hybrid = combination).' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Business priority assigned to this negotiation, reflecting urgency relative to study start timelines, sponsor commitments, or regulatory milestones. Drives resource allocation in the contracts team.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redlineReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Redline Received Date' ;
    rdfs:comment 'Date on which the counterparty\'s marked-up (redlined) version of the contract was received in the current negotiation round. Null if no redline has been received. Used to measure counterparty response time.' ;
    rdfs:domain ind:ContractNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:roundEndDate rdf:type rdf:Property ;
    rdfs:label 'Round End Date' ;
    rdfs:comment 'Date on which the current negotiation round concluded, i.e., when a response was received or the round was closed. Null if the round is still open. Used to compute per-round turnaround time.' ;
    rdfs:domain ind:ContractNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:roundStartDate rdf:type rdf:Property ;
    rdfs:label 'Round Start Date' ;
    rdfs:comment 'Date on which the current negotiation round commenced, i.e., when the draft or redline was sent to the counterparty for this specific round. Enables per-round cycle time analysis.' ;
    rdfs:domain ind:ContractNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceFeeValue rdf:type rdf:Property ;
    rdfs:label 'Service Fee Value' ;
    rdfs:comment 'Portion of the negotiated contract value representing CRO service fees (professional services, management fees) as proposed in the current negotiation round. Distinct from pass-through costs.' ;
    rdfs:domain ind:ContractNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sponsorLeadContact rdf:type rdf:Property ;
    rdfs:label 'Sponsor Lead Contact' ;
    rdfs:comment 'Name or identifier of the primary sponsor representative leading the negotiation on behalf of the pharmaceutical or biotech sponsor. Typically a procurement officer or legal counsel.' ;
    rdfs:domain ind:ContractNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Target Execution Date' ;
    rdfs:comment 'Planned date by which the contract is expected to be fully executed (signed by all parties). Used for SLA tracking and bottleneck identification in the contracting process.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationFlag rdf:type rdf:Property ;
    rdfs:label 'Termination Flag' ;
    rdfs:comment 'Indicates whether this negotiation was terminated without reaching execution (e.g., sponsor withdrew, parties could not agree). True = terminated without execution; False = active or successfully executed.' ;
    rdfs:domain ind:ContractNegotiation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractObligationId rdf:type rdf:Property ;
    rdfs:label 'Contract Obligation Id' ;
    rdfs:comment 'Unique system-generated identifier for each contractual obligation record tracked within the agreement domain.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractObligation .

ind:complianceSopId rdf:type rdf:Property ;
    rdfs:label 'Compliance Sop Id' ;
    rdfs:comment 'Foreign key linking to compliance.sop. Business justification: Contract obligations mandate adherence to specific SOPs (e.g., obligation to conduct monitoring per SOP-MON-001). Linking obligation to the governing SOP supports compliance verification and ensures e' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceSop .

ind:linkedMilestoneAgreementBillingMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Linked Milestone Agreement Billing Milestone Id' ;
    rdfs:comment 'Reference to the associated billing milestone in the finance domain when this obligation is tied to a payment trigger (e.g., obligation fulfillment unlocks a billing milestone in SAP S/4HANA).' ;
    rdfs:domain ind:ContractObligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AgreementBillingMilestone .

ind:regulatoryActionItemId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Action Item Id' ;
    rdfs:comment 'Foreign key linking to regulatory.regulatory_action_item. Business justification: Regulatory inspection findings and agency action items frequently generate contractual obligations on the CRO (e.g., CAPA implementation, data resubmission). Linking contract_obligation to the trigger' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryActionItem .

ind:regulatoryCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Commitment Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_commitment. Business justification: Regulatory commitments made to health authorities (post-inspection) are operationalized as contract obligations. Linking contract_obligation to the originating regulatory_commitment enables end-to-end' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClinicalTrials .

ind:responsibleOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Contract obligations are assigned to specific employees for fulfillment. This FK enables obligation ownership tracking, overdue obligation reporting by employee, escalation workflows, and compliance d' ;
    rdfs:domain ind:ContractObligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:studyMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Study Milestone Id' ;
    rdfs:comment 'Foreign key linking to study.study_milestone. Business justification: Contract obligations (regulatory submission deadlines, safety reporting requirements, enrollment commitments) are fulfilled upon specific study milestone achievements. Contract managers tracking oblig' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudyMilestone .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text field for additional context, notes, or clarifications related to this obligation, such as waiver rationale, extension justification, or sponsor communication summaries.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsObligationReference rdf:type rdf:Property ;
    rdfs:label 'Ctms Obligation Reference' ;
    rdfs:comment 'Cross-reference identifier for this obligation record in Oracle Siebel CTMS, enabling bidirectional traceability between the lakehouse silver layer and the operational CTMS system.' ;
    rdfs:domain ind:ContractObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeDescription rdf:type rdf:Property ;
    rdfs:label 'Dispute Description' ;
    rdfs:comment 'Narrative description of the nature of the contractual dispute associated with this obligation, including the contested position of each party. Populated only when is_dispute_item is true. Confidential legal information.' ;
    rdfs:domain ind:ContractObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'The contractually agreed date by which this obligation must be fulfilled. Used as the primary trigger for overdue escalation and SLA breach calculations.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationStatus rdf:type rdf:Property ;
    rdfs:label 'Escalation Status' ;
    rdfs:comment 'Current state of the escalation workflow for this obligation: not_triggered (no escalation active), triggered (escalation notification sent), acknowledged (escalation received and acknowledged), or resolved (escalation closed).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTrigger rdf:type rdf:Property ;
    rdfs:label 'Escalation Trigger' ;
    rdfs:comment 'Defined condition or threshold that triggers an escalation notification (e.g., \'5 business days before due date\', \'overdue by 48 hours\', \'penalty threshold reached\'). Used by automated monitoring workflows.' ;
    rdfs:domain ind:ContractObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceDescription rdf:type rdf:Property ;
    rdfs:label 'Evidence Description' ;
    rdfs:comment 'Narrative description of the evidence provided to demonstrate fulfillment of this obligation (e.g., \'SAE report submitted via Argus Safety on 2024-03-15\', \'CSR delivered and accepted by sponsor\', \'Invoice paid per SAP payment record\').' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Date' ;
    rdfs:comment 'The actual date on which the obligation was fulfilled and accepted by the receiving party. Null if not yet fulfilled.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Current lifecycle state of the obligation: pending (not yet started), in_progress (actively being worked), fulfilled (completed and evidenced), overdue (past due date without fulfillment), waived (formally waived by mutual agreement), disputed (contested by either party), or cancelled (obligation voided by amendment). [ENUM-REF-CANDIDATE: pending|in_progress|fulfilled|overdue|waived|disputed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDisputeItem rdf:type rdf:Property ;
    rdfs:label 'Is Dispute Item' ;
    rdfs:comment 'Indicates whether this obligation is currently subject to a formal contractual dispute between the sponsor and CRO. When true, the obligation is tracked as a dispute item requiring legal or governance review.' ;
    rdfs:domain ind:ContractObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryRequired rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Required' ;
    rdfs:comment 'Indicates whether this obligation is mandated by a regulatory authority (FDA, EMA, ICH, MHRA, PMDA, etc.) as opposed to being a purely commercial or operational commitment. Regulatory obligations carry heightened compliance risk.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:obligationDescription rdf:type rdf:Property ;
    rdfs:label 'Obligation Description' ;
    rdfs:comment 'Full narrative description of the contractual obligation as extracted or paraphrased from the source contract, MSA, SOW, or amendment, including specific deliverable criteria and acceptance conditions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationNumber rdf:type rdf:Property ;
    rdfs:label 'Obligation Number' ;
    rdfs:comment 'Externally-known, human-readable unique reference number assigned to this obligation for cross-system tracking, audit, and dispute resolution purposes (e.g., OBL-MSA001-00042).' ;
    rdfs:domain ind:ContractObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationSubtype rdf:type rdf:Property ;
    rdfs:label 'Obligation Subtype' ;
    rdfs:comment 'Granular sub-classification within the obligation type (e.g., SAE reporting, enrollment milestone, regulatory submission, invoice payment, SLA penalty, CAPA delivery). [ENUM-REF-CANDIDATE: sae_reporting|enrollment_milestone|regulatory_submission|invoice_payment|sla_penalty|capa_delivery|site_activation|data_delivery|audit_response|change_order_approval — promote to reference product]' ;
    rdfs:domain ind:ContractObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationTitle rdf:type rdf:Property ;
    rdfs:label 'Obligation Title' ;
    rdfs:comment 'Short, human-readable title summarizing the obligation (e.g., \'Deliver Final Clinical Study Report\', \'Submit SAE within 24 hours\', \'Achieve 80% enrollment by Q3\').' ;
    rdfs:domain ind:ContractObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationType rdf:type rdf:Property ;
    rdfs:label 'Obligation Type' ;
    rdfs:comment 'High-level classification of the obligation: regulatory (e.g., IRB/IEC submissions, GCP compliance), financial (e.g., payment milestones, pass-through caps), operational (e.g., site activation timelines, enrollment targets), reporting (e.g., CSR delivery, safety reporting), or dispute (e.g., contested deliverables, penalty triggers).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Monetary value of the contractual penalty or liquidated damages applicable upon breach of this obligation. Expressed in the contract currency. Confidential commercial data.' ;
    rdfs:domain ind:ContractObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyClause rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause' ;
    rdfs:comment 'Description of the contractual penalty, liquidated damages, or service credit that applies if this obligation is not fulfilled by the due date. Confidential commercial information.' ;
    rdfs:domain ind:ContractObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceEndDate rdf:type rdf:Property ;
    rdfs:label 'Recurrence End Date' ;
    rdfs:comment 'For recurring obligations, the date after which no further recurrence instances are generated. Null for one-time obligations or open-ended recurring obligations.' ;
    rdfs:domain ind:ContractObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recurrencePattern rdf:type rdf:Property ;
    rdfs:label 'Recurrence Pattern' ;
    rdfs:comment 'Indicates whether the obligation is a one-time commitment or a recurring obligation with a defined frequency (e.g., monthly safety reports, quarterly enrollment updates, annual GCP training confirmations).' ;
    rdfs:domain ind:ContractObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'The specific regulatory body to which this obligation relates (e.g., FDA, EMA, MHRA, PMDA, TGA, Health Canada). Populated only when is_regulatory_required is true. [ENUM-REF-CANDIDATE: FDA|EMA|MHRA|PMDA|TGA|Health Canada|OHRP|WHO — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'The contractual party accountable for fulfilling this obligation: sponsor (pharmaceutical/biotech client), CRO (contract research organization), site (investigative site), subcontractor (third-party vendor), or joint (shared responsibility).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'The date on which the formal review of this obligation\'s fulfillment was completed and accepted.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewRequired rdf:type rdf:Property ;
    rdfs:label 'Review Required' ;
    rdfs:comment 'Indicates whether this obligation requires a formal review or approval step before it can be marked as fulfilled (e.g., sponsor sign-off on CSR, IRB/IEC acknowledgment of protocol deviation).' ;
    rdfs:domain ind:ContractObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Name of the individual or role responsible for reviewing and approving fulfillment of this obligation. Populated when review_required is true.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceClauseReference rdf:type rdf:Property ;
    rdfs:label 'Source Clause Reference' ;
    rdfs:comment 'Specific section, article, clause, or exhibit number within the source contract document from which this obligation is extracted (e.g., \'Section 4.2.1\', \'Exhibit B, Clause 7\', \'Schedule 3\'). Enables rapid legal traceability.' ;
    rdfs:domain ind:ContractObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Source Document Type' ;
    rdfs:comment 'Type of the source contractual document from which this obligation was extracted: MSA (Master Service Agreement), SOW (Statement of Work), amendment, change order, subcontract, or SLA (Service Level Agreement).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableId rdf:type rdf:Property ;
    rdfs:label 'Deliverable Id' ;
    rdfs:comment 'Unique system-generated identifier for each contractually committed deliverable record within the agreement domain.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Deliverable .

ind:auditId rdf:type rdf:Property ;
    rdfs:label 'Audit Id' ;
    rdfs:comment 'Foreign key linking to compliance.audit. Business justification: Deliverables with gcp_audit_required_flag=true are directly reviewed in GCP audits. Linking deliverable to the audit that assessed it supports audit scope documentation, qc_review_status tracking, and' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:consentIcfVersionId rdf:type rdf:Property ;
    rdfs:label 'Consent Icf Version Id' ;
    rdfs:comment 'Foreign key linking to consent.consent_icf_version. Business justification: ICF approval, translation, and IRB submission are contractual deliverables under a SOW. Linking the deliverable record to the specific ICF version enables SOW deliverable tracking and SLA measurement ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsentIcfVersion .

ind:employeeId rdf:type rdf:Property ;
    rdfs:label 'Employee Id' ;
    rdfs:comment 'Reference to the CRO staff member (typically a Project Manager or functional lead) who is the named accountable owner for this deliverable\'s timely and quality completion.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:labAccreditationId rdf:type rdf:Property ;
    rdfs:label 'Lab Accreditation Id' ;
    rdfs:comment 'Foreign key linking to laboratory.lab_accreditation. Business justification: Lab accreditation certificates are contractual deliverables under the SOW — the lab must submit proof of accreditation as a condition of study initiation. Contracts/QA teams track accreditation certif' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabAccreditation .

ind:labCertificationId rdf:type rdf:Property ;
    rdfs:label 'Lab Certification Id' ;
    rdfs:comment 'Foreign key linking to laboratory.lab_certification. Business justification: Lab certifications (CLIA, CAP, GLP) are contractual deliverables — labs must provide current certificates as study startup deliverables. Contracts/QA teams track certification submission, expiry, and ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabCertification .

ind:sponsorContactId rdf:type rdf:Property ;
    rdfs:label 'Sponsor Contact Id' ;
    rdfs:comment 'FK to sponsor.sponsor_contact' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SponsorContact .

ind:acceptanceCriteria rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria' ;
    rdfs:comment 'Contractually defined quality and completeness criteria that the deliverable must satisfy for sponsor acceptance, as specified in the SOW. Used by QA reviewers and project managers during review.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date on which the sponsor formally accepted the deliverable as meeting the contractual acceptance criteria. Triggers billing milestone recognition and TMF archival.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Date on which the CRO formally submitted or transmitted the deliverable to the sponsor. Compared against planned_delivery_date to calculate schedule variance and SLA compliance.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualEffortHours rdf:type rdf:Property ;
    rdfs:label 'Actual Effort Hours' ;
    rdfs:comment 'Actual labor hours expended to produce and deliver this deliverable. Compared against estimated_effort_hours to calculate effort variance and inform future SOW scoping.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdiscCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Cdisc Compliant Flag' ;
    rdfs:comment 'Indicates whether this deliverable (typically a dataset or tabulation) must conform to CDISC SDTM or ADaM standards as required by the sponsor or regulatory authority.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractedValueUsd rdf:type rdf:Property ;
    rdfs:label 'Contracted Value Usd' ;
    rdfs:comment 'Monetary value assigned to this deliverable in the SOW or contract, denominated in US Dollars. Represents the billable amount triggered upon acceptance. Business-confidential commercial data.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysOverdue rdf:type rdf:Property ;
    rdfs:label 'Days Overdue' ;
    rdfs:comment 'Number of calendar days by which the actual delivery date exceeded the planned delivery date. Negative values indicate early delivery. Used for SLA performance reporting and sponsor relationship management.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliverableCategory rdf:type rdf:Property ;
    rdfs:label 'Deliverable Category' ;
    rdfs:comment 'Functional domain category of the deliverable, indicating which CRO functional team is primarily responsible (e.g., clinical, statistical, data management, regulatory, safety, monitoring). [ENUM-REF-CANDIDATE: clinical|statistical|data_management|regulatory|safety|monitoring|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableCode rdf:type rdf:Property ;
    rdfs:label 'Deliverable Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this deliverable within the SOW or contract. Used in sponsor communications, billing milestones, and regulatory submissions.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableName rdf:type rdf:Property ;
    rdfs:label 'Deliverable Name' ;
    rdfs:comment 'Human-readable name of the contractual deliverable as defined in the SOW (e.g., Clinical Study Report, Statistical Analysis Plan, Data Management Plan, Monitoring Plan, Regulatory Submission Package).' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableType rdf:type rdf:Property ;
    rdfs:label 'Deliverable Type' ;
    rdfs:comment 'Classification of the deliverable by output category. Drives workflow routing, acceptance criteria templates, and regulatory tracking. [ENUM-REF-CANDIDATE: report|plan|submission|dataset|package|database|training_material|other — promote to reference product]' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Channel or mechanism by which the deliverable is transmitted to the sponsor (e.g., eTMF upload, secure email, sponsor portal, eCTD gateway). Supports audit trail and compliance verification.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current lifecycle state of the deliverable from initiation through sponsor acceptance. Drives milestone billing triggers and project management dashboards.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Document Reference Number' ;
    rdfs:comment 'Identifier of the associated document record in the eTMF or document management system (e.g., Veeva Vault document ID) for the accepted deliverable artifact. Enables cross-system traceability.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedEffortHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Effort Hours' ;
    rdfs:comment 'Planned labor hours estimated to produce this deliverable, as defined during SOW scoping. Used for resource planning, budget tracking, and variance analysis against actuals.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gcpAuditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Gcp Audit Required Flag' ;
    rdfs:comment 'Indicates whether this deliverable requires a formal GCP quality audit prior to submission, as mandated by the sponsor\'s quality agreement or applicable regulatory requirements.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phaseMilestone rdf:type rdf:Property ;
    rdfs:label 'Phase Milestone' ;
    rdfs:comment 'Study phase or operational milestone during which this deliverable is due (e.g., startup, enrollment, interim, closeout, post-study). Supports timeline planning and phase-gate reporting.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Date' ;
    rdfs:comment 'Contractually committed date by which the CRO must deliver this output to the sponsor, as defined in the SOW or study contract. Used for SLA tracking and milestone billing.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qcReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Qc Review Status' ;
    rdfs:comment 'Current status of the internal QC review process for this deliverable prior to sponsor submission. Ensures GCP compliance and reduces rejection risk.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Flag' ;
    rdfs:comment 'Indicates whether this deliverable is intended for inclusion in a regulatory submission package (e.g., NDA, BLA, MAA, eCTD). When true, triggers enhanced QC review and audit trail requirements.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleFunctionalTeam rdf:type rdf:Property ;
    rdfs:label 'Responsible Functional Team' ;
    rdfs:comment 'CRO functional team accountable for producing and delivering this output (e.g., Biostatistics, Data Management, Clinical Operations, Regulatory Affairs, Medical Writing). Drives resource allocation and escalation routing. [ENUM-REF-CANDIDATE: biostatistics|data_management|clinical_operations|regulatory_affairs|safety|medical_writing|pharmacovigilance|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Review Deadline Date' ;
    rdfs:comment 'Contractually defined date by which the sponsor must complete review and provide acceptance or rejection feedback. Supports SLA enforcement and escalation workflows.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionCount rdf:type rdf:Property ;
    rdfs:label 'Revision Count' ;
    rdfs:comment 'Total number of revision cycles this deliverable has undergone following initial submission. High revision counts may indicate quality issues or unclear acceptance criteria.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revisionDueDate rdf:type rdf:Property ;
    rdfs:label 'Revision Due Date' ;
    rdfs:comment 'Date by which the CRO must resubmit a revised deliverable following sponsor rejection or request for changes. Populated only when delivery_status is \'rejected\'.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Met Flag' ;
    rdfs:comment 'Indicates whether the deliverable was submitted within the contractually defined SLA target days. Populated upon actual delivery. Used for sponsor performance reporting and contract compliance.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetDays rdf:type rdf:Property ;
    rdfs:label 'Sla Target Days' ;
    rdfs:comment 'Contractually defined number of calendar days within which the CRO must deliver this output from the triggering event (e.g., database lock, last patient last visit). Basis for SLA compliance measurement.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Precise date and time when the deliverable was formally submitted to the sponsor, including timezone offset. Supports ALCOA+ audit trail requirements for electronic records.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tmfFilingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Tmf Filing Required Flag' ;
    rdfs:comment 'Indicates whether the accepted deliverable must be archived in the electronic Trial Master File (eTMF) per ICH E6(R2) and sponsor TMF reference model requirements.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigatorGrantId rdf:type rdf:Property ;
    rdfs:label 'Investigator Grant Id' ;
    rdfs:comment 'Primary key for investigator_grant' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestigatorGrant .

ind:approvedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Investigator grant approvals require employee-level traceability for fair market value compliance, Sunshine Act reporting, and financial controls. The approving employee\'s identity is auditable eviden' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:clinicalTrialAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Clinical Trial Authorization Id' ;
    rdfs:comment 'Foreign key linking to regulatory.clinical_trial_authorization. Business justification: Investigator grants cannot be executed and sites cannot be activated without a valid CTA for that country. Linking investigator_grant to the governing CTA is a real site activation dependency — grant ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClinicalTrialAuthorization .

ind:ethicsApprovalId rdf:type rdf:Property ;
    rdfs:label 'Ethics Approval Id' ;
    rdfs:comment 'Foreign key linking to compliance.ethics_approval. Business justification: Investigator grants cannot be executed without IRB/IEC ethics approval (irb_iec_approval_required flag). The irb_iec_approval_date is a denormalized copy of ethics_approval.decision_date; a proper FK ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EthicsApproval .

ind:ethicsSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Ethics Submission Id' ;
    rdfs:comment 'Foreign key linking to compliance.ethics_submission. Business justification: Investigator grants reference the ethics submission that authorized the study at the site. Linking grant to ethics_submission enables tracking of grant activation against submission status, supporting' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EthicsSubmission .

ind:investigationalSiteId rdf:type rdf:Property ;
    rdfs:label 'Investigational Site Id' ;
    rdfs:comment 'Reference to the investigational site (clinical research site) that is party to this grant agreement.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestigationalSite .

ind:principalInvestigatorId rdf:type rdf:Property ;
    rdfs:label 'Principal Investigator Id' ;
    rdfs:comment 'FK to site.principal_investigator' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrincipalInvestigator .

ind:studySiteId rdf:type rdf:Property ;
    rdfs:label 'Study Site Id' ;
    rdfs:comment 'Foreign key linking to site.study_site. Business justification: An investigator grant is created for a specific study-site combination. Linking investigator_grant to study_site enables direct lookup of the operational site record during payment processing, site ac' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudySite .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time at which the grant was formally approved internally by the CRO. Provides a precise audit trail event for the approval lifecycle stage.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the investigational site. Determines applicable regulatory requirements, tax treatment, currency, and local payment regulations for the grant.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsGrantReference rdf:type rdf:Property ;
    rdfs:label 'Ctms Grant Reference' ;
    rdfs:comment 'Identifier of the corresponding investigator grant record in Oracle Siebel CTMS. Enables cross-system traceability between the lakehouse Silver layer and the operational CTMS.' ;
    rdfs:domain ind:InvestigatorGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fairMarketValueVerified rdf:type rdf:Property ;
    rdfs:label 'Fair Market Value Verified' ;
    rdfs:comment 'Indicates whether the grant payment rates have been verified against Fair Market Value (FMV) benchmarks to ensure compliance with anti-kickback statutes and industry transparency requirements (e.g., Sunshine Act).' ;
    rdfs:domain ind:InvestigatorGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fmvBenchmarkSource rdf:type rdf:Property ;
    rdfs:label 'Fmv Benchmark Source' ;
    rdfs:comment 'Source of the Fair Market Value benchmark data used to validate grant payment rates (e.g., Medidata Grants Manager, McLaughlin & Associates, BBK Worldwide, internal database). Required for compliance documentation.' ;
    rdfs:domain ind:InvestigatorGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'Jurisdiction whose laws govern the interpretation and enforcement of this investigator grant (e.g., State of New York, England and Wales, Germany). Critical for dispute resolution.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantNumber rdf:type rdf:Property ;
    rdfs:label 'Grant Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the investigator grant, used in CTMS, SAP S/4HANA purchase orders, and site correspondence. Serves as the business-facing reference number across systems.' ;
    rdfs:domain ind:InvestigatorGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantTitle rdf:type rdf:Property ;
    rdfs:label 'Grant Title' ;
    rdfs:comment 'Descriptive title of the investigator grant agreement, typically referencing the study protocol number and site name for human-readable identification.' ;
    rdfs:domain ind:InvestigatorGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantType rdf:type rdf:Property ;
    rdfs:label 'Grant Type' ;
    rdfs:comment 'Classification of the investigator grant structure. Per-capita grants pay a fixed amount per enrolled subject; fee-for-service grants pay per completed procedure/visit; hybrid combines both; fixed-fee covers all site activities for a lump sum.' ;
    rdfs:domain ind:InvestigatorGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantVersion rdf:type rdf:Property ;
    rdfs:label 'Grant Version' ;
    rdfs:comment 'Version identifier of the investigator grant document (e.g., v1.0, v2.0). Incremented with each amendment or renegotiation cycle to maintain a complete audit trail of rate changes.' ;
    rdfs:domain ind:InvestigatorGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbIecApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Approval Required' ;
    rdfs:comment 'Indicates whether the grant terms (particularly payment rates) require review and approval by the site\'s Institutional Review Board (IRB) or Independent Ethics Committee (IEC) to ensure payments do not constitute undue inducement.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overheadPercentage rdf:type rdf:Property ;
    rdfs:label 'Overhead Percentage' ;
    rdfs:comment 'Institutional overhead or indirect cost rate (expressed as a percentage) applied on top of direct procedure and visit costs. Negotiated with the site institution and added to the base grant rates.' ;
    rdfs:domain ind:InvestigatorGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passThroughBudget rdf:type rdf:Property ;
    rdfs:label 'Pass Through Budget' ;
    rdfs:comment 'Portion of the grant budget designated as pass-through costs (e.g., lab fees, imaging, central lab kits) that are reimbursed at cost without markup. Tracked separately from service fees for financial reporting.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Agreed mechanism for disbursing grant payments to the investigational site or PI (e.g., wire transfer, ACH, check). Drives SAP S/4HANA accounts payable processing.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentScheduleType rdf:type rdf:Property ;
    rdfs:label 'Payment Schedule Type' ;
    rdfs:comment 'Classification of the payment trigger mechanism for this grant. Determines how and when site payments are generated: per completed visit, per completed procedure, upon milestone achievement, or on a periodic basis.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Number of days from invoice receipt or milestone trigger within which payment must be made to the site. Standard net payment terms (e.g., Net 30, Net 45) as agreed in the grant.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedSubjectCount rdf:type rdf:Property ;
    rdfs:label 'Planned Subject Count' ;
    rdfs:comment 'Number of subjects the site is contracted to enroll under this grant. Drives the total grant value calculation and site capacity planning.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sapPurchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Purchase Order Number' ;
    rdfs:comment 'SAP S/4HANA purchase order number created to encumber funds for this investigator grant. Links financial commitments in the ERP to the contractual grant terms.' ;
    rdfs:domain ind:InvestigatorGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenFailurePaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Screen Failure Payment Amount' ;
    rdfs:comment 'Fixed monetary amount payable to the site per screen-failed subject, in the grant currency. Used when screen failure compensation is a flat fee rather than a percentage.' ;
    rdfs:domain ind:InvestigatorGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:screenFailureRate rdf:type rdf:Property ;
    rdfs:label 'Screen Failure Rate' ;
    rdfs:comment 'Agreed reimbursement rate per screen-failed subject (as a percentage of the full screening visit cost or a fixed amount). Compensates sites for screening work on subjects who do not meet eligibility criteria.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceFeeBudget rdf:type rdf:Property ;
    rdfs:label 'Service Fee Budget' ;
    rdfs:comment 'Portion of the grant budget representing direct service fees for investigator and site staff time (visits, procedures, coordination). Excludes pass-through costs.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sunshineActReportable rdf:type rdf:Property ;
    rdfs:label 'Sunshine Act Reportable' ;
    rdfs:comment 'Indicates whether payments under this grant are reportable under the US Physician Payments Sunshine Act (Open Payments) or equivalent transparency regulations. Drives compliance reporting workflows.' ;
    rdfs:domain ind:InvestigatorGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Tax identification number (TIN) or VAT registration number of the investigational site or PI entity for payment processing and tax reporting compliance.' ;
    rdfs:domain ind:InvestigatorGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalGrantValue rdf:type rdf:Property ;
    rdfs:label 'Total Grant Value' ;
    rdfs:comment 'Total estimated monetary value of the investigator grant based on planned subject enrollment, visit schedule, and procedure rates. Used for budget planning, accrual calculations, and SAP purchase order creation.' ;
    rdfs:domain ind:InvestigatorGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vatApplicable rdf:type rdf:Property ;
    rdfs:label 'Vat Applicable' ;
    rdfs:comment 'Indicates whether Value Added Tax (VAT) or equivalent indirect tax applies to payments under this grant. Drives tax calculation logic in SAP S/4HANA accounts payable.' ;
    rdfs:domain ind:InvestigatorGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:withholdingPercentage rdf:type rdf:Property ;
    rdfs:label 'Withholding Percentage' ;
    rdfs:comment 'Percentage of each payment withheld and held in reserve until study completion or database lock (DBL). Released upon satisfactory completion of site obligations. Common risk-management mechanism in investigator grants.' ;
    rdfs:domain ind:InvestigatorGrant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentMsaMasterServiceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Parent Msa Master Service Agreement Id' ;
    rdfs:comment 'Reference to the original MSA record when this record represents an amendment or change order. Enables hierarchical agreement versioning. Null for original MSAs.' ;
    rdfs:domain ind:MasterServiceAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MasterServiceAgreement .

ind:therapeuticAreaId rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Area Id' ;
    rdfs:comment 'Foreign key linking to program.therapeutic_area. Business justification: MSA scope is defined by therapeutic area; contract portfolio analytics, rate benchmarking, and CRO capability assessments are all segmented by TA. Linking to the canonical therapeutic_area table norma' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TherapeuticArea .

ind:auditRightFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Right Flag' ;
    rdfs:comment 'Indicates whether the sponsor has contractual rights to audit the CRO\'s facilities, systems, and study records. True = audit rights granted; False = no audit rights. Required for GCP compliance and regulatory inspection readiness.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:executedDate rdf:type rdf:Property ;
    rdfs:label 'Executed Date' ;
    rdfs:comment 'Actual date on which the MSA was fully executed (signed by all authorized parties). Marks the transition from PENDING_EXECUTION to ACTIVE status. Sourced from Veeva Vault e-signature record.' ;
    rdfs:domain ind:MasterServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forceMajeureClause rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Clause' ;
    rdfs:comment 'Indicates whether the MSA contains a force majeure clause that excuses performance obligations under extraordinary circumstances (e.g., pandemic, natural disaster). True = clause present; False = no force majeure provision.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:indemnificationScope rdf:type rdf:Property ;
    rdfs:label 'Indemnification Scope' ;
    rdfs:comment 'Contractual indemnification structure defining which party bears liability for third-party claims. MUTUAL = both parties indemnify each other; SPONSOR_INDEMNIFIES_CRO = sponsor bears primary liability; CRO_INDEMNIFIES_SPONSOR = CRO bears primary liability; LIMITED = capped or restricted indemnification.' ;
    rdfs:domain ind:MasterServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Required Flag' ;
    rdfs:comment 'Indicates whether the MSA mandates that the CRO maintain specified levels of professional indemnity, clinical trial, or general liability insurance. True = insurance requirements specified; False = no insurance mandate.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipOwnership rdf:type rdf:Property ;
    rdfs:label 'Ip Ownership' ;
    rdfs:comment 'Contractual allocation of intellectual property rights arising from the clinical research activities. SPONSOR = all IP vests in sponsor; CRO = CRO retains IP; JOINT = jointly owned; BACKGROUND_RETAINED = each party retains pre-existing background IP.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msaNumber rdf:type rdf:Property ;
    rdfs:label 'Msa Number' ;
    rdfs:comment 'Externally-known, human-readable agreement reference number assigned by the CRO or sponsor (e.g., MSA-2024-00123). Used for cross-system reconciliation between Veeva Vault and SAP S/4HANA. Serves as the BUSINESS_IDENTIFIER category for this MASTER_AGREEMENT entity.' ;
    rdfs:domain ind:MasterServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryScope rdf:type rdf:Property ;
    rdfs:label 'Regulatory Scope' ;
    rdfs:comment 'Primary regulatory authority or geographic scope under which studies governed by this MSA will be conducted and submitted. Determines applicable GCP guidelines, data privacy requirements, and submission standards. [ENUM-REF-CANDIDATE: FDA|EMA|PMDA|MHRA|TGA|MULTI_REGIONAL|GLOBAL — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MasterServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapContractNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Contract Number' ;
    rdfs:comment 'Contract identifier assigned in SAP S/4HANA project accounting and procurement module. Enables financial reconciliation of billing milestones, purchase orders, and revenue recognition entries against the MSA.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Included Flag' ;
    rdfs:comment 'Indicates whether the MSA incorporates Service Level Agreement (SLA) provisions defining performance standards, KPIs, and remedies for non-performance. True = SLA terms embedded or referenced; False = no SLA provisions.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorName rdf:type rdf:Property ;
    rdfs:label 'Sponsor Name' ;
    rdfs:comment 'Legal entity name of the pharmaceutical or biotech sponsor that is the counterparty to this MSA. Sourced from Veeva Vault and SAP S/4HANA vendor master. Used for reporting and regulatory correspondence.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractingPermitted rdf:type rdf:Property ;
    rdfs:label 'Subcontracting Permitted' ;
    rdfs:comment 'Indicates whether the CRO is permitted to subcontract any portion of the services to third-party vendors without prior sponsor approval. True = permitted (subject to conditions); False = not permitted without explicit sponsor consent.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationForConvenienceDays rdf:type rdf:Property ;
    rdfs:label 'Termination For Convenience Days' ;
    rdfs:comment 'Number of days advance written notice required for either party to terminate the MSA for convenience (without cause). A key commercial risk management term.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalContractValue rdf:type rdf:Property ;
    rdfs:label 'Total Contract Value' ;
    rdfs:comment 'Estimated or committed total financial value of the MSA over its full term, in the contract currency. Used for revenue recognition planning, financial forecasting, and SAP S/4HANA project accounting. Not a calculated aggregate — represents the contractually stated or estimated TCV.' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredProviderAgreementId rdf:type rdf:Property ;
    rdfs:label 'Preferred Provider Agreement Id' ;
    rdfs:comment 'Primary key for preferred_provider_agreement' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PreferredProviderAgreement .

ind:croAllianceManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Cro Alliance Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: The CRO alliance manager on a PPA is a named internal employee responsible for the strategic sponsor relationship. This FK supports alliance management reporting, key personnel tracking, governance co' ;
    rdfs:domain ind:PreferredProviderAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentPpaPreferredProviderAgreementId rdf:type rdf:Property ;
    rdfs:label 'Parent Ppa Preferred Provider Agreement Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original or parent PPA when this record represents an amendment or successor agreement. Null for original agreements. Enables amendment lineage tracking.' ;
    rdfs:domain ind:PreferredProviderAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PreferredProviderAgreement .

ind:ctmsPpaReference rdf:type rdf:Property ;
    rdfs:label 'Ctms Ppa Reference' ;
    rdfs:comment 'Reference identifier for this Preferred Provider Agreement in Oracle Siebel CTMS. Links the strategic agreement to study-level task orders and site monitoring activities managed within the CTMS.' ;
    rdfs:domain ind:PreferredProviderAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Description of the geographic regions or countries covered by this Preferred Provider Agreement (e.g., North America, Europe, Global). Defines where the CRO is authorized to conduct services under the PPA terms.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governanceCommitteeName rdf:type rdf:Property ;
    rdfs:label 'Governance Committee Name' ;
    rdfs:comment 'Name of the joint governance body (e.g., Joint Steering Committee, Alliance Management Committee) established under this PPA to oversee performance, resolve escalations, and manage the strategic partnership.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governanceReviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Governance Review Frequency' ;
    rdfs:comment 'Contractually agreed frequency at which the joint governance committee convenes to review PPA performance, KPIs, and strategic alignment between sponsor and CRO.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppaNumber rdf:type rdf:Property ;
    rdfs:label 'Ppa Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the Preferred Provider Agreement, used in correspondence, SAP contracts, and Veeva Vault document references. Follows the format PPA-{SPONSOR_CODE}-{YEAR}.' ;
    rdfs:domain ind:PreferredProviderAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardReference rdf:type rdf:Property ;
    rdfs:label 'Rate Card Reference' ;
    rdfs:comment 'Reference identifier for the pre-negotiated rate card document associated with this Preferred Provider Agreement. Links to the Veeva Vault document or SAP pricing schedule containing unit rates for services delivered under the PPA.' ;
    rdfs:domain ind:PreferredProviderAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCategoryScope rdf:type rdf:Property ;
    rdfs:label 'Service Category Scope' ;
    rdfs:comment 'Comma-separated list of CRO service categories covered under this PPA (e.g., Clinical Operations, Data Management, Biostatistics, Regulatory Affairs, Pharmacovigilance). Defines the functional scope of the preferred partnership. [ENUM-REF-CANDIDATE: clinical_operations|data_management|biostatistics|regulatory_affairs|pharmacovigilance|medical_writing|laboratory — promote to reference product]' ;
    rdfs:domain ind:PreferredProviderAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Sla Document Reference' ;
    rdfs:comment 'Reference identifier for the SLA schedule document in Veeva Vault or eTMF. Populated only when sla_included_flag is True. Links to the specific SLA exhibit defining KPI targets and remediation terms.' ;
    rdfs:domain ind:PreferredProviderAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorAllianceManager rdf:type rdf:Property ;
    rdfs:label 'Sponsor Alliance Manager' ;
    rdfs:comment 'Full name of the sponsor-side Alliance Manager or Relationship Manager responsible for overseeing the strategic partnership and governance of this Preferred Provider Agreement.' ;
    rdfs:domain ind:PreferredProviderAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticAreaScope rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Area Scope' ;
    rdfs:comment 'Comma-separated list of therapeutic areas (e.g., Oncology, Neurology, Cardiovascular) covered under this Preferred Provider Agreement. Defines the portfolio of studies eligible to be placed under the PPA. [ENUM-REF-CANDIDATE: oncology|neurology|cardiovascular|immunology|rare_disease|infectious_disease|metabolic|respiratory — promote to reference product]' ;
    rdfs:domain ind:PreferredProviderAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCommitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Amount' ;
    rdfs:comment 'Minimum financial volume (in contract currency) the sponsor commits to place with the CRO over the PPA term. Triggers preferred pricing tiers and governs rebate or penalty clauses if thresholds are not met.' ;
    rdfs:domain ind:PreferredProviderAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCommitmentUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Unit' ;
    rdfs:comment 'Unit of measure for the volume commitment threshold (e.g., currency for financial commitment, study_count for number of studies, fte_hours for full-time equivalent hours). Determines how compliance with the volume commitment is tracked.' ;
    rdfs:domain ind:PreferredProviderAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardId rdf:type rdf:Property ;
    rdfs:label 'Rate Card Id' ;
    rdfs:comment 'Unique system-generated identifier for the rate card record. Primary key for the rate_card data product within the agreement domain.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateCard .

ind:jobProfileId rdf:type rdf:Property ;
    rdfs:label 'Job Profile Id' ;
    rdfs:comment 'Foreign key linking to workforce.job_profile. Business justification: Rate cards in clinical trials are structured around job profiles (CRA Level II, Data Manager, etc.). Linking rate_card to job_profile enables billing rate validation against actual workforce grades, s' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobProfile .

ind:labPanelId rdf:type rdf:Property ;
    rdfs:label 'Lab Panel Id' ;
    rdfs:comment 'Foreign key linking to laboratory.lab_panel. Business justification: Rate cards price lab services at the panel level (per panel per specimen). Finance teams validate central lab invoices by matching billed panel codes to contracted rate card line items. Direct FK repl' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabPanel .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date on which the rate card received final approval from both the CRO and sponsor. Marks the transition from negotiation to binding commercial reference. Required for SOX audit trail and contract management compliance.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingMilestoneFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Milestone Flag' ;
    rdfs:comment 'Indicates whether this rate card line is associated with a milestone-based billing event (True) rather than a time-and-materials or unit-based billing model (False). Supports milestone payment schedule construction in SOW and study contract workflows.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeOrderApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Change Order Applicable Flag' ;
    rdfs:comment 'Indicates whether this rate card line can be used for change order valuation (True). Some rate card lines may be restricted to initial SOW pricing only and not applicable for out-of-scope change order pricing.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ctmsRateReference rdf:type rdf:Property ;
    rdfs:label 'Ctms Rate Reference' ;
    rdfs:comment 'Reference identifier for this rate card entry in Oracle Siebel CTMS, used for SOW budget construction and site payment planning. Enables cross-system reconciliation between contract rates and operational trial management.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationBasis rdf:type rdf:Property ;
    rdfs:label 'Escalation Basis' ;
    rdfs:comment 'The basis on which annual rate escalation is calculated: \'fixed\' (predetermined fixed percentage), \'cpi_linked\' (tied to Consumer Price Index), \'negotiated\' (subject to annual renegotiation), \'none\' (no escalation applies for the rate card term).' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRatePct rdf:type rdf:Property ;
    rdfs:label 'Escalation Rate Pct' ;
    rdfs:comment 'Annual rate escalation percentage applied to the unit rate at each contract year anniversary (e.g., CPI-linked or fixed escalation). Expressed as a percentage (e.g., 3.00 = 3%). Governs automatic rate adjustments over multi-year MSA terms.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Geographic region or country scope for which this rate applies (e.g., North America, Western Europe, Asia-Pacific, or specific ISO 3166-1 alpha-3 country codes). Reflects regional labor cost differentials and regulatory environment complexity. Null if the rate is globally applicable.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this rate card record. Required for ALCOA+ data integrity compliance, 21 CFR Part 11 audit trail, and SOX change management controls. Enables detection of unauthorized rate modifications.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:markupPct rdf:type rdf:Property ;
    rdfs:label 'Markup Pct' ;
    rdfs:comment 'CRO margin markup percentage applied to pass-through costs before billing to the sponsor. Expressed as a percentage (e.g., 10.00 = 10%). Applicable only when pass_through_flag is True. Governs pass-through billing in sponsor invoices.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumUnits rdf:type rdf:Property ;
    rdfs:label 'Maximum Units' ;
    rdfs:comment 'Maximum number of units covered at this rate before a volume tier escalation or renegotiation is triggered. Supports tiered pricing structures in MSAs and PPAs. Null if no maximum cap applies.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumUnits rdf:type rdf:Property ;
    rdfs:label 'Minimum Units' ;
    rdfs:comment 'Minimum number of units that must be purchased or committed to for this rate to apply. Supports volume commitment structures in preferred provider agreements. Null if no minimum commitment is required.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passThroughFlag rdf:type rdf:Property ;
    rdfs:label 'Pass Through Flag' ;
    rdfs:comment 'Indicates whether this rate card line represents a pass-through cost (True) that is billed to the sponsor at cost without CRO margin, or a service fee (False) that includes CRO margin. Critical for SOW budget categorization and sponsor invoice reconciliation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateCardName rdf:type rdf:Property ;
    rdfs:label 'Rate Card Name' ;
    rdfs:comment 'Human-readable descriptive name for the rate card (e.g., \'Oncology Phase III Global Rate Card FY2024\'). Used for identification in CTMS, SAP, and contract management workflows.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardNumber rdf:type rdf:Property ;
    rdfs:label 'Rate Card Number' ;
    rdfs:comment 'Externally-known unique business identifier for the rate card, used in SOW budget construction, change order valuation, and sponsor communications. Follows the CRO internal numbering convention (e.g., RC-SPONS2024-001).' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Card Status' ;
    rdfs:comment 'Current lifecycle status of the rate card. \'draft\' indicates under negotiation; \'active\' indicates currently in use for SOW pricing; \'superseded\' indicates replaced by a newer version; \'expired\' indicates past effective date range; \'withdrawn\' indicates cancelled before activation.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardType rdf:type rdf:Property ;
    rdfs:label 'Rate Card Type' ;
    rdfs:comment 'Classification of the rate card by its commercial scope. \'standard\' applies to general CRO service pricing; \'preferred_provider\' applies under a PPA; \'study_specific\' is negotiated for a single study; \'therapeutic_area\' is scoped to a disease area; \'regional\' applies to a geographic region. [ENUM-REF-CANDIDATE: standard|preferred_provider|study_specific|therapeutic_area|regional — promote to reference product]' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPriceListNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Price List Number' ;
    rdfs:comment 'Reference identifier for the corresponding price list or condition record in SAP S/4HANA used for automated invoice generation and revenue recognition. Ensures alignment between the contract rate card and the financial billing system.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCategory rdf:type rdf:Property ;
    rdfs:label 'Service Category' ;
    rdfs:comment 'High-level CRO service category to which this rate applies (e.g., Clinical Monitoring, Data Management, Biostatistics, Regulatory Affairs, Medical Writing, Project Management, Pharmacovigilance, Laboratory Services). Aligns with SOW service category taxonomy. [ENUM-REF-CANDIDATE: clinical_monitoring|data_management|biostatistics|regulatory_affairs|medical_writing|project_management|pharmacovigilance|laboratory — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceSubcategory rdf:type rdf:Property ;
    rdfs:label 'Service Subcategory' ;
    rdfs:comment 'Granular sub-classification of the CRO service within the service category (e.g., within Clinical Monitoring: Site Initiation Visit, Routine Monitoring Visit, Close-Out Visit; within Data Management: eCRF Design, Data Entry, Query Management). Enables precise SOW line-item pricing.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sowApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Sow Applicable Flag' ;
    rdfs:comment 'Indicates whether this rate card line is currently available for use in new Scope of Work (SOW) budget construction (True) or has been restricted from new SOW use (False). Supports rate card governance and prevents use of expired or withdrawn rates in new agreements.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Sponsor Approved By' ;
    rdfs:comment 'Name or identifier of the sponsor\'s authorized representative who approved the rate card. Confirms bilateral acceptance of the pre-negotiated rates. Required for contract enforceability and SOX audit trail.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'The billing unit against which the unit rate is applied. Defines how the CRO service is quantified for invoicing: per_hour (time-and-materials), per_day (daily rate), per_visit (site monitoring visit), per_subject (enrolled patient), per_procedure (clinical procedure), per_site (investigator site), per_month (FTE or retainer), per_milestone (deliverable-based), flat_fee (fixed price). [ENUM-REF-CANDIDATE: per_hour|per_day|per_visit|per_subject|per_procedure|per_site|per_month|per_milestone|flat_fee — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitRate rdf:type rdf:Property ;
    rdfs:label 'Unit Rate' ;
    rdfs:comment 'Pre-negotiated price per unit of measure for this service/staff category combination. The principal quantitative fact of the rate card. Used as the pricing reference for SOW budget construction and change order valuation. Stored with 4 decimal places to support multi-currency precision.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Pct' ;
    rdfs:comment 'Percentage discount applied to the unit rate when volume thresholds defined in the MSA or PPA are met. Expressed as a percentage (e.g., 5.00 = 5%). Supports tiered pricing and preferred provider incentive structures.' ;
    rdfs:domain ind:RateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Billing Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which sponsor invoices will be issued under this SOW. May differ from contract currency_code when multi-currency billing arrangements apply.' ;
    rdfs:domain ind:ScopeOfWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biostatisticsIncluded rdf:type rdf:Property ;
    rdfs:label 'Biostatistics Included' ;
    rdfs:comment 'Indicates whether biostatistical analysis and reporting services (Statistical Analysis Plan authoring, analysis datasets, tables/listings/figures) are included in this SOW. True = biostatistics is in scope.' ;
    rdfs:domain ind:ScopeOfWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryCount rdf:type rdf:Property ;
    rdfs:label 'Country Count' ;
    rdfs:comment 'Number of countries included in the geographic scope of this SOW. Used for complexity assessment, resource planning, and regulatory submission tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ctmsSowReference rdf:type rdf:Property ;
    rdfs:label 'Ctms Sow Reference' ;
    rdfs:comment 'Identifier of the corresponding SOW record in the Oracle Siebel CTMS system. Supports cross-system reconciliation between the lakehouse and the operational CTMS.' ;
    rdfs:domain ind:ScopeOfWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataManagementIncluded rdf:type rdf:Property ;
    rdfs:label 'Data Management Included' ;
    rdfs:comment 'Indicates whether clinical data management services (EDC build, eCRF design, data cleaning, database lock) are included in this SOW. True = data management is in scope.' ;
    rdfs:domain ind:ScopeOfWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCurrentVersion rdf:type rdf:Property ;
    rdfs:label 'Is Current Version' ;
    rdfs:comment 'Indicates whether this SOW record represents the currently active and operative version. True = this is the current version; False = this version has been superseded by a later amendment. Enables efficient filtering to the active SOW.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyAssumptions rdf:type rdf:Property ;
    rdfs:label 'Key Assumptions' ;
    rdfs:comment 'Material assumptions underlying the SOW budget and timeline (e.g., assumed screen failure rate, assumed site activation timeline, assumed protocol amendment frequency). Deviations from these assumptions may trigger change orders.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringIncluded rdf:type rdf:Property ;
    rdfs:label 'Monitoring Included' ;
    rdfs:comment 'Indicates whether clinical site monitoring services (on-site and/or remote monitoring by CRAs, Source Data Verification) are included in this SOW. True = monitoring is in scope.' ;
    rdfs:domain ind:ScopeOfWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outOfScopeItems rdf:type rdf:Property ;
    rdfs:label 'Out Of Scope Items' ;
    rdfs:comment 'Explicit list of services or activities that are excluded from this SOW. Prevents scope creep disputes and clarifies sponsor versus CRO responsibilities.' ;
    rdfs:domain ind:ScopeOfWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacovigilanceIncluded rdf:type rdf:Property ;
    rdfs:label 'Pharmacovigilance Included' ;
    rdfs:comment 'Indicates whether pharmacovigilance and safety reporting services (SAE/SUSAR processing, expedited regulatory reporting, signal detection) are included in this SOW. True = pharmacovigilance is in scope.' ;
    rdfs:domain ind:ScopeOfWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedSiteCount rdf:type rdf:Property ;
    rdfs:label 'Planned Site Count' ;
    rdfs:comment 'Number of investigational sites planned under this SOW. Drives resource allocation for Clinical Research Associates (CRAs), monitoring visit budgets, and site management activities.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryIncluded rdf:type rdf:Property ;
    rdfs:label 'Regulatory Included' ;
    rdfs:comment 'Indicates whether regulatory affairs services (IND/NDA/BLA/MAA submissions, eCTD compilation, agency interactions) are included in this SOW. True = regulatory is in scope.' ;
    rdfs:domain ind:ScopeOfWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceCategorySummary rdf:type rdf:Property ;
    rdfs:label 'Service Category Summary' ;
    rdfs:comment 'Free-text summary of all service categories included in this SOW (e.g., \'Monitoring, Data Management, Biostatistics, Medical Writing, Regulatory\'). Provides a human-readable overview of the CRO\'s service obligations for reporting and contract management.' ;
    rdfs:domain ind:ScopeOfWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sowNumber rdf:type rdf:Property ;
    rdfs:label 'Sow Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the Scope of Work document, used in sponsor communications, contract management systems, and regulatory correspondence. Follows the CRO\'s SOW numbering convention.' ;
    rdfs:domain ind:ScopeOfWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sowTitle rdf:type rdf:Property ;
    rdfs:label 'Sow Title' ;
    rdfs:comment 'Human-readable title or short description of the Scope of Work document, typically referencing the study name, therapeutic area, or service bundle (e.g., \'Phase III Oncology Study – Full-Service CRO SOW\').' ;
    rdfs:domain ind:ScopeOfWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sowType rdf:type rdf:Property ;
    rdfs:label 'Sow Type' ;
    rdfs:comment 'Classification of the SOW by engagement model: full_service (CRO manages all study functions), functional_service (CRO provides specific functional units), task_order (discrete task under a master SOW), change_order (modification to an existing SOW), or amendment (formal contractual amendment). [ENUM-REF-CANDIDATE: full_service|functional_service|task_order|change_order|amendment — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:ScopeOfWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorContactName rdf:type rdf:Property ;
    rdfs:label 'Sponsor Contact Name' ;
    rdfs:comment 'Name of the sponsor\'s designated representative or project manager who is the primary point of contact for this SOW. Used for contract governance and escalation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededDate rdf:type rdf:Property ;
    rdfs:label 'Superseded Date' ;
    rdfs:comment 'Date on which this SOW version was superseded by a newer amendment or version. Null if the SOW is still the current active version. Supports version lineage tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceLevelAgreementId rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement Id' ;
    rdfs:comment 'Unique surrogate identifier for the Service Level Agreement record in the lakehouse silver layer.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceLevelAgreement .

ind:healthAuthorityId rdf:type rdf:Property ;
    rdfs:label 'Health Authority Id' ;
    rdfs:comment 'Foreign key linking to regulatory.health_authority. Business justification: SLAs with regulatory_commitment_flag are driven by specific health authority requirements (e.g., FDA 15-day expedited safety reporting timelines). Linking SLA to the governing health authority enables' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HealthAuthority .

ind:supersededByServiceLevelAgreementId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Service Level Agreement Id' ;
    rdfs:comment 'Reference to the newer SLA record that replaces this one when sla_status is \'superseded\'. Enables forward navigation of the SLA version chain for audit and historical analysis.' ;
    rdfs:domain ind:ServiceLevelAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceLevelAgreement .

ind:creditApplicable rdf:type rdf:Property ;
    rdfs:label 'Credit Applicable' ;
    rdfs:comment 'Indicates whether a service credit (bonus or rebate) is awarded to the sponsor when the CRO exceeds the SLA threshold. Supports incentive-based contract structures.' ;
    rdfs:domain ind:ServiceLevelAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditValue rdf:type rdf:Property ;
    rdfs:label 'Credit Value' ;
    rdfs:comment 'Numeric value of the service credit awarded when the CRO exceeds the SLA target. Expressed in contract currency or as a percentage of invoice, consistent with penalty_type conventions.' ;
    rdfs:domain ind:ServiceLevelAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Calendar date on which this SLA ceases to be binding. Nullable for open-ended SLAs that remain in force until the contract terminates.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Calendar date on which this SLA becomes binding and performance measurement begins. Aligns with the contract or SOW commencement date.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationContact rdf:type rdf:Property ;
    rdfs:label 'Escalation Contact' ;
    rdfs:comment 'Name or role of the designated escalation contact (e.g., Project Manager, Sponsor Alliance Manager) who must be notified when the escalation threshold is breached. Supports SLA governance and sponsor relationship management.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Value' ;
    rdfs:comment 'Numeric value at which a near-breach warning or escalation is triggered before the formal SLA threshold is reached (e.g., escalate at 20 hours for a 24-hour SAE reporting SLA). Enables proactive remediation.' ;
    rdfs:domain ind:ServiceLevelAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusionCriteria rdf:type rdf:Property ;
    rdfs:label 'Exclusion Criteria' ;
    rdfs:comment 'Free-text description of conditions or events that are excluded from SLA measurement (e.g., sponsor-caused delays, system downtime, force majeure, regulatory authority hold). Critical for fair breach adjudication.' ;
    rdfs:domain ind:ServiceLevelAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingRegulation rdf:type rdf:Property ;
    rdfs:label 'Governing Regulation' ;
    rdfs:comment 'Specific regulatory citation that mandates or informs this SLA threshold when regulatory_commitment_flag is True (e.g., \'FDA 21 CFR 312.32 – 15-day SAE reporting\', \'ICH E2A – expedited safety reporting\', \'EU CTR 536/2014 Article 42\'). Supports regulatory audit readiness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gracePeriodUnit rdf:type rdf:Property ;
    rdfs:label 'Grace Period Unit' ;
    rdfs:comment 'Unit of measure for the grace period value (hours, business_days, or calendar_days). Paired with grace_period_value to define the full grace period window.' ;
    rdfs:domain ind:ServiceLevelAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gracePeriodValue rdf:type rdf:Property ;
    rdfs:label 'Grace Period Value' ;
    rdfs:comment 'Numeric value of the allowable grace period beyond the threshold before a breach is formally recorded (e.g., 2 for a 2-hour grace period). Accommodates system downtime or force majeure scenarios.' ;
    rdfs:domain ind:ServiceLevelAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'How frequently SLA performance is measured and reported: per_event (each occurrence), daily, weekly, monthly, quarterly, or annually. Drives the cadence of SLA performance review meetings with the sponsor.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'Description of how the SLA metric is measured and from which source system (e.g., \'Calculated from SAE receipt timestamp to submission timestamp in Oracle Argus Safety\', \'Query open-to-close duration in Medidata Rave EDC\'). Ensures auditability of performance calculations.' ;
    rdfs:domain ind:ServiceLevelAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyApplicable rdf:type rdf:Property ;
    rdfs:label 'Penalty Applicable' ;
    rdfs:comment 'Indicates whether a financial penalty or service credit applies when this SLA is breached. True = penalty/credit terms are defined; False = informational SLA with no financial consequence.' ;
    rdfs:domain ind:ServiceLevelAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyCapValue rdf:type rdf:Property ;
    rdfs:label 'Penalty Cap Value' ;
    rdfs:comment 'Maximum cumulative penalty or credit that can be applied under this SLA within a measurement period, expressed in the penalty currency or as a percentage cap. Protects the CRO from unlimited liability exposure.' ;
    rdfs:domain ind:ServiceLevelAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code applicable to the penalty_value when penalty_type is fixed_fee (e.g., USD, EUR, GBP). Null for non-monetary penalty types.' ;
    rdfs:domain ind:ServiceLevelAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyType rdf:type rdf:Property ;
    rdfs:label 'Penalty Type' ;
    rdfs:comment 'Type of financial consequence applied upon SLA breach: fixed_fee (flat monetary penalty), percentage_of_invoice (percentage deducted from the relevant invoice), service_credit (credit applied to future invoices), milestone_hold (billing milestone withheld), none (no financial penalty).' ;
    rdfs:domain ind:ServiceLevelAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyValue rdf:type rdf:Property ;
    rdfs:label 'Penalty Value' ;
    rdfs:comment 'Numeric value of the penalty or credit applied upon breach. Interpretation depends on penalty_type: a fixed monetary amount (in contract currency) for fixed_fee, or a percentage for percentage_of_invoice. Commercially sensitive.' ;
    rdfs:domain ind:ServiceLevelAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryCommitmentFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Commitment Flag' ;
    rdfs:comment 'Indicates whether this SLA is directly tied to a regulatory reporting obligation (e.g., FDA 15-day SAE reporting, EMA SUSAR submission timelines). True = regulatory deadline drives the SLA threshold; False = contractual performance target only.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingFormat rdf:type rdf:Property ;
    rdfs:label 'Reporting Format' ;
    rdfs:comment 'Agreed format for communicating SLA performance results to the sponsor: dashboard (real-time portal), monthly_report (formal written report), quarterly_review (governance meeting), ad_hoc (on-request), automated_alert (system-generated notification).' ;
    rdfs:domain ind:ServiceLevelAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCode rdf:type rdf:Property ;
    rdfs:label 'Sla Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this SLA within the contract management system (e.g., SLA-QRY-001). Used as the business key for cross-system reference and regulatory traceability.' ;
    rdfs:domain ind:ServiceLevelAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Status' ;
    rdfs:comment 'Current lifecycle state of the SLA: draft (under negotiation), active (in force), suspended (temporarily paused by mutual agreement), expired (past effective end date), terminated (ended early), superseded (replaced by an amendment).' ;
    rdfs:domain ind:ServiceLevelAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTitle rdf:type rdf:Property ;
    rdfs:label 'Sla Title' ;
    rdfs:comment 'Human-readable short title describing the SLA commitment (e.g., \'SAE Reporting Turnaround – 24h\', \'Query Resolution – 5 Business Days\'). Used in dashboards, reports, and sponsor communications.' ;
    rdfs:domain ind:ServiceLevelAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaType rdf:type rdf:Property ;
    rdfs:label 'Sla Type' ;
    rdfs:comment 'Classification of the SLA metric type: response_time (time to first action), turnaround_time (time to completion), frequency (how often an activity must occur), rate (throughput rate), percentage (proportion-based target), count (absolute volume target).' ;
    rdfs:domain ind:ServiceLevelAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMetricName rdf:type rdf:Property ;
    rdfs:label 'Target Metric Name' ;
    rdfs:comment 'Descriptive name of the specific performance metric being measured (e.g., \'Time to SAE Initial Report\', \'Query Resolution Turnaround\', \'Monitoring Visit Frequency\', \'Data Entry Lag Days\', \'Site Activation Cycle Time\').' ;
    rdfs:domain ind:ServiceLevelAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdDirection rdf:type rdf:Property ;
    rdfs:label 'Threshold Direction' ;
    rdfs:comment 'Specifies whether compliance requires the measured value to be less than or equal to (e.g., turnaround time ≤ 24h), greater than or equal to (e.g., visit frequency ≥ 1/month), or exactly equal to the threshold. Critical for automated compliance evaluation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit' ;
    rdfs:comment 'Unit of measure for the threshold value (e.g., hours, business_days, calendar_days, percentage, visits_per_month). Defines how the threshold_value is interpreted for compliance assessment. [ENUM-REF-CANDIDATE: hours|business_days|calendar_days|percentage|visits_per_month|days|weeks — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceLevelAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Value' ;
    rdfs:comment 'The numeric performance threshold that the CRO must meet or exceed for this SLA (e.g., 24 for a 24-hour SAE reporting window, 95 for 95% query resolution rate, 5 for 5 business days). The principal quantitative commitment of the SLA.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationId rdf:type rdf:Property ;
    rdfs:label 'Application Id' ;
    rdfs:comment 'Foreign key linking to regulatory.application. Business justification: Study contracts are scoped to a specific regulatory application (IND/NDA/BLA). Contract managers must know which regulatory application governs the contracted work to align scope, obligations, and tim' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Application .

ind:contractManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Contract Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Contract managers are internal employees responsible for negotiating and managing study contracts. This FK supports contract ownership reporting, workload management, key personnel tracking per ICH E6' ;
    rdfs:domain ind:Agreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'Frequency at which the CRO invoices the sponsor under this contract (e.g., monthly, quarterly, milestone-triggered). Governs the billing milestone schedule and revenue recognition cadence.' ;
    rdfs:domain ind:StudyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeOrderCount rdf:type rdf:Property ;
    rdfs:label 'Change Order Count' ;
    rdfs:comment 'Cumulative number of executed change orders (contract amendments modifying scope or budget) against this study contract. Supports contract health monitoring and scope creep analysis.' ;
    rdfs:domain ind:StudyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known, human-readable contract reference number assigned by the CRO or sponsor at execution (e.g., CTA-2024-00123). Used for cross-system reconciliation with SAP S/4HANA procurement and Oracle Siebel CTMS.' ;
    rdfs:domain ind:StudyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle state of the Clinical Trial Agreement. Tracks progression from initial drafting through negotiation, execution, active performance, and eventual termination or expiry. [ENUM-REF-CANDIDATE: draft|under_negotiation|pending_execution|executed|active|suspended|terminated|expired|superseded — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractTitle rdf:type rdf:Property ;
    rdfs:label 'Contract Title' ;
    rdfs:comment 'Descriptive title of the Clinical Trial Agreement, typically including the study name or protocol number and sponsor name (e.g., \'CTA – SPONSOR-XYZ – Protocol ABC-001 Phase III\').' ;
    rdfs:domain ind:StudyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the engagement model governing the CRO-sponsor relationship: full_service (CRO manages all study operations), functional_service (FSP – specific functional areas only), co_development (joint development partnership), pass_through_only (cost reimbursement only), letter_of_intent (pre-contract binding intent). [ENUM-REF-CANDIDATE: full_service|functional_service|co_development|pass_through_only|letter_of_intent — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:StudyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractVersion rdf:type rdf:Property ;
    rdfs:label 'Contract Version' ;
    rdfs:comment 'Version identifier of the current executed contract document (e.g., v1.0, v2.1). Incremented with each executed amendment. Supports document traceability in Veeva Vault eTMF.' ;
    rdfs:domain ind:StudyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentContractedValue rdf:type rdf:Property ;
    rdfs:label 'Current Contracted Value' ;
    rdfs:comment 'Total contracted value as adjusted by all executed change orders to date. Represents the live commercial commitment and is the basis for revenue recognition and financial forecasting.' ;
    rdfs:domain ind:StudyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indemnificationCap rdf:type rdf:Property ;
    rdfs:label 'Indemnification Cap' ;
    rdfs:comment 'Maximum monetary liability cap agreed between the CRO and sponsor for indemnification claims under this contract. Expressed in the contract currency. Key risk management and insurance alignment parameter.' ;
    rdfs:domain ind:StudyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:keyOpenIssues rdf:type rdf:Property ;
    rdfs:label 'Key Open Issues' ;
    rdfs:comment 'Free-text summary of the principal unresolved contractual issues blocking execution (e.g., indemnification language, IP ownership, payment terms). Populated by the contract manager during negotiation.' ;
    rdfs:domain ind:StudyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'Number of calendar days of advance written notice required by either party to terminate or elect non-renewal of the contract. Drives automated alerts in contract management workflows.' ;
    rdfs:domain ind:StudyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phase rdf:type rdf:Property ;
    rdfs:label 'Phase' ;
    rdfs:comment 'Regulatory development phase of the clinical study covered by this contract (Phase I through Phase IV). Influences contract complexity, budget scale, and regulatory compliance requirements.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolNumber rdf:type rdf:Property ;
    rdfs:label 'Protocol Number' ;
    rdfs:comment 'Sponsor-assigned clinical study protocol number referenced in this contract (e.g., ABC-001). Provides direct traceability between the commercial instrument and the scientific protocol document.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'Date on which the contract was renewed or extended. Captures the renewal lifecycle event for long-running studies requiring contract extensions beyond the original effective_end_date.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeOfWorkVersion rdf:type rdf:Property ;
    rdfs:label 'Scope Of Work Version' ;
    rdfs:comment 'Version identifier of the current governing Scope of Work (SOW) document attached to this contract. Ensures traceability to the specific deliverable schedule and service definitions in effect.' ;
    rdfs:domain ind:StudyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaPenaltyClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Penalty Clause Flag' ;
    rdfs:comment 'Indicates whether the contract includes Service Level Agreement (SLA) penalty or credit provisions triggered by CRO performance failures against agreed KPI thresholds.' ;
    rdfs:domain ind:StudyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorContractNumber rdf:type rdf:Property ;
    rdfs:label 'Sponsor Contract Number' ;
    rdfs:comment 'Sponsor-assigned contract reference number for the same Clinical Trial Agreement, used for cross-party reconciliation and sponsor billing correspondence.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalContractedValue rdf:type rdf:Property ;
    rdfs:label 'Total Contracted Value' ;
    rdfs:comment 'Gross total monetary value of the Clinical Trial Agreement as executed, inclusive of all service fees and pass-through budgets but before any change orders. Expressed in the contract currency.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subcontractId rdf:type rdf:Property ;
    rdfs:label 'Subcontract Id' ;
    rdfs:comment 'Unique system-generated identifier for the subcontract or sub-CRO agreement record.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subcontract .

ind:amendmentDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Date' ;
    rdfs:comment 'Date on which the most recent amendment to the subcontract was executed.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ctmsSubcontractReference rdf:type rdf:Property ;
    rdfs:label 'Ctms Subcontract Reference' ;
    rdfs:comment 'Reference identifier for this subcontract in Oracle Siebel CTMS, enabling cross-system traceability for vendor oversight and site management activities.' ;
    rdfs:domain ind:Subcontract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowDownObligations rdf:type rdf:Property ;
    rdfs:label 'Flow Down Obligations' ;
    rdfs:comment 'Description of the contractual obligations from the primary sponsor-CRO contract that are flowed down to the subcontractor, including GCP compliance, audit rights, confidentiality, and regulatory requirements.' ;
    rdfs:domain ind:Subcontract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gcpComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Gcp Compliance Required' ;
    rdfs:comment 'Indicates whether the subcontractor is required to operate in compliance with ICH E6(R2) Good Clinical Practice guidelines as a flow-down obligation from the primary contract.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passThroughAmount rdf:type rdf:Property ;
    rdfs:label 'Pass Through Amount' ;
    rdfs:comment 'Portion of the subcontract value representing pass-through costs (e.g., investigator fees, travel, lab kits) that are reimbursed at cost without CRO markup.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBondRequired rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Required' ;
    rdfs:comment 'Indicates whether the subcontractor is required to provide a performance bond or financial guarantee as a condition of the subcontract.' ;
    rdfs:domain ind:Subcontract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Expiry Date' ;
    rdfs:comment 'Date on which the subcontractor\'s vendor qualification certification expires, triggering re-qualification activities to maintain GCP compliance.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapPoNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Po Number' ;
    rdfs:comment 'Purchase Order number in SAP S/4HANA linked to this subcontract, used for financial commitment tracking, invoice matching, and procurement compliance.' ;
    rdfs:domain ind:Subcontract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Service Fee Amount' ;
    rdfs:comment 'Portion of the subcontract value representing the subcontractor\'s professional service fees, distinct from pass-through reimbursements.' ;
    rdfs:domain ind:Subcontract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sponsorApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Sponsor Approval Status' ;
    rdfs:comment 'Status of the sponsor\'s review and approval of this subcontract, required under GCP where the primary contract mandates sponsor consent for subcontracting arrangements.' ;
    rdfs:domain ind:Subcontract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractNumber rdf:type rdf:Property ;
    rdfs:label 'Subcontract Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned to the subcontract, used for cross-referencing with the CRO\'s contract management system and SAP S/4HANA procurement records.' ;
    rdfs:domain ind:Subcontract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractType rdf:type rdf:Property ;
    rdfs:label 'Subcontract Type' ;
    rdfs:comment 'Classification of the subcontract by the category of services being delegated. Common types include laboratory services (central lab), imaging (radiology), eCOA (electronic Clinical Outcome Assessment), translation, and monitoring. [ENUM-REF-CANDIDATE: laboratory_services|imaging|eCOA|translation|monitoring|pharmacovigilance|biostatistics|data_management|patient_recruitment|supply_chain|other — promote to reference product]' ;
    rdfs:domain ind:Subcontract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractValue rdf:type rdf:Property ;
    rdfs:label 'Subcontract Value' ;
    rdfs:comment 'Total contracted monetary value of the subcontract representing the gross base amount committed to the subcontractor for all delegated services.' ;
    rdfs:domain ind:Subcontract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subcontractedServicesDescription rdf:type rdf:Property ;
    rdfs:label 'Subcontracted Services Description' ;
    rdfs:comment 'Narrative description of the specific services delegated to the subcontractor, including scope boundaries, deliverables, and any service-level commitments.' ;
    rdfs:domain ind:Subcontract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractorContactName rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the subcontractor organization responsible for contract execution and service delivery.' ;
    rdfs:domain ind:Subcontract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractorQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Qualification Status' ;
    rdfs:comment 'Current qualification status of the subcontractor in the CRO\'s vendor qualification program, confirming GCP compliance and capability assessment prior to engagement.' ;
    rdfs:domain ind:Subcontract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adamDatasetSpecId rdf:type rdf:Property ;
    rdfs:label 'Adam Dataset Spec Id' ;
    rdfs:comment 'Unique surrogate identifier for each ADaM dataset specification record. Primary key for this entity. Role: MASTER_RESOURCE.' ;
    rdfs:domain ind:Biostatistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdamDatasetSpec .

ind:analysisPopulationId rdf:type rdf:Property ;
    rdfs:label 'Analysis Population Id' ;
    rdfs:comment 'Foreign key linking to biostatistics.analysis_population. Business justification: adam_dataset_spec has analysis_population (STRING) indicating which analysis population the dataset serves. Normalizing to a FK to analysis_population.analysis_population_id enforces referential integ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AnalysisPopulation .

ind:deliveryPreferenceId rdf:type rdf:Property ;
    rdfs:label 'Delivery Preference Id' ;
    rdfs:comment 'Foreign key linking to sponsor.delivery_preference. Business justification: ADaM dataset specifications must conform to sponsor delivery preferences (adam_version, sdtm_version, cdisc_define_xml_version, data_transfer_format, biostatistics_software). Programmers reference the' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryPreference .

ind:sapId rdf:type rdf:Property ;
    rdfs:label 'Sap Id' ;
    rdfs:comment 'Reference to the Statistical Analysis Plan that governs the derivation rules and analysis objectives for this ADaM dataset. Ensures traceability from dataset design to the approved SAP.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sap .

ind:sdtmDatasetId rdf:type rdf:Property ;
    rdfs:label 'Sdtm Dataset Id' ;
    rdfs:comment 'Foreign key linking to data.sdtm_dataset. Business justification: ADaM dataset specs are derived from specific SDTM datasets. Biostatisticians and programmers reference the source SDTM dataset record for version, QC status, and data cut date when building ADaM specs' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SdtmDataset .

ind:adamIgVersion rdf:type rdf:Property ;
    rdfs:label 'Adam Ig Version' ;
    rdfs:comment 'Version of the CDISC ADaM Implementation Guide to which this dataset specification conforms (e.g., \'ADaM IG v1.3\', \'ADSL v1.1\', \'BDS v1.1\'). Required for regulatory submission conformance validation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisVariableFlag rdf:type rdf:Property ;
    rdfs:label 'Analysis Variable Flag' ;
    rdfs:comment 'Indicates whether this variable is a primary analysis variable (AVAL, AVALC, or equivalent) used directly in statistical analyses and TLF production. True = analysis variable; False = supporting/descriptive variable. Guides programmer prioritization.' ;
    rdfs:domain ind:AdamDatasetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authoredBy rdf:type rdf:Property ;
    rdfs:label 'Authored By' ;
    rdfs:comment 'Name or user identifier of the biostatistician who authored this ADaM dataset specification. Establishes accountability and is referenced in the audit trail for regulatory inspection readiness.' ;
    rdfs:domain ind:AdamDatasetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blindingStatus rdf:type rdf:Property ;
    rdfs:label 'Blinding Status' ;
    rdfs:comment 'Indicates whether this ADaM dataset contains unblinded treatment assignment data. Blinded = treatment codes masked; Unblinded = actual treatment assignments visible (post-DBL or for open-label studies); Open-Label = study design is inherently unblinded. Governs access control and data release procedures.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codelistName rdf:type rdf:Property ;
    rdfs:label 'Codelist Name' ;
    rdfs:comment 'Name of the specific CDISC or sponsor-defined codelist associated with this variable (e.g., \'NY\', \'SEX\', \'RACE\', \'DTYPE\'). Referenced in the define.xml ItemDef and used for PINNACLE 21 conformance validation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlledTerminology rdf:type rdf:Property ;
    rdfs:label 'Controlled Terminology' ;
    rdfs:comment 'Reference to the controlled terminology codelist applicable to this variable (e.g., \'CDISC SDTM CT RACE\', \'NCI Thesaurus C66742\', \'MedDRA v26.0 PT\', \'WHO-DD\'). Ensures standardized values for regulatory submission and cross-study comparability.' ;
    rdfs:domain ind:AdamDatasetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coreDesignation rdf:type rdf:Property ;
    rdfs:label 'Core Designation' ;
    rdfs:comment 'CDISC ADaM core designation indicating the requirement level for this variable. Required = must be present in all datasets of this class; Expected = should be present when applicable; Permissible = may be included at sponsor discretion. Drives conformance validation.' ;
    rdfs:domain ind:Biostatistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:datasetClass rdf:type rdf:Property ;
    rdfs:label 'Dataset Class' ;
    rdfs:comment 'CDISC ADaM structural class of the dataset. ADSL = Subject-Level Analysis Dataset (one record per subject); BDS = Basic Data Structure (one or more records per subject per analysis parameter per analysis timepoint); OCCDS = Occurrence Data Structure (one or more records per subject per occurrence of an event); OTHER = datasets not conforming to a standard class.' ;
    rdfs:domain ind:AdamDatasetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:datasetLabel rdf:type rdf:Property ;
    rdfs:label 'Dataset Label' ;
    rdfs:comment 'Human-readable descriptive label for the dataset (e.g., \'Subject-Level Analysis Dataset\', \'Adverse Events Analysis Dataset\'). Used in SAS PROC CONTENTS output and regulatory submission metadata.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:datasetName rdf:type rdf:Property ;
    rdfs:label 'Dataset Name' ;
    rdfs:comment 'Short, uppercase dataset name conforming to CDISC ADaM naming conventions (e.g., ADSL, ADAE, ADTTE, ADLB, ADCM, ADEX, ADRS). Maximum 8 characters per CDISC standard. This is the externally-known identifier used by SAS programmers and regulatory submissions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:datasetPurpose rdf:type rdf:Property ;
    rdfs:label 'Dataset Purpose' ;
    rdfs:comment 'Narrative description of the analytical purpose of this dataset, including the primary analysis populations it supports, key endpoints addressed, and its role in the Clinical Study Report (CSR). Authored by the biostatistician.' ;
    rdfs:domain ind:AdamDatasetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defineXmlVersion rdf:type rdf:Property ;
    rdfs:label 'Define Xml Version' ;
    rdfs:comment 'Version of the CDISC Define-XML standard used to generate the define.xml metadata file for this dataset (e.g., \'Define-XML v2.0\', \'Define-XML v2.1\'). Required for FDA and EMA electronic submission packages.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:derivationAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Derivation Algorithm' ;
    rdfs:comment 'Detailed narrative or pseudocode describing the derivation logic for this variable, including source variables, transformation rules, imputation methods (e.g., LOCF), and conditional logic. The primary programming instruction for SAS programmers. Must be unambiguous and traceable to the SAP.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interimAnalysisFlag rdf:type rdf:Property ;
    rdfs:label 'Interim Analysis Flag' ;
    rdfs:comment 'Indicates whether this dataset specification is intended for use in an interim analysis (True) or the final analysis (False). Interim analysis datasets may have restricted access and require DSMB/DMC review procedures.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyVariables rdf:type rdf:Property ;
    rdfs:label 'Key Variables' ;
    rdfs:comment 'Comma-separated list of variable names that form the unique record key for this dataset (e.g., \'USUBJID\' for ADSL; \'USUBJID, PARAMCD, ADT\' for BDS datasets). Defines the grain of the dataset and is critical for merge/join operations in SAS programming.' ;
    rdfs:domain ind:AdamDatasetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pinnacle21ValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Pinnacle21 Validation Status' ;
    rdfs:comment 'Result of the Pinnacle 21 (formerly OpenCDISC) conformance validation run against this ADaM dataset. Pass = no errors; Pass with Warnings = minor issues noted; Fail = conformance errors requiring remediation; Not Run = validation pending. Required for FDA submission readiness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programmingLanguage rdf:type rdf:Property ;
    rdfs:label 'Programming Language' ;
    rdfs:comment 'Statistical programming language used to implement this ADaM dataset specification. SAS is the regulatory standard; R and Python may be used for exploratory or supplemental analyses. Governs QC and validation approach.' ;
    rdfs:domain ind:AdamDatasetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcMethod rdf:type rdf:Property ;
    rdfs:label 'Qc Method' ;
    rdfs:comment 'Quality control methodology applied to validate this ADaM dataset. Double Programming = independent programmer recreates dataset and compares; Peer Review = senior programmer reviews code and output; Independent QC = separate QC team validates; Not Required = exploratory/non-submission dataset.' ;
    rdfs:domain ind:AdamDatasetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcStatus rdf:type rdf:Property ;
    rdfs:label 'Qc Status' ;
    rdfs:comment 'Current QC completion status for this ADaM dataset. Not Started = QC not yet initiated; In Progress = QC underway; QC Complete = dataset passed QC validation; Failed QC = discrepancies found requiring programmer remediation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sasFormat rdf:type rdf:Property ;
    rdfs:label 'Sas Format' ;
    rdfs:comment 'SAS display format assigned to this variable (e.g., \'DATE9.\', \'DATETIME20.\', \'$CHAR200.\', \'8.2\'). Governs how values are displayed in SAS output and define.xml DisplayFormat attribute. Required for SAS Drug Development programming specifications.' ;
    rdfs:domain ind:AdamDatasetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sasInformat rdf:type rdf:Property ;
    rdfs:label 'Sas Informat' ;
    rdfs:comment 'SAS informat used to read raw values into this variable (e.g., \'YYMMDD10.\', \'E8601DT.\', \'$CHAR200.\'). Required for date/datetime variables derived from ISO 8601 SDTM character dates. Specified in SAS Drug Development programming specs.' ;
    rdfs:domain ind:AdamDatasetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sasProgramReference rdf:type rdf:Property ;
    rdfs:label 'Sas Program Reference' ;
    rdfs:comment 'File path or program name of the SAS program in SAS Drug Development that produces this ADaM dataset (e.g., \'/studies/STUDY001/adam/programs/adsl.sas\'). Links the specification to its implementing program for traceability and QC.' ;
    rdfs:domain ind:Biostatistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceVariable rdf:type rdf:Property ;
    rdfs:label 'Source Variable' ;
    rdfs:comment 'Name of the source SDTM or predecessor ADaM variable(s) from which this variable is derived (e.g., \'AE.AEDECOD\', \'DM.RFSTDTC\', \'ADSL.TRT01P\'). Supports CDISC traceability requirements and audit trail for regulatory submissions.' ;
    rdfs:domain ind:AdamDatasetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specStatus rdf:type rdf:Property ;
    rdfs:label 'Spec Status' ;
    rdfs:comment 'Current lifecycle status of the ADaM dataset specification. Draft = initial authoring; Under Review = submitted for biostatistics/programming review; Approved = formally signed off for programming use; Superseded = replaced by a newer version; Retired = no longer applicable.' ;
    rdfs:domain ind:Biostatistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specVersion rdf:type rdf:Property ;
    rdfs:label 'Spec Version' ;
    rdfs:comment 'Version number of this ADaM dataset specification document following major.minor versioning (e.g., 1.0, 1.1, 2.0). Incremented upon each approved revision to support change control and audit traceability.' ;
    rdfs:domain ind:Biostatistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionFlag rdf:type rdf:Property ;
    rdfs:label 'Submission Flag' ;
    rdfs:comment 'Indicates whether this ADaM dataset is included in the regulatory submission package (NDA, BLA, MAA, or IND). True = included in eCTD submission; False = internal analysis only. Governs define.xml inclusion and FDA/EMA conformance validation requirements.' ;
    rdfs:domain ind:AdamDatasetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timingVariableFlag rdf:type rdf:Property ;
    rdfs:label 'Timing Variable Flag' ;
    rdfs:comment 'Indicates whether this variable is a CDISC ADaM timing variable (e.g., ADT, ADTM, ADY, AVISIT, AVISITN). True = timing variable subject to ADaM timing variable conventions. Used for conformance checking and define.xml classification.' ;
    rdfs:domain ind:AdamDatasetSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:variableLabel rdf:type rdf:Property ;
    rdfs:label 'Variable Label' ;
    rdfs:comment 'Descriptive SAS variable label (max 256 characters) providing a human-readable description of the variable (e.g., \'Unique Subject Identifier\', \'Parameter Code\', \'Analysis Value\'). Appears in SAS PROC CONTENTS and submission define.xml.' ;
    rdfs:domain ind:Biostatistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variableLength rdf:type rdf:Property ;
    rdfs:label 'Variable Length' ;
    rdfs:comment 'SAS variable length in bytes. For character variables, specifies maximum string length (e.g., 200 for USUBJID). For numeric variables, typically 8 (SAS default double precision). Required for SAS dataset creation and define.xml generation.' ;
    rdfs:domain ind:Biostatistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:variableName rdf:type rdf:Property ;
    rdfs:label 'Variable Name' ;
    rdfs:comment 'SAS-compliant variable name for this specification record (uppercase, max 8 characters per SAS/CDISC convention, e.g., USUBJID, PARAMCD, AVAL, DTYPE). Each row in this table represents one variable within the dataset specification.' ;
    rdfs:domain ind:Biostatistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variableType rdf:type rdf:Property ;
    rdfs:label 'Variable Type' ;
    rdfs:comment 'SAS data type of the variable. Char = character/string variable; Num = numeric variable. Governs SAS dataset structure and informat/format assignments in programming specifications.' ;
    rdfs:domain ind:Biostatistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adamVariableSpecId rdf:type rdf:Property ;
    rdfs:label 'Adam Variable Spec Id' ;
    rdfs:comment 'Unique surrogate identifier for each ADaM variable specification record within the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:AdamVariableSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:labAnalyteId rdf:type rdf:Property ;
    rdfs:label 'Lab Analyte Id' ;
    rdfs:comment 'Foreign key linking to laboratory.lab_analyte. Business justification: ADaM variable specs for ADLB datasets map each variable to a source lab analyte (LOINC code, unit, CTCAE mapping). The source_variables plain-text field denormalizes this reference. A structured FK en' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabAnalyte .

ind:primaryAdamDatasetSpecId rdf:type rdf:Property ;
    rdfs:label 'Primary Adam Dataset Spec Id' ;
    rdfs:comment 'Reference to the parent ADaM dataset to which this variable specification belongs (e.g., ADSL, ADAE, ADLB). Links variable-level spec to its dataset container.' ;
    rdfs:domain ind:AdamVariableSpec ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdamDatasetSpec .

ind:stratificationFactorId rdf:type rdf:Property ;
    rdfs:label 'Stratification Factor Id' ;
    rdfs:comment 'Foreign key linking to randomization.stratification_factor. Business justification: ADaM ADSL stratification variables (STRAT1, STRAT2) must be derived from the randomization stratification factors. CDISC ADaM programming requires the variable spec to reference the exact stratificati' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StratificationFactor .

ind:adamStructure rdf:type rdf:Property ;
    rdfs:label 'Adam Structure' ;
    rdfs:comment 'CDISC ADaM structural classification of the parent dataset: ADSL (Subject-Level Analysis Dataset), BDS (Basic Data Structure — one record per subject per parameter per analysis timepoint), OCCDS (Occurrence Data Structure — for events like AEs and CMs), or OTHER.' ;
    rdfs:domain ind:AdamVariableSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineFlag rdf:type rdf:Property ;
    rdfs:label 'Baseline Flag' ;
    rdfs:comment 'Name of the associated baseline flag variable (e.g., ABLFL) used to identify the baseline record for this analysis variable. Supports change-from-baseline derivations and is required for BDS datasets.' ;
    rdfs:domain ind:AdamVariableSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeFromBaselineVar rdf:type rdf:Property ;
    rdfs:label 'Change From Baseline Var' ;
    rdfs:comment 'Name of the corresponding change-from-baseline variable (CHG) or percent change-from-baseline variable (PCHG) derived from this analysis variable. Establishes the analytical linkage between AVAL and its change metrics.' ;
    rdfs:domain ind:AdamVariableSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlledTerminologyRef rdf:type rdf:Property ;
    rdfs:label 'Controlled Terminology Ref' ;
    rdfs:comment 'Reference to the applicable CDISC controlled terminology codelist, MedDRA dictionary, WHO-DD, or CTCAE version governing the permissible values for this variable. Example: \'CDISC CT DTYPE 2023-09-29\', \'MedDRA v26.0 PT\', \'CTCAE v5.0\'.' ;
    rdfs:domain ind:AdamVariableSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defineXmlDisplayFormat rdf:type rdf:Property ;
    rdfs:label 'Define Xml Display Format' ;
    rdfs:comment 'Display format specification for this variable as it will appear in the DEFINE-XML submission metadata file (define.xml). Includes display format string and any associated decode mapping for coded values. Required for FDA/EMA electronic submission packages.' ;
    rdfs:domain ind:AdamVariableSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimandReference rdf:type rdf:Property ;
    rdfs:label 'Estimand Reference' ;
    rdfs:comment 'Reference to the ICH E9(R1) estimand strategy associated with this variable\'s derivation (e.g., treatment policy, hypothetical, composite, while on treatment). Aligns variable derivation with the study\'s estimand framework for regulatory submissions.' ;
    rdfs:domain ind:AdamVariableSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatName rdf:type rdf:Property ;
    rdfs:label 'Format Name' ;
    rdfs:comment 'SAS format or informat name applied to this variable for display or input purposes (e.g., DATE9., DATETIME20., $CHAR200.). Used in SAS program generation and dataset creation.' ;
    rdfs:domain ind:AdamVariableSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imputationMethod rdf:type rdf:Property ;
    rdfs:label 'Imputation Method' ;
    rdfs:comment 'Description of the missing data imputation method applied to this variable as specified in the SAP. Examples: LOCF (Last Observation Carried Forward), BOCF (Baseline Observation Carried Forward), multiple imputation, worst-case, or none. Critical for regulatory submission transparency.' ;
    rdfs:domain ind:AdamVariableSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAnalysisVariable rdf:type rdf:Property ;
    rdfs:label 'Is Analysis Variable' ;
    rdfs:comment 'Indicates whether this variable is designated as a primary or secondary analysis variable (AVAL, AVALC, or equivalent) used directly in statistical analyses as defined in the SAP.' ;
    rdfs:domain ind:AdamVariableSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isKeyVariable rdf:type rdf:Property ;
    rdfs:label 'Is Key Variable' ;
    rdfs:comment 'Indicates whether this variable is part of the dataset\'s sort key (BY variables) as defined in the ADaM dataset specification. Key variables determine dataset sort order and are required for PROC SORT and merge operations in SAS.' ;
    rdfs:domain ind:AdamVariableSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isParamVariable rdf:type rdf:Property ;
    rdfs:label 'Is Param Variable' ;
    rdfs:comment 'Indicates whether this variable is a PARAM/PARAMCD/PARAMN grouping variable used in BDS (Basic Data Structure) or OCCDS datasets to identify the analysis parameter. Drives parameter-level filtering in TLF production.' ;
    rdfs:domain ind:AdamVariableSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:origin rdf:type rdf:Property ;
    rdfs:label 'Origin' ;
    rdfs:comment 'CDISC-defined origin classification indicating how the variable value is obtained: Derived (computed from other variables), Assigned (set by sponsor/programmer per protocol), Collected (directly from eCRF/EDC), Protocol (defined in study protocol), or Not Available.' ;
    rdfs:domain ind:AdamVariableSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationFlag rdf:type rdf:Property ;
    rdfs:label 'Population Flag' ;
    rdfs:comment 'Name of the analysis population flag variable this specification defines (e.g., ITTFL for Intent-to-Treat, SAFFL for Safety, PPROTFL for Per Protocol, FASFL for Full Analysis Set). Null if the variable is not a population flag.' ;
    rdfs:domain ind:AdamVariableSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predecessorVariable rdf:type rdf:Property ;
    rdfs:label 'Predecessor Variable' ;
    rdfs:comment 'Name of the predecessor variable from which this variable is directly derived, as required in DEFINE-XML metadata. Establishes the data lineage chain from SDTM collected data through ADaM derived variables for regulatory traceability.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcDate rdf:type rdf:Property ;
    rdfs:label 'Qc Date' ;
    rdfs:comment 'Date on which the independent QC programmer completed verification of this variable\'s derivation. Recorded as part of the audit trail for regulatory submission readiness.' ;
    rdfs:domain ind:AdamVariableSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qcProgrammer rdf:type rdf:Property ;
    rdfs:label 'Qc Programmer' ;
    rdfs:comment 'Name or identifier of the independent QC programmer responsible for verifying the derivation of this variable through independent programming. Required for dual-programming QC methodology compliance.' ;
    rdfs:domain ind:AdamVariableSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:significantDigits rdf:type rdf:Property ;
    rdfs:label 'Significant Digits' ;
    rdfs:comment 'Number of significant digits to retain for numeric variables in analysis outputs and TLF displays. Defined in the SAP and applied during SAS program generation to ensure consistent rounding across tables, listings, and figures.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceDataset rdf:type rdf:Property ;
    rdfs:label 'Source Dataset' ;
    rdfs:comment 'Primary SDTM or ADaM source dataset from which this variable is derived or mapped (e.g., AE, LB, VS, ADSL). Supports traceability from analysis results back to raw clinical data.' ;
    rdfs:domain ind:AdamVariableSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceVariables rdf:type rdf:Property ;
    rdfs:label 'Source Variables' ;
    rdfs:comment 'Comma-separated list of source variable names (from SDTM datasets or other ADaM datasets) used in the derivation of this variable. Supports data lineage tracing and ALCOA+ compliance. Example: \'SDTM.AE.AESTDTC, SDTM.DM.RFSTDTC\'.' ;
    rdfs:domain ind:AdamVariableSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticArea rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Area' ;
    rdfs:comment 'Therapeutic area or disease indication for which this variable specification is designed (e.g., Oncology, Cardiology, Neurology). Relevant for CDISC Therapeutic Area User Guides (TAUGs) compliance and cross-study reuse.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variableOrder rdf:type rdf:Property ;
    rdfs:label 'Variable Order' ;
    rdfs:comment 'Sequential position of this variable within the ADaM dataset column order as defined in the specification. Determines the column sequence in the SAS dataset and DEFINE-XML variable listing. Required for consistent dataset structure across programming and QC.' ;
    rdfs:domain ind:AdamVariableSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:variableRole rdf:type rdf:Property ;
    rdfs:label 'Variable Role' ;
    rdfs:comment 'CDISC-defined role classification describing the variable\'s functional purpose within the dataset structure. Drives DEFINE-XML metadata generation and reviewer interpretation. [ENUM-REF-CANDIDATE: Identifier|Topic|Timing|Grouping Qualifier|Result Qualifier|Record Qualifier|Synonym Qualifier|Variable Qualifier|Rule — promote to reference product]' ;
    rdfs:domain ind:AdamVariableSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:randomizationTreatmentArmId rdf:type rdf:Property ;
    rdfs:label 'Randomization Treatment Arm Id' ;
    rdfs:comment 'Foreign key linking to randomization.treatment_arm. Business justification: Analysis populations (ITT, PP, Safety) are scoped to specific treatment arms. ADSL derivation requires the exact treatment arm definition to set population flags. The treatment_arm_scope text field is' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TreatmentArm .

ind:acronym rdf:type rdf:Property ;
    rdfs:label 'Acronym' ;
    rdfs:comment 'Standardized abbreviation for the analysis population (e.g., ITT, mITT, PP, SAF, PK, PD). Used in TLF titles, CSR statistical sections, and ADaM dataset variable labels.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adamDatasetName rdf:type rdf:Property ;
    rdfs:label 'Adam Dataset Name' ;
    rdfs:comment 'The CDISC ADaM dataset name where the ADSL flag variable for this population resides (typically ADSL). Used to locate the population flag in the ADaM submission package.' ;
    rdfs:domain ind:AnalysisPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adslFlagVariable rdf:type rdf:Property ;
    rdfs:label 'Adsl Flag Variable' ;
    rdfs:comment 'The CDISC ADaM ADSL dataset flag variable name (e.g., ITTFL, SAFFL, PPROTFL, MITTFL, PKFL) that identifies subjects belonging to this population. Must conform to CDISC ADaM naming convention ending in \'FL\'.' ;
    rdfs:domain ind:AnalysisPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisPhase rdf:type rdf:Property ;
    rdfs:label 'Analysis Phase' ;
    rdfs:comment 'Designates the analysis phase in which this population definition is applied: interim analysis, final analysis, post-hoc analysis, or exploratory analysis. Governs which TLF shells and CSR sections reference this population.' ;
    rdfs:domain ind:AnalysisPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdiscStandardVersion rdf:type rdf:Property ;
    rdfs:label 'Cdisc Standard Version' ;
    rdfs:comment 'The version of the CDISC ADaM standard applied to the derivation of this analysis population (e.g., ADaM IG v1.3, ADSL v1.1). Required for FDA/EMA electronic submission conformance.' ;
    rdfs:domain ind:AnalysisPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dblDate rdf:type rdf:Property ;
    rdfs:label 'Dbl Date' ;
    rdfs:comment 'The date on which the study database was locked (DBL) for the analysis associated with this population. Subject counts and population assignments are finalized as of this date.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:doseReceivedRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Dose Received Required Flag' ;
    rdfs:comment 'Indicates whether receipt of at least one dose of investigational product is a mandatory inclusion criterion for this analysis population. Distinguishes ITT (randomized only) from Safety (randomized and dosed) populations.' ;
    rdfs:domain ind:AnalysisPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'The date from which this version of the analysis population definition became effective, supporting SAP amendment versioning. Enables temporal tracking of population definition changes across SAP versions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'The date on which this version of the analysis population definition was superseded or retired, supporting SAP amendment versioning. Null if this is the current active version.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusionCriteriaDescription rdf:type rdf:Property ;
    rdfs:label 'Exclusion Criteria Description' ;
    rdfs:comment 'Narrative description of the criteria that would exclude a subject from this analysis population despite meeting inclusion criteria (e.g., major protocol deviations, missing primary endpoint data). Defined in the SAP.' ;
    rdfs:domain ind:AnalysisPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inclusionCriteriaDescription rdf:type rdf:Property ;
    rdfs:label 'Inclusion Criteria Description' ;
    rdfs:comment 'Narrative description of the criteria a subject must meet to be included in this analysis population, as defined in the SAP. Captures the logical rules (e.g., randomized and received at least one dose of study drug).' ;
    rdfs:domain ind:AnalysisPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:missingEndpointHandling rdf:type rdf:Property ;
    rdfs:label 'Missing Endpoint Handling' ;
    rdfs:comment 'The pre-specified method for handling missing primary endpoint data for subjects in this population, as defined in the SAP (e.g., LOCF - Last Observation Carried Forward, multiple imputation, observed cases only). [ENUM-REF-CANDIDATE: locf|bocf|wocf|multiple_imputation|observed_cases|none — promote to reference product]' ;
    rdfs:domain ind:AnalysisPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedSampleSize rdf:type rdf:Property ;
    rdfs:label 'Planned Sample Size' ;
    rdfs:comment 'The pre-specified planned number of subjects for this analysis population as determined by the sample size calculation in the SAP. Serves as the denominator benchmark for enrollment tracking and power calculations.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:populationCode rdf:type rdf:Property ;
    rdfs:label 'Population Code' ;
    rdfs:comment 'Short, unique alphanumeric code identifying the analysis population within the study (e.g., ITT, PP, SAF, MITT, PK). Used as the CDISC ADaM ADSL flag variable name prefix and in TLF shell headers.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationFinalizedDate rdf:type rdf:Property ;
    rdfs:label 'Population Finalized Date' ;
    rdfs:comment 'The date on which the analysis population definition was formally finalized and approved in the SAP, prior to unblinding. Supports pre-specification audit trail for regulatory compliance.' ;
    rdfs:domain ind:AnalysisPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:populationLogicSummary rdf:type rdf:Property ;
    rdfs:label 'Population Logic Summary' ;
    rdfs:comment 'Concise programmatic or pseudo-code summary of the population derivation logic used in SAS Drug Development ADaM programming (e.g., RANDFL=\'Y\' AND DOSEFL=\'Y\'). Bridges the narrative SAP definition and the SAS implementation.' ;
    rdfs:domain ind:AnalysisPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationName rdf:type rdf:Property ;
    rdfs:label 'Population Name' ;
    rdfs:comment 'Full descriptive name of the analysis population as defined in the SAP (e.g., Intent-to-Treat Population, Per Protocol Population, Safety Population, Modified Intent-to-Treat Population, Pharmacokinetic Population).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationRationale rdf:type rdf:Property ;
    rdfs:label 'Population Rationale' ;
    rdfs:comment 'Scientific and regulatory rationale for defining this analysis population, as documented in the SAP. Explains why this population is appropriate for the associated analysis objectives and how it aligns with regulatory guidance.' ;
    rdfs:domain ind:AnalysisPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationStatus rdf:type rdf:Property ;
    rdfs:label 'Population Status' ;
    rdfs:comment 'Current lifecycle status of the analysis population definition. Tracks progression from initial SAP drafting through biostatistics review, approval, and potential supersession by an amended SAP version.' ;
    rdfs:domain ind:AnalysisPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationType rdf:type rdf:Property ;
    rdfs:label 'Population Type' ;
    rdfs:comment 'Categorical classification of the analysis population by its primary analytical purpose. [ENUM-REF-CANDIDATE: efficacy|safety|pharmacokinetic|pharmacodynamic|per_protocol|modified_itt|other — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPopulationFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Population Flag' ;
    rdfs:comment 'Indicates whether this population is designated as the primary analysis population for the study as specified in the SAP. The primary population drives the primary efficacy endpoint analysis and regulatory submission.' ;
    rdfs:domain ind:AnalysisPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:protocolDeviationExclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Protocol Deviation Exclusion Flag' ;
    rdfs:comment 'Indicates whether subjects with major protocol deviations are excluded from this analysis population. Typically True for Per Protocol (PP) populations and False for ITT populations.' ;
    rdfs:domain ind:AnalysisPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:randomizationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Randomization Required Flag' ;
    rdfs:comment 'Indicates whether randomization is a mandatory inclusion criterion for subjects in this analysis population. True for ITT and most efficacy populations; may be False for screening failure or safety populations.' ;
    rdfs:domain ind:AnalysisPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryPrimaryFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Primary Flag' ;
    rdfs:comment 'Indicates whether this population is the pre-specified primary population for regulatory submission purposes (NDA/BLA/MAA). Distinct from internal primary flag; reflects the population declared in the IND/protocol.' ;
    rdfs:domain ind:AnalysisPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapSectionReference rdf:type rdf:Property ;
    rdfs:label 'Sap Section Reference' ;
    rdfs:comment 'The specific section number or identifier within the SAP document that formally defines this analysis population (e.g., Section 5.2.1). Enables direct traceability from the data product to the governing statistical document.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapVersion rdf:type rdf:Property ;
    rdfs:label 'Sap Version' ;
    rdfs:comment 'Version number of the SAP document in which this analysis population definition was introduced or last amended (e.g., v1.0, v2.1). Supports version-controlled traceability for regulatory audit.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sasProgramName rdf:type rdf:Property ;
    rdfs:label 'Sas Program Name' ;
    rdfs:comment 'Name of the SAS Drug Development program used to derive and validate the ADSL flag variable for this analysis population (e.g., adsl.sas). Enables traceability from population definition to the validated SAS code.' ;
    rdfs:domain ind:Biostatistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensitivityAnalysisFlag rdf:type rdf:Property ;
    rdfs:label 'Sensitivity Analysis Flag' ;
    rdfs:comment 'Indicates whether this population is designated as a sensitivity analysis population (as opposed to a primary or secondary analysis population). Sensitivity populations test the robustness of primary analysis conclusions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subjectCountAtDbl rdf:type rdf:Property ;
    rdfs:label 'Subject Count At Dbl' ;
    rdfs:comment 'The number of subjects assigned to this analysis population at the time of Database Lock (DBL). This is the final, locked count used in the Clinical Study Report (CSR) and regulatory submission.' ;
    rdfs:domain ind:AnalysisPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subjectCountInterim rdf:type rdf:Property ;
    rdfs:label 'Subject Count Interim' ;
    rdfs:comment 'Number of subjects assigned to this analysis population at the most recent interim analysis cut, if applicable. Used by the DSMB/DMC for interim review and blinded/unblinded reporting.' ;
    rdfs:domain ind:AnalysisPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionPopulationFlag rdf:type rdf:Property ;
    rdfs:label 'Submission Population Flag' ;
    rdfs:comment 'Indicates whether this analysis population is included in the regulatory submission package (NDA/BLA/MAA/eCTD). Populations marked True must have fully validated ADaM datasets and TLF outputs.' ;
    rdfs:domain ind:AnalysisPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tlfShellReference rdf:type rdf:Property ;
    rdfs:label 'Tlf Shell Reference' ;
    rdfs:comment 'Reference identifier(s) for the TLF shells that use this analysis population as their denominator or subject set. Links the population definition to the output specifications in the SAP/TLF shell document.' ;
    rdfs:domain ind:AnalysisPopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Current validation status of the SAS programming for this analysis population\'s ADSL flag variable in SAS Drug Development. Tracks QC progress from initial programming through double-programming validation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:databaseLockEventId rdf:type rdf:Property ;
    rdfs:label 'Database Lock Event Id' ;
    rdfs:comment 'Primary key for database_lock_event' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DatabaseLockEvent .

ind:primaryDatabaseEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Database Employee Id' ;
    rdfs:comment 'Reference to the Data Management representative who authorized the database lock. One of the three required lock authorization approvers per GCP and the DMP. Approval is captured with electronic signature per 21 CFR Part 11.' ;
    rdfs:domain ind:DatabaseLockEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryDatabaseUnblindingAuthorizedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Database Unblinding Authorized By Employee Id' ;
    rdfs:comment 'Reference to the individual (typically the lead statistician or designated unblinding officer) who authorized and executed the treatment unblinding procedure following the database lock.' ;
    rdfs:domain ind:DatabaseLockEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:randListId rdf:type rdf:Property ;
    rdfs:label 'Rand List Id' ;
    rdfs:comment 'Foreign key linking to randomization.rand_list. Business justification: Pre-lock QC checklists require reconciliation of all randomized subjects in the locked dataset against the active rand_list version. The subjects_locked_count must match the rand_list\'s allocated_slot' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RandList .

ind:tertiaryDatabaseMedicalMonitorApproverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Database Medical Monitor Approver Employee Id' ;
    rdfs:comment 'Reference to the Medical Monitor who authorized the database lock. Confirms clinical data completeness and medical review is satisfactory prior to lock.' ;
    rdfs:domain ind:DatabaseLockEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualLockDate rdf:type rdf:Property ;
    rdfs:label 'Actual Lock Date' ;
    rdfs:comment 'The calendar date on which the database was formally locked. This is the principal business event date for the DBL milestone and is recorded in the eTMF, regulatory submissions, and CSR statistical sections.' ;
    rdfs:domain ind:DatabaseLockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentReason rdf:type rdf:Property ;
    rdfs:label 'Amendment Reason' ;
    rdfs:comment 'Formal description of the reason for unlocking and re-locking the database after the initial lock. Documents the nature of the data correction or update requiring the amendment. Null for the original lock (amendment_number = 0).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisType rdf:type rdf:Property ;
    rdfs:label 'Analysis Type' ;
    rdfs:comment 'The type of statistical analysis for which this database lock is being performed. Determines the downstream workflow: interim analyses feed DSMB/DMC reviews; final analyses feed CSR and regulatory submissions (NDA/BLA/MAA).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biostatisticsApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Biostatistics Approval Timestamp' ;
    rdfs:comment 'Date and time at which the Biostatistics representative provided electronic authorization for the database lock. Required for 21 CFR Part 11 audit trail.' ;
    rdfs:domain ind:DatabaseLockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:codingComplete rdf:type rdf:Property ;
    rdfs:label 'Coding Complete' ;
    rdfs:comment 'Indicates whether all medical coding assignments (MedDRA for adverse events/medical history, WHO-DD for concomitant medications) have been completed and verified in the EDC system prior to database lock.' ;
    rdfs:domain ind:DatabaseLockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataCutDate rdf:type rdf:Property ;
    rdfs:label 'Data Cut Date' ;
    rdfs:comment 'The clinical data cut-off date defining which subject data and observations are included in this lock. All data with a collection date on or before this date is included in the locked dataset. Critical for interim and partial locks.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dblEventNumber rdf:type rdf:Property ;
    rdfs:label 'Dbl Event Number' ;
    rdfs:comment 'Externally-known, human-readable unique identifier for this database lock event (e.g., DBL-2024-001). Used in regulatory submissions, TMF filings, and cross-system references in Medidata Rave and Oracle Siebel CTMS.' ;
    rdfs:domain ind:DatabaseLockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dm Approval Timestamp' ;
    rdfs:comment 'Date and time at which the Data Management representative provided electronic authorization for the database lock. Required for 21 CFR Part 11 audit trail.' ;
    rdfs:domain ind:DatabaseLockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dmpVersion rdf:type rdf:Property ;
    rdfs:label 'Dmp Version' ;
    rdfs:comment 'Version identifier of the Data Management Plan (DMP) that governed the data collection and cleaning activities for this database lock event.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsmbNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Dsmb Notification Date' ;
    rdfs:comment 'The date on which the DSMB/DMC was formally notified of the database lock and provided access to the locked dataset for their review.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dsmbNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Dsmb Notification Required' ;
    rdfs:comment 'Indicates whether the Data Safety Monitoring Board (DSMB) or Data Monitoring Committee (DMC) must be notified of this database lock event, typically for interim analysis locks where the DSMB reviews unblinded data.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:edcSystemLockReference rdf:type rdf:Property ;
    rdfs:label 'Edc System Lock Reference' ;
    rdfs:comment 'The lock event reference number or identifier generated by the EDC system (Medidata Rave) at the time of lock execution. Used for cross-system traceability between the lakehouse and the source EDC system.' ;
    rdfs:domain ind:DatabaseLockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockMemoReference rdf:type rdf:Property ;
    rdfs:label 'Lock Memo Reference' ;
    rdfs:comment 'Document reference number for the formal database lock memo filed in the eTMF (Veeva Vault). The lock memo documents the lock rationale, approvals, outstanding items, and any deviations from the DMP.' ;
    rdfs:domain ind:DatabaseLockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockScope rdf:type rdf:Property ;
    rdfs:label 'Lock Scope' ;
    rdfs:comment 'Defines the scope of data included in this lock event. Full study locks the entire study database; interim locks a defined data cut for interim analysis; partial locks a subset of data (e.g., specific sites or forms); cohort locks a defined patient cohort; site-specific locks data from one or more named sites.' ;
    rdfs:domain ind:DatabaseLockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockStatus rdf:type rdf:Property ;
    rdfs:label 'Lock Status' ;
    rdfs:comment 'Current lifecycle status of the database lock event. Tracks progression from planning through execution and any subsequent unlock/re-lock cycles required for data corrections or amendments.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lock Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone) at which the database lock was executed in the EDC system (Medidata Rave). Required for 21 CFR Part 11 audit trail compliance and ALCOA+ data integrity standards.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lockType rdf:type rdf:Property ;
    rdfs:label 'Lock Type' ;
    rdfs:comment 'Indicates whether the lock is a hard lock (no further data changes permitted without formal unlock and re-lock procedure) or a soft lock (data is locked for analysis but minor corrections may still be applied under controlled conditions). Hard locks are required prior to final DBL and regulatory submission.' ;
    rdfs:domain ind:DatabaseLockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalMonitorApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Medical Monitor Approval Timestamp' ;
    rdfs:comment 'Date and time at which the Medical Monitor provided electronic authorization for the database lock. Required for 21 CFR Part 11 audit trail.' ;
    rdfs:domain ind:DatabaseLockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:outstandingQueryCount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Query Count' ;
    rdfs:comment 'Number of open data queries (discrepancies) remaining unresolved in the EDC system (Medidata Rave) at the time of database lock. A non-zero count must be formally justified and documented per GCP and ALCOA+ requirements.' ;
    rdfs:domain ind:DatabaseLockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outstandingQueryJustification rdf:type rdf:Property ;
    rdfs:label 'Outstanding Query Justification' ;
    rdfs:comment 'Formal written justification for proceeding with database lock when outstanding queries remain unresolved. Required by GCP and ALCOA+ when outstanding_query_count is greater than zero. Documented in the DMP and lock memo.' ;
    rdfs:domain ind:DatabaseLockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedLockDate rdf:type rdf:Property ;
    rdfs:label 'Planned Lock Date' ;
    rdfs:comment 'The originally scheduled calendar date for the database lock event as defined in the Data Management Plan (DMP) and study timeline. Used for milestone tracking in Oracle Siebel CTMS and project planning.' ;
    rdfs:domain ind:DatabaseLockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preLockQcChecklistComplete rdf:type rdf:Property ;
    rdfs:label 'Pre Lock Qc Checklist Complete' ;
    rdfs:comment 'Indicates whether all items on the pre-database lock Quality Control (QC) checklist have been completed and signed off prior to lock execution. The checklist covers data cleaning, query resolution, coding completion, and SAE reconciliation.' ;
    rdfs:domain ind:DatabaseLockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preLockQcCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Pre Lock Qc Completion Date' ;
    rdfs:comment 'The date on which the pre-database lock QC checklist was formally completed and all items signed off. Must precede the actual lock date.' ;
    rdfs:domain ind:DatabaseLockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:saeReconciliationComplete rdf:type rdf:Property ;
    rdfs:label 'Sae Reconciliation Complete' ;
    rdfs:comment 'Indicates whether the reconciliation between the EDC system (Medidata Rave) and the safety database (Oracle Argus Safety) for Serious Adverse Events (SAEs) has been completed and confirmed prior to database lock.' ;
    rdfs:domain ind:DatabaseLockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdvComplete rdf:type rdf:Property ;
    rdfs:label 'Sdv Complete' ;
    rdfs:comment 'Indicates whether Source Data Verification (SDV) has been completed to the required percentage or scope across all sites prior to database lock. SDV confirms EDC data matches source documents per GCP requirements.' ;
    rdfs:domain ind:DatabaseLockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sitesLockedCount rdf:type rdf:Property ;
    rdfs:label 'Sites Locked Count' ;
    rdfs:comment 'Total number of investigative sites whose data is included in this database lock event. Relevant for partial and site-specific lock scopes.' ;
    rdfs:domain ind:DatabaseLockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:studyPart rdf:type rdf:Property ;
    rdfs:label 'Study Part' ;
    rdfs:comment 'Identifies the specific study part, period, or epoch covered by this lock event (e.g., Part A, Part B, Period 1, Run-in, Treatment, Follow-up). Applicable for multi-part or adaptive study designs.' ;
    rdfs:domain ind:DatabaseLockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectsLockedCount rdf:type rdf:Property ;
    rdfs:label 'Subjects Locked Count' ;
    rdfs:comment 'Total number of study subjects whose data is included in this database lock event. Used for completeness verification and comparison against enrollment targets defined in the SAP.' ;
    rdfs:domain ind:DatabaseLockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unblindingDate rdf:type rdf:Property ;
    rdfs:label 'Unblinding Date' ;
    rdfs:comment 'The date on which treatment assignment unblinding was performed following the database lock. Null if unblinding_required is false or unblinding has not yet occurred.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unblindingRequired rdf:type rdf:Property ;
    rdfs:label 'Unblinding Required' ;
    rdfs:comment 'Indicates whether treatment unblinding is required as part of or immediately following this database lock event. Applicable for blinded studies where the lock precedes the formal unblinding procedure for final or interim analysis.' ;
    rdfs:domain ind:DatabaseLockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unlockTimestamp rdf:type rdf:Property ;
    rdfs:label 'Unlock Timestamp' ;
    rdfs:comment 'Date and time at which the database was formally unlocked to permit post-lock data corrections. Null if the database has not been unlocked. Required for 21 CFR Part 11 audit trail.' ;
    rdfs:domain ind:DatabaseLockEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dsmbCharterId rdf:type rdf:Property ;
    rdfs:label 'Dsmb Charter Id' ;
    rdfs:comment 'Unique surrogate identifier for the DSMB/DMC charter record in the lakehouse silver layer.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DsmbCharter .

ind:blindingConfigId rdf:type rdf:Property ;
    rdfs:label 'Blinding Config Id' ;
    rdfs:comment 'Foreign key linking to randomization.blinding_config. Business justification: DSMB charters define unblinding procedures, open/closed session scope, and blinding maintenance for the sponsor. These are operationally governed by the blinding_config. GCP and ICH E6 require the cha' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BlindingConfig .

ind:governanceId rdf:type rdf:Property ;
    rdfs:label 'Governance Id' ;
    rdfs:comment 'Foreign key linking to program.program_governance. Business justification: The DSMB is a governance body registered in program_governance. The dsmb_charter is the governing document for that body. Linking charter to program_governance enables governance reporting, charter ve' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Governance .

ind:independentStatisticianEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Independent Statistician Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: ICH E9 and FDA guidance require the independent statistician\'s qualifications, GCP training, and independence to be verifiable. Linking dsmb_charter to workforce.employee enables inspection-ready qual' ;
    rdfs:domain ind:DsmbCharter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:protocolId rdf:type rdf:Property ;
    rdfs:label 'Protocol Id' ;
    rdfs:comment 'Reference to the specific protocol version under which this DSMB charter was authored, ensuring alignment between statistical stopping rules and the approved study protocol.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Protocol .

ind:randSchemeId rdf:type rdf:Property ;
    rdfs:label 'Rand Scheme Id' ;
    rdfs:comment 'Foreign key linking to randomization.rand_scheme. Business justification: DSMB charters define stopping rules and interim analysis schedules that are directly tied to the randomization scheme\'s alpha spending function and allocation structure. Regulatory and GCP requirement' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RandScheme .

ind:alphaSpendingFunction rdf:type rdf:Property ;
    rdfs:label 'Alpha Spending Function' ;
    rdfs:comment 'Statistical alpha-spending function used to allocate the overall Type I error rate across planned interim analyses, as specified in the DSMB charter and SAP. [ENUM-REF-CANDIDATE: OBrien_Fleming|Pocock|Lan_DeMets|Hwang_Shih_DeCani|Haybittle_Peto|other — promote to reference product]' ;
    rdfs:domain ind:Biostatistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blindingMaintainedForSponsor rdf:type rdf:Property ;
    rdfs:label 'Blinding Maintained For Sponsor' ;
    rdfs:comment 'Indicates whether the sponsor remains blinded to unblinded interim analysis results during the study. True means the sponsor does not receive unblinded data; False means the sponsor has access (open-label or sponsor-unblinded design).' ;
    rdfs:domain ind:DsmbCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:charterIdentifier rdf:type rdf:Property ;
    rdfs:label 'Charter Identifier' ;
    rdfs:comment 'Externally-known alphanumeric code or document number assigned to this DSMB/DMC charter, used for cross-referencing in the eTMF, regulatory submissions, and sponsor communications (e.g., STUDY-001-DSMB-CHR-001).' ;
    rdfs:domain ind:DsmbCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:charterScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Charter Scope Description' ;
    rdfs:comment 'Narrative description of the DSMB/DMC mandate and scope, including the populations, endpoints, and study phases covered by the committee\'s oversight responsibilities.' ;
    rdfs:domain ind:DsmbCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:charterStatus rdf:type rdf:Property ;
    rdfs:label 'Charter Status' ;
    rdfs:comment 'Current lifecycle status of the DSMB/DMC charter document. Drives which version is operationally active for interim analyses and stopping rule enforcement.' ;
    rdfs:domain ind:DsmbCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:charterTitle rdf:type rdf:Property ;
    rdfs:label 'Charter Title' ;
    rdfs:comment 'Full descriptive title of the DSMB/DMC charter document as it appears on the official document header, typically including study name and committee type.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:charterVersion rdf:type rdf:Property ;
    rdfs:label 'Charter Version' ;
    rdfs:comment 'Version number of the DSMB/DMC charter document (e.g., v1.0, v2.0). Tracks amendments and superseded versions throughout the study lifecycle.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedSessionScope rdf:type rdf:Property ;
    rdfs:label 'Closed Session Scope' ;
    rdfs:comment 'Description of the agenda items and participants permitted in the closed (confidential) session of DSMB/DMC meetings, restricted to committee members and the independent statistician reviewing unblinded data.' ;
    rdfs:domain ind:DsmbCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committeeChairName rdf:type rdf:Property ;
    rdfs:label 'Committee Chair Name' ;
    rdfs:comment 'Full name of the independent physician or scientist designated as chair of the DSMB/DMC. The chair is responsible for convening meetings, managing deliberations, and communicating recommendations to the sponsor.' ;
    rdfs:domain ind:DsmbCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committeeType rdf:type rdf:Property ;
    rdfs:label 'Committee Type' ;
    rdfs:comment 'Classification of the independent monitoring committee type. DSMB (Data Safety Monitoring Board), DMC (Data Monitoring Committee), IDMC (Independent Data Monitoring Committee), ISMC (Independent Safety Monitoring Committee), and DSMC (Data and Safety Monitoring Committee) are used interchangeably across sponsors and regions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityRequirements rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Requirements' ;
    rdfs:comment 'Narrative description of confidentiality obligations for DSMB/DMC members, including restrictions on disclosure of interim results, data firewall arrangements, and consequences of breach. Aligned with GDPR and HIPAA data protection requirements.' ;
    rdfs:domain ind:DsmbCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:efficacyStoppingRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Efficacy Stopping Rule Description' ;
    rdfs:comment 'Narrative description of the pre-specified statistical criteria for early stopping of the study due to overwhelming efficacy (e.g., conditional power threshold, p-value boundary at each interim look). Authored by Biostatistics.' ;
    rdfs:domain ind:DsmbCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:futilityRuleBinding rdf:type rdf:Property ;
    rdfs:label 'Futility Rule Binding' ;
    rdfs:comment 'Indicates whether the futility stopping rule is binding (the DSMB recommendation to stop for futility is mandatory) or non-binding (advisory only). Binding rules have regulatory and operational implications.' ;
    rdfs:domain ind:DsmbCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:futilityStoppingRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Futility Stopping Rule Description' ;
    rdfs:comment 'Narrative description of the pre-specified criteria for early stopping due to futility (e.g., conditional power below threshold, binding or non-binding futility boundary). Authored by Biostatistics.' ;
    rdfs:domain ind:DsmbCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingRegulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Governing Regulatory Framework' ;
    rdfs:comment 'Primary regulatory framework(s) under which the DSMB/DMC operates (e.g., FDA 21 CFR, EU CTR 536/2014, ICH E6(R2)). Determines applicable procedural and reporting requirements.' ;
    rdfs:domain ind:DsmbCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:independentStatisticianOrganization rdf:type rdf:Property ;
    rdfs:label 'Independent Statistician Organization' ;
    rdfs:comment 'Name of the organization or academic institution to which the independent DSMB statistician is affiliated, confirming independence from the sponsor and CRO.' ;
    rdfs:domain ind:DsmbCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interimAnalysisScheduleDescription rdf:type rdf:Property ;
    rdfs:label 'Interim Analysis Schedule Description' ;
    rdfs:comment 'Narrative description of the timing and triggers for each planned interim analysis (e.g., after 25%, 50%, 75% of events; after N subjects enrolled). Complements the structured interim analysis count.' ;
    rdfs:domain ind:DsmbCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mastercontrolDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Mastercontrol Document Reference' ;
    rdfs:comment 'Document control identifier assigned to this DSMB charter in MasterControl, used for tracking approval workflows, training requirements, and audit trails associated with the charter.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingFrequency rdf:type rdf:Property ;
    rdfs:label 'Meeting Frequency' ;
    rdfs:comment 'Scheduled frequency of DSMB/DMC meetings as defined in the charter. Governs the cadence of safety reviews and interim analyses. [ENUM-REF-CANDIDATE: monthly|quarterly|semi_annual|annual|per_interim_analysis|ad_hoc|other — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openSessionScope rdf:type rdf:Property ;
    rdfs:label 'Open Session Scope' ;
    rdfs:comment 'Description of the agenda items and participants permitted in the open (non-confidential) session of DSMB/DMC meetings, typically including sponsor representatives and investigators reviewing blinded aggregate safety data.' ;
    rdfs:domain ind:DsmbCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quorumRequirement rdf:type rdf:Property ;
    rdfs:label 'Quorum Requirement' ;
    rdfs:comment 'Minimum number of DSMB/DMC members required to be present for a meeting to be valid and for recommendations to be binding. Defined in the charter.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recommendationTypesAllowed rdf:type rdf:Property ;
    rdfs:label 'Recommendation Types Allowed' ;
    rdfs:comment 'Enumeration of the formal recommendation categories the DSMB/DMC is empowered to issue per the charter (e.g., continue as planned, modify protocol, stop for efficacy, stop for futility, stop for safety, increase sample size). [ENUM-REF-CANDIDATE: continue|modify_protocol|stop_efficacy|stop_futility|stop_safety|increase_sample_size|other — promote to reference product]' ;
    rdfs:domain ind:DsmbCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingTimelineDays rdf:type rdf:Property ;
    rdfs:label 'Reporting Timeline Days' ;
    rdfs:comment 'Maximum number of calendar days within which the DSMB/DMC must issue its written recommendation report to the sponsor following a meeting, as specified in the charter.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyStoppingRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Safety Stopping Rule Description' ;
    rdfs:comment 'Narrative description of the pre-specified criteria for early stopping or study modification due to unacceptable safety signals (e.g., excess SAE rate, SUSAR threshold, mortality imbalance). Aligned with Oracle Argus Safety signal detection.' ;
    rdfs:domain ind:DsmbCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorResponseTimelineDays rdf:type rdf:Property ;
    rdfs:label 'Sponsor Response Timeline Days' ;
    rdfs:comment 'Maximum number of calendar days within which the sponsor must formally respond to a DSMB/DMC recommendation, as defined in the charter.' ;
    rdfs:domain ind:DsmbCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalInterimAnalysesPlanned rdf:type rdf:Property ;
    rdfs:label 'Total Interim Analyses Planned' ;
    rdfs:comment 'Total number of formal interim analyses planned for the study as specified in the DSMB charter and aligned with the Statistical Analysis Plan (SAP). Drives alpha-spending allocation.' ;
    rdfs:domain ind:DsmbCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalMemberCount rdf:type rdf:Property ;
    rdfs:label 'Total Member Count' ;
    rdfs:comment 'Total number of voting members constituting the DSMB/DMC as defined in the charter. Typically an odd number (3–7) to enable majority voting on recommendations.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unblindingProcedureDescription rdf:type rdf:Property ;
    rdfs:label 'Unblinding Procedure Description' ;
    rdfs:comment 'Narrative description of the procedures governing when and how unblinded data are provided to the DSMB/DMC independent statistician, including access controls, secure data transfer protocols, and firewall arrangements between the independent statistician and the sponsor.' ;
    rdfs:domain ind:DsmbCharter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsmbMeetingId rdf:type rdf:Property ;
    rdfs:label 'Dsmb Meeting Id' ;
    rdfs:comment 'Unique surrogate identifier for each DSMB/DMC meeting record in the biostatistics domain. Primary key for the dsmb_meeting entity.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DsmbMeeting .

ind:interimAnalysisId rdf:type rdf:Property ;
    rdfs:label 'Interim Analysis Id' ;
    rdfs:comment 'Foreign key linking to biostatistics.interim_analysis. Business justification: DSMB meetings are frequently convened to review interim analysis results. dsmb_meeting already has interim_analysis_number (a business display number), but lacks a proper FK to the interim_analysis re' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InterimAnalysis .

ind:actionItemDueDate rdf:type rdf:Property ;
    rdfs:label 'Action Item Due Date' ;
    rdfs:comment 'Target date by which the sponsor or study team must respond to or resolve the action items issued by the DSMB at this meeting. Drives follow-up tracking and regulatory compliance.' ;
    rdfs:domain ind:DsmbMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionItems rdf:type rdf:Property ;
    rdfs:label 'Action Items' ;
    rdfs:comment 'Narrative description of specific action items assigned to the sponsor, CRO, or study team arising from the DSMB meeting. Includes responsible party and requested completion timeframe where specified.' ;
    rdfs:domain ind:DsmbMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agendaItems rdf:type rdf:Property ;
    rdfs:label 'Agenda Items' ;
    rdfs:comment 'Structured list or narrative description of the agenda items reviewed during the DSMB meeting, including safety data review, efficacy data review, protocol deviations, SAE summaries, and any special topics. Stored as a delimited text field.' ;
    rdfs:domain ind:DsmbMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityMaintained rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Maintained' ;
    rdfs:comment 'Confirms that the confidentiality of unblinded interim analysis data was maintained throughout the DSMB meeting process, with no unauthorized disclosure to sponsor or study team. Required attestation for blinding integrity audit trail.' ;
    rdfs:domain ind:DsmbMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:etmfDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Etmf Document Reference' ;
    rdfs:comment 'Reference identifier for the DSMB meeting minutes and associated documents as filed in the Veeva Vault eTMF system. Enables cross-system traceability between the biostatistics data product and the document management system.' ;
    rdfs:domain ind:DsmbMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:independentStatisticianPresent rdf:type rdf:Property ;
    rdfs:label 'Independent Statistician Present' ;
    rdfs:comment 'Indicates whether the independent (unblinded) statistician was present at the closed session of this DSMB meeting. The independent statistician\'s presence is required for valid interim analysis review per the DSMB charter.' ;
    rdfs:domain ind:DsmbMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interimAnalysisDataPackageVersion rdf:type rdf:Property ;
    rdfs:label 'Interim Analysis Data Package Version' ;
    rdfs:comment 'Version identifier of the unblinded interim analysis data package (ADaM datasets and TLFs) reviewed by the DSMB at this meeting. Ensures traceability to the exact data cut used for committee deliberations.' ;
    rdfs:domain ind:DsmbMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingDate rdf:type rdf:Property ;
    rdfs:label 'Meeting Date' ;
    rdfs:comment 'The calendar date on which the DSMB/DMC meeting was held or is scheduled to be held. Principal real-world event date for this transaction record.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meetingDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Meeting Duration Minutes' ;
    rdfs:comment 'Total duration of the DSMB meeting in minutes, including both open and closed sessions. Used for meeting management reporting and resource planning.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:meetingIdentifier rdf:type rdf:Property ;
    rdfs:label 'Meeting Identifier' ;
    rdfs:comment 'Externally-known alphanumeric code or reference number assigned to this DSMB/DMC meeting (e.g., STUDY001-DSMB-003). Used in regulatory correspondence, meeting minutes, and TMF filing.' ;
    rdfs:domain ind:DsmbMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingLocation rdf:type rdf:Property ;
    rdfs:label 'Meeting Location' ;
    rdfs:comment 'Physical location or virtual platform where the DSMB meeting was conducted (e.g., city and venue for in-person meetings, or platform name for teleconferences). Documented in meeting minutes for audit trail.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingNumber rdf:type rdf:Property ;
    rdfs:label 'Meeting Number' ;
    rdfs:comment 'Sequential ordinal number of this DSMB/DMC meeting within the study (e.g., 1st, 2nd, 3rd meeting). Used to track the cadence of oversight activities across the study lifecycle.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingStatus rdf:type rdf:Property ;
    rdfs:label 'Meeting Status' ;
    rdfs:comment 'Current lifecycle status of the DSMB/DMC meeting record. Tracks whether the meeting has been scheduled, is in progress, has been completed, cancelled, or postponed.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingType rdf:type rdf:Property ;
    rdfs:label 'Meeting Type' ;
    rdfs:comment 'Classification of the meeting as a regularly scheduled review, an ad hoc convening triggered by a safety signal or sponsor request, or an emergency meeting. Drives agenda preparation and regulatory notification requirements.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membersPresentCount rdf:type rdf:Property ;
    rdfs:label 'Members Present Count' ;
    rdfs:comment 'Number of DSMB/DMC voting members who attended this meeting. Used to verify quorum and document committee composition for regulatory audit trail.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minutesApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Minutes Approval Date' ;
    rdfs:comment 'Date on which the DSMB meeting minutes were formally approved by the committee chair. Required for eTMF filing and regulatory inspection readiness.' ;
    rdfs:domain ind:DsmbMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minutesStatus rdf:type rdf:Property ;
    rdfs:label 'Minutes Status' ;
    rdfs:comment 'Current approval status of the DSMB meeting minutes document. Tracks the lifecycle from draft through committee review to final approval. Finalized minutes are filed in the eTMF and are subject to regulatory inspection.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Next Meeting Date' ;
    rdfs:comment 'Tentative or confirmed date for the next scheduled DSMB meeting as agreed upon at the conclusion of this meeting. Supports study oversight planning and timeline management.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:protocolAmendmentTriggered rdf:type rdf:Property ;
    rdfs:label 'Protocol Amendment Triggered' ;
    rdfs:comment 'Indicates whether the DSMB recommendation from this meeting resulted in a protocol amendment being initiated (e.g., dose modification, stopping rule revision, sample size re-estimation). Links to the protocol amendment workflow.' ;
    rdfs:domain ind:DsmbMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quorumMet rdf:type rdf:Property ;
    rdfs:label 'Quorum Met' ;
    rdfs:comment 'Indicates whether the required quorum of DSMB/DMC members was present for the meeting to be considered valid per the DSMB charter. Meetings without quorum may require rescheduling or special procedures.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recommendation rdf:type rdf:Property ;
    rdfs:label 'Recommendation' ;
    rdfs:comment 'The formal recommendation issued by the DSMB/DMC following review of the interim data. Drives critical study-level decisions including continuation, modification, or termination. Regulatory agencies require documentation of all DSMB recommendations.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationRationale rdf:type rdf:Property ;
    rdfs:label 'Recommendation Rationale' ;
    rdfs:comment 'Narrative explanation of the scientific and safety basis for the DSMB recommendation. Captured in the closed session minutes and required for regulatory submissions and CSR documentation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saeCountReviewed rdf:type rdf:Property ;
    rdfs:label 'Sae Count Reviewed' ;
    rdfs:comment 'Total number of Serious Adverse Events (SAEs) included in the safety data package reviewed by the DSMB at this meeting. Provides a quantitative measure of the safety data scope presented.' ;
    rdfs:domain ind:DsmbMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionType rdf:type rdf:Property ;
    rdfs:label 'Session Type' ;
    rdfs:comment 'Indicates whether the meeting session was open (sponsor representatives present), closed (committee members and unblinded statistician only), or executive (committee deliberation only). Critical for blinding integrity and regulatory audit trail.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Sponsor Notification Date' ;
    rdfs:comment 'Date on which the sponsor was formally notified of the DSMB recommendation. Required for regulatory compliance tracking and audit trail. Must be within the timeframe specified in the DSMB charter.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sponsorNotified rdf:type rdf:Property ;
    rdfs:label 'Sponsor Notified' ;
    rdfs:comment 'Indicates whether the sponsor has been formally notified of the DSMB recommendation following this meeting. Regulatory timelines for sponsor notification are defined in the DSMB charter and applicable regulations.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statisticalReportVersion rdf:type rdf:Property ;
    rdfs:label 'Statistical Report Version' ;
    rdfs:comment 'Version identifier of the unblinded statistical report (produced in SAS Drug Development) submitted to the DSMB for this meeting. Distinct from the data package version; tracks the analysis output document.' ;
    rdfs:domain ind:DsmbMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stoppingBoundaryCrossed rdf:type rdf:Property ;
    rdfs:label 'Stopping Boundary Crossed' ;
    rdfs:comment 'Indicates whether any pre-specified statistical stopping boundary (efficacy, futility, or safety) was crossed at this interim analysis. True triggers mandatory sponsor notification and potential protocol amendment.' ;
    rdfs:domain ind:DsmbMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stoppingBoundaryType rdf:type rdf:Property ;
    rdfs:label 'Stopping Boundary Type' ;
    rdfs:comment 'Specifies which type of pre-defined stopping boundary was crossed at this interim analysis, if any. Null or \'none\' when no boundary was crossed. Informs the recommendation and regulatory notification pathway.' ;
    rdfs:domain ind:DsmbMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectsCompletedAtReview rdf:type rdf:Property ;
    rdfs:label 'Subjects Completed At Review' ;
    rdfs:comment 'Number of subjects who had completed the study treatment or observation period as of the data cut-off date. Used by the DSMB to assess study progress relative to the planned timeline.' ;
    rdfs:domain ind:DsmbMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subjectsEnrolledAtReview rdf:type rdf:Property ;
    rdfs:label 'Subjects Enrolled At Review' ;
    rdfs:comment 'Total number of subjects enrolled in the study as of the data cut-off date for this DSMB meeting. Provides context for the safety and efficacy data reviewed and supports sample size tracking.' ;
    rdfs:domain ind:DsmbMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unblindingOccurred rdf:type rdf:Property ;
    rdfs:label 'Unblinding Occurred' ;
    rdfs:comment 'Indicates whether treatment assignment unblinding occurred for the purposes of this DSMB meeting\'s interim analysis. Critical for blinding integrity audit trail and regulatory compliance.' ;
    rdfs:domain ind:DsmbMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unblindingScope rdf:type rdf:Property ;
    rdfs:label 'Unblinding Scope' ;
    rdfs:comment 'Describes the extent of unblinding performed for this meeting: full (all treatment arms revealed), partial (aggregate or selected data only), or none (blinded review only). Supports blinding integrity documentation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimandId rdf:type rdf:Property ;
    rdfs:label 'Estimand Id' ;
    rdfs:comment 'Unique surrogate identifier for the estimand definition record within the biostatistics data product. Primary key for the estimand entity in the Databricks Silver Layer.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Estimand .

ind:endpointId rdf:type rdf:Property ;
    rdfs:label 'Endpoint Id' ;
    rdfs:comment 'Foreign key linking to study.study_endpoint. Business justification: ICH E9(R1) defines estimands as operationalizations of specific clinical endpoints. Regulatory submissions require explicit estimand-to-endpoint traceability. estimand.endpoint_name is a denormalized ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Endpoint .

ind:sponsorRegulatoryStrategyId rdf:type rdf:Property ;
    rdfs:label 'Sponsor Regulatory Strategy Id' ;
    rdfs:comment 'Foreign key linking to sponsor.regulatory_strategy. Business justification: Estimands per ICH E9(R1) must align with the sponsor\'s regulatory strategy (submission_pathway, regulatory_designation, target_health_authority). The estimand\'s regulatory_framework and intercurrent_e' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryStrategy .

ind:adamParameterCode rdf:type rdf:Property ;
    rdfs:label 'Adam Parameter Code' ;
    rdfs:comment 'The CDISC ADaM PARAMCD value identifying the specific analysis parameter within the ADaM dataset that corresponds to this estimand\'s endpoint variable. Enables direct linkage to TLF outputs and CDISC submission datasets.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alphaLevel rdf:type rdf:Property ;
    rdfs:label 'Alpha Level' ;
    rdfs:comment 'The pre-specified significance level (Type I error rate) allocated to this estimand in the confirmatory testing procedure (e.g., 0.05000, 0.02500 for two-sided tests). Null for exploratory estimands.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analysisTimepoint rdf:type rdf:Property ;
    rdfs:label 'Analysis Timepoint' ;
    rdfs:comment 'The primary timepoint or time window at which the endpoint variable is assessed for this estimand (e.g., \'Week 24\', \'End of Treatment\', \'Month 12\', \'Event-driven at 300 events\'). Defines the temporal scope of the estimand.' ;
    rdfs:domain ind:Biostatistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csrSectionReference rdf:type rdf:Property ;
    rdfs:label 'Csr Section Reference' ;
    rdfs:comment 'Reference to the section of the Clinical Study Report (CSR) where results for this estimand are reported (e.g., \'Section 11.4.1\'). Supports ICH E3 CSR structure compliance and regulatory submission traceability.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectDirection rdf:type rdf:Property ;
    rdfs:label 'Effect Direction' ;
    rdfs:comment 'The inferential objective of the estimand — whether the analysis is designed to demonstrate superiority, non-inferiority, or equivalence of the treatment condition relative to the comparator.' ;
    rdfs:domain ind:Estimand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointType rdf:type rdf:Property ;
    rdfs:label 'Endpoint Type' ;
    rdfs:comment 'Statistical nature of the endpoint variable. Determines the appropriate population-level summary measure and analysis methodology (e.g., continuous endpoints use mean difference; time-to-event use hazard ratio).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimandCode rdf:type rdf:Property ;
    rdfs:label 'Estimand Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the estimand, used in SAP documents, regulatory submissions, and cross-functional communications. Follows the pattern EST-{STUDYCODE}{SEQ}.' ;
    rdfs:domain ind:Estimand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimandStatus rdf:type rdf:Property ;
    rdfs:label 'Estimand Status' ;
    rdfs:comment 'Current lifecycle state of the estimand definition record within the SAP authoring and regulatory submission workflow. Drives version control and approval gating in SAS Drug Development.' ;
    rdfs:domain ind:Estimand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimandType rdf:type rdf:Property ;
    rdfs:label 'Estimand Type' ;
    rdfs:comment 'Classification of the estimand within the study\'s endpoint hierarchy. Determines regulatory weight and reporting obligations. [ENUM-REF-CANDIDATE: primary|key_secondary|secondary|exploratory|sensitivity — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:Estimand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercurrentEventDescription rdf:type rdf:Property ;
    rdfs:label 'Intercurrent Event Description' ;
    rdfs:comment 'Narrative description of the specific intercurrent event(s) addressed by this estimand (e.g., \'Discontinuation of study treatment due to adverse event\', \'Initiation of rescue medication\'). Provides regulatory-submission-ready documentation.' ;
    rdfs:domain ind:Estimand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercurrentEventStrategy rdf:type rdf:Property ;
    rdfs:label 'Intercurrent Event Strategy' ;
    rdfs:comment 'The primary strategy applied to handle intercurrent events (ICEs) for this estimand, per ICH E9(R1) Section 3.2. Defines how post-ICE data are treated in the analysis (e.g., treatment policy ignores ICE occurrence; hypothetical posits ICE did not occur).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConfirmatory rdf:type rdf:Property ;
    rdfs:label 'Is Confirmatory' ;
    rdfs:comment 'Flag indicating whether this estimand is part of the confirmatory (inferential) testing hierarchy, as opposed to exploratory or descriptive analyses. Confirmatory estimands are subject to multiplicity control procedures defined in the SAP.' ;
    rdfs:domain ind:Estimand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryEndpoint rdf:type rdf:Property ;
    rdfs:label 'Is Primary Endpoint' ;
    rdfs:comment 'Flag indicating whether this estimand corresponds to the study\'s primary endpoint. Primary endpoint estimands carry the highest regulatory weight and drive sample size calculations and confirmatory testing procedures.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:label rdf:type rdf:Property ;
    rdfs:label 'Label' ;
    rdfs:comment 'Short human-readable label or title for the estimand (e.g., \'Primary Efficacy Estimand\', \'Key Secondary Estimand 1\'). Used in TLF headers, CSR statistical sections, and regulatory submission narratives.' ;
    rdfs:domain ind:Estimand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:missingDataStrategy rdf:type rdf:Property ;
    rdfs:label 'Missing Data Strategy' ;
    rdfs:comment 'The statistical strategy applied to handle missing outcome data for this estimand (e.g., Last Observation Carried Forward (LOCF), multiple imputation, mixed model for repeated measures). Distinct from the ICE strategy — addresses data gaps rather than post-ICE observations.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiplicityAdjustmentMethod rdf:type rdf:Property ;
    rdfs:label 'Multiplicity Adjustment Method' ;
    rdfs:comment 'The statistical method used to control Type I error across multiple estimands or endpoints in the confirmatory testing hierarchy (e.g., \'Bonferroni\', \'Hochberg\', \'Hierarchical testing\', \'Gatekeeping procedure\'). Null if estimand is exploratory.' ;
    rdfs:domain ind:Biostatistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonInferiorityMargin rdf:type rdf:Property ;
    rdfs:label 'Non Inferiority Margin' ;
    rdfs:comment 'The pre-specified non-inferiority margin (delta) for this estimand, applicable when the effect direction is non-inferiority. Expressed in the units of the summary measure. Null for superiority or equivalence estimands.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:populationLevelSummary rdf:type rdf:Property ;
    rdfs:label 'Population Level Summary' ;
    rdfs:comment 'The \'Summary Measure\' component of the ICH E9(R1) estimand framework — the statistical measure used to summarize the endpoint at the population level (e.g., \'Difference in means\', \'Odds ratio\', \'Hazard ratio\', \'Difference in proportions\').' ;
    rdfs:domain ind:Estimand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'The primary regulatory framework or agency guideline under which this estimand is defined and will be submitted. Determines the specific regulatory expectations for estimand documentation in the Clinical Study Report (CSR). [ENUM-REF-CANDIDATE: ICH_E9R1|FDA|EMA|PMDA|MHRA|TGA|Health_Canada — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapAlignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Sap Alignment Status' ;
    rdfs:comment 'Indicates whether this estimand definition is currently aligned with the approved SAP version. Misalignment triggers a SAP amendment workflow. Critical for regulatory inspection readiness and DBL (Database Lock) governance.' ;
    rdfs:domain ind:Estimand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensitivityAnalysisDescription rdf:type rdf:Property ;
    rdfs:label 'Sensitivity Analysis Description' ;
    rdfs:comment 'Description of the associated sensitivity analyses planned to assess the robustness of the primary estimand result to deviations from assumptions, per ICH E9(R1) Section 3.8. References specific SAP sections where sensitivity analyses are detailed.' ;
    rdfs:domain ind:Biostatistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplementaryAnalysisDescription rdf:type rdf:Property ;
    rdfs:label 'Supplementary Analysis Description' ;
    rdfs:comment 'Description of supplementary analyses associated with this estimand that provide additional context or explore alternative assumptions beyond the primary and sensitivity analyses, per ICH E9(R1) Section 3.9.' ;
    rdfs:domain ind:Estimand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPopulationDescription rdf:type rdf:Property ;
    rdfs:label 'Target Population Description' ;
    rdfs:comment 'Narrative description of the \'Population\' component of the ICH E9(R1) estimand framework — the set of subjects to whom the question of interest applies (e.g., \'All randomized patients with Type 2 Diabetes and baseline HbA1c ≥ 7.5%\').' ;
    rdfs:domain ind:Estimand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epochId rdf:type rdf:Property ;
    rdfs:label 'Epoch Id' ;
    rdfs:comment 'Foreign key linking to study.study_epoch. Business justification: Interim analyses are planned at epoch boundaries (end of treatment epoch, end of follow-up). This FK enables DSMB meeting scheduling aligned to epoch completion, alpha-spending function application at' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Epoch .

ind:pipelineAssetId rdf:type rdf:Property ;
    rdfs:label 'Pipeline Asset Id' ;
    rdfs:comment 'Foreign key linking to sponsor.pipeline_asset. Business justification: Interim analysis outcomes (stopping_rule_triggered, analysis_outcome, conditional_power) directly drive go/no-go decisions for the pipeline asset\'s phase progression. Sponsors track interim results at' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PipelineAsset .

ind:safetyReportSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Safety Report Submission Id' ;
    rdfs:comment 'Foreign key linking to regulatory.safety_report_submission. Business justification: Interim analyses generating safety signals trigger expedited IND safety reports (DSURs, SUSARs). The interim_analysis has \'regulatory_submission_required\' flag. This FK links the interim analysis data' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyReportSubmission .

ind:actualAnalysisDate rdf:type rdf:Property ;
    rdfs:label 'Actual Analysis Date' ;
    rdfs:comment 'The actual calendar date on which the interim analysis was executed and results were produced. May differ from planned date due to enrollment pace or operational factors.' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adamDatasetVersion rdf:type rdf:Property ;
    rdfs:label 'Adam Dataset Version' ;
    rdfs:comment 'Version identifier of the CDISC ADaM datasets used as input to this interim analysis, ensuring traceability between the analysis results and the underlying data snapshot.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adaptationDescription rdf:type rdf:Property ;
    rdfs:label 'Adaptation Description' ;
    rdfs:comment 'Narrative description of any pre-specified design adaptation implemented as a result of this interim analysis (e.g., sample size re-estimation, dose selection, population enrichment). Populated only when analysis_outcome is \'adapt\'.' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alphaAllocated rdf:type rdf:Property ;
    rdfs:label 'Alpha Allocated' ;
    rdfs:comment 'The portion of the overall one-sided or two-sided alpha (Type I error rate) allocated to this specific interim look by the alpha spending function. Used to derive the efficacy stopping boundary.' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alphaSpendingParameter rdf:type rdf:Property ;
    rdfs:label 'Alpha Spending Parameter' ;
    rdfs:comment 'Numeric parameter (gamma) for the selected alpha spending function, where applicable (e.g., the gamma parameter for Hwang-Shih-DeCani function). Null for functions that do not require a parameter.' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analysisCode rdf:type rdf:Property ;
    rdfs:label 'Analysis Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for this interim analysis, used in regulatory submissions, DSMB/DMC charters, and TMF documentation (e.g., IA-STUDY001-001).' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisNumber rdf:type rdf:Property ;
    rdfs:label 'Analysis Number' ;
    rdfs:comment 'Sequential ordinal number identifying this interim analysis within the study (e.g., 1 for first interim, 2 for second interim). Used to track the series of planned looks at accumulating data.' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analysisOutcome rdf:type rdf:Property ;
    rdfs:label 'Analysis Outcome' ;
    rdfs:comment 'The formal decision or recommendation resulting from the interim analysis: continue (study proceeds as planned), stop_efficacy (early termination for demonstrated benefit), stop_futility (early termination for lack of benefit), stop_safety (early termination for safety concerns), adapt (pre-specified design adaptation implemented), or pending (DSMB/DMC recommendation not yet issued).' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisStatus rdf:type rdf:Property ;
    rdfs:label 'Analysis Status' ;
    rdfs:comment 'Current lifecycle state of the interim analysis: planned (scheduled but not yet initiated), in_progress (analysis underway), completed (results finalized), cancelled (analysis removed from plan), or on_hold (temporarily suspended).' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionalPower rdf:type rdf:Property ;
    rdfs:label 'Conditional Power' ;
    rdfs:comment 'Probability of achieving a statistically significant result at the final analysis, conditional on the data observed at this interim look and assuming the originally hypothesized treatment effect. Used in futility assessments.' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataCutoffDate rdf:type rdf:Property ;
    rdfs:label 'Data Cutoff Date' ;
    rdfs:comment 'The date through which subject data was included in the interim analysis dataset. All data collected after this date is excluded from the analysis. Critical for regulatory traceability and blinding integrity.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dsmbInvolved rdf:type rdf:Property ;
    rdfs:label 'Dsmb Involved' ;
    rdfs:comment 'Indicates whether a Data Safety Monitoring Board (DSMB) or Data Monitoring Committee (DMC) reviewed the unblinded interim analysis results (True = DSMB/DMC reviewed; False = internal review only).' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dsmbMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Dsmb Meeting Date' ;
    rdfs:comment 'Date on which the Data Safety Monitoring Board (DSMB) or Data Monitoring Committee (DMC) convened to review the interim analysis results and issue a recommendation.' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:efficacyBoundaryValue rdf:type rdf:Property ;
    rdfs:label 'Efficacy Boundary Value' ;
    rdfs:comment 'Pre-specified critical value (e.g., z-statistic or p-value threshold) for the efficacy stopping boundary at this interim look. If the observed test statistic exceeds this boundary, early stopping for efficacy is triggered.' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventsObserved rdf:type rdf:Property ;
    rdfs:label 'Events Observed' ;
    rdfs:comment 'Number of primary endpoint events (e.g., deaths, disease progression events) observed as of the data cutoff date. Applicable for event-driven trials; used to compute the actual information fraction.' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventsPlannedTotal rdf:type rdf:Property ;
    rdfs:label 'Events Planned Total' ;
    rdfs:comment 'Total number of primary endpoint events required for the final analysis as specified in the SAP and sample size calculation. Used as the denominator for the information fraction in event-driven trials.' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firewallMaintained rdf:type rdf:Property ;
    rdfs:label 'Firewall Maintained' ;
    rdfs:comment 'Indicates whether a blinding firewall was maintained between the unblinded interim analysis team and the blinded study team (True = firewall in place; False = firewall not maintained or not applicable). Critical for regulatory compliance in adaptive trials.' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:futilityBoundaryBinding rdf:type rdf:Property ;
    rdfs:label 'Futility Boundary Binding' ;
    rdfs:comment 'Indicates whether the futility stopping boundary is binding (True = mandatory stop if crossed; False = non-binding/advisory only). Binding futility boundaries affect the overall Type I error calculation.' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:futilityBoundaryValue rdf:type rdf:Property ;
    rdfs:label 'Futility Boundary Value' ;
    rdfs:comment 'Pre-specified critical value for the futility stopping boundary at this interim look. If the observed test statistic falls below this boundary, early stopping for futility (lack of efficacy) may be triggered. May be binding or non-binding per the SAP.' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:informationFractionActual rdf:type rdf:Property ;
    rdfs:label 'Information Fraction Actual' ;
    rdfs:comment 'Observed proportion of total planned statistical information actually accumulated at the time of this interim analysis. May differ from planned fraction due to enrollment variability or event rate changes.' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:informationFractionPlanned rdf:type rdf:Property ;
    rdfs:label 'Information Fraction Planned' ;
    rdfs:comment 'Pre-specified proportion of the total planned statistical information (e.g., events, subjects) accumulated at the time of this interim analysis, expressed as a decimal between 0 and 1 (e.g., 0.5000 = 50% of planned events). Drives alpha spending calculations.' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:observedPValue rdf:type rdf:Property ;
    rdfs:label 'Observed P Value' ;
    rdfs:comment 'The nominal p-value from the primary hypothesis test at this interim analysis. Must be interpreted in the context of the alpha spending boundary, not as a standalone significance threshold.' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:observedTestStatistic rdf:type rdf:Property ;
    rdfs:label 'Observed Test Statistic' ;
    rdfs:comment 'The actual computed test statistic (e.g., z-score, chi-square, log-rank statistic) from the interim analysis dataset. Compared against efficacy and futility boundaries to determine the outcome.' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedAnalysisDate rdf:type rdf:Property ;
    rdfs:label 'Planned Analysis Date' ;
    rdfs:comment 'Pre-specified calendar date on which the interim analysis is planned to be conducted, as documented in the SAP and DSMB/DMC charter.' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatorySubmissionRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Required' ;
    rdfs:comment 'Indicates whether the interim analysis results or the resulting design adaptation must be submitted to a regulatory authority (FDA, EMA, PMDA, etc.) as part of an IND, NDA, BLA, or MAA amendment (True = submission required; False = not required).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resultsDisclosedExternally rdf:type rdf:Property ;
    rdfs:label 'Results Disclosed Externally' ;
    rdfs:comment 'Indicates whether the interim analysis results have been disclosed externally (e.g., to regulators, in a public registry, or in a publication) prior to study completion (True = disclosed; False = not disclosed). Tracks blinding integrity at the study level.' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revisedSampleSize rdf:type rdf:Property ;
    rdfs:label 'Revised Sample Size' ;
    rdfs:comment 'Updated total sample size determined through the pre-specified sample size re-estimation procedure at this interim analysis. Null if sample_size_reestimated is False.' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleSizeReestimated rdf:type rdf:Property ;
    rdfs:label 'Sample Size Reestimated' ;
    rdfs:comment 'Indicates whether a pre-specified sample size re-estimation was performed as part of this interim analysis (True = sample size re-estimated; False = no re-estimation performed).' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sasProgramVersion rdf:type rdf:Property ;
    rdfs:label 'Sas Program Version' ;
    rdfs:comment 'Version identifier of the SAS Drug Development program or analysis package used to execute this interim analysis, enabling reproducibility and audit traceability.' ;
    rdfs:domain ind:Biostatistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stoppingRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Stopping Rule Description' ;
    rdfs:comment 'Narrative description of the specific stopping rule(s) triggered at this interim analysis, including the criterion crossed and the observed vs. boundary values. Populated only when stopping_rule_triggered is True.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stoppingRuleTriggered rdf:type rdf:Property ;
    rdfs:label 'Stopping Rule Triggered' ;
    rdfs:comment 'Indicates whether any pre-specified stopping rule (efficacy, futility, or safety) was triggered by the results of this interim analysis (True = stopping rule crossed; False = no stopping rule triggered).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subjectsEnrolledAtCutoff rdf:type rdf:Property ;
    rdfs:label 'Subjects Enrolled At Cutoff' ;
    rdfs:comment 'Total number of subjects enrolled in the study as of the data cutoff date for this interim analysis. Provides context for the information fraction and statistical power.' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unblindingAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Unblinding Authorization Date' ;
    rdfs:comment 'Date on which formal authorization was granted to unblind the interim analysis data, as documented in the unblinding log. Required for audit trail and blinding integrity compliance.' ;
    rdfs:domain ind:InterimAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pkAnalysisSpecId rdf:type rdf:Property ;
    rdfs:label 'Pk Analysis Spec Id' ;
    rdfs:comment 'Unique surrogate identifier for the PK analysis specification record. Primary key for this entity.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PkAnalysisSpec .

ind:bioanalyticalAssayId rdf:type rdf:Property ;
    rdfs:label 'Bioanalytical Assay Id' ;
    rdfs:comment 'Foreign key linking to laboratory.bioanalytical_assay. Business justification: The PK analysis spec defines LLOQ handling, NCA method, and matrix-specific rules that are directly tied to the validated bioanalytical assay. DMPK statisticians must reference the assay validation re' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BioanalyticalAssay .

ind:dosingRegimenId rdf:type rdf:Property ;
    rdfs:label 'Dosing Regimen Id' ;
    rdfs:comment 'Foreign key linking to study.dosing_regimen. Business justification: PK analysis specs reference specific dosing regimens for dose normalization (dose_normalization_flag/method) and steady-state determination. DMPK teams author specs per regimen in dose-escalation stud' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DosingRegimen .

ind:externalTransferId rdf:type rdf:Property ;
    rdfs:label 'External Transfer Id' ;
    rdfs:comment 'Foreign key linking to data.external_transfer. Business justification: PK analysis specifications depend on bioanalytical concentration data delivered via external transfer from the lab. Biostatisticians and DMPK scientists must reference the specific external transfer r' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExternalTransfer .

ind:investigationalProductId rdf:type rdf:Property ;
    rdfs:label 'Investigational Product Id' ;
    rdfs:comment 'Foreign key linking to study.investigational_product. Business justification: PK analysis specs are authored per investigational product — dose normalization methods, compartmental model types, and BE bounds are IP-specific. In multi-product or combination studies, DMPK teams n' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestigationalProduct .

ind:pkSamplingScheduleId rdf:type rdf:Property ;
    rdfs:label 'Pk Sampling Schedule Id' ;
    rdfs:comment 'Foreign key linking to study.pk_sampling_schedule. Business justification: DMPK teams author PK analysis specs against specific protocol sampling schedules. The spec\'s NCA/compartmental modeling parameters (lambda_z, AUC extrapolation thresholds) are directly determined by t' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PkSamplingSchedule .

ind:aucExtrapolationPctThreshold rdf:type rdf:Property ;
    rdfs:label 'Auc Extrapolation Pct Threshold' ;
    rdfs:comment 'Maximum acceptable percentage of AUC0-inf attributable to extrapolation beyond the last measurable concentration (AUC_extrap%). Subjects exceeding this threshold (typically 20%) may have AUC0-inf excluded from analysis per regulatory guidance.' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beLowerBoundPct rdf:type rdf:Property ;
    rdfs:label 'Be Lower Bound Pct' ;
    rdfs:comment 'Lower bound of the bioequivalence acceptance range expressed as a percentage of the reference geometric mean ratio (e.g., 80.00 for the standard 80-125% BE window). Applies when bioequivalence_flag is True.' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beUpperBoundPct rdf:type rdf:Property ;
    rdfs:label 'Be Upper Bound Pct' ;
    rdfs:comment 'Upper bound of the bioequivalence acceptance range expressed as a percentage of the reference geometric mean ratio (e.g., 125.00 for the standard 80-125% BE window). Applies when bioequivalence_flag is True.' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bioequivalenceFlag rdf:type rdf:Property ;
    rdfs:label 'Bioequivalence Flag' ;
    rdfs:comment 'Indicates whether this PK analysis specification includes a formal bioequivalence (BE) assessment. True = BE criteria and confidence interval (CI) testing apply. Relevant for generic drug applications (ANDA) and biosimilar submissions.' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ciLevelPct rdf:type rdf:Property ;
    rdfs:label 'Ci Level Pct' ;
    rdfs:comment 'Confidence level for the statistical interval estimate expressed as a percentage (e.g., 90.00 for 90% CI used in BE studies, 95.00 for standard efficacy analyses). Regulatory standard for BE is 90%.' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ciMethod rdf:type rdf:Property ;
    rdfs:label 'Ci Method' ;
    rdfs:comment 'Statistical method used to construct the confidence interval for the primary PK parameter comparison. The two one-sided t-test (TOST) / 90% CI using a linear mixed-effects model is the regulatory standard for bioequivalence. Schuirmann\'s procedure is the classical BE test.' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compartmentalModelType rdf:type rdf:Property ;
    rdfs:label 'Compartmental Model Type' ;
    rdfs:comment 'Specifies the pharmacokinetic compartmental model structure used when compartmental or population PK analysis is selected. Drives model parameterization in Phoenix WinNonlin or NONMEM. Not applicable for pure NCA analyses.' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmpkCollaborationRef rdf:type rdf:Property ;
    rdfs:label 'Dmpk Collaboration Ref' ;
    rdfs:comment 'Reference identifier linking this PK analysis specification to the Drug Metabolism and Pharmacokinetics (DMPK) team collaboration record, preclinical PK data package, or DMPK study report. Supports integrated PK/PD and translational PK reporting.' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doseNormalizationFlag rdf:type rdf:Property ;
    rdfs:label 'Dose Normalization Flag' ;
    rdfs:comment 'Indicates whether PK parameters are to be dose-normalized (divided by administered dose) to enable cross-dose comparisons in multiple ascending dose (MAD) or dose-proportionality studies. True = dose normalization applied.' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doseNormalizationMethod rdf:type rdf:Property ;
    rdfs:label 'Dose Normalization Method' ;
    rdfs:comment 'Method used to normalize PK parameters by dose when dose_normalization_flag is True. Actual dose uses the recorded administered dose; nominal dose uses the protocol-specified dose. Body weight and BSA normalization are used for oncology and pediatric studies.' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lambdaZMethod rdf:type rdf:Property ;
    rdfs:label 'Lambda Z Method' ;
    rdfs:comment 'Method for selecting the terminal log-linear phase data points used to estimate the terminal elimination rate constant (Lambda-z / Kel) and derived parameters (t½, AUC0-inf). Best-fit uses automated regression; manual selection allows analyst override.' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lambdaZMinPoints rdf:type rdf:Property ;
    rdfs:label 'Lambda Z Min Points' ;
    rdfs:comment 'Minimum number of data points required in the terminal phase for Lambda-z estimation to be considered valid. Typically set to 3 per regulatory guidance. Specifications below this threshold result in flagged or excluded Lambda-z estimates.' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lloqHandlingMethod rdf:type rdf:Property ;
    rdfs:label 'Lloq Handling Method' ;
    rdfs:comment 'Specifies how concentrations below the lower limit of quantification (LLOQ) are handled in the PK analysis dataset. Regulatory guidance typically requires setting pre-dose BLQ values to zero and post-dose BLQ values to zero or excluding them depending on context.' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logTransformationFlag rdf:type rdf:Property ;
    rdfs:label 'Log Transformation Flag' ;
    rdfs:comment 'Indicates whether PK parameters are log-transformed prior to statistical analysis. Log-normal distribution is the regulatory default for AUC and Cmax in BE and PK studies per FDA and EMA guidance.' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:missingConcentrationRule rdf:type rdf:Property ;
    rdfs:label 'Missing Concentration Rule' ;
    rdfs:comment 'Rule applied when scheduled PK concentration timepoints are missing. Defines whether the subject is excluded from analysis, the timepoint is excluded, or imputation is applied. Last Observation Carried Forward (LOCF) imputation is used in specific contexts per the SAP.' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncaMethod rdf:type rdf:Property ;
    rdfs:label 'Nca Method' ;
    rdfs:comment 'Specifies the trapezoidal integration rule applied during Non-Compartmental Analysis (NCA) for area-under-the-curve (AUC) estimation. Linear-up/log-down is the most common default in Phoenix WinNonlin for oral dosing studies.' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pkParameters rdf:type rdf:Property ;
    rdfs:label 'Pk Parameters' ;
    rdfs:comment 'Comma-separated list of pharmacokinetic parameters to be estimated in this analysis (e.g., AUC0-t, AUC0-inf, Cmax, Tmax, t½, CL, Vd, Vss, MRT, Kel). Defines the scope of PK endpoints reported in the CSR and regulatory submission. [ENUM-REF-CANDIDATE: AUC0_t|AUC0_inf|Cmax|Tmax|t_half|CL|Vd|Vss|MRT|Kel|F|ka|Cmin|Ctrough — promote to reference product]' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pkSoftware rdf:type rdf:Property ;
    rdfs:label 'Pk Software' ;
    rdfs:comment 'Software platform used to execute the PK analysis (e.g., Phoenix WinNonlin for NCA, NONMEM for population PK, SAS Drug Development for CDISC-compliant outputs). Documented for regulatory reproducibility per 21 CFR Part 11.' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pkSoftwareVersion rdf:type rdf:Property ;
    rdfs:label 'Pk Software Version' ;
    rdfs:comment 'Version of the PK analysis software used (e.g., Phoenix WinNonlin 8.3, SAS 9.4). Required for regulatory submission reproducibility and audit trail under 21 CFR Part 11 and GCP.' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPkParameter rdf:type rdf:Property ;
    rdfs:label 'Primary Pk Parameter' ;
    rdfs:comment 'The single primary pharmacokinetic parameter designated as the principal endpoint for this analysis (e.g., AUC0-inf for bioavailability studies, Cmax for peak exposure). Drives the primary statistical comparison and sample size justification in the SAP. [ENUM-REF-CANDIDATE: AUC0_t|AUC0_inf|Cmax|Tmax|t_half|CL|Vd|Vss — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rSquaredThreshold rdf:type rdf:Property ;
    rdfs:label 'R Squared Threshold' ;
    rdfs:comment 'Minimum adjusted R-squared value required for the terminal phase regression used in Lambda-z estimation to be accepted (e.g., 0.8000). Estimates below this threshold are flagged for biostatistician review.' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:samplingScheduleType rdf:type rdf:Property ;
    rdfs:label 'Sampling Schedule Type' ;
    rdfs:comment 'Classifies the blood sampling schedule design for PK data collection. Intensive sampling (rich PK) is used in Phase I; sparse/population sampling is used in Phase II/III for population PK modeling. Trough-only is used for therapeutic drug monitoring.' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmPcDomainRef rdf:type rdf:Property ;
    rdfs:label 'Sdtm Pc Domain Ref' ;
    rdfs:comment 'Reference to the CDISC SDTM Pharmacokinetics Concentrations (PC) domain dataset that serves as the source data for this PK analysis. Ensures traceability from raw concentration data through ADaM to TLF outputs per CDISC standards.' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specCode rdf:type rdf:Property ;
    rdfs:label 'Spec Code' ;
    rdfs:comment 'Externally-known, human-readable unique code assigned to this PK analysis specification (e.g., PK-SPEC-001). Used for cross-referencing in the Statistical Analysis Plan (SAP), Clinical Study Report (CSR), and regulatory submissions.' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specTitle rdf:type rdf:Property ;
    rdfs:label 'Spec Title' ;
    rdfs:comment 'Descriptive title of the PK analysis specification (e.g., \'Non-Compartmental PK Analysis for Study XYZ Phase I Single Ascending Dose\'). Used for identification in SAS Drug Development and regulatory documentation.' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyDesignType rdf:type rdf:Property ;
    rdfs:label 'Study Design Type' ;
    rdfs:comment 'Specifies the clinical study design relevant to PK analysis (e.g., crossover for BE studies, parallel for oncology PK, replicate crossover for highly variable drugs). Determines the statistical model structure for PK comparisons.' ;
    rdfs:domain ind:Biostatistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tlfProgramName rdf:type rdf:Property ;
    rdfs:label 'Tlf Program Name' ;
    rdfs:comment 'Name of the SAS Drug Development program or script used to generate the Tables, Listings, and Figures (TLF) outputs for this PK analysis. Supports audit trail and reproducibility requirements for regulatory submissions.' ;
    rdfs:domain ind:PkAnalysisSpec ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSizeCalcId rdf:type rdf:Property ;
    rdfs:label 'Sample Size Calc Id' ;
    rdfs:comment 'Unique surrogate identifier for each sample size calculation record within the biostatistics domain.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SampleSizeCalc .

ind:accrualPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Accrual Period Months' ;
    rdfs:comment 'The assumed patient accrual (enrollment) period in months, used in time-to-event sample size calculations to determine the number of events required.' ;
    rdfs:domain ind:SampleSizeCalc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationRatio rdf:type rdf:Property ;
    rdfs:label 'Allocation Ratio' ;
    rdfs:comment 'The randomization allocation ratio between treatment arms (e.g., \'1:1\', \'2:1\', \'1:1:1\'), specifying the relative number of subjects assigned to each arm.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alphaSpendingMethod rdf:type rdf:Property ;
    rdfs:label 'Alpha Spending Method' ;
    rdfs:comment 'The alpha-spending function applied to control Type I error across planned interim analyses (e.g., O\'Brien-Fleming, Pocock, Lan-DeMets). Null or \'none\' if no interim analysis is planned.' ;
    rdfs:domain ind:SampleSizeCalc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calcDate rdf:type rdf:Property ;
    rdfs:label 'Calc Date' ;
    rdfs:comment 'The date on which this sample size calculation was performed or finalized, serving as the principal business event date for regulatory traceability.' ;
    rdfs:domain ind:SampleSizeCalc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calcIdentifier rdf:type rdf:Property ;
    rdfs:label 'Calc Identifier' ;
    rdfs:comment 'Externally-known alphanumeric code or reference number assigned to this sample size calculation, used in regulatory submissions and protocol documentation (e.g., SSC-2024-001).' ;
    rdfs:domain ind:SampleSizeCalc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calcStatus rdf:type rdf:Property ;
    rdfs:label 'Calc Status' ;
    rdfs:comment 'Current lifecycle status of the sample size calculation record, from initial draft through regulatory approval to archival.' ;
    rdfs:domain ind:SampleSizeCalc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calcVersion rdf:type rdf:Property ;
    rdfs:label 'Calc Version' ;
    rdfs:comment 'Version number of this sample size calculation (e.g., v1.0, v2.1), enabling tracking of revisions driven by protocol amendments or updated assumptions.' ;
    rdfs:domain ind:SampleSizeCalc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dropoutRate rdf:type rdf:Property ;
    rdfs:label 'Dropout Rate' ;
    rdfs:comment 'The assumed proportion of enrolled subjects expected to discontinue or be lost to follow-up, used to inflate the calculated sample size to ensure adequate evaluable subjects.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectSize rdf:type rdf:Property ;
    rdfs:label 'Effect Size' ;
    rdfs:comment 'The clinically meaningful difference or effect size assumed between treatment arms (e.g., mean difference, odds ratio, hazard ratio) used as the basis for the sample size calculation.' ;
    rdfs:domain ind:SampleSizeCalc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectSizeUnit rdf:type rdf:Property ;
    rdfs:label 'Effect Size Unit' ;
    rdfs:comment 'Unit of measurement for the assumed effect size (e.g., mmHg, %, hazard ratio, odds ratio, mean difference), providing dimensional context for regulatory interpretation.' ;
    rdfs:domain ind:SampleSizeCalc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventRateControl rdf:type rdf:Property ;
    rdfs:label 'Event Rate Control' ;
    rdfs:comment 'The assumed event rate or response rate in the control arm, applicable for binary or time-to-event endpoints. Null for continuous endpoints.' ;
    rdfs:domain ind:SampleSizeCalc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventRateTreatment rdf:type rdf:Property ;
    rdfs:label 'Event Rate Treatment' ;
    rdfs:comment 'The assumed event rate or response rate in the treatment arm, applicable for binary or time-to-event endpoints. Null for continuous endpoints.' ;
    rdfs:domain ind:SampleSizeCalc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:followUpPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Follow Up Period Months' ;
    rdfs:comment 'The assumed minimum follow-up period in months after the last patient enrolled, used in time-to-event calculations to ensure sufficient events are observed.' ;
    rdfs:domain ind:SampleSizeCalc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hypothesisType rdf:type rdf:Property ;
    rdfs:label 'Hypothesis Type' ;
    rdfs:comment 'The statistical hypothesis framework applied (superiority, non-inferiority, equivalence), which determines the directionality and margin used in the sample size formula.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interimAnalysisPlanned rdf:type rdf:Property ;
    rdfs:label 'Interim Analysis Planned' ;
    rdfs:comment 'Indicates whether one or more interim analyses are planned for this study, which may require alpha-spending adjustments to the sample size calculation.' ;
    rdfs:domain ind:SampleSizeCalc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medianSurvivalControl rdf:type rdf:Property ;
    rdfs:label 'Median Survival Control' ;
    rdfs:comment 'The assumed median survival time in the control arm for time-to-event endpoints, used in log-rank or exponential model-based sample size calculations. Null for non-survival endpoints.' ;
    rdfs:domain ind:SampleSizeCalc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfArms rdf:type rdf:Property ;
    rdfs:label 'Number Of Arms' ;
    rdfs:comment 'Total number of treatment arms (including control) in the study design, used to determine the allocation structure and multiplicity adjustments.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfEventsRequired rdf:type rdf:Property ;
    rdfs:label 'Number Of Events Required' ;
    rdfs:comment 'The minimum number of primary endpoint events (e.g., deaths, progressions) required to achieve the specified power for time-to-event analyses. Null for non-event-driven endpoints.' ;
    rdfs:domain ind:SampleSizeCalc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:power rdf:type rdf:Property ;
    rdfs:label 'Power' ;
    rdfs:comment 'The pre-specified statistical power (1 minus Type II error rate, beta) used in the calculation, representing the probability of detecting the assumed effect size. Typically 0.80 or 0.90.' ;
    rdfs:domain ind:SampleSizeCalc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryEndpointDescription rdf:type rdf:Property ;
    rdfs:label 'Primary Endpoint Description' ;
    rdfs:comment 'Narrative description of the primary endpoint used in the sample size calculation (e.g., \'Change from baseline in HbA1c at Week 24\'), providing clinical context for regulatory reviewers.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEndpointType rdf:type rdf:Property ;
    rdfs:label 'Primary Endpoint Type' ;
    rdfs:comment 'Statistical nature of the primary efficacy endpoint (e.g., continuous, binary, time-to-event, ordinal, count) that drives the choice of sample size formula.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceSource rdf:type rdf:Property ;
    rdfs:label 'Reference Source' ;
    rdfs:comment 'Citation or reference for the data source used to derive the assumed effect size, standard deviation, or event rate (e.g., published literature citation, prior Phase II study identifier, internal pilot data).' ;
    rdfs:domain ind:SampleSizeCalc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSizePerArm rdf:type rdf:Property ;
    rdfs:label 'Sample Size Per Arm' ;
    rdfs:comment 'The calculated number of subjects required per treatment arm to achieve the specified power at the given alpha level, accounting for the assumed effect size and standard deviation.' ;
    rdfs:domain ind:SampleSizeCalc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:softwareName rdf:type rdf:Property ;
    rdfs:label 'Software Name' ;
    rdfs:comment 'Name of the validated statistical software used to perform the sample size calculation (e.g., PASS, nQuery Advisor, SAS PROC POWER, R), required for regulatory audit trail.' ;
    rdfs:domain ind:SampleSizeCalc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softwareVersion rdf:type rdf:Property ;
    rdfs:label 'Software Version' ;
    rdfs:comment 'Version number of the statistical software used (e.g., PASS 2023, nQuery 9.1), required for reproducibility and regulatory validation documentation.' ;
    rdfs:domain ind:SampleSizeCalc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardDeviation rdf:type rdf:Property ;
    rdfs:label 'Standard Deviation' ;
    rdfs:comment 'The assumed population standard deviation for continuous endpoints, derived from prior studies or literature, used in the sample size formula. Null for non-continuous endpoints.' ;
    rdfs:domain ind:SampleSizeCalc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statisticalMethod rdf:type rdf:Property ;
    rdfs:label 'Statistical Method' ;
    rdfs:comment 'The specific statistical formula or method used for the calculation (e.g., two-sample t-test, log-rank test, chi-square test, Kaplan-Meier), providing methodological traceability.' ;
    rdfs:domain ind:Biostatistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testSidedness rdf:type rdf:Property ;
    rdfs:label 'Test Sidedness' ;
    rdfs:comment 'Specifies whether the statistical test is one-sided or two-sided, directly affecting the critical value and resulting sample size.' ;
    rdfs:domain ind:SampleSizeCalc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEnrollmentTarget rdf:type rdf:Property ;
    rdfs:label 'Total Enrollment Target' ;
    rdfs:comment 'The total number of subjects to be enrolled (randomized) after inflating the total sample size by the assumed dropout rate, representing the actual recruitment target submitted in the protocol.' ;
    rdfs:domain ind:SampleSizeCalc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSampleSize rdf:type rdf:Property ;
    rdfs:label 'Total Sample Size' ;
    rdfs:comment 'The total number of subjects required across all treatment arms before applying the dropout inflation, representing the minimum evaluable sample.' ;
    rdfs:domain ind:SampleSizeCalc ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadStatisticianEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lead Statistician Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory accountability requires the SAP lead statistician to be a named, GCP-certified employee. Inspection-ready SAPs must link to workforce for training verification, delegation tracking, and spo' ;
    rdfs:domain ind:Sap ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adamDatasetSpecifications rdf:type rdf:Property ;
    rdfs:label 'Adam Dataset Specifications' ;
    rdfs:comment 'Reference to or summary of the ADaM (Analysis Data Model) dataset specifications linked to this SAP, including key analysis datasets (ADSL, ADAE, ADTTE, ADLB, etc.) and their derivation rules. Sourced from SAS Drug Development and aligned with CDISC ADaM standards.' ;
    rdfs:domain ind:Sap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentRationale rdf:type rdf:Property ;
    rdfs:label 'Amendment Rationale' ;
    rdfs:comment 'Narrative justification for the SAP amendment, describing the business or scientific reason for changes (e.g., protocol amendment, regulatory feedback, updated endpoint definition). Required for regulatory audit trail per ICH E9.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authoringSystem rdf:type rdf:Property ;
    rdfs:label 'Authoring System' ;
    rdfs:comment 'Name of the system used to author and manage this SAP document (e.g., SAS Drug Development, Veeva Vault). Supports system-of-record traceability and integration lineage.' ;
    rdfs:domain ind:Sap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsmbReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Dsmb Review Required' ;
    rdfs:comment 'Indicates whether this SAP includes or supports interim analyses to be reviewed by a Data Safety Monitoring Board (DSMB) or Data Monitoring Committee (DMC). Drives interim analysis planning and blinding procedures.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'Date from which this SAP version is considered effective and binding for statistical analyses. Typically the approval date. Supports version history and regulatory audit trail.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'Date on which this SAP version was superseded by a newer version or retired. Null for the currently active version. Supports version history management and regulatory audit trail.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimandDescription rdf:type rdf:Property ;
    rdfs:label 'Estimand Description' ;
    rdfs:comment 'Description of the treatment effect estimand(s) as defined per ICH E9(R1), including the population, variable (endpoint), intercurrent events handling strategy, and summary measure. Mandatory for SAPs submitted to FDA and EMA under ICH E9(R1) framework.' ;
    rdfs:domain ind:Sap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interimAnalysisCount rdf:type rdf:Property ;
    rdfs:label 'Interim Analysis Count' ;
    rdfs:comment 'Number of pre-specified interim analyses planned for this study as defined in the SAP. Zero if no interim analyses are planned. Drives alpha spending function selection and DSMB/DMC meeting scheduling.' ;
    rdfs:domain ind:Sap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ittPopulationDefinition rdf:type rdf:Property ;
    rdfs:label 'Itt Population Definition' ;
    rdfs:comment 'Formal definition of the Intent-to-Treat (ITT) analysis population as specified in the SAP, including inclusion/exclusion criteria for subjects in this population. The ITT population is the primary analysis population for most confirmatory trials per ICH E9.' ;
    rdfs:domain ind:Sap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerPercent rdf:type rdf:Property ;
    rdfs:label 'Power Percent' ;
    rdfs:comment 'Pre-specified statistical power (1 - beta) expressed as a percentage (e.g., 80.00, 90.00) used in the sample size calculation. Represents the probability of detecting a true treatment effect of the assumed magnitude.' ;
    rdfs:domain ind:Sap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppPopulationDefinition rdf:type rdf:Property ;
    rdfs:label 'Pp Population Definition' ;
    rdfs:comment 'Formal definition of the Per Protocol (PP) analysis population as specified in the SAP, including criteria for protocol deviations that would exclude subjects. Used as a sensitivity analysis population alongside ITT.' ;
    rdfs:domain ind:Sap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryStatisticalMethod rdf:type rdf:Property ;
    rdfs:label 'Primary Statistical Method' ;
    rdfs:comment 'Description of the primary statistical methodology applied to the primary endpoint analysis (e.g., ANCOVA, mixed-effects model for repeated measures (MMRM), Cox proportional hazards, logistic regression). Sourced from SAS Drug Development SAP authoring.' ;
    rdfs:domain ind:Sap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryImpact rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact' ;
    rdfs:comment 'Classification of the regulatory impact of this SAP version or amendment. \'none\' for administrative changes; \'minor\' for non-material updates; \'major\' for changes affecting primary analysis; \'requires_submission\' for changes requiring regulatory notification or submission.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionAlignment rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Alignment' ;
    rdfs:comment 'Identifies the regulatory submission type(s) this SAP is aligned to support (e.g., IND, NDA, BLA, MAA, eCTD). Ensures the SAP meets the statistical requirements of the target regulatory agency. [ENUM-REF-CANDIDATE: IND|NDA|BLA|MAA|CTD|eCTD|none — promote to reference product]' ;
    rdfs:domain ind:Sap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyPopulationDefinition rdf:type rdf:Property ;
    rdfs:label 'Safety Population Definition' ;
    rdfs:comment 'Formal definition of the safety analysis population as specified in the SAP, typically all randomized subjects who received at least one dose of study treatment. Used for all safety and adverse event analyses.' ;
    rdfs:domain ind:Sap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Total number of subjects planned for enrollment as specified in the SAP sample size calculation section. Derived from power calculations and protocol-specified assumptions. Used for enrollment tracking and regulatory review.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sapNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Number' ;
    rdfs:comment 'Externally-known, human-readable identifier for the SAP document, typically assigned by the sponsor or CRO (e.g., SAP-STUDY001-001). Used for regulatory submissions and cross-system referencing in Veeva Vault and SAS Drug Development.' ;
    rdfs:domain ind:Sap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryEndpointDescription rdf:type rdf:Property ;
    rdfs:label 'Secondary Endpoint Description' ;
    rdfs:comment 'Narrative description of all pre-specified secondary endpoints as defined in the SAP. May include multiple endpoints listed in priority order. Supports regulatory review and CSR statistical sections.' ;
    rdfs:domain ind:Sap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectionsModified rdf:type rdf:Property ;
    rdfs:label 'Sections Modified' ;
    rdfs:comment 'Comma-separated list or narrative description of SAP sections that were modified in this amendment (e.g., \'Section 3.1 Primary Endpoint, Section 5.2 Multiplicity Adjustment\'). Supports change impact assessment and regulatory review.' ;
    rdfs:domain ind:Biostatistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:significanceLevel rdf:type rdf:Property ;
    rdfs:label 'Significance Level' ;
    rdfs:comment 'Pre-specified two-sided alpha level for hypothesis testing (e.g., 0.0500 for 5%). Defines the threshold for declaring statistical significance. May be adjusted for multiplicity. Stored as a decimal fraction.' ;
    rdfs:domain ind:Biostatistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Full descriptive title of the Statistical Analysis Plan document, typically including the study name, indication, and phase (e.g., \'Statistical Analysis Plan for a Phase III Randomized Controlled Trial of Drug X in Indication Y\').' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tlfSpecifications rdf:type rdf:Property ;
    rdfs:label 'Tlf Specifications' ;
    rdfs:comment 'Reference to or summary of the Tables, Listings, and Figures (TLF) shells or specifications associated with this SAP. Defines the outputs to be produced by the statistical programming team in SAS Drug Development for the CSR.' ;
    rdfs:domain ind:Sap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionStatus rdf:type rdf:Property ;
    rdfs:label 'Version Status' ;
    rdfs:comment 'Current lifecycle status of this SAP version. \'draft\' indicates authoring in progress; \'in_review\' indicates under biostatistics or sponsor review; \'approved\' indicates final sign-off obtained; \'superseded\' indicates replaced by a newer version; \'retired\' indicates withdrawn.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Sap Amendment Id' ;
    rdfs:comment 'Unique surrogate identifier for each SAP amendment record in the Databricks Silver Layer. Primary key for the sap_amendment data product.' ;
    rdfs:domain ind:SapAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amendmentId rdf:type rdf:Property ;
    rdfs:label 'Amendment Id' ;
    rdfs:comment 'Foreign key linking to program.program_amendment. Business justification: Program amendments that change development strategy trigger SAP amendments. Regulatory audit trails require traceability from program-level changes to statistical plan changes. sap_amendment.protocol_' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:icfAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Icf Amendment Id' ;
    rdfs:comment 'Foreign key linking to consent.icf_amendment. Business justification: Protocol amendments co-trigger both SAP amendments and ICF amendments. Regulatory submissions and inspection readiness require direct traceability linking statistical plan changes to corresponding con' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcfAmendment .

ind:primarySapEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sap Employee Id' ;
    rdfs:comment 'Reference to the biostatistician or statistical programmer who authored this SAP amendment. Supports ALCOA+ attributability requirements for audit trail.' ;
    rdfs:domain ind:SapAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Employee Id' ;
    rdfs:comment 'Reference to the qualified statistician or biostatistics lead who performed the quality review of this SAP amendment prior to approval.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adamDatasetImpact rdf:type rdf:Property ;
    rdfs:label 'Adam Dataset Impact' ;
    rdfs:comment 'Comma-delimited list of ADaM datasets (e.g., ADSL, ADAE, ADTTE, ADLB) whose specifications are affected by this SAP amendment. Drives downstream ADaM dataset re-specification and re-validation.' ;
    rdfs:domain ind:SapAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentVersionCode rdf:type rdf:Property ;
    rdfs:label 'Amendment Version Code' ;
    rdfs:comment 'Human-readable version label for the amended SAP document (e.g., v1.1, v2.0, v3.1). Aligns with document management versioning conventions in Veeva Vault eTMF.' ;
    rdfs:domain ind:SapAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisPopulationChanged rdf:type rdf:Property ;
    rdfs:label 'Analysis Population Changed' ;
    rdfs:comment 'Indicates whether this amendment modifies the definition of any analysis population (e.g., Intent-to-Treat (ITT), Per Protocol (PP), Safety population). Population changes affect the integrity of the statistical inference.' ;
    rdfs:domain ind:SapAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Full name of the responsible statistician or biostatistics director who approved this SAP amendment. Captured at time of approval for regulatory audit trail integrity.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorName rdf:type rdf:Property ;
    rdfs:label 'Author Name' ;
    rdfs:comment 'Full name of the biostatistician or statistical programmer who authored this SAP amendment. Captured at time of authorship for audit trail integrity per ALCOA+ principles.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authoredDate rdf:type rdf:Property ;
    rdfs:label 'Authored Date' ;
    rdfs:comment 'Date on which the SAP amendment was completed by the author and submitted for review. Establishes the contemporaneous authorship timestamp per ALCOA+ principles.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blindingImpact rdf:type rdf:Property ;
    rdfs:label 'Blinding Impact' ;
    rdfs:comment 'Assessment of whether this amendment has any impact on study blinding integrity. Amendments that require access to unblinded data must be documented and controlled to prevent bias.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeSummary rdf:type rdf:Property ;
    rdfs:label 'Change Summary' ;
    rdfs:comment 'Concise executive summary of all changes introduced by this amendment, suitable for inclusion in the Clinical Study Report (CSR) statistical section and regulatory submission cover letter.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interimAnalysisChanged rdf:type rdf:Property ;
    rdfs:label 'Interim Analysis Changed' ;
    rdfs:comment 'Indicates whether this amendment modifies the interim analysis plan, including timing, stopping rules, alpha spending, or DSMB/DMC charter alignment.' ;
    rdfs:domain ind:SapAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irbIecNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Notification Required' ;
    rdfs:comment 'Indicates whether this SAP amendment requires notification or submission to the IRB/IEC overseeing the study. Relevant when SAP changes affect subject safety or consent.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:missingDataMethodChanged rdf:type rdf:Property ;
    rdfs:label 'Missing Data Method Changed' ;
    rdfs:comment 'Indicates whether this amendment revises the strategy for handling missing data (e.g., Last Observation Carried Forward (LOCF), multiple imputation, mixed models). Missing data methodology is a key regulatory focus area.' ;
    rdfs:domain ind:SapAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preDblFlag rdf:type rdf:Property ;
    rdfs:label 'Pre Dbl Flag' ;
    rdfs:comment 'Indicates whether this amendment was issued before (True) or after (False) the Database Lock (DBL). Pre-DBL amendments are standard; post-DBL amendments require heightened regulatory scrutiny and justification.' ;
    rdfs:domain ind:SapAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryEndpointChanged rdf:type rdf:Property ;
    rdfs:label 'Primary Endpoint Changed' ;
    rdfs:comment 'Indicates whether this amendment includes a change to the primary efficacy endpoint definition or analysis. Primary endpoint changes post-DBL are subject to heightened regulatory scrutiny.' ;
    rdfs:domain ind:SapAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:randomizationSchemeChanged rdf:type rdf:Property ;
    rdfs:label 'Randomization Scheme Changed' ;
    rdfs:comment 'Indicates whether this amendment modifies the randomization scheme or stratification factors used in the statistical analysis. Changes to randomization factors require protocol-level review.' ;
    rdfs:domain ind:SapAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact Assessment' ;
    rdfs:comment 'Assessed level of regulatory impact of this SAP amendment on the study\'s regulatory submission package (IND, NDA, BLA, MAA). Drives escalation, notification, and documentation requirements.' ;
    rdfs:domain ind:SapAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Review Completed Date' ;
    rdfs:comment 'Date on which the quality review of the SAP amendment was completed and the document was forwarded for approval.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleSizeChanged rdf:type rdf:Property ;
    rdfs:label 'Sample Size Changed' ;
    rdfs:comment 'Indicates whether this amendment revises the planned sample size or power assumptions. Sample size changes typically require protocol amendment and regulatory notification.' ;
    rdfs:domain ind:SapAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tlfImpact rdf:type rdf:Property ;
    rdfs:label 'Tlf Impact' ;
    rdfs:comment 'Description or list of Tables, Listings, and Figures (TLFs) in the Clinical Study Report (CSR) that are affected by this SAP amendment. Used to scope re-programming and QC activities.' ;
    rdfs:domain ind:SapAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalEndpointId rdf:type rdf:Property ;
    rdfs:label 'Statistical Endpoint Id' ;
    rdfs:comment 'Unique surrogate identifier for each statistical endpoint record defined in the Statistical Analysis Plan (SAP). Primary key for the statistical_endpoint data product.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StatisticalEndpoint .

ind:protocolEndpointId rdf:type rdf:Property ;
    rdfs:label 'Protocol Endpoint Id' ;
    rdfs:comment 'Foreign key linking to study.study_endpoint. Business justification: ICH E9(R1) and regulatory submissions require explicit traceability from SAP statistical endpoints to protocol-defined endpoints. Statisticians map each protocol endpoint to its statistical operationa' ;
    rdfs:domain ind:StatisticalEndpoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Endpoint .

ind:tlfShellId rdf:type rdf:Property ;
    rdfs:label 'Tlf Shell Id' ;
    rdfs:comment 'Foreign key linking to biostatistics.tlf_shell. Business justification: statistical_endpoint has tlf_reference (STRING) pointing to the TLF shell that displays the endpoint results. Normalizing this to a FK to tlf_shell.tlf_shell_id creates a proper referential link betwe' ;
    rdfs:domain ind:Biostatistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TlfShell .

ind:alternativeHypothesis rdf:type rdf:Property ;
    rdfs:label 'Alternative Hypothesis' ;
    rdfs:comment 'Formal statement of the alternative hypothesis (H1) for this endpoint as specified in the SAP (e.g., \'Overall survival is superior in the treatment arm compared to control\'). Defines the direction of the test (superiority, non-inferiority, equivalence).' ;
    rdfs:domain ind:StatisticalEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceIntervalLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Level' ;
    rdfs:comment 'Pre-specified confidence interval level for the treatment effect estimate (e.g., 95.00 for a 95% CI, 97.50 for a one-sided 97.5% CI). Defined in the SAP and reported in TLFs and regulatory submissions.' ;
    rdfs:domain ind:StatisticalEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:covariates rdf:type rdf:Property ;
    rdfs:label 'Covariates' ;
    rdfs:comment 'Comma-separated list of pre-specified covariates and stratification factors included in the statistical model for this endpoint (e.g., \'baseline_value, region, age_group\'). Defined in the SAP per EMA guideline on adjustment for baseline covariates.' ;
    rdfs:domain ind:StatisticalEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectMeasure rdf:type rdf:Property ;
    rdfs:label 'Effect Measure' ;
    rdfs:comment 'The statistical measure used to quantify the treatment effect for this endpoint (e.g., \'Mean Difference\', \'Hazard Ratio\', \'Odds Ratio\', \'Risk Difference\', \'Least Squares Mean Difference\'). Specified in the SAP and reported in TLFs and the CSR.' ;
    rdfs:domain ind:StatisticalEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointClassification rdf:type rdf:Property ;
    rdfs:label 'Endpoint Classification' ;
    rdfs:comment 'Hierarchical classification of the endpoint within the study\'s inferential framework: primary (confirmatory, controls Type I error), secondary (supportive), exploratory (hypothesis-generating), or safety (adverse event-related). Drives multiplicity adjustment strategy.' ;
    rdfs:domain ind:StatisticalEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointCode rdf:type rdf:Property ;
    rdfs:label 'Endpoint Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the endpoint, used in SAP documents, TLF shells, and regulatory submissions. Follows the pattern EP-{STUDY_CODE}-{SEQ}.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointDescription rdf:type rdf:Property ;
    rdfs:label 'Endpoint Description' ;
    rdfs:comment 'Full narrative description of the statistical endpoint as stated in the SAP, including the precise definition of the outcome measure, population, and timeframe.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointName rdf:type rdf:Property ;
    rdfs:label 'Endpoint Name' ;
    rdfs:comment 'Short, human-readable name of the statistical endpoint as defined in the SAP (e.g., \'Overall Survival\', \'Change from Baseline in HbA1c at Week 24\'). Used in TLF titles and regulatory submissions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointStatus rdf:type rdf:Property ;
    rdfs:label 'Endpoint Status' ;
    rdfs:comment 'Current lifecycle status of the statistical endpoint definition within the SAP authoring and versioning workflow: draft (being authored), under_review (in statistical/medical review), approved (finalized in SAP), locked (post-database lock, immutable), superseded (replaced by a newer version), or retired (no longer active).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockedDate rdf:type rdf:Property ;
    rdfs:label 'Locked Date' ;
    rdfs:comment 'Date on which this endpoint definition was locked following database lock (DBL), rendering it immutable for regulatory submission purposes. Supports ALCOA+ audit trail requirements.' ;
    rdfs:domain ind:StatisticalEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementScale rdf:type rdf:Property ;
    rdfs:label 'Measurement Scale' ;
    rdfs:comment 'Statistical measurement scale of the endpoint variable: continuous (numeric), binary (two outcomes), categorical (nominal groups), ordinal (ranked categories), or time_to_event (survival/event-time). Determines the appropriate statistical test method.' ;
    rdfs:domain ind:StatisticalEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:missingDataMethod rdf:type rdf:Property ;
    rdfs:label 'Missing Data Method' ;
    rdfs:comment 'Pre-specified method for handling missing data for this endpoint (e.g., \'Multiple Imputation\', \'Last Observation Carried Forward (LOCF)\', \'Baseline Observation Carried Forward (BOCF)\', \'Mixed Model for Repeated Measures (MMRM)\', \'Complete Case Analysis\'). Defined in the SAP per ICH E9(R1). [ENUM-REF-CANDIDATE: multiple_imputation|locf|bocf|mmrm|complete_case|worst_case — promote to reference product]' ;
    rdfs:domain ind:StatisticalEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiplicityTestingFamily rdf:type rdf:Property ;
    rdfs:label 'Multiplicity Testing Family' ;
    rdfs:comment 'Name or label of the multiplicity testing family or hierarchy to which this endpoint belongs (e.g., \'Primary Family\', \'Secondary Family 1\'). Used to group endpoints within a gatekeeping or hierarchical testing procedure defined in the SAP.' ;
    rdfs:domain ind:StatisticalEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nullHypothesis rdf:type rdf:Property ;
    rdfs:label 'Null Hypothesis' ;
    rdfs:comment 'Formal statement of the null hypothesis (H0) for this endpoint as specified in the SAP (e.g., \'There is no difference in overall survival between treatment and control arms\'). Required for confirmatory endpoints per ICH E9.' ;
    rdfs:domain ind:StatisticalEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDesignation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Designation' ;
    rdfs:comment 'Regulatory authority-specific designation of this endpoint indicating its role in submissions to FDA, EMA, or both. Enables endpoint-level traceability for multi-regional regulatory submissions (IND, NDA, BLA, MAA). [ENUM-REF-CANDIDATE: fda_primary|ema_primary|fda_secondary|ema_secondary|fda_exploratory|ema_exploratory|global — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalTestMethod rdf:type rdf:Property ;
    rdfs:label 'Statistical Test Method' ;
    rdfs:comment 'The primary statistical test or model used to analyze this endpoint (e.g., \'ANCOVA\', \'Log-rank test\', \'Cox proportional hazards model\', \'Mixed Model for Repeated Measures (MMRM)\', \'Wilcoxon rank-sum test\'). Specified in the SAP and implemented in SAS Drug Development. [ENUM-REF-CANDIDATE: ancova|log_rank|cox_ph|mmrm|wilcoxon|logistic_regression|cmh — promote to reference product]' ;
    rdfs:domain ind:StatisticalEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subgroupAnalysisFlag rdf:type rdf:Property ;
    rdfs:label 'Subgroup Analysis Flag' ;
    rdfs:comment 'Indicates whether pre-specified subgroup analyses are defined for this endpoint in the SAP (e.g., by age, sex, region, disease severity). True if subgroup analyses are planned; False otherwise. Relevant for FDA and EMA subgroup reporting requirements.' ;
    rdfs:domain ind:StatisticalEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testingSequenceOrder rdf:type rdf:Property ;
    rdfs:label 'Testing Sequence Order' ;
    rdfs:comment 'Numeric position of this endpoint within the pre-specified hierarchical or fixed-sequence testing procedure. Determines the order in which endpoints are tested to control Type I error. Lower values are tested first.' ;
    rdfs:domain ind:StatisticalEndpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tlfOutputId rdf:type rdf:Property ;
    rdfs:label 'Tlf Output Id' ;
    rdfs:comment 'Unique system-generated identifier for each produced TLF output instance. Serves as the primary key for the tlf_output data product within the biostatistics domain.' ;
    rdfs:domain ind:TlfOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financeBillingMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Finance Billing Milestone Id' ;
    rdfs:comment 'Foreign key linking to finance.finance_billing_milestone. Business justification: Final TLF package delivery is a contractual billing milestone in CRO agreements. Linking tlf_output to finance_billing_milestone allows finance to confirm deliverable completion before invoicing. Name' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceBillingMilestone .

ind:primaryTlfEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Tlf Employee Id' ;
    rdfs:comment 'Reference to the statistical programmer responsible for authoring the SAS program that produced this TLF output.' ;
    rdfs:domain ind:TlfOutput ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:datasetLockStatus rdf:type rdf:Property ;
    rdfs:label 'Dataset Lock Status' ;
    rdfs:comment 'Indicates whether this TLF output was produced from a pre-database lock (DBL), post-database lock, or interim analysis dataset. Critical for distinguishing final regulatory submission outputs from exploratory or interim analyses.' ;
    rdfs:domain ind:TlfOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:datasetVersion rdf:type rdf:Property ;
    rdfs:label 'Dataset Version' ;
    rdfs:comment 'Version label of the ADaM dataset used as input for this TLF production run (e.g., v1.0, v2.3-interim). Ensures traceability between the output and the exact data snapshot used, critical for database lock (DBL) compliance.' ;
    rdfs:domain ind:TlfOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'Date on which this TLF output was formally delivered to the sponsor, regulatory team, or CSR authoring team. Used for milestone tracking and contractual deliverable compliance.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discrepancyCount rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Count' ;
    rdfs:comment 'Total number of discrepancies identified between the primary programmer output and the QC programmer output during validation. A count of zero indicates a clean validation pass. Non-zero counts require resolution before final approval.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discrepancyResolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Resolution Notes' ;
    rdfs:comment 'Narrative description of how identified discrepancies between primary and QC programmer outputs were investigated and resolved. Required when discrepancy_count is greater than zero to support audit trail and regulatory inspection readiness.' ;
    rdfs:domain ind:TlfOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFinalVersion rdf:type rdf:Property ;
    rdfs:label 'Is Final Version' ;
    rdfs:comment 'Indicates whether this TLF output instance is the final approved version intended for inclusion in the Clinical Study Report (CSR) or regulatory submission. Only one version per output_number should have this flag set to True.' ;
    rdfs:domain ind:TlfOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outputCategory rdf:type rdf:Property ;
    rdfs:label 'Output Category' ;
    rdfs:comment 'Functional category of the TLF output indicating the statistical domain it covers (e.g., demographics, efficacy, safety, pharmacokinetics, laboratory). Used for organizing outputs within the CSR and regulatory submission. [ENUM-REF-CANDIDATE: demographics|efficacy|safety|pharmacokinetics|laboratory|vital_signs|exposure|disposition|concomitant_medications|other — promote to reference product]' ;
    rdfs:domain ind:Biostatistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputFileFormat rdf:type rdf:Property ;
    rdfs:label 'Output File Format' ;
    rdfs:comment 'File format of the produced TLF output (e.g., RTF for Word-compatible tables, PDF for final regulatory submissions, SAS7BDAT for dataset outputs). Determines compatibility with CSR authoring tools and eCTD submission requirements.' ;
    rdfs:domain ind:TlfOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputFileName rdf:type rdf:Property ;
    rdfs:label 'Output File Name' ;
    rdfs:comment 'Name of the output file generated by the SAS program (e.g., t_14_1_1_demog.rtf, l_16_2_3_ae.pdf). Used for file management, eTMF archival, and regulatory submission packaging.' ;
    rdfs:domain ind:Biostatistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputFilePath rdf:type rdf:Property ;
    rdfs:label 'Output File Path' ;
    rdfs:comment 'Full repository or file system path to the stored TLF output file in SAS Drug Development or the eTMF system. Enables direct retrieval for CSR authoring, regulatory review, and inspection readiness.' ;
    rdfs:domain ind:TlfOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputNumber rdf:type rdf:Property ;
    rdfs:label 'Output Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for this TLF output as defined in the SAP or TLF shell specification (e.g., T-14.1.1, L-16.2.3, F-11.4). Used for cross-referencing in the Clinical Study Report (CSR).' ;
    rdfs:domain ind:Biostatistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputTitle rdf:type rdf:Property ;
    rdfs:label 'Output Title' ;
    rdfs:comment 'Full descriptive title of the TLF output as it appears in the header of the produced document (e.g., \'Summary of Adverse Events by System Organ Class and Preferred Term — Safety Population\'). Used for CSR cross-referencing and regulatory submission.' ;
    rdfs:domain ind:Biostatistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputType rdf:type rdf:Property ;
    rdfs:label 'Output Type' ;
    rdfs:comment 'Classification of the statistical output as a Table (T), Listing (L), or Figure (F), corresponding to the three standard output categories in clinical trial reporting per ICH E3 and CDISC conventions.' ;
    rdfs:domain ind:Biostatistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputVersion rdf:type rdf:Property ;
    rdfs:label 'Output Version' ;
    rdfs:comment 'Version label of this TLF output instance (e.g., v1.0, v2.1, vFinal). Tracks the production history of the output across multiple runs, enabling identification of the current approved version versus superseded drafts.' ;
    rdfs:domain ind:TlfOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionEnvironment rdf:type rdf:Property ;
    rdfs:label 'Production Environment' ;
    rdfs:comment 'Environment in which this TLF output was generated: development (exploratory/testing), validation (UAT), or production (regulatory-grade). Only production-environment outputs are eligible for regulatory submission.' ;
    rdfs:domain ind:TlfOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Production Run Timestamp' ;
    rdfs:comment 'Date and time when the SAS program was executed to produce this TLF output instance. Serves as the principal business event timestamp for the production lifecycle, supporting ALCOA+ contemporaneous documentation requirements.' ;
    rdfs:domain ind:TlfOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qcCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qc Completion Timestamp' ;
    rdfs:comment 'Date and time when the QC validation process for this TLF output was completed and the qc_status was set to a terminal state (passed, failed, or waived). Supports milestone tracking and SLA compliance.' ;
    rdfs:domain ind:TlfOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Sequential run number for this TLF output, incremented each time the SAS program is executed for the same output_number. Enables tracking of the full production history from first run to final delivery.' ;
    rdfs:domain ind:TlfOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sasProgramPath rdf:type rdf:Property ;
    rdfs:label 'Sas Program Path' ;
    rdfs:comment 'Full file system or repository path to the SAS program in SAS Drug Development used to produce this TLF output. Supports traceability and regulatory inspection readiness.' ;
    rdfs:domain ind:TlfOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unblindingAuthorizationRef rdf:type rdf:Property ;
    rdfs:label 'Unblinding Authorization Ref' ;
    rdfs:comment 'Reference number or document identifier for the formal unblinding authorization (e.g., DSMB/DMC recommendation, sponsor authorization memo) that permitted production of this unblinded TLF output. Required for audit trail when blinding_status is \'unblinded\'.' ;
    rdfs:domain ind:TlfOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationMethod rdf:type rdf:Property ;
    rdfs:label 'Validation Method' ;
    rdfs:comment 'Method used to validate the accuracy of this TLF output. Double programming involves an independent programmer replicating the output from scratch; peer review involves a qualified reviewer checking the program and output without independent replication.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:armId rdf:type rdf:Property ;
    rdfs:label 'Arm Id' ;
    rdfs:comment 'Foreign key linking to study.study_arm. Business justification: TLF shells are authored for specific treatment arms (e.g., \'Treatment A 100mg vs. Placebo\'). tlf_shell.treatment_arm is a denormalized text field. A proper FK enables arm-level TLF completeness checks' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Arm .

ind:shellAuthorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Shell Author Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: TLF shell authorship must be traceable to a named, qualified statistician/programmer for regulatory submission and inspection readiness. Linking to workforce.employee enables GCP training and study as' ;
    rdfs:domain ind:TlfShell ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:abbreviations rdf:type rdf:Property ;
    rdfs:label 'Abbreviations' ;
    rdfs:comment 'List of abbreviations and their definitions used within this TLF output (e.g., \'SD=Standard Deviation; CI=Confidence Interval; n=number of subjects\'). Required for regulatory submission readability per ICH E3.' ;
    rdfs:domain ind:TlfShell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisVisit rdf:type rdf:Property ;
    rdfs:label 'Analysis Visit' ;
    rdfs:comment 'Study visit or visit window covered by this TLF output (e.g., Baseline, Week 12, End of Treatment, Follow-Up). Derived from the ADaM AVISIT variable and SAP visit schedule definition.' ;
    rdfs:domain ind:TlfShell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctcaeVersion rdf:type rdf:Property ;
    rdfs:label 'Ctcae Version' ;
    rdfs:comment 'Version of the CTCAE grading scale applied in this TLF output for adverse event severity classification (e.g., CTCAE v5.0). Applicable to safety tables and listings presenting AE/SAE data.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayFormat rdf:type rdf:Property ;
    rdfs:label 'Display Format' ;
    rdfs:comment 'File format in which the TLF output is delivered (e.g., RTF for CSR word processing, PDF for regulatory submission, SAS7BDAT for data review). Drives output generation settings in SAS Drug Development.' ;
    rdfs:domain ind:TlfShell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:footnotes rdf:type rdf:Property ;
    rdfs:label 'Footnotes' ;
    rdfs:comment 'Footnote text to be displayed beneath the TLF output in the CSR and submission package. Captures abbreviation definitions, statistical notes, data source qualifications, and population clarifications as specified in the SAP.' ;
    rdfs:domain ind:TlfShell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRegulatorySubmission rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Submission' ;
    rdfs:comment 'Indicates whether this TLF output is included in the regulatory submission package (NDA/BLA/MAA/eCTD). Submission outputs require additional QC validation and compliance with FDA/EMA/PMDA formatting standards.' ;
    rdfs:domain ind:TlfShell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locfFlag rdf:type rdf:Property ;
    rdfs:label 'Locf Flag' ;
    rdfs:comment 'Indicates whether the Last Observation Carried Forward (LOCF) imputation method is applied in this TLF output for handling missing data. Specified in the SAP missing data handling section.' ;
    rdfs:domain ind:TlfShell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meddraSoc rdf:type rdf:Property ;
    rdfs:label 'Meddra Soc' ;
    rdfs:comment 'MedDRA System Organ Class (SOC) associated with this TLF output when the output presents safety or adverse event data. Enables standardized safety reporting alignment with MedDRA coding hierarchy.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orientation rdf:type rdf:Property ;
    rdfs:label 'Orientation' ;
    rdfs:comment 'Page orientation for the TLF output display (portrait or landscape). Determined by the number of columns and display width requirements; specified in the TLF shell for SAS programmer implementation.' ;
    rdfs:domain ind:TlfShell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputFinalizedDate rdf:type rdf:Property ;
    rdfs:label 'Output Finalized Date' ;
    rdfs:comment 'Date on which the TLF output was finalized and locked for inclusion in the CSR or regulatory submission. Aligns with the Database Lock (DBL) milestone and submission timeline.' ;
    rdfs:domain ind:TlfShell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pageSize rdf:type rdf:Property ;
    rdfs:label 'Page Size' ;
    rdfs:comment 'Paper size specification for the TLF output (A4 for EMA/MHRA/TGA submissions; Letter for FDA submissions). Ensures regulatory submission formatting compliance across jurisdictions.' ;
    rdfs:domain ind:TlfShell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityTier rdf:type rdf:Property ;
    rdfs:label 'Priority Tier' ;
    rdfs:comment 'Programming priority classification for this TLF output (Tier 1=primary efficacy/safety outputs required for DBL; Tier 2=secondary outputs; Tier 3=supportive/exploratory outputs). Drives resource allocation and delivery scheduling.' ;
    rdfs:domain ind:TlfShell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionStatus rdf:type rdf:Property ;
    rdfs:label 'Production Status' ;
    rdfs:comment 'Current lifecycle state of the TLF shell and its associated program in the production workflow. Tracks progression from initial shell authoring through QC review to final approved output for CSR inclusion.' ;
    rdfs:domain ind:TlfShell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Program Delivery Date' ;
    rdfs:comment 'Planned or actual date by which the SAS program producing this TLF output is scheduled to be delivered for QC review. Used for project milestone tracking and CSR timeline management.' ;
    rdfs:domain ind:TlfShell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Name of the SAS program file responsible for producing this TLF output (e.g., t_14_1_demog.sas). Used as the SSOT for program-to-output traceability in SAS Drug Development and the TLF catalog.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programPath rdf:type rdf:Property ;
    rdfs:label 'Program Path' ;
    rdfs:comment 'Full directory path to the SAS program file within the study programming environment (e.g., /studies/STUDY001/programs/tables/). Enables automated program execution and audit trail in SAS Drug Development.' ;
    rdfs:domain ind:TlfShell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcReviewer rdf:type rdf:Property ;
    rdfs:label 'Qc Reviewer' ;
    rdfs:comment 'Name or user identifier of the independent QC reviewer who validated the TLF shell specification and/or the produced output. Supports double-programming QC traceability per CDISC and GCP standards.' ;
    rdfs:domain ind:TlfShell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shellApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Shell Approved Date' ;
    rdfs:comment 'Date on which the TLF shell specification was formally approved for programming. Marks the transition from specification to active development in the TLF production lifecycle.' ;
    rdfs:domain ind:TlfShell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shellCreatedDate rdf:type rdf:Property ;
    rdfs:label 'Shell Created Date' ;
    rdfs:comment 'Date on which the TLF shell specification was first created in the system. Establishes the start of the output lifecycle for audit and project tracking purposes.' ;
    rdfs:domain ind:TlfShell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shellNotes rdf:type rdf:Property ;
    rdfs:label 'Shell Notes' ;
    rdfs:comment 'Free-text notes and instructions from the biostatistician to the SAS programmer regarding special handling, display requirements, or clarifications for this TLF output. Not displayed in the final output.' ;
    rdfs:domain ind:TlfShell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shellVersion rdf:type rdf:Property ;
    rdfs:label 'Shell Version' ;
    rdfs:comment 'Version identifier of the TLF shell specification (e.g., v1.0, v2.1). Tracks revisions to the shell driven by SAP amendments, protocol changes, or QC feedback. Enables version-controlled traceability.' ;
    rdfs:domain ind:TlfShell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistTemplateId rdf:type rdf:Property ;
    rdfs:label 'Checklist Template Id' ;
    rdfs:comment 'Reference to the standardized audit checklist template used during fieldwork, as configured in MasterControl. Templates are type-specific (site GCP, vendor, system) and version-controlled per SOP requirements.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Template .

ind:followUpAuditId rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Id' ;
    rdfs:comment 'Reference to the subsequent follow-up audit record created to verify CAPA effectiveness. Populated when follow_up_required is True and the follow-up audit has been scheduled or completed.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:masterAgreementId rdf:type rdf:Property ;
    rdfs:label 'Master Agreement Id' ;
    rdfs:comment 'Foreign key linking to sponsor.master_agreement. Business justification: GCP audits of CRO operations are scoped to the master agreement governing the sponsor-CRO relationship. Quality teams track audit outcomes per preferred provider agreement to assess contractual compli' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MasterAgreement .

ind:sponsorEngagementId rdf:type rdf:Property ;
    rdfs:label 'Sponsor Engagement Id' ;
    rdfs:comment 'Foreign key linking to sponsor.engagement. Business justification: Audits are conducted within the context of a sponsor engagement. Account managers use audit outcomes to update relationship health scores and report quality performance to sponsors during governance r' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SponsorEngagement .

ind:vendorOrganizationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Organization Id' ;
    rdfs:comment 'Reference to the external vendor or CRO subject to this audit. Populated for vendor-type audits; nullable for site, system, or process audits.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organization .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'Calendar date on which audit fieldwork actually concluded. Used to compute actual audit duration and assess deviation from planned schedule.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Calendar date on which audit fieldwork actually commenced. Compared against planned_start_date to measure schedule adherence and audit program performance.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditCategory rdf:type rdf:Property ;
    rdfs:label 'Audit Category' ;
    rdfs:comment 'Categorization of the audit by initiating party and trigger: internal (self-initiated QA), external (sponsor or third-party), regulatory_inspection (FDA/EMA/MHRA inspector-led), for_cause (triggered by specific concern or signal), or routine (scheduled per audit plan).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Externally-known, human-readable unique audit reference number assigned by MasterControl at audit creation (e.g., AUD-2024-00123). Used in regulatory correspondence, CAPA linkage, and TMF filing.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Narrative description of the audit scope, defining the boundaries, processes, systems, or study activities subject to evaluation. Documented in the audit plan and referenced throughout the audit lifecycle.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle state of the audit record within MasterControl: planned (scheduled, not yet started), in_progress (fieldwork underway), completed (report issued), cancelled (audit withdrawn), or on_hold (paused pending resolution).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit by the subject being evaluated: system (EDC, CTMS, safety systems), process (SOPs, workflows), vendor (CRO, lab, IRT), site (investigational site GCP), or TMF (Trial Master File completeness). Drives audit planning templates and checklist selection in MasterControl.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditeeCountry rdf:type rdf:Property ;
    rdfs:label 'Auditee Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the auditee location. Used for geographic risk stratification, regulatory jurisdiction determination, and cross-border audit planning.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditeeName rdf:type rdf:Property ;
    rdfs:label 'Auditee Name' ;
    rdfs:comment 'Name of the organization, department, site, or system being audited. Provides a human-readable identifier for the audit subject independent of system IDs, supporting audit register reporting.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaDueDate rdf:type rdf:Property ;
    rdfs:label 'Capa Due Date' ;
    rdfs:comment 'Deadline by which the auditee must submit a Corrective and Preventive Action (CAPA) plan in response to audit findings. Calculated from report_issue_date per sponsor or regulatory requirements.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaRequired rdf:type rdf:Property ;
    rdfs:label 'Capa Required' ;
    rdfs:comment 'Indicates whether a formal CAPA plan is required as a result of this audit. Set to True when critical or major findings are identified. Triggers CAPA workflow initiation in MasterControl.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalFindingCount rdf:type rdf:Property ;
    rdfs:label 'Critical Finding Count' ;
    rdfs:comment 'Number of critical GCP findings identified during the audit. Critical findings indicate conditions that may directly impact subject safety, data integrity, or regulatory compliance and require immediate CAPA. Sourced from MasterControl finding records.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followUpRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required' ;
    rdfs:comment 'Indicates whether a follow-up audit has been determined necessary to verify CAPA effectiveness or re-assess compliance after an unsatisfactory or needs_improvement outcome.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gcpStandardVersion rdf:type rdf:Property ;
    rdfs:label 'Gcp Standard Version' ;
    rdfs:comment 'Version of the ICH GCP guideline applied during this audit (e.g., ICH E6(R2), ICH E6(R3)). Ensures traceability of the regulatory standard in force at the time of audit execution.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'Classification of regulatory inspection by trigger: routine (scheduled surveillance), for_cause (triggered by safety signal or complaint), pre_approval (NDA/BLA/MAA submission review), or post_approval (post-marketing commitment). Populated only for regulatory_inspection category audits.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'Modality of audit execution: on_site (auditor physically present at auditee location), remote (conducted via video conference and electronic document review), or hybrid (combination of both). Relevant for resource planning and post-COVID audit program management.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorFindingCount rdf:type rdf:Property ;
    rdfs:label 'Major Finding Count' ;
    rdfs:comment 'Number of major GCP findings identified during the audit. Major findings represent significant non-compliance that could affect subject rights, safety, or data reliability but are not immediately life-threatening.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorFindingCount rdf:type rdf:Property ;
    rdfs:label 'Minor Finding Count' ;
    rdfs:comment 'Number of minor GCP findings identified during the audit. Minor findings represent isolated deviations that do not significantly impact subject safety or data integrity but require corrective action.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:observationCount rdf:type rdf:Property ;
    rdfs:label 'Observation Count' ;
    rdfs:comment 'Number of audit observations (non-findings) documented during the audit. Observations are areas for improvement that do not constitute formal GCP non-compliance but are noted for quality enhancement.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Overall quality determination issued at audit close: satisfactory (no significant findings), needs_improvement (minor findings requiring corrective action), or unsatisfactory (critical/major findings indicating systemic GCP non-compliance). Drives CAPA initiation and escalation decisions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version identifier of the audit plan document used to conduct this audit (e.g., v1.0, v2.1). Supports document control traceability and links to the approved audit plan in Veeva Vault eTMF.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Scheduled calendar date on which audit fieldwork is planned to conclude. Used to calculate planned audit duration and monitor schedule adherence.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Scheduled calendar date on which audit fieldwork is planned to commence, as documented in the annual audit plan or risk-based audit schedule. Used for resource planning and audit readiness tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportIssueDate rdf:type rdf:Property ;
    rdfs:label 'Report Issue Date' ;
    rdfs:comment 'Date on which the final audit report was formally issued to the auditee and sponsor. Triggers the CAPA response timeline and is a key metric for audit cycle time KPIs.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskPriorityScore rdf:type rdf:Property ;
    rdfs:label 'Risk Priority Score' ;
    rdfs:comment 'Numeric risk prioritization score (typically 1–100) calculated from risk factors such as subject safety criticality, protocol complexity, site performance history, and time since last audit. Drives risk-based audit scheduling per ICH E6(R2) R2 addendum requirements.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskTier rdf:type rdf:Property ;
    rdfs:label 'Risk Tier' ;
    rdfs:comment 'Categorical risk classification derived from risk_priority_score: critical, high, medium, or low. Used for audit frequency determination, resource allocation, and escalation thresholds in the quality management system.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:summary rdf:type rdf:Property ;
    rdfs:label 'Summary' ;
    rdfs:comment 'Executive summary narrative of the audit outcome, key findings, and overall GCP compliance assessment as documented in the final audit report. Supports audit readiness reviews and regulatory inspection preparation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmfReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Tmf Reference Number' ;
    rdfs:comment 'Document reference number assigned to the audit report and supporting documentation filed in the eTMF (Veeva Vault). Enables direct retrieval of audit artifacts during regulatory inspections per DIA TMF Reference Model.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Auditor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: GCP audit finding reports must identify the qualified internal auditor who raised each finding for regulatory inspection readiness and accountability. \'auditor_name\' is a denormalized plain-text field' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:complianceCapaId rdf:type rdf:Property ;
    rdfs:label 'Compliance Capa Id' ;
    rdfs:comment 'Reference to the CAPA record triggered by this finding, if applicable. A finding may initiate a formal CAPA lifecycle in MasterControl.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceCapa .

ind:deviationClassificationId rdf:type rdf:Property ;
    rdfs:label 'Deviation Classification Id' ;
    rdfs:comment 'Foreign key linking to compliance.deviation_classification. Business justification: audit_finding.protocol_deviation_classification is a free-text string that should reference the standardized deviation_classification taxonomy. Adding a FK to deviation_classification.compliance_devia' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviationClassification .

ind:auditReportReference rdf:type rdf:Property ;
    rdfs:label 'Audit Report Reference' ;
    rdfs:comment 'Document identifier or version reference of the formal audit report in which this finding was published. Links the finding to the official audit report stored in Veeva Vault eTMF.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditeeRole rdf:type rdf:Property ;
    rdfs:label 'Auditee Role' ;
    rdfs:comment 'Professional role or function of the auditee (e.g., Principal Investigator, Clinical Research Coordinator, Data Manager, Sponsor Representative). Supports workforce quality analytics.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorOrganization rdf:type rdf:Property ;
    rdfs:label 'Auditor Organization' ;
    rdfs:comment 'Name of the organization to which the auditor belongs (e.g., internal QA department, sponsor QA team, third-party audit firm). Distinguishes internal from external audit sources.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Capa Required Flag' ;
    rdfs:comment 'Indicates whether this finding mandates the initiation of a formal CAPA process. Critical and major findings typically require CAPA; minor findings and observations may not.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'The date on which the QA team formally verified and closed the finding after confirming that the corrective action was implemented and effective. Null if the finding remains open.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataIntegrityImpact rdf:type rdf:Property ;
    rdfs:label 'Data Integrity Impact' ;
    rdfs:comment 'Assessment of whether the finding has a confirmed, potential, or no impact on clinical trial data integrity. Relevant to ALCOA+ principles and regulatory submission reliability.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingCategory rdf:type rdf:Property ;
    rdfs:label 'Finding Category' ;
    rdfs:comment 'Severity classification of the finding per GCP audit standards. Critical: systemic failure with patient safety or data integrity risk. Major: significant GCP deviation. Minor: low-risk procedural gap. Observation: noted for improvement without formal deviation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDescription rdf:type rdf:Property ;
    rdfs:label 'Finding Description' ;
    rdfs:comment 'Detailed narrative of the finding as documented by the auditor. Describes the observed deficiency, evidence reviewed, and the specific GCP or regulatory requirement that was not met.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned to the finding at the time of audit. Used in audit reports, management responses, and CAPA tracking. Format: AF-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingStatus rdf:type rdf:Property ;
    rdfs:label 'Finding Status' ;
    rdfs:comment 'Current lifecycle state of the finding within the quality management workflow. Tracks progression from identification through resolution and closure verification.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingTitle rdf:type rdf:Property ;
    rdfs:label 'Finding Title' ;
    rdfs:comment 'Short, human-readable title summarizing the nature of the finding. Used in audit reports, dashboards, and management communications.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ichGcpClauseReference rdf:type rdf:Property ;
    rdfs:label 'Ich Gcp Clause Reference' ;
    rdfs:comment 'Specific clause or section of the ICH E6(R2) GCP guideline that was violated or is relevant to this finding (e.g., \'5.18.4\', \'4.9.0\'). Enables regulatory traceability and trend analysis by GCP requirement.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'The calendar date on which the finding was formally identified and documented during the audit. Represents the principal real-world event date for this transaction record.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implicatedSystem rdf:type rdf:Property ;
    rdfs:label 'Implicated System' ;
    rdfs:comment 'Name of the operational system or application implicated in the finding (e.g., Medidata Rave, Oracle Argus Safety, Veeva Vault, MasterControl). Relevant for system-level findings distinct from site-level findings.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementResponse rdf:type rdf:Property ;
    rdfs:label 'Management Response' ;
    rdfs:comment 'Full text of the auditee\'s formal management response to the finding, including root cause analysis, proposed corrective actions, and preventive measures. Captured verbatim from MasterControl.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientSafetyImpact rdf:type rdf:Property ;
    rdfs:label 'Patient Safety Impact' ;
    rdfs:comment 'Assessment of whether the finding has a confirmed, potential, or no impact on patient safety. Critical for risk-based quality management and escalation decisions.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorFindingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Prior Finding Reference Number' ;
    rdfs:comment 'Reference number of the previously identified finding that this record repeats, if repeat_finding_flag is True. Enables lineage tracking of recurring quality issues.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processArea rdf:type rdf:Property ;
    rdfs:label 'Process Area' ;
    rdfs:comment 'The clinical trial business process area implicated by the finding (e.g., Informed Consent Management, Adverse Event Reporting, Source Data Verification, Randomization, Drug Accountability). Enables process-level quality trending. [ENUM-REF-CANDIDATE: informed_consent|adverse_event_reporting|source_data_verification|randomization|drug_accountability|protocol_deviation|data_management|site_monitoring|regulatory_submission|training_compliance — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaReviewerComment rdf:type rdf:Property ;
    rdfs:label 'Qa Reviewer Comment' ;
    rdfs:comment 'QA reviewer\'s assessment of the adequacy of the management response and corrective action. Documents acceptance, rejection, or request for additional information during the closure review cycle.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCitation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Citation' ;
    rdfs:comment 'Specific regulatory citation from applicable authority (e.g., FDA 21 CFR Part 312.62, EMA Directive 2001/20/EC, EU CTR 536/2014 Article 58) that underpins the finding. Supports regulatory inspection readiness.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatFindingFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Finding Flag' ;
    rdfs:comment 'Indicates whether this finding is a recurrence of a previously identified and closed finding at the same site, system, or process area. True signals potential systemic quality failure and escalation risk.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'The contractual or procedurally mandated deadline by which the auditee must submit a formal management response to the finding. Typically 14–30 days post-audit report issuance per SOP.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Response Received Date' ;
    rdfs:comment 'The actual date on which the auditee\'s formal management response was received by the QA team. Used to calculate response timeliness and SLA compliance.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'Categorized root cause of the finding as determined during root cause analysis (e.g., training gap, process failure, system error, resource constraint, communication breakdown). Enables systemic quality trend analysis. [ENUM-REF-CANDIDATE: training_gap|process_failure|system_error|resource_constraint|communication_breakdown|documentation_failure|oversight_gap — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopVersion rdf:type rdf:Property ;
    rdfs:label 'Sop Version' ;
    rdfs:comment 'Version number of the SOP in effect at the time the finding was identified. Critical for determining whether the deviation was against a current or superseded procedure.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectCountAffected rdf:type rdf:Property ;
    rdfs:label 'Subject Count Affected' ;
    rdfs:comment 'Number of study subjects potentially affected by the finding. Used to assess the scope and patient safety impact of the deficiency. Zero for system or process findings with no direct subject impact.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetClosureDate rdf:type rdf:Property ;
    rdfs:label 'Target Closure Date' ;
    rdfs:comment 'The planned date by which the finding is expected to be fully resolved and closed, as agreed between the QA team and the auditee. Distinct from response_due_date which covers only the management response.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used by the QA team to verify that the corrective action for this finding was effectively implemented prior to closure (e.g., document review, on-site visit, remote review, interview, system audit).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceInspectionId rdf:type rdf:Property ;
    rdfs:label 'Compliance Inspection Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_inspection. Business justification: A CAPA can be initiated directly from a regulatory inspection (source_type=\'inspection\'). While inspection_finding->compliance_capa links findings to CAPAs, a CAPA may also reference the inspection it' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceInspection .

ind:primaryComplianceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Compliance Employee Id' ;
    rdfs:comment 'Identifier of the staff member or role accountable for executing and closing the CAPA. Maps to the workforce record in Workday HCM. Drives task assignment and escalation notifications.' ;
    rdfs:domain ind:ComplianceCapa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryComplianceResponsibleOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Compliance Responsible Owner Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:ComplianceCapa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryComplianceApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Compliance Approved By Employee Id' ;
    rdfs:comment 'Identifier of the QA manager or authorized approver who reviewed and approved the CAPA plan in MasterControl. Required for GCP compliance and electronic signature audit trail per 21 CFR Part 11.' ;
    rdfs:domain ind:ComplianceCapa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:trainingCurriculumId rdf:type rdf:Property ;
    rdfs:label 'Training Curriculum Id' ;
    rdfs:comment 'Foreign key linking to workforce.training_curriculum. Business justification: CAPAs with training_required_flag=true must specify the exact training curriculum assigned as corrective/preventive action. This link supports QMS-to-LMS integration, CAPA effectiveness checks, and GC' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingCurriculum .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Actual calendar date on which all corrective and preventive actions were completed and verified. Null until CAPA is closed. Used to calculate cycle time and on-time closure rate KPIs.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaType rdf:type rdf:Property ;
    rdfs:label 'Capa Type' ;
    rdfs:comment 'Indicates whether the action is corrective (addressing an existing non-conformance), preventive (addressing a potential non-conformance), or both. Drives workflow routing in MasterControl.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureJustification rdf:type rdf:Property ;
    rdfs:label 'Closure Justification' ;
    rdfs:comment 'Narrative justification provided by the responsible owner and QA approver at the time of CAPA closure, summarizing evidence that all actions were completed and the root cause was resolved. Required for regulatory inspection readiness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCapaStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Capa Status' ;
    rdfs:comment 'Current lifecycle state of the CAPA record. Drives workflow routing, escalation triggers, and regulatory reporting. \'Overdue\' is system-set when target completion date is passed without closure.' ;
    rdfs:domain ind:ComplianceCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Detailed description of the corrective actions planned or implemented to address the identified root cause and prevent recurrence of the quality issue. Core CAPA deliverable per GCP requirements.' ;
    rdfs:domain ind:ComplianceCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataIntegrityImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Data Integrity Impact Flag' ;
    rdfs:comment 'Indicates whether the quality issue underlying this CAPA had or could have had an impact on clinical data integrity. Triggers data review, potential database query, and regulatory notification workflows.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectivenessCheckDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Date' ;
    rdfs:comment 'Planned or actual date on which the effectiveness of the implemented corrective and preventive actions will be or was verified. Required by GCP to confirm the CAPA resolved the root cause.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessCheckDescription rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Description' ;
    rdfs:comment 'Narrative description of the methodology and findings from the effectiveness check, including evidence reviewed and conclusions drawn. Supports regulatory inspection readiness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessCheckResult rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Result' ;
    rdfs:comment 'Outcome of the effectiveness verification assessment confirming whether the implemented CAPA actions successfully resolved the root cause and prevented recurrence. Drives CAPA closure or re-opening decisions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gcpImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Gcp Impact Assessment' ;
    rdfs:comment 'Assessment of the impact of the underlying quality issue on GCP compliance and data integrity. Drives CAPA priority, escalation, and regulatory reporting decisions. Aligned with FDA and EMA GCP inspection classification standards.' ;
    rdfs:domain ind:ComplianceCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateActionTaken rdf:type rdf:Property ;
    rdfs:label 'Immediate Action Taken' ;
    rdfs:comment 'Description of any immediate containment or interim actions taken at the time of CAPA initiation to mitigate the impact of the quality issue before the full corrective action is implemented.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mastercontrolRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Mastercontrol Record Number' ;
    rdfs:comment 'Native record identifier assigned by the MasterControl CAPA module. Used for source system traceability, data lineage, and reconciliation between the lakehouse silver layer and the operational system of record.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Plan' ;
    rdfs:comment 'Detailed description of the preventive actions planned to eliminate the potential for recurrence of similar quality issues across the organization or study portfolio.' ;
    rdfs:domain ind:ComplianceCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:problemDescription rdf:type rdf:Property ;
    rdfs:label 'Problem Description' ;
    rdfs:comment 'Detailed description of the quality issue, non-conformance, or finding that triggered the CAPA. Captures the \'what happened\' narrative for audit trail and regulatory inspection purposes.' ;
    rdfs:domain ind:ComplianceCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Indicates whether this CAPA addresses a recurring quality issue that has been the subject of a prior CAPA. True signals a systemic quality problem requiring escalated management attention.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'Externally-known, human-readable CAPA reference number assigned by MasterControl upon initiation (e.g., CAPA-2024-00123). Used in audit trails, regulatory submissions, and sponsor communications.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable Flag' ;
    rdfs:comment 'Indicates whether this CAPA is associated with a finding that requires regulatory reporting to FDA, EMA, MHRA, or other health authority. Drives regulatory submission workflow in Veeva Vault.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Organizational department or functional area accountable for CAPA execution (e.g., Clinical Operations, Data Management, Regulatory Affairs, Quality Assurance). Used for departmental quality KPI reporting.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed narrative describing the identified root cause of the quality issue, as determined through root cause analysis (RCA). Supports regulatory inspection readiness and CAPA justification.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Source Reference Code' ;
    rdfs:comment 'Identifier of the originating record that triggered this CAPA (e.g., audit finding ID, inspection finding ID, protocol deviation ID, or QC failure ID). Enables traceability back to the root triggering event.' ;
    rdfs:domain ind:ComplianceCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Category of the triggering event that initiated the CAPA. Classifies whether the CAPA originated from an internal audit, regulatory inspection, protocol deviation, QC failure, self-identified quality issue, complaint, or safety signal. [ENUM-REF-CANDIDATE: audit_finding|inspection_finding|protocol_deviation|qc_failure|self_identified|complaint|safety_signal — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Sponsor Notified Flag' ;
    rdfs:comment 'Indicates whether the study sponsor has been formally notified of this CAPA. Required for CRO-managed studies where sponsor oversight obligations apply per ICH E6(R2) GCP.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subjectSafetyImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Subject Safety Impact Flag' ;
    rdfs:comment 'Indicates whether the quality issue underlying this CAPA had or could have had a direct impact on subject safety. Triggers expedited review and potential safety reporting obligations.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned date by which all corrective and preventive actions must be completed and the CAPA closed. Used for overdue status calculation, escalation triggers, and sponsor/regulatory reporting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Required Flag' ;
    rdfs:comment 'Indicates whether the corrective or preventive action includes a mandatory training component. When True, triggers training assignment workflow in MasterControl training management module.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capaActionItemId rdf:type rdf:Property ;
    rdfs:label 'Capa Action Item Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual action item within a CAPA plan. Primary key for this transactional line record. Entity role: TRANSACTION_LINE — each action item is a discrete line within a parent CAPA plan header, with its own owner, due date, and completion lifecycle.' ;
    rdfs:domain ind:CapaActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCapaEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Capa Employee Id' ;
    rdfs:comment 'Reference to the individual (employee or contractor) responsible for executing and completing this action item. Serves as the PARTY_REFERENCE for this TRANSACTION_LINE entity. Accountability is tracked at the action item level to enable granular CAPA execution monitoring.' ;
    rdfs:domain ind:CapaActionItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryCapaAssignedOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Capa Assigned Owner Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:CapaActionItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryCapaEscalatedToEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Capa Escalated To Employee Id' ;
    rdfs:comment 'Reference to the senior manager or QA leader to whom this action item has been escalated. Null if escalation_flag is False. Enables accountability tracking and escalation resolution reporting.' ;
    rdfs:domain ind:CapaActionItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionItemNumber rdf:type rdf:Property ;
    rdfs:label 'Action Item Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for this action item within MasterControl (e.g., CAPA-AI-2024-0042). Used in audit trails, regulatory inspection responses, and cross-system references. Serves as the BUSINESS_IDENTIFIER for this line record.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionItemStatus rdf:type rdf:Property ;
    rdfs:label 'Action Item Status' ;
    rdfs:comment 'Current workflow state of the action item within the CAPA execution lifecycle. Drives CAPA closure eligibility — all action items must reach \'completed\' or \'cancelled\' before the parent CAPA can be closed. Serves as the LIFECYCLE_STATUS for this entity. [ENUM-REF-CANDIDATE: open|in_progress|completed|overdue|cancelled|on_hold — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionItemType rdf:type rdf:Property ;
    rdfs:label 'Action Item Type' ;
    rdfs:comment 'Classification of the action item by its nature within the CAPA framework: corrective (addresses the identified nonconformance), preventive (prevents recurrence), effectiveness check (verifies the CAPA resolved the issue), root cause analysis, training, process change, or documentation update. [ENUM-REF-CANDIDATE: corrective|preventive|effectiveness_check|root_cause_analysis|training|process_change|documentation_update — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedOwnerDepartment rdf:type rdf:Property ;
    rdfs:label 'Assigned Owner Department' ;
    rdfs:comment 'Organizational department or functional unit of the assigned owner (e.g., Quality Assurance, Data Management, Clinical Operations). Used for workload analysis, departmental CAPA metrics, and escalation routing.' ;
    rdfs:domain ind:CapaActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaActionItemDescription rdf:type rdf:Property ;
    rdfs:label 'Capa Action Item Description' ;
    rdfs:comment 'Detailed narrative describing the specific action to be taken, including scope, methodology, and expected outcome. Provides the full context required for the assigned owner to execute the action and for auditors to assess adequacy of the response.' ;
    rdfs:domain ind:CapaActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Timestamp when this action item was formally closed in MasterControl following successful completion and verification. Null until the item reaches a terminal state (completed or cancelled). Used to calculate cycle time metrics.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:daysOpen rdf:type rdf:Property ;
    rdfs:label 'Days Open' ;
    rdfs:comment 'Number of calendar days this action item has been open, calculated from opened_timestamp to either actual_completion_date (if closed) or the current date (if still open). Used as a KPI for CAPA execution timeliness and audit readiness dashboards. Note: this is a business-captured operational metric from MasterControl, not a derived aggregate.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dueDateExtensionCount rdf:type rdf:Property ;
    rdfs:label 'Due Date Extension Count' ;
    rdfs:comment 'Number of times the planned completion date has been extended for this action item. A high extension count is a quality risk indicator and may trigger escalation or QA review. Tracked per MasterControl audit trail requirements.' ;
    rdfs:domain ind:CapaActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectivenessCheckDueDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Due Date' ;
    rdfs:comment 'Target date by which the effectiveness check for this action item must be completed. Null if effectiveness_check_required is False. Used to schedule and track post-implementation reviews.' ;
    rdfs:domain ind:CapaActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Required' ;
    rdfs:comment 'Indicates whether a post-completion effectiveness check is required for this action item to confirm the corrective or preventive action achieved its intended outcome. Typically mandated for critical or repeat findings per GCP quality standards.' ;
    rdfs:domain ind:CapaActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectivenessCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Status' ;
    rdfs:comment 'Current status of the post-completion effectiveness check for this action item. \'Effective\' confirms the action resolved the root cause; \'ineffective\' triggers re-opening of the CAPA or creation of a new CAPA.' ;
    rdfs:domain ind:CapaActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Document Reference' ;
    rdfs:comment 'Reference identifier or URL to the supporting evidence document stored in Veeva Vault or MasterControl (e.g., document ID, eTMF reference, SOP version number). Links the action item completion to the formal document management system.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionJustification rdf:type rdf:Property ;
    rdfs:label 'Extension Justification' ;
    rdfs:comment 'Narrative explanation provided by the action item owner or QA approver when the planned completion date is extended. Required for audit trail completeness and regulatory inspection readiness. Null if no extension has been granted.' ;
    rdfs:domain ind:CapaActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opened Timestamp' ;
    rdfs:comment 'Timestamp when this action item was formally opened and assigned to an owner. Serves as the BUSINESS_EVENT_TIMESTAMP for this TRANSACTION_LINE entity. Distinct from created_timestamp, which reflects system record creation.' ;
    rdfs:domain ind:CapaActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Date' ;
    rdfs:comment 'Target date by which the action item is expected to be completed, as agreed upon during CAPA planning. Used to calculate overdue status, track CAPA execution timeliness, and report on compliance with committed timelines to sponsors and regulatory bodies.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryCommitment rdf:type rdf:Property ;
    rdfs:label 'Regulatory Commitment' ;
    rdfs:comment 'Indicates whether this action item represents a formal commitment made to a regulatory authority (FDA, EMA, MHRA, etc.) during an inspection or in a regulatory submission response. Regulatory commitment items are subject to heightened monitoring and escalation.' ;
    rdfs:domain ind:CapaActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Ordinal position of this action item within the parent CAPA plan (e.g., 1, 2, 3). Enables ordered display and reporting of action items within a CAPA. Serves as the LINE_SEQUENCE for this TRANSACTION_LINE entity.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceFindingReference rdf:type rdf:Property ;
    rdfs:label 'Source Finding Reference' ;
    rdfs:comment 'Reference identifier of the specific audit finding, inspection observation, protocol deviation, or nonconformance that this action item directly addresses (e.g., audit finding number, deviation ID). Provides traceability from action item back to the originating quality event.' ;
    rdfs:domain ind:CapaActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'Date on which all required training associated with this action item was completed and documented in MasterControl. Null if training_required is False or training has not yet been completed. Required as part of completion evidence.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingRequired rdf:type rdf:Property ;
    rdfs:label 'Training Required' ;
    rdfs:comment 'Indicates whether completion of this action item requires associated staff training (e.g., training on a revised SOP). When True, training completion records in MasterControl must be linked as evidence before the action item can be verified.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationComments rdf:type rdf:Property ;
    rdfs:label 'Verification Comments' ;
    rdfs:comment 'Free-text comments entered by the QA verifier during the evidence review, including rationale for rejection or conditions for acceptance. Provides the audit trail narrative required for regulatory inspection readiness.' ;
    rdfs:domain ind:CapaActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date on which the QA verifier confirmed the completion evidence was adequate and the action item was satisfactorily executed. Null until verification is completed. Required for regulatory inspection audit trail.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationOutcome rdf:type rdf:Property ;
    rdfs:label 'Verification Outcome' ;
    rdfs:comment 'Result of the QA verification review of the action item completion evidence. \'Accepted\' closes the verification loop; \'rejected\' returns the item to the owner for rework; \'pending_revision\' indicates partial acceptance with required amendments.' ;
    rdfs:domain ind:CapaActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationRequired rdf:type rdf:Property ;
    rdfs:label 'Verification Required' ;
    rdfs:comment 'Indicates whether independent QA verification of completion evidence is required before this action item can be marked as completed. True for high-risk or critical action items per the CAPA procedure. Drives the QA review workflow in MasterControl.' ;
    rdfs:domain ind:CapaActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:continuingReviewId rdf:type rdf:Property ;
    rdfs:label 'Continuing Review Id' ;
    rdfs:comment 'Unique surrogate identifier for each continuing review record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:ContinuingReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentIcfVersionId rdf:type rdf:Property ;
    rdfs:label 'Document Icf Version Id' ;
    rdfs:comment 'Foreign key linking to document.document_icf_version. Business justification: Continuing review assesses whether the current ICF version remains adequate for ongoing subject protection. ICH E6 requires traceability from continuing review to the specific ICF version in use. Repl' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocumentIcfVersion .

ind:ethicsCommitteeId rdf:type rdf:Property ;
    rdfs:label 'Ethics Committee Id' ;
    rdfs:comment 'Reference to the IRB or IEC responsible for conducting this continuing review and granting approval.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EthicsCommittee .

ind:approvalExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Approval Expiry Date' ;
    rdfs:comment 'Date on which the IRB/IEC approval granted by this continuing review expires. Study activities must cease or a new continuing review must be approved before this date.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalStartDate rdf:type rdf:Property ;
    rdfs:label 'Approval Start Date' ;
    rdfs:comment 'Date from which the IRB/IEC approval granted by this continuing review becomes effective, authorizing continued conduct of the study.' ;
    rdfs:domain ind:ContinuingReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completedSubjectCount rdf:type rdf:Property ;
    rdfs:label 'Completed Subject Count' ;
    rdfs:comment 'Number of subjects who have completed all study procedures as of the continuing review submission date.' ;
    rdfs:domain ind:ContinuingReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conditionsOfApproval rdf:type rdf:Property ;
    rdfs:label 'Conditions Of Approval' ;
    rdfs:comment 'Narrative description of any conditions, stipulations, or modifications required by the IRB/IEC as part of an approval with conditions decision. Null if unconditional approval.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'Date on which the IRB/IEC issued its formal decision (approval, deferral, disapproval, or suspension) for this continuing review.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disapprovalReason rdf:type rdf:Property ;
    rdfs:label 'Disapproval Reason' ;
    rdfs:comment 'Narrative explanation provided by the IRB/IEC for a disapproval, deferral, or suspension decision. Required for regulatory documentation and CAPA initiation.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrolledSubjectCount rdf:type rdf:Property ;
    rdfs:label 'Enrolled Subject Count' ;
    rdfs:comment 'Total number of subjects enrolled in the study at the time of this continuing review submission. Key metric for IRB/IEC risk-benefit assessment.' ;
    rdfs:domain ind:ContinuingReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:icfUpdateRequired rdf:type rdf:Property ;
    rdfs:label 'Icf Update Required' ;
    rdfs:comment 'Indicates whether the IRB/IEC has determined that the Informed Consent Form must be revised and re-consented as a condition of this continuing review approval.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irbIecDecision rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Decision' ;
    rdfs:comment 'Formal decision rendered by the IRB/IEC following review of the continuing review application. Distinct from review_status as it captures the specific regulatory outcome.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Due Date' ;
    rdfs:comment 'Calculated deadline by which the next continuing review submission must be received by the IRB/IEC to maintain uninterrupted approval. Typically one year from approval date unless a shorter interval is specified.' ;
    rdfs:domain ind:ContinuingReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:piSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Pi Signature Date' ;
    rdfs:comment 'Date on which the Principal Investigator signed the continuing review application, certifying accuracy and completeness per ALCOA+ principles.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:protocolDeviationCount rdf:type rdf:Property ;
    rdfs:label 'Protocol Deviation Count' ;
    rdfs:comment 'Total number of protocol deviations recorded since the previous continuing review period. Informs IRB/IEC assessment of GCP compliance and study conduct quality.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:protocolVersion rdf:type rdf:Property ;
    rdfs:label 'Protocol Version' ;
    rdfs:comment 'Version number of the study protocol in effect at the time of this continuing review submission.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Notification Required' ;
    rdfs:comment 'Indicates whether the outcome of this continuing review (e.g., suspension or termination) requires notification to a regulatory authority such as FDA, EMA, or MHRA.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Review Interval Days' ;
    rdfs:comment 'Number of days between the current approval and the required next continuing review, as specified by the IRB/IEC. Standard is 365 days but may be shortened based on risk level.' ;
    rdfs:domain ind:ContinuingReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Review Meeting Date' ;
    rdfs:comment 'Date on which the IRB/IEC convened or conducted the review of this continuing review application, whether full board or expedited.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Review Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned by the IRB/IEC or the sponsor/CRO to uniquely reference this continuing review submission. Used in regulatory correspondence and TMF filing.' ;
    rdfs:domain ind:ContinuingReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current lifecycle status of the continuing review record. Tracks progression from initial submission through IRB/IEC decision. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|approved_with_conditions|deferred|disapproved|suspended|withdrawn — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewType rdf:type rdf:Property ;
    rdfs:label 'Review Type' ;
    rdfs:comment 'Classification of the continuing review procedure. Annual reviews occur on a scheduled cycle; interim reviews are triggered by safety events or protocol amendments; expedited reviews apply to minimal-risk studies; full board reviews require convened IRB/IEC quorum.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskBenefitAssessment rdf:type rdf:Property ;
    rdfs:label 'Risk Benefit Assessment' ;
    rdfs:comment 'IRB/IEC determination of whether the risk-benefit ratio of the study remains acceptable for continued conduct, based on accumulated safety and efficacy data.' ;
    rdfs:domain ind:ContinuingReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyStatusAtReview rdf:type rdf:Property ;
    rdfs:label 'Study Status At Review' ;
    rdfs:comment 'Operational status of the clinical study at the time of this continuing review submission. Determines the scope of IRB/IEC oversight required.' ;
    rdfs:domain ind:ContinuingReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date on which the continuing review application package was formally submitted to the IRB/IEC. Serves as the principal business event date for this transaction.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'Method by which the continuing review application was submitted to the IRB/IEC (electronic via eTMF/portal, paper, or hybrid). Relevant for 21 CFR Part 11 compliance tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmfDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Tmf Document Reference' ;
    rdfs:comment 'Reference identifier for the continuing review submission package and approval letter filed in the electronic Trial Master File (eTMF) in Veeva Vault, per TMF Reference Model Zone 6.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unanticipatedProblemCount rdf:type rdf:Property ;
    rdfs:label 'Unanticipated Problem Count' ;
    rdfs:comment 'Number of unanticipated problems involving risks to subjects or others reported since the last review period. Includes SUSARs and other unexpected safety findings.' ;
    rdfs:domain ind:ContinuingReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:withdrawnSubjectCount rdf:type rdf:Property ;
    rdfs:label 'Withdrawn Subject Count' ;
    rdfs:comment 'Number of subjects who withdrew consent or were withdrawn from the study prior to completion as of the submission date.' ;
    rdfs:domain ind:ContinuingReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicablePhase rdf:type rdf:Property ;
    rdfs:label 'Applicable Phase' ;
    rdfs:comment 'Clinical trial phase(s) to which this deviation classification applies (e.g., \'Phase I\', \'Phase II\', \'Phase III\', \'Phase IV\', \'All\'). Some deviation types are phase-specific (e.g., first-in-human dose escalation deviations). [ENUM-REF-CANDIDATE: Phase I|Phase II|Phase III|Phase IV|Phase I/II|Phase II/III|All — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationStatus rdf:type rdf:Property ;
    rdfs:label 'Classification Status' ;
    rdfs:comment 'Lifecycle status of this deviation classification record: \'draft\' (under review), \'active\' (approved and in use), \'retired\' (no longer applicable to new studies), or \'superseded\' (replaced by a newer version). Controls which classifications are available for selection in EDC and CTMS.' ;
    rdfs:domain ind:DeviationClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationVersion rdf:type rdf:Property ;
    rdfs:label 'Classification Version' ;
    rdfs:comment 'Version number of this deviation classification record (e.g., \'1.0\', \'2.1\'). Supports version control of the taxonomy in MasterControl, ensuring studies reference the correct classification version at the time of protocol approval.' ;
    rdfs:domain ind:DeviationClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csrReportingSection rdf:type rdf:Property ;
    rdfs:label 'Csr Reporting Section' ;
    rdfs:comment 'Section of the Clinical Study Report (CSR) where deviations of this type must be summarized per ICH E3 guidelines (e.g., \'Section 10.2 — Protocol Deviations\', \'Section 12 — Safety\'). Guides medical writers and biostatisticians in SAS Drug Development.' ;
    rdfs:domain ind:DeviationClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationCategory rdf:type rdf:Property ;
    rdfs:label 'Deviation Category' ;
    rdfs:comment 'High-level classification of the deviation severity: \'major\' (significant impact on subject safety or data integrity), \'minor\' (minimal impact), or \'important_protocol_deviation\' (IPD — deviations that may significantly affect subject safety, rights, or data reliability per ICH E6(R2) and FDA guidance). Drives regulatory reporting obligations and CAPA requirements.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationSubcategory rdf:type rdf:Property ;
    rdfs:label 'Deviation Subcategory' ;
    rdfs:comment 'Secondary classification grouping deviation types into functional areas (e.g., \'Eligibility\', \'Dosing\', \'Visit Schedule\', \'Informed Consent\', \'Laboratory\', \'Randomization\', \'Blinding\'). Enables granular analytics and trend reporting across studies. [ENUM-REF-CANDIDATE: eligibility|dosing|visit_schedule|informed_consent|laboratory|randomization|blinding|data_collection|safety_reporting|concomitant_medication — promote to reference product]' ;
    rdfs:domain ind:DeviationClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationTypeCode rdf:type rdf:Property ;
    rdfs:label 'Deviation Type Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the specific deviation type within the classification taxonomy (e.g., PD-001, PD-002). Used as the externally-known business identifier for cross-study referencing and regulatory submissions. Managed in MasterControl.' ;
    rdfs:domain ind:DeviationClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationTypeName rdf:type rdf:Property ;
    rdfs:label 'Deviation Type Name' ;
    rdfs:comment 'Human-readable name of the deviation type (e.g., \'Missed Study Visit\', \'Incorrect Dose Administration\', \'Eligibility Criteria Violation\'). Serves as the primary identity label for display in CTMS, EDC, and regulatory reports.' ;
    rdfs:domain ind:DeviationClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emaGuidanceReference rdf:type rdf:Property ;
    rdfs:label 'Ema Guidance Reference' ;
    rdfs:comment 'Specific EMA guideline or regulation section applicable to this deviation type (e.g., \'EMA GCP Guideline CPMP/ICH/135/95\', \'EU CTR 536/2014 Article 54\'). Supports compliance for EU-based clinical trials.' ;
    rdfs:domain ind:DeviationClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaGuidanceReference rdf:type rdf:Property ;
    rdfs:label 'Fda Guidance Reference' ;
    rdfs:comment 'Specific FDA guidance document and section applicable to this deviation type (e.g., \'FDA Guidance for Industry: Oversight of Clinical Investigations, Section IV\'). Supports regulatory inspection readiness and audit trail documentation.' ;
    rdfs:domain ind:DeviationClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyThresholdCount rdf:type rdf:Property ;
    rdfs:label 'Frequency Threshold Count' ;
    rdfs:comment 'Maximum acceptable number of occurrences of this deviation type at a single site before a systematic issue is declared and escalated per the risk-based monitoring plan. Null if no frequency threshold is defined for this type.' ;
    rdfs:domain ind:DeviationClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gcpPrincipleViolated rdf:type rdf:Property ;
    rdfs:label 'Gcp Principle Violated' ;
    rdfs:comment 'Specific ICH GCP principle(s) violated by deviations of this type (e.g., \'Subject Rights and Safety\', \'Data Integrity\', \'Investigator Responsibilities\'). Used in QA reporting and regulatory inspection responses to demonstrate GCP compliance awareness.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ichGuidanceReference rdf:type rdf:Property ;
    rdfs:label 'Ich Guidance Reference' ;
    rdfs:comment 'Specific ICH guideline section(s) applicable to this deviation type (e.g., \'ICH E6(R2) Section 4.5\', \'ICH E8(R1)\'). Provides the authoritative regulatory basis for the classification and reporting requirements.' ;
    rdfs:domain ind:DeviationClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReadinessNotes rdf:type rdf:Property ;
    rdfs:label 'Inspection Readiness Notes' ;
    rdfs:comment 'Free-text notes providing guidance on how to present and defend deviations of this type during FDA, EMA, or MHRA regulatory inspections. Maintained by the QA team to support audit readiness activities.' ;
    rdfs:domain ind:DeviationClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBlindingSensitive rdf:type rdf:Property ;
    rdfs:label 'Is Blinding Sensitive' ;
    rdfs:comment 'Indicates whether deviations of this type involve or risk unblinding of treatment assignment in blinded studies. When True, special handling procedures apply to protect study integrity and prevent unintended unblinding during deviation review.' ;
    rdfs:domain ind:DeviationClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ittExclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Itt Exclusion Flag' ;
    rdfs:comment 'Indicates whether deviations of this type may trigger exclusion of the affected subject from the Intent-to-Treat (ITT) analysis population. Typically False for most deviation types; True only for critical eligibility violations. Reviewed by biostatistics per the SAP.' ;
    rdfs:domain ind:DeviationClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meddraSocCode rdf:type rdf:Property ;
    rdfs:label 'Meddra Soc Code' ;
    rdfs:comment 'MedDRA System Organ Class (SOC) code associated with this deviation type when the deviation relates to a clinical or safety event. Enables cross-referencing with adverse event coding in Oracle Argus Safety for integrated safety analysis.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringEscalationRequired rdf:type rdf:Property ;
    rdfs:label 'Monitoring Escalation Required' ;
    rdfs:comment 'Indicates whether identification of this deviation type at a site requires escalation of monitoring intensity (e.g., triggered on-site visit, increased SDV rate) per the risk-based monitoring plan. Drives monitoring plan adjustments in Oracle Siebel CTMS.' ;
    rdfs:domain ind:DeviationClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:perProtocolExclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Per Protocol Exclusion Flag' ;
    rdfs:comment 'Indicates whether deviations of this type automatically trigger exclusion of the affected subject from the Per Protocol (PP) analysis population. Used by biostatisticians in SAS Drug Development when applying the Statistical Analysis Plan (SAP) population definitions.' ;
    rdfs:domain ind:DeviationClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required' ;
    rdfs:comment 'Indicates whether this deviation type meets the threshold requiring regulatory reporting to the FDA, EMA, or other applicable health authority. When True, deviations of this type must be included in IND annual reports, clinical study reports (CSR), or expedited submissions per applicable regulations.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingTimeframeDays rdf:type rdf:Property ;
    rdfs:label 'Reporting Timeframe Days' ;
    rdfs:comment 'Maximum number of calendar days within which a deviation of this type must be reported to the applicable regulatory authority or sponsor after identification. Null if no mandatory reporting timeframe applies. Used to trigger automated deadline alerts in CTMS.' ;
    rdfs:domain ind:DeviationClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date on which this deviation classification version was retired or superseded. Null if the classification is currently active. Studies ongoing at retirement may continue using the prior version per protocol freeze rules.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Numeric risk score (typically 1–10) assigned to this deviation type based on its potential impact on subject safety, data integrity, and regulatory compliance. Used in risk-based monitoring (RBM) algorithms in Oracle Siebel CTMS to prioritize site monitoring activities.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmDomainCode rdf:type rdf:Property ;
    rdfs:label 'Sdtm Domain Code' ;
    rdfs:comment 'CDISC SDTM domain code associated with this deviation type (typically \'DV\' for Protocol Deviations). Used to map deviation records to the correct SDTM submission dataset during regulatory data package preparation in SAS Drug Development.' ;
    rdfs:domain ind:DeviationClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Sop Reference Code' ;
    rdfs:comment 'Document control code of the governing Standard Operating Procedure (SOP) in MasterControl that defines the handling, reporting, and CAPA requirements for this deviation type (e.g., \'SOP-QA-0042\'). Ensures traceability to the quality management system.' ;
    rdfs:domain ind:DeviationClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Sponsor Notification Required' ;
    rdfs:comment 'Indicates whether deviations of this type require immediate or expedited notification to the study sponsor per ICH GCP and the clinical trial agreement. When True, the CRA or site must notify the sponsor within the defined timeframe.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardDescriptionTemplate rdf:type rdf:Property ;
    rdfs:label 'Standard Description Template' ;
    rdfs:comment 'Pre-approved narrative template text for describing deviations of this type in eCRFs, deviation logs, and regulatory submissions. Ensures consistent, ALCOA+-compliant documentation language across studies and sites. Managed in MasterControl.' ;
    rdfs:domain ind:DeviationClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectSafetyImpact rdf:type rdf:Property ;
    rdfs:label 'Subject Safety Impact' ;
    rdfs:comment 'Assessment of the potential impact on subject safety for deviations of this type: \'none\' (no safety implications), \'potential\' (possible safety concern requiring evaluation), or \'confirmed\' (known safety impact). Informs risk-based monitoring prioritization and DSMB review.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByCode rdf:type rdf:Property ;
    rdfs:label 'Superseded By Code' ;
    rdfs:comment 'Deviation type code of the classification record that replaces this one when status is \'superseded\'. Enables forward navigation of the classification version history for regulatory audit trail purposes.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User identifier or name of the individual who created this deviation classification record in MasterControl. Supports ALCOA+ attributability requirements and 21 CFR Part 11 audit trail.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalConditions rdf:type rdf:Property ;
    rdfs:label 'Approval Conditions' ;
    rdfs:comment 'Free-text description of any conditions, stipulations, or modifications required by the IRB/IEC as part of a conditional approval. Null for unconditional approvals.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalLetterDate rdf:type rdf:Property ;
    rdfs:label 'Approval Letter Date' ;
    rdfs:comment 'The date printed on the official ethics approval letter issued by the IRB/IEC. May differ from decision_date if the letter is issued after the meeting.' ;
    rdfs:domain ind:EthicsApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned by the Institutional Review Board (IRB) or Independent Ethics Committee (IEC) to this approval decision. Used for regulatory correspondence and audit trail.' ;
    rdfs:domain ind:EthicsApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalType rdf:type rdf:Property ;
    rdfs:label 'Approval Type' ;
    rdfs:comment 'Categorises the review pathway used by the IRB/IEC: full board review, expedited review, exempt determination, central ethics committee review, or local site-level review.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsMetDate rdf:type rdf:Property ;
    rdfs:label 'Conditions Met Date' ;
    rdfs:comment 'The date on which the sponsor or PI confirmed that all IRB/IEC-stipulated conditions for a conditional approval were satisfied, enabling the study to proceed.' ;
    rdfs:domain ind:EthicsApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ctmsRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Ctms Record Number' ;
    rdfs:comment 'Record identifier in Oracle Siebel CTMS where this ethics approval is tracked for site activation and monitoring workflows.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicable Flag' ;
    rdfs:comment 'Indicates whether GDPR data protection requirements apply to this ethics approval, relevant for studies conducted in EU/EEA jurisdictions.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hipaaApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Hipaa Applicable Flag' ;
    rdfs:comment 'Indicates whether HIPAA privacy rule requirements apply to this ethics approval, relevant for studies conducted in the United States.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:icfApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Icf Approval Date' ;
    rdfs:comment 'The date on which the specific ICF version was approved by the IRB/IEC. May differ from the overall protocol decision_date when ICF and protocol are reviewed separately.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:icfVersionApproved rdf:type rdf:Property ;
    rdfs:label 'Icf Version Approved' ;
    rdfs:comment 'Version identifier of the Informed Consent Form (ICF) that was reviewed and approved as part of this ethics submission. Null if the submission did not include an ICF.' ;
    rdfs:domain ind:EthicsApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbIecCountry rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the country where the IRB/IEC is registered and operates.' ;
    rdfs:domain ind:EthicsApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbIecName rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Name' ;
    rdfs:comment 'Full legal name of the IRB or IEC that issued this approval. Retained as a denormalized reference for reporting and regulatory submissions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbIecRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Registration Number' ;
    rdfs:comment 'Official registration or accreditation number of the IRB/IEC as assigned by the relevant regulatory authority (e.g., FDA OHRP registration number, EMA ethics committee identifier).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piName rdf:type rdf:Property ;
    rdfs:label 'Pi Name' ;
    rdfs:comment 'Full name of the Principal Investigator (PI) named on the ethics approval. Retained as a denormalized field for regulatory correspondence and inspection readiness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quorumMetFlag rdf:type rdf:Property ;
    rdfs:label 'Quorum Met Flag' ;
    rdfs:comment 'Indicates whether the required quorum of IRB/IEC members was present at the review meeting, as required for a valid approval decision.' ;
    rdfs:domain ind:EthicsApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryAuthorityNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Notification Date' ;
    rdfs:comment 'Date on which the regulatory authority was notified of the IRB/IEC approval decision. Null if regulatory_authority_notified_flag is False.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryAuthorityNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Notified Flag' ;
    rdfs:comment 'Indicates whether the relevant regulatory authority (e.g., FDA, EMA, MHRA) was notified of the IRB/IEC approval decision as required by applicable regulations.' ;
    rdfs:domain ind:EthicsApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'The date by which a renewal submission must be received by the IRB/IEC to maintain continuous approval. Typically calculated from expiry_date minus the committee\'s required lead time.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionType rdf:type rdf:Property ;
    rdfs:label 'Submission Type' ;
    rdfs:comment 'Classifies the type of submission reviewed by the IRB/IEC: initial protocol review, protocol amendment, annual renewal, safety report, Informed Consent Form (ICF) revision, or other. [ENUM-REF-CANDIDATE: initial|amendment|renewal|safety_report|icf_revision|other — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voteAbstainCount rdf:type rdf:Property ;
    rdfs:label 'Vote Abstain Count' ;
    rdfs:comment 'Number of IRB/IEC board members who abstained from voting at the review meeting.' ;
    rdfs:domain ind:EthicsApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:voteAgainstCount rdf:type rdf:Property ;
    rdfs:label 'Vote Against Count' ;
    rdfs:comment 'Number of IRB/IEC board members who voted against approval at the review meeting.' ;
    rdfs:domain ind:EthicsApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:voteInFavorCount rdf:type rdf:Property ;
    rdfs:label 'Vote In Favor Count' ;
    rdfs:comment 'Number of IRB/IEC board members who voted in favor of approval at the review meeting. Supports audit trail and quorum verification.' ;
    rdfs:domain ind:EthicsApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vulnerablePopulationFlag rdf:type rdf:Property ;
    rdfs:label 'Vulnerable Population Flag' ;
    rdfs:comment 'Indicates whether the approved study involves vulnerable populations (e.g., minors, pregnant women, prisoners, cognitively impaired individuals) requiring additional IRB/IEC safeguards.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverOfConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Of Consent Flag' ;
    rdfs:comment 'Indicates whether the IRB/IEC granted a waiver or alteration of the informed consent requirement as part of this approval.' ;
    rdfs:domain ind:EthicsApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accreditationBody rdf:type rdf:Property ;
    rdfs:label 'Accreditation Body' ;
    rdfs:comment 'Name of the organization that granted accreditation to this ethics committee (e.g., \'AAHRPP\', \'UKAS\', \'DAkkS\', \'NATA\'). Used to validate the committee\'s standing for regulatory submissions and sponsor qualification checks.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Expiry Date' ;
    rdfs:comment 'Date on which the current accreditation certificate expires. Triggers renewal workflows and alerts to prevent use of an expired committee for new study submissions. Null if accreditation is perpetual or not applicable.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Accreditation Number' ;
    rdfs:comment 'Official accreditation certificate number issued by the accrediting body. Referenced in regulatory submissions, TMF documentation, and sponsor qualification audits to verify committee standing.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Accreditation Status' ;
    rdfs:comment 'Current accreditation status of the ethics committee with the relevant accrediting body (e.g., AAHRPP for U.S. IRBs, national competent authority for EU IECs). Determines eligibility to provide ethical oversight for sponsored clinical trials.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRenewalRequired rdf:type rdf:Property ;
    rdfs:label 'Annual Renewal Required' ;
    rdfs:comment 'Indicates whether ongoing studies require annual continuing review and renewal of ethics approval from this committee. True = annual renewal mandatory; False = approval is indefinite until amendment or closure. Drives renewal reminder workflows in CTMS.' ;
    rdfs:domain ind:EthicsCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chairName rdf:type rdf:Property ;
    rdfs:label 'Chair Name' ;
    rdfs:comment 'Full name of the current chairperson of the ethics committee. Required for regulatory correspondence, submission cover letters, and TMF documentation. Classified as confidential as it identifies a named individual in a professional capacity.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City in which the ethics committee office is physically located. Used for geographic reporting, site feasibility assessments, and regulatory jurisdiction mapping.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committeeCategory rdf:type rdf:Property ;
    rdfs:label 'Committee Category' ;
    rdfs:comment 'Operational category of the ethics committee: \'institutional\' (affiliated with a hospital or university), \'independent\' (standalone commercial IRB/IEC), \'central\' (single IRB/IEC covering multiple sites), \'national\' (government-mandated national body), \'regional\' (covering a geographic region). Drives site assignment and submission routing logic.' ;
    rdfs:domain ind:EthicsCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committeeCode rdf:type rdf:Property ;
    rdfs:label 'Committee Code' ;
    rdfs:comment 'Unique business-facing alphanumeric code assigned to the IRB/IEC, used as the externally-known identifier in CTMS, eTMF, and regulatory submissions (e.g., \'IRB-MAYO-001\'). Serves as the BUSINESS_IDENTIFIER for this master-party entity.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Official email address for submitting applications, amendments, and correspondence to the ethics committee. Serves as the PRIMARY_CONTACT for this master-party entity. Classified as confidential PII as it is an organizational contact email.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Official telephone number for the ethics committee office, used for urgent safety communications, protocol deviation notifications, and SAE reporting. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementEndDate rdf:type rdf:Property ;
    rdfs:label 'Engagement End Date' ;
    rdfs:comment 'The date on which this ethics committee\'s oversight of the clinical program was formally concluded or terminated. Null if the engagement is still active.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementStartDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Start Date' ;
    rdfs:comment 'The date on which this ethics committee was formally engaged to provide oversight for the clinical program. Marks the beginning of the regulatory relationship for this program-committee pairing.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementStatus rdf:type rdf:Property ;
    rdfs:label 'Engagement Status' ;
    rdfs:comment 'Current lifecycle status of this program-committee engagement. Tracks whether the committee is actively reviewing the program, suspended, or the engagement has been formally closed.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicsCommitteeName rdf:type rdf:Property ;
    rdfs:label 'Ethics Committee Name' ;
    rdfs:comment 'Official registered name of the IRB or IEC body as it appears on accreditation certificates and regulatory submissions (e.g., \'Mayo Clinic Institutional Review Board\'). Serves as the IDENTITY_LABEL for this master-party entity.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicsCommitteeStatus rdf:type rdf:Property ;
    rdfs:label 'Ethics Committee Status' ;
    rdfs:comment 'Current operational lifecycle status of the ethics committee. \'active\' indicates the committee is fully operational and accepting submissions; \'suspended\' indicates temporary halt of operations; \'dissolved\' indicates permanent closure. Serves as the LIFECYCLE_STATUS for this master-party entity.' ;
    rdfs:domain ind:EthicsCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expeditedReviewAvailable rdf:type rdf:Property ;
    rdfs:label 'Expedited Review Available' ;
    rdfs:comment 'Indicates whether this ethics committee offers an expedited review pathway for minimal-risk studies or protocol amendments, allowing approval without convening a full committee meeting. True = expedited review available; False = full committee review required for all submissions.' ;
    rdfs:domain ind:EthicsCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fwaNumber rdf:type rdf:Property ;
    rdfs:label 'Fwa Number' ;
    rdfs:comment 'OHRP-issued Federalwide Assurance number for U.S. institutions, confirming commitment to protect human research subjects (format: FWA followed by 8 digits). Required for federally funded research and referenced in IND/NDA submissions to FDA.' ;
    rdfs:domain ind:EthicsCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprApplicable rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicable' ;
    rdfs:comment 'Indicates whether GDPR (General Data Protection Regulation) applies to submissions and data processed under this ethics committee\'s jurisdiction. True = GDPR requirements apply (EU/EEA-based committee); False = non-EU jurisdiction. Drives data privacy compliance workflows.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hipaaApplicable rdf:type rdf:Property ;
    rdfs:label 'Hipaa Applicable' ;
    rdfs:comment 'Indicates whether HIPAA (Health Insurance Portability and Accountability Act) privacy and security rules apply to research conducted under this ethics committee\'s oversight. True = HIPAA applies (U.S.-based committee); False = non-U.S. jurisdiction.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:icfTemplateRequired rdf:type rdf:Property ;
    rdfs:label 'Icf Template Required' ;
    rdfs:comment 'Indicates whether this ethics committee mandates use of its own Informed Consent Form (ICF) template rather than the sponsor\'s template. True = committee-specific ICF template required; False = sponsor template acceptable with committee approval.' ;
    rdfs:domain ind:EthicsCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:institutionName rdf:type rdf:Property ;
    rdfs:label 'Institution Name' ;
    rdfs:comment 'Name of the parent institution or organization to which this ethics committee is affiliated (e.g., \'Mayo Clinic\', \'University of Oxford\', \'Charité – Universitätsmedizin Berlin\'). Distinguishes institutional IRBs/IECs from independent/central committees.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCentralIrb rdf:type rdf:Property ;
    rdfs:label 'Is Central Irb' ;
    rdfs:comment 'Indicates whether this ethics committee serves as a central IRB/IEC providing oversight for multiple investigational sites under a single review, as permitted by the NIH Single IRB Policy and 21st Century Cures Act. True = central/single IRB model; False = site-specific review.' ;
    rdfs:domain ind:EthicsCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionDescription rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Description' ;
    rdfs:comment 'Free-text description of the geographic or institutional jurisdiction covered by the ethics committee (e.g., \'State of Minnesota, USA\', \'European Union member states\', \'Federal Republic of Germany\'). Complements country_code with sub-national or multi-national scope details.' ;
    rdfs:domain ind:EthicsCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'BCP 47 language tag representing the primary language in which submissions must be prepared for this ethics committee (e.g., \'en\', \'de\', \'fr\', \'ja\'). Drives ICF translation requirements and document preparation workflows.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddress rdf:type rdf:Property ;
    rdfs:label 'Mailing Address' ;
    rdfs:comment 'Full mailing address of the ethics committee office, used for formal regulatory correspondence, submission packages, and TMF documentation. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oversightScope rdf:type rdf:Property ;
    rdfs:label 'Oversight Scope' ;
    rdfs:comment 'Defines the specific protocols, studies, or investigational sites within the clinical program that this ethics committee is responsible for reviewing and overseeing. Belongs to the engagement, not to either entity alone.' ;
    rdfs:domain ind:EthicsCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContact rdf:type rdf:Property ;
    rdfs:label 'Primary Contact' ;
    rdfs:comment 'The designated contact person at the ethics committee who is responsible for communications related to this specific clinical program. Distinct from the general committee contact_email on the ethics_committee master record, as this is program-specific.' ;
    rdfs:domain ind:EthicsCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Official government or regulatory registration number for the IRB or IEC (e.g., OHRP-assigned IRB registration number in the format \'IRB00XXXXXX\', or EU national competent authority registration). Required for IND applications, regulatory submissions, and eTMF documentation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresLocalPiSignature rdf:type rdf:Property ;
    rdfs:label 'Requires Local Pi Signature' ;
    rdfs:comment 'Indicates whether this ethics committee requires the local Principal Investigator (PI) to co-sign the ethics application or ICF submission. True = local PI signature mandatory; False = sponsor or CRO signature sufficient. Affects site activation workflows.' ;
    rdfs:domain ind:EthicsCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewTurnaroundDays rdf:type rdf:Property ;
    rdfs:label 'Review Turnaround Days' ;
    rdfs:comment 'Standard number of calendar days the ethics committee requires to complete initial protocol review from submission date. Used in study timeline planning, site feasibility assessments, and KPI tracking for enrollment readiness.' ;
    rdfs:domain ind:EthicsCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:saeReportingTimeframeDays rdf:type rdf:Property ;
    rdfs:label 'Sae Reporting Timeframe Days' ;
    rdfs:comment 'Number of calendar days within which Serious Adverse Events (SAEs) and SUSARs must be reported to this ethics committee following identification. Varies by committee and jurisdiction; drives safety reporting workflow configuration in Oracle Argus Safety.' ;
    rdfs:domain ind:EthicsCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or sub-national administrative region where the ethics committee is located. Relevant for U.S. state-level IRB regulations and Canadian provincial health research ethics requirements.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionPortalUrl rdf:type rdf:Property ;
    rdfs:label 'Submission Portal Url' ;
    rdfs:comment 'URL of the ethics committee\'s electronic submission portal or online application system. Used by CRAs and regulatory affairs teams to route submissions and track application status.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionStrategy rdf:type rdf:Property ;
    rdfs:label 'Submission Strategy' ;
    rdfs:comment 'The agreed or required approach for submitting protocol amendments, safety reports, and annual reviews to this ethics committee for this specific program. May differ by committee and program based on regulatory jurisdiction and committee preferences.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaVaultRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Record Number' ;
    rdfs:comment 'Unique record identifier for this ethics committee in Veeva Vault eTMF, used to cross-reference TMF documents, ethics approval letters, and correspondence stored in the document management system.' ;
    rdfs:domain ind:EthicsCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicsCorrespondenceId rdf:type rdf:Property ;
    rdfs:label 'Ethics Correspondence Id' ;
    rdfs:comment 'Unique surrogate identifier for each ethics committee correspondence record in the Databricks Silver Layer.' ;
    rdfs:domain ind:EthicsCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:communicationChannel rdf:type rdf:Property ;
    rdfs:label 'Communication Channel' ;
    rdfs:comment 'The medium through which the correspondence was transmitted (e.g., email, postal mail, fax, electronic submission portal, hand delivery).' ;
    rdfs:domain ind:EthicsCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondenceCategory rdf:type rdf:Property ;
    rdfs:label 'Correspondence Category' ;
    rdfs:comment 'High-level category grouping the correspondence by subject matter: safety (SAE/SUSAR notifications), regulatory, protocol-related, consent-related, or administrative.' ;
    rdfs:domain ind:EthicsCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondenceDate rdf:type rdf:Property ;
    rdfs:label 'Correspondence Date' ;
    rdfs:comment 'The principal real-world date on which the correspondence was formally issued, sent, or received — the business event date as recorded on the document.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correspondenceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Correspondence Reference Number' ;
    rdfs:comment 'Externally-known unique alphanumeric reference number assigned to this correspondence item, used for tracking across systems such as Veeva Vault eTMF and Oracle Siebel CTMS.' ;
    rdfs:domain ind:EthicsCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondenceStatus rdf:type rdf:Property ;
    rdfs:label 'Correspondence Status' ;
    rdfs:comment 'Current lifecycle state of the correspondence item, tracking its workflow from draft through closure. [ENUM-REF-CANDIDATE: draft|sent|received|acknowledged|pending_response|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondenceSummary rdf:type rdf:Property ;
    rdfs:label 'Correspondence Summary' ;
    rdfs:comment 'A concise narrative summary of the content, purpose, and key points of the correspondence, enabling quick review without accessing the full document.' ;
    rdfs:domain ind:EthicsCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondenceType rdf:type rdf:Property ;
    rdfs:label 'Correspondence Type' ;
    rdfs:comment 'Classification of the correspondence by its business purpose: initial protocol submission, amendment submission, query from IRB/IEC, clarification response, safety notification, approval acknowledgement, or adverse event report. [ENUM-REF-CANDIDATE: initial_submission|amendment_submission|query|clarification_response|notification|approval_acknowledgement|adverse_event_report|annual_renewal|deviation_report|closure_notification — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Indicates whether the correspondence was sent by the sponsor/CRO to the IRB/IEC (outbound) or received from the IRB/IEC (inbound).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbIecReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Reference Number' ;
    rdfs:comment 'The reference or tracking number assigned by the IRB/IEC to this correspondence or submission, used for cross-referencing with the ethics committee\'s own records.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queryDescription rdf:type rdf:Property ;
    rdfs:label 'Query Description' ;
    rdfs:comment 'Detailed description of the query or clarification request raised by the IRB/IEC or sponsor, applicable when correspondence_type is \'query\' or \'clarification_response\'.' ;
    rdfs:domain ind:EthicsCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'The date on which the correspondence was received by the intended recipient. Used for response timeline tracking and regulatory compliance.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recipientName rdf:type rdf:Property ;
    rdfs:label 'Recipient Name' ;
    rdfs:comment 'Full name of the individual or committee to whom the correspondence is addressed (e.g., IRB/IEC Chair, Ethics Committee Secretary).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientOrganization rdf:type rdf:Property ;
    rdfs:label 'Recipient Organization' ;
    rdfs:comment 'Name of the IRB/IEC or organization to which the correspondence is addressed.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseOverdueFlag rdf:type rdf:Property ;
    rdfs:label 'Response Overdue Flag' ;
    rdfs:comment 'Indicates whether the required response to this correspondence has not been received by the response_due_date, triggering escalation workflows.' ;
    rdfs:domain ind:EthicsCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseSummary rdf:type rdf:Property ;
    rdfs:label 'Response Summary' ;
    rdfs:comment 'Summary of the response provided to a query or clarification request, capturing the key points of the reply for audit trail and TMF documentation purposes.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderName rdf:type rdf:Property ;
    rdfs:label 'Sender Name' ;
    rdfs:comment 'Full name of the individual or organization that authored and sent this correspondence (e.g., Principal Investigator, Sponsor Medical Monitor, CRO Regulatory Affairs).' ;
    rdfs:domain ind:EthicsCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderOrganization rdf:type rdf:Property ;
    rdfs:label 'Sender Organization' ;
    rdfs:comment 'Name of the organization from which the correspondence originated (e.g., sponsor company, CRO name, investigational site institution).' ;
    rdfs:domain ind:EthicsCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderRole rdf:type rdf:Property ;
    rdfs:label 'Sender Role' ;
    rdfs:comment 'The functional role of the sender within the clinical trial organizational structure (e.g., Principal Investigator (PI), sponsor representative, CRO regulatory affairs).' ;
    rdfs:domain ind:EthicsCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentDate rdf:type rdf:Property ;
    rdfs:label 'Sent Date' ;
    rdfs:comment 'The date on which the correspondence was dispatched to the IRB/IEC or sponsor. Distinct from correspondence_date (document date) and received_date.' ;
    rdfs:domain ind:EthicsCorrespondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subjectLine rdf:type rdf:Property ;
    rdfs:label 'Subject Line' ;
    rdfs:comment 'The formal subject or title of the correspondence as it appears on the document, used for identification and search.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigatorBrochureSafetyId rdf:type rdf:Property ;
    rdfs:label 'Investigator Brochure Safety Id' ;
    rdfs:comment 'Foreign key linking to safety.investigator_brochure_safety. Business justification: IB updates (especially SUSAR-triggered amendments) require IRB/IEC submission. ethics_submission already stores investigator_brochure_version as a denormalized text field. A proper FK to investigator_' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestigatorBrochureSafety .

ind:parentSubmissionEthicsSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Parent Submission Ethics Submission Id' ;
    rdfs:comment 'Reference to the original or preceding ethics submission that this record amends or continues. Enables lineage tracking across the full submission history for a study.' ;
    rdfs:domain ind:EthicsSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EthicsSubmission .

ind:continuingReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Continuing Review Due Date' ;
    rdfs:comment 'Date by which the next continuing review submission must be filed with the IRB or IEC to maintain uninterrupted approval. Calculated from the approval expiry date minus any required lead time.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decisionOutcome rdf:type rdf:Property ;
    rdfs:label 'Decision Outcome' ;
    rdfs:comment 'The formal decision rendered by the IRB or IEC on this submission. Drives downstream study activation, amendment implementation, and regulatory reporting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReadinessFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Readiness Flag' ;
    rdfs:comment 'Indicates whether this ethics submission record and its associated documentation are complete and ready for regulatory inspection review. Used in audit readiness dashboards.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptConfirmedDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Confirmed Date' ;
    rdfs:comment 'Date on which the IRB or IEC formally acknowledged receipt of the submission package. Marks the start of the review clock for regulatory timeline tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Response Submitted Date' ;
    rdfs:comment 'Date on which the sponsor or investigator submitted a formal response to IRB or IEC queries or conditions of approval.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subjectEnrollmentAuthorized rdf:type rdf:Property ;
    rdfs:label 'Subject Enrollment Authorized' ;
    rdfs:comment 'Indicates whether this ethics approval authorizes the enrollment of new subjects at the site. False for submissions that do not grant or maintain enrollment authorization (e.g., pending conditions).' ;
    rdfs:domain ind:EthicsSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionCategory rdf:type rdf:Property ;
    rdfs:label 'Submission Category' ;
    rdfs:comment 'Detailed categorization of the submission content beyond the submission type, enabling granular tracking of what changed or was reported. [ENUM-REF-CANDIDATE: initial_application|protocol_amendment|icf_amendment|safety_update|annual_renewal|study_closure|deviation_report|investigator_brochure_update|consent_form_update — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionCountry rdf:type rdf:Property ;
    rdfs:label 'Submission Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction in which this ethics submission is filed. Determines applicable regulatory framework (e.g., FDA, EMA, PMDA, Health Canada).' ;
    rdfs:domain ind:EthicsSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionNotes rdf:type rdf:Property ;
    rdfs:label 'Submission Notes' ;
    rdfs:comment 'Free-text field for capturing additional context, cover letter summary, or operational notes related to this ethics submission that are not captured in structured fields.' ;
    rdfs:domain ind:EthicsSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Number' ;
    rdfs:comment 'Externally-known, human-readable reference number assigned to this submission package (e.g., IRB-2024-0042-A01). Used for tracking across systems and correspondence with the ethics committee.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'Current lifecycle state of the ethics submission package from preparation through final ethics committee decision. Drives workflow and compliance tracking. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|conditionally_approved|rejected|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverGranted rdf:type rdf:Property ;
    rdfs:label 'Waiver Granted' ;
    rdfs:comment 'Indicates whether the IRB or IEC granted a waiver of informed consent or waiver of documentation of informed consent as part of this submission decision.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lead Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: The internal inspection lead (sponsor/CRO employee coordinating the regulatory inspection response) must be linked to workforce for GCP accountability, inspection readiness reporting, and workload tra' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:priorInspectionComplianceInspectionId rdf:type rdf:Property ;
    rdfs:label 'Prior Inspection Compliance Inspection Id' ;
    rdfs:comment 'Reference to the previous inspection record that this inspection follows up on. Populated only when repeat_inspection is True, enabling inspection history chain analysis.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceInspection .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Final regulatory classification assigned by the inspecting agency upon completion of the inspection. NAI (No Action Indicated) means no significant deviations found; VAI (Voluntary Action Indicated) means minor deviations requiring voluntary corrective action; OAI (Official Action Indicated) means significant deviations requiring mandatory regulatory action. Pending until the agency issues the final classification letter.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationDate rdf:type rdf:Property ;
    rdfs:label 'Classification Date' ;
    rdfs:comment 'Date on which the regulatory authority issued the final inspection classification (NAI/VAI/OAI) or equivalent outcome letter. Marks the start of any mandatory CAPA response timelines.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:country rdf:type rdf:Property ;
    rdfs:label 'Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country where the inspection was conducted. Used for regulatory jurisdiction mapping and cross-regional compliance reporting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Number of findings classified as critical severity by the inspecting agency. Critical findings indicate conditions that may directly impact subject safety, data integrity, or regulatory compliance and typically require immediate corrective action.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:form483Issued rdf:type rdf:Property ;
    rdfs:label 'Form 483 Issued' ;
    rdfs:comment 'Indicates whether the FDA issued a Form 483 (Inspectional Observations) at the close of the inspection. Applicable only to FDA inspections. True if a Form 483 was issued; False otherwise.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectedEntityName rdf:type rdf:Property ;
    rdfs:label 'Inspected Entity Name' ;
    rdfs:comment 'Legal or registered name of the organization, site, or facility being inspected by the regulatory authority.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectedEntityType rdf:type rdf:Property ;
    rdfs:label 'Inspected Entity Type' ;
    rdfs:comment 'Category of the organization or entity being inspected. Distinguishes between sponsor-level, Contract Research Organization (CRO)-level, investigational site-level, central laboratory, or Institutional Review Board (IRB)/Independent Ethics Committee (IEC) inspections.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectingAgency rdf:type rdf:Property ;
    rdfs:label 'Inspecting Agency' ;
    rdfs:comment 'Name of the regulatory health authority conducting the inspection (e.g., FDA, EMA, PMDA, MHRA, Health Canada, TGA). Determines applicable regulatory framework and reporting obligations. [ENUM-REF-CANDIDATE: FDA|EMA|PMDA|MHRA|Health Canada|TGA|ANVISA|COFEPRIS|Other — promote to reference product]' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionMode rdf:type rdf:Property ;
    rdfs:label 'Inspection Mode' ;
    rdfs:comment 'Indicates whether the inspection was conducted physically on-site at the inspected facility, remotely via electronic document review and virtual meetings, or as a hybrid combination of both modalities.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Number' ;
    rdfs:comment 'Externally-assigned or internally-generated unique alphanumeric reference number for the inspection, used for cross-referencing with regulatory agency correspondence and the Trial Master File (TMF).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionScope rdf:type rdf:Property ;
    rdfs:label 'Inspection Scope' ;
    rdfs:comment 'Defines the breadth of the inspection — whether it is limited to a specific clinical study, covers broader quality systems and processes, or focuses on a specific compliance area such as data integrity or safety reporting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current lifecycle state of the inspection record, from initial notification through final classification and closure. Drives audit readiness workflows and CAPA tracking in MasterControl.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorCount rdf:type rdf:Property ;
    rdfs:label 'Inspector Count' ;
    rdfs:comment 'Total number of regulatory inspectors participating in the inspection team from the health authority. Informs resource planning for inspection hosting and document preparation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadInspectorName rdf:type rdf:Property ;
    rdfs:label 'Lead Inspector Name' ;
    rdfs:comment 'Full name of the primary regulatory inspector assigned by the health authority to lead the inspection. Used for correspondence tracking and relationship management with the inspecting agency.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Major Findings Count' ;
    rdfs:comment 'Number of findings classified as major severity by the inspecting agency. Major findings represent significant deviations from GCP or regulatory requirements that could potentially affect subject safety or data reliability.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Findings Count' ;
    rdfs:comment 'Number of findings classified as minor or other severity by the inspecting agency. Minor findings are deviations that are unlikely to have a significant impact on subject safety or data integrity but require corrective action.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'Date on which the regulatory authority formally notified the sponsor, CRO, or site of the upcoming inspection. Critical for calculating preparation lead time and triggering audit readiness activities.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preliminaryFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Preliminary Findings Count' ;
    rdfs:comment 'Total number of preliminary observations or findings communicated by the inspectors during or immediately after the inspection (e.g., via a Form FDA 483 or equivalent). Provides an early indicator of inspection severity before final classification.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualitySystemArea rdf:type rdf:Property ;
    rdfs:label 'Quality System Area' ;
    rdfs:comment 'Specific quality system area or functional domain covered by the inspection scope (e.g., Clinical Operations, Data Management, Pharmacovigilance, Regulatory Affairs, Laboratory Operations). Enables trend analysis of inspection focus areas across the organization. [ENUM-REF-CANDIDATE: Clinical Operations|Data Management|Pharmacovigilance|Regulatory Affairs|Laboratory|Supply Chain|Quality Assurance|Biostatistics — promote to reference product]' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionRef rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Ref' ;
    rdfs:comment 'Reference number of the associated regulatory submission (e.g., IND, NDA, BLA, MAA, eCTD sequence number) that triggered or is associated with this inspection. Particularly relevant for Pre-Approval Inspections (PAI).' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatInspection rdf:type rdf:Property ;
    rdfs:label 'Repeat Inspection' ;
    rdfs:comment 'Indicates whether this inspection is a follow-up or repeat inspection of the same entity by the same regulatory authority, typically triggered by unresolved findings from a prior inspection. True if this is a repeat inspection.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportDate rdf:type rdf:Property ;
    rdfs:label 'Report Date' ;
    rdfs:comment 'Date on which the regulatory authority issued the formal inspection report (e.g., Establishment Inspection Report for FDA, or GCP Inspection Report for EMA) to the inspected organization.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Response Submission Date' ;
    rdfs:comment 'Actual date on which the formal written response to the inspection findings was submitted to the regulatory authority. Compared against response_due_date to assess timeliness of regulatory response.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Planned end date of the inspection window as communicated by the regulatory authority. Together with scheduled_start_date defines the expected inspection duration.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned start date of the on-site or remote inspection as communicated by the regulatory authority in the inspection notification.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tmfReference rdf:type rdf:Property ;
    rdfs:label 'Tmf Reference' ;
    rdfs:comment 'Document reference or folder path in the Electronic Trial Master File (eTMF) system (Veeva Vault) where inspection-related documentation, correspondence, and evidence packages are archived.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warningLetterIssued rdf:type rdf:Property ;
    rdfs:label 'Warning Letter Issued' ;
    rdfs:comment 'Indicates whether the regulatory authority issued a formal Warning Letter or equivalent enforcement communication following the inspection. A Warning Letter signals serious GCP non-compliance and triggers mandatory regulatory response.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labResultId rdf:type rdf:Property ;
    rdfs:label 'Lab Result Id' ;
    rdfs:comment 'Foreign key linking to laboratory.lab_result. Business justification: Regulatory inspection findings (FDA Form 483, EMA findings) cite specific lab results as evidence of GCP violations. inspection_finding has data_integrity_impact. Linking to the specific lab_result is' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabResult .

ind:priorFindingInspectionFindingId rdf:type rdf:Property ;
    rdfs:label 'Prior Finding Inspection Finding Id' ;
    rdfs:comment 'Reference to the earlier inspection finding that this finding repeats or is related to. Populated only when repeat_finding is True. Enables lineage tracking of recurring deficiencies across inspection cycles.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionFinding .

ind:affectedProcessArea rdf:type rdf:Property ;
    rdfs:label 'Affected Process Area' ;
    rdfs:comment 'The specific clinical trial process or functional area implicated by the finding (e.g., \'Informed Consent Management\', \'SAE Reporting\', \'Investigational Product Accountability\', \'Source Data Verification\', \'Protocol Deviation Management\'). Used for root cause analysis and SOP compliance tracking.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSubjectCount rdf:type rdf:Property ;
    rdfs:label 'Affected Subject Count' ;
    rdfs:comment 'Number of study subjects (patients) directly impacted by the deficiency identified in this inspection finding. Used to assess the scope of subject safety risk and to prioritize remediation efforts.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditReadinessFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Readiness Flag' ;
    rdfs:comment 'Indicates whether all required documentation, CAPA evidence, and response materials for this finding have been compiled and are ready for re-inspection or follow-up audit review. Supports inspection readiness programs and executive reporting.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:findingClassification rdf:type rdf:Property ;
    rdfs:label 'Finding Classification' ;
    rdfs:comment 'Regulatory severity classification of the inspection finding as assigned by the inspecting authority. \'Critical\' indicates a condition that poses significant risk to subject safety or data integrity and may result in a Warning Letter or consent decree. \'Major\' indicates a significant deficiency requiring corrective action. \'Other\' (also termed \'minor\' or \'observation\' by some authorities) indicates a lesser deficiency. Aligns with EMA GCP inspection classification and FDA enforcement terminology.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDate rdf:type rdf:Property ;
    rdfs:label 'Finding Date' ;
    rdfs:comment 'The date on which the regulatory authority formally issued or documented this finding during the inspection. This is the principal real-world event date (TRANSACTION_HEADER: BUSINESS_EVENT_TIMESTAMP at date granularity), distinct from the inspection start date and the response deadline.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Number' ;
    rdfs:comment 'Externally-assigned sequential identifier for this finding within the inspection, as issued by the regulatory authority (e.g., FDA Form 483 observation number, EMA GCP inspection finding reference). Serves as the business-facing identifier for regulatory correspondence and response tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionAuthority rdf:type rdf:Property ;
    rdfs:label 'Inspection Authority' ;
    rdfs:comment 'Regulatory authority that issued the inspection finding (e.g., FDA, EMA, MHRA, PMDA, TGA, Health Canada). Determines the applicable response format, deadline, and escalation pathway. [ENUM-REF-CANDIDATE: FDA|EMA|MHRA|PMDA|TGA|Health_Canada|ANVISA|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionFindingSource rdf:type rdf:Property ;
    rdfs:label 'Inspection Finding Source' ;
    rdfs:comment 'The type of regulatory document in which this finding was formally issued. \'Form_483\' refers to FDA Inspectional Observations. \'Warning_letter\' refers to an FDA Warning Letter. \'EIR\' refers to an FDA Establishment Inspection Report. \'GCP_inspection_report\' refers to an EMA or MHRA GCP inspection report.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'Name of the regulatory inspector or lead inspector who identified and documented this finding. Recorded for correspondence and response addressing purposes. Classified as confidential as it identifies a government official in a regulatory context.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolDeviationRelated rdf:type rdf:Property ;
    rdfs:label 'Protocol Deviation Related' ;
    rdfs:comment 'Indicates whether this inspection finding is directly related to a protocol deviation or series of protocol deviations. Enables cross-domain linkage between compliance findings and protocol deviation management.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordOwner rdf:type rdf:Property ;
    rdfs:label 'Record Owner' ;
    rdfs:comment 'Name or identifier of the individual (typically a QA manager or Regulatory Affairs lead) responsible for managing the response and resolution of this inspection finding within the sponsor or CRO organization. Supports accountability tracking in MasterControl.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatFinding rdf:type rdf:Property ;
    rdfs:label 'Repeat Finding' ;
    rdfs:comment 'Indicates whether this finding is a recurrence of a previously identified deficiency at the same site or sponsor level. Repeat findings signal systemic quality failures and may trigger escalated regulatory enforcement action.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseAdequacyAssessment rdf:type rdf:Property ;
    rdfs:label 'Response Adequacy Assessment' ;
    rdfs:comment 'The regulatory authority\'s assessment of whether the sponsor\'s formal response to the finding is adequate. \'Adequate\' results in finding closure. \'Inadequate\' or \'Partially_adequate\' requires a supplemental response. \'Pending_review\' indicates the authority has not yet issued its assessment.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorResponseSummary rdf:type rdf:Property ;
    rdfs:label 'Sponsor Response Summary' ;
    rdfs:comment 'Executive summary of the sponsor\'s or CRO\'s formal written response to the inspection finding, including the root cause identified, immediate corrective actions taken, and preventive measures committed. Stored in MasterControl and linked to the eTMF in Veeva Vault.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplementalResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Supplemental Response Due Date' ;
    rdfs:comment 'Deadline for submission of a supplemental or follow-up response when the initial response was assessed as inadequate or partially adequate by the regulatory authority. Null if no supplemental response is required.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warningLetterReference rdf:type rdf:Property ;
    rdfs:label 'Warning Letter Reference' ;
    rdfs:comment 'Official reference number of the FDA Warning Letter or equivalent regulatory enforcement communication issued in connection with this finding. Populated only when escalation_status is \'warning_letter\'. Used for regulatory commitment tracking and legal response management.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbRelianceId rdf:type rdf:Property ;
    rdfs:label 'Irb Reliance Id' ;
    rdfs:comment 'Unique surrogate identifier for the IRB reliance agreement record in the lakehouse silver layer.' ;
    rdfs:domain ind:IrbReliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewingEthicsCommitteeId rdf:type rdf:Property ;
    rdfs:label 'Reviewing Ethics Committee Id' ;
    rdfs:comment 'Foreign key linking to compliance.ethics_committee. Business justification: irb_reliance stores the reviewing IRB identity as three free-text fields (name, registration_number, fwa_number). The ethics_committee master table contains exactly these attributes (name, registratio' ;
    rdfs:domain ind:IrbReliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EthicsCommittee .

ind:exemptCategory rdf:type rdf:Property ;
    rdfs:label 'Exempt Category' ;
    rdfs:comment 'Specific exemption category (1–6 under the Revised Common Rule) assigned by the reviewing IRB if the research qualifies as exempt from full IRB oversight. Null for non-exempt research. [ENUM-REF-CANDIDATE: category_1|category_2|category_3|category_4|category_5|category_6 — promote to reference product]' ;
    rdfs:domain ind:IrbReliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date on which the reliance agreement ceases to be in force. Null for open-ended agreements. Triggers renewal workflow when approaching.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fdaRegulatedFlag rdf:type rdf:Property ;
    rdfs:label 'Fda Regulated Flag' ;
    rdfs:comment 'Indicates whether the research covered by this reliance agreement is subject to FDA regulations (e.g., IND or IDE studies), which may impose additional IRB requirements beyond the Common Rule.' ;
    rdfs:domain ind:IrbReliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:indNumber rdf:type rdf:Property ;
    rdfs:label 'Ind Number' ;
    rdfs:comment 'FDA-assigned IND application number for the investigational product under study, required for FDA-regulated research covered by this reliance agreement.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Initial Approval Date' ;
    rdfs:comment 'Date on which the reviewing IRB granted initial approval for the protocol at the relying institution under this reliance agreement.' ;
    rdfs:domain ind:IrbReliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:irbSubmissionNumber rdf:type rdf:Property ;
    rdfs:label 'Irb Submission Number' ;
    rdfs:comment 'Submission tracking number assigned by the reviewing IRB for the initial protocol submission or reliance request, used to cross-reference IRB correspondence and approval letters.' ;
    rdfs:domain ind:IrbReliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContinuingReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Continuing Review Date' ;
    rdfs:comment 'Date of the most recent continuing review approval granted by the reviewing IRB for the protocol covered under this reliance agreement.' ;
    rdfs:domain ind:IrbReliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:multiSiteFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Site Flag' ;
    rdfs:comment 'Indicates whether this reliance agreement covers multiple clinical trial sites (True) or a single site (False), relevant for NIH-mandated single IRB requirements for multi-site studies.' ;
    rdfs:domain ind:IrbReliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nihFundedFlag rdf:type rdf:Property ;
    rdfs:label 'Nih Funded Flag' ;
    rdfs:comment 'Indicates whether the study covered by this reliance agreement is funded by the National Institutes of Health (NIH), triggering mandatory single IRB requirements under the NIH sIRB policy.' ;
    rdfs:domain ind:IrbReliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:piContactEmail rdf:type rdf:Property ;
    rdfs:label 'Pi Contact Email' ;
    rdfs:comment 'Email address of the Principal Investigator at the relying institution, used for reliance agreement notifications, amendment communications, and IRB correspondence.' ;
    rdfs:domain ind:IrbReliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relianceScope rdf:type rdf:Property ;
    rdfs:label 'Reliance Scope' ;
    rdfs:comment 'Defines the scope of oversight transferred to the reviewing IRB: full study oversight, specific procedures only, specific sites only, or amendments only.' ;
    rdfs:domain ind:IrbReliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relyingInstitutionFwaNumber rdf:type rdf:Property ;
    rdfs:label 'Relying Institution Fwa Number' ;
    rdfs:comment 'OHRP-issued Federal Wide Assurance number for the relying institution, confirming its commitment to the Common Rule and eligibility to enter into a reliance agreement.' ;
    rdfs:domain ind:IrbReliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relyingInstitutionName rdf:type rdf:Property ;
    rdfs:label 'Relying Institution Name' ;
    rdfs:comment 'Full legal name of the institution that cedes IRB oversight to the reviewing IRB under this reliance agreement. For multi-site agreements, this may represent the primary relying institution.' ;
    rdfs:domain ind:IrbReliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmfSectionReference rdf:type rdf:Property ;
    rdfs:label 'Tmf Section Reference' ;
    rdfs:comment 'TMF Reference Model section code where the reliance agreement document is filed (e.g., 06.02 for IRB/IEC correspondence), supporting inspection readiness and eTMF completeness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationId rdf:type rdf:Property ;
    rdfs:label 'Obligation Id' ;
    rdfs:comment 'Primary key for obligation' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:obligationApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Obligation Approved By Employee Id' ;
    rdfs:comment 'Identifier of the individual who formally approved this obligation record for inclusion in the active compliance framework. Supports electronic signature requirements under 21 CFR Part 11 and audit trail integrity.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:obligationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Obligation Employee Id' ;
    rdfs:comment 'Identifier of the individual (typically a QA or Regulatory Affairs professional) designated as the primary owner of this obligation record, responsible for maintaining its accuracy, triggering reviews, and ensuring organizational compliance. References the workforce management system.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:responsibleOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Responsible Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: Regulatory obligations must be assigned to specific org units for compliance dashboard reporting, escalation routing, and GCP inspection readiness. \'responsible_function\' is a plain-text denormalizati' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:applicableStudyPhase rdf:type rdf:Property ;
    rdfs:label 'Applicable Study Phase' ;
    rdfs:comment 'Clinical trial phase(s) to which this obligation applies (Phase I through Phase IV, All phases, or Not Applicable for non-phase-specific obligations such as GCP training requirements). Used to filter obligations relevant to a specific study during audit scope definition.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableStudyType rdf:type rdf:Property ;
    rdfs:label 'Applicable Study Type' ;
    rdfs:comment 'Type of clinical study to which this obligation applies (interventional, observational, expanded access, compassionate use, or registry). Certain obligations (e.g., IND reporting) apply only to interventional studies, while privacy obligations apply broadly.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdiscDomainReference rdf:type rdf:Property ;
    rdfs:label 'Cdisc Domain Reference' ;
    rdfs:comment 'Reference to the applicable CDISC SDTM or ADaM domain that this obligation governs (e.g., \'SDTM AE domain\', \'ADaM ADAE dataset\'). Relevant for data integrity and submission obligations, linking compliance requirements to specific data standards.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataIntegrityRelevance rdf:type rdf:Property ;
    rdfs:label 'Data Integrity Relevance' ;
    rdfs:comment 'Assessment of the degree to which this obligation relates to data integrity requirements (ALCOA+ principles: Attributable, Legible, Contemporaneous, Original, Accurate, Complete, Consistent, Enduring, Available). Critical for EDC validation, audit trail, and 21 CFR Part 11 compliance.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gcpClauseReference rdf:type rdf:Property ;
    rdfs:label 'Gcp Clause Reference' ;
    rdfs:comment 'Specific ICH GCP E6(R2) clause or section number that this obligation maps to (e.g., \'ICH E6(R2) 5.17.1\', \'ICH E6(R2) 4.8.2\'). Enables direct mapping between internal obligations and GCP requirements for audit finding classification and inspection preparation.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReadinessPriority rdf:type rdf:Property ;
    rdfs:label 'Inspection Readiness Priority' ;
    rdfs:comment 'Priority tier assigned to this obligation for inspection readiness planning: tier_1 (highest priority, routinely inspected by FDA/EMA/PMDA), tier_2 (frequently reviewed), tier_3 (lower frequency but still in scope). Drives the depth of pre-inspection audit activities and documentation review.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Geographic or regulatory jurisdiction(s) to which this obligation applies, expressed as ISO 3166-1 alpha-3 country codes or a named regulatory region (e.g., \'USA\', \'GBR\', \'JPN\', \'EU\'). Supports multi-jurisdictional compliance mapping for global studies.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date on which this obligation was most recently reviewed for continued accuracy, regulatory alignment, and applicability. Used to identify overdue reviews and ensure the obligation register remains current ahead of inspections.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency' ;
    rdfs:comment 'How frequently compliance with this obligation must be monitored or assessed (e.g., continuous for real-time safety reporting obligations, annual for SOP review obligations, per_event for SAE reporting triggers). Drives the compliance monitoring calendar and QA review schedule. [ENUM-REF-CANDIDATE: continuous|daily|weekly|monthly|quarterly|semi_annual|annual|per_event|ad_hoc — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next periodic review of this obligation. Calculated from last_reviewed_date plus review_cycle_months. Triggers review workflow in MasterControl and compliance calendar alerts.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonComplianceConsequence rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Consequence' ;
    rdfs:comment 'Description of the regulatory, legal, or operational consequences of failing to meet this obligation (e.g., \'Warning Letter\', \'Clinical Hold\', \'Study Suspension\', \'Financial Penalty\', \'Data Exclusion from Submission\'). Used in risk-based compliance monitoring and sponsor communication.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationCategory rdf:type rdf:Property ;
    rdfs:label 'Obligation Category' ;
    rdfs:comment 'Business process category to which this obligation belongs, enabling grouping for audit scope planning and compliance monitoring. Examples include safety_reporting (SAE/SUSAR timelines), data_integrity (ALCOA+ requirements), informed_consent (ICF management), regulatory_submission (IND/NDA/BLA filings). [ENUM-REF-CANDIDATE: safety_reporting|data_integrity|informed_consent|site_management|regulatory_submission|record_retention|training|audit_inspection|privacy|financial_disclosure — promote to reference product]' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationStatus rdf:type rdf:Property ;
    rdfs:label 'Obligation Status' ;
    rdfs:comment 'Current lifecycle status of the obligation record: active (currently enforceable), superseded (replaced by a newer version), retired (no longer applicable), draft (under development), or under_review (being assessed for regulatory change impact). Drives which obligations are included in active audit scope.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyDescription rdf:type rdf:Property ;
    rdfs:label 'Penalty Description' ;
    rdfs:comment 'Specific description of financial or administrative penalties associated with non-compliance (e.g., \'Up to EUR 20 million or 4% of global annual turnover under GDPR\', \'Civil monetary penalties under 21 CFR Part 17\'). Supports risk quantification in compliance risk assessments.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyRegulationFlag rdf:type rdf:Property ;
    rdfs:label 'Privacy Regulation Flag' ;
    rdfs:comment 'Indicates whether this obligation is driven by or intersects with a patient data privacy regulation (GDPR, HIPAA, or equivalent). When True, additional data protection impact assessment and privacy controls are required. Supports privacy-by-design compliance monitoring.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Months' ;
    rdfs:comment 'Number of months between scheduled periodic reviews of this obligation to assess continued applicability, regulatory changes, and alignment with current SOPs (e.g., 12 for annual review, 6 for semi-annual). Drives the compliance calendar in MasterControl.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:secondaryResponsibleFunction rdf:type rdf:Property ;
    rdfs:label 'Secondary Responsible Function' ;
    rdfs:comment 'Secondary organizational function that shares accountability or provides support for fulfilling this obligation (e.g., \'Legal\', \'IT\', \'Finance\'). Captures cross-functional obligations where primary ownership is shared.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Source Document Reference' ;
    rdfs:comment 'Reference to the authoritative source document from which this obligation is derived, such as a Veeva Vault document ID, eTMF document number, or external regulatory publication reference (e.g., Federal Register citation, EMA guideline document number). Enables direct traceability to the source text.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorContractualReference rdf:type rdf:Property ;
    rdfs:label 'Sponsor Contractual Reference' ;
    rdfs:comment 'Reference to the specific sponsor contract, Clinical Trial Agreement (CTA), or Master Service Agreement (MSA) clause that establishes this obligation when source_type is \'contractual\' or \'sponsor\'. Enables traceability between contractual commitments and compliance monitoring activities.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectSafetyRelevance rdf:type rdf:Property ;
    rdfs:label 'Subject Safety Relevance' ;
    rdfs:comment 'Assessment of the degree to which non-compliance with this obligation could directly impact clinical trial subject safety. Critical obligations (e.g., SAE reporting, SUSAR notification) require immediate escalation upon non-compliance. Used to prioritize audit findings and CAPA urgency.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByReference rdf:type rdf:Property ;
    rdfs:label 'Superseded By Reference' ;
    rdfs:comment 'Reference number of the obligation that replaced this one when status is \'superseded\'. Enables forward navigation in the obligation version chain for regulatory change impact analysis.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timelineBasis rdf:type rdf:Property ;
    rdfs:label 'Timeline Basis' ;
    rdfs:comment 'Specifies the basis for calculating the reporting timeline: whether days are calendar or business days, and the triggering event from which the clock starts (e.g., from_awareness for SAE reporting, from_database_lock for CSR submission). Critical for accurate deadline computation.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCurriculumReference rdf:type rdf:Property ;
    rdfs:label 'Training Curriculum Reference' ;
    rdfs:comment 'Reference to the MasterControl training curriculum or course code required to demonstrate competency for this obligation (e.g., \'TRN-GCP-001\', \'TRN-SAE-003\'). Populated when training_required_flag is True.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolDeviationId rdf:type rdf:Property ;
    rdfs:label 'Protocol Deviation Id' ;
    rdfs:comment 'Primary key for protocol_deviation' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProtocolDeviation .

ind:protocolLabScheduleId rdf:type rdf:Property ;
    rdfs:label 'Protocol Lab Schedule Id' ;
    rdfs:comment 'Foreign key linking to laboratory.protocol_lab_schedule. Business justification: Protocol deviations for missed or incorrect lab assessments are evaluated against the protocol lab schedule. Linking the specific schedule requirement that was deviated from enables deviation classifi' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProtocolLabSchedule .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Foreign key linking to supply.shipment. Business justification: Shipment failures (delayed delivery causing missed dose window, wrong kits shipped) are a documented category of protocol deviations. Linking protocol_deviation to the causative shipment enables root ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:specimenCollectionId rdf:type rdf:Property ;
    rdfs:label 'Specimen Collection Id' ;
    rdfs:comment 'Foreign key linking to laboratory.specimen_collection. Business justification: Specimen collection errors (wrong tube, wrong time, insufficient volume) are among the most frequent protocol deviation types. specimen_collection has has_deviation and deviation_description flags. Li' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpecimenCollection .

ind:trialSubjectId rdf:type rdf:Property ;
    rdfs:label 'Trial Subject Id' ;
    rdfs:comment 'Reference to the study subject (patient) associated with this deviation, if applicable. Nullable for site-level or system-level deviations not tied to a specific subject.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrialSubject .

ind:visitId rdf:type rdf:Property ;
    rdfs:label 'Visit Id' ;
    rdfs:comment 'Reference to the monitoring visit during which this deviation was identified, if applicable. Links to the monitoring visit record for traceability.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SubjectVisit .

ind:auditReadinessStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Readiness Status' ;
    rdfs:comment 'Indicates the current audit readiness state of this deviation record, confirming that all required documentation, reporting, and CAPA activities are complete and the record is inspection-ready.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionSummary rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Summary' ;
    rdfs:comment 'Brief summary of the immediate corrective actions taken to address the deviation and prevent recurrence, prior to or independent of a formal CAPA. Captures site-level remediation steps.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedBy rdf:type rdf:Property ;
    rdfs:label 'Detected By' ;
    rdfs:comment 'The method or source by which the deviation was detected. Indicates whether it was found during CRA monitoring visit, site self-identification, sponsor audit, regulatory inspection, central data review, or subject report. Used for monitoring effectiveness metrics. [ENUM-REF-CANDIDATE: cra_monitoring|site_self_identified|sponsor_audit|regulatory_inspection|data_review|subject_report|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationDescription rdf:type rdf:Property ;
    rdfs:label 'Deviation Description' ;
    rdfs:comment 'Detailed narrative description of the protocol deviation, including what protocol requirement was not met, the circumstances under which it occurred, and any immediate actions taken. Sourced from the eCRF or CTMS deviation entry.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationRefNumber rdf:type rdf:Property ;
    rdfs:label 'Deviation Ref Number' ;
    rdfs:comment 'Externally-known, human-readable unique reference number assigned to the protocol deviation record, typically generated by the CTMS (Oracle Siebel CTMS) or EDC (Medidata Rave). Used for cross-system traceability and regulatory correspondence.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationStatus rdf:type rdf:Property ;
    rdfs:label 'Deviation Status' ;
    rdfs:comment 'Current workflow lifecycle state of the deviation record. \'Open\' indicates newly identified; \'under_review\' indicates active investigation; \'resolved\' indicates corrective action completed; \'closed\' indicates fully adjudicated and archived; \'escalated\' indicates elevated to sponsor or regulatory authority; \'voided\' indicates entered in error.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationType rdf:type rdf:Property ;
    rdfs:label 'Deviation Type' ;
    rdfs:comment 'Functional classification of the deviation describing which protocol requirement was violated. Common types include: eligibility, dosing, visit_window, prohibited_medication, consent, randomization, assessments, sample_collection, concomitant_medication, data_collection. [ENUM-REF-CANDIDATE: eligibility|dosing|visit_window|prohibited_medication|consent|randomization|assessments|sample_collection|concomitant_medication|data_collection — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryDate rdf:type rdf:Property ;
    rdfs:label 'Discovery Date' ;
    rdfs:comment 'The date on which the protocol deviation was first identified or discovered, which may differ from the occurrence date. Used to calculate detection lag and assess monitoring effectiveness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ecrfFormRef rdf:type rdf:Property ;
    rdfs:label 'Ecrf Form Ref' ;
    rdfs:comment 'Reference to the specific eCRF form or data point in Medidata Rave EDC that is associated with this deviation, enabling direct traceability to the source data record.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:includeInCsrFlag rdf:type rdf:Property ;
    rdfs:label 'Include In Csr Flag' ;
    rdfs:comment 'Indicates whether this deviation must be listed or summarized in the Clinical Study Report (CSR) per ICH E3 requirements. Major and important deviations are typically included.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irbIecReportedDate rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Reported Date' ;
    rdfs:comment 'The date on which the deviation was formally submitted to the IRB/IEC. Used to verify compliance with reporting timelines and to support audit readiness.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:irbIecReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Reporting Required' ;
    rdfs:comment 'Indicates whether this deviation must be reported to the Institutional Review Board (IRB) or Independent Ethics Committee (IEC) per applicable regulations and the IRB/IEC-approved protocol.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:occurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Occurrence Date' ;
    rdfs:comment 'The date on which the protocol deviation actually occurred (i.e., the date the protocol requirement was not met). This is the principal real-world event date per CDISC SDTM DVSTDTC.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:piNotifiedDate rdf:type rdf:Property ;
    rdfs:label 'Pi Notified Date' ;
    rdfs:comment 'The date on which the Principal Investigator (PI) was formally notified of the deviation. Required for GCP compliance and site management accountability.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:protocolRequirementRef rdf:type rdf:Property ;
    rdfs:label 'Protocol Requirement Ref' ;
    rdfs:comment 'Specific section, clause, or criterion number within the study protocol that was deviated from (e.g., \'Section 5.3 Inclusion Criterion 2\'). Enables precise traceability to the protocol document.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityReportedDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Reported Date' ;
    rdfs:comment 'The date on which the deviation was formally submitted to the applicable regulatory authority (FDA, EMA, PMDA, etc.), where regulatory reporting was required.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repeatDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Deviation Flag' ;
    rdfs:comment 'Indicates whether this deviation is a recurrence of a previously identified deviation of the same type at the same site or by the same subject. Used for trend analysis and escalation decisions.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedDate rdf:type rdf:Property ;
    rdfs:label 'Reported Date' ;
    rdfs:comment 'The date on which the deviation was formally reported to the sponsor, IRB/IEC, or regulatory authority as required. Used to assess compliance with reporting timelines.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'The date on which the deviation was resolved and corrective actions were confirmed as complete. Marks the end of the active deviation lifecycle.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Source System Record Number' ;
    rdfs:comment 'The native record identifier from the originating source system (e.g., Medidata Rave deviation ID or Oracle Siebel CTMS deviation record ID). Enables upstream reconciliation and audit trail.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorReportedDate rdf:type rdf:Property ;
    rdfs:label 'Sponsor Reported Date' ;
    rdfs:comment 'The date on which the deviation was formally communicated to the sponsor. Used to verify compliance with sponsor notification timelines per the Clinical Trial Agreement.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sponsorReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Sponsor Reporting Required' ;
    rdfs:comment 'Indicates whether this deviation must be formally reported to the study sponsor per the Clinical Trial Agreement and sponsor SOPs.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subjectExcludedFromPpFlag rdf:type rdf:Property ;
    rdfs:label 'Subject Excluded From Pp Flag' ;
    rdfs:comment 'Indicates whether this deviation resulted in the exclusion of the subject from the Per Protocol (PP) analysis population, as determined by the biostatistics team per the Statistical Analysis Plan (SAP).' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subjectImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Subject Impact Assessment' ;
    rdfs:comment 'Assessment of whether the deviation had an impact on subject safety, rights, or well-being. Used to determine reporting obligations and CAPA urgency.' ;
    rdfs:domain ind:ProtocolDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmfDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Tmf Document Ref' ;
    rdfs:comment 'Reference identifier for the deviation documentation filed in the electronic Trial Master File (eTMF) in Veeva Vault. Enables cross-system document traceability for inspection readiness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitName rdf:type rdf:Property ;
    rdfs:label 'Visit Name' ;
    rdfs:comment 'Name or identifier of the study visit (e.g., \'Week 4 Visit\', \'Screening\') during which the deviation occurred, as defined in the protocol schedule of assessments.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityEventId rdf:type rdf:Property ;
    rdfs:label 'Quality Event Id' ;
    rdfs:comment 'Unique system-generated identifier for the quality event record within the MasterControl quality management module. Serves as the primary key for all downstream references to this quality event.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityEvent .

ind:identifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Identified By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Quality event management requires tracking the specific employee who identified the event for GCP accountability, trend analysis by identifier role, and inspection readiness. \'identified_by\' is a plai' ;
    rdfs:domain ind:QualityEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:manufactureBatchId rdf:type rdf:Property ;
    rdfs:label 'Manufacture Batch Id' ;
    rdfs:comment 'Foreign key linking to supply.manufacture_batch. Business justification: Manufacturing batch failures, OOS results, and QP release holds are quality events under GMP. Linking quality_event to the affected manufacture_batch enables batch recall traceability, GMP deviation m' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManufactureBatch .

ind:parentEventQualityEventId rdf:type rdf:Property ;
    rdfs:label 'Parent Event Quality Event Id' ;
    rdfs:comment 'Reference to a prior quality event record that this event is a recurrence of, or a related parent event in a cluster of related quality issues. Populated when recurrence_flag is True or when events are grouped for systemic analysis. Null for first-occurrence events.' ;
    rdfs:domain ind:QualityEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualityEvent .

ind:specimenShipmentId rdf:type rdf:Property ;
    rdfs:label 'Specimen Shipment Id' ;
    rdfs:comment 'Foreign key linking to laboratory.specimen_shipment. Business justification: Temperature excursions during specimen shipment are a named quality event type in clinical trials. specimen_shipment has temperature_excursion_flag. Linking the shipment to the formal quality event re' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpecimenShipment .

ind:subjectConsentId rdf:type rdf:Property ;
    rdfs:label 'Subject Consent Id' ;
    rdfs:comment 'Foreign key linking to consent.subject_consent. Business justification: Quality events in clinical trials frequently arise from consent process failures (wrong ICF version used, consent obtained after procedures, missing signatures). Linking quality_event to subject_conse' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SubjectConsent .

ind:affectedDataDomain rdf:type rdf:Property ;
    rdfs:label 'Affected Data Domain' ;
    rdfs:comment 'The CDISC SDTM or clinical data domain affected by the quality event (e.g., AE, CM, LB, VS, DM, DS, EX). Used for data management impact assessment, targeted re-monitoring, and SDTM submission quality review. Null if the event is not data-domain-specific.' ;
    rdfs:domain ind:QualityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProcess rdf:type rdf:Property ;
    rdfs:label 'Affected Process' ;
    rdfs:comment 'The specific clinical trial business process or functional area impacted by the quality event (e.g., informed consent management, adverse event reporting, randomization, data entry, site monitoring, regulatory submission). Used for process-level quality trending and SOP compliance analytics.' ;
    rdfs:domain ind:QualityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCount rdf:type rdf:Property ;
    rdfs:label 'Error Count' ;
    rdfs:comment 'Number of errors, discrepancies, or non-conformances identified within the QC sample reviewed. Used in conjunction with sample_size to compute error rate for quality trending and threshold monitoring.' ;
    rdfs:domain ind:QualityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:errorRate rdf:type rdf:Property ;
    rdfs:label 'Error Rate' ;
    rdfs:comment 'Proportion of errors identified relative to the total sample size (error_count / sample_size). Expressed as a decimal (e.g., 0.0250 = 2.50%). Used for quality threshold monitoring, KPI reporting, and CAPA escalation triggers. Null if sample_size is zero or not applicable.' ;
    rdfs:domain ind:QualityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Detailed narrative description of the quality event, including what was observed, where it occurred, and the potential impact on subject safety, data integrity, or regulatory compliance. Captured at time of identification per ALCOA+ contemporaneous documentation standards.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Reference Number' ;
    rdfs:comment 'Human-readable, externally-visible reference number assigned to the quality event upon creation in MasterControl. Used in audit trails, regulatory correspondence, and CAPA linkage. Format: QE-YYYY-NNNNNN.' ;
    rdfs:domain ind:QualityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle status of the quality event within the MasterControl workflow. Open: newly identified, awaiting triage. Under Review: QA/QC team actively investigating. Pending CAPA: CAPA determination made, awaiting CAPA initiation. Closed: event resolved and verified. Cancelled: event determined to be invalid or duplicate.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Classification of the quality event by its nature. Drives routing, escalation rules, and CAPA determination logic. Values: data_quality_issue (EDC/eCRF data errors), process_non_compliance (GCP/SOP deviation), system_failure (EDC, CTMS, or IRT system outage/error), vendor_quality_issue (CRO, lab, or third-party vendor failure), qc_review_finding (finding from a formal QC review activity).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identificationSource rdf:type rdf:Property ;
    rdfs:label 'Identification Source' ;
    rdfs:comment 'The activity or mechanism through which the quality event was detected. Drives root cause analysis and process improvement analytics. [ENUM-REF-CANDIDATE: qc_review|self_inspection|routine_monitoring|sdv|audit|regulatory_inspection|proactive_surveillance|system_alert — promote to reference product]' ;
    rdfs:domain ind:QualityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbIecReportable rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Reportable' ;
    rdfs:comment 'Indicates whether this quality event must be reported to the Institutional Review Board (IRB) or Independent Ethics Committee (IEC) overseeing the study. True: IRB/IEC notification required. False: not required. Driven by protocol deviation severity and subject safety impact.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:protocolDeviationCategory rdf:type rdf:Property ;
    rdfs:label 'Protocol Deviation Category' ;
    rdfs:comment 'Classification of the quality event as a protocol deviation per ICH E6(R2) and sponsor requirements. Major: deviation that may affect subject safety or data integrity. Minor: deviation with minimal impact. Not Applicable: event is not a protocol deviation (e.g., system failure, vendor issue). Required for regulatory submission deviation summaries.' ;
    rdfs:domain ind:QualityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcOutcome rdf:type rdf:Property ;
    rdfs:label 'Qc Outcome' ;
    rdfs:comment 'Overall outcome of the QC review activity that generated this quality event. Pass: quality threshold met, no significant issues. Fail: quality threshold exceeded, formal action required. Conditional Pass: threshold borderline, enhanced monitoring required. Applicable when identification_source is qc_review.' ;
    rdfs:domain ind:QualityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityNotified rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Notified' ;
    rdfs:comment 'Name of the regulatory authority (e.g., FDA, EMA, MHRA, PMDA, TGA, Health Canada) notified of this quality event, if applicable. Null if regulatory_reportability is not_reportable. Supports regulatory submission tracking and inspection readiness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportability rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportability' ;
    rdfs:comment 'Assessment of whether this quality event requires reporting to a regulatory authority (FDA, EMA, MHRA, etc.) or to the sponsor. Reportable: must be submitted to regulatory body. Not Reportable: no regulatory notification required. Under Assessment: reportability determination pending QA review.' ;
    rdfs:domain ind:QualityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Description' ;
    rdfs:comment 'Narrative description of how the quality event was resolved, including actions taken, verification of effectiveness, and confirmation that the issue has been addressed. Required for event closure in MasterControl and supports regulatory inspection readiness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'Name or user identifier of the Quality Assurance (QA) professional who reviewed and assessed the quality event in MasterControl. Supports 21 CFR Part 11 electronic signature audit trail and GCP oversight accountability.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Risk-based severity classification of the quality event per GCP quality standards. Critical: may impact subject safety or data integrity requiring immediate action. Major: significant GCP deviation with potential regulatory impact. Minor: low-risk deviation with limited impact. Observation: informational finding with no immediate compliance risk.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsmbReviewId rdf:type rdf:Property ;
    rdfs:label 'Dsmb Review Id' ;
    rdfs:comment 'Foreign key linking to safety.dsmb_review. Business justification: DSMB reviews with stopping rule triggers or safety concerns requiring regulatory notification generate regulatory commitments. dsmb_review.regulatory_notification_required flag indicates this workflow' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DsmbReview .

ind:primaryRegulatoryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Employee Id' ;
    rdfs:comment 'Identifier of the individual (employee or contractor) accountable for delivering the committed action. Links to the workforce record for the designated commitment owner.' ;
    rdfs:domain ind:RegulatoryCommitment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryRegulatoryResponsibleOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Regulatory Responsible Owner Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:RegulatoryCommitment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryRegulatoryApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Regulatory Approved By Employee Id' ;
    rdfs:comment 'Identifier of the Quality Assurance (QA) or Regulatory Affairs approver who reviewed and authorized this commitment record before submission to the regulatory authority.' ;
    rdfs:domain ind:RegulatoryCommitment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:authorityAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Authority Acknowledgement Date' ;
    rdfs:comment 'Date on which the regulatory authority formally acknowledged or accepted the commitment response or closure evidence. Marks the external closure of the commitment from the agency perspective.' ;
    rdfs:domain ind:RegulatoryCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorityClosureStatus rdf:type rdf:Property ;
    rdfs:label 'Authority Closure Status' ;
    rdfs:comment 'Status of the regulatory authority\'s review of the commitment response. Indicates whether the agency has accepted the response, rejected it, requested additional information, or has it pending review.' ;
    rdfs:domain ind:RegulatoryCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentDescription rdf:type rdf:Property ;
    rdfs:label 'Commitment Description' ;
    rdfs:comment 'Detailed narrative description of the regulatory commitment as formally communicated to the regulatory authority. Captures the full scope of what was committed, including context from the originating finding or query.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Commitment Reference Number' ;
    rdfs:comment 'Externally-known, human-readable unique reference number assigned to the regulatory commitment (e.g., RC-2024-00123). Used in correspondence with regulatory authorities and in audit trails.' ;
    rdfs:domain ind:RegulatoryCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Commitment Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory commitment. Tracks progression from open through in-progress, completed, overdue, cancelled, or pending verification by the regulatory authority.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentTitle rdf:type rdf:Property ;
    rdfs:label 'Commitment Title' ;
    rdfs:comment 'Short, human-readable title summarizing the regulatory commitment. Used in dashboards, reports, and regulatory correspondence for quick identification.' ;
    rdfs:domain ind:RegulatoryCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentType rdf:type rdf:Property ;
    rdfs:label 'Commitment Type' ;
    rdfs:comment 'Categorical classification of the nature of the commitment (e.g., procedural change, training, system enhancement, documentation update, process improvement, labeling revision). Supports portfolio-level analysis of commitment categories. [ENUM-REF-CANDIDATE: procedural|training|system|documentation|process_improvement|labeling|other — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedAction rdf:type rdf:Property ;
    rdfs:label 'Committed Action' ;
    rdfs:comment 'Specific action(s) formally committed to the regulatory authority in response to the originating finding or query. Describes what the organization has pledged to do, distinct from the broader commitment description.' ;
    rdfs:domain ind:RegulatoryCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Committed Completion Date' ;
    rdfs:comment 'The date formally committed to the regulatory authority by which the action will be completed. This is the externally-binding deadline communicated in the regulatory response letter or inspection response.' ;
    rdfs:domain ind:RegulatoryCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessCheckRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Check Required Flag' ;
    rdfs:comment 'Indicates whether a post-completion effectiveness check is required to verify that the committed action has achieved its intended outcome and prevented recurrence.' ;
    rdfs:domain ind:RegulatoryCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gcpRequirementReference rdf:type rdf:Property ;
    rdfs:label 'Gcp Requirement Reference' ;
    rdfs:comment 'Reference to the specific GCP guideline, regulation, or standard that was cited in the originating regulatory finding (e.g., ICH E6(R2) Section 5.18, 21 CFR 312.62). Enables compliance gap analysis.' ;
    rdfs:domain ind:RegulatoryCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingActionReference rdf:type rdf:Property ;
    rdfs:label 'Originating Action Reference' ;
    rdfs:comment 'The official reference number or identifier of the regulatory action that generated this commitment (e.g., FDA Warning Letter reference number, inspection report number, agency query tracking number). Enables direct traceability to the source regulatory document.' ;
    rdfs:domain ind:RegulatoryCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingActionType rdf:type rdf:Property ;
    rdfs:label 'Originating Action Type' ;
    rdfs:comment 'Classification of the regulatory action that gave rise to this commitment. Distinguishes between inspection findings, FDA Warning Letters, Complete Response Letters (CRL), agency queries, Untitled Letters, and consent decrees. Drives workflow and escalation rules. [ENUM-REF-CANDIDATE: inspection_finding|warning_letter|complete_response_letter|agency_query|untitled_letter|consent_decree — promote to reference product]' ;
    rdfs:domain ind:RegulatoryCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Response Due Date' ;
    rdfs:comment 'The deadline by which the organization must submit a formal written response to the regulatory authority regarding this commitment. Distinct from the committed_completion_date, which is the action delivery date.' ;
    rdfs:domain ind:RegulatoryCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryResponseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Response Submitted Date' ;
    rdfs:comment 'The date on which the formal written response was submitted to the regulatory authority. Used to confirm timely submission and calculate response latency.' ;
    rdfs:domain ind:RegulatoryCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Id' ;
    rdfs:comment 'Unique system-generated identifier for each quality risk assessment record within the compliance domain. Serves as the primary key for the risk_assessment data product.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskAssessment .

ind:depotId rdf:type rdf:Property ;
    rdfs:label 'Depot Id' ;
    rdfs:comment 'Foreign key linking to supply.depot. Business justification: Depot qualification risk assessments evaluate cold chain capability, geographic coverage, and GMP compliance. Linking risk_assessment to the assessed depot enables risk-based depot selection, qualific' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:impMasterId rdf:type rdf:Property ;
    rdfs:label 'Imp Master Id' ;
    rdfs:comment 'Foreign key linking to supply.imp_master. Business justification: IMP-specific risk assessments cover stability risks, cold chain requirements, controlled substance handling, and biological product safety. Linking risk_assessment to imp_master enables product-level ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ImpMaster .

ind:primaryRiskOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Risk Owner Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryRiskApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Risk Approved By Employee Id' ;
    rdfs:comment 'Reference to the QA Manager or authorized signatory who formally approved the risk assessment in MasterControl. Required for 21 CFR Part 11 electronic signature compliance.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:riskId rdf:type rdf:Property ;
    rdfs:label 'Risk Id' ;
    rdfs:comment 'Foreign key linking to program.program_risk. Business justification: GCP compliance risk assessments are often triggered by or linked to program-level strategic risks. Linking compliance.risk_assessment to program.program_risk supports cross-domain risk traceability, e' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Risk .

ind:signalId rdf:type rdf:Property ;
    rdfs:label 'Signal Id' ;
    rdfs:comment 'Foreign key linking to safety.safety_signal. Business justification: ICH E6 R2 risk-based monitoring requires that identified safety signals directly inform quality risk assessments. Risk management plans are updated when signals are detected. A clinical-research exper' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Signal .

ind:tertiaryRiskAssessedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Risk Assessed By Employee Id' ;
    rdfs:comment 'Reference to the individual who conducted and documented the risk assessment (typically a QA Specialist or CRA). Distinct from the risk owner who is accountable for ongoing management.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'The date on which the risk assessment was formally conducted and documented. Represents the principal business event date for this record. Used for trend analysis and review frequency tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current lifecycle state of the risk assessment record in MasterControl: draft (being authored), in_review (under QA/sponsor review), approved (formally accepted), active (monitoring in progress), closed (risk resolved or accepted), cancelled (assessment voided).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlMeasuresDescription rdf:type rdf:Property ;
    rdfs:label 'Control Measures Description' ;
    rdfs:comment 'Narrative description of the existing or planned quality control and risk mitigation measures applied to reduce the identified risk (e.g., enhanced SDV, targeted monitoring, additional training, SOP updates, EDC edit checks). Sourced from MasterControl.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gcpImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Gcp Impact Flag' ;
    rdfs:comment 'Indicates whether the identified risk has a direct impact on Good Clinical Practice (GCP) compliance. Drives escalation to QA leadership and potential regulatory notification obligations.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identifiedGaps rdf:type rdf:Property ;
    rdfs:label 'Identified Gaps' ;
    rdfs:comment 'Narrative description of quality gaps, process deficiencies, or compliance vulnerabilities identified during the risk assessment (e.g., missing SDV documentation, incomplete ICF versions, delayed SAE reporting). Drives CAPA initiation and remediation planning.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentDetectabilityScore rdf:type rdf:Property ;
    rdfs:label 'Inherent Detectability Score' ;
    rdfs:comment 'Numeric score (typically 1–5) representing the ability to detect the risk before it causes harm, prior to control measures. Used in FMEA-style risk scoring (Risk Priority Number = Likelihood × Impact × Detectability).' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inherentImpactScore rdf:type rdf:Property ;
    rdfs:label 'Inherent Impact Score' ;
    rdfs:comment 'Numeric score (typically 1–5) representing the severity of impact on patient safety, data integrity, or regulatory compliance if the risk materializes before controls are applied. Component of the inherent risk score calculation.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inherentLikelihoodScore rdf:type rdf:Property ;
    rdfs:label 'Inherent Likelihood Score' ;
    rdfs:comment 'Numeric score (typically 1–5) representing the probability of the risk occurring before any control measures are applied. Component of the inherent risk score calculation per ICH Q9 risk estimation methodology.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inherentRiskRating rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Rating' ;
    rdfs:comment 'Qualitative risk rating derived from the inherent risk score before controls: critical, high, medium, or low. Used for risk prioritization, escalation thresholds, and sponsor/QA reporting dashboards.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentRiskScore rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Score' ;
    rdfs:comment 'Composite numeric risk score calculated before control measures are applied, typically derived from likelihood, impact, and detectability scores (e.g., product or weighted sum). Establishes the baseline risk level for prioritization.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remediationPlan rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan' ;
    rdfs:comment 'Documented plan for addressing identified gaps and reducing residual risk, including specific actions, responsible parties, and target timelines. Distinct from CAPA (which is a formal corrective/preventive action record); this is the risk-level remediation narrative.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of remediation activities for identified gaps: not_started, in_progress, completed, or overdue. Supports inspection readiness dashboards and QA oversight reporting.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationTargetDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Target Date' ;
    rdfs:comment 'Target completion date for the remediation actions identified in the risk assessment. Used for tracking remediation progress and escalation when overdue.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:residualDetectabilityScore rdf:type rdf:Property ;
    rdfs:label 'Residual Detectability Score' ;
    rdfs:comment 'Numeric score (typically 1–5) representing the ability to detect the risk after control measures are in place. Component of the residual risk score calculation.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualImpactScore rdf:type rdf:Property ;
    rdfs:label 'Residual Impact Score' ;
    rdfs:comment 'Numeric score (typically 1–5) representing the severity of impact after control measures have been applied. Used to calculate the residual risk score.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualLikelihoodScore rdf:type rdf:Property ;
    rdfs:label 'Residual Likelihood Score' ;
    rdfs:comment 'Numeric score (typically 1–5) representing the probability of the risk occurring after control measures have been applied. Used to calculate the residual risk score.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualRiskRating rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Rating' ;
    rdfs:comment 'Qualitative risk rating after control measures are applied: critical, high, medium, or low. Drives risk acceptance decisions, escalation to DSMB/DMC, and CAPA initiation. A residual rating of critical or high typically triggers mandatory CAPA.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskScore rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Score' ;
    rdfs:comment 'Composite numeric risk score calculated after control measures are applied. Represents the remaining risk exposure. Compared against risk acceptance thresholds to determine if further mitigation is required.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Days' ;
    rdfs:comment 'Defined interval in calendar days between periodic re-assessments of this risk (e.g., 30, 60, 90, 180 days). Drives scheduling of next_review_date and ensures ongoing risk monitoring per ICH Q9 principles.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskAcceptanceDecision rdf:type rdf:Property ;
    rdfs:label 'Risk Acceptance Decision' ;
    rdfs:comment 'Formal decision on whether the residual risk level is acceptable: accepted (risk within tolerance), not_accepted (requires further mitigation or CAPA), or conditionally_accepted (accepted with defined monitoring conditions). Documented per ICH Q9 risk acceptance principles.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'High-level classification of the risk domain being assessed: data_integrity (ALCOA+ violations, EDC issues), patient_safety (adverse event under-reporting, protocol deviations), regulatory_compliance (GCP, ICH, FDA/EMA non-compliance), or operational (site performance, resource, supply chain). Drives escalation and reporting pathways.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Detailed narrative describing the identified risk, including the potential failure mode, root cause hypothesis, and potential impact on study quality, patient safety, or regulatory compliance. Sourced from MasterControl risk assessment form.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskOwnerDepartment rdf:type rdf:Property ;
    rdfs:label 'Risk Owner Department' ;
    rdfs:comment 'Organizational department of the risk owner (e.g., Quality Assurance, Data Management, Clinical Operations, Regulatory Affairs). Used for departmental risk reporting and workload analysis.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskSubcategory rdf:type rdf:Property ;
    rdfs:label 'Risk Subcategory' ;
    rdfs:comment 'More granular classification within the risk category (e.g., \'Source Data Verification\', \'Informed Consent Process\', \'SAE Reporting Timeliness\', \'Protocol Deviation Management\'). Enables detailed risk trending and root cause analysis.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scope rdf:type rdf:Property ;
    rdfs:label 'Scope' ;
    rdfs:comment 'Defines the level at which the risk assessment was conducted: study-level (entire protocol), site-level (specific investigational site), process-level (e.g., data management, consent), system-level (e.g., EDC, CTMS), or inspection-readiness (pre-inspection GCP audit preparation).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Author Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: GCP document control requires traceable authorship of SOPs linked to qualified employees for inspection readiness and change control audits. \'author_name\' is a plain-text denormalization; a proper FK ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededSopComplianceSopId rdf:type rdf:Property ;
    rdfs:label 'Superseded Sop Compliance Sop Id' ;
    rdfs:comment 'Reference to the sop record that this version supersedes. Supports version lineage navigation and ensures the document control chain of custody is maintained for regulatory inspection.' ;
    rdfs:domain ind:ComplianceSop ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceSop .

ind:applicableRoles rdf:type rdf:Property ;
    rdfs:label 'Applicable Roles' ;
    rdfs:comment 'Comma-separated list of job roles or role groups required to be trained on and comply with this SOP (e.g., CRA, CRC, PI, QA Manager, Data Manager). Drives training assignment generation in MasterControl.' ;
    rdfs:domain ind:ComplianceSop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingReference rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Reference' ;
    rdfs:comment 'Reference identifier of the internal or external audit finding that prompted this SOP revision or creation. Supports traceability from audit observations to corrective document updates.' ;
    rdfs:domain ind:ComplianceSop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Reference Number' ;
    rdfs:comment 'Reference number of any CAPA record in MasterControl that triggered the creation or revision of this SOP version. Links SOP updates to root cause corrective actions identified through audits, inspections, or deviation investigations.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeControlNumber rdf:type rdf:Property ;
    rdfs:label 'Change Control Number' ;
    rdfs:comment 'Reference number of the change control record in MasterControl that authorized the creation or revision of this SOP version. Provides traceability from the SOP to the formal change management process.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationClassificationRelevance rdf:type rdf:Property ;
    rdfs:label 'Deviation Classification Relevance' ;
    rdfs:comment 'Indicates the severity classification of protocol deviations that non-compliance with this SOP would typically generate (critical, major, minor). Used by QA to pre-classify deviation risk and prioritize SOP compliance monitoring.' ;
    rdfs:domain ind:ComplianceSop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCategory rdf:type rdf:Property ;
    rdfs:label 'Document Category' ;
    rdfs:comment 'Functional category grouping for the SOP within the document management taxonomy (e.g., Quality Management, Clinical Operations, Data Management, Regulatory Affairs, Safety, Laboratory, Finance). Supports document library navigation and compliance reporting. [ENUM-REF-CANDIDATE: quality_management|clinical_operations|data_management|regulatory_affairs|safety|laboratory|finance|human_resources|supply_chain|information_technology — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStatus rdf:type rdf:Property ;
    rdfs:label 'Document Status' ;
    rdfs:comment 'Current lifecycle state of the SOP document within the quality management system workflow. Controls whether the SOP is actionable for training and compliance purposes. \'approved\' is the only status permitting operational use.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classification of the document within the quality management system hierarchy. SOPs define mandatory procedures; work instructions provide step-by-step task guidance; policies set organizational rules; guidance documents are advisory.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicSignatureRequired rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Required' ;
    rdfs:comment 'Indicates whether this SOP requires electronic signatures for approval in compliance with FDA 21 CFR Part 11 and EU Annex 11 electronic records requirements. When True, wet signatures are not acceptable as the sole approval mechanism.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicApplicability rdf:type rdf:Property ;
    rdfs:label 'Geographic Applicability' ;
    rdfs:comment 'Countries or regions where this SOP is applicable, expressed as ISO 3166-1 alpha-3 country codes or region labels (e.g., USA, GBR, DEU, GLOBAL). Relevant for multi-regional trials where regulatory requirements differ by jurisdiction.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mastercontrolDocNumber rdf:type rdf:Property ;
    rdfs:label 'Mastercontrol Doc Number' ;
    rdfs:comment 'Native document identifier assigned by the MasterControl quality management system. Used for direct cross-reference and deep-linking back to the source system record for audit trail and change control purposes.' ;
    rdfs:domain ind:ComplianceSop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerDepartment rdf:type rdf:Property ;
    rdfs:label 'Owner Department' ;
    rdfs:comment 'Name of the organizational department accountable for authoring, maintaining, and periodically reviewing this SOP (e.g., Quality Assurance, Data Management, Regulatory Affairs). Determines the primary escalation path for SOP-related queries.' ;
    rdfs:domain ind:ComplianceSop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerRole rdf:type rdf:Property ;
    rdfs:label 'Owner Role' ;
    rdfs:comment 'Job role or title of the individual responsible for the SOP within the owning department (e.g., QA Manager, Director of Data Management). Used for accountability tracking and escalation in audit findings.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentSopNumber rdf:type rdf:Property ;
    rdfs:label 'Parent Sop Number' ;
    rdfs:comment 'SOP number of the higher-level or governing SOP under which this SOP sits in the document hierarchy (e.g., a site-specific SOP may reference a global SOP as its parent). Supports hierarchical document structure navigation.' ;
    rdfs:domain ind:ComplianceSop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purposeDescription rdf:type rdf:Property ;
    rdfs:label 'Purpose Description' ;
    rdfs:comment 'Brief statement of the business purpose and objective of the SOP, summarizing what process it governs and why it exists. Sourced from the SOP document\'s purpose/objective section.' ;
    rdfs:domain ind:ComplianceSop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qmsWorkflowStage rdf:type rdf:Property ;
    rdfs:label 'Qms Workflow Stage' ;
    rdfs:comment 'Current stage of the SOP within the MasterControl quality management system workflow. More granular than document_status; tracks the specific workflow step the document is in during its lifecycle (e.g., authoring, peer review, QA review, approval routing). [ENUM-REF-CANDIDATE: authoring|peer_review|qa_review|approval|effective|periodic_review|retirement — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ComplianceSop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis' ;
    rdfs:comment 'Primary regulatory practice standard(s) that this SOP is designed to satisfy: Good Clinical Practice (GCP), Good Laboratory Practice (GLP), Good Manufacturing Practice (GMP), or applicable combinations. Drives which regulatory inspections this SOP is relevant to.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReferences rdf:type rdf:Property ;
    rdfs:label 'Regulatory References' ;
    rdfs:comment 'Free-text or structured list of specific regulatory citations, guidelines, and standards that this SOP implements or references (e.g., ICH E6(R2) Section 5.18, FDA 21 CFR Part 312, EU CTR 536/2014 Article 47). Supports regulatory inspection readiness and gap analysis.' ;
    rdfs:domain ind:ComplianceSop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedSopNumbers rdf:type rdf:Property ;
    rdfs:label 'Related Sop Numbers' ;
    rdfs:comment 'Comma-separated list of SOP numbers that are cross-referenced by this SOP (e.g., parent SOPs, companion procedures, referenced work instructions). Supports document dependency mapping and impact analysis during revisions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Review Due Date' ;
    rdfs:comment 'Scheduled date by which the SOP owner must initiate a periodic review to confirm continued applicability and accuracy. May precede the expiry date to allow time for revision and approval before expiry.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionSummary rdf:type rdf:Property ;
    rdfs:label 'Revision Summary' ;
    rdfs:comment 'Brief narrative describing the nature and rationale of changes made in this version relative to the superseded version (e.g., \'Updated to reflect ICH E6(R3) requirements; added remote monitoring guidance\'). Required for change control documentation.' ;
    rdfs:domain ind:ComplianceSop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopNumber rdf:type rdf:Property ;
    rdfs:label 'Sop Number' ;
    rdfs:comment 'Externally-known, human-readable document control number assigned to the SOP within MasterControl (e.g., QA-GCP-001). Serves as the business identifier used in audit trails, regulatory submissions, and training records. Unique per SOP title across all versions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxApplicable rdf:type rdf:Property ;
    rdfs:label 'Sox Applicable' ;
    rdfs:comment 'Indicates whether this SOP governs financial reporting or internal control processes subject to SOX compliance requirements (e.g., finance, procurement, project accounting SOPs). Relevant for publicly-listed sponsors and CROs.' ;
    rdfs:domain ind:ComplianceSop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded Version Number' ;
    rdfs:comment 'Version number of the immediately preceding SOP version that this current version replaces. Enables version lineage tracing and ensures retired versions are correctly linked in the document control audit trail.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompletionDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Training Completion Deadline Days' ;
    rdfs:comment 'Number of calendar days from the SOP effective date within which all applicable staff must complete the required training. Used by MasterControl to auto-calculate individual training due dates and trigger overdue notifications.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sopTrainingRecordId rdf:type rdf:Property ;
    rdfs:label 'Sop Training Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each SOP training record in the MasterControl training management module. Primary key for this transactional entity. Entity role: TRANSACTION_HEADER — captures a discrete training completion event with its own lifecycle.' ;
    rdfs:domain ind:SopTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:electronicSignatureId rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Id' ;
    rdfs:comment 'The unique identifier of the 21 CFR Part 11-compliant electronic signature applied by the staff member to confirm training completion. Mandatory for GCP-regulated training records. Links to the electronic signature audit trail in MasterControl.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Signature .

ind:primarySopEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sop Employee Id' ;
    rdfs:comment 'Identifier of the staff member (employee, contractor, or investigator) who completed or is required to complete the SOP training. Links to the workforce party record. Satisfies TRANSACTION_HEADER PARTY_REFERENCE category.' ;
    rdfs:domain ind:SopTrainingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sopTrainingRequirementId rdf:type rdf:Property ;
    rdfs:label 'Sop Training Requirement Id' ;
    rdfs:comment 'Foreign key linking to compliance.sop_training_requirement. Business justification: A training record documents the completion of a training requirement. Linking sop_training_record.sop_training_requirement_id → sop_training_requirement.sop_training_requirement_id creates the critica' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SopTrainingRequirement .

ind:trainingPlanId rdf:type rdf:Property ;
    rdfs:label 'Training Plan Id' ;
    rdfs:comment 'Identifier of the training plan or curriculum that mandated this SOP training record. Links to the role-based or study-specific training plan in MasterControl that defines required SOPs for a given staff role or study assignment.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingPlan .

ind:assessmentPassed rdf:type rdf:Property ;
    rdfs:label 'Assessment Passed' ;
    rdfs:comment 'Indicates whether the staff member achieved a passing score on the training assessment. True if assessment_score >= passing_score_threshold; False if below threshold; Null if no assessment was required for this training method.' ;
    rdfs:domain ind:SopTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assessmentScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Score' ;
    rdfs:comment 'Numeric score achieved by the staff member on the post-training assessment or quiz, expressed as a percentage (0.00–100.00). Applicable only for training methods that include a formal assessment (e-learning, classroom). Null for read-and-understand method. Satisfies TRANSACTION_HEADER QUANTITATIVE_RESULT category.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attemptNumber rdf:type rdf:Property ;
    rdfs:label 'Attempt Number' ;
    rdfs:comment 'Sequential attempt number for this training record, indicating how many times the staff member has attempted the training or assessment for this SOP version. First attempt = 1. Supports quality metrics and identification of staff requiring additional support.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'The date on which the staff member completed the SOP training. For read-and-understand, this is the date the staff member signed off. For e-learning, this is the date the module was completed. Satisfies TRANSACTION_HEADER BUSINESS_EVENT_TIMESTAMP category (date precision appropriate for training compliance).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Precise date and time at which the training was electronically recorded as completed in MasterControl. Supports 21 CFR Part 11 electronic records requirements and ALCOA+ contemporaneous documentation standards. Distinct from completion_date which captures the business event date.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Organizational department or functional unit of the staff member at the time of training (e.g., Clinical Operations, Data Management, Biostatistics, Quality Assurance). Used for departmental training compliance reporting and gap analysis.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrentVersionTraining rdf:type rdf:Property ;
    rdfs:label 'Is Current Version Training' ;
    rdfs:comment 'Indicates whether this training record corresponds to the currently effective version of the SOP. True if the sop_version matches the current approved version; False if the staff member was trained on a superseded version. Critical for GCP inspection readiness checks.' ;
    rdfs:domain ind:SopTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passingScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Passing Score Threshold' ;
    rdfs:comment 'The minimum assessment score percentage required to achieve a passing result for this SOP training (e.g., 80.00%). Enables determination of pass/fail outcome and supports quality metrics on training effectiveness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:signatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Signature Timestamp' ;
    rdfs:comment 'The precise date and time at which the staff member applied their electronic signature to confirm training completion. Required for 21 CFR Part 11 compliance and ALCOA+ contemporaneous documentation. Distinct from completion_timestamp which records system processing time.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sopCategory rdf:type rdf:Property ;
    rdfs:label 'Sop Category' ;
    rdfs:comment 'Functional category of the SOP being trained on (e.g., Clinical Operations, Data Management, Safety Reporting, Regulatory Affairs, Quality Assurance, Laboratory). Enables category-level compliance reporting and training gap analysis by functional area. [ENUM-REF-CANDIDATE: clinical_operations|data_management|safety_reporting|regulatory_affairs|quality_assurance|laboratory|finance|it_systems|human_resources — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Source Record Number' ;
    rdfs:comment 'The native record identifier from the source operational system (e.g., MasterControl internal training record ID). Enables traceability back to the originating system for audit and reconciliation purposes per ALCOA+ principles.' ;
    rdfs:domain ind:SopTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staffFullName rdf:type rdf:Property ;
    rdfs:label 'Staff Full Name' ;
    rdfs:comment 'Full name of the staff member who completed or is required to complete the training. Denormalized for audit trail completeness and GCP inspection readiness per ALCOA+ principles. Supports historical record integrity.' ;
    rdfs:domain ind:SopTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staffRole rdf:type rdf:Property ;
    rdfs:label 'Staff Role' ;
    rdfs:comment 'The job role or function of the staff member at the time of training (e.g., Clinical Research Associate, Principal Investigator, Data Manager, Biostatistician). Captured at training time for historical accuracy. Used to verify role-appropriate SOP training coverage during GCP inspections.' ;
    rdfs:domain ind:SopTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainerName rdf:type rdf:Property ;
    rdfs:label 'Trainer Name' ;
    rdfs:comment 'Full name of the qualified trainer who delivered the training. Denormalized for audit trail completeness and GCP inspection readiness. Supports historical record integrity even if trainer record is modified.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Training Duration Minutes' ;
    rdfs:comment 'The actual time in minutes spent by the staff member completing the training. Captured automatically by e-learning systems or recorded manually for classroom and OJT sessions. Used for training effort reporting and curriculum planning.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingMethod rdf:type rdf:Property ;
    rdfs:label 'Training Method' ;
    rdfs:comment 'The instructional delivery method used for this SOP training event. Read-and-understand (R&U) is the most common GCP method; classroom and e-learning are used for complex SOPs; on-the-job training (OJT) is used for procedural skills. Drives assessment requirements and documentation standards.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Training Record Number' ;
    rdfs:comment 'Externally-known, human-readable unique identifier for this training record as assigned by MasterControl (e.g., TR-2024-000123). Used for audit trail references, GCP inspection documentation, and regulatory correspondence. Satisfies TRANSACTION_HEADER BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingStatus rdf:type rdf:Property ;
    rdfs:label 'Training Status' ;
    rdfs:comment 'Current lifecycle status of this training record indicating whether the staff member has completed, is overdue, has been granted a waiver, is in progress, or has not yet started the required SOP training. Satisfies TRANSACTION_HEADER LIFECYCLE_STATUS category.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingType rdf:type rdf:Property ;
    rdfs:label 'Training Type' ;
    rdfs:comment 'Classification of the training event indicating whether it is initial training (first time on this SOP), retraining (following a failed assessment or deviation), refresher (periodic recertification), or change-control training (triggered by a new SOP version release).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved By' ;
    rdfs:comment 'Name or identifier of the Quality Assurance (QA) manager or authorized approver who granted the training waiver. Required for audit trail and GCP inspection documentation when training_status is \'waived\'.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Date' ;
    rdfs:comment 'The date on which the training waiver was formally approved and recorded. Applicable only when training_status is \'waived\'. Supports audit trail completeness per ALCOA+ principles.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Documented justification for granting a training waiver when training_status is \'waived\'. Examples include equivalent prior training, role change making SOP non-applicable, or temporary exemption with documented rationale. Required for audit trail completeness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitId rdf:type rdf:Property ;
    rdfs:label 'Org Unit Id' ;
    rdfs:comment 'Reference to the organizational department for which this SOP training requirement applies. Null if the requirement is role-based rather than department-based.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:applicabilityScope rdf:type rdf:Property ;
    rdfs:label 'Applicability Scope' ;
    rdfs:comment 'Defines the organizational scope at which this training requirement applies. \'global\' = all staff; \'study_specific\' = only staff assigned to a particular study; \'department_specific\' = only a department; \'role_specific\' = only a job role; \'site_specific\' = only staff at a particular investigational site.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoAssignEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Assign Enabled' ;
    rdfs:comment 'Indicates whether MasterControl should automatically assign this training requirement to qualifying personnel when they are assigned to the applicable role, department, or study. When False, manual assignment by a training coordinator is required.' ;
    rdfs:domain ind:SopTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capaRequiredOnOverdue rdf:type rdf:Property ;
    rdfs:label 'Capa Required On Overdue' ;
    rdfs:comment 'Indicates whether a formal CAPA must be initiated when this training requirement becomes overdue beyond the grace period. Distinct from escalation_required — CAPA is a formal quality system record with root cause analysis obligations.' ;
    rdfs:domain ind:SopTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:curriculumCode rdf:type rdf:Property ;
    rdfs:label 'Curriculum Code' ;
    rdfs:comment 'Code identifying the training curriculum or learning path in MasterControl to which this SOP training requirement belongs. Enables grouping of related SOP requirements into structured training programs (e.g., GCP Onboarding Curriculum, Annual Refresher Curriculum).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRequired rdf:type rdf:Property ;
    rdfs:label 'Escalation Required' ;
    rdfs:comment 'Indicates whether a compliance escalation notification must be triggered if training is not completed within the grace period. When True, MasterControl generates a CAPA or non-conformance record and notifies the QA manager.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gcpApplicable rdf:type rdf:Property ;
    rdfs:label 'Gcp Applicable' ;
    rdfs:comment 'Indicates whether this training requirement is classified as a GCP training obligation under ICH E6(R2). GCP-applicable requirements are subject to heightened audit scrutiny and must be documented in the Trial Master File (TMF).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Grace Period Days' ;
    rdfs:comment 'Number of calendar days after the training due date during which the training may still be completed without triggering a compliance violation or non-conformance. Typically 0–30 days depending on SOP criticality and sponsor requirements.' ;
    rdfs:domain ind:SopTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether this SOP training is mandatory (True) or optional/recommended (False) for the assigned role, department, or study. Mandatory training must be completed before study participation or role activation per GCP requirements.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStudyParticipationPrerequisite rdf:type rdf:Property ;
    rdfs:label 'Is Study Participation Prerequisite' ;
    rdfs:comment 'Indicates whether completion of this SOP training is a prerequisite for a staff member to be activated on a clinical study. When True, the system blocks study assignment until training is recorded as complete.' ;
    rdfs:domain ind:SopTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobFunction rdf:type rdf:Property ;
    rdfs:label 'Job Function' ;
    rdfs:comment 'The specific job function or functional area for which this training requirement applies (e.g., Clinical Research Associate, Data Manager, Biostatistician, Principal Investigator). Complements role_id with a human-readable functional label for reporting.' ;
    rdfs:domain ind:SopTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxAttemptsAllowed rdf:type rdf:Property ;
    rdfs:label 'Max Attempts Allowed' ;
    rdfs:comment 'Maximum number of times a trainee may attempt the training assessment before escalation or remediation is required. Null if unlimited attempts are permitted.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passingScorePct rdf:type rdf:Property ;
    rdfs:label 'Passing Score Pct' ;
    rdfs:comment 'Minimum percentage score required to pass the training assessment associated with this SOP requirement. Applicable when training_delivery_method includes an assessment component. Null if no scored assessment is required.' ;
    rdfs:domain ind:SopTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phaseApplicability rdf:type rdf:Property ;
    rdfs:label 'Phase Applicability' ;
    rdfs:comment 'Specifies the clinical trial phase(s) for which this SOP training requirement is applicable. Enables phase-specific training assignment for staff transitioning between study phases.' ;
    rdfs:domain ind:SopTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonForChange rdf:type rdf:Property ;
    rdfs:label 'Reason For Change' ;
    rdfs:comment 'Free-text justification for the most recent modification to this training requirement record. Mandatory for any update per 21 CFR Part 11 audit trail requirements and ALCOA+ data integrity principles.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Recurrence Frequency Days' ;
    rdfs:comment 'Number of days between required retraining cycles for recurring training types (e.g., 365 for annual). Null for one-time training types such as \'initial\'. Used by MasterControl to auto-generate the next training due date.' ;
    rdfs:domain ind:SopTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reminderDaysBeforeDue rdf:type rdf:Property ;
    rdfs:label 'Reminder Days Before Due' ;
    rdfs:comment 'Number of days before the training due date that an automated reminder notification should be sent to the trainee and their manager. Configurable per SOP criticality to drive proactive compliance.' ;
    rdfs:domain ind:SopTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requirementCode rdf:type rdf:Property ;
    rdfs:label 'Requirement Code' ;
    rdfs:comment 'Unique business identifier for the SOP training requirement record, used for cross-system referencing and audit trail. Follows the format TRQ-[alphanumeric]. Serves as the externally-known identifier in MasterControl.' ;
    rdfs:domain ind:SopTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementStatus rdf:type rdf:Property ;
    rdfs:label 'Requirement Status' ;
    rdfs:comment 'Current lifecycle state of the SOP training requirement record. \'active\' = currently enforced; \'inactive\' = no longer enforced; \'superseded\' = replaced by a newer version requirement; \'draft\' = under review; \'pending_approval\' = awaiting QA sign-off.' ;
    rdfs:domain ind:SopTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorRequired rdf:type rdf:Property ;
    rdfs:label 'Sponsor Required' ;
    rdfs:comment 'Indicates whether this training requirement was mandated by the study sponsor as a condition of the clinical trial agreement. Sponsor-required training may have additional documentation and audit trail obligations.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tmfDocumentationRequired rdf:type rdf:Property ;
    rdfs:label 'Tmf Documentation Required' ;
    rdfs:comment 'Indicates whether evidence of training completion for this requirement must be filed in the Trial Master File (TMF) or electronic TMF (eTMF) in Veeva Vault. Required for GCP-essential training per ICH E6(R2) Section 8.' ;
    rdfs:domain ind:SopTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingCategory rdf:type rdf:Property ;
    rdfs:label 'Training Category' ;
    rdfs:comment 'Functional classification of the SOP training requirement. Used for compliance reporting, training curriculum grouping, and regulatory inspection readiness. [ENUM-REF-CANDIDATE: gcp|regulatory|safety|data_management|clinical_operations|quality|sponsor_specific — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Training Delivery Method' ;
    rdfs:comment 'Specifies the required method by which the SOP training must be completed. \'read_and_understand\' = staff reads and signs off; \'instructor_led\' = classroom or virtual session; \'elearning\' = online module; \'on_the_job\' = supervised practical; \'assessment_only\' = pass a quiz without formal training.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingMaterialReference rdf:type rdf:Property ;
    rdfs:label 'Training Material Reference' ;
    rdfs:comment 'Document identifier or URL reference to the training material, curriculum, or assessment associated with this SOP requirement in MasterControl or the eTMF. Enables direct navigation to training content from compliance dashboards.' ;
    rdfs:domain ind:SopTrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vulnerablePopulationId rdf:type rdf:Property ;
    rdfs:label 'Vulnerable Population Id' ;
    rdfs:comment 'Unique surrogate identifier for a vulnerable population protection record within the compliance domain. Serves as the primary key for this entity.' ;
    rdfs:domain ind:VulnerablePopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Capacity Assessment Id' ;
    rdfs:comment 'Reference to the formal cognitive capacity assessment record conducted for this subject to determine consent capacity. Links to the consent.capacity_assessment product.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapacityAssessment .

ind:larRepresentativeId rdf:type rdf:Property ;
    rdfs:label 'Lar Representative Id' ;
    rdfs:comment 'Reference to the LAR record associated with this vulnerable population subject. Links to the consent domain LAR representative product for tracking guardian/parent/legal representative details.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LarRepresentative .

ind:additionalSafeguardsDescription rdf:type rdf:Property ;
    rdfs:label 'Additional Safeguards Description' ;
    rdfs:comment 'Narrative description of any additional ethical safeguards, protections, or monitoring measures implemented beyond standard GCP requirements for this vulnerable population subject. Includes enhanced monitoring frequency, independent advocate assignment, or special data handling procedures.' ;
    rdfs:domain ind:VulnerablePopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assentRequired rdf:type rdf:Property ;
    rdfs:label 'Assent Required' ;
    rdfs:comment 'Indicates whether subject assent (in addition to LAR consent) is required for this vulnerable population subject, typically applicable to pediatric subjects with sufficient cognitive capacity to understand participation. Governed by 21 CFR Part 50.55 and ICH E11.' ;
    rdfs:domain ind:VulnerablePopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityAssessmentRequired rdf:type rdf:Property ;
    rdfs:label 'Capacity Assessment Required' ;
    rdfs:comment 'Indicates whether a formal cognitive capacity assessment is required to determine the subject\'s ability to provide informed consent. Primarily applicable to cognitively impaired and elderly populations. Links to the consent.capacity_assessment product.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:directBenefitToSubject rdf:type rdf:Property ;
    rdfs:label 'Direct Benefit To Subject' ;
    rdfs:comment 'Indicates whether the research intervention offers a prospect of direct benefit to the individual vulnerable subject. A key regulatory criterion for permissibility of enrollment under 21 CFR Part 46 and EU CTR 536/2014 Article 32.' ;
    rdfs:domain ind:VulnerablePopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dsmbOversightRequired rdf:type rdf:Property ;
    rdfs:label 'Dsmb Oversight Required' ;
    rdfs:comment 'Indicates whether DSMB/DMC oversight is specifically required for the vulnerable population cohort within this study, in addition to or separate from overall study DSMB oversight. Ensures independent safety review for high-risk vulnerable populations.' ;
    rdfs:domain ind:VulnerablePopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enhancedMonitoringRequired rdf:type rdf:Property ;
    rdfs:label 'Enhanced Monitoring Required' ;
    rdfs:comment 'Indicates whether enhanced or increased frequency monitoring is required for this vulnerable population subject beyond the standard site monitoring plan. Triggers additional CRA visit scheduling and SDV requirements in Oracle Siebel CTMS.' ;
    rdfs:domain ind:VulnerablePopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrollmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment End Date' ;
    rdfs:comment 'Date on which enrollment of subjects from this vulnerable population category was closed or completed at the study or site level. Null if enrollment is ongoing.' ;
    rdfs:domain ind:VulnerablePopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentJustification rdf:type rdf:Property ;
    rdfs:label 'Enrollment Justification' ;
    rdfs:comment 'Documented scientific and ethical justification for enrolling subjects from this vulnerable population, including why the research cannot be conducted in non-vulnerable populations and how the study addresses the specific health needs of this group. Required for IRB/IEC submission and regulatory inspection.' ;
    rdfs:domain ind:VulnerablePopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Start Date' ;
    rdfs:comment 'Date on which enrollment of subjects from this vulnerable population category commenced at the study or site level. Must be on or after IRB/IEC approval date and all required safeguards being in place.' ;
    rdfs:domain ind:VulnerablePopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprSpecialCategoryFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Special Category Flag' ;
    rdfs:comment 'Indicates whether data collected from this vulnerable population subject constitutes GDPR Article 9 special category data (health data, genetic data, biometric data). Triggers enhanced data protection measures, explicit consent requirements, and Data Protection Impact Assessment (DPIA) obligations.' ;
    rdfs:domain ind:VulnerablePopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hipaaPhiFlag rdf:type rdf:Property ;
    rdfs:label 'Hipaa Phi Flag' ;
    rdfs:comment 'Indicates whether Protected Health Information (PHI) under HIPAA is involved in data collection for this vulnerable population subject. Triggers HIPAA-compliant data handling, de-identification, and authorization requirements for U.S.-based sites.' ;
    rdfs:domain ind:VulnerablePopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impairmentType rdf:type rdf:Property ;
    rdfs:label 'Impairment Type' ;
    rdfs:comment 'Specific type of cognitive or decisional impairment affecting the subject\'s consent capacity (e.g., dementia, intellectual disability, acute psychiatric condition, traumatic brain injury). Applicable when population_category is \'cognitively_impaired\'. Informs capacity assessment methodology and safeguard design.' ;
    rdfs:domain ind:VulnerablePopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:independentAdvocateName rdf:type rdf:Property ;
    rdfs:label 'Independent Advocate Name' ;
    rdfs:comment 'Name of the independent advocate or patient representative assigned to this vulnerable population subject. Populated when independent_advocate_required is True.' ;
    rdfs:domain ind:VulnerablePopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:independentAdvocateRequired rdf:type rdf:Property ;
    rdfs:label 'Independent Advocate Required' ;
    rdfs:comment 'Indicates whether an independent patient advocate or subject representative (independent of the research team) is required to be present during the consent process for this vulnerable subject. Applicable in certain jurisdictions and for specific vulnerable categories.' ;
    rdfs:domain ind:VulnerablePopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irbIecApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Approval Date' ;
    rdfs:comment 'Date on which the IRB or IEC granted approval for enrollment of this vulnerable population category. Must precede first subject enrollment per GCP requirements.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:irbIecExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Expiry Date' ;
    rdfs:comment 'Date on which the IRB/IEC approval for this vulnerable population enrollment expires. Triggers renewal workflow in MasterControl to ensure continuous compliance coverage.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:larConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Lar Consent Required' ;
    rdfs:comment 'Indicates whether consent from a Legally Authorized Representative (LAR) is required because the subject lacks capacity to provide independent informed consent. Applicable to pediatric, cognitively impaired, and other incapacitated populations.' ;
    rdfs:domain ind:VulnerablePopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pediatricAgeBand rdf:type rdf:Property ;
    rdfs:label 'Pediatric Age Band' ;
    rdfs:comment 'ICH E11-defined age band classification for pediatric subjects. Applicable only when population_category is \'pediatric\'. Drives age-appropriate dosing, formulation, and consent/assent requirements. Values: neonate (0-27 days), infant (28 days-23 months), toddler/child (2-11 years), adolescent (12-17 years).' ;
    rdfs:domain ind:VulnerablePopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationCategory rdf:type rdf:Property ;
    rdfs:label 'Population Category' ;
    rdfs:comment 'Primary classification of the vulnerable population type as defined by ICH E6(R2) and applicable regulations. Drives the specific ethical safeguards, consent requirements, and regulatory reporting obligations applicable to this subject. [ENUM-REF-CANDIDATE: pediatric|pregnant|cognitively_impaired|prisoner|elderly|economically_disadvantaged|terminally_ill — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationSubcategory rdf:type rdf:Property ;
    rdfs:label 'Population Subcategory' ;
    rdfs:comment 'Further granular classification within the primary population category (e.g., neonates, infants, adolescents within pediatric; first trimester, third trimester within pregnant; mild, moderate, severe within cognitively impaired). Aligns with ICH E11 pediatric age bands and CTCAE severity grading where applicable.' ;
    rdfs:domain ind:VulnerablePopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pregnancyTrimester rdf:type rdf:Property ;
    rdfs:label 'Pregnancy Trimester' ;
    rdfs:comment 'Trimester classification for pregnant subjects at time of enrollment or identification. Applicable only when population_category is \'pregnant\'. Relevant for teratogenicity risk assessment, fetal safety monitoring, and regulatory reporting under ICH S5.' ;
    rdfs:domain ind:VulnerablePopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectionStatus rdf:type rdf:Property ;
    rdfs:label 'Protection Status' ;
    rdfs:comment 'Current lifecycle status of the ethical protection and safeguard record for this vulnerable population subject. \'Active\' indicates safeguards are in force; \'under_review\' indicates a triggered reassessment; \'suspended\' indicates enrollment or participation is paused pending review; \'waived\' indicates IRB/IEC-approved waiver of specific protections; \'closed\' indicates the subject has exited the study.' ;
    rdfs:domain ind:VulnerablePopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolSectionReference rdf:type rdf:Property ;
    rdfs:label 'Protocol Section Reference' ;
    rdfs:comment 'Reference to the specific section(s) of the study protocol that address vulnerable population inclusion criteria, special safeguards, and ethical considerations. Enables traceability between this protection record and the governing protocol document.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordNumber rdf:type rdf:Property ;
    rdfs:label 'Record Number' ;
    rdfs:comment 'Human-readable, externally referenceable identifier for this vulnerable population protection record, used in regulatory submissions, audit trails, and TMF cross-referencing. Format: VP-{StudyCode}-{Sequence}.' ;
    rdfs:domain ind:VulnerablePopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityNotifiedDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Notified Date' ;
    rdfs:comment 'Date on which the applicable regulatory authority was notified of the enrollment of this vulnerable population subject or cohort. Populated when regulatory_authority_notification_required is True.' ;
    rdfs:domain ind:VulnerablePopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskBenefitAssessmentDocumented rdf:type rdf:Property ;
    rdfs:label 'Risk Benefit Assessment Documented' ;
    rdfs:comment 'Indicates whether a documented risk-benefit assessment specific to this vulnerable population category has been completed and filed in the TMF. Required by ICH E6(R2) and applicable regulations before enrollment of vulnerable subjects.' ;
    rdfs:domain ind:VulnerablePopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Regulatory risk classification for the research procedures applied to this vulnerable population subject, as assessed by the IRB/IEC. Determines permissibility of enrollment under 21 CFR Part 46 Subparts B/C/D and OHRP guidance.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyReportingExpedited rdf:type rdf:Property ;
    rdfs:label 'Safety Reporting Expedited' ;
    rdfs:comment 'Indicates whether expedited adverse event and SAE reporting timelines apply to this vulnerable population subject due to heightened safety concerns. When True, AE/SAE events for this subject are subject to accelerated reporting to Oracle Argus Safety and regulatory authorities.' ;
    rdfs:domain ind:VulnerablePopulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assentRecordId rdf:type rdf:Property ;
    rdfs:label 'Assent Record Id' ;
    rdfs:comment 'Unique surrogate identifier for the assent record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:AssentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:econsentSessionId rdf:type rdf:Property ;
    rdfs:label 'Econsent Session Id' ;
    rdfs:comment 'Unique session identifier from the Clinpal eConsent platform for the electronic assent interaction. Enables traceability back to the source system audit log for 21 CFR Part 11 compliance. Null for non-electronic assent methods.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EconsentSession .

ind:irbIecApprovalId rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Approval Id' ;
    rdfs:comment 'Foreign key linking to site.irb_iec_approval. Business justification: GCP/pediatric regulatory requirement: assent forms for pediatric subjects require separate IRB/IEC approval. Direct FK to site.irb_iec_approval enables traceability from each assent record to the appr' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IrbIecApproval .

ind:piEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Pi Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: The PI overseeing pediatric assent must be documented as a qualified employee per GCP and IRB requirements for vulnerable population protection. pi_name is a plain text denormalization; pi_employee_id' ;
    rdfs:domain ind:AssentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reconsentTriggerId rdf:type rdf:Property ;
    rdfs:label 'Reconsent Trigger Id' ;
    rdfs:comment 'Foreign key linking to consent.reconsent_trigger. Business justification: assent_record has reconsent_required (BOOLEAN) and reconsent_trigger (STRING) as denormalized fields. When re-assent is required (e.g., due to an amendment), the assent_record should reference the rec' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReconsentTrigger .

ind:assentDate rdf:type rdf:Property ;
    rdfs:label 'Assent Date' ;
    rdfs:comment 'The calendar date on which the subject provided assent. This is the principal real-world event date per ALCOA+ contemporaneous documentation requirements.' ;
    rdfs:domain ind:AssentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assentFormVersion rdf:type rdf:Property ;
    rdfs:label 'Assent Form Version' ;
    rdfs:comment 'Version identifier of the IRB/IEC-approved assent form used at the time of assent. Must correspond to the currently approved version on file in the eTMF (Veeva Vault). Format: v{Major}.{Minor}.' ;
    rdfs:domain ind:AssentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assentMethod rdf:type rdf:Property ;
    rdfs:label 'Assent Method' ;
    rdfs:comment 'The method by which assent was obtained from the subject. \'written\' = paper-based signed form; \'verbal\' = verbal assent documented by witness; \'eassent\' = electronic assent via Clinpal platform; \'video_assisted\' = assent supported by video explanation; \'pictorial\' = assent using pictorial/visual aids for cognitively limited subjects.' ;
    rdfs:domain ind:AssentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assentNumber rdf:type rdf:Property ;
    rdfs:label 'Assent Number' ;
    rdfs:comment 'Externally-known, human-readable unique identifier for the assent record, used in regulatory submissions, audit trails, and site communications. Format: ASN-{StudyCode}-{Sequence}.' ;
    rdfs:domain ind:AssentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assentStatus rdf:type rdf:Property ;
    rdfs:label 'Assent Status' ;
    rdfs:comment 'Current lifecycle status of the assent record. \'obtained\' = assent successfully documented; \'declined\' = subject declined assent; \'withdrawn\' = previously given assent was withdrawn; \'pending\' = assent process initiated but not completed; \'not_applicable\' = subject determined incapable of providing assent; \'capacity_reassessed\' = subject capacity re-evaluated triggering re-assent. [ENUM-REF-CANDIDATE: obtained|declined|withdrawn|pending|not_applicable|capacity_reassessed — promote to reference product]' ;
    rdfs:domain ind:AssentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assent Timestamp' ;
    rdfs:comment 'Precise date and time at which the assent was electronically captured or documented, including timezone offset. Required for 21 CFR Part 11 electronic records compliance and Clinpal eConsent audit trail.' ;
    rdfs:domain ind:AssentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assentWaived rdf:type rdf:Property ;
    rdfs:label 'Assent Waived' ;
    rdfs:comment 'Indicates whether the IRB/IEC granted a waiver of assent for this subject, typically when the subject is incapable of providing meaningful assent or the research offers direct benefit not otherwise available.' ;
    rdfs:domain ind:AssentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assentWaiverReason rdf:type rdf:Property ;
    rdfs:label 'Assent Waiver Reason' ;
    rdfs:comment 'Documented justification for the IRB/IEC-approved waiver of assent. Required when assent_waived is True. Must reference the specific regulatory basis for the waiver.' ;
    rdfs:domain ind:AssentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Capacity Assessment Date' ;
    rdfs:comment 'Date on which the capacity assessment was conducted. Must precede or coincide with the assent date to confirm eligibility for assent.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capacityAssessmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Capacity Assessment Outcome' ;
    rdfs:comment 'Result of the cognitive capacity assessment determining the subject\'s ability to provide meaningful assent. \'capable\' = subject can provide assent; \'incapable\' = subject cannot provide assent (assent waived); \'partially_capable\' = limited capacity, assent obtained with accommodations; \'deferred\' = assessment deferred pending further evaluation.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityAssessmentPerformed rdf:type rdf:Property ;
    rdfs:label 'Capacity Assessment Performed' ;
    rdfs:comment 'Indicates whether a formal cognitive capacity assessment was performed prior to obtaining assent. Required for subjects with potential cognitive limitations to confirm they are capable of providing meaningful assent.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityAssessorName rdf:type rdf:Property ;
    rdfs:label 'Capacity Assessor Name' ;
    rdfs:comment 'Full name of the qualified professional (e.g., physician, psychologist) who performed the capacity assessment. Retained for audit and regulatory inspection purposes.' ;
    rdfs:domain ind:AssentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comprehensionConfirmed rdf:type rdf:Property ;
    rdfs:label 'Comprehension Confirmed' ;
    rdfs:comment 'Indicates whether the consenter confirmed that the subject demonstrated adequate understanding of the study and their rights before assent was obtained. Core GCP requirement for valid assent.' ;
    rdfs:domain ind:AssentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consenterName rdf:type rdf:Property ;
    rdfs:label 'Consenter Name' ;
    rdfs:comment 'Full name of the qualified study team member (e.g., CRC, sub-investigator) who administered the assent process and documented the subject\'s assent.' ;
    rdfs:domain ind:AssentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consenterRole rdf:type rdf:Property ;
    rdfs:label 'Consenter Role' ;
    rdfs:comment 'Role of the study team member who administered the assent. Must be a qualified individual delegated on the site delegation log per GCP requirements.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eassentPlatform rdf:type rdf:Property ;
    rdfs:label 'Eassent Platform' ;
    rdfs:comment 'The technology platform used to capture the electronic assent. Clinpal is the primary eConsent system of record. Used for system-level audit and validation tracking.' ;
    rdfs:domain ind:AssentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interpreterUsed rdf:type rdf:Property ;
    rdfs:label 'Interpreter Used' ;
    rdfs:comment 'Indicates whether a language interpreter was used during the assent process. When True, interpreter details must be documented in the site source records.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:questionsAsked rdf:type rdf:Property ;
    rdfs:label 'Questions Asked' ;
    rdfs:comment 'Indicates whether the subject asked questions during the assent discussion, and whether those questions were answered to the subject\'s satisfaction. Documents the interactive nature of the assent process per GCP.' ;
    rdfs:domain ind:AssentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconsentDueDate rdf:type rdf:Property ;
    rdfs:label 'Reconsent Due Date' ;
    rdfs:comment 'The deadline by which re-assent must be obtained from the subject or their guardian. Drives compliance monitoring and site follow-up activities in Oracle Siebel CTMS.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconsentRequired rdf:type rdf:Property ;
    rdfs:label 'Reconsent Required' ;
    rdfs:comment 'Indicates whether a re-assent is required for this subject, triggered by a protocol amendment, new safety information, updated assent form version, or the subject reaching the age of majority.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdvDate rdf:type rdf:Property ;
    rdfs:label 'Sdv Date' ;
    rdfs:comment 'Date on which the CRA completed Source Data Verification (SDV) for this assent record during a monitoring visit.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sdvStatus rdf:type rdf:Property ;
    rdfs:label 'Sdv Status' ;
    rdfs:comment 'Status of Source Data Verification (SDV) for this assent record, performed by the Clinical Research Associate (CRA) during site monitoring visits. Tracks whether the assent documentation has been verified against source records.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentLocation rdf:type rdf:Property ;
    rdfs:label 'Source Document Location' ;
    rdfs:comment 'Physical or electronic location of the original signed assent form source document (e.g., site binder reference, Veeva Vault eTMF document ID, or scanned document path). Required for SDV and regulatory inspection readiness.' ;
    rdfs:domain ind:AssentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectAgeAtAssent rdf:type rdf:Property ;
    rdfs:label 'Subject Age At Assent' ;
    rdfs:comment 'Age of the subject in whole years at the time assent was obtained. Critical for pediatric trial compliance to confirm the subject met the minimum age threshold for assent per applicable national regulations and ICH E11.' ;
    rdfs:domain ind:AssentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subjectAgeGroup rdf:type rdf:Property ;
    rdfs:label 'Subject Age Group' ;
    rdfs:comment 'ICH E11 pediatric age group classification of the subject at time of assent. Used for regulatory reporting and pediatric study compliance. Values align with ICH E11(R1) age band definitions.' ;
    rdfs:domain ind:AssentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'Date on which the subject withdrew their assent. Populated only when assent_status is \'withdrawn\'. Triggers subject discontinuation workflow in the EDC and CTMS.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Free-text or coded reason provided by the subject or guardian for withdrawing assent. Retained for regulatory reporting and subject safety follow-up.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessName rdf:type rdf:Property ;
    rdfs:label 'Witness Name' ;
    rdfs:comment 'Full name of the impartial witness present during the assent process. Required when the subject cannot read or when verbal assent is documented. Null if no witness was required.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessRelationship rdf:type rdf:Property ;
    rdfs:label 'Witness Relationship' ;
    rdfs:comment 'Relationship of the witness to the subject. Must be impartial and independent per GCP requirements. Used to verify no conflict of interest in the assent witnessing process.' ;
    rdfs:domain ind:AssentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessRequired rdf:type rdf:Property ;
    rdfs:label 'Witness Required' ;
    rdfs:comment 'Indicates whether a witness was required for the assent process, typically when the subject is illiterate, assent is verbal, or applicable regulations mandate a witness.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorAssessmentCapacityAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Prior Assessment Capacity Assessment Id' ;
    rdfs:comment 'Reference to the immediately preceding capacity assessment record for this subject on this study, enabling longitudinal tracking of capacity status changes over the subject\'s participation lifecycle.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapacityAssessment .

ind:assessmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for this capacity assessment, typically generated by the CTMS or eConsent system (Clinpal). Used for cross-system referencing, audit trails, and regulatory submissions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Assessment Outcome' ;
    rdfs:comment 'Formal determination of the subject\'s mental capacity to provide informed consent. Drives downstream consent workflow: Capable proceeds to standard ICF signing; Incapable triggers LAR (Legally Authorized Representative) requirement; Borderline may require re-assessment or specialist review.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentScoreMax rdf:type rdf:Property ;
    rdfs:label 'Assessment Score Max' ;
    rdfs:comment 'Maximum possible score for the assessment tool used, providing context for interpreting the assessment_score. Required when multiple tools with different scales are used across sites.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentSetting rdf:type rdf:Property ;
    rdfs:label 'Assessment Setting' ;
    rdfs:comment 'Mode in which the capacity assessment was conducted: In-Person at the investigative site, Remote via telehealth/eConsent platform (Clinpal), or Hybrid. Relevant for regulatory acceptability and audit trail documentation.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assessment Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) at which the capacity assessment was performed. Supports ALCOA+ contemporaneous documentation requirements and audit trail integrity per 21 CFR Part 11.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assessmentTool rdf:type rdf:Property ;
    rdfs:label 'Assessment Tool' ;
    rdfs:comment 'Name or code of the standardized tool, instrument, or method used to evaluate mental capacity (e.g., MacCAT-CR, MMSE, ACE-III, clinical interview, structured questionnaire). Supports methodological consistency and IRB/IEC reporting.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentToolVersion rdf:type rdf:Property ;
    rdfs:label 'Assessment Tool Version' ;
    rdfs:comment 'Version or edition of the assessment tool or instrument used. Ensures reproducibility and comparability of assessments across sites and time points.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Classification of the assessment within the subject\'s consent lifecycle: Initial (first assessment at screening), Re-Assessment (triggered by condition change or borderline outcome), Periodic (scheduled interval), Post-Amendment (following protocol or ICF amendment), or Withdrawal (assessing capacity to withdraw consent).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorCredentials rdf:type rdf:Property ;
    rdfs:label 'Assessor Credentials' ;
    rdfs:comment 'Professional credentials or qualifications of the assessor (e.g., MD, PhD, RN, NP) as documented at the time of assessment. Supports regulatory verification of assessor competency.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorName rdf:type rdf:Property ;
    rdfs:label 'Assessor Name' ;
    rdfs:comment 'Full name of the qualified individual who conducted the capacity assessment, captured at the time of assessment for audit trail completeness. Retained as a denormalized field to preserve historical accuracy even if personnel records change.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorRole rdf:type rdf:Property ;
    rdfs:label 'Assessor Role' ;
    rdfs:comment 'Professional role or qualification of the individual who conducted the capacity assessment. Determines the regulatory acceptability of the assessment per GCP and applicable local regulations. [ENUM-REF-CANDIDATE: Principal Investigator|Sub-Investigator|Study Physician|Psychiatrist|Psychologist|Nurse Practitioner|Other — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assessor Signature Timestamp' ;
    rdfs:comment 'Date and time at which the assessor applied their electronic signature to the capacity assessment record, as required by 21 CFR Part 11 for electronic records. Distinct from the assessment_timestamp (when the assessment occurred).' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:irbIecNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Notification Date' ;
    rdfs:comment 'Date on which the IRB/IEC was notified of the capacity assessment outcome. Populated when irb_iec_notification_required is True. Used for regulatory compliance tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:languageOfAssessment rdf:type rdf:Property ;
    rdfs:label 'Language Of Assessment' ;
    rdfs:comment 'ISO 639-1/639-2 language code indicating the language in which the capacity assessment was conducted (e.g., \'en\', \'fr\', \'de\', \'zh-CN\'). Ensures the subject was assessed in their primary language per GCP requirements.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:larRequired rdf:type rdf:Property ;
    rdfs:label 'Lar Required' ;
    rdfs:comment 'Indicates whether a Legally Authorized Representative (LAR) is required to provide consent on behalf of the subject due to incapacity or borderline capacity determination. Triggers LAR consent workflow in Clinpal eConsent system.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outcomeBasis rdf:type rdf:Property ;
    rdfs:label 'Outcome Basis' ;
    rdfs:comment 'Narrative description of the clinical and factual basis for the capacity determination, including observations, test scores, and reasoning. Required for regulatory defensibility and IRB/IEC reporting. Supports ALCOA+ attributable and accurate principles.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reassessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Reassessment Due Date' ;
    rdfs:comment 'Scheduled date by which a follow-up capacity re-assessment must be completed. Populated when reassessment_required is True. Used for site monitoring and compliance tracking.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reassessmentRequired rdf:type rdf:Property ;
    rdfs:label 'Reassessment Required' ;
    rdfs:comment 'Indicates whether a follow-up capacity re-assessment is required, typically triggered by a borderline outcome, change in subject condition, protocol amendment, or regulatory requirement.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reassessmentTrigger rdf:type rdf:Property ;
    rdfs:label 'Reassessment Trigger' ;
    rdfs:comment 'Reason or event that triggered the requirement for a capacity re-assessment. Supports audit trail and IRB/IEC reporting on re-consent and re-assessment activities.' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vulnerabilityCategory rdf:type rdf:Property ;
    rdfs:label 'Vulnerability Category' ;
    rdfs:comment 'Classification of the type of vulnerability applicable to the subject. Drives additional regulatory safeguards and IRB/IEC reporting requirements. Populated when vulnerable_population_flag is True. [ENUM-REF-CANDIDATE: Cognitive Impairment|Psychiatric Disorder|Minor|Prisoner|Pregnant|Economically Disadvantaged|Other — promote to reference product]' ;
    rdfs:domain ind:CapacityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditEntryId rdf:type rdf:Property ;
    rdfs:label 'Audit Entry Id' ;
    rdfs:comment 'Unique surrogate identifier for each immutable consent audit trail record in the Silver Layer lakehouse. Primary key for the consent_audit_entry data product. Role: EVENT_LOG.' ;
    rdfs:domain ind:AuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAuditEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Audit Employee Id' ;
    rdfs:comment 'System user identifier of the individual who performed the consent action that triggered this audit entry. Satisfies ALCOA+ Attributable requirement and 21 CFR Part 11 electronic signature attribution. Sourced from Clinpal or Veeva Vault user registry.' ;
    rdfs:domain ind:AuditEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actorFullName rdf:type rdf:Property ;
    rdfs:label 'Actor Full Name' ;
    rdfs:comment 'Full name of the user who performed the consent action, captured at the time of the event for human-readable audit trail display. Stored as confidential business data to support regulatory inspection readiness without exposing unnecessary PII.' ;
    rdfs:domain ind:AuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actorRole rdf:type rdf:Property ;
    rdfs:label 'Actor Role' ;
    rdfs:comment 'Clinical role of the user who performed the consent action (e.g., Principal Investigator (PI), Clinical Research Coordinator (CRC), subject, Legally Authorized Representative (LAR)). Required for GCP accountability and regulatory inspection. [ENUM-REF-CANDIDATE: PI|CRC|CRA|subject|LAR|sponsor_monitor|data_manager|system — promote to reference product]' ;
    rdfs:domain ind:AuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedRecordReference rdf:type rdf:Property ;
    rdfs:label 'Affected Record Reference' ;
    rdfs:comment 'Surrogate identifier of the specific consent domain record (subject_consent, icf_version, econsent_session, etc.) that was created or modified by this audit event. Used in conjunction with affected_record_type to locate the exact record.' ;
    rdfs:domain ind:AuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedRecordType rdf:type rdf:Property ;
    rdfs:label 'Affected Record Type' ;
    rdfs:comment 'Identifies the type of consent domain record that was created or modified by this audit event (e.g., subject_consent, icf_version, econsent_session, withdrawal). Enables filtering audit entries by consent entity type during regulatory inspections.' ;
    rdfs:domain ind:AuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityAssessmentResult rdf:type rdf:Property ;
    rdfs:label 'Capacity Assessment Result' ;
    rdfs:comment 'Outcome of the subject\'s mental capacity assessment conducted prior to or during the consent process. Populated for events involving capacity evaluation. Determines whether direct consent or LAR consent pathway applies.' ;
    rdfs:domain ind:AuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Change Reason Code' ;
    rdfs:comment 'Standardized reason code explaining why the consent record was modified (e.g., DATA_ENTRY_ERROR, PROTOCOL_AMENDMENT, SUBJECT_REQUEST, SYSTEM_CORRECTION). Supports ALCOA+ Attributable requirement and audit trail completeness for regulatory inspections.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonText rdf:type rdf:Property ;
    rdfs:label 'Change Reason Text' ;
    rdfs:comment 'Free-text narrative explanation provided by the actor for the consent record modification. Complements change_reason_code with additional context. Required by ALCOA+ and GCP for any post-entry modification to clinical data.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changedFieldName rdf:type rdf:Property ;
    rdfs:label 'Changed Field Name' ;
    rdfs:comment 'Name of the specific data field on the consent record that was modified by this audit event. Null for creation events where no prior value exists. Supports granular field-level audit trail as required by ALCOA+ and 21 CFR Part 11.' ;
    rdfs:domain ind:AuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Consent Language Code' ;
    rdfs:comment 'ISO 639-1 language code (optionally with ISO 3166-1 country subtag) of the ICF version presented to the subject at the time of this consent event (e.g., \'en\', \'fr-FR\', \'es-ES\'). Confirms the subject received consent information in their understood language.' ;
    rdfs:domain ind:AuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentMethod rdf:type rdf:Property ;
    rdfs:label 'Consent Method' ;
    rdfs:comment 'The modality through which consent was obtained for this event (e.g., paper ICF, Clinpal eConsent, remote eConsent via video). Relevant for regulatory submissions and site monitoring to confirm GCP-compliant consent procedures.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatusAfter rdf:type rdf:Property ;
    rdfs:label 'Consent Status After' ;
    rdfs:comment 'The overall consent status of the subject-study-site combination immediately after this audit event was applied. Together with consent_status_before, provides a complete state transition record for regulatory inspection and GCP compliance verification.' ;
    rdfs:domain ind:AuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatusBefore rdf:type rdf:Property ;
    rdfs:label 'Consent Status Before' ;
    rdfs:comment 'The overall consent status of the subject-study-site combination immediately before this audit event. Provides a high-level consent lifecycle snapshot independent of field-level changes. Enables chronological consent status history reconstruction per subject.' ;
    rdfs:domain ind:AuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Device Identifier' ;
    rdfs:comment 'Unique identifier of the device (tablet, computer, mobile) used to perform the consent action. Relevant for eConsent sessions via Clinpal where device-level traceability is required for 21 CFR Part 11 compliance.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalSignatureHash rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Hash' ;
    rdfs:comment 'Cryptographic hash of the electronic signature applied to the consent record at the time of this audit event. Validates the integrity and non-repudiation of the electronic consent signature per 21 CFR Part 11 requirements. Sourced from Clinpal eConsent platform.' ;
    rdfs:domain ind:AuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) when the consent domain event occurred in the source system. This is the real-world event time, distinct from the record ingestion timestamp. Mandatory for ALCOA+ contemporaneous data integrity and 21 CFR Part 11 audit trail requirements.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gdprLawfulBasis rdf:type rdf:Property ;
    rdfs:label 'Gdpr Lawful Basis' ;
    rdfs:comment 'The GDPR Article 6/9 lawful basis under which the subject\'s personal data is processed in connection with this consent event. Required for EU/EEA trial sites to demonstrate lawful processing of special category health data.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipaaAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Hipaa Authorization Flag' ;
    rdfs:comment 'Indicates whether a HIPAA Authorization for use and disclosure of Protected Health Information (PHI) was obtained as part of this consent event. Applicable for US trial sites. Required for HIPAA compliance documentation.' ;
    rdfs:domain ind:AuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'IP address of the device from which the consent action was performed. Supports 21 CFR Part 11 electronic records compliance by providing network-level attribution for each consent event. May be considered PII under GDPR.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbIecApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Approval Number' ;
    rdfs:comment 'The IRB or IEC approval reference number associated with the ICF version in effect at the time of this audit event. Confirms that the consent was obtained under a currently approved protocol version, as required by GCP and FDA/EMA regulations.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isVoid rdf:type rdf:Property ;
    rdfs:label 'Is Void' ;
    rdfs:comment 'Indicates whether this audit entry has been voided due to a system error or data correction. Voided entries are retained for regulatory completeness but excluded from active consent status calculations. Supports ALCOA+ Enduring data integrity.' ;
    rdfs:domain ind:AuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:larRelationship rdf:type rdf:Property ;
    rdfs:label 'Lar Relationship' ;
    rdfs:comment 'Relationship of the Legally Authorized Representative (LAR) to the subject when consent was obtained via a surrogate (e.g., parent, legal guardian, spouse). Populated when actor_role = \'LAR\'. Required for vulnerable population consent documentation.' ;
    rdfs:domain ind:AuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newValue rdf:type rdf:Property ;
    rdfs:label 'New Value' ;
    rdfs:comment 'The value of the changed field after this audit event was applied. Stores the resulting state for the modified field. Required for before/after comparison in regulatory inspections and ALCOA+ data integrity verification.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousValue rdf:type rdf:Property ;
    rdfs:label 'Previous Value' ;
    rdfs:comment 'The value of the changed field immediately before this audit event was applied. Null for record creation events. Stored as STRING to accommodate any field type. Required for before/after comparison in regulatory inspections and ALCOA+ Original data integrity.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reConsentTriggerReason rdf:type rdf:Property ;
    rdfs:label 'Re Consent Trigger Reason' ;
    rdfs:comment 'Free-text description of the reason that triggered a re-consent requirement for the subject (e.g., protocol amendment, new safety information, ICF version update). Populated only for event_type = \'re_consented\' or \'status_changed\' to re_consent_required.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when this audit entry record was first ingested into the Silver Layer lakehouse. Distinct from event_timestamp (the real-world event time). Supports data lineage tracking and ETL reconciliation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to this audit entry record in the Silver Layer. Since consent audit entries are immutable by design, this field is expected to remain null after initial load; populated only for void corrections or metadata updates.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:signatureMeaning rdf:type rdf:Property ;
    rdfs:label 'Signature Meaning' ;
    rdfs:comment 'The declared meaning associated with the electronic signature captured at this audit event (e.g., \'I agree\', \'Witnessed\', \'Approved\'). Required by 21 CFR Part 11.50 to associate a meaning with each electronic signature in the audit trail.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'Native record identifier assigned by the originating source system (Clinpal, Veeva Vault, CTMS) for this audit event. Enables traceability back to the system of record for data lineage and reconciliation purposes.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidReason rdf:type rdf:Property ;
    rdfs:label 'Void Reason' ;
    rdfs:comment 'Explanation for why this audit entry was voided. Populated only when is_void = True. Maintains a complete and transparent audit trail even for corrected records, as required by ALCOA+ and 21 CFR Part 11.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDelegationLogId rdf:type rdf:Property ;
    rdfs:label 'Consent Delegation Log Id' ;
    rdfs:comment 'Unique surrogate identifier for each consent delegation log record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:ConsentDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gcpTrainingRecordId rdf:type rdf:Property ;
    rdfs:label 'Gcp Training Record Id' ;
    rdfs:comment 'Reference to the GCP training record in MasterControl that documents the staff member\'s current GCP certification, supporting delegation eligibility verification.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GcpTrainingRecord .

ind:primaryConsentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Consent Employee Id' ;
    rdfs:comment 'Reference to the site staff member (PI, sub-investigator, CRC, or other qualified personnel) to whom consent responsibilities are delegated.' ;
    rdfs:domain ind:ConsentDelegationLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:protocolTrainingRecordId rdf:type rdf:Property ;
    rdfs:label 'Protocol Training Record Id' ;
    rdfs:comment 'Reference to the protocol-specific training record confirming the staff member has been trained on the study protocol prior to conducting consent activities.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProtocolTrainingRecord .

ind:studyAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Study Assignment Id' ;
    rdfs:comment 'Foreign key linking to workforce.study_assignment. Business justification: GCP requires that staff delegated consent responsibilities have a valid study assignment. Linking consent_delegation_log to study_assignment enables direct verification that delegated staff are formal' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudyAssignment .

ind:supersededByLogConsentDelegationLogId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Log Consent Delegation Log Id' ;
    rdfs:comment 'Reference to the newer consent_delegation_log record that supersedes this entry when a delegation is amended or replaced. Null if this is the current active delegation.' ;
    rdfs:domain ind:ConsentDelegationLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsentDelegationLog .

ind:workforceDelegationLogId rdf:type rdf:Property ;
    rdfs:label 'Workforce Delegation Log Id' ;
    rdfs:comment 'Foreign key linking to workforce.workforce_delegation_log. Business justification: ICH E6(R2) requires consent delegation to be traceable to the master site delegation log. Linking consent_delegation_log to workforce_delegation_log enables cross-domain audit trails confirming consen' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkforceDelegationLog .

ind:applicableIcfVersions rdf:type rdf:Property ;
    rdfs:label 'Applicable Icf Versions' ;
    rdfs:comment 'Comma-separated list or range of IRB/IEC-approved ICF version identifiers for which this delegation is valid (e.g., \'v1.0, v1.1, v2.0\'). Ensures the delegated staff member is only authorized for approved consent document versions.' ;
    rdfs:domain ind:ConsentDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationEndDate rdf:type rdf:Property ;
    rdfs:label 'Authorization End Date' ;
    rdfs:comment 'The date on which the staff member\'s consent delegation authority expires or was terminated. Null indicates an open-ended delegation valid until study close-out or explicit withdrawal.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationStartDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Start Date' ;
    rdfs:comment 'The date from which the staff member is authorized to conduct the informed consent process under this delegation. Must not precede the PI signature date.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentScope rdf:type rdf:Property ;
    rdfs:label 'Consent Scope' ;
    rdfs:comment 'Defines the specific consent activities the staff member is authorized to perform under this delegation. \'initial_consent\' covers first-time ICF administration; \'re_consent\' covers protocol amendment re-consent; \'assent\' covers pediatric or capacity-limited subject assent; \'all\' covers all consent activities.' ;
    rdfs:domain ind:ConsentDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsDelegationRef rdf:type rdf:Property ;
    rdfs:label 'Ctms Delegation Ref' ;
    rdfs:comment 'The source system reference identifier for this delegation record as recorded in Oracle Siebel CTMS, supporting data lineage and reconciliation between the lakehouse and the operational system of record.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegatedRole rdf:type rdf:Property ;
    rdfs:label 'Delegated Role' ;
    rdfs:comment 'The site role of the staff member receiving the consent delegation (e.g., sub-investigator, Clinical Research Coordinator (CRC)). Determines the scope of authority granted. [ENUM-REF-CANDIDATE: principal_investigator|sub_investigator|clinical_research_coordinator|study_nurse|research_assistant|other — promote to reference product]' ;
    rdfs:domain ind:ConsentDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegationAmendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Delegation Amendment Number' ;
    rdfs:comment 'Sequential amendment number for this delegation entry, incremented each time the scope, dates, or ICF versions are modified. Version 0 or 1 represents the original delegation; subsequent integers represent amendments.' ;
    rdfs:domain ind:ConsentDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delegationLogNumber rdf:type rdf:Property ;
    rdfs:label 'Delegation Log Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for this delegation log entry, typically generated by the CTMS or site delegation log system. Used for site inspection readiness and audit trail referencing.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegationNotes rdf:type rdf:Property ;
    rdfs:label 'Delegation Notes' ;
    rdfs:comment 'Free-text field for additional context, restrictions, or conditions associated with this consent delegation (e.g., \'authorized for screening visits only\', \'requires PI co-signature for re-consent\').' ;
    rdfs:domain ind:ConsentDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegationStatus rdf:type rdf:Property ;
    rdfs:label 'Delegation Status' ;
    rdfs:comment 'Current lifecycle state of the consent delegation authorization. \'active\' indicates the delegation is currently in force; \'superseded\' indicates replaced by a newer delegation; \'withdrawn\' indicates revoked by the PI; \'expired\' indicates the authorization end date has passed; \'pending\' indicates awaiting PI signature.' ;
    rdfs:domain ind:ConsentDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:econsentPlatformUserCode rdf:type rdf:Property ;
    rdfs:label 'Econsent Platform User Code' ;
    rdfs:comment 'The user account identifier of the delegated staff member within the Clinpal eConsent platform, enabling traceability of eConsent workflow actions to this delegation authorization.' ;
    rdfs:domain ind:ConsentDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageQualifications rdf:type rdf:Property ;
    rdfs:label 'Language Qualifications' ;
    rdfs:comment 'Comma-separated list of languages in which the delegated staff member is qualified to administer the informed consent process (e.g., \'English, Spanish, Mandarin\'). Supports multilingual site operations and subject comprehension requirements.' ;
    rdfs:domain ind:ConsentDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piSignatureCaptured rdf:type rdf:Property ;
    rdfs:label 'Pi Signature Captured' ;
    rdfs:comment 'Indicates whether the PI\'s electronic or wet signature has been captured and stored for this delegation record. Required for GCP compliance and site inspection readiness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:staffMemberName rdf:type rdf:Property ;
    rdfs:label 'Staff Member Name' ;
    rdfs:comment 'Full name of the site staff member to whom consent responsibilities are delegated. Captured at time of delegation for audit trail integrity per ALCOA+ principles, as the staff record may change over time.' ;
    rdfs:domain ind:ConsentDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staffMemberSignatureCaptured rdf:type rdf:Property ;
    rdfs:label 'Staff Member Signature Captured' ;
    rdfs:comment 'Indicates whether the delegated staff member\'s electronic or wet signature has been captured and stored for this delegation record, confirming acknowledgment of delegated responsibilities.' ;
    rdfs:domain ind:ConsentDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:staffMemberSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Staff Member Signature Date' ;
    rdfs:comment 'The date on which the delegated staff member signed the delegation log, acknowledging their responsibilities and scope of consent authority.' ;
    rdfs:domain ind:ConsentDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:staffMemberTitle rdf:type rdf:Property ;
    rdfs:label 'Staff Member Title' ;
    rdfs:comment 'Professional title or credentials of the delegated staff member at the time of delegation (e.g., MD, RN, PhD, CRC). Supports qualification verification for consent delegation eligibility.' ;
    rdfs:domain ind:ConsentDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompletionConfirmed rdf:type rdf:Property ;
    rdfs:label 'Training Completion Confirmed' ;
    rdfs:comment 'Indicates whether the delegated staff member has completed all required GCP and protocol-specific training prior to being authorized to conduct the informed consent process. Must be True before delegation becomes active.' ;
    rdfs:domain ind:ConsentDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentDeviationId rdf:type rdf:Property ;
    rdfs:label 'Consent Deviation Id' ;
    rdfs:comment 'Unique surrogate identifier for each consent deviation record in the lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsentDeviation .

ind:discoveredByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Discovered By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Consent deviation discovery must be attributed to a specific qualified employee for CAPA root cause analysis and regulatory reporting. discovered_by is a plain text denormalization; discovered_by_empl' ;
    rdfs:domain ind:ConsentDeviation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:dispensingRecordId rdf:type rdf:Property ;
    rdfs:label 'Dispensing Record Id' ;
    rdfs:comment 'Foreign key linking to supply.dispensing_record. Business justification: The most critical consent deviation type is IMP dispensed without valid consent. Linking consent_deviation directly to the causative dispensing_record enables root cause analysis, CAPA tracking, and r' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DispensingRecord .

ind:subjectRandomizationId rdf:type rdf:Property ;
    rdfs:label 'Subject Randomization Id' ;
    rdfs:comment 'Foreign key linking to randomization.subject_randomization. Business justification: Consent deviations (e.g., randomization before consent, wrong ICF version at randomization) must be linked to the specific randomization event for population impact assessment, protocol deviation repo' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SubjectRandomization .

ind:consentDeviationDescription rdf:type rdf:Property ;
    rdfs:label 'Consent Deviation Description' ;
    rdfs:comment 'Free-text narrative describing the specific nature of the consent deviation, including what happened, when, and the circumstances surrounding the event. Provides context beyond the structured deviation type classification.' ;
    rdfs:domain ind:ConsentDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Free-text description of the immediate corrective actions taken to address this specific consent deviation instance (e.g., re-consent obtained, missing witness signature collected, subject notified). Distinct from the broader CAPA record which addresses systemic prevention.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataIntegrityImpacted rdf:type rdf:Property ;
    rdfs:label 'Data Integrity Impacted' ;
    rdfs:comment 'Boolean flag indicating whether the consent deviation has a potential impact on the integrity or validity of data collected from the affected subject, which may affect the subject\'s inclusion in analysis populations (ITT, PP).' ;
    rdfs:domain ind:ConsentDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationNumber rdf:type rdf:Property ;
    rdfs:label 'Deviation Number' ;
    rdfs:comment 'Human-readable, externally-known business identifier for the consent deviation record, typically assigned by the CTMS or quality management system (e.g., CD-STUDY001-00042). Used for cross-system referencing, regulatory inspection, and CAPA linkage.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactAssessment rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment' ;
    rdfs:comment 'Narrative assessment of the actual or potential impact of the consent deviation on subject rights, subject safety, data integrity, and study validity. Informs the regulatory reportability determination and severity classification.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReady rdf:type rdf:Property ;
    rdfs:label 'Inspection Ready' ;
    rdfs:comment 'Boolean flag indicating whether this consent deviation record and all associated documentation (CAPA, notifications, re-consent records) are complete and ready for regulatory inspection review. Supports inspection readiness dashboards.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irbIecNotified rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Notified' ;
    rdfs:comment 'Boolean flag indicating whether the Institutional Review Board (IRB) or Independent Ethics Committee (IEC) overseeing the study has been formally notified of this consent deviation, as required by GCP and applicable regulations.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:piAware rdf:type rdf:Property ;
    rdfs:label 'Pi Aware' ;
    rdfs:comment 'Boolean flag indicating whether the Principal Investigator (PI) at the site has been made aware of this consent deviation. PI awareness is a GCP requirement for site-level deviation management.' ;
    rdfs:domain ind:ConsentDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:piAwarenessDate rdf:type rdf:Property ;
    rdfs:label 'Pi Awareness Date' ;
    rdfs:comment 'The date on which the Principal Investigator (PI) was formally made aware of this consent deviation. Used to track timeliness of PI notification and GCP compliance.' ;
    rdfs:domain ind:ConsentDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preventiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Description' ;
    rdfs:comment 'Free-text description of preventive actions planned or implemented to prevent recurrence of this type of consent deviation (e.g., site retraining on ICF version control, system alert configuration in Clinpal for ICF expiry). Complements the formal CAPA record.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconsentCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Reconsent Completed Date' ;
    rdfs:comment 'The date on which the required re-consent process was completed and the subject signed the appropriate ICF version. Nullable if re-consent is not required or has not yet been completed.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportable rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable' ;
    rdfs:comment 'Boolean flag indicating whether this consent deviation must be reported to a regulatory authority (FDA, EMA, MHRA, PMDA, etc.), IRB/IEC, or sponsor per applicable regulations and the study protocol. Drives regulatory submission workflows.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Documented root cause analysis narrative explaining the underlying reason the consent deviation occurred (e.g., site staff training gap, ICF version control failure, system notification failure for re-consent trigger). Used to drive CAPA development and prevent recurrence.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectContinuedInStudy rdf:type rdf:Property ;
    rdfs:label 'Subject Continued In Study' ;
    rdfs:comment 'Boolean flag indicating whether the affected subject continued participation in the clinical study following the consent deviation and any required corrective actions. A value of False may indicate subject withdrawal or discontinuation related to the deviation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subjectRightsImpacted rdf:type rdf:Property ;
    rdfs:label 'Subject Rights Impacted' ;
    rdfs:comment 'Boolean flag indicating whether the consent deviation directly impacted the rights or welfare of the trial subject (e.g., subject underwent a procedure without valid informed consent). Critical for regulatory reportability and IRB/IEC notification decisions.' ;
    rdfs:domain ind:ConsentDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentIcfVersionConsentIcfVersionId rdf:type rdf:Property ;
    rdfs:label 'Parent Icf Version Consent Icf Version Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent ICF version from which this version was derived. Used to track amendment lineage (e.g., v1.0 → v2.0) and translation relationships (e.g., English master → Spanish translation). Null for the initial root version.' ;
    rdfs:domain ind:ConsentIcfVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsentIcfVersion .

ind:templateId rdf:type rdf:Property ;
    rdfs:label 'Template Id' ;
    rdfs:comment 'Foreign key linking to document.document_template. Business justification: ICF versions are authored from sponsor-approved document templates. Regulatory inspectors verify that the correct, current-version template was used to create each ICF. Tracing consent_icf_version to ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Template .

ind:affectedPopulationDescription rdf:type rdf:Property ;
    rdfs:label 'Affected Population Description' ;
    rdfs:comment 'Description of the subject population affected by the ICF amendment, specifying which enrolled subjects must be re-consented (e.g., \'All currently enrolled subjects\', \'Subjects in Cohort A only\', \'Subjects who have not yet completed Visit 4\').' ;
    rdfs:domain ind:ConsentIcfVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentNatureOfChange rdf:type rdf:Property ;
    rdfs:label 'Amendment Nature Of Change' ;
    rdfs:comment 'Free-text description of the substantive changes introduced in this ICF version relative to the prior version, including new risks, procedures, or study design changes that required IRB/IEC re-review. Supports regulatory inspection and re-consent decision-making.' ;
    rdfs:domain ind:ConsentIcfVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backTranslationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Back Translation Completion Date' ;
    rdfs:comment 'The date on which the back-translation quality review was completed and approved for this translated ICF version. Null for master language versions or translations where back-translation is not yet complete.' ;
    rdfs:domain ind:ConsentIcfVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backTranslationStatus rdf:type rdf:Property ;
    rdfs:label 'Back Translation Status' ;
    rdfs:comment 'Status of the back-translation quality check for this translated ICF version. \'not_required\' = master language version; \'pending\' = back-translation in progress; \'completed\' = back-translation verified and approved; \'failed\' = back-translation identified discrepancies requiring correction.' ;
    rdfs:domain ind:ConsentIcfVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biobankingConsentIncluded rdf:type rdf:Property ;
    rdfs:label 'Biobanking Consent Included' ;
    rdfs:comment 'Indicates whether this ICF version includes optional or mandatory consent language for the collection, storage, and future use of biological samples (biobanking). Relevant for studies collecting samples for future exploratory research.' ;
    rdfs:domain ind:ConsentIcfVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clinpalConsentFormCode rdf:type rdf:Property ;
    rdfs:label 'Clinpal Consent Form Code' ;
    rdfs:comment 'The unique identifier assigned by Clinpal (eConsent platform) to the deployed electronic consent form corresponding to this ICF version. Enables reconciliation between the eTMF document record and the active eConsent workflow.' ;
    rdfs:domain ind:ConsentIcfVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'Classification of the consent form by its purpose in the subject enrollment lifecycle. \'initial\' = first consent at enrollment; \'re-consent\' = required after protocol amendment or new safety information; \'assent\' = minor subject assent form; \'lar\' = Legally Authorized Representative consent; \'short_form\' = abbreviated oral consent form; \'addendum\' = supplemental consent for a specific procedure.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:econsentDeploymentDate rdf:type rdf:Property ;
    rdfs:label 'Econsent Deployment Date' ;
    rdfs:comment 'The date on which this ICF version was deployed and activated in the Clinpal eConsent platform for subject use. Null if eConsent is not enabled for this version.' ;
    rdfs:domain ind:ConsentIcfVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:econsentEnabled rdf:type rdf:Property ;
    rdfs:label 'Econsent Enabled' ;
    rdfs:comment 'Indicates whether this ICF version is deployed as an electronic consent (eConsent) form via Clinpal. True = eConsent workflow is active in Clinpal for this version; False = paper-based consent only.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprDataProcessingIncluded rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Processing Included' ;
    rdfs:comment 'Indicates whether this ICF version includes the required GDPR data processing disclosure and consent language for EU/EEA subjects, covering data controller identity, processing purposes, data subject rights, and cross-border transfer provisions.' ;
    rdfs:domain ind:ConsentIcfVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geneticTestingConsentIncluded rdf:type rdf:Property ;
    rdfs:label 'Genetic Testing Consent Included' ;
    rdfs:comment 'Indicates whether this ICF version includes specific consent language for genetic or genomic testing, as required by applicable regulations and IRB/IEC requirements for studies involving genetic data collection.' ;
    rdfs:domain ind:ConsentIcfVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hipaaAuthorizationIncluded rdf:type rdf:Property ;
    rdfs:label 'Hipaa Authorization Included' ;
    rdfs:comment 'Indicates whether this ICF version incorporates the HIPAA Authorization for use and disclosure of Protected Health Information (PHI), as required for U.S. clinical trial subjects under 45 CFR 164.508.' ;
    rdfs:domain ind:ConsentIcfVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:icfTitle rdf:type rdf:Property ;
    rdfs:label 'Icf Title' ;
    rdfs:comment 'The official title of the Informed Consent Form as it appears on the document header (e.g., \'Informed Consent Form for Study XYZ-001 — Version 2.0 — Spanish\'). Used for document identification in the eTMF and regulatory binder.' ;
    rdfs:domain ind:ConsentIcfVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icfVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Icf Version Number' ;
    rdfs:comment 'The official version number of the ICF as assigned by the sponsor or CRO (e.g., \'1.0\', \'2.1\', \'3.0a\'). Used to uniquely identify and reference the ICF version in regulatory submissions, IRB/IEC correspondence, and subject consent records.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Internal Review Status' ;
    rdfs:comment 'Tracks the internal document lifecycle status of the ICF version within the sponsor/CRO quality management workflow, distinct from the external IRB/IEC regulatory approval status. [ENUM-REF-CANDIDATE: in_authoring|internal_review|sponsor_approved|submitted_to_irb_iec|approved|archived — promote to reference product]' ;
    rdfs:domain ind:ConsentIcfVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMasterLanguage rdf:type rdf:Property ;
    rdfs:label 'Is Master Language' ;
    rdfs:comment 'Indicates whether this ICF version is the master (source) language version from which translations are derived. True = this is the authoritative master language document; False = this is a translation derived from a master language version.' ;
    rdfs:domain ind:ConsentIcfVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:larConsentApplicable rdf:type rdf:Property ;
    rdfs:label 'Lar Consent Applicable' ;
    rdfs:comment 'Indicates whether this ICF version includes or supports consent by a Legally Authorized Representative (LAR) on behalf of a subject who lacks decision-making capacity. Relevant for emergency research, pediatric studies, or cognitively impaired populations.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:readabilityGradeLevel rdf:type rdf:Property ;
    rdfs:label 'Readability Grade Level' ;
    rdfs:comment 'The assessed reading grade level of this ICF version (e.g., \'6th grade\', \'8th grade\') based on a standardized readability assessment (e.g., Flesch-Kincaid, Gunning Fog). Regulatory guidance recommends ICFs be written at an 8th grade reading level or below to ensure subject comprehension.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconsentDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Reconsent Deadline Date' ;
    rdfs:comment 'The date by which all affected enrolled subjects must be re-consented using this ICF version, as specified by the IRB/IEC approval conditions or sponsor protocol. Null if re-consent is not required.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryBasisForChange rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis For Change' ;
    rdfs:comment 'The regulatory or scientific rationale driving the ICF amendment (e.g., new safety signal from DSMB review, protocol design change, updated risk-benefit information, new IND safety report, SUSAR notification). Provides audit trail for regulatory submissions.' ;
    rdfs:domain ind:ConsentIcfVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translatorName rdf:type rdf:Property ;
    rdfs:label 'Translator Name' ;
    rdfs:comment 'Full name of the qualified translator responsible for producing this translated ICF version. Applicable only for non-master-language versions. Required for translation quality audit trail.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vaultDocumentCode rdf:type rdf:Property ;
    rdfs:label 'Vault Document Code' ;
    rdfs:comment 'The unique document identifier assigned by Veeva Vault (eTMF) to the ICF document record. Enables direct traceability back to the source system document for audit and regulatory inspection purposes.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vaultLifecycleState rdf:type rdf:Property ;
    rdfs:label 'Vault Lifecycle State' ;
    rdfs:comment 'The document lifecycle state as managed within Veeva Vault eTMF, reflecting the document management workflow state. Distinct from the regulatory approval_status — this represents the eTMF system-level document state used for TMF completeness and inspection readiness tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessSignatureRequired rdf:type rdf:Property ;
    rdfs:label 'Witness Signature Required' ;
    rdfs:comment 'Indicates whether a witness signature is required on this ICF version in addition to the subject and investigator signatures (e.g., for illiterate subjects, subjects using a short form, or per local regulatory requirements).' ;
    rdfs:domain ind:ConsentIcfVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:translationId rdf:type rdf:Property ;
    rdfs:label 'Translation Id' ;
    rdfs:comment 'Unique surrogate identifier for each Informed Consent Form (ICF) translation record in the Silver Layer lakehouse. Primary key for the consent_translation data product.' ;
    rdfs:domain ind:Translation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countryId rdf:type rdf:Property ;
    rdfs:label 'Country Id' ;
    rdfs:comment 'Foreign key linking to study.study_country. Business justification: Consent translations are country-specific and must align with country-level IRB/IEC approvals and regulatory requirements. Linking consent_translation to study_country enables country activation readi' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:qualityReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quality Reviewer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: ICF translation quality review must be performed by a qualified internal employee per GCP and IRB requirements. quality_reviewer_name is a plain text denormalization; quality_reviewer_employee_id enab' ;
    rdfs:domain ind:Translation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByTranslationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Translation Id' ;
    rdfs:comment 'Reference to the newer consent_translation record that replaced this version. Enables forward navigation of the translation version chain for audit and compliance purposes.' ;
    rdfs:domain ind:Translation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Translation .

ind:backTranslationComplete rdf:type rdf:Property ;
    rdfs:label 'Back Translation Complete' ;
    rdfs:comment 'Indicates whether the back-translation process has been completed for this ICF translation. True = back-translation is complete and reconciled. Used to gate IRB/IEC submission readiness.' ;
    rdfs:domain ind:Translation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backTranslationDate rdf:type rdf:Property ;
    rdfs:label 'Back Translation Date' ;
    rdfs:comment 'The date on which the back-translation of the ICF was completed and reconciled against the source document. Null if back-translation has not been completed.' ;
    rdfs:domain ind:Translation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backTranslationRequired rdf:type rdf:Property ;
    rdfs:label 'Back Translation Required' ;
    rdfs:comment 'Indicates whether a back-translation (re-translation from target language back to source language) is required for this ICF translation per sponsor or regulatory requirements. True = back-translation is mandated.' ;
    rdfs:domain ind:Translation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backTranslatorName rdf:type rdf:Property ;
    rdfs:label 'Back Translator Name' ;
    rdfs:comment 'Full name of the individual or vendor who performed the back-translation of the ICF. Must be independent from the forward translator per GCP best practice.' ;
    rdfs:domain ind:Translation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFileName rdf:type rdf:Property ;
    rdfs:label 'Document File Name' ;
    rdfs:comment 'File name of the translated ICF document as stored in the eTMF or document management system (e.g., Veeva Vault). Supports document retrieval and audit trail.' ;
    rdfs:domain ind:Translation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:econsentPlatformRef rdf:type rdf:Property ;
    rdfs:label 'Econsent Platform Ref' ;
    rdfs:comment 'Reference identifier for this translated ICF version within the eConsent platform (Clinpal). Enables traceability between the lakehouse record and the operational eConsent workflow system.' ;
    rdfs:domain ind:Translation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbIecApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Approval Status' ;
    rdfs:comment 'Current approval status of this translated ICF version with the relevant IRB or IEC. \'not_submitted\' = pending submission; \'submitted\' = under review; \'approved\' = ethics committee approved; \'rejected\' = not approved; \'waived\' = formal approval waived by authority.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityReviewComplete rdf:type rdf:Property ;
    rdfs:label 'Quality Review Complete' ;
    rdfs:comment 'Indicates whether a formal quality review (QC check) of the translated ICF has been completed by the sponsor, CRO, or designated reviewer. True = QC review passed. Supports GCP quality assurance requirements.' ;
    rdfs:domain ind:Translation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityReviewDate rdf:type rdf:Property ;
    rdfs:label 'Quality Review Date' ;
    rdfs:comment 'The date on which the quality review of the translated ICF was completed. Null if quality review has not yet been performed.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:readabilityScore rdf:type rdf:Property ;
    rdfs:label 'Readability Score' ;
    rdfs:comment 'Numeric readability score of the translated ICF document (e.g., Flesch-Kincaid or equivalent localized readability metric). Regulatory guidance recommends ICF documents be written at an appropriate reading level for the target population.' ;
    rdfs:domain ind:Translation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationNotes rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Notes' ;
    rdfs:comment 'Free-text notes documenting any discrepancies identified during back-translation reconciliation and how they were resolved. Supports audit trail and regulatory inspection readiness.' ;
    rdfs:domain ind:Translation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionName rdf:type rdf:Property ;
    rdfs:label 'Region Name' ;
    rdfs:comment 'Named geographic region or territory for which this translation applies when a single language spans multiple countries (e.g., \'Latin America Spanish\', \'Canadian French\'). Supplements country_code for multi-country language variants.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceIcfVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Source Icf Version Number' ;
    rdfs:comment 'The version number of the source (original language) ICF document that was translated, as assigned by the sponsor or CRO (e.g., v1.0, v2.1). Ensures traceability between source and translated documents.' ;
    rdfs:domain ind:Translation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Source Language Code' ;
    rdfs:comment 'ISO 639-1 two-letter code representing the original language of the ICF document prior to translation (e.g., \'en\' for English). Establishes the translation direction.' ;
    rdfs:domain ind:Translation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Sponsor Approval Required' ;
    rdfs:comment 'Indicates whether formal sponsor approval is required for this translated ICF version before it can be submitted to the IRB/IEC or used at site. True = sponsor sign-off is mandatory.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Target Language Code' ;
    rdfs:comment 'ISO 639-1 two-letter code representing the language into which the ICF was translated (e.g., \'fr\' for French, \'de\' for German, \'ja\' for Japanese). Required per GCP ICH E6 to provide consent in the subject\'s native language.' ;
    rdfs:domain ind:Translation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLanguageName rdf:type rdf:Property ;
    rdfs:label 'Target Language Name' ;
    rdfs:comment 'Human-readable full name of the target language (e.g., \'French\', \'German\', \'Japanese\'). Complements the ISO code for display in reports and regulatory submissions.' ;
    rdfs:domain ind:Translation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translationCode rdf:type rdf:Property ;
    rdfs:label 'Translation Code' ;
    rdfs:comment 'Externally-known unique business identifier for this translation record, following the format TRN-{StudyCode}-{LanguageCode}-{Sequence}. Used in eTMF filing, IRB/IEC submissions, and vendor communications.' ;
    rdfs:domain ind:Translation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translationDate rdf:type rdf:Property ;
    rdfs:label 'Translation Date' ;
    rdfs:comment 'The date on which the forward translation of the ICF was completed by the translation vendor or translator. Establishes the timeline for regulatory and IRB/IEC review.' ;
    rdfs:domain ind:Translation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:translationStatus rdf:type rdf:Property ;
    rdfs:label 'Translation Status' ;
    rdfs:comment 'Current lifecycle status of the ICF translation document. \'draft\' = initial translation in progress; \'under_review\' = submitted for back-translation or IRB/IEC review; \'approved\' = IRB/IEC approved for use at site; \'superseded\' = replaced by a newer version; \'withdrawn\' = removed from use.' ;
    rdfs:domain ind:Translation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translationType rdf:type rdf:Property ;
    rdfs:label 'Translation Type' ;
    rdfs:comment 'Classifies the type of consent document translated. \'full\' = complete ICF; \'summary\' = short-form consent summary; \'assent\' = pediatric assent form; \'lay_summary\' = plain language summary; \'amendment_only\' = translation of an ICF amendment only.' ;
    rdfs:domain ind:Translation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translatorQualification rdf:type rdf:Property ;
    rdfs:label 'Translator Qualification' ;
    rdfs:comment 'Description of the translator\'s professional qualifications, certifications, or credentials (e.g., ATA Certified Translator, medical translation specialist). Supports GCP documentation of qualified personnel.' ;
    rdfs:domain ind:Translation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverId rdf:type rdf:Property ;
    rdfs:label 'Waiver Id' ;
    rdfs:comment 'Unique surrogate identifier for the consent waiver record in the lakehouse Silver layer. Primary key for this entity.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByWaiverId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Waiver Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the newer consent waiver record that supersedes this one, enabling version chain traceability. Null if this is the current active version.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Waiver .

ind:communityConsultationConducted rdf:type rdf:Property ;
    rdfs:label 'Community Consultation Conducted' ;
    rdfs:comment 'Indicates whether community consultation was conducted prior to initiating the study under this waiver, as required for emergency research exception under 21 CFR 50.24. Mandatory for FDA-regulated emergency research.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionsAttached rdf:type rdf:Property ;
    rdfs:label 'Conditions Attached' ;
    rdfs:comment 'Any conditions, restrictions, or obligations imposed by the IRB/IEC as part of granting the waiver (e.g., requirement to notify subjects post-study, community consultation obligations, mandatory safety reporting thresholds).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyImpactAssessed rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Impact Assessed' ;
    rdfs:comment 'Indicates whether a Data Protection Impact Assessment (DPIA) was conducted prior to processing personal data under this consent waiver, as required by GDPR Article 35 for high-risk processing activities.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprLegalBasis rdf:type rdf:Property ;
    rdfs:label 'Gdpr Legal Basis' ;
    rdfs:comment 'The GDPR Article 6/9 legal basis under which personal data is processed when informed consent is waived. Required for EU/EEA studies to ensure lawful processing of personal data without subject consent.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipaaAuthorizationWaived rdf:type rdf:Property ;
    rdfs:label 'Hipaa Authorization Waived' ;
    rdfs:comment 'Indicates whether a HIPAA Authorization waiver has also been granted alongside the informed consent waiver, permitting use of Protected Health Information (PHI) without individual authorization. Applicable to US-based studies.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this consent waiver record. Supports ALCOA+ audit trail requirements and change detection in the Silver layer.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:piAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Pi Acknowledgement Date' ;
    rdfs:comment 'Date on which the Principal Investigator acknowledged receipt and understanding of the consent waiver approval and its conditions. Required for GCP compliance and site activation under the waiver.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postStudyNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Post Study Notification Required' ;
    rdfs:comment 'Indicates whether the IRB/IEC has mandated that subjects (or their representatives) must be notified of their participation after the fact, as a condition of the waiver. Common in emergency research under 21 CFR 50.24.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicDisclosureConducted rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Conducted' ;
    rdfs:comment 'Indicates whether public disclosure of the research was made prior to and following completion of the study, as required under 21 CFR 50.24 for exception from informed consent in emergency research.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rationale rdf:type rdf:Property ;
    rdfs:label 'Rationale' ;
    rdfs:comment 'Detailed justification explaining why the waiver of informed consent is appropriate for this study and subject population. Must satisfy IRB/IEC criteria and is included in the regulatory submission package.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Name' ;
    rdfs:comment 'Name of the regulatory authority notified or that granted approval for the waiver (e.g., FDA, EMA, MHRA, PMDA, TGA, Health Canada). Supports multi-jurisdictional regulatory tracking.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Date' ;
    rdfs:comment 'Date on which the consent waiver documentation was submitted to the applicable regulatory authority. Required for compliance tracking and regulatory inspection readiness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalRequired rdf:type rdf:Property ;
    rdfs:label 'Renewal Required' ;
    rdfs:comment 'Indicates whether this consent waiver requires periodic renewal by the IRB/IEC (e.g., annual continuing review). Drives renewal workflow and expiry notifications.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:researchCategory rdf:type rdf:Property ;
    rdfs:label 'Research Category' ;
    rdfs:comment 'Categorises the type of research context that necessitates the consent waiver. Drives applicable regulatory framework and reporting requirements. [ENUM-REF-CANDIDATE: emergency_research|retrospective_data_use|minimal_risk|public_benefit|deceased_subjects|other — promote to reference product if additional categories are needed]' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectPopulationDescription rdf:type rdf:Property ;
    rdfs:label 'Subject Population Description' ;
    rdfs:comment 'Narrative description of the subject population to which this waiver applies (e.g., unconscious emergency patients, retrospective data subjects, deceased individuals). Defines eligibility boundaries for waiver application.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectsEnrolledUnderWaiver rdf:type rdf:Property ;
    rdfs:label 'Subjects Enrolled Under Waiver' ;
    rdfs:comment 'Count of subjects enrolled into the study under the authority of this consent waiver. Tracked for regulatory reporting and IRB/IEC continuing review submissions.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waivedElements rdf:type rdf:Property ;
    rdfs:label 'Waived Elements' ;
    rdfs:comment 'For waiver_of_elements type: free-text enumeration of the specific ICF elements that have been waived (e.g., right to withdraw, disclosure of experimental nature). Populated only when waiver_type is waiver_of_elements or alteration_of_consent.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverNumber rdf:type rdf:Property ;
    rdfs:label 'Waiver Number' ;
    rdfs:comment 'Externally-known, human-readable unique reference number assigned to this consent waiver by the IRB/IEC or the sponsor/CRO. Used in regulatory submissions and audit trails.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverScope rdf:type rdf:Property ;
    rdfs:label 'Waiver Scope' ;
    rdfs:comment 'Defines the operational scope of the waiver: study_wide (applies to all sites and subjects), site_specific (limited to a named site), subject_population_specific (limited to a defined subject cohort), procedure_specific (limited to a particular study procedure).' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverStatus rdf:type rdf:Property ;
    rdfs:label 'Waiver Status' ;
    rdfs:comment 'Current lifecycle state of the consent waiver from initial drafting through IRB/IEC approval, active use, expiry, or withdrawal. Controls whether the waiver may be applied to new subjects. [ENUM-REF-CANDIDATE: draft|submitted|approved|active|expired|withdrawn|superseded — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverType rdf:type rdf:Property ;
    rdfs:label 'Waiver Type' ;
    rdfs:comment 'Classification of the consent waiver: full_waiver (entire informed consent requirement waived), waiver_of_documentation (verbal consent permitted, no written ICF required), waiver_of_elements (specific ICF elements omitted), alteration_of_consent (consent process modified). Drives regulatory reporting obligations.' ;
    rdfs:domain ind:Waiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalId rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Id' ;
    rdfs:comment 'Unique surrogate identifier for the consent withdrawal event record. Primary key for the consent_withdrawal data product in the Silver Layer lakehouse.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Withdrawal .

ind:complianceProtocolDeviationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Protocol Deviation Id' ;
    rdfs:comment 'Foreign key linking to compliance.protocol_deviation. Business justification: Consent withdrawals can trigger protocol deviations (e.g., subject withdraws mid-treatment requiring deviation reporting). consent_withdrawal has protocol_deviation_triggered flag but no FK to the spe' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProtocolDeviation .

ind:ctmsWithdrawalRef rdf:type rdf:Property ;
    rdfs:label 'Ctms Withdrawal Ref' ;
    rdfs:comment 'Cross-reference identifier for this withdrawal event in Oracle Siebel CTMS, enabling reconciliation between the lakehouse Silver Layer and the operational CTMS system of record.' ;
    rdfs:domain ind:Withdrawal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionStatus rdf:type rdf:Property ;
    rdfs:label 'Data Retention Status' ;
    rdfs:comment 'Current status of the subject\'s data retention following withdrawal. Tracks whether data has been retained, anonymized, or destroyed in accordance with post_withdrawal_data_handling instructions and applicable privacy regulations.' ;
    rdfs:domain ind:Withdrawal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcSubjectStatusUpdated rdf:type rdf:Property ;
    rdfs:label 'Edc Subject Status Updated' ;
    rdfs:comment 'Indicates whether the subject\'s status in the Electronic Data Capture (EDC) system (Medidata Rave) has been updated to reflect the withdrawal, ensuring downstream data collection is halted appropriately.' ;
    rdfs:domain ind:Withdrawal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatedBy rdf:type rdf:Property ;
    rdfs:label 'Initiated By' ;
    rdfs:comment 'Identifies the party who formally initiated the withdrawal: \'subject\' (the enrolled participant), \'lar\' (Legally Authorized Representative acting on behalf of the subject), \'investigator\' (Principal Investigator or site physician), \'sponsor\' (study sponsor or CRO), \'regulatory_authority\' (FDA, EMA, or other governing body mandate).' ;
    rdfs:domain ind:Withdrawal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbIecNotifiedDate rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Notified Date' ;
    rdfs:comment 'Date on which the IRB or IEC was formally notified of the consent withdrawal, when notification was required.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ittPopulationImpact rdf:type rdf:Property ;
    rdfs:label 'Itt Population Impact' ;
    rdfs:comment 'Indicates the impact of this withdrawal on the subject\'s inclusion in the Intent-to-Treat (ITT) analysis population: \'included\' means the subject remains in ITT per SAP rules; \'excluded\' means the subject is removed from ITT; \'pending_review\' means biostatistics team review is required.' ;
    rdfs:domain ind:Withdrawal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pi Notification Timestamp' ;
    rdfs:comment 'Date and time at which the Principal Investigator (PI) was formally notified of the consent withdrawal event.' ;
    rdfs:domain ind:Withdrawal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:piNotified rdf:type rdf:Property ;
    rdfs:label 'Pi Notified' ;
    rdfs:comment 'Indicates whether the Principal Investigator (PI) has been formally notified of the subject\'s withdrawal of consent, as required by GCP.' ;
    rdfs:domain ind:Withdrawal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postWithdrawalDataHandling rdf:type rdf:Property ;
    rdfs:label 'Post Withdrawal Data Handling' ;
    rdfs:comment 'Specifies how previously collected subject data must be handled following withdrawal, per protocol and applicable regulations. \'retain_all\' allows retention of all data collected prior to withdrawal; \'retain_safety_only\' retains only safety-relevant data; \'destroy_all\' requires deletion of all subject data; \'anonymize\' requires de-identification; \'per_protocol\' defers to the protocol-specific data handling plan.' ;
    rdfs:domain ind:Withdrawal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolDeviationTriggered rdf:type rdf:Property ;
    rdfs:label 'Protocol Deviation Triggered' ;
    rdfs:comment 'Indicates whether the consent withdrawal event triggered a protocol deviation that must be reported to the sponsor, IRB/IEC, or regulatory authority.' ;
    rdfs:domain ind:Withdrawal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reasonCategory rdf:type rdf:Property ;
    rdfs:label 'Reason Category' ;
    rdfs:comment 'Standardized categorical classification of the primary reason for withdrawal. \'voluntary\' indicates subject-initiated without specific cause; \'adverse_event_related\' indicates withdrawal driven by an Adverse Event (AE) or safety concern; \'sponsor_decision\' indicates sponsor or regulatory authority-mandated withdrawal; \'lost_to_follow_up\' indicates subject is unreachable; \'protocol_non_compliance\' indicates withdrawal due to protocol deviation; \'physician_decision\' indicates investigator-initiated withdrawal for medical reasons. [ENUM-REF-CANDIDATE: voluntary|adverse_event_related|sponsor_decision|lost_to_follow_up|protocol_non_compliance|physician_decision — promote to reference product]' ;
    rdfs:domain ind:Withdrawal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconsentAttempted rdf:type rdf:Property ;
    rdfs:label 'Reconsent Attempted' ;
    rdfs:comment 'Indicates whether site staff attempted to re-consent the subject before the withdrawal was finalized, for example by providing additional information or addressing concerns.' ;
    rdfs:domain ind:Withdrawal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconsentOutcome rdf:type rdf:Property ;
    rdfs:label 'Reconsent Outcome' ;
    rdfs:comment 'Outcome of the re-consent attempt: \'successful\' indicates the subject agreed to continue and withdrawal was rescinded; \'unsuccessful\' indicates the subject maintained the withdrawal decision; \'not_attempted\' indicates no re-consent was attempted.' ;
    rdfs:domain ind:Withdrawal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyFollowUpEndDate rdf:type rdf:Property ;
    rdfs:label 'Safety Follow Up End Date' ;
    rdfs:comment 'The date through which safety follow-up activities must continue for the subject post-withdrawal, as defined by the protocol. Applicable when safety_follow_up_required is true.' ;
    rdfs:domain ind:Withdrawal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyFollowUpRequired rdf:type rdf:Property ;
    rdfs:label 'Safety Follow Up Required' ;
    rdfs:comment 'Indicates whether the subject requires ongoing safety follow-up activities (e.g., SAE reporting, survival follow-up) after withdrawal of consent, as mandated by the protocol or regulatory requirements.' ;
    rdfs:domain ind:Withdrawal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:studyDiscontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Study Discontinuation Date' ;
    rdfs:comment 'Date on which the subject was formally discontinued from the study following consent withdrawal. Used for Intent-to-Treat (ITT) and Per Protocol (PP) population analyses.' ;
    rdfs:domain ind:Withdrawal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subjectStatedReason rdf:type rdf:Property ;
    rdfs:label 'Subject Stated Reason' ;
    rdfs:comment 'Free-text verbatim reason for withdrawal as stated by the subject or their Legally Authorized Representative (LAR). Captured to support ALCOA+ attributability and regulatory audit requirements. May contain sensitive personal context.' ;
    rdfs:domain ind:Withdrawal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmfFilingStatus rdf:type rdf:Property ;
    rdfs:label 'Tmf Filing Status' ;
    rdfs:comment 'Status of the withdrawal documentation filing in the electronic Trial Master File (eTMF) in Veeva Vault: \'pending\' indicates documents are awaiting upload; \'filed\' indicates documents have been uploaded; \'verified\' indicates QC review of the filing is complete.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentStopDate rdf:type rdf:Property ;
    rdfs:label 'Treatment Stop Date' ;
    rdfs:comment 'Date on which the subject\'s investigational treatment was discontinued as a result of the consent withdrawal. May differ from the withdrawal_timestamp for treatment_withdrawal type.' ;
    rdfs:domain ind:Withdrawal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withdrawalMethod rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Method' ;
    rdfs:comment 'The medium through which the withdrawal was communicated and documented: \'electronic\' via Clinpal eConsent platform, \'paper\' via signed paper form, \'verbal\' with documented witness, \'telephone\' with documented confirmation.' ;
    rdfs:domain ind:Withdrawal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalNumber rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for this withdrawal event, typically generated by the eConsent system (Clinpal) or CTMS (Oracle Siebel). Used for cross-system traceability and regulatory audit trails.' ;
    rdfs:domain ind:Withdrawal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalStatus rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Status' ;
    rdfs:comment 'Current lifecycle state of the withdrawal record. \'pending\' indicates the withdrawal has been initiated but not yet formally confirmed; \'confirmed\' indicates the withdrawal is complete and binding; \'rescinded\' indicates the subject reversed the withdrawal and re-consented; \'superseded\' indicates replaced by a subsequent withdrawal event; \'archived\' indicates the record has been closed out.' ;
    rdfs:domain ind:Withdrawal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Timestamp' ;
    rdfs:comment 'The precise date and time (with timezone offset) at which the subject or their Legally Authorized Representative (LAR) formally communicated withdrawal of consent. This is the principal real-world event time per GCP requirements and ALCOA+ principles.' ;
    rdfs:domain ind:Withdrawal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:withdrawalType rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Type' ;
    rdfs:comment 'Categorizes the scope of the withdrawal: \'full_withdrawal\' means the subject withdraws from all study activities and data use; \'treatment_withdrawal\' means withdrawal from investigational treatment only while allowing continued data collection; \'data_use_withdrawal\' means the subject requests no further use of their data; \'future_sample_withdrawal\' means withdrawal of consent for future use of biological samples.' ;
    rdfs:domain ind:Withdrawal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinpalSessionRef rdf:type rdf:Property ;
    rdfs:label 'Clinpal Session Ref' ;
    rdfs:comment 'The native session identifier assigned by the Clinpal eConsent platform for this workflow session. Used for cross-system traceability and reconciliation with the source system of record.' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationPlatform rdf:type rdf:Property ;
    rdfs:label 'Communication Platform' ;
    rdfs:comment 'The teleconference or video communication platform used for remote consent sessions (e.g., Zoom, Microsoft Teams, WebEx). Applicable only when session_modality is \'remote-video\' or \'remote-phone\'. [ENUM-REF-CANDIDATE: Zoom|Teams|WebEx|Skype|Clinpal-Video|Phone|Other — promote to reference product]' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comprehensionAttemptNumber rdf:type rdf:Property ;
    rdfs:label 'Comprehension Attempt Number' ;
    rdfs:comment 'The sequential attempt number for the comprehension check within this session. Subjects may be permitted multiple attempts after remediation. Tracks how many times the subject attempted the comprehension assessment.' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:comprehensionCheckVersion rdf:type rdf:Property ;
    rdfs:label 'Comprehension Check Version' ;
    rdfs:comment 'Version identifier of the comprehension check question set administered to the subject during this session. Ensures traceability to the specific validated question set used, as question sets may be updated with ICF amendments.' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comprehensionOverallPassed rdf:type rdf:Property ;
    rdfs:label 'Comprehension Overall Passed' ;
    rdfs:comment 'Indicates whether the subject passed the overall comprehension check for this session (True = passed; False = failed). Determined by comparing the score against the minimum passing threshold defined in the ICF version.' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:comprehensionQuestionsPassed rdf:type rdf:Property ;
    rdfs:label 'Comprehension Questions Passed' ;
    rdfs:comment 'Number of comprehension check questions answered correctly by the subject in this session. Used to compute the overall comprehension score and determine pass/fail outcome.' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:comprehensionQuestionsTotal rdf:type rdf:Property ;
    rdfs:label 'Comprehension Questions Total' ;
    rdfs:comment 'Total number of comprehension check questions administered to the subject in this session. Used to calculate the comprehension score and assess understanding of the consent content.' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consentGranted rdf:type rdf:Property ;
    rdfs:label 'Consent Granted' ;
    rdfs:comment 'Indicates whether the subject (or legally authorized representative) granted informed consent at the conclusion of this session (True = consent granted; False = consent not granted or declined). The definitive consent outcome flag for this session.' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceOs rdf:type rdf:Property ;
    rdfs:label 'Device Os' ;
    rdfs:comment 'Operating system and version of the device used during the eConsent session (e.g., iOS 16.4, Android 13, Windows 11). Supports technical audit trail and system validation requirements under 21 CFR Part 11.' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'Category of device used by the subject to access and complete the eConsent session. Supports technical audit trail requirements and device compatibility analysis.' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esignatureCaptured rdf:type rdf:Property ;
    rdfs:label 'Esignature Captured' ;
    rdfs:comment 'Indicates whether an electronic signature was successfully captured from the subject (or legally authorized representative) during this session (True = captured; False = not captured). A prerequisite for consent to be considered legally valid under 21 CFR Part 11.' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:esignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Esignature Timestamp' ;
    rdfs:comment 'Date and time (with timezone offset) when the subject\'s electronic signature was captured in Clinpal. Critical for ALCOA+ (Contemporaneous) compliance and 21 CFR Part 11 audit trail. Null if no signature was captured.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:irbApprovalRef rdf:type rdf:Property ;
    rdfs:label 'Irb Approval Ref' ;
    rdfs:comment 'The IRB or IEC approval number or reference associated with the ICF version used in this session. Confirms the consent document presented was approved by the appropriate ethics body at the time of the session.' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconsentTrigger rdf:type rdf:Property ;
    rdfs:label 'Reconsent Trigger' ;
    rdfs:comment 'Indicates whether this session was initiated as a re-consent event (True) rather than an initial consent (False). Re-consent is triggered by protocol amendments, new safety information, or ICF version updates requiring subjects to re-affirm consent.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationProvided rdf:type rdf:Property ;
    rdfs:label 'Remediation Provided' ;
    rdfs:comment 'Indicates whether remediation (additional educational content or re-review of ICF sections) was provided to the subject following a failed comprehension check attempt (True = remediation was provided; False = not provided).' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationStepsCount rdf:type rdf:Property ;
    rdfs:label 'Remediation Steps Count' ;
    rdfs:comment 'Number of remediation steps (re-review sections or educational modules) completed by the subject following a failed comprehension check. Null if no remediation was provided.' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewStepsCompleted rdf:type rdf:Property ;
    rdfs:label 'Review Steps Completed' ;
    rdfs:comment 'The number of ICF review steps (content sections) the subject completed during this session. Compared against review_steps_total to assess session progress and identify drop-off points.' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewStepsTotal rdf:type rdf:Property ;
    rdfs:label 'Review Steps Total' ;
    rdfs:comment 'The total number of review steps (content sections or pages) defined in the ICF version presented during this session. Used to calculate completion percentage and identify where subjects abandoned the session.' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session End Timestamp' ;
    rdfs:comment 'Date and time (with timezone offset) when the eConsent session concluded, regardless of outcome (completed, abandoned, timed-out, or declined). Null if the session is still in-progress.' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionLanguage rdf:type rdf:Property ;
    rdfs:label 'Session Language' ;
    rdfs:comment 'IETF BCP 47 language tag representing the language in which the eConsent session was conducted (e.g., \'en\', \'es\', \'fr-CA\'). Ensures the subject received consent information in their preferred language, as required by GCP and GDPR.' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionModality rdf:type rdf:Property ;
    rdfs:label 'Session Modality' ;
    rdfs:comment 'The mode by which the consent session was conducted. \'in-person\' indicates the subject and site staff were physically co-located; \'remote-video\' indicates a teleconference/video call; \'remote-phone\' indicates a telephone-only session; \'hybrid\' indicates a combination. Supports FDA remote consent guidance compliance.' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionRecordingRef rdf:type rdf:Property ;
    rdfs:label 'Session Recording Ref' ;
    rdfs:comment 'Reference identifier or URL to the recording of the remote consent session (e.g., stored in Veeva Vault or a secure media repository). Applicable for remote sessions where recording is required per FDA remote consent guidance. Null for in-person sessions.' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session Start Timestamp' ;
    rdfs:comment 'Date and time (with timezone offset) when the eConsent session was initiated by the subject or site staff in Clinpal. Serves as the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionStatus rdf:type rdf:Property ;
    rdfs:label 'Session Status' ;
    rdfs:comment 'Current lifecycle state of the eConsent workflow session. \'in-progress\' indicates an active session; \'completed\' indicates the subject finished all steps; \'abandoned\' indicates the subject exited without completing; \'timed-out\' indicates the session expired due to inactivity; \'declined\' indicates the subject explicitly refused consent.' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectAuthMethod rdf:type rdf:Property ;
    rdfs:label 'Subject Auth Method' ;
    rdfs:comment 'The method used to authenticate the subject\'s identity at the start of the eConsent session. Supports 21 CFR Part 11 identity verification requirements for electronic signatures. [ENUM-REF-CANDIDATE: password|otp-sms|otp-email|biometric|pin|site-staff-verified — promote to reference product]' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectLocationCountry rdf:type rdf:Property ;
    rdfs:label 'Subject Location Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the country where the subject was physically located at the time of the eConsent session. Relevant for decentralized trials and cross-border GDPR/HIPAA compliance determination.' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalIssueDescription rdf:type rdf:Property ;
    rdfs:label 'Technical Issue Description' ;
    rdfs:comment 'Free-text description of any technical issue encountered during the session (e.g., \'Video connection dropped at step 3\', \'Signature pad unresponsive\'). Null if no technical issue was encountered. Supports deviation investigation and CAPA processes.' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalIssueEncountered rdf:type rdf:Property ;
    rdfs:label 'Technical Issue Encountered' ;
    rdfs:comment 'Indicates whether any technical issue (connectivity failure, platform error, device malfunction, signature capture failure) was encountered during the session (True = issue encountered; False = no issues). Supports root cause analysis for incomplete sessions.' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:witnessEsignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Witness Esignature Timestamp' ;
    rdfs:comment 'Date and time (with timezone offset) when the site staff witness (PI or CRC) applied their electronic countersignature to the consent record. Required for GCP-compliant consent documentation. Null if witness signature was not captured in this session.' ;
    rdfs:domain ind:EconsentSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gdprDataConsentId rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Consent Id' ;
    rdfs:comment 'Unique surrogate identifier for each GDPR/HIPAA data processing consent record. Primary key for the gdpr_data_consent product in the consent domain.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:biobankingConsent rdf:type rdf:Property ;
    rdfs:label 'Biobanking Consent' ;
    rdfs:comment 'Indicates whether the data subject has consented to long-term storage and use of biological samples and associated data in a biobank for future research. True = consented; False = not consented.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clinpalConsentRecordCode rdf:type rdf:Property ;
    rdfs:label 'Clinpal Consent Record Code' ;
    rdfs:comment 'The source system identifier from Clinpal (eConsent management platform) corresponding to this data processing consent record. Enables traceability back to the originating eConsent workflow and audit trail in Clinpal.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialUseConsent rdf:type rdf:Property ;
    rdfs:label 'Commercial Use Consent' ;
    rdfs:comment 'Indicates whether the data subject has consented to use of their data for commercial purposes, such as drug development, licensing, or product registration activities beyond the immediate study.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Consent Collection Method' ;
    rdfs:comment 'The method by which data processing consent was collected from the data subject. \'econsent\' refers to Clinpal or equivalent eConsent platform; \'paper\' refers to physical ICF/consent form; \'electronic_signature\' refers to 21 CFR Part 11 compliant e-signature.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'The date on which the data subject provided explicit consent to data processing. This is the principal real-world event date for the consent transaction, distinct from the record creation timestamp.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Consent Expiry Date' ;
    rdfs:comment 'The date on which this data processing consent expires, if a defined consent period was specified. Null for open-ended consents. Triggers re-consent workflow when approaching.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Consent Reference Number' ;
    rdfs:comment 'Externally visible, human-readable unique reference number assigned to this data processing consent record (e.g., DPC-2024-00123). Used for audit trails, regulatory submissions, and subject rights request tracking.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current lifecycle status of the data processing consent record. \'active\' indicates valid consent in force; \'withdrawn\' indicates the data subject has revoked consent; \'expired\' indicates the consent period has lapsed; \'pending\' indicates awaiting subject acknowledgment; \'superseded\' indicates replaced by a newer consent version; \'refused\' indicates the subject declined.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataAccessRequested rdf:type rdf:Property ;
    rdfs:label 'Data Access Requested' ;
    rdfs:comment 'Indicates whether the data subject has exercised their right of access under GDPR Article 15 to obtain a copy of their personal data. True = access request submitted.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataErasureRequestDate rdf:type rdf:Property ;
    rdfs:label 'Data Erasure Request Date' ;
    rdfs:comment 'The date on which the data subject submitted a request for erasure of their personal data. Null if no erasure request has been made. Initiates the 30-day regulatory response clock.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataErasureRequested rdf:type rdf:Property ;
    rdfs:label 'Data Erasure Requested' ;
    rdfs:comment 'Indicates whether the data subject has exercised their right to erasure (right to be forgotten) under GDPR Article 17. True = erasure request submitted. Triggers data deletion or anonymization workflow.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataPortabilityRequested rdf:type rdf:Property ;
    rdfs:label 'Data Portability Requested' ;
    rdfs:comment 'Indicates whether the data subject has exercised their right to data portability under GDPR Article 20, requesting their data in a structured, machine-readable format.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataProcessorName rdf:type rdf:Property ;
    rdfs:label 'Data Processor Name' ;
    rdfs:comment 'The name of the legal entity acting as the GDPR Data Processor processing personal data on behalf of the Data Controller (e.g., the CRO, EDC vendor, or laboratory). Required for GDPR Article 30 records.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRestrictionRequested rdf:type rdf:Property ;
    rdfs:label 'Data Restriction Requested' ;
    rdfs:comment 'Indicates whether the data subject has exercised their right to restriction of processing under GDPR Article 18. True = restriction request submitted. Limits further processing until resolved.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hipaaAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Hipaa Authorization Date' ;
    rdfs:comment 'The date on which the HIPAA Authorization was signed by the data subject or their legally authorized representative. Null if HIPAA authorization is not applicable.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hipaaAuthorizationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Hipaa Authorization Expiry Date' ;
    rdfs:comment 'The date on which the HIPAA Authorization expires, if a specific expiration date was stated. Null if the authorization is open-ended or not applicable.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hipaaAuthorizationRequired rdf:type rdf:Property ;
    rdfs:label 'Hipaa Authorization Required' ;
    rdfs:comment 'Indicates whether a HIPAA Authorization (45 CFR 164.508) is required for this data subject in addition to GDPR consent, applicable for US-based subjects or US-covered entities. True = HIPAA authorization required.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irbIecApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Approval Reference' ;
    rdfs:comment 'The IRB or IEC approval reference number for the privacy notice and data processing consent form version used. Confirms that the consent documentation was reviewed and approved by the ethics committee.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalBasis rdf:type rdf:Property ;
    rdfs:label 'Legal Basis' ;
    rdfs:comment 'The GDPR Article 6 lawful basis under which personal data is processed. \'consent\' applies when the data subject has given explicit consent; other bases apply per applicable regulatory context. Required for GDPR Article 30 Records of Processing Activities.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Notice Language Code' ;
    rdfs:comment 'ISO 639-1 language code (optionally with ISO 3166-1 alpha-2 country subtag) of the privacy notice delivered to the data subject (e.g., \'en\', \'fr\', \'de\', \'ja\', \'en-US\'). Ensures the notice was provided in the subject\'s native language.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryResearchConsent rdf:type rdf:Property ;
    rdfs:label 'Primary Research Consent' ;
    rdfs:comment 'Indicates whether the data subject has consented to processing of their personal data for the primary clinical research purpose of the study (e.g., efficacy and safety analysis). True = consented; False = not consented.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privacyNoticeDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Privacy Notice Delivery Date' ;
    rdfs:comment 'The date on which the privacy notice was delivered to the data subject prior to or at the time of consent. Required to demonstrate compliance with GDPR transparency obligations.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:privacyNoticeDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Privacy Notice Delivery Method' ;
    rdfs:comment 'The method by which the privacy notice was delivered to the data subject. Supports audit evidence for GDPR transparency compliance. Values: paper, electronic (e.g., Clinpal eConsent), verbal (with written record), email, portal.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyNoticeVersion rdf:type rdf:Property ;
    rdfs:label 'Privacy Notice Version' ;
    rdfs:comment 'Version identifier of the privacy notice (per GDPR Articles 13/14) delivered to the data subject at the time of consent. Enables tracking of which notice version was in effect when consent was obtained.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reConsentCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Re Consent Completion Date' ;
    rdfs:comment 'The date on which the data subject completed the re-consent process following a re-consent trigger. Null if re-consent has not yet been completed.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Re Consent Required' ;
    rdfs:comment 'Indicates whether the data subject is required to provide fresh data processing consent due to a material change in processing purposes, privacy notice amendment, or protocol amendment. True = re-consent workflow must be initiated.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recontactConsent rdf:type rdf:Property ;
    rdfs:label 'Recontact Consent' ;
    rdfs:comment 'Indicates whether the data subject has consented to being re-contacted for future studies, follow-up research, or additional data collection after the current study concludes.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rightsRequestResponseDate rdf:type rdf:Property ;
    rdfs:label 'Rights Request Response Date' ;
    rdfs:comment 'The date on which the organization responded to the data subject\'s rights request. Must be within 30 days of the request per GDPR Article 12(3). Null if no rights request has been submitted.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rightsRequestStatus rdf:type rdf:Property ;
    rdfs:label 'Rights Request Status' ;
    rdfs:comment 'Current status of any outstanding data subject rights request (access, erasure, restriction, portability) associated with this consent record. \'none\' if no rights request has been submitted.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryResearchConsent rdf:type rdf:Property ;
    rdfs:label 'Secondary Research Consent' ;
    rdfs:comment 'Indicates whether the data subject has consented to use of their data for secondary research purposes beyond the primary study objective (e.g., exploratory analyses, future research). True = consented; False = not consented.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subjectAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Subject Acknowledgment Date' ;
    rdfs:comment 'The date on which the data subject formally acknowledged receipt and understanding of the privacy notice. May differ from consent_date if acknowledgment precedes formal consent signature.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:thirdPartySharingConsent rdf:type rdf:Property ;
    rdfs:label 'Third Party Sharing Consent' ;
    rdfs:comment 'Indicates whether the data subject has consented to sharing of their personal data with third parties (e.g., sponsors, regulatory authorities, CRO partners, academic institutions). True = consented; False = not consented.' ;
    rdfs:domain ind:GdprDataConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authoredByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Authored By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: ICF amendment authorship must be traceable to a qualified employee per ICH E6(R2) for TMF and regulatory inspection. authored_by is a plain text denormalization of the employee; replacing it with auth' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:clinpalWorkflowId rdf:type rdf:Property ;
    rdfs:label 'Clinpal Workflow Id' ;
    rdfs:comment 'The workflow identifier assigned by the Clinpal eConsent system for the re-consent or new consent workflow triggered by this amendment. Enables traceability between the amendment record and the eConsent execution.' ;
    rdfs:domain ind:IcfAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Workflow .

ind:safetyCommunicationId rdf:type rdf:Property ;
    rdfs:label 'Safety Communication Id' ;
    rdfs:comment 'Foreign key linking to safety.safety_communication. Business justification: Safety-related ICF amendments are directly triggered by safety communications (e.g., SUSAR letters, urgent safety measures). icf_amendment has a `safety_related` boolean but no FK to the triggering sa' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyCommunication .

ind:supersededByAmendmentIcfAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Amendment Icf Amendment Id' ;
    rdfs:comment 'Reference to the subsequent amendment that supersedes this one, if applicable. Null for the current active amendment. Enables full amendment lineage chain reconstruction for regulatory inspection.' ;
    rdfs:domain ind:IcfAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcfAmendment .

ind:affectedSubjectPopulation rdf:type rdf:Property ;
    rdfs:label 'Affected Subject Population' ;
    rdfs:comment 'Defines which subject population is required to undergo re-consent as a result of this amendment. Drives the re-consent workflow in Clinpal and determines the scope of CRA site monitoring activities.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeDescription rdf:type rdf:Property ;
    rdfs:label 'Change Description' ;
    rdfs:comment 'Detailed narrative describing the nature and rationale of the changes introduced by this amendment. Captures what was changed, why it was changed, and the impact on subject safety or study conduct. Required for IRB/IEC submission packages and TMF completeness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Deviation Risk Level' ;
    rdfs:comment 'Risk classification assigned to the amendment indicating the potential for protocol deviations if re-consent is not completed within the required timeframe. Informs monitoring prioritization in Oracle Siebel CTMS.' ;
    rdfs:domain ind:IcfAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:econsentApplicable rdf:type rdf:Property ;
    rdfs:label 'Econsent Applicable' ;
    rdfs:comment 'Indicates whether the amended ICF will be deployed via the Clinpal eConsent platform. When True, triggers the eConsent build and validation workflow in Clinpal for the resulting ICF version.' ;
    rdfs:domain ind:IcfAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:implementationDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Date' ;
    rdfs:comment 'The date from which the amended ICF version becomes effective for use at clinical sites. Sites must not use the amended ICF prior to this date. Typically set to or after the IRB/IEC approval date.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiringAuthority rdf:type rdf:Property ;
    rdfs:label 'Requiring Authority' ;
    rdfs:comment 'The regulatory authority, ethics committee, or organizational body that mandated or triggered this amendment. Supports regulatory inspection readiness by documenting the source of the amendment requirement. [ENUM-REF-CANDIDATE: FDA|EMA|MHRA|PMDA|TGA|Health_Canada|IRB|IEC|sponsor|investigator|other — promote to reference product]' ;
    rdfs:domain ind:IcfAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyRelated rdf:type rdf:Property ;
    rdfs:label 'Safety Related' ;
    rdfs:comment 'Indicates whether this amendment was triggered by a safety finding, SUSAR, SAE signal, or DSMB/DMC recommendation. Safety-related amendments require expedited IRB/IEC review and may trigger immediate site notification.' ;
    rdfs:domain ind:IcfAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siteApplicability rdf:type rdf:Property ;
    rdfs:label 'Site Applicability' ;
    rdfs:comment 'Defines whether this amendment applies to all clinical sites globally, a specific subset of sites, or only sites within a particular country. Drives site notification and monitoring workflows in Oracle Siebel CTMS.' ;
    rdfs:domain ind:IcfAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaDocumentCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Document Code' ;
    rdfs:comment 'The document identifier in Veeva Vault eTMF for the amendment package (cover letter, revised ICF, IRB/IEC correspondence). Supports TMF completeness checks and regulatory inspection readiness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalAuthorityTmfDocumentId rdf:type rdf:Property ;
    rdfs:label 'Legal Authority Tmf Document Id' ;
    rdfs:comment 'Foreign key linking to document.tmf_document. Business justification: The legal authority document (power of attorney, guardianship order) authorizing the LAR must be on file in the TMF as an essential document for vulnerable subject protection. legal_authority_document' ;
    rdfs:domain ind:LarRepresentative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TmfDocument .

ind:verifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Verified By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: LAR legal authority verification must be performed by a qualified employee per GCP and IRB requirements for vulnerable population protection. verified_by is a plain text denormalization; verified_by_e' ;
    rdfs:domain ind:LarRepresentative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:authorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Authorization Status' ;
    rdfs:comment 'Current lifecycle status of the LAR\'s legal authorization to consent on behalf of the subject. Drives consent workflow eligibility in Clinpal eConsent and Oracle Siebel CTMS.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsLarRecordCode rdf:type rdf:Property ;
    rdfs:label 'Ctms Lar Record Code' ;
    rdfs:comment 'Unique identifier of the LAR record in Oracle Siebel CTMS. Enables reconciliation between the lakehouse Silver layer and the CTMS operational system for site monitoring and visit tracking.' ;
    rdfs:domain ind:LarRepresentative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:econsentPlatformRecordCode rdf:type rdf:Property ;
    rdfs:label 'Econsent Platform Record Code' ;
    rdfs:comment 'Unique identifier of the LAR record in the Clinpal eConsent platform. Used for cross-system traceability between the Silver layer lakehouse and the operational eConsent system of record.' ;
    rdfs:domain ind:LarRepresentative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Email address of the Legally Authorized Representative. Used for eConsent workflow notifications via Clinpal, re-consent triggers, and regulatory correspondence.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Legal given name of the Legally Authorized Representative as it appears on their government-issued identification or legal authority document.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Legal family name or surname of the Legally Authorized Representative as it appears on their government-issued identification or legal authority document.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalAuthorityDocumentDate rdf:type rdf:Property ;
    rdfs:label 'Legal Authority Document Date' ;
    rdfs:comment 'Date on which the legal authority document (e.g., court order, power of attorney) was issued or became effective. Used to validate currency of authorization.' ;
    rdfs:domain ind:LarRepresentative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalAuthorityDocumentType rdf:type rdf:Property ;
    rdfs:label 'Legal Authority Document Type' ;
    rdfs:comment 'Classification of the legal instrument that establishes the LAR\'s authority to consent on behalf of the subject (e.g., court order, power of attorney, guardianship certificate). Required for regulatory compliance per 21 CFR 50.3(l).' ;
    rdfs:domain ind:LarRepresentative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line1' ;
    rdfs:comment 'First line of the LAR\'s mailing address (street number and name). Used for postal correspondence, regulatory notifications, and ICF delivery.' ;
    rdfs:domain ind:LarRepresentative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line2' ;
    rdfs:comment 'Second line of the LAR\'s mailing address (apartment, suite, unit number). Supplements address line 1 for complete postal delivery.' ;
    rdfs:domain ind:LarRepresentative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCity rdf:type rdf:Property ;
    rdfs:label 'Mailing City' ;
    rdfs:comment 'City or municipality of the LAR\'s mailing address. Required for complete postal address and jurisdictional determination.' ;
    rdfs:domain ind:LarRepresentative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the LAR\'s mailing address (e.g., USA, GBR, DEU). Determines applicable privacy regulations (GDPR, HIPAA) and legal authority standards.' ;
    rdfs:domain ind:LarRepresentative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the LAR\'s mailing address. Required for complete postal address and geographic analytics.' ;
    rdfs:domain ind:LarRepresentative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Mailing State Province' ;
    rdfs:comment 'State, province, or region of the LAR\'s mailing address. Used for jurisdictional compliance and postal delivery.' ;
    rdfs:domain ind:LarRepresentative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Legal middle name or initial of the Legally Authorized Representative as recorded on official identification documents. May be null if not applicable.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'The LAR\'s preferred channel for receiving communications from the site, including re-consent notifications and study updates. Drives outreach workflow in Clinpal and Oracle Siebel CTMS.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'ISO 639-1/639-2 language code representing the LAR\'s preferred language for consent documentation and communications (e.g., \'en\', \'es\', \'fr-CA\'). Ensures ICF is provided in a language the LAR understands per GCP.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'Primary telephone number for contacting the Legally Authorized Representative. Used for re-consent notifications, safety communications, and site follow-up.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Categorical classification of the LAR\'s legal or familial relationship to the trial subject (e.g., parent, legal guardian, healthcare proxy). Determines the basis of legal authority. [ENUM-REF-CANDIDATE: parent|legal_guardian|spouse|adult_child|sibling|healthcare_proxy|court_appointed|power_of_attorney|next_of_kin — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryPhone rdf:type rdf:Property ;
    rdfs:label 'Secondary Phone' ;
    rdfs:comment 'Alternate telephone number for the Legally Authorized Representative, used when the primary phone is unreachable. Supports continuity of contact for consent and safety communications.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectAssentDate rdf:type rdf:Property ;
    rdfs:label 'Subject Assent Date' ;
    rdfs:comment 'Date on which the subject\'s assent was obtained alongside the LAR\'s consent. Applicable for pediatric or partially capacitated subjects. Null if assent was not required or not obtained.' ;
    rdfs:domain ind:LarRepresentative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subjectAssentObtained rdf:type rdf:Property ;
    rdfs:label 'Subject Assent Obtained' ;
    rdfs:comment 'Indicates whether the subject\'s assent (agreement to participate, distinct from formal consent) was obtained in addition to the LAR\'s consent. Applicable for pediatric subjects with developing capacity per 21 CFR 50.55.' ;
    rdfs:domain ind:LarRepresentative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status of the site staff\'s verification of the LAR\'s identity and legal authority documentation. Tracks whether the CRC or PI has confirmed the LAR\'s credentials per GCP requirements.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsmbRecommendationId rdf:type rdf:Property ;
    rdfs:label 'Dsmb Recommendation Id' ;
    rdfs:comment 'Foreign key linking to safety.dsmb_recommendation. Business justification: DSMB recommendations with `informed_consent_update_required=true` directly mandate reconsent. Sponsors must document which DSMB recommendation drove each reconsent campaign. reconsent_trigger has no F' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DsmbRecommendation .

ind:primaryReconsentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Reconsent Employee Id' ;
    rdfs:comment 'Reference to the site staff member (typically the Principal Investigator or Clinical Research Coordinator) responsible for executing the re-consent process with the subject. Drives task assignment and accountability tracking.' ;
    rdfs:domain ind:ReconsentTrigger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:safetyLetterSafetyCommunicationId rdf:type rdf:Property ;
    rdfs:label 'Safety Letter Safety Communication Id' ;
    rdfs:comment 'Reference to the safety communication (e.g., SUSAR notification, DSMB safety letter, updated Investigator Brochure) that triggered re-consent due to new safety information. Nullable for non-safety triggers.' ;
    rdfs:domain ind:ReconsentTrigger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyCommunication .

ind:affectedIcfVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Affected Icf Version Number' ;
    rdfs:comment 'The version number of the new IRB/IEC-approved ICF that subjects must sign as part of the re-consent process. Stored as a human-readable version string (e.g., \'v3.0\', \'Amendment 2\') for audit trail and site communication purposes.' ;
    rdfs:domain ind:ReconsentTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingRegulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Regulatory Authority' ;
    rdfs:comment 'The regulatory authority that issued the directive requiring re-consent, when trigger_type is \'regulatory_authority_requirement\'. Values: FDA (U.S. Food and Drug Administration), EMA (European Medicines Agency), PMDA (Pharmaceuticals and Medical Devices Agency), MHRA (Medicines and Healthcare products Regulatory Agency), TGA (Therapeutic Goods Administration), Health_Canada, other. [ENUM-REF-CANDIDATE: FDA|EMA|PMDA|MHRA|TGA|Health_Canada|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReconsentTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousIcfVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Previous Icf Version Number' ;
    rdfs:comment 'The version number of the ICF that the subject had previously signed before this re-consent trigger was raised. Enables version-to-version change tracking and audit trail completeness per ALCOA+ principles.' ;
    rdfs:domain ind:ReconsentTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolDeviationRaised rdf:type rdf:Property ;
    rdfs:label 'Protocol Deviation Raised' ;
    rdfs:comment 'Indicates whether a protocol deviation has been raised in the compliance system as a result of failure to re-consent within the required timeframe. When True, links to the compliance.protocol_deviation product for CAPA tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconsentDeadline rdf:type rdf:Property ;
    rdfs:label 'Reconsent Deadline' ;
    rdfs:comment 'The date by which re-consent must be obtained from the subject, as mandated by the IRB/IEC approval, regulatory authority, or sponsor protocol. Used to calculate overdue status and drive site escalation workflows.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconsentedSubjectCount rdf:type rdf:Property ;
    rdfs:label 'Reconsented Subject Count' ;
    rdfs:comment 'The number of subjects who have been successfully re-consented to date against this trigger. Compared against affected_subject_count to track completion progress and identify outstanding re-consents.' ;
    rdfs:domain ind:ReconsentTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryAuthorityDirectiveRef rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Directive Ref' ;
    rdfs:comment 'The reference number or identifier of the regulatory authority directive (e.g., FDA clinical hold letter, EMA variation request, PMDA query) that mandated this re-consent. Nullable for non-regulatory triggers. Required for regulatory submission traceability.' ;
    rdfs:domain ind:ReconsentTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderCount rdf:type rdf:Property ;
    rdfs:label 'Reminder Count' ;
    rdfs:comment 'The total number of reminder notifications sent to the site for this re-consent trigger. Used to assess site responsiveness and determine when escalation is warranted per sponsor oversight SOPs.' ;
    rdfs:domain ind:ReconsentTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reminderSentDate rdf:type rdf:Property ;
    rdfs:label 'Reminder Sent Date' ;
    rdfs:comment 'The date on which the most recent reminder notification was sent to the site regarding the outstanding re-consent requirement. Used to track communication cadence and demonstrate sponsor oversight diligence.' ;
    rdfs:domain ind:ReconsentTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Current workflow state of the re-consent trigger. Drives operational dashboards and site follow-up. Values: pending (trigger raised, re-consent not yet initiated), in_progress (re-consent process underway), completed (subject successfully re-consented), waived (re-consent waived with documented IRB/IEC justification), overdue (deadline passed without completion), cancelled (trigger voided, e.g., subject discontinued).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectScope rdf:type rdf:Property ;
    rdfs:label 'Subject Scope' ;
    rdfs:comment 'Defines the population of subjects affected by this re-consent trigger. Values: individual_subject (single subject identified by subject_id), all_active_subjects (all currently enrolled subjects at the site), site_cohort (a defined subset at the site), study_wide (all subjects across all sites in the study).' ;
    rdfs:domain ind:ReconsentTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectWithdrawalFlag rdf:type rdf:Property ;
    rdfs:label 'Subject Withdrawal Flag' ;
    rdfs:comment 'Indicates whether the subject withdrew from the study as a result of the re-consent process (e.g., declined to sign the updated ICF). When True, triggers subject discontinuation workflow and safety follow-up per protocol.' ;
    rdfs:domain ind:ReconsentTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:triggerDate rdf:type rdf:Property ;
    rdfs:label 'Trigger Date' ;
    rdfs:comment 'The date on which the re-consent triggering event occurred (e.g., date of protocol amendment approval, date of safety letter issuance, date of regulatory authority directive). This is the principal real-world event date, distinct from the record creation timestamp.' ;
    rdfs:domain ind:ReconsentTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:triggerDescription rdf:type rdf:Property ;
    rdfs:label 'Trigger Description' ;
    rdfs:comment 'Narrative description of the specific event or change that necessitated re-consent. Provides context beyond the trigger type classification, including the nature of the protocol change, safety finding, or regulatory directive.' ;
    rdfs:domain ind:ReconsentTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Trigger Reference Number' ;
    rdfs:comment 'Externally-known business identifier for the re-consent trigger event, used in site communications, audit trails, and regulatory correspondence. Follows the format RCT-{StudyCode}-{Sequence}.' ;
    rdfs:domain ind:ReconsentTrigger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerType rdf:type rdf:Property ;
    rdfs:label 'Trigger Type' ;
    rdfs:comment 'Classification of the event that necessitated re-consent. Drives workflow routing and regulatory reporting. Values: protocol_amendment (change to study protocol), new_safety_information (SAE/SUSAR/IB update), icf_version_update (administrative ICF revision), regulatory_authority_requirement (FDA/EMA/PMDA directive), irb_iec_requirement (IRB or IEC mandate), other (documented justification required). [ENUM-REF-CANDIDATE: promote to reference product if additional values are needed]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Approval Date' ;
    rdfs:comment 'The date on which the IRB/IEC formally approved the waiver of re-consent for this trigger. Nullable when no waiver has been granted. Required for regulatory audit trail when resolution_status is \'waived\'.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverJustification rdf:type rdf:Property ;
    rdfs:label 'Waiver Justification' ;
    rdfs:comment 'Documented justification for waiving the re-consent requirement, as approved by the IRB/IEC. Required when resolution_status is \'waived\'. Must reference the IRB/IEC waiver approval and the regulatory basis for the waiver.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentingStaffStudyAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Consenting Staff Study Assignment Id' ;
    rdfs:comment 'Foreign key linking to workforce.study_assignment. Business justification: ICH E6(R2) requires that consenting staff have a valid, active study assignment at the time of consent. consenting_staff_study_assignment_id enables GCP compliance verification that the consenting emp' ;
    rdfs:domain ind:SubjectConsent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudyAssignment .

ind:comprehensionAssessmentPerformed rdf:type rdf:Property ;
    rdfs:label 'Comprehension Assessment Performed' ;
    rdfs:comment 'Indicates whether a formal comprehension assessment (e.g., teach-back method, quiz) was administered to verify the subject understood the consent information. Increasingly required by IRBs and FDA for complex protocols.' ;
    rdfs:domain ind:SubjectConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:comprehensionAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Comprehension Assessment Score' ;
    rdfs:comment 'Numeric score from the comprehension assessment administered to the subject (e.g., percentage correct on a quiz). Populated when comprehension_assessment_performed is True. Used for quality metrics and IRB reporting.' ;
    rdfs:domain ind:SubjectConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consentNumber rdf:type rdf:Property ;
    rdfs:label 'Consent Number' ;
    rdfs:comment 'Externally-known business identifier for this consent event, typically generated by the EDC or eConsent system (Clinpal). Used for cross-system traceability and audit referencing (e.g., CNST-2024-00123).' ;
    rdfs:domain ind:SubjectConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) at which the consent signature or electronic acknowledgement was captured. Required for 21 CFR Part 11 electronic records compliance and ALCOA+ contemporaneous documentation.' ;
    rdfs:domain ind:SubjectConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentingStaffRole rdf:type rdf:Property ;
    rdfs:label 'Consenting Staff Role' ;
    rdfs:comment 'Role of the staff member who obtained consent. \'PI\' = Principal Investigator; \'sub_investigator\' = Sub-Investigator; \'CRC\' = Clinical Research Coordinator; \'delegate\' = other delegated staff member listed on the delegation log.' ;
    rdfs:domain ind:SubjectConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataUseAfterWithdrawal rdf:type rdf:Property ;
    rdfs:label 'Data Use After Withdrawal' ;
    rdfs:comment 'Indicates whether the subject explicitly permitted use of previously collected data after withdrawal of consent. Critical for GDPR right-to-erasure compliance and statistical analysis plan (SAP) decisions on data inclusion.' ;
    rdfs:domain ind:SubjectConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:econsentCompletionPct rdf:type rdf:Property ;
    rdfs:label 'Econsent Completion Pct' ;
    rdfs:comment 'Percentage of the eConsent workflow modules completed by the subject in Clinpal (0.00–100.00). Used to track partial completions and identify subjects who did not fully review all consent materials before signing.' ;
    rdfs:domain ind:SubjectConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hipaaAuthorizationObtained rdf:type rdf:Property ;
    rdfs:label 'Hipaa Authorization Obtained' ;
    rdfs:comment 'Indicates whether a HIPAA Authorization for use and disclosure of Protected Health Information (PHI) was obtained from the subject, as required for U.S. clinical trials. May be combined with or separate from the ICF.' ;
    rdfs:domain ind:SubjectConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:larInvolved rdf:type rdf:Property ;
    rdfs:label 'Lar Involved' ;
    rdfs:comment 'Indicates whether a Legally Authorized Representative (LAR) provided consent on behalf of the subject (e.g., for subjects who lack decision-making capacity, minors, or cognitively impaired individuals).' ;
    rdfs:domain ind:SubjectConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleUseAfterWithdrawal rdf:type rdf:Property ;
    rdfs:label 'Sample Use After Withdrawal' ;
    rdfs:comment 'Indicates whether the subject permitted continued use of previously collected biological samples (e.g., blood, tissue) after withdrawal of consent. Distinct from data_use_after_withdrawal as it governs physical biospecimen retention.' ;
    rdfs:domain ind:SubjectConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subjectQuestionsDocumented rdf:type rdf:Property ;
    rdfs:label 'Subject Questions Documented' ;
    rdfs:comment 'Indicates whether the subject\'s questions and the investigator\'s responses were documented during the consent discussion, as required by GCP. Supports audit readiness and IRB inspection compliance.' ;
    rdfs:domain ind:SubjectConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:translationLanguage rdf:type rdf:Property ;
    rdfs:label 'Translation Language' ;
    rdfs:comment 'ISO 639-1/639-2 language code of the ICF translation provided to the subject (e.g., \'es\' for Spanish, \'fr\' for French, \'zh-CN\' for Simplified Chinese). Null if the ICF was provided in the site\'s primary language. Required for multi-lingual trial compliance.' ;
    rdfs:domain ind:SubjectConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Witness Signature Date' ;
    rdfs:comment 'Date on which the impartial witness signed the ICF, confirming they witnessed the consent process. Must match or follow the subject\'s consent_date.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:alcoaAuditEntryId rdf:type rdf:Property ;
    rdfs:label 'Alcoa Audit Entry Id' ;
    rdfs:comment 'Unique surrogate identifier for each immutable ALCOA+ audit trail entry in the EDC system. Primary key. Entity role: EVENT_LOG — append-only immutable record of every clinical data change event in Medidata Rave EDC, capturing ALCOA+ compliance attributes per 21 CFR Part 11 and ICH E6(R2).' ;
    rdfs:domain ind:AlcoaAuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Audited By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: ALCOA audit entries must be attributable to a specific employee for regulatory inspection readiness (ICH E6, 21 CFR Part 11). user_identifier and user_full_name are denormalized employee references; t' ;
    rdfs:domain ind:AlcoaAuditEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:discrepancyQueryId rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Query Id' ;
    rdfs:comment 'Identifier of the data query (discrepancy) in the EDC system that triggered this data change, if applicable. Links the audit entry to the query management workflow in Medidata Rave for query-driven change traceability.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DiscrepancyQuery .

ind:ecrfFieldId rdf:type rdf:Property ;
    rdfs:label 'Ecrf Field Id' ;
    rdfs:comment 'Foreign key linking to data.ecrf_field. Business justification: alcoa_audit_entry captures field-level data changes. ecrf_field is the master field definition. Adding ecrf_field_id normalizes the relationship and allows removal of the denormalized ecrf_field_name.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EcrfField .

ind:ecrfFormId rdf:type rdf:Property ;
    rdfs:label 'Ecrf Form Id' ;
    rdfs:comment 'Foreign key linking to data.ecrf_form. Business justification: alcoa_audit_entry captures audit trail entries for data changes on specific eCRF forms. ecrf_form is the master form definition. Adding ecrf_form_id normalizes the relationship and allows removal of t' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EcrfForm .

ind:fieldEntryId rdf:type rdf:Property ;
    rdfs:label 'Field Entry Id' ;
    rdfs:comment 'Foreign key linking to data.field_entry. Business justification: ALCOA+ audit trail entries track changes to clinical data. The field_entry product captures atomic-level data entries. An ALCOA audit entry should reference the specific field_entry it audits to provi' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FieldEntry .

ind:kitInventoryId rdf:type rdf:Property ;
    rdfs:label 'Kit Inventory Id' ;
    rdfs:comment 'Foreign key linking to supply.kit_inventory. Business justification: Audit trail entries for kit number or dispensing quantity field changes in the EDC must be traceable to the specific kit inventory record. This supports IMP accountability audit trails and inspection ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KitInventory .

ind:sessionId rdf:type rdf:Property ;
    rdfs:label 'Session Id' ;
    rdfs:comment 'Identifier of the EDC user session during which the data change was performed. Supports security audit, concurrent session analysis, and 21 CFR Part 11 access control review.' ;
    rdfs:domain ind:AlcoaAuditEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataEntrySession .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Type of data action performed on the eCRF record: CREATE (initial data entry), UPDATE (modification of existing value), DELETE (removal), LOCK (record locked), UNLOCK (record unlocked), SIGN (electronic signature applied), VERIFY (source data verification completed). [ENUM-REF-CANDIDATE: CREATE|UPDATE|DELETE|LOCK|UNLOCK|SIGN|VERIFY — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alcoaOverallStatus rdf:type rdf:Property ;
    rdfs:label 'Alcoa Overall Status' ;
    rdfs:comment 'Aggregated ALCOA+ compliance status for this audit entry based on evaluation of all nine ALCOA+ attribute flags. COMPLIANT = all flags are True; NON_COMPLIANT = one or more flags are False; UNDER_REVIEW = compliance assessment is pending or in dispute.' ;
    rdfs:domain ind:AlcoaAuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataEntryLagMinutes rdf:type rdf:Property ;
    rdfs:label 'Data Entry Lag Minutes' ;
    rdfs:comment 'Number of minutes elapsed between the clinical event date/time (as recorded in the eCRF) and the event_timestamp of this audit entry. Used to assess Contemporaneous compliance — large lags may indicate ALCOA+ violations requiring investigation.' ;
    rdfs:domain ind:AlcoaAuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dblFlag rdf:type rdf:Property ;
    rdfs:label 'Dbl Flag' ;
    rdfs:comment 'Indicates whether this audit entry was created after the Database Lock (DBL) event for the associated study. Post-lock entries require special authorization and are flagged for regulatory scrutiny. True = post-lock entry; False = pre-lock entry.' ;
    rdfs:domain ind:AlcoaAuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ecrfVersion rdf:type rdf:Property ;
    rdfs:label 'Ecrf Version' ;
    rdfs:comment 'Version of the eCRF form design active in the EDC system at the time of the data change. Supports traceability of data collected under different form versions across protocol amendments.' ;
    rdfs:domain ind:AlcoaAuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcRecordReference rdf:type rdf:Property ;
    rdfs:label 'Edc Record Reference' ;
    rdfs:comment 'System-generated unique identifier of the specific eCRF record (data point) within Medidata Rave EDC that was created or modified. Provides direct traceability to the source data record.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcSystemName rdf:type rdf:Property ;
    rdfs:label 'Edc System Name' ;
    rdfs:comment 'Name of the EDC system that generated this audit entry (e.g., Medidata Rave). Supports multi-system audit trail consolidation and system-level traceability.' ;
    rdfs:domain ind:AlcoaAuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcSystemVersion rdf:type rdf:Property ;
    rdfs:label 'Edc System Version' ;
    rdfs:comment 'Version of the EDC software at the time the audit entry was generated. Required for regulatory inspection readiness to demonstrate system validation status at the time of data entry.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esignatureReference rdf:type rdf:Property ;
    rdfs:label 'Esignature Reference' ;
    rdfs:comment 'Reference identifier for the electronic signature applied to this audit entry, where applicable (e.g., for SIGN action types or investigator-verified records). Links to the 21 CFR Part 11 compliant e-signature record in Medidata Rave.' ;
    rdfs:domain ind:AlcoaAuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAccurate rdf:type rdf:Property ;
    rdfs:label 'Is Accurate' ;
    rdfs:comment 'Indicates whether this audit entry satisfies the Accurate requirement of ALCOA+: the data value is correct, and any change is accompanied by a valid change reason. True = compliant; False = compliance gap.' ;
    rdfs:domain ind:AlcoaAuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAttributable rdf:type rdf:Property ;
    rdfs:label 'Is Attributable' ;
    rdfs:comment 'Indicates whether this audit entry satisfies the Attributable requirement of ALCOA+: the data change is traceable to the individual who made it (user_identifier is populated and valid). True = compliant; False = compliance gap requiring remediation.' ;
    rdfs:domain ind:AlcoaAuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAvailable rdf:type rdf:Property ;
    rdfs:label 'Is Available' ;
    rdfs:comment 'Indicates whether this audit entry satisfies the Available requirement of ALCOA+: the record is accessible for review by authorized personnel and regulatory inspectors throughout the required retention period. True = compliant; False = compliance gap.' ;
    rdfs:domain ind:AlcoaAuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isComplete rdf:type rdf:Property ;
    rdfs:label 'Is Complete' ;
    rdfs:comment 'Indicates whether this audit entry satisfies the Complete requirement of ALCOA+: all required fields for this data change are populated with no missing mandatory data. True = compliant; False = compliance gap.' ;
    rdfs:domain ind:AlcoaAuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConsistent rdf:type rdf:Property ;
    rdfs:label 'Is Consistent' ;
    rdfs:comment 'Indicates whether this audit entry satisfies the Consistent requirement of ALCOA+: the data change is internally consistent with other related data points and does not introduce contradictions within the subject record. True = compliant; False = compliance gap.' ;
    rdfs:domain ind:AlcoaAuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isContemporaneous rdf:type rdf:Property ;
    rdfs:label 'Is Contemporaneous' ;
    rdfs:comment 'Indicates whether this audit entry satisfies the Contemporaneous requirement of ALCOA+: the event_timestamp reflects the actual time of data entry or change, not a backdated or delayed entry. True = compliant; False = compliance gap.' ;
    rdfs:domain ind:AlcoaAuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEnduring rdf:type rdf:Property ;
    rdfs:label 'Is Enduring' ;
    rdfs:comment 'Indicates whether this audit entry satisfies the Enduring requirement of ALCOA+: the record is stored in a durable, non-erasable medium and will be retained for the required regulatory retention period. True = compliant; False = compliance gap.' ;
    rdfs:domain ind:AlcoaAuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLegible rdf:type rdf:Property ;
    rdfs:label 'Is Legible' ;
    rdfs:comment 'Indicates whether this audit entry satisfies the Legible requirement of ALCOA+: the data values (original and new) are readable and interpretable. True = compliant; False = compliance gap (e.g., corrupted or unreadable data).' ;
    rdfs:domain ind:AlcoaAuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOriginal rdf:type rdf:Property ;
    rdfs:label 'Is Original' ;
    rdfs:comment 'Indicates whether this audit entry satisfies the Original requirement of ALCOA+: the data represents the first recorded observation or a properly documented change from the original. True = compliant; False = compliance gap.' ;
    rdfs:domain ind:AlcoaAuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalValue rdf:type rdf:Property ;
    rdfs:label 'Original Value' ;
    rdfs:comment 'The data value that existed in the eCRF field before the change was applied. NULL for CREATE actions. Satisfies the Original requirement of ALCOA+ by preserving the prior state of the data.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sdvTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sdv Timestamp' ;
    rdfs:comment 'Date and time when Source Data Verification was completed for this audit entry. Populated only when sdv_status is VERIFIED or FAILED. Supports monitoring visit reporting and SDV coverage metrics.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sdvUserIdentifier rdf:type rdf:Property ;
    rdfs:label 'Sdv User Identifier' ;
    rdfs:comment 'Identifier of the CRA or authorized user who performed Source Data Verification for this audit entry. Provides attribution for the SDV action per GCP monitoring requirements.' ;
    rdfs:domain ind:AlcoaAuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyProtocolVersion rdf:type rdf:Property ;
    rdfs:label 'Study Protocol Version' ;
    rdfs:comment 'Version of the study protocol in effect at the time of the data change. Ensures the audit entry is contextualized against the correct protocol amendment, supporting protocol deviation analysis.' ;
    rdfs:domain ind:AlcoaAuditEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userRole rdf:type rdf:Property ;
    rdfs:label 'User Role' ;
    rdfs:comment 'Role of the EDC user at the time of the data change (e.g., CRC - Clinical Research Coordinator, CRA - Clinical Research Associate, PI - Principal Investigator, DATA_MANAGER). Captured at event time to support role-based audit analysis. [ENUM-REF-CANDIDATE: CRC|CRA|PI|DATA_MANAGER|MEDICAL_MONITOR|BIOSTATISTICIAN|SYSTEM_ADMIN — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codingAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Coding Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each medical coding assignment record in the Silver Layer lakehouse. Primary key for this transactional entity.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodingAssignment .

ind:approverUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver User Employee Id' ;
    rdfs:comment 'The system user identifier of the authorized reviewer who approved the coding assignment. Required for regulatory audit trail demonstrating dual-review compliance where applicable.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:comparatorDrugId rdf:type rdf:Property ;
    rdfs:label 'Comparator Drug Id' ;
    rdfs:comment 'Foreign key linking to supply.comparator_drug. Business justification: WHODrug coding of concomitant medications may identify comparator drugs used in the trial. Medical coders must trace coded comparator drug terms to the comparator drug master record to support pharmac' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComparatorDrug .

ind:indicationId rdf:type rdf:Property ;
    rdfs:label 'Indication Id' ;
    rdfs:comment 'Foreign key linking to program.indication. Business justification: MedDRA SOC hierarchy selection and coding dictionary version are indication-driven. Indication-level coding quality reports (e.g., AE coding consistency across studies in the same indication) and regu' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Indication .

ind:primaryCodingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Coding Employee Id' ;
    rdfs:comment 'The system user identifier of the coder who assigned or last modified the coding assignment in Medidata Rave or the coding module. Required for audit trail and ALCOA+ attributability compliance.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignedCode rdf:type rdf:Property ;
    rdfs:label 'Assigned Code' ;
    rdfs:comment 'The standardized dictionary code assigned to the verbatim term. For MedDRA, this is the numeric PT code (e.g., 10047700). For WHO-DD, this is the drug record number. This is the primary coded output used in regulatory submissions and safety analyses.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autocodingConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Autocoding Confidence Score' ;
    rdfs:comment 'The algorithmic confidence score (0.0000 to 1.0000) returned by the autocoding engine when automatically matching the verbatim term to a dictionary code. Scores below a configured threshold require manual review. Null for manually coded terms.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:codingDate rdf:type rdf:Property ;
    rdfs:label 'Coding Date' ;
    rdfs:comment 'The calendar date on which the verbatim term was coded (code assigned). Used for coding timeliness metrics, regulatory timelines, and ALCOA+ contemporaneity compliance.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:codingDictionary rdf:type rdf:Property ;
    rdfs:label 'Coding Dictionary' ;
    rdfs:comment 'The medical coding dictionary used to assign the standardized code to the verbatim term. MedDRA (Medical Dictionary for Regulatory Activities) is used for adverse events and medical history; WHO-DD (WHO Drug Dictionary) is used for concomitant medications. [ENUM-REF-CANDIDATE: MedDRA|WHO-DD|SNOMED-CT|ICD-10|CTCAE|NCI-Thesaurus — promote to reference product]' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codingDomain rdf:type rdf:Property ;
    rdfs:label 'Coding Domain' ;
    rdfs:comment 'The CDISC SDTM domain to which this coding assignment belongs. Determines the regulatory submission context. AE=Adverse Events, CM=Concomitant Medications, MH=Medical History, DS=Disposition, DV=Protocol Deviations, EX=Exposure. [ENUM-REF-CANDIDATE: AE|CM|MH|DS|DV|EX|LB|VS|PR — promote to reference product]' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codingFlag rdf:type rdf:Property ;
    rdfs:label 'Coding Flag' ;
    rdfs:comment 'A quality control flag applied to the coding assignment indicating its readiness for database lock (DBL) and regulatory submission. \'clean\' = no issues; \'flagged\' = requires attention; \'review_required\' = pending medical review; \'locked\' = included in database lock.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codingMethod rdf:type rdf:Property ;
    rdfs:label 'Coding Method' ;
    rdfs:comment 'The method by which the coding assignment was made. \'autocoding\' indicates the EDC system (Medidata Rave) automatically matched the verbatim term; \'manual\' indicates a coder manually assigned the code; \'assisted\' indicates a system suggestion accepted by a coder; \'recoded\' indicates a previously coded term was reassigned.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codingStatus rdf:type rdf:Property ;
    rdfs:label 'Coding Status' ;
    rdfs:comment 'Current workflow status of the coding assignment. \'pending\' = awaiting coding; \'coded\' = code assigned but not yet approved; \'approved\' = coding reviewed and approved by authorized coder or supervisor; \'rejected\' = coding rejected and requires rework; \'queried\' = a data query has been raised; \'recoded\' = previously approved code has been revised.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Coding Timestamp' ;
    rdfs:comment 'The precise date and time (with timezone) when the coding assignment was created or last modified in the source system. Supports ALCOA+ contemporaneity requirements and audit trail reconstruction.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dblIncluded rdf:type rdf:Property ;
    rdfs:label 'Dbl Included' ;
    rdfs:comment 'Indicates whether this coding assignment was included in the final database lock (DBL) snapshot for regulatory submission. True = included in DBL; False = excluded or post-lock amendment. Critical for submission integrity and audit trail.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dictionaryVersion rdf:type rdf:Property ;
    rdfs:label 'Dictionary Version' ;
    rdfs:comment 'The specific version of the coding dictionary applied at the time of coding (e.g., MedDRA 26.1, WHO-DD March 2024). Regulatory submissions require explicit dictionary version documentation to ensure reproducibility and consistency.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldName rdf:type rdf:Property ;
    rdfs:label 'Field Name' ;
    rdfs:comment 'The specific eCRF field name within the form from which the verbatim term was captured (e.g., \'AETERM\', \'CMTRT\'). Enables precise source data traceability per ALCOA+ and SDTM variable mapping.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formName rdf:type rdf:Property ;
    rdfs:label 'Form Name' ;
    rdfs:comment 'The name of the eCRF form (e.g., \'Adverse Events\', \'Concomitant Medications\') in Medidata Rave from which the verbatim term was collected. Supports data lineage and source data verification (SDV) traceability.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highLevelGroupTerm rdf:type rdf:Property ;
    rdfs:label 'High Level Group Term' ;
    rdfs:comment 'The MedDRA High Level Group Term (HLGT) associated with the assigned Preferred Term. Second-highest level in the MedDRA hierarchy, used for broader safety signal grouping and regulatory tabulations.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highLevelTerm rdf:type rdf:Property ;
    rdfs:label 'High Level Term' ;
    rdfs:comment 'The MedDRA High Level Term (HLT) grouping the assigned Preferred Term. Intermediate level in the MedDRA hierarchy between PT and HLGT, used in aggregate safety analyses and signal detection.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimarySoc rdf:type rdf:Property ;
    rdfs:label 'Is Primary Soc' ;
    rdfs:comment 'Indicates whether this coding assignment uses the primary SOC classification for the assigned Preferred Term. MedDRA allows a PT to belong to multiple SOCs; the primary SOC is used for regulatory safety tabulations. True = primary SOC; False = secondary SOC.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSeriousAe rdf:type rdf:Property ;
    rdfs:label 'Is Serious Ae' ;
    rdfs:comment 'Indicates whether the verbatim term being coded is associated with a Serious Adverse Event (SAE). True = the source record is an SAE. Drives expedited regulatory reporting timelines (e.g., 7-day/15-day reporting per ICH E2A) and SUSAR assessment workflows.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lowestLevelTerm rdf:type rdf:Property ;
    rdfs:label 'Lowest Level Term' ;
    rdfs:comment 'The MedDRA Lowest Level Term (LLT) that most closely matches the verbatim term. The LLT is the most granular level of the MedDRA hierarchy and is used to capture the precise clinical concept before mapping to the PT.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Medical Review Date' ;
    rdfs:comment 'The date on which the medical reviewer completed their review of the coding assignment. Null if medical review is not required or not yet performed for this record.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredTerm rdf:type rdf:Property ;
    rdfs:label 'Preferred Term' ;
    rdfs:comment 'The MedDRA Preferred Term (PT) or WHO-DD preferred drug name assigned to the verbatim term. The PT is the primary level of the MedDRA hierarchy used in regulatory safety reporting and aggregate analyses.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorAssignedCode rdf:type rdf:Property ;
    rdfs:label 'Prior Assigned Code' ;
    rdfs:comment 'The dictionary code that was previously assigned before a recoding event. Preserved for audit trail purposes to document the history of coding changes per ALCOA+ and 21 CFR Part 11 requirements. Null for initial coding assignments.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorPreferredTerm rdf:type rdf:Property ;
    rdfs:label 'Prior Preferred Term' ;
    rdfs:comment 'The MedDRA Preferred Term (PT) that was previously assigned before a recoding event. Preserved alongside prior_assigned_code for complete audit trail documentation of coding history changes.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ptCode rdf:type rdf:Property ;
    rdfs:label 'Pt Code' ;
    rdfs:comment 'The numeric MedDRA code for the Preferred Term (PT). Used in SDTM datasets (AEPTCD) and regulatory submissions. Distinct from the PT text label to support code-based lookups and dictionary version migrations.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recodingReason rdf:type rdf:Property ;
    rdfs:label 'Recoding Reason' ;
    rdfs:comment 'Free-text justification provided by the coder when a previously approved coding assignment is revised (recoded). Required for audit trail integrity and regulatory inspection readiness. Null for initial coding assignments.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmVariable rdf:type rdf:Property ;
    rdfs:label 'Sdtm Variable' ;
    rdfs:comment 'The CDISC SDTM variable name to which this coding assignment maps (e.g., AEDECOD for AE Preferred Term, AEBODSYS for AE SOC, CMDECOD for CM decoded name). Supports automated SDTM dataset generation and regulatory submission preparation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socCode rdf:type rdf:Property ;
    rdfs:label 'Soc Code' ;
    rdfs:comment 'The numeric MedDRA code for the System Organ Class (SOC). Used in SDTM datasets (AESOCCD) and regulatory submissions to uniquely identify the SOC category.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemOrganClass rdf:type rdf:Property ;
    rdfs:label 'System Organ Class' ;
    rdfs:comment 'The MedDRA System Organ Class (SOC) associated with the assigned Preferred Term. The SOC is the highest level of the MedDRA hierarchy and is used for aggregate safety tabulations in clinical study reports and regulatory submissions.' ;
    rdfs:domain ind:CodingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verbatimTerm rdf:type rdf:Property ;
    rdfs:label 'Verbatim Term' ;
    rdfs:comment 'The exact, unmodified text as entered by the investigator or site staff in the eCRF prior to coding. Preserved verbatim per ALCOA+ principles to maintain data integrity and auditability. May contain patient-reported or clinician-reported language.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raisedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Raised By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Query management SLA reporting and CRA workload tracking require knowing which employee raised each data query. GCP inspection readiness demands attributable query authorship. raised_by_user is a deno' ;
    rdfs:domain ind:DiscrepancyQuery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:validationRuleId rdf:type rdf:Property ;
    rdfs:label 'Validation Rule Id' ;
    rdfs:comment 'Foreign key linking to data.validation_rule. Business justification: discrepancy_query has edit_check_name indicating the validation rule (edit check) that triggered the query. validation_rule is the master definition of programmatic edit checks. Adding validation_rule' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ValidationRule .

ind:assignedToUser rdf:type rdf:Property ;
    rdfs:label 'Assigned To User' ;
    rdfs:comment 'Username of the site user (CRC or PI) to whom the query is currently assigned for response. Drives site-facing query worklist in Medidata Rave.' ;
    rdfs:domain ind:DiscrepancyQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Explanation for why the discrepancy query was cancelled (e.g., raised in error, duplicate query, data corrected via another mechanism). Required for audit trail integrity.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Date and time when the discrepancy query was cancelled (withdrawn) in Medidata Rave. Populated only when query_status = cancelled.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closedByUser rdf:type rdf:Property ;
    rdfs:label 'Closed By User' ;
    rdfs:comment 'Username of the DM or reviewer who closed the discrepancy query after verifying the site response and confirming data correction in Medidata Rave.' ;
    rdfs:domain ind:DiscrepancyQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataValueCorrected rdf:type rdf:Property ;
    rdfs:label 'Data Value Corrected' ;
    rdfs:comment 'The corrected data value entered in the eCRF field after query resolution. Populated when the site updates the data entry in response to the query. Supports data change audit trail.' ;
    rdfs:domain ind:DiscrepancyQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataValueOriginal rdf:type rdf:Property ;
    rdfs:label 'Data Value Original' ;
    rdfs:comment 'The original data value entered in the eCRF field at the time the query was raised. Preserved for audit trail and ALCOA+ compliance to document the pre-correction state.' ;
    rdfs:domain ind:DiscrepancyQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'Date and time when the query was escalated. Populated only when is_escalated = true. Used to track escalation response times and site performance.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isDblBlocking rdf:type rdf:Property ;
    rdfs:label 'Is Dbl Blocking' ;
    rdfs:comment 'Indicates whether this open query is blocking the Database Lock (DBL) process. DBL-blocking queries must be resolved before the study database can be locked for statistical analysis.' ;
    rdfs:domain ind:DiscrepancyQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEscalated rdf:type rdf:Property ;
    rdfs:label 'Is Escalated' ;
    rdfs:comment 'Indicates whether this discrepancy query has been escalated due to non-response, repeated failure to resolve, or critical data impact. Triggers escalation workflow in CTMS and monitoring processes.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyRelated rdf:type rdf:Property ;
    rdfs:label 'Is Safety Related' ;
    rdfs:comment 'Indicates whether the discrepancy query relates to safety data (e.g., Adverse Events, SAEs, concomitant medications). Safety-related queries require expedited resolution per GCP and regulatory requirements.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:queryCategory rdf:type rdf:Property ;
    rdfs:label 'Query Category' ;
    rdfs:comment 'Business classification of the data issue driving the query (e.g., missing data, out-of-range value, inconsistency, protocol deviation, transcription error, coding discrepancy). [ENUM-REF-CANDIDATE: missing_data|out_of_range|inconsistency|protocol_deviation|transcription_error|coding_discrepancy|illegible|other — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queryNumber rdf:type rdf:Property ;
    rdfs:label 'Query Number' ;
    rdfs:comment 'Externally visible, human-readable identifier for the discrepancy query as assigned by Medidata Rave EDC (e.g., QRY-0001234). Used in site communications, monitoring reports, and audit trails.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queryStatus rdf:type rdf:Property ;
    rdfs:label 'Query Status' ;
    rdfs:comment 'Current lifecycle state of the discrepancy query within the data cleaning workflow. Open = awaiting site response; Answered = site has responded, pending review; Closed = resolved and accepted; Cancelled = query withdrawn.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queryText rdf:type rdf:Property ;
    rdfs:label 'Query Text' ;
    rdfs:comment 'Full text of the discrepancy query message as displayed to the site. Describes the data issue and requests specific corrective action or clarification from the investigator.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queryType rdf:type rdf:Property ;
    rdfs:label 'Query Type' ;
    rdfs:comment 'Classification of the query origin: manual = CRA/DM-raised; system = auto-generated by Medidata Rave edit check; review = raised during medical or data review; reconciliation = raised from external data source comparison (e.g., lab, SAE reconciliation).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raisedByRole rdf:type rdf:Property ;
    rdfs:label 'Raised By Role' ;
    rdfs:comment 'Functional role of the person or system that raised the query (e.g., CRA - Clinical Research Associate, DM - Data Manager, medical reviewer, system for automated edit checks). Supports workload and quality analytics by role.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raisedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Raised Timestamp' ;
    rdfs:comment 'Date and time when the discrepancy query was first raised in Medidata Rave EDC. Represents the principal business event timestamp for this transaction. Critical for ALCOA+ contemporaneous documentation compliance.' ;
    rdfs:domain ind:DiscrepancyQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:raveQueryReference rdf:type rdf:Property ;
    rdfs:label 'Rave Query Reference' ;
    rdfs:comment 'Native query identifier from Medidata Rave EDC source system. Enables traceability back to the originating system record for audit and reconciliation purposes.' ;
    rdfs:domain ind:DiscrepancyQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reopenCount rdf:type rdf:Property ;
    rdfs:label 'Reopen Count' ;
    rdfs:comment 'Number of times this query has been re-opened after being answered or closed, indicating iterative resolution cycles. High reopen counts signal site data quality issues or unclear query text.' ;
    rdfs:domain ind:DiscrepancyQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionCycleDays rdf:type rdf:Property ;
    rdfs:label 'Resolution Cycle Days' ;
    rdfs:comment 'Number of calendar days between raised_timestamp and closed_timestamp. Measures end-to-end query resolution efficiency; key data management KPI for study performance dashboards.' ;
    rdfs:domain ind:DiscrepancyQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseByUser rdf:type rdf:Property ;
    rdfs:label 'Response By User' ;
    rdfs:comment 'Username of the site staff member (CRC or PI) who submitted the query response in Medidata Rave. Required for ALCOA+ attributability.' ;
    rdfs:domain ind:DiscrepancyQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseCycleDays rdf:type rdf:Property ;
    rdfs:label 'Response Cycle Days' ;
    rdfs:comment 'Number of calendar days between raised_timestamp and response_timestamp. Measures site responsiveness to data queries; used in site performance KPI reporting.' ;
    rdfs:domain ind:DiscrepancyQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseText rdf:type rdf:Property ;
    rdfs:label 'Response Text' ;
    rdfs:comment 'Site\'s textual response to the discrepancy query, entered by the CRC or PI in Medidata Rave. Captures the explanation, correction, or clarification provided by the site.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'Date and time when the site submitted their response to the discrepancy query in Medidata Rave. Used to calculate query response cycle time KPIs.' ;
    rdfs:domain ind:DiscrepancyQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dmpId rdf:type rdf:Property ;
    rdfs:label 'Dmp Id' ;
    rdfs:comment 'Unique surrogate identifier for the Data Management Plan record in the lakehouse silver layer.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dmp .

ind:dmpApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Dmp Approved By Employee Id' ;
    rdfs:comment 'Reference to the individual (typically the Head of Data Management or Study Director) who provided final approval for this version of the DMP.' ;
    rdfs:domain ind:Dmp ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:dmpEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Dmp Employee Id' ;
    rdfs:comment 'Reference to the lead data manager accountable for authoring, maintaining, and executing this DMP throughout the study lifecycle.' ;
    rdfs:domain ind:Dmp ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:indApplicationId rdf:type rdf:Property ;
    rdfs:label 'Ind Application Id' ;
    rdfs:comment 'Foreign key linking to regulatory.ind_application. Business justification: The DMP is developed in alignment with the IND application — data collection strategy, safety reporting obligations, and SDTM requirements must comply with IND commitments. Regulatory affairs teams re' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IndApplication .

ind:programPlanId rdf:type rdf:Property ;
    rdfs:label 'Program Plan Id' ;
    rdfs:comment 'Foreign key linking to program.program_plan. Business justification: The DMP is authored in alignment with the program plan\'s regulatory pathway and submission strategy. Regulatory submissions require traceability from the DMP\'s data collection strategy back to the pro' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgramPlan .

ind:alcoaComplianceApproach rdf:type rdf:Property ;
    rdfs:label 'Alcoa Compliance Approach' ;
    rdfs:comment 'Description of the approach and controls implemented to ensure ALCOA+ (Attributable, Legible, Contemporaneous, Original, Accurate, plus Complete, Consistent, Enduring, Available) data integrity compliance as defined in the DMP.' ;
    rdfs:domain ind:Dmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autocodingEnabled rdf:type rdf:Property ;
    rdfs:label 'Autocoding Enabled' ;
    rdfs:comment 'Indicates whether automated medical coding (auto-coding) is enabled for this study in the coding platform. When true, verbatim terms are automatically matched to dictionary terms without manual intervention.' ;
    rdfs:domain ind:Dmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:codingPlatform rdf:type rdf:Property ;
    rdfs:label 'Coding Platform' ;
    rdfs:comment 'Software platform used to perform MedDRA and WHO-DD medical coding for this study as specified in the DMP.' ;
    rdfs:domain ind:Dmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalDataFieldsDefined rdf:type rdf:Property ;
    rdfs:label 'Critical Data Fields Defined' ;
    rdfs:comment 'Indicates whether the DMP includes a defined list of critical data fields (primary and key secondary endpoints) subject to enhanced data review and 100% SDV requirements.' ;
    rdfs:domain ind:Dmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataCollectionStrategy rdf:type rdf:Property ;
    rdfs:label 'Data Collection Strategy' ;
    rdfs:comment 'Primary strategy for clinical data collection as defined in the DMP. Specifies whether data is collected via eCRF only, eCRF supplemented by external data transfers, paper CRF, or a hybrid approach.' ;
    rdfs:domain ind:Dmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Data Retention Period Years' ;
    rdfs:comment 'Number of years that clinical study data must be retained after study completion or database lock, as mandated by applicable regulations and specified in the DMP.' ;
    rdfs:domain ind:Dmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataReviewPlanSummary rdf:type rdf:Property ;
    rdfs:label 'Data Review Plan Summary' ;
    rdfs:comment 'Summary of the data review plan as defined in the DMP, describing the approach for central data review, medical review, and programmatic data checks prior to database lock.' ;
    rdfs:domain ind:Dmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dblActualDate rdf:type rdf:Property ;
    rdfs:label 'Dbl Actual Date' ;
    rdfs:comment 'Actual date on which the database was locked (DBL) for this study. Null until lock is achieved. Compared against target date for KPI reporting.' ;
    rdfs:domain ind:Dmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dblCriteria rdf:type rdf:Property ;
    rdfs:label 'Dbl Criteria' ;
    rdfs:comment 'Narrative description of the criteria that must be satisfied before the database can be locked (DBL), as defined in the DMP. Includes query resolution thresholds, outstanding discrepancy limits, and data review completion requirements.' ;
    rdfs:domain ind:Dmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dblTargetDate rdf:type rdf:Property ;
    rdfs:label 'Dbl Target Date' ;
    rdfs:comment 'Planned target date for achieving database lock (DBL) as specified in the DMP. Used for study timeline planning and milestone tracking.' ;
    rdfs:domain ind:Dmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dmpCode rdf:type rdf:Property ;
    rdfs:label 'Dmp Code' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the DMP, typically formatted as DMP-{StudyCode}-{SequenceNumber}. Used in regulatory submissions, TMF indexing, and cross-system references.' ;
    rdfs:domain ind:Dmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcStudyEnvironment rdf:type rdf:Property ;
    rdfs:label 'Edc Study Environment' ;
    rdfs:comment 'Deployment environment of the EDC system for this study (production, UAT, training). Ensures data management operations reference the correct validated environment.' ;
    rdfs:domain ind:Dmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcStudyName rdf:type rdf:Property ;
    rdfs:label 'Edc Study Name' ;
    rdfs:comment 'Name of the study as configured within the EDC system (e.g., Medidata Rave study name). Used to cross-reference DMP governance with the operational EDC configuration.' ;
    rdfs:domain ind:Dmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcSystem rdf:type rdf:Property ;
    rdfs:label 'Edc System' ;
    rdfs:comment 'Name of the Electronic Data Capture (EDC) system configured for this study as specified in the DMP. Governs which system is the authoritative source for eCRF data collection.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalDataSources rdf:type rdf:Property ;
    rdfs:label 'External Data Sources' ;
    rdfs:comment 'Comma-separated list or narrative description of external data sources feeding into the study database (e.g., central laboratory, ECG vendor, PK laboratory, ePRO, wearable devices) as specified in the DMP.' ;
    rdfs:domain ind:Dmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalDataTransferRequired rdf:type rdf:Property ;
    rdfs:label 'External Data Transfer Required' ;
    rdfs:comment 'Indicates whether the study requires ingestion of external data transfers (e.g., central lab, ECG, PK, imaging) as specified in the DMP. When true, external data transfer specifications must be documented.' ;
    rdfs:domain ind:Dmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meddraVersion rdf:type rdf:Property ;
    rdfs:label 'Meddra Version' ;
    rdfs:comment 'Version of the MedDRA coding dictionary mandated by this DMP for adverse event and medical history coding (e.g., 26.0). Ensures consistent regulatory coding across the study lifecycle.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:part11ComplianceConfirmed rdf:type rdf:Property ;
    rdfs:label 'Part11 Compliance Confirmed' ;
    rdfs:comment 'Indicates whether the EDC system and data management processes for this study have been confirmed as compliant with FDA 21 CFR Part 11 requirements for electronic records and electronic signatures.' ;
    rdfs:domain ind:Dmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pseudonymizationMethod rdf:type rdf:Property ;
    rdfs:label 'Pseudonymization Method' ;
    rdfs:comment 'Method used to pseudonymize subject data in the EDC and downstream datasets as specified in the DMP, ensuring subject identity is protected in compliance with GDPR and HIPAA.' ;
    rdfs:domain ind:Dmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queryManagementConvention rdf:type rdf:Property ;
    rdfs:label 'Query Management Convention' ;
    rdfs:comment 'Narrative description of the query management approach defined in the DMP, including rules for raising, routing, escalating, and closing data queries in the EDC system.' ;
    rdfs:domain ind:Dmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmIgVersion rdf:type rdf:Property ;
    rdfs:label 'Sdtm Ig Version' ;
    rdfs:comment 'Version of the CDISC SDTM Implementation Guide (SDTM IG) used for this study (e.g., 3.3, 3.4). Determines the domain structures and controlled terminology applied in SDTM dataset generation.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmMappingVersion rdf:type rdf:Property ;
    rdfs:label 'Sdtm Mapping Version' ;
    rdfs:comment 'Version of the CDISC SDTM mapping specification applied to this study as defined in the DMP. Governs the transformation of raw EDC data to SDTM-compliant datasets for regulatory submission.' ;
    rdfs:domain ind:Dmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unblindingProcedureDocumented rdf:type rdf:Property ;
    rdfs:label 'Unblinding Procedure Documented' ;
    rdfs:comment 'Indicates whether the DMP documents the procedure for emergency and planned unblinding of randomization codes, including roles, authorization levels, and audit trail requirements.' ;
    rdfs:domain ind:Dmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validationCheckCount rdf:type rdf:Property ;
    rdfs:label 'Validation Check Count' ;
    rdfs:comment 'Total number of programmatic data validation checks (edit checks) defined in the EDC system for this study as documented in the DMP. Indicates the scope of automated data quality controls.' ;
    rdfs:domain ind:Dmp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:whoddVersion rdf:type rdf:Property ;
    rdfs:label 'Whodd Version' ;
    rdfs:comment 'Version of the WHO Drug Dictionary (WHO-DD) mandated by this DMP for concomitant medication coding. Ensures standardized drug coding for regulatory submissions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: eCRF field authorship is required for EDC system change control documentation and GCP audit trails. Linking field creation to the employee record enables accountability reporting for regulatory inspec' ;
    rdfs:domain ind:EcrfField ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alcoaAttribute rdf:type rdf:Property ;
    rdfs:label 'Alcoa Attribute' ;
    rdfs:comment 'Primary ALCOA+ data integrity attribute that this field is designed to support (e.g., contemporaneous for date/time fields, attributable for signature fields, accurate for validated numeric fields). Supports ALCOA+ compliance tracking at the field level. [ENUM-REF-CANDIDATE: attributable|legible|contemporaneous|original|accurate|complete|consistent|enduring|available — promote to reference product]' ;
    rdfs:domain ind:EcrfField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdashVariable rdf:type rdf:Property ;
    rdfs:label 'Cdash Variable' ;
    rdfs:comment 'CDISC CDASH variable name that this eCRF field implements, representing the standardized data collection variable. Ensures harmonized data collection aligned with CDISC CDASH standards for cross-study comparability.' ;
    rdfs:domain ind:EcrfField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codelistOid rdf:type rdf:Property ;
    rdfs:label 'Codelist Oid' ;
    rdfs:comment 'Object identifier (OID) of the controlled terminology codelist bound to this field in Medidata Rave. Applicable for codelist-type fields; references CDISC Controlled Terminology or sponsor-defined codelists governing permissible values.' ;
    rdfs:domain ind:EcrfField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codingDictionaryVersion rdf:type rdf:Property ;
    rdfs:label 'Coding Dictionary Version' ;
    rdfs:comment 'Version of the medical coding dictionary applied to this field (e.g., MedDRA 26.1, WHO-DD March 2024). Ensures reproducibility of coded terms across study lifecycle and regulatory submissions.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultValue rdf:type rdf:Property ;
    rdfs:label 'Default Value' ;
    rdfs:comment 'Pre-populated default value for this field as configured in Medidata Rave. Reduces data entry burden for fields with a common expected value while remaining editable by site staff.' ;
    rdfs:domain ind:EcrfField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldDataType rdf:type rdf:Property ;
    rdfs:label 'Field Data Type' ;
    rdfs:comment 'Data type of the field as configured in Medidata Rave, determining the kind of value that can be entered. Drives validation rule applicability and CDISC SDTM variable type mapping. [ENUM-REF-CANDIDATE: text|integer|float|date|datetime|codelist|checkbox|file|log — promote to reference product]' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldLabel rdf:type rdf:Property ;
    rdfs:label 'Field Label' ;
    rdfs:comment 'Human-readable label displayed to the data entry user on the eCRF in Medidata Rave. Represents the question or prompt as seen by the Clinical Research Coordinator (CRC) or site staff.' ;
    rdfs:domain ind:EcrfField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldLength rdf:type rdf:Property ;
    rdfs:label 'Field Length' ;
    rdfs:comment 'Maximum character length allowed for text entry in this field. Constrains free-text input to prevent data truncation during SDTM transformation and downstream database storage.' ;
    rdfs:domain ind:EcrfField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fieldOid rdf:type rdf:Property ;
    rdfs:label 'Field Oid' ;
    rdfs:comment 'Unique object identifier (OID) for the field as defined in Medidata Rave and conforming to ODM XML standards. Used for cross-system referencing and CDISC ODM data exchange.' ;
    rdfs:domain ind:EcrfField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldOrder rdf:type rdf:Property ;
    rdfs:label 'Field Order' ;
    rdfs:comment 'Numeric sequence position of the field within its parent eCRF form, determining the display order presented to data entry users. Used for form layout and navigation.' ;
    rdfs:domain ind:EcrfField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fieldStatus rdf:type rdf:Property ;
    rdfs:label 'Field Status' ;
    rdfs:comment 'Current lifecycle status of the eCRF field definition. Controls whether the field is available for data entry in active studies. Draft fields are under design review; retired fields are no longer used in new study builds.' ;
    rdfs:domain ind:EcrfField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:helpText rdf:type rdf:Property ;
    rdfs:label 'Help Text' ;
    rdfs:comment 'Instructional or contextual help text displayed to data entry users for this field in Medidata Rave. Provides guidance on how to complete the field, acceptable formats, and clinical definitions to ensure data quality.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAuditTrailEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Audit Trail Enabled' ;
    rdfs:comment 'Indicates whether field-level audit trail tracking is enabled for this eCRF field, capturing all data entry, modification, and deletion events with user, timestamp, and reason for change. Mandatory for ALCOA+ and 21 CFR Part 11 compliance.' ;
    rdfs:domain ind:EcrfField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isKeyField rdf:type rdf:Property ;
    rdfs:label 'Is Key Field' ;
    rdfs:comment 'Indicates whether this field is designated as a key field in Medidata Rave, used for record identification and deduplication within a log or repeating form. Key fields are critical for data integrity in multi-record forms.' ;
    rdfs:domain ind:EcrfField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLogField rdf:type rdf:Property ;
    rdfs:label 'Is Log Field' ;
    rdfs:comment 'Indicates whether this field belongs to a log (repeating) form in Medidata Rave, allowing multiple rows of data entry per subject visit (e.g., concomitant medications log, adverse events log).' ;
    rdfs:domain ind:EcrfField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReadOnly rdf:type rdf:Property ;
    rdfs:label 'Is Read Only' ;
    rdfs:comment 'Indicates whether the field is read-only and cannot be directly edited by site users. Read-only fields are typically auto-populated by the system or derived from other data points.' ;
    rdfs:domain ind:EcrfField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRequired rdf:type rdf:Property ;
    rdfs:label 'Is Required' ;
    rdfs:comment 'Indicates whether data entry for this field is mandatory before the eCRF can be submitted. Required fields enforce ALCOA+ completeness compliance and are enforced by Medidata Rave validation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSdvRequired rdf:type rdf:Property ;
    rdfs:label 'Is Sdv Required' ;
    rdfs:comment 'Indicates whether this field is designated for Source Data Verification (SDV) by the Clinical Research Associate (CRA) during monitoring visits. Drives risk-based monitoring plans and SDV scope configuration.' ;
    rdfs:domain ind:EcrfField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSponsorDefined rdf:type rdf:Property ;
    rdfs:label 'Is Sponsor Defined' ;
    rdfs:comment 'Indicates whether this field is a sponsor-defined custom field beyond the standard CDISC CDASH variables. Sponsor-defined fields require additional SDTM mapping documentation for regulatory submissions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVisible rdf:type rdf:Property ;
    rdfs:label 'Is Visible' ;
    rdfs:comment 'Indicates whether the field is currently visible to data entry users on the eCRF. Invisible fields may be conditionally hidden by edit check logic or used for internal system calculations.' ;
    rdfs:domain ind:EcrfField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxValue rdf:type rdf:Property ;
    rdfs:label 'Max Value' ;
    rdfs:comment 'Maximum permissible numeric value for this field as defined in the validation rules. Applicable to numeric and date fields; values above this threshold trigger a data query in Medidata Rave.' ;
    rdfs:domain ind:EcrfField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minValue rdf:type rdf:Property ;
    rdfs:label 'Min Value' ;
    rdfs:comment 'Minimum permissible numeric value for this field as defined in the validation rules. Applicable to numeric and date fields; values below this threshold trigger a data query in Medidata Rave.' ;
    rdfs:domain ind:EcrfField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'Username or user identifier of the individual who last modified this eCRF field definition in Medidata Rave. Supports ALCOA+ attributability and change control audit trail.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this eCRF field definition record. Tracks configuration changes for audit trail purposes and supports ALCOA+ compliance.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:queryGenerationMode rdf:type rdf:Property ;
    rdfs:label 'Query Generation Mode' ;
    rdfs:comment 'Specifies how data queries (discrepancies) are generated for this field in Medidata Rave: automatic (system-generated by edit checks), manual (raised by data managers or monitors), or none (no query generation configured).' ;
    rdfs:domain ind:EcrfField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raveFieldType rdf:type rdf:Property ;
    rdfs:label 'Rave Field Type' ;
    rdfs:comment 'Medidata Rave-specific UI control type for this field, determining the data entry widget rendered on the eCRF (e.g., text box, radio button, dropdown list, checkbox). Distinct from the logical data type. [ENUM-REF-CANDIDATE: text|longtext|integer|float|date|datetime|checkbox|radiobutton|dropdownlist|file|signature|label — promote to reference product]' ;
    rdfs:domain ind:EcrfField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmDomain rdf:type rdf:Property ;
    rdfs:label 'Sdtm Domain' ;
    rdfs:comment 'CDISC SDTM domain code (e.g., DM, AE, LB, VS, CM) to which this eCRF field maps. Drives automated CDISC SDTM transformation in SAS Drug Development and regulatory submission dataset generation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemFieldReference rdf:type rdf:Property ;
    rdfs:label 'Source System Field Reference' ;
    rdfs:comment 'Native field identifier as assigned by Medidata Rave EDC. Enables traceability between the Silver Layer data product and the originating EDC system record for reconciliation and lineage purposes.' ;
    rdfs:domain ind:EcrfField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitDictionary rdf:type rdf:Property ;
    rdfs:label 'Unit Dictionary' ;
    rdfs:comment 'Name of the unit dictionary or unit codelist bound to this field in Medidata Rave (e.g., SI units, lab units). Governs permissible units of measure for numeric fields and supports SDTM --ORRESU and --STRESU variable mapping.' ;
    rdfs:domain ind:EcrfField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationRuleExpression rdf:type rdf:Property ;
    rdfs:label 'Validation Rule Expression' ;
    rdfs:comment 'Edit check or validation rule expression applied to this field in Medidata Rave (e.g., range checks, cross-field consistency checks, date logic). Defines the programmatic logic that triggers data queries when violated.' ;
    rdfs:domain ind:EcrfField ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcStudyBuildId rdf:type rdf:Property ;
    rdfs:label 'Edc Study Build Id' ;
    rdfs:comment 'Reference to the specific EDC study build (Medidata Rave study version/draft) in which this eCRF form is deployed. Tracks which build configuration contains this form.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EdcStudyBuild .

ind:kitDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Kit Definition Id' ;
    rdfs:comment 'Foreign key linking to supply.kit_definition. Business justification: Dispensing and accountability eCRF forms are designed around specific kit definitions (dose strength, pack size, dispensing unit). EDC build teams must associate each dispensing form with the correct ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KitDefinition .

ind:annotationText rdf:type rdf:Property ;
    rdfs:label 'Annotation Text' ;
    rdfs:comment 'SDTM variable annotation text associated with this form, documenting the mapping between eCRF data fields and SDTM dataset variables. Used in annotated CRF (aCRF) generation for regulatory submissions.' ;
    rdfs:domain ind:EcrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdashDomain rdf:type rdf:Property ;
    rdfs:label 'Cdash Domain' ;
    rdfs:comment 'CDISC CDASH domain code that this eCRF form implements for standardized data collection (e.g., \'AE\', \'CM\', \'EX\', \'MH\'). Ensures alignment with CDASH data collection standards for regulatory submissions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionRule rdf:type rdf:Property ;
    rdfs:label 'Completion Rule' ;
    rdfs:comment 'Business rule governing what constitutes a \'complete\' eCRF form for database lock purposes. Defines whether all fields must be populated, partial completion is acceptable, or conditional logic applies.' ;
    rdfs:domain ind:EcrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataEntryMode rdf:type rdf:Property ;
    rdfs:label 'Data Entry Mode' ;
    rdfs:comment 'Specifies whether data entry for this form requires single entry (one operator) or double entry (two independent operators for verification) as configured in Medidata Rave. Impacts data quality and ALCOA+ compliance.' ;
    rdfs:domain ind:EcrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:editCheckCount rdf:type rdf:Property ;
    rdfs:label 'Edit Check Count' ;
    rdfs:comment 'Number of programmed edit checks (validation rules) associated with this eCRF form in the Medidata Rave study build. Indicates the complexity of data validation logic applied to the form.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fieldCount rdf:type rdf:Property ;
    rdfs:label 'Field Count' ;
    rdfs:comment 'Total number of data fields (eCRF fields) contained within this form definition. Used for form complexity assessment, UAT planning, and data management workload estimation.' ;
    rdfs:domain ind:EcrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formDescription rdf:type rdf:Property ;
    rdfs:label 'Form Description' ;
    rdfs:comment 'Detailed narrative description of the eCRF form\'s purpose, the clinical data it captures, and any special instructions for data entry personnel (CRCs/site staff).' ;
    rdfs:domain ind:EcrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formOid rdf:type rdf:Property ;
    rdfs:label 'Form Oid' ;
    rdfs:comment 'Unique object identifier (OID) for the eCRF form as defined in the ODM-compliant Medidata Rave study design. Used for CDISC ODM data exchange and SDTM mapping. Externally referenceable identifier.' ;
    rdfs:domain ind:EcrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formOrder rdf:type rdf:Property ;
    rdfs:label 'Form Order' ;
    rdfs:comment 'Numeric sequence position of this form within its assigned visit or folder in the Medidata Rave EDC navigation. Controls the order in which forms are presented to data entry personnel.' ;
    rdfs:domain ind:EcrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formStatus rdf:type rdf:Property ;
    rdfs:label 'Form Status' ;
    rdfs:comment 'Current lifecycle status of the eCRF form definition within the EDC system. Draft forms are under development; active forms are deployed for data collection; inactive/retired forms are no longer used.' ;
    rdfs:domain ind:EcrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formType rdf:type rdf:Property ;
    rdfs:label 'Form Type' ;
    rdfs:comment 'Categorization of the eCRF form by its structural and scheduling behavior in Medidata Rave. Visit-based forms appear at scheduled visits; log/repeating forms allow multiple instances per subject; unscheduled forms capture ad hoc data; common forms are shared across visits. [ENUM-REF-CANDIDATE: visit_based|unscheduled|log|repeating|common|standalone — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:EcrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formVersion rdf:type rdf:Property ;
    rdfs:label 'Form Version' ;
    rdfs:comment 'Version label of the eCRF form design (e.g., \'1.0\', \'2.1\', \'Draft\'). Tracks design iterations and amendments to the form across study lifecycle.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRepeating rdf:type rdf:Property ;
    rdfs:label 'Is Repeating' ;
    rdfs:comment 'Indicates whether this eCRF form supports multiple instances (log lines) per subject per visit, such as Adverse Events or Concomitant Medications forms. True for log/repeating forms in Medidata Rave.' ;
    rdfs:domain ind:EcrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSubjectLevel rdf:type rdf:Property ;
    rdfs:label 'Is Subject Level' ;
    rdfs:comment 'Indicates whether this form is collected once per subject across the entire study (e.g., Demographics, Medical History) rather than at each visit. Drives form placement in the EDC navigation structure.' ;
    rdfs:domain ind:EcrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalCodingRequired rdf:type rdf:Property ;
    rdfs:label 'Medical Coding Required' ;
    rdfs:comment 'Indicates whether data collected on this form requires medical coding using standardized dictionaries (MedDRA for adverse events/medical history, WHO-DD for concomitant medications). Drives coding workflow assignment.' ;
    rdfs:domain ind:EcrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryEndpointFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Endpoint Flag' ;
    rdfs:comment 'Indicates whether this eCRF form captures data for the study\'s primary efficacy or safety endpoint. Primary endpoint forms receive heightened data quality scrutiny, 100% SDV, and priority query resolution.' ;
    rdfs:domain ind:EcrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:protocolSectionRef rdf:type rdf:Property ;
    rdfs:label 'Protocol Section Ref' ;
    rdfs:comment 'Reference to the specific section(s) of the study protocol that this eCRF form supports (e.g., \'Section 8.2 - Safety Assessments\'). Ensures traceability between protocol requirements and data collection instruments.' ;
    rdfs:domain ind:EcrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queryAutoGeneration rdf:type rdf:Property ;
    rdfs:label 'Query Auto Generation' ;
    rdfs:comment 'Indicates whether the EDC system is configured to automatically generate data queries (discrepancies) for this form based on programmed edit checks and validation rules.' ;
    rdfs:domain ind:EcrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:raveFormReference rdf:type rdf:Property ;
    rdfs:label 'Rave Form Reference' ;
    rdfs:comment 'Native form identifier as assigned by the Medidata Rave EDC source system. Used for cross-referencing with the operational EDC system and data lineage tracking from source to lakehouse.' ;
    rdfs:domain ind:EcrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresSignature rdf:type rdf:Property ;
    rdfs:label 'Requires Signature' ;
    rdfs:comment 'Indicates whether this eCRF form requires an electronic signature (e.g., Principal Investigator sign-off) upon completion. Governs 21 CFR Part 11 compliant e-signature workflows in Medidata Rave.' ;
    rdfs:domain ind:EcrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyFormFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Form Flag' ;
    rdfs:comment 'Indicates whether this eCRF form is designated as a safety data collection instrument (e.g., Adverse Events, Serious Adverse Events, Concomitant Medications). Safety forms are subject to expedited review and regulatory reporting timelines.' ;
    rdfs:domain ind:EcrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdvPercentage rdf:type rdf:Property ;
    rdfs:label 'Sdv Percentage' ;
    rdfs:comment 'Target percentage of data points on this form subject to Source Data Verification (SDV) as defined in the monitoring plan. Supports risk-based monitoring strategies (e.g., 100%, 50%, 10%).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sdvRequired rdf:type rdf:Property ;
    rdfs:label 'Sdv Required' ;
    rdfs:comment 'Indicates whether Source Data Verification (SDV) is required for data entered on this form. Critical forms (e.g., primary endpoints, safety data) typically require 100% SDV; others may be risk-based.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureRole rdf:type rdf:Property ;
    rdfs:label 'Signature Role' ;
    rdfs:comment 'The role required to provide the electronic signature on this eCRF form (e.g., Principal Investigator). Applicable only when requires_signature is True.' ;
    rdfs:domain ind:EcrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorFormNumber rdf:type rdf:Property ;
    rdfs:label 'Sponsor Form Number' ;
    rdfs:comment 'Sponsor-assigned form number or code used in the paper CRF or sponsor\'s internal document management system. Enables cross-referencing between the EDC form and sponsor documentation (e.g., annotated CRF).' ;
    rdfs:domain ind:EcrfForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentSopId rdf:type rdf:Property ;
    rdfs:label 'Document Sop Id' ;
    rdfs:comment 'Foreign key linking to document.document_sop. Business justification: EDC study builds are executed per an EDC Build and Validation SOP. GCP requires documented evidence that system validation followed an approved SOP. This FK links each build to its governing SOP, enab' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocumentSop .

ind:predecessorBuildEdcStudyBuildId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Build Edc Study Build Id' ;
    rdfs:comment 'Reference to the previous EDC study build version that this build supersedes. Enables amendment history traversal and change impact analysis across build versions.' ;
    rdfs:domain ind:EdcStudyBuild ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EdcStudyBuild .

ind:protocolVersionId rdf:type rdf:Property ;
    rdfs:label 'Protocol Version Id' ;
    rdfs:comment 'Reference to the specific protocol version that this EDC study build implements. Ensures the build is aligned to the correct protocol amendment.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Version .

ind:buildCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Build Completion Date' ;
    rdfs:comment 'The date on which the EDC study build configuration was completed and handed over for UAT. Marks the end of the development phase.' ;
    rdfs:domain ind:EdcStudyBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:buildEnvironment rdf:type rdf:Property ;
    rdfs:label 'Build Environment' ;
    rdfs:comment 'The Medidata Rave environment in which this build configuration resides: development (active build/configuration), UAT (User Acceptance Testing validation), or production (live data collection).' ;
    rdfs:domain ind:EdcStudyBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildName rdf:type rdf:Property ;
    rdfs:label 'Build Name' ;
    rdfs:comment 'Human-readable descriptive name for the EDC study build configuration, typically including the study acronym and build purpose (e.g., STUDY-001 Phase III Production Build).' ;
    rdfs:domain ind:EdcStudyBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildNotes rdf:type rdf:Property ;
    rdfs:label 'Build Notes' ;
    rdfs:comment 'Free-text notes capturing key decisions, known issues, deviations from standard build practices, or special configurations relevant to this EDC study build version.' ;
    rdfs:domain ind:EdcStudyBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildNumber rdf:type rdf:Property ;
    rdfs:label 'Build Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for this specific EDC study build version in Medidata Rave (e.g., BUILD_001, v2.3.1). Used for traceability and change control documentation.' ;
    rdfs:domain ind:EdcStudyBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildStartDate rdf:type rdf:Property ;
    rdfs:label 'Build Start Date' ;
    rdfs:comment 'The date on which active development/configuration of this EDC study build commenced in Medidata Rave. Used for project planning and build timeline tracking.' ;
    rdfs:domain ind:EdcStudyBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:buildStatus rdf:type rdf:Property ;
    rdfs:label 'Build Status' ;
    rdfs:comment 'Current lifecycle status of the EDC study build configuration. Tracks progression from initial development through UAT, approval, deployment, and eventual retirement. [ENUM-REF-CANDIDATE: draft|in_development|in_uat|uat_complete|approved|deployed|retired — promote to reference product]' ;
    rdfs:domain ind:EdcStudyBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildType rdf:type rdf:Property ;
    rdfs:label 'Build Type' ;
    rdfs:comment 'Classification of the build change type: initial (first build for the study), amendment (protocol amendment-driven rebuild), patch (minor correction), or hotfix (urgent production fix).' ;
    rdfs:domain ind:EdcStudyBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildVersion rdf:type rdf:Property ;
    rdfs:label 'Build Version' ;
    rdfs:comment 'Semantic version number of the EDC study build (e.g., 1.0, 2.1, 3.0.1). Incremented with each approved change to the build configuration to support audit trail and change control.' ;
    rdfs:domain ind:EdcStudyBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdashVersion rdf:type rdf:Property ;
    rdfs:label 'Cdash Version' ;
    rdfs:comment 'Version of the CDISC CDASH standard used to design the eCRF data collection fields in this EDC study build. Ensures harmonized data collection aligned with regulatory submission requirements.' ;
    rdfs:domain ind:EdcStudyBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdiscSdtmMappingVersion rdf:type rdf:Property ;
    rdfs:label 'Cdisc Sdtm Mapping Version' ;
    rdfs:comment 'Version of the CDISC SDTM mapping specification applied to this EDC study build. Governs how collected eCRF data is transformed into SDTM-compliant datasets for regulatory submission.' ;
    rdfs:domain ind:EdcStudyBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crfCount rdf:type rdf:Property ;
    rdfs:label 'Crf Count' ;
    rdfs:comment 'Total number of electronic Case Report Forms (eCRFs) configured in this EDC study build. Provides a high-level measure of build scope and complexity.' ;
    rdfs:domain ind:EdcStudyBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:derivationCount rdf:type rdf:Property ;
    rdfs:label 'Derivation Count' ;
    rdfs:comment 'Total number of programmed data derivations (auto-calculated fields) configured in this EDC study build. Derivations reduce manual data entry and support data consistency.' ;
    rdfs:domain ind:EdcStudyBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:econsentIntegrated rdf:type rdf:Property ;
    rdfs:label 'Econsent Integrated' ;
    rdfs:comment 'Indicates whether this EDC study build is integrated with an eConsent platform (e.g., Clinpal) for electronic Informed Consent Form (ICF) management and subject consent tracking.' ;
    rdfs:domain ind:EdcStudyBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goLiveDate rdf:type rdf:Property ;
    rdfs:label 'Go Live Date' ;
    rdfs:comment 'The date on which the EDC study build was deployed to the production environment and made available for live clinical data collection at study sites.' ;
    rdfs:domain ind:EdcStudyBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Lab Integration Enabled' ;
    rdfs:comment 'Indicates whether this EDC study build has automated laboratory data integration configured (e.g., central lab data feeds into Medidata Rave). Reduces manual transcription and supports ALCOA+.' ;
    rdfs:domain ind:EdcStudyBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:part11Compliant rdf:type rdf:Property ;
    rdfs:label 'Part11 Compliant' ;
    rdfs:comment 'Indicates whether this EDC study build has been validated and confirmed compliant with 21 CFR Part 11 requirements for electronic records and electronic signatures.' ;
    rdfs:domain ind:EdcStudyBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:randomizationIntegrated rdf:type rdf:Property ;
    rdfs:label 'Randomization Integrated' ;
    rdfs:comment 'Indicates whether this EDC study build is integrated with the Medidata Rave RTSM (Randomization and Trial Supply Management) module for subject randomization and IRT functionality.' ;
    rdfs:domain ind:EdcStudyBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:raveStudyName rdf:type rdf:Property ;
    rdfs:label 'Rave Study Name' ;
    rdfs:comment 'The exact study name as configured and registered within the Medidata Rave EDC system. Used for system-level identification and integration with downstream CDISC SDTM pipelines.' ;
    rdfs:domain ind:EdcStudyBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raveStudyUuid rdf:type rdf:Property ;
    rdfs:label 'Rave Study Uuid' ;
    rdfs:comment 'Universally unique identifier assigned to the study within Medidata Rave. Used for system-to-system integration, API calls, and cross-environment traceability.' ;
    rdfs:domain ind:EdcStudyBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uatCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Uat Completion Date' ;
    rdfs:comment 'The date on which UAT was formally completed and signed off. Prerequisite for build approval and production deployment.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:uatDefectCount rdf:type rdf:Property ;
    rdfs:label 'Uat Defect Count' ;
    rdfs:comment 'Total number of defects identified during UAT for this build version. Used to assess build quality and readiness for production deployment.' ;
    rdfs:domain ind:EdcStudyBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uatPassed rdf:type rdf:Property ;
    rdfs:label 'Uat Passed' ;
    rdfs:comment 'Indicates whether the EDC study build successfully passed all UAT test cases without critical defects. True = UAT passed; False = UAT failed or has open critical defects.' ;
    rdfs:domain ind:EdcStudyBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:uatStartDate rdf:type rdf:Property ;
    rdfs:label 'Uat Start Date' ;
    rdfs:comment 'The date on which User Acceptance Testing of the EDC study build commenced. UAT validates that the build meets protocol requirements before production deployment.' ;
    rdfs:domain ind:EdcStudyBuild ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Date' ;
    rdfs:comment 'Date on which the formal acknowledgement of receipt was received from the target system or recipient.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgementReceived rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Received' ;
    rdfs:comment 'Indicates whether a formal acknowledgement of receipt was received from the target system or recipient following the transfer. Supports ALCOA+ traceability.' ;
    rdfs:domain ind:ExternalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdiscDomain rdf:type rdf:Property ;
    rdfs:label 'Cdisc Domain' ;
    rdfs:comment 'The CDISC SDTM or ADaM domain code applicable to the transferred data (e.g., LB for laboratory, PC for pharmacokinetic concentration, EG for ECG). Governs downstream SDTM transformation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Checksum Algorithm' ;
    rdfs:comment 'Algorithm used to generate the checksum value for file integrity verification (e.g., MD5, SHA-256).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumValue rdf:type rdf:Property ;
    rdfs:label 'Checksum Value' ;
    rdfs:comment 'Cryptographic checksum (e.g., MD5 or SHA-256 hash) of the transferred file, used to verify file integrity and detect corruption or tampering during transmission.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dblImpacted rdf:type rdf:Property ;
    rdfs:label 'Dbl Impacted' ;
    rdfs:comment 'Indicates whether this transfer is on the critical path for a database lock (DBL) milestone. Transfers flagged as DBL-impacted require prioritized reconciliation and sign-off.' ;
    rdfs:domain ind:ExternalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:encryptionMethod rdf:type rdf:Property ;
    rdfs:label 'Encryption Method' ;
    rdfs:comment 'Encryption or secure transmission method applied to the data file during transfer (e.g., PGP encryption, SFTP, HTTPS). Supports data security and regulatory compliance.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorDescription rdf:type rdf:Property ;
    rdfs:label 'Error Description' ;
    rdfs:comment 'Free-text description of any errors, failures, or exceptions encountered during the transfer, validation, or reconciliation process. Populated when transfer_status is \'failed\'.' ;
    rdfs:domain ind:ExternalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedRecordCount rdf:type rdf:Property ;
    rdfs:label 'Expected Record Count' ;
    rdfs:comment 'Number of records expected in the transfer as defined in the transfer specification or agreed with the vendor. Compared against actual record_count during reconciliation.' ;
    rdfs:domain ind:ExternalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'Technical format of the transferred data file (e.g., SAS XPT for CDISC submissions, CSV for flat file transfers, HL7 for lab/clinical messaging). Governs parsing and validation approach.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'Name of the data file or package transferred, as received or sent. Used for traceability and reconciliation against transfer specifications.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeKb rdf:type rdf:Property ;
    rdfs:label 'File Size Kb' ;
    rdfs:comment 'Size of the transferred data file in kilobytes. Used for transfer validation, completeness checks, and anomaly detection (e.g., unexpectedly small or large files).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCount rdf:type rdf:Property ;
    rdfs:label 'Record Count' ;
    rdfs:comment 'Total number of data records contained in the transferred file or dataset. Used for reconciliation against expected counts from the source vendor.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatorySubmissionRelevant rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Relevant' ;
    rdfs:comment 'Indicates whether the transferred data is intended for inclusion in a regulatory submission (e.g., NDA, BLA, MAA, eCTD). Triggers additional QC and traceability requirements.' ;
    rdfs:domain ind:ExternalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'Number of times this transfer was retried following an initial failure. Supports operational monitoring and escalation decisions.' ;
    rdfs:domain ind:ExternalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetSystem rdf:type rdf:Property ;
    rdfs:label 'Target System' ;
    rdfs:comment 'Name or identifier of the destination system receiving the transferred data (e.g., Medidata Rave EDC, SAS Drug Development, sponsor data warehouse).' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferDate rdf:type rdf:Property ;
    rdfs:label 'Transfer Date' ;
    rdfs:comment 'The actual calendar date on which the external data transfer was executed. This is the principal real-world business event date for the transfer.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transferDirection rdf:type rdf:Property ;
    rdfs:label 'Transfer Direction' ;
    rdfs:comment 'Indicates whether data is flowing into the clinical database (inbound) from an external source, or being sent out (outbound) to an external recipient.' ;
    rdfs:domain ind:ExternalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferFrequency rdf:type rdf:Property ;
    rdfs:label 'Transfer Frequency' ;
    rdfs:comment 'Scheduled frequency of this type of external data transfer as agreed in the data transfer specification (e.g., weekly lab data feeds, one-time PK data transfer).' ;
    rdfs:domain ind:ExternalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Number' ;
    rdfs:comment 'Human-readable, externally-known business identifier for the transfer event (e.g., EXT-STUDY001-202401). Used for cross-system traceability and audit references.' ;
    rdfs:domain ind:ExternalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferProtocol rdf:type rdf:Property ;
    rdfs:label 'Transfer Protocol' ;
    rdfs:comment 'Network or file transfer protocol used to transmit the data (e.g., SFTP, FTPS, HTTPS, AS2, or manual upload). Governs technical integration and security posture.' ;
    rdfs:domain ind:ExternalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferSpecVersion rdf:type rdf:Property ;
    rdfs:label 'Transfer Spec Version' ;
    rdfs:comment 'Version number of the data transfer specification document in effect at the time of this transfer. Ensures traceability to the correct specification version.' ;
    rdfs:domain ind:ExternalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle state of the external data transfer workflow, from initiation through completion or failure.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transfer Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone) at which the external data transfer was initiated or completed, supporting ALCOA+ contemporaneous documentation requirements.' ;
    rdfs:domain ind:ExternalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the external data transfer by data category. Identifies the nature of the third-party data being transferred. [ENUM-REF-CANDIDATE: central_lab|pk_pd|epro_ecoa|ecg|medical_imaging|wearable_device|other — promote to reference product]' ;
    rdfs:domain ind:ExternalTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataEntrySessionId rdf:type rdf:Property ;
    rdfs:label 'Data Entry Session Id' ;
    rdfs:comment 'Foreign key linking to data.data_entry_session. Business justification: A field entry occurs within a data entry session. Multiple field entries are captured during a single session. This FK links each atomic field entry to the session context (session type, duration, use' ;
    rdfs:domain ind:Data ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataEntrySession .

ind:enteredByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Entered By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: ALCOA attributability at the field level is a 21 CFR Part 11 and ICH E6 GCP requirement; each data entry must be traceable to a specific employee. entered_by_user is a denormalized employee identifier' ;
    rdfs:domain ind:FieldEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:irtTransactionId rdf:type rdf:Property ;
    rdfs:label 'Irt Transaction Id' ;
    rdfs:comment 'Foreign key linking to randomization.irt_transaction. Business justification: IRT-EDC reconciliation requires linking eCRF field entries for randomization/kit fields directly to the IRT transaction that triggered them. This supports automated discrepancy detection between IRT-a' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IrtTransaction .

ind:subjectVisitDataId rdf:type rdf:Property ;
    rdfs:label 'Subject Visit Data Id' ;
    rdfs:comment 'Foreign key linking to data.subject_visit_data. Business justification: field_entry is an atomic-level data entry that belongs to a subject visit data record. subject_visit_data is the aggregate visit-level record capturing all eCRF data for a subject at a visit. Adding s' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SubjectVisitData .

ind:subjectVisitId rdf:type rdf:Property ;
    rdfs:label 'Subject Visit Id' ;
    rdfs:comment 'Reference to the scheduled or unscheduled study visit during which this field entry was collected. Provides temporal context for the data point within the subject\'s study timeline.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SubjectVisit .

ind:alcoaAccurate rdf:type rdf:Property ;
    rdfs:label 'Alcoa Accurate' ;
    rdfs:comment 'ALCOA+ compliance flag indicating whether the field entry value has been verified as accurate against the source document or original observation. Set to true upon successful SDV or data review confirmation.' ;
    rdfs:domain ind:FieldEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alcoaAttributable rdf:type rdf:Property ;
    rdfs:label 'Alcoa Attributable' ;
    rdfs:comment 'ALCOA+ compliance flag indicating whether the field entry is attributable to a specific, identified individual (i.e., the entered_by_user is known and authenticated). One of the core ALCOA+ data integrity principles required by FDA and ICH.' ;
    rdfs:domain ind:FieldEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alcoaContemporaneous rdf:type rdf:Property ;
    rdfs:label 'Alcoa Contemporaneous' ;
    rdfs:comment 'ALCOA+ compliance flag indicating whether the field entry was recorded at the time the observation was made (i.e., entry_timestamp is within an acceptable window of the actual observation date). Supports data integrity and GCP compliance monitoring.' ;
    rdfs:domain ind:FieldEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alcoaLegible rdf:type rdf:Property ;
    rdfs:label 'Alcoa Legible' ;
    rdfs:comment 'ALCOA+ compliance flag indicating whether the field entry value is legible and readable. Particularly relevant for transcribed or scanned source data. Supports data integrity assessments during regulatory inspections.' ;
    rdfs:domain ind:FieldEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alcoaOriginal rdf:type rdf:Property ;
    rdfs:label 'Alcoa Original' ;
    rdfs:comment 'ALCOA+ compliance flag indicating whether this field entry represents the original (first) recorded value, as opposed to a transcription or copy. Distinguishes primary source data from derived or transferred data.' ;
    rdfs:domain ind:FieldEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditTrailRef rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Ref' ;
    rdfs:comment 'The unique reference identifier linking this field entry to its corresponding audit trail record in Medidata Rave. Enables direct cross-referencing with the EDC system\'s immutable audit log for regulatory inspection and SDV activities.' ;
    rdfs:domain ind:FieldEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codedTerm rdf:type rdf:Property ;
    rdfs:label 'Coded Term' ;
    rdfs:comment 'The standardized dictionary term assigned to this field entry after medical coding (e.g., MedDRA Preferred Term (PT) for adverse events, WHO-DD drug name for medications). Null for fields not requiring coding.' ;
    rdfs:domain ind:FieldEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataEntryType rdf:type rdf:Property ;
    rdfs:label 'Data Entry Type' ;
    rdfs:comment 'Classifies how the field value was populated in the EDC system. Distinguishes between manual site entry, system auto-population (e.g., calculated fields), data migration, or external data import (e.g., lab data transfer). Supports ALCOA+ \'Original\' assessment.' ;
    rdfs:domain ind:FieldEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryStatus rdf:type rdf:Property ;
    rdfs:label 'Entry Status' ;
    rdfs:comment 'Current workflow status of the field entry within the EDC system lifecycle. Drives data review, query management, and database lock (DBL) readiness assessments. [ENUM-REF-CANDIDATE: entered|modified|deleted|frozen|locked|sdv_complete — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entry Timestamp' ;
    rdfs:comment 'The date and time (with timezone) at which the field value was originally entered into the EDC system by the site user. Supports ALCOA+ contemporaneous data entry verification and audit trail analysis.' ;
    rdfs:domain ind:FieldEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:entryValue rdf:type rdf:Property ;
    rdfs:label 'Entry Value' ;
    rdfs:comment 'The actual data value entered into the eCRF field by the site user. Stored as STRING to accommodate all field types (numeric, text, date, coded). This is the primary clinical data payload and is classified as Protected Health Information (PHI) under HIPAA.' ;
    rdfs:domain ind:FieldEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hasOpenQuery rdf:type rdf:Property ;
    rdfs:label 'Has Open Query' ;
    rdfs:comment 'Indicates whether this field entry currently has at least one open data query (discrepancy) requiring resolution. Supports real-time data cleaning dashboards and DBL readiness tracking.' ;
    rdfs:domain ind:FieldEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFrozen rdf:type rdf:Property ;
    rdfs:label 'Is Frozen' ;
    rdfs:comment 'Indicates whether this field entry has been frozen, preventing further modification by site users. Freezing is a pre-lock step in the database lock (DBL) workflow to protect data integrity prior to statistical analysis.' ;
    rdfs:domain ind:FieldEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLocked rdf:type rdf:Property ;
    rdfs:label 'Is Locked' ;
    rdfs:comment 'Indicates whether this field entry has been locked as part of the Database Lock (DBL) process. Locked fields are immutable and represent the final, analysis-ready dataset. Supports ALCOA+ \'Enduring\' and \'Available\' principles.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMissing rdf:type rdf:Property ;
    rdfs:label 'Is Missing' ;
    rdfs:comment 'Indicates whether this field entry represents a missing data point (i.e., the field was expected but no value was entered or a missing reason code was provided). Supports data completeness reporting and ALCOA+ compliance tracking.' ;
    rdfs:domain ind:FieldEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Locked Timestamp' ;
    rdfs:comment 'The date and time at which this field entry was locked as part of the Database Lock (DBL) process. Null if the field has not yet been locked. Provides a precise audit record of the lock event for regulatory submissions.' ;
    rdfs:domain ind:FieldEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:medicalCodingStatus rdf:type rdf:Property ;
    rdfs:label 'Medical Coding Status' ;
    rdfs:comment 'The medical coding status for fields requiring standardized coding (e.g., adverse event terms coded to MedDRA, concomitant medications coded to WHO-DD). Tracks whether the verbatim term has been coded to a standard dictionary term.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:missingReasonCode rdf:type rdf:Property ;
    rdfs:label 'Missing Reason Code' ;
    rdfs:comment 'Standardized code explaining why a field value is missing (e.g., NOT_DONE, UNKNOWN, NA). Aligns with CDISC CDASH missing data handling conventions and supports statistical analysis plan (SAP) imputation strategies. [ENUM-REF-CANDIDATE: NOT_DONE|UNKNOWN|NA|NOT_APPLICABLE|TECHNICAL_FAILURE|SUBJECT_REFUSED — promote to reference product]' ;
    rdfs:domain ind:FieldEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'The username or system identifier of the EDC user who last modified this field entry. Null if the field has never been modified. Required for complete audit trail attribution under 21 CFR Part 11.' ;
    rdfs:domain ind:FieldEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raveRecordReference rdf:type rdf:Property ;
    rdfs:label 'Rave Record Reference' ;
    rdfs:comment 'The native record identifier assigned by Medidata Rave EDC to the parent data record (row) containing this field entry. Used for cross-referencing with the source EDC system and audit trail reconciliation.' ;
    rdfs:domain ind:FieldEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdvByUser rdf:type rdf:Property ;
    rdfs:label 'Sdv By User' ;
    rdfs:comment 'The username of the CRA or authorized reviewer who performed Source Data Verification (SDV) on this field entry. Satisfies ALCOA+ \'Attributable\' requirement for the verification action.' ;
    rdfs:domain ind:FieldEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationResult rdf:type rdf:Property ;
    rdfs:label 'Validation Result' ;
    rdfs:comment 'The outcome of the edit check or validation rule applied to this field entry at the time of data entry. A \'fail\' result triggers a data query. Supports data quality monitoring and DMP compliance.' ;
    rdfs:domain ind:FieldEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationId rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Id' ;
    rdfs:comment 'Unique surrogate identifier for each reconciliation activity record in the data management domain. Primary key for the reconciliation data product.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Reconciliation .

ind:accountabilityReconciliationId rdf:type rdf:Property ;
    rdfs:label 'Accountability Reconciliation Id' ;
    rdfs:comment 'Foreign key linking to supply.accountability_reconciliation. Business justification: Data managers reconcile EDC dispensing entries against IMP accountability records as a named GCP process. Linking data.reconciliation to supply.accountability_reconciliation formalizes the relationshi' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountabilityReconciliation .

ind:programMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Program Milestone Id' ;
    rdfs:comment 'Foreign key linking to program.program_milestone. Business justification: Database lock reconciliation completion is a named program milestone gate (DBL milestone). Linking reconciliation records to the program milestone they satisfy supports milestone evidence tracking, go' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgramMilestone .

ind:reconciliationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Employee Id' ;
    rdfs:comment 'Reference to the responsible data manager (DM) who owns and executes this reconciliation activity. Supports accountability tracking per ALCOA+ principles.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:capaReference rdf:type rdf:Property ;
    rdfs:label 'Capa Reference' ;
    rdfs:comment 'Reference identifier for any Corrective and Preventive Action (CAPA) initiated as a result of systemic discrepancies identified during this reconciliation. Links to the CAPA management system (MasterControl).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalDiscrepancyCount rdf:type rdf:Property ;
    rdfs:label 'Critical Discrepancy Count' ;
    rdfs:comment 'Number of discrepancies classified as critical (e.g., safety-impacting, primary endpoint data, regulatory submission data). Critical discrepancies require mandatory resolution before DBL.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dblRequired rdf:type rdf:Property ;
    rdfs:label 'Dbl Required' ;
    rdfs:comment 'Indicates whether this reconciliation is a mandatory prerequisite for Database Lock (DBL). When True, outstanding discrepancies must be resolved or formally waived before DBL can proceed.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyRatePct rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Rate Pct' ;
    rdfs:comment 'Percentage of records with at least one discrepancy relative to total records compared (discrepancy_count / total_records_compared * 100). Key quality KPI for data management performance reporting and study risk assessment.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationNotes rdf:type rdf:Property ;
    rdfs:label 'Escalation Notes' ;
    rdfs:comment 'Free-text description of the reason for escalation, including the nature of critical discrepancies, impacted data domains, and recommended corrective actions. Populated only when escalation_required is True.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'Cadence at which this type of reconciliation is performed for the study, as defined in the DMP. Drives scheduling and resource planning for data management activities.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingCount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Count' ;
    rdfs:comment 'Number of discrepancies that remain unresolved at the time of the reconciliation record. A non-zero value blocks DBL (Database Lock) unless formally justified and documented.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodEnd rdf:type rdf:Property ;
    rdfs:label 'Period End' ;
    rdfs:comment 'End date of the data window covered by this reconciliation activity. Defines the upper bound of the data extract or comparison period.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStart rdf:type rdf:Property ;
    rdfs:label 'Period Start' ;
    rdfs:comment 'Start date of the data window covered by this reconciliation activity. Defines the lower bound of the data extract or comparison period.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Planned Reconciliation Date' ;
    rdfs:comment 'Scheduled date for the reconciliation activity as defined in the Data Management Plan (DMP) or study timeline. Enables variance tracking between planned and actual reconciliation dates.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'The calendar date on which the reconciliation activity was formally executed. Principal business event date used for scheduling, DMP milestone tracking, and pre-DBL (Database Lock) compliance verification.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationMethod rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Method' ;
    rdfs:comment 'Approach used to perform the reconciliation — fully manual review, automated system comparison, or a hybrid semi-automated process. Informs quality risk assessment and resource planning.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationNumber rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the reconciliation activity, used in Data Management Plans (DMP), audit trails, and cross-system references. Typically formatted as REC-{StudyCode}-{Sequence}.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationScope rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Scope' ;
    rdfs:comment 'Granularity level at which the reconciliation is performed — whether it covers the full study, a specific site, individual subjects, a visit window, or a specific dataset. Determines the breadth of the reconciliation exercise.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Current lifecycle state of the reconciliation activity, from initiation through sign-off. Drives workflow progression and DBL (Database Lock) readiness gates.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationType rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Type' ;
    rdfs:comment 'Classification of the reconciliation activity by the category of external data source being reconciled against the EDC (Electronic Data Capture) system. Drives workflow routing and DMP compliance checks. [ENUM-REF-CANDIDATE: central_lab|safety_database|irt_rtsm|epro|external_vendor|edc_internal — promote to reference product if additional types are anticipated]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedCount rdf:type rdf:Property ;
    rdfs:label 'Resolved Count' ;
    rdfs:comment 'Number of discrepancies that have been investigated and resolved (closed) as of the reconciliation sign-off date. Used to assess reconciliation completeness.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signoffBy rdf:type rdf:Property ;
    rdfs:label 'Signoff By' ;
    rdfs:comment 'Name or user identifier of the individual who formally approved and signed off the reconciliation activity. Supports electronic signature audit trail per 21 CFR Part 11.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signoffStatus rdf:type rdf:Property ;
    rdfs:label 'Signoff Status' ;
    rdfs:comment 'Formal approval status of the reconciliation activity by the responsible data manager and/or study team. Approved sign-off is required before the reconciliation can be considered complete for DBL purposes.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Signoff Timestamp' ;
    rdfs:comment 'Date and time at which the reconciliation was formally signed off. Provides the precise audit timestamp for regulatory inspection readiness per 21 CFR Part 11.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceDataExtractTimestamp rdf:type rdf:Property ;
    rdfs:label 'Source Data Extract Timestamp' ;
    rdfs:comment 'Date and time at which the data extract was pulled from the source system for reconciliation purposes. Critical for ALCOA+ contemporaneity and audit trail integrity.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:targetDataExtractTimestamp rdf:type rdf:Property ;
    rdfs:label 'Target Data Extract Timestamp' ;
    rdfs:comment 'Date and time at which the data extract was pulled from the target system for reconciliation comparison. Paired with source_data_extract_timestamp to establish the comparison window.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tool rdf:type rdf:Property ;
    rdfs:label 'Tool' ;
    rdfs:comment 'Name of the software tool or system used to perform the reconciliation (e.g., Medidata Rave, SAS macro, custom script, Oracle Clinical One). Supports audit trail and reproducibility documentation.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRecordsCompared rdf:type rdf:Property ;
    rdfs:label 'Total Records Compared' ;
    rdfs:comment 'Total count of data records (e.g., subject visits, lab results, AE entries) included in the reconciliation comparison between source and target systems. Denominator for discrepancy rate calculations.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version number of the reconciliation activity, incremented when a reconciliation is re-executed (e.g., after additional data is received or discrepancies are resolved). Supports iterative reconciliation tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waivedCount rdf:type rdf:Property ;
    rdfs:label 'Waived Count' ;
    rdfs:comment 'Number of discrepancies formally waived with documented justification (e.g., clinically insignificant, data not required for analysis). Supports transparent DBL decision-making.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySdtmEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sdtm Employee Id' ;
    rdfs:comment 'Reference to the SAS/statistical programmer responsible for generating and maintaining this SDTM dataset. Supports accountability and ALCOA+ traceability.' ;
    rdfs:domain ind:SdtmDataset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:regulatoryBinderId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Binder Id' ;
    rdfs:comment 'Foreign key linking to document.regulatory_binder. Business justification: SDTM datasets are submitted as part of NDA/BLA regulatory submissions and are included in CTD Module 5 regulatory binders. This FK links each dataset to its submission package, enabling submission com' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryBinder .

ind:analysisPopulation rdf:type rdf:Property ;
    rdfs:label 'Analysis Population' ;
    rdfs:comment 'Clinical analysis population represented in this dataset where applicable (e.g., Intent-to-Treat (ITT), Per Protocol (PP), Safety Population, Full Analysis Set). Relevant for ADaM-linked SDTM datasets.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlledTerminologyVersion rdf:type rdf:Property ;
    rdfs:label 'Controlled Terminology Version' ;
    rdfs:comment 'Version of the CDISC Controlled Terminology package applied during dataset generation (e.g., \'2023-09-29\'). Ensures consistent use of standardized code lists across the submission package.' ;
    rdfs:domain ind:SdtmDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:datasetStatus rdf:type rdf:Property ;
    rdfs:label 'Dataset Status' ;
    rdfs:comment 'Current lifecycle status of the SDTM dataset within the data management and submission workflow. Progresses from Draft through QC Complete, Frozen, Locked, and Submitted. Superseded indicates a prior version replaced by a newer submission. [ENUM-REF-CANDIDATE: Draft|In Review|QC Complete|Frozen|Locked|Submitted|Superseded — promote to reference product]' ;
    rdfs:domain ind:SdtmDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defineXmlReference rdf:type rdf:Property ;
    rdfs:label 'Define Xml Reference' ;
    rdfs:comment 'File path or URI reference to the define.xml document that describes the metadata for this SDTM dataset within the eCTD submission package. Enables direct navigation to the dataset metadata specification.' ;
    rdfs:domain ind:SdtmDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:domainClass rdf:type rdf:Property ;
    rdfs:label 'Domain Class' ;
    rdfs:comment 'CDISC SDTM observation class to which this dataset belongs. Classifies the dataset into one of the standard SDTM domain classes: Events (e.g., AE, DS), Interventions (e.g., CM, EX), Findings (e.g., LB, VS, EG), Special Purpose (e.g., DM, CO), Relationship (e.g., RELREC, SUPPQUAL), or Trial Design (e.g., TA, TE, TV).' ;
    rdfs:domain ind:SdtmDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generationDate rdf:type rdf:Property ;
    rdfs:label 'Generation Date' ;
    rdfs:comment 'Calendar date on which this SDTM dataset was generated from source EDC data. Used for audit trail and submission package dating per ALCOA+ contemporaneous principle.' ;
    rdfs:domain ind:SdtmDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:generationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Generation Timestamp' ;
    rdfs:comment 'Precise date and time at which the SDTM dataset was generated, including timezone offset. Supports ALCOA+ contemporaneous documentation and 21 CFR Part 11 audit trail requirements.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isSplitDataset rdf:type rdf:Property ;
    rdfs:label 'Is Split Dataset' ;
    rdfs:comment 'Indicates whether this dataset has been split into multiple physical files due to size constraints (e.g., LB domain split by lab panel). True = dataset is one part of a split; False = single complete dataset file.' ;
    rdfs:domain ind:SdtmDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSubmissionReady rdf:type rdf:Property ;
    rdfs:label 'Is Submission Ready' ;
    rdfs:comment 'Indicates whether this SDTM dataset has passed all QC checks, Pinnacle 21 validation, and internal review gates and is approved for inclusion in a regulatory submission package. True = ready for submission; False = not yet approved.' ;
    rdfs:domain ind:SdtmDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pinnacle21ErrorCount rdf:type rdf:Property ;
    rdfs:label 'Pinnacle21 Error Count' ;
    rdfs:comment 'Number of errors (severity: Error) identified during the Pinnacle 21 validation run. Errors must be resolved or formally justified before regulatory submission.' ;
    rdfs:domain ind:SdtmDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pinnacle21RunDate rdf:type rdf:Property ;
    rdfs:label 'Pinnacle21 Run Date' ;
    rdfs:comment 'Date on which the most recent Pinnacle 21 validation was executed against this dataset. Supports audit trail and ensures validation currency relative to dataset generation.' ;
    rdfs:domain ind:SdtmDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pinnacle21WarningCount rdf:type rdf:Property ;
    rdfs:label 'Pinnacle21 Warning Count' ;
    rdfs:comment 'Number of warnings identified during the Pinnacle 21 validation run. Warnings require documented justification in the Reviewer\'s Guide or ADRG if not resolved.' ;
    rdfs:domain ind:SdtmDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qcCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Qc Completion Date' ;
    rdfs:comment 'Date on which the QC review of this SDTM dataset was completed and signed off. Required for audit trail documentation per ALCOA+ and 21 CFR Part 11.' ;
    rdfs:domain ind:SdtmDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewerGuideReference rdf:type rdf:Property ;
    rdfs:label 'Reviewer Guide Reference' ;
    rdfs:comment 'File path or document reference to the Analysis Data Reviewer\'s Guide (ADRG) or Study Data Reviewer\'s Guide (SDRG) section that documents dataset-specific conventions, deviations, and reviewer instructions for this SDTM domain.' ;
    rdfs:domain ind:SdtmDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sasDatasetPath rdf:type rdf:Property ;
    rdfs:label 'Sas Dataset Path' ;
    rdfs:comment 'File system path or storage location of the SAS transport file (XPT format) for this SDTM dataset. FDA requires submission datasets in SAS Version 5 transport format (.xpt).' ;
    rdfs:domain ind:SdtmDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:splitSequence rdf:type rdf:Property ;
    rdfs:label 'Split Sequence' ;
    rdfs:comment 'Sequential number identifying the order of this file within a split dataset series (e.g., 1 for LB1, 2 for LB2). Null when is_split_dataset is False.' ;
    rdfs:domain ind:SdtmDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sponsorDatasetName rdf:type rdf:Property ;
    rdfs:label 'Sponsor Dataset Name' ;
    rdfs:comment 'Sponsor-specific internal name or alias for this dataset, which may differ from the standard CDISC domain abbreviation in cases of custom or extended domains. Used for internal tracking and sponsor communication.' ;
    rdfs:domain ind:SdtmDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectCount rdf:type rdf:Property ;
    rdfs:label 'Subject Count' ;
    rdfs:comment 'Number of unique study subjects (USUBJID) represented in this SDTM dataset. Supports population-level QC checks and reconciliation against the DM domain.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionVersion rdf:type rdf:Property ;
    rdfs:label 'Submission Version' ;
    rdfs:comment 'Version identifier for the regulatory submission package in which this dataset is included (e.g., \'v1.0\', \'v2.1\'). Tracks dataset evolution across multiple submission cycles for the same study.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppqualIncluded rdf:type rdf:Property ;
    rdfs:label 'Suppqual Included' ;
    rdfs:comment 'Indicates whether a supplemental qualifier dataset (SUPP--) accompanies this SDTM domain dataset to capture non-standard variables. True = a corresponding SUPP-- dataset exists; False = no supplemental dataset.' ;
    rdfs:domain ind:SdtmDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:variableCount rdf:type rdf:Property ;
    rdfs:label 'Variable Count' ;
    rdfs:comment 'Total number of variables (columns) in this SDTM dataset. Used for define.xml completeness verification and to ensure compliance with CDISC domain variable requirements.' ;
    rdfs:domain ind:SdtmDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:xptFileSizeKb rdf:type rdf:Property ;
    rdfs:label 'Xpt File Size Kb' ;
    rdfs:comment 'Size of the SAS transport (.xpt) file in kilobytes. Used for submission package size management and to flag datasets approaching the 5GB FDA file size limit.' ;
    rdfs:domain ind:SdtmDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sdtmMappingId rdf:type rdf:Property ;
    rdfs:label 'Sdtm Mapping Id' ;
    rdfs:comment 'Unique surrogate identifier for a single source-to-target SDTM variable mapping rule record within the Clinical Trials data management system. Entity role: TRANSACTION_LINE — this record represents one variable-level mapping line within a parent SDTM dataset specification.' ;
    rdfs:domain ind:SdtmMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programmerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Programmer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: SDTM mapping programmer accountability is required for regulatory submission packages; FDA reviewers expect attributable mapping specifications. responsible_programmer is a denormalized employee name ' ;
    rdfs:domain ind:SdtmMapping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sourceEcrfFieldId rdf:type rdf:Property ;
    rdfs:label 'Source Ecrf Field Id' ;
    rdfs:comment 'Foreign key linking to data.ecrf_field. Business justification: sdtm_mapping defines transformation rules from raw EDC eCRF fields to SDTM variables. source_field_name and source_field_label are denormalized references to the source eCRF field. Adding source_ecrf_' ;
    rdfs:domain ind:SdtmMapping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EcrfField .

ind:sourceEcrfFormId rdf:type rdf:Property ;
    rdfs:label 'Source Ecrf Form Id' ;
    rdfs:comment 'Foreign key linking to data.ecrf_form. Business justification: sdtm_mapping defines transformation rules from raw EDC eCRF fields to SDTM variables. source_form_name is a denormalized reference to the source eCRF form. Adding source_ecrf_form_id normalizes this r' ;
    rdfs:domain ind:SdtmMapping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EcrfForm .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when this mapping rule was formally approved and promoted to \'approved\' status by the authorized reviewer. Represents the principal business event timestamp for this mapping lifecycle transition. Required for 21 CFR Part 11 electronic signature audit trail.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:controlledTerminologyCodelist rdf:type rdf:Property ;
    rdfs:label 'Controlled Terminology Codelist' ;
    rdfs:comment 'Name of the CDISC Controlled Terminology code list applied to this SDTM variable (e.g., \'AESEV\', \'NCOMPLT\', \'SEX\', \'RACE\'). Null if no controlled terminology applies. Governs permissible values for the target variable in regulatory submissions.' ;
    rdfs:domain ind:SdtmMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctVersion rdf:type rdf:Property ;
    rdfs:label 'Ct Version' ;
    rdfs:comment 'Version of the CDISC Controlled Terminology package applied for this mapping (e.g., \'2023-09-29\'). Ensures reproducibility of coded values across transformation runs and regulatory submissions. Critical for FDA/EMA submission compliance.' ;
    rdfs:domain ind:SdtmMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defineXmlComment rdf:type rdf:Property ;
    rdfs:label 'Define Xml Comment' ;
    rdfs:comment 'Supplementary comment text to be included in the CDISC Define-XML v2.1 submission package for this variable. Provides additional context for FDA/EMA reviewers about the derivation logic, data source, or special handling. Appears in the define.xml ItemDef Comment attribute.' ;
    rdfs:domain ind:SdtmMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defineXmlOrigin rdf:type rdf:Property ;
    rdfs:label 'Define Xml Origin' ;
    rdfs:comment 'Origin attribute value for this variable as it will appear in the CDISC Define-XML v2.1 submission metadata. Indicates the source of the data: \'CRF\' (collected on eCRF), \'Derived\' (algorithmically derived), \'Assigned\' (assigned by sponsor/CRO), \'Protocol\' (defined in protocol), \'eDT\' (electronic data transfer), \'Predecessor\' (derived from prior SDTM variable).' ;
    rdfs:domain ind:SdtmMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:derivationType rdf:type rdf:Property ;
    rdfs:label 'Derivation Type' ;
    rdfs:comment 'Classification of the mapping derivation method: \'direct\' (verbatim copy from source), \'derived\' (computed from one or more source fields), \'assigned\' (constant or protocol-defined value), \'predecessor\' (derived from a previously mapped SDTM variable), \'computed\' (algorithmic calculation), \'coded\' (medical coding via MedDRA or WHO-DD lookup).' ;
    rdfs:domain ind:SdtmMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMultiSource rdf:type rdf:Property ;
    rdfs:label 'Is Multi Source' ;
    rdfs:comment 'Indicates whether this SDTM variable mapping requires data from more than one source field or form (True) or derives from a single source field (False). When True, the derivation_algorithm field documents all contributing source fields and the combination logic.' ;
    rdfs:domain ind:SdtmMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPredecessorRequired rdf:type rdf:Property ;
    rdfs:label 'Is Predecessor Required' ;
    rdfs:comment 'Indicates whether the predecessor variable dependency documented in predecessor_variable is a hard requirement (True) that must be resolved before this mapping executes, or an informational dependency (False). Governs transformation program execution sequencing.' ;
    rdfs:domain ind:SdtmMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSensitiveVariable rdf:type rdf:Property ;
    rdfs:label 'Is Sensitive Variable' ;
    rdfs:comment 'Indicates whether the target SDTM variable contains sensitive subject data requiring special handling under GDPR, HIPAA, or sponsor data privacy agreements (True). Examples include subject identifiers, dates of birth, and geographic data. Governs data masking and de-identification procedures in submission datasets.' ;
    rdfs:domain ind:SdtmMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mappingRuleCode rdf:type rdf:Property ;
    rdfs:label 'Mapping Rule Code' ;
    rdfs:comment 'Externally-known, human-readable unique code identifying this mapping rule within the study\'s SDTM mapping specification document. Follows the pattern MAP-{DOMAIN}-{VARIABLE}-{SEQUENCE}. Used in Data Management Plans (DMP) and CDISC submission packages.' ;
    rdfs:domain ind:SdtmMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mappingStatus rdf:type rdf:Property ;
    rdfs:label 'Mapping Status' ;
    rdfs:comment 'Current lifecycle state of this SDTM mapping rule. Controls which version is active for production CDISC transformation runs. \'approved\' rules are eligible for DBL and regulatory submission. [ENUM-REF-CANDIDATE: draft|in_review|approved|deprecated|superseded|on_hold — promote to reference product]' ;
    rdfs:domain ind:SdtmMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mappingVersion rdf:type rdf:Property ;
    rdfs:label 'Mapping Version' ;
    rdfs:comment 'Version number of this mapping rule in major.minor format (e.g., 1.0, 2.3). Incremented when the transformation logic, source field, or controlled terminology mapping changes. Supports version-controlled, auditable CDISC data transformation per ALCOA+ principles.' ;
    rdfs:domain ind:SdtmMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmVariableCore rdf:type rdf:Property ;
    rdfs:label 'Sdtm Variable Core' ;
    rdfs:comment 'CDISC core designation indicating whether the target SDTM variable is Required (Req), Expected (Exp), or Permissible (Perm) for the domain. Required variables must be populated; Expected variables should be populated when data is collected; Permissible variables are optional.' ;
    rdfs:domain ind:SdtmMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmVariableLabel rdf:type rdf:Property ;
    rdfs:label 'Sdtm Variable Label' ;
    rdfs:comment 'Human-readable descriptive label for the target SDTM variable as defined in the CDISC SDTM Implementation Guide (e.g., \'Dictionary-Derived Term\', \'Numeric Result/Finding in Standard Units\'). Used in SAS dataset metadata and regulatory submission define.xml.' ;
    rdfs:domain ind:SdtmMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmVariableName rdf:type rdf:Property ;
    rdfs:label 'Sdtm Variable Name' ;
    rdfs:comment 'Name of the target CDISC SDTM variable within the specified domain (e.g., AEDECOD, LBSTRESN, VSORRES). Must conform to CDISC SDTM naming conventions: uppercase, 2–8 characters, domain prefix for most variables. This is the column name in the final SDTM dataset submitted to regulatory agencies.' ;
    rdfs:domain ind:SdtmMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmVariableRole rdf:type rdf:Property ;
    rdfs:label 'Sdtm Variable Role' ;
    rdfs:comment 'CDISC-defined role of the target SDTM variable within its domain class (Identifier, Topic, Qualifier, Timing, Rule). Determines how the variable functions within the SDTM dataset structure and governs its position and usage in regulatory submissions.' ;
    rdfs:domain ind:SdtmMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmVariableType rdf:type rdf:Property ;
    rdfs:label 'Sdtm Variable Type' ;
    rdfs:comment 'CDISC-defined data type of the target SDTM variable. \'Char\' for character/text variables and \'Num\' for numeric variables, as specified in the SDTM Implementation Guide and define.xml metadata. Governs SAS dataset column type in regulatory submissions.' ;
    rdfs:domain ind:SdtmMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDatasetName rdf:type rdf:Property ;
    rdfs:label 'Source Dataset Name' ;
    rdfs:comment 'Name of the raw/staging dataset (SAS dataset or EDC extract table) that contains the source field prior to SDTM transformation (e.g., \'RAW_AE\', \'RAW_VS\'). Used in SAS Drug Development transformation programs to identify the input dataset for each mapping rule.' ;
    rdfs:domain ind:SdtmMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppqualFlag rdf:type rdf:Property ;
    rdfs:label 'Suppqual Flag' ;
    rdfs:comment 'Indicates whether this variable is mapped to a CDISC SDTM Supplemental Qualifier (SUPP--) dataset rather than the parent domain dataset (True). SUPPQUAL datasets hold non-standard variables that cannot be accommodated in the standard domain structure.' ;
    rdfs:domain ind:SdtmMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suppqualQnam rdf:type rdf:Property ;
    rdfs:label 'Suppqual Qnam' ;
    rdfs:comment 'Short variable name (QNAM) used in the SUPPQUAL dataset for this non-standard variable. Populated only when suppqual_flag is True. Must be uppercase, 1–8 characters, and unique within the SUPPQUAL dataset for the domain.' ;
    rdfs:domain ind:SdtmMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationErrorCode rdf:type rdf:Property ;
    rdfs:label 'Validation Error Code' ;
    rdfs:comment 'Pinnacle 21 / CDISC conformance rule error or warning code associated with the most recent validation failure for this mapping (e.g., \'SD0083\', \'SD0006\'). Null when validation_status is \'passed\' or \'not_validated\'. Supports targeted remediation by the CDISC programmer.' ;
    rdfs:domain ind:SdtmMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdvPerformedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sdv Performed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Source Data Verification is a core GCP regulatory activity; monitoring reports and TMF filings require identifying which CRA employee performed SDV for each visit. sdv_performed_by is a denormalized e' ;
    rdfs:domain ind:SubjectVisitData ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:studyVisitScheduleId rdf:type rdf:Property ;
    rdfs:label 'Study Visit Schedule Id' ;
    rdfs:comment 'Foreign key linking to study.study_visit_schedule. Business justification: Protocol deviation detection and data completeness monitoring: linking actual subject visit data records to the protocol-defined visit schedule entry enables automated identification of missing visits' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudyVisitSchedule .

ind:alcoaCompliant rdf:type rdf:Property ;
    rdfs:label 'Alcoa Compliant' ;
    rdfs:comment 'Indicates whether this subject visit data record meets all ALCOA+ data quality principles (Attributable, Legible, Contemporaneous, Original, Accurate, plus Complete, Consistent, Enduring, Available). True = fully compliant; False = one or more ALCOA+ criteria not met.' ;
    rdfs:domain ind:SubjectVisitData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdiscSdtmDomain rdf:type rdf:Property ;
    rdfs:label 'Cdisc Sdtm Domain' ;
    rdfs:comment 'The CDISC SDTM domain code to which this eCRF form maps (e.g., \'DM\' for Demographics, \'VS\' for Vital Signs, \'AE\' for Adverse Events, \'LB\' for Laboratory). Used to drive SDTM transformation and regulatory submission packaging in SAS Drug Development.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Current lifecycle state of the eCRF form in Medidata Rave. Reflects the data entry and review workflow: incomplete (data entry in progress), complete (all required fields entered), frozen (data frozen pending review), locked (data locked post-database lock), signed (investigator signature applied). This is the primary lifecycle status for this transactional entity.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCompletenessPct rdf:type rdf:Property ;
    rdfs:label 'Data Completeness Pct' ;
    rdfs:comment 'The percentage of required eCRF fields that have been populated for this subject visit form, calculated as (completed fields / total required fields) × 100. Key metric for data quality monitoring and site performance KPIs. Range: 0.00 to 100.00.' ;
    rdfs:domain ind:SubjectVisitData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataEntryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Entry Timestamp' ;
    rdfs:comment 'The date and time when data was first entered into this eCRF form in Medidata Rave. Represents the ALCOA+ \'Contemporaneous\' requirement — data must be recorded at the time of the observation. This is the record creation audit timestamp.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Data Review Status' ;
    rdfs:comment 'Current status of the medical/data management review of this subject visit form. Tracks the review workflow from initial data entry through medical monitor approval. Values: not_started, in_review, reviewed, approved, requires_correction.' ;
    rdfs:domain ind:SubjectVisitData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enteredBy rdf:type rdf:Property ;
    rdfs:label 'Entered By' ;
    rdfs:comment 'The username of the Clinical Research Coordinator (CRC) or site staff member who initially entered data into this eCRF form in Medidata Rave. Satisfies ALCOA+ \'Attributable\' requirement — data must be traceable to the person who recorded it.' ;
    rdfs:domain ind:SubjectVisitData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freezeStatus rdf:type rdf:Property ;
    rdfs:label 'Freeze Status' ;
    rdfs:comment 'Indicates whether this subject visit form has been frozen in Medidata Rave (True = frozen; False = not frozen). Freezing is a pre-lock step that prevents further data entry while allowing review. Distinct from lock_status.' ;
    rdfs:domain ind:Data ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freezeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Freeze Timestamp' ;
    rdfs:comment 'The date and time when this subject visit form was frozen in Medidata Rave. Null if the form has not been frozen. Supports the pre-database lock workflow audit trail.' ;
    rdfs:domain ind:SubjectVisitData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:investigatorSignatureStatus rdf:type rdf:Property ;
    rdfs:label 'Investigator Signature Status' ;
    rdfs:comment 'Status of the Principal Investigator (PI) or sub-investigator electronic signature on this eCRF form. Required for regulatory compliance under 21 CFR Part 11 and ICH E6(R2). Values: not_required, pending, signed, rejected.' ;
    rdfs:domain ind:SubjectVisitData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigatorSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Investigator Signature Timestamp' ;
    rdfs:comment 'The date and time when the Principal Investigator (PI) or sub-investigator applied their electronic signature to this eCRF form. Null if not yet signed. Required for 21 CFR Part 11 audit trail.' ;
    rdfs:domain ind:SubjectVisitData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'The username of the user who most recently modified this eCRF form record in Medidata Rave. Supports ALCOA+ \'Attributable\' requirement for all data changes.' ;
    rdfs:domain ind:SubjectVisitData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockedBy rdf:type rdf:Property ;
    rdfs:label 'Locked By' ;
    rdfs:comment 'The username of the data management user who applied the lock to this subject visit form in Medidata Rave. Required for 21 CFR Part 11 electronic records audit trail.' ;
    rdfs:domain ind:SubjectVisitData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:missingDataFlag rdf:type rdf:Property ;
    rdfs:label 'Missing Data Flag' ;
    rdfs:comment 'Indicates whether one or more required data fields are missing or unanswered on this eCRF form for the subject visit. True = missing data present; False = all required fields populated. Supports ALCOA+ compliance tracking.' ;
    rdfs:domain ind:SubjectVisitData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:missingFieldCount rdf:type rdf:Property ;
    rdfs:label 'Missing Field Count' ;
    rdfs:comment 'The number of required eCRF fields that are currently unanswered or missing for this subject visit form. Provides granular data completeness tracking beyond the binary missing_data_flag.' ;
    rdfs:domain ind:SubjectVisitData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openQueryCount rdf:type rdf:Property ;
    rdfs:label 'Open Query Count' ;
    rdfs:comment 'The number of currently open data queries (discrepancies) raised against this subject visit form in Medidata Rave. Used to track data cleaning progress and site responsiveness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:protocolDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Protocol Deviation Flag' ;
    rdfs:comment 'Indicates whether a protocol deviation has been identified in association with this subject visit data record (True = deviation present; False = no deviation). Supports compliance monitoring and regulatory reporting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ravePageRepeatKey rdf:type rdf:Property ;
    rdfs:label 'Rave Page Repeat Key' ;
    rdfs:comment 'The repeat sequence key for repeating forms (log pages) in Medidata Rave, used when a subject has multiple instances of the same form within a single visit (e.g., multiple adverse event entries). Value is 1 for non-repeating forms.' ;
    rdfs:domain ind:SubjectVisitData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subjectNumber rdf:type rdf:Property ;
    rdfs:label 'Subject Number' ;
    rdfs:comment 'The externally-known alphanumeric identifier assigned to the subject within the study (e.g., site-subject number such as \'001-0042\'). Used in eCRF, regulatory submissions, and CDISC SDTM USUBJID derivation. Directly identifies a trial participant.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalQueryCount rdf:type rdf:Property ;
    rdfs:label 'Total Query Count' ;
    rdfs:comment 'The total number of data queries (discrepancies) ever raised against this subject visit form, including open, answered, and closed queries. Supports data quality trend analysis.' ;
    rdfs:domain ind:SubjectVisitData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visitDate rdf:type rdf:Property ;
    rdfs:label 'Visit Date' ;
    rdfs:comment 'The actual calendar date on which the subject attended the study visit and clinical data was collected. Represents the principal real-world event date. Maps to SVSTDTC in CDISC SDTM.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:visitNumber rdf:type rdf:Property ;
    rdfs:label 'Visit Number' ;
    rdfs:comment 'The sequential numeric identifier of the study visit as defined in the protocol schedule of assessments. Maps to VISITNUM in CDISC SDTM. Used for ordering and analysis.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitType rdf:type rdf:Property ;
    rdfs:label 'Visit Type' ;
    rdfs:comment 'Classification of the visit as defined in the protocol (e.g., scheduled per protocol, unscheduled/ad hoc, early termination, follow-up, telephone contact). Drives protocol deviation detection and data completeness expectations.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Visit Window End Date' ;
    rdfs:comment 'The latest acceptable calendar date for this protocol-defined visit per the study schedule of assessments. Used to assess whether the visit occurred within the protocol-specified window.' ;
    rdfs:domain ind:SubjectVisitData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:visitWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Visit Window Start Date' ;
    rdfs:comment 'The earliest acceptable calendar date for this protocol-defined visit per the study schedule of assessments. Used to assess whether the visit occurred within the protocol-specified window.' ;
    rdfs:domain ind:SubjectVisitData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:visitWithinWindow rdf:type rdf:Property ;
    rdfs:label 'Visit Within Window' ;
    rdfs:comment 'Indicates whether the actual visit date falls within the protocol-defined visit window (visit_window_start_date to visit_window_end_date). True = within window; False = outside window (potential protocol deviation).' ;
    rdfs:domain ind:SubjectVisitData ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referenceRangeId rdf:type rdf:Property ;
    rdfs:label 'Reference Range Id' ;
    rdfs:comment 'Foreign key linking to laboratory.reference_range. Business justification: EDC range-check validation rules must be derived from and linked to the lab facility\'s reference ranges to ensure consistency. Data management plans require that EDC edit check thresholds match the ce' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReferenceRange .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'The date on which this validation rule was activated (deployed to production) in Medidata Rave EDC. Marks the start of the rule\'s operational period. Used for change control documentation and audit trail.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appliesToAllSites rdf:type rdf:Property ;
    rdfs:label 'Applies To All Sites' ;
    rdfs:comment 'Indicates whether this validation rule applies globally to all investigative sites in the study (True) or is restricted to specific sites (False). Site-specific rules may reflect local regulatory requirements or country-specific data collection differences.' ;
    rdfs:domain ind:ValidationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdiscVariable rdf:type rdf:Property ;
    rdfs:label 'Cdisc Variable' ;
    rdfs:comment 'The CDISC SDTM or CDASH variable name that this validation rule maps to (e.g., AESTDTC, VSVAL, CMTRT). Enables traceability from the edit check to the CDISC submission variable for regulatory compliance and SDTM transformation validation.' ;
    rdfs:domain ind:ValidationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryApplicability rdf:type rdf:Property ;
    rdfs:label 'Country Applicability' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes (e.g., USA,GBR,DEU) indicating the countries where this validation rule applies. Null if the rule applies globally. Supports country-specific regulatory compliance (FDA, EMA, PMDA, MHRA, TGA, Health Canada).' ;
    rdfs:domain ind:ValidationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'The date on which this validation rule was deactivated or retired in Medidata Rave EDC. Null if the rule is currently active. Required for version history tracking and regulatory audit trail per 21 CFR Part 11.' ;
    rdfs:domain ind:ValidationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:generatesQuery rdf:type rdf:Property ;
    rdfs:label 'Generates Query' ;
    rdfs:comment 'Indicates whether this validation rule automatically generates a data query (discrepancy) in Medidata Rave when triggered (True) or only performs a silent validation without raising a query (False). Drives query management workflow volume.' ;
    rdfs:domain ind:ValidationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCdiscCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Cdisc Compliant' ;
    rdfs:comment 'Indicates whether this validation rule has been verified as compliant with CDISC CDASH/SDTM data standards. True = rule aligns with CDISC requirements; False = rule is study-specific or non-standard. Used in regulatory submission readiness assessments.' ;
    rdfs:domain ind:ValidationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousVersion rdf:type rdf:Property ;
    rdfs:label 'Previous Version' ;
    rdfs:comment 'Version identifier of the immediately preceding version of this validation rule, enabling version chain traceability. Supports audit trail reconstruction and change impact analysis per 21 CFR Part 11.' ;
    rdfs:domain ind:ValidationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raveEditCheckReference rdf:type rdf:Property ;
    rdfs:label 'Rave Edit Check Reference' ;
    rdfs:comment 'The native edit check identifier as assigned by Medidata Rave EDC (source system key). Enables direct traceability back to the source system record for reconciliation, UAT, and system integration purposes.' ;
    rdfs:domain ind:ValidationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCategory rdf:type rdf:Property ;
    rdfs:label 'Rule Category' ;
    rdfs:comment 'Classification of the validation rule by its logical type: range_check (numeric bounds), cross_form (inter-form consistency), date_logic (temporal relationships), required_field (mandatory data presence), consistency_check (intra-form logic), coding_check (MedDRA/WHO-DD coding validation). [ENUM-REF-CANDIDATE: range_check|cross_form|date_logic|required_field|consistency_check|coding_check|derived_field|format_check — promote to reference product]' ;
    rdfs:domain ind:ValidationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to the validation rule within the EDC system (e.g., EC_AESTDT_001). Used as the business identifier for cross-referencing in DMP, SAP, and audit documentation.' ;
    rdfs:domain ind:ValidationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Detailed narrative description of the validation rule\'s business purpose, the data quality condition it enforces, and the expected corrective action when triggered. Supports DMP documentation and regulatory audit readiness.' ;
    rdfs:domain ind:ValidationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleExpression rdf:type rdf:Property ;
    rdfs:label 'Rule Expression' ;
    rdfs:comment 'The programmatic logic or expression defining the edit check condition as coded in Medidata Rave (e.g., OpenRave expression syntax or Rave Edit Check language). Captures the exact computational rule used to evaluate data validity.' ;
    rdfs:domain ind:ValidationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name or short title of the validation rule as configured in Medidata Rave EDC (e.g., \'AE Start Date Cannot Be After End Date\'). Used for display in query management and DMP documentation.' ;
    rdfs:domain ind:ValidationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the validation rule in Medidata Rave EDC: draft (in development, not yet deployed), active (deployed and executing), inactive (temporarily disabled), retired (permanently decommissioned), under_review (pending change control review). Governs whether the rule fires during data entry.' ;
    rdfs:domain ind:ValidationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Classifies the technical implementation type of the validation rule in Medidata Rave: edit_check (standard Rave edit check), derivation (computed/derived field rule), custom_function (OpenRave custom function), system_check (system-level validation). Determines the execution engine and maintenance approach.' ;
    rdfs:domain ind:ValidationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleVersion rdf:type rdf:Property ;
    rdfs:label 'Rule Version' ;
    rdfs:comment 'Version identifier of the validation rule following semantic versioning (e.g., 1.0, 1.1, 2.0). Tracks the change history of the rule expression, severity, or configuration. Required for 21 CFR Part 11 audit trail and change control compliance.' ;
    rdfs:domain ind:ValidationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Severity classification of the validation rule determining how the EDC system responds when the rule fires: error (blocks data entry/save), warning (alerts user but allows save), informational (advisory only). Governs automated query generation behavior in Medidata Rave.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerCondition rdf:type rdf:Property ;
    rdfs:label 'Trigger Condition' ;
    rdfs:comment 'The EDC system event that causes this validation rule to execute: on_save (when the eCRF page is saved), on_entry (during data entry), on_change (when a field value changes), on_activation (when a form is activated), on_signature (at electronic signature), batch (scheduled batch execution). Determines when automated queries are raised.' ;
    rdfs:domain ind:ValidationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uatStatus rdf:type rdf:Property ;
    rdfs:label 'Uat Status' ;
    rdfs:comment 'Current User Acceptance Testing (UAT) status of this validation rule: not_started, in_progress, passed, failed, waived. UAT must be completed before a rule can be activated in production per GCP and 21 CFR Part 11 validation requirements.' ;
    rdfs:domain ind:ValidationRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archivalRecordId rdf:type rdf:Property ;
    rdfs:label 'Archival Record Id' ;
    rdfs:comment 'Unique system-generated identifier for each archival record entry tracking the disposition of a TMF document or study file at study close-out.' ;
    rdfs:domain ind:ArchivalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:archivalAuthorizedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Archival Authorized By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Archival authorization must be traceable to a qualified employee under ICH E6 and 21 CFR Part 11 — inspectors verify authorization authority. Replaces denormalized \'archival_authorized_by\' text with a' ;
    rdfs:domain ind:ArchivalRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tmfArtifactId rdf:type rdf:Property ;
    rdfs:label 'Tmf Artifact Id' ;
    rdfs:comment 'Foreign key linking to document.tmf_artifact. Business justification: Archival records reference the DIA TMF Reference Model artifact classification for retention period determination and regulatory compliance. tmf_reference_model_artifact (STRING) is a denormalized ref' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TmfArtifact .

ind:archivalDate rdf:type rdf:Property ;
    rdfs:label 'Archival Date' ;
    rdfs:comment 'The date on which the document or study file was formally transferred to the archive. This is the principal business event date for the archival transaction, distinct from the record creation timestamp.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:archivalLocation rdf:type rdf:Property ;
    rdfs:label 'Archival Location' ;
    rdfs:comment 'Physical or electronic location where the archived document is stored. For physical archives, this includes the facility name, building, room, shelf, and box reference. For electronic archives, this includes the system name and repository path (e.g., Veeva Vault long-term archive vault name).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archivalNotes rdf:type rdf:Property ;
    rdfs:label 'Archival Notes' ;
    rdfs:comment 'Free-text field for recording additional context, exceptions, or special instructions related to the archival record (e.g., partial document archival, known deviations from standard archival procedures, special handling instructions).' ;
    rdfs:domain ind:ArchivalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archivalStatus rdf:type rdf:Property ;
    rdfs:label 'Archival Status' ;
    rdfs:comment 'Current lifecycle status of the archival record. \'pending\' = awaiting archival; \'archived\' = successfully archived; \'retrieved\' = temporarily retrieved from archive; \'destroyed\' = permanently destroyed per retention schedule; \'on_hold\' = destruction or retrieval suspended (e.g., litigation hold).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archivalType rdf:type rdf:Property ;
    rdfs:label 'Archival Type' ;
    rdfs:comment 'Indicates whether the document is archived electronically (eTMF/long-term electronic archive), physically (paper-based archive facility), or as a hybrid (both electronic and physical copies retained).' ;
    rdfs:domain ind:ArchivalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveFacilityName rdf:type rdf:Property ;
    rdfs:label 'Archive Facility Name' ;
    rdfs:comment 'Name of the physical or electronic archive facility or vendor responsible for storing the archived documents (e.g., Iron Mountain, sponsor internal archive, Veeva Vault long-term archive). Supports vendor management and retrieval logistics.' ;
    rdfs:domain ind:ArchivalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Archive Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the archived document or file by the archive facility or eTMF system (e.g., Veeva Vault document ID or physical archive box/folder reference). Used for retrieval and audit trail purposes.' ;
    rdfs:domain ind:ArchivalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianName rdf:type rdf:Property ;
    rdfs:label 'Custodian Name' ;
    rdfs:comment 'Name of the organization or individual currently responsible for the custody and safekeeping of the archived documents (e.g., sponsor name, CRO name, third-party archive vendor). Supports accountability and retrieval logistics.' ;
    rdfs:domain ind:ArchivalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodyTransferDate rdf:type rdf:Property ;
    rdfs:label 'Custody Transfer Date' ;
    rdfs:comment 'Date on which formal custody of the archived documents was transferred to the sponsor or designated archive custodian. Null if transfer has not occurred. Supports chain of custody documentation.' ;
    rdfs:domain ind:ArchivalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:databaseLockDate rdf:type rdf:Property ;
    rdfs:label 'Database Lock Date' ;
    rdfs:comment 'The date on which the clinical database was locked for the study, which may serve as the reference date for calculating retention periods for certain document categories per sponsor SOPs.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:destructionAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Destruction Authorization Number' ;
    rdfs:comment 'Unique reference number of the formal destruction authorization document or approval record that sanctioned the permanent destruction of the archived file. Provides the audit trail required by GCP and regulatory agencies.' ;
    rdfs:domain ind:ArchivalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionAuthorizedBy rdf:type rdf:Property ;
    rdfs:label 'Destruction Authorized By' ;
    rdfs:comment 'Name or identifier of the authorized individual (e.g., sponsor representative, QA director) who formally approved the destruction of the archived document. Required for GCP compliance and regulatory inspection readiness.' ;
    rdfs:domain ind:ArchivalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionDate rdf:type rdf:Property ;
    rdfs:label 'Destruction Date' ;
    rdfs:comment 'The actual date on which the archived document was permanently destroyed following expiry of the retention period and completion of the destruction authorization process. Null if document has not been destroyed.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:destructionMethod rdf:type rdf:Property ;
    rdfs:label 'Destruction Method' ;
    rdfs:comment 'The method used to permanently destroy the archived document upon expiry of the retention period (e.g., shredding for physical documents, secure digital deletion or degaussing for electronic records). Required for GCP compliance audit trail.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentClassification rdf:type rdf:Property ;
    rdfs:label 'Document Classification' ;
    rdfs:comment 'Classification of the archived document per ICH GCP essential document categories (e.g., essential document, non-essential, regulatory submission document, site file, sponsor file). Determines applicable retention requirements.' ;
    rdfs:domain ind:ArchivalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTitle rdf:type rdf:Property ;
    rdfs:label 'Document Title' ;
    rdfs:comment 'Human-readable title or name of the document or study file being archived, as recorded in the eTMF (Veeva Vault) or physical archive index.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etmfVaultDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Etmf Vault Document Reference' ;
    rdfs:comment 'The unique document identifier assigned by Veeva Vault eTMF to the archived document. Enables direct traceability between the archival record in the lakehouse and the source document in the operational eTMF system.' ;
    rdfs:domain ind:ArchivalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:litigationHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Litigation Hold Flag' ;
    rdfs:comment 'Indicates whether a litigation hold (legal hold) has been placed on this archived document, preventing destruction regardless of retention expiry. True = document is under legal hold; False = no hold in effect.' ;
    rdfs:domain ind:ArchivalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retentionBasis rdf:type rdf:Property ;
    rdfs:label 'Retention Basis' ;
    rdfs:comment 'The regulatory or contractual basis that determines the retention period for this document. [ENUM-REF-CANDIDATE: ICH_GCP_15yr|FDA_21CFR_312.62|EMA_EU_CTR|sponsor_requirement|PMDA_requirement|MHRA_requirement|other — promote to reference product]' ;
    rdfs:domain ind:ArchivalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiry Date' ;
    rdfs:comment 'The calculated date on which the mandatory retention period expires and the document becomes eligible for destruction, based on the archival date plus the retention period. Drives destruction scheduling workflows.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'The required retention period in years for the archived document, as determined by the applicable regulatory requirement or sponsor policy (e.g., 15 years per ICH GCP, 2 years post-NDA approval per 21 CFR 312.62, or longer per sponsor requirement).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retrievalDate rdf:type rdf:Property ;
    rdfs:label 'Retrieval Date' ;
    rdfs:comment 'Actual date on which the archived document was physically or electronically retrieved from the archive. Null if not yet retrieved. Distinct from retrieval_request_date to track turnaround time.' ;
    rdfs:domain ind:ArchivalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retrievalReason rdf:type rdf:Property ;
    rdfs:label 'Retrieval Reason' ;
    rdfs:comment 'The business reason for retrieving the archived document from the archive (e.g., regulatory inspection, audit, litigation, study amendment, sponsor request). Supports access control and audit trail requirements.' ;
    rdfs:domain ind:ArchivalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retrievalRequestDate rdf:type rdf:Property ;
    rdfs:label 'Retrieval Request Date' ;
    rdfs:comment 'Date on which a formal request was made to retrieve the archived document from the archive facility. Null if no retrieval has been requested. Supports archive access tracking and SLA monitoring.' ;
    rdfs:domain ind:ArchivalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnToArchiveDate rdf:type rdf:Property ;
    rdfs:label 'Return To Archive Date' ;
    rdfs:comment 'Date on which a previously retrieved document was returned to the archive. Null if the document has not been retrieved or has not yet been returned. Ensures chain of custody integrity.' ;
    rdfs:domain ind:ArchivalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyCloseoutDate rdf:type rdf:Property ;
    rdfs:label 'Study Closeout Date' ;
    rdfs:comment 'The date on which the clinical study was formally closed out, triggering the archival obligations for TMF documents. Used to calculate retention period start dates and compliance deadlines.' ;
    rdfs:domain ind:ArchivalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tmfReferenceModelZone rdf:type rdf:Property ;
    rdfs:label 'Tmf Reference Model Zone' ;
    rdfs:comment 'The DIA TMF Reference Model zone classification of the archived document (e.g., Zone 01 - Trial Management, Zone 02 - Central Trial Documents, Zone 03 - Regulatory, Zone 04 - IRB/IEC, Zone 05 - Site Management). Supports inspection readiness and completeness assessment.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferOfCustodyFlag rdf:type rdf:Property ;
    rdfs:label 'Transfer Of Custody Flag' ;
    rdfs:comment 'Indicates whether custody of the archived documents has been formally transferred to the sponsor or a designated third-party archive (True) or remains with the CRO (False). Relevant for CRO-managed studies at close-out.' ;
    rdfs:domain ind:ArchivalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:binderDocumentId rdf:type rdf:Property ;
    rdfs:label 'Binder Document Id' ;
    rdfs:comment 'Unique surrogate identifier for each binder-document association record in the silver layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:BinderDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qcReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Qc Reviewer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory submission binder QC review requires traceable employee accountability — the reviewer\'s qualifications are verified during regulatory agency inspections. Replaces denormalized \'qc_reviewer\'' ;
    rdfs:domain ind:BinderDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:addedByUser rdf:type rdf:Property ;
    rdfs:label 'Added By User' ;
    rdfs:comment 'Username or system identifier of the Veeva Vault user who added this document to the binder. Required for 21 CFR Part 11 electronic records audit trail.' ;
    rdfs:domain ind:BinderDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addedDate rdf:type rdf:Property ;
    rdfs:label 'Added Date' ;
    rdfs:comment 'The calendar date on which this document version was formally added to the regulatory binder or eCTD sequence. Supports submission timeline tracking and ALCOA+ compliance.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Added Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone) when this document version was added to the binder, captured from Veeva Vault for audit trail and 21 CFR Part 11 compliance.' ;
    rdfs:domain ind:BinderDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'Username of the Veeva Vault user who granted final approval for this document\'s inclusion in the binder. Required for 21 CFR Part 11 electronic signature audit trail.' ;
    rdfs:domain ind:BinderDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctdSectionCode rdf:type rdf:Property ;
    rdfs:label 'Ctd Section Code' ;
    rdfs:comment 'The CTD module and section code designating where this document is placed within the eCTD structure (e.g., Module 1.2, Module 5.3.5.1). Aligns with ICH M4 CTD table of contents.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctdSectionTitle rdf:type rdf:Property ;
    rdfs:label 'Ctd Section Title' ;
    rdfs:comment 'Human-readable title of the CTD section corresponding to the ctd_section_code (e.g., \'Tabular Listing of All Clinical Studies\', \'Clinical Overview\'). Supports navigation and inspection readiness.' ;
    rdfs:domain ind:BinderDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Document Effective Date' ;
    rdfs:comment 'The effective date of the document version included in this binder, as recorded at the time of inclusion. Supports regulatory review of document currency and applicability.' ;
    rdfs:domain ind:BinderDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentRole rdf:type rdf:Property ;
    rdfs:label 'Document Role' ;
    rdfs:comment 'The operational role of this document within the binder or eCTD sequence lifecycle: original (first inclusion), replacement (supersedes prior version), withdrawal (removes prior document), amendment, or addendum.' ;
    rdfs:domain ind:BinderDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Document Version Number' ;
    rdfs:comment 'Version number of the document at the time it was included in the binder (e.g., v1.0, v2.3, FINAL). Captured as a denormalized field to support point-in-time submission traceability without requiring a join.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inclusionRationale rdf:type rdf:Property ;
    rdfs:label 'Inclusion Rationale' ;
    rdfs:comment 'Narrative explanation of why this specific document version was included in the binder or regulatory submission package. Supports regulatory justification and inspection readiness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inclusionType rdf:type rdf:Property ;
    rdfs:label 'Inclusion Type' ;
    rdfs:comment 'Classification of how the document is included in the binder: primary (core submission document), supporting (supplementary evidence), reference (cross-reference only), appendix, or cover (cover letter/page). [ENUM-REF-CANDIDATE: primary|supporting|reference|appendix|cover|amendment — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReadinessStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Readiness Status' ;
    rdfs:comment 'Assessment of whether this document\'s binder inclusion meets inspection readiness standards: ready (fully compliant), gap_identified (deficiency noted), remediation_in_progress (corrective action underway), or not_assessed. Supports regulatory inspection preparation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPlaceholder rdf:type rdf:Property ;
    rdfs:label 'Is Placeholder' ;
    rdfs:comment 'Indicates whether this binder-document entry is a placeholder (document expected but not yet filed). True = placeholder awaiting document; False = actual document filed. Supports eTMF completeness tracking and inspection readiness.' ;
    rdfs:domain ind:BinderDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placeholderDueDate rdf:type rdf:Property ;
    rdfs:label 'Placeholder Due Date' ;
    rdfs:comment 'Expected date by which the actual document must be filed to replace this placeholder entry. Applicable only when is_placeholder = True. Drives eTMF completeness alerts and inspection readiness dashboards.' ;
    rdfs:domain ind:BinderDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qcComments rdf:type rdf:Property ;
    rdfs:label 'Qc Comments' ;
    rdfs:comment 'Free-text comments entered by the QC reviewer regarding the document\'s inclusion, any findings, or justification for waiver. Supports audit trail and CAPA tracking.' ;
    rdfs:domain ind:BinderDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcReviewDate rdf:type rdf:Property ;
    rdfs:label 'Qc Review Date' ;
    rdfs:comment 'Date on which the QC review of this document\'s binder inclusion was completed. Used for inspection readiness reporting and submission timeline management.' ;
    rdfs:domain ind:BinderDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:redactionRequired rdf:type rdf:Property ;
    rdfs:label 'Redaction Required' ;
    rdfs:comment 'Indicates whether this document requires redaction of personally identifiable or commercially sensitive information before inclusion in a public or semi-public regulatory submission. True = redaction required; False = no redaction needed.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:removalReason rdf:type rdf:Property ;
    rdfs:label 'Removal Reason' ;
    rdfs:comment 'Narrative explanation for why this document was removed or withdrawn from the binder (e.g., superseded by updated version, filed in error, regulatory authority request). Required when removed_date is populated.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removedDate rdf:type rdf:Property ;
    rdfs:label 'Removed Date' ;
    rdfs:comment 'Date on which this document was formally removed or withdrawn from the binder. Null if the document remains active in the binder. Supports full lifecycle traceability.' ;
    rdfs:domain ind:BinderDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sequenceOrder rdf:type rdf:Property ;
    rdfs:label 'Sequence Order' ;
    rdfs:comment 'Numeric position of this document within the binder or eCTD section, defining the presentation order for regulatory reviewers and inspection readiness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Sequence Number' ;
    rdfs:comment 'The four-digit eCTD sequence number (e.g., 0000, 0001) identifying the specific regulatory submission sequence in which this document was included. Aligns with FDA and EMA eCTD technical specifications.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmfReferenceModelArtifact rdf:type rdf:Property ;
    rdfs:label 'Tmf Reference Model Artifact' ;
    rdfs:comment 'The specific DIA TMF Reference Model artifact identifier (e.g., 01.01.01 - Protocol) assigned to this document within the eTMF structure. Enables artifact-level completeness tracking.' ;
    rdfs:domain ind:BinderDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:translationRequired rdf:type rdf:Property ;
    rdfs:label 'Translation Required' ;
    rdfs:comment 'Indicates whether a translation of this document is required for the target regulatory authority\'s submission. True = translation required; False = no translation needed. Supports multi-regional submission planning.' ;
    rdfs:domain ind:BinderDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vaultBinderReference rdf:type rdf:Property ;
    rdfs:label 'Vault Binder Reference' ;
    rdfs:comment 'The native binder identifier assigned by Veeva Vault to the parent binder record. Enables reconciliation between the lakehouse silver layer and the Veeva Vault system of record.' ;
    rdfs:domain ind:BinderDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vaultDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Vault Document Reference' ;
    rdfs:comment 'The native document identifier assigned by Veeva Vault to the source document record. Enables direct traceability back to the system of record for audit and reconciliation purposes.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessLogId rdf:type rdf:Property ;
    rdfs:label 'Access Log Id' ;
    rdfs:comment 'Unique surrogate identifier for each document access event record in the audit trail. Primary key for the document_access_log table.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vaultDocumentVersionId rdf:type rdf:Property ;
    rdfs:label 'Vault Document Version Id' ;
    rdfs:comment 'The specific version identifier of the document in Veeva Vault that was accessed (e.g., 1.0, 2.1, DRAFT). Ensures the audit trail captures exactly which version was viewed, downloaded, or modified, supporting ALCOA+ traceability.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Version .

ind:accessAction rdf:type rdf:Property ;
    rdfs:label 'Access Action' ;
    rdfs:comment 'The type of action performed on the document during this access event. Enumerated values: view (read-only display), download (file retrieved to local device), print (document sent to printer), edit (document content modified), delete (document removed or marked for deletion). Critical for GCP inspection readiness and 21 CFR Part 11 audit trail completeness.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessChannel rdf:type rdf:Property ;
    rdfs:label 'Access Channel' ;
    rdfs:comment 'The interface or channel through which the document was accessed in Veeva Vault: web_browser (standard UI), vault_api (programmatic API access), mobile_app (Veeva Vault mobile), integration (system-to-system integration). Supports security monitoring and access pattern analysis.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessDeviceType rdf:type rdf:Property ;
    rdfs:label 'Access Device Type' ;
    rdfs:comment 'The category of device used to access the document (desktop, laptop, tablet, mobile, server). Supports security monitoring and access pattern analysis for GCP inspection readiness.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessJustification rdf:type rdf:Property ;
    rdfs:label 'Access Justification' ;
    rdfs:comment 'The business reason provided by the user for accessing a restricted or confidential document, as required by document confidentiality policy. Mandatory for restricted-level documents; optional for confidential. Supports GCP inspection readiness and ALCOA+ \'Attributable\' requirement.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessResult rdf:type rdf:Property ;
    rdfs:label 'Access Result' ;
    rdfs:comment 'The outcome of the access attempt: success (access granted and action completed), denied (access refused due to permissions), error (system error prevented completion), timeout (session expired before completion). Supports security monitoring and unauthorized access detection.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessTimestamp rdf:type rdf:Property ;
    rdfs:label 'Access Timestamp' ;
    rdfs:comment 'The exact date and time (with timezone) when the document access event occurred, as recorded by Veeva Vault. Satisfies the ALCOA+ \'Contemporaneous\' requirement and 21 CFR Part 11 audit trail timestamp mandate. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:anomalyReason rdf:type rdf:Property ;
    rdfs:label 'Anomaly Reason' ;
    rdfs:comment 'A description of why this access event was flagged as anomalous, populated when is_anomalous_access is True. Examples: \'Access outside business hours\', \'Bulk download detected\', \'Access from unrecognized IP\', \'Access to superseded document version\'. Null when not anomalous.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataExtractTimestamp rdf:type rdf:Property ;
    rdfs:label 'Data Extract Timestamp' ;
    rdfs:comment 'The timestamp when this audit record was extracted from Veeva Vault and loaded into the Databricks Silver Layer. Supports data lineage tracking and ETL reconciliation for the lakehouse pipeline.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:documentConfidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Document Confidentiality Level' ;
    rdfs:comment 'The data classification level of the document at the time of access. Determines whether an access justification is required (restricted and confidential documents require justification per policy). Aligns with the business data classification levels.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentName rdf:type rdf:Property ;
    rdfs:label 'Document Name' ;
    rdfs:comment 'The title or name of the controlled document at the time of access, captured as a denormalized snapshot. Ensures the audit record remains interpretable even if the document is renamed or archived.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStatusAtAccess rdf:type rdf:Property ;
    rdfs:label 'Document Status At Access' ;
    rdfs:comment 'The lifecycle status of the document at the exact moment of access. Captures whether the user accessed a draft, approved, superseded, or archived version, which is critical for GCP compliance and inspection readiness.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downloadFileFormat rdf:type rdf:Property ;
    rdfs:label 'Download File Format' ;
    rdfs:comment 'The file format in which the document was downloaded, applicable only when access_action is \'download\'. Null for non-download actions. Supports data leakage monitoring and controlled document distribution tracking.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionContext rdf:type rdf:Property ;
    rdfs:label 'Inspection Context' ;
    rdfs:comment 'Indicates whether this access event occurred in the context of a regulatory inspection (e.g., FDA, EMA, MHRA audit). True when the access was performed to support an active regulatory inspection. Enables inspection-specific access pattern reporting.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAnomalousAccess rdf:type rdf:Property ;
    rdfs:label 'Is Anomalous Access' ;
    rdfs:comment 'Indicates whether this access event has been flagged as anomalous by automated monitoring rules (e.g., access outside business hours, access from unusual IP, bulk download, access to superseded documents). Supports GCP compliance monitoring and inspection readiness.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:justificationProvided rdf:type rdf:Property ;
    rdfs:label 'Justification Provided' ;
    rdfs:comment 'Indicates whether the user actually provided an access justification when one was required. Used in conjunction with justification_required to identify compliance gaps where justification was mandated but not supplied.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:justificationRequired rdf:type rdf:Property ;
    rdfs:label 'Justification Required' ;
    rdfs:comment 'Indicates whether an access justification was required for this access event based on the document\'s confidentiality level and access action. True when justification was mandated by policy; False otherwise. Supports compliance gap detection.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:printCopyCount rdf:type rdf:Property ;
    rdfs:label 'Print Copy Count' ;
    rdfs:comment 'The number of copies printed during a print access event. Applicable only when access_action is \'print\'. Null for non-print actions. Supports controlled document print tracking per GCP requirements.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorAccessTimestamp rdf:type rdf:Property ;
    rdfs:label 'Prior Access Timestamp' ;
    rdfs:comment 'The timestamp of the immediately preceding access event by the same user on the same document version. Enables detection of unusual access frequency patterns and supports forensic audit analysis.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceIpAddress rdf:type rdf:Property ;
    rdfs:label 'Source Ip Address' ;
    rdfs:comment 'The IP address of the device from which the document access event originated. Required for 21 CFR Part 11 audit trail completeness and cybersecurity monitoring. May be considered PII under GDPR in some jurisdictions.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyProtocolNumber rdf:type rdf:Property ;
    rdfs:label 'Study Protocol Number' ;
    rdfs:comment 'The sponsor-assigned protocol number of the clinical study associated with the accessed document, captured as a denormalized snapshot. Enables direct audit trail readability without requiring a join to the study table.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmfSection rdf:type rdf:Property ;
    rdfs:label 'Tmf Section' ;
    rdfs:comment 'The specific section identifier within the TMF zone for the accessed document per the DIA TMF Reference Model (e.g., \'01.01 Trial Oversight\', \'03.01 Regulatory Approvals\'). Enables granular TMF access pattern analysis.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmfZone rdf:type rdf:Property ;
    rdfs:label 'Tmf Zone' ;
    rdfs:comment 'The TMF zone classification of the accessed document per the DIA TMF Reference Model (e.g., Zone 01 - Trial Management, Zone 02 - Central Trial Documents, Zone 03 - Regulatory, Zone 04 - IRB/IEC, Zone 05 - Site Management). Supports TMF completeness and inspection readiness reporting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userFullName rdf:type rdf:Property ;
    rdfs:label 'User Full Name' ;
    rdfs:comment 'The full name of the user who performed the access event at the time of the event. Captured as a denormalized field to preserve the audit record even if the user record changes, per ALCOA+ contemporaneous and enduring requirements.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userOrganization rdf:type rdf:Property ;
    rdfs:label 'User Organization' ;
    rdfs:comment 'The organization or company affiliation of the user at the time of access (e.g., sponsor name, CRO name, investigative site name). Supports multi-sponsor and multi-site access auditing.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vaultAuditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Vault Audit Trail Reference' ;
    rdfs:comment 'The native audit trail record identifier generated by Veeva Vault for this access event. Serves as the source system reference key enabling traceability back to the original immutable audit record in Veeva Vault for regulatory inspection purposes.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vaultSessionReference rdf:type rdf:Property ;
    rdfs:label 'Vault Session Reference' ;
    rdfs:comment 'The Veeva Vault session identifier associated with this access event. Enables correlation of multiple access events within a single user session for forensic audit analysis and inspection support.' ;
    rdfs:domain ind:AccessLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionId rdf:type rdf:Property ;
    rdfs:label 'Distribution Id' ;
    rdfs:comment 'Unique surrogate identifier for each document distribution record in the controlled distribution log.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Distributed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Document distribution accountability is a GCP audit trail requirement — the distributing employee must be identifiable for inspection. Replaces denormalized \'distributed_by\' text with an employee FK e' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acknowledgementDueDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Due Date' ;
    rdfs:comment 'The deadline by which the recipient must acknowledge receipt of the document, as defined by the distribution plan or SOP. Used to identify overdue acknowledgements and trigger escalation workflows.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgementMethod rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Method' ;
    rdfs:comment 'The mechanism by which the recipient acknowledged receipt of the document (e.g., electronic signature in Veeva Vault, email reply, physical signature on distribution log). Required for 21 CFR Part 11 compliance.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgementRequired rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Required' ;
    rdfs:comment 'Indicates whether the recipient is required to formally acknowledge receipt of the document. Mandatory for GCP-critical documents such as protocols, amendments, and Informed Consent Forms (ICFs). Drives overdue acknowledgement tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acknowledgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Timestamp' ;
    rdfs:comment 'Precise date and time at which the recipient\'s acknowledgement was recorded in the system. Supports 21 CFR Part 11 electronic signature and audit trail requirements.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:daysToAcknowledge rdf:type rdf:Property ;
    rdfs:label 'Days To Acknowledge' ;
    rdfs:comment 'The number of calendar days allowed from distribution date for the recipient to acknowledge receipt, as specified in the distribution plan or governing SOP. Drives due date calculation and KPI reporting.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionDate rdf:type rdf:Property ;
    rdfs:label 'Distribution Date' ;
    rdfs:comment 'The calendar date on which the document was formally distributed to the recipient. This is the principal business event date for the distribution record, used for GCP compliance timelines and inspection readiness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionMethod rdf:type rdf:Property ;
    rdfs:label 'Distribution Method' ;
    rdfs:comment 'The channel or mechanism used to distribute the document to the recipient (e.g., Veeva Vault system notification, email, physical courier, CTMS portal). Relevant for GCP-compliant controlled distribution audit trails.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionNumber rdf:type rdf:Property ;
    rdfs:label 'Distribution Number' ;
    rdfs:comment 'Externally-known unique business identifier for this distribution event, typically generated by the document management system (e.g., Veeva Vault). Used for audit trail references and regulatory inspection queries.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionScope rdf:type rdf:Property ;
    rdfs:label 'Distribution Scope' ;
    rdfs:comment 'The organizational scope of this distribution event, indicating whether the document was distributed globally, by country, to a specific site, department, or individual recipient.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Status' ;
    rdfs:comment 'Current lifecycle state of the document distribution record. Tracks progression from initiation through delivery and acknowledgement. Used for inspection readiness dashboards and overdue acknowledgement tracking.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Distribution Timestamp' ;
    rdfs:comment 'Precise date and time at which the document distribution was initiated or completed in the system (e.g., Veeva Vault notification sent). Supports 21 CFR Part 11 electronic audit trail requirements.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Controlled document number (e.g., SOP-0042, PROT-2024-001) as assigned by the document control system. Denormalized for audit trail completeness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientEmail rdf:type rdf:Property ;
    rdfs:label 'Recipient Email' ;
    rdfs:comment 'Email address of the document recipient at the time of distribution. Used for electronic distribution audit trail and follow-up communications. Classified as confidential PII.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientOrganizationType rdf:type rdf:Property ;
    rdfs:label 'Recipient Organization Type' ;
    rdfs:comment 'Classification of the recipient\'s organization type. Enables segmentation of distribution records by stakeholder category for compliance reporting and inspection readiness.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientRole rdf:type rdf:Property ;
    rdfs:label 'Recipient Role' ;
    rdfs:comment 'The functional role of the document recipient within the clinical trial (e.g., Principal Investigator (PI), Clinical Research Coordinator (CRC), Clinical Research Associate (CRA), Sponsor representative). Determines distribution obligations and acknowledgement requirements. [ENUM-REF-CANDIDATE: PI|CRC|CRA|Sponsor|IRB/IEC|Regulatory Authority|CRO Staff|Biostatistician|Data Manager|Other — promote to reference product]' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderDate rdf:type rdf:Property ;
    rdfs:label 'Reminder Date' ;
    rdfs:comment 'The date on which the most recent acknowledgement reminder was sent to the recipient. Null if no reminder has been sent.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reminderSent rdf:type rdf:Property ;
    rdfs:label 'Reminder Sent' ;
    rdfs:comment 'Indicates whether an acknowledgement reminder notification has been sent to the recipient for this distribution. Used to track follow-up actions for overdue acknowledgements.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tmfArtifactNumber rdf:type rdf:Property ;
    rdfs:label 'Tmf Artifact Number' ;
    rdfs:comment 'The DIA TMF Reference Model artifact number associated with the distributed document (e.g., 01.01.01 for Study Plan). Enables structured TMF completeness tracking and regulatory inspection readiness.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaVaultDistributionReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Distribution Reference' ;
    rdfs:comment 'The native distribution event identifier assigned by Veeva Vault for this distribution record. Supports reconciliation between the lakehouse silver layer and the Veeva Vault source system.' ;
    rdfs:domain ind:Distribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaVaultDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Document Reference' ;
    rdfs:comment 'The native document identifier assigned by Veeva Vault eTMF for the distributed document. Enables direct traceability back to the source system record for audit and inspection purposes.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Prepared By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: ICF preparation must be traceable to a qualified employee — IRBs and regulatory inspectors verify preparer qualifications and GCP training. Replaces denormalized \'prepared_by\' text with an employee FK' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByVersionDocumentIcfVersionId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Version Document Icf Version Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the newer ICF version that replaced this one. Enables version chain traceability for audit and inspection readiness.' ;
    rdfs:domain ind:DocumentIcfVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocumentIcfVersion .

ind:econsentPlatform rdf:type rdf:Property ;
    rdfs:label 'Econsent Platform' ;
    rdfs:comment 'The eConsent platform used to deliver this ICF version electronically (e.g., Clinpal, Medidata Rave, Oracle Clinical One). Null or \'paper\' if consent is obtained via traditional paper process.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icfType rdf:type rdf:Property ;
    rdfs:label 'Icf Type' ;
    rdfs:comment 'Categorizes the ICF document by its consent purpose: main_consent (primary study consent), assent (pediatric assent form), hipaa_authorization (HIPAA privacy authorization), optional_procedures (consent for optional study procedures), lar_consent (Legally Authorized Representative consent), short_form (short-form consent for non-English speakers). [ENUM-REF-CANDIDATE: main_consent|assent|hipaa_authorization|optional_procedures|lar_consent|short_form — promote to reference product]' ;
    rdfs:domain ind:DocumentIcfVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Irb Approval Date' ;
    rdfs:comment 'The date on which the IRB or IEC formally approved this ICF version for use. No subject may be consented using this version prior to this date.' ;
    rdfs:domain ind:DocumentIcfVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:irbExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Irb Expiry Date' ;
    rdfs:comment 'The date on which the IRB/IEC approval for this ICF version expires. After this date, the ICF version is no longer valid for obtaining new consents unless renewed.' ;
    rdfs:domain ind:DocumentIcfVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isInspectionReady rdf:type rdf:Property ;
    rdfs:label 'Is Inspection Ready' ;
    rdfs:comment 'Indicates whether this ICF version record and its associated Vault document are confirmed as inspection-ready (complete, filed, and verified). Used for regulatory inspection preparedness tracking.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:protocolVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Protocol Version Number' ;
    rdfs:comment 'The protocol version number (e.g., \'3.0\', \'Amendment 2\') that this ICF version is aligned with. Ensures the consent document reflects the current study procedures and risks.' ;
    rdfs:domain ind:DocumentIcfVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionEndDate rdf:type rdf:Property ;
    rdfs:label 'Retention End Date' ;
    rdfs:comment 'The date after which this ICF document record may be destroyed per applicable regulatory retention requirements (typically 2 years after last marketing approval or 15 years per ICH E6). Supports records management compliance.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sponsorProvided rdf:type rdf:Property ;
    rdfs:label 'Sponsor Provided' ;
    rdfs:comment 'Indicates whether this ICF version was provided by the sponsor as a template (True) or was independently developed by the site/CRO (False). Relevant for sponsor oversight and TMF filing responsibilities.' ;
    rdfs:domain ind:DocumentIcfVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subjectPopulation rdf:type rdf:Property ;
    rdfs:label 'Subject Population' ;
    rdfs:comment 'Identifies the target subject population for which this ICF version is applicable: adult, pediatric, lar (Legally Authorized Representative), adolescent, or geriatric. Drives which consent form is presented during enrollment.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vaultDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Vault Document Number' ;
    rdfs:comment 'The human-readable document number assigned by Veeva Vault, used for cross-referencing in regulatory binders and inspection readiness activities.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReadinessId rdf:type rdf:Property ;
    rdfs:label 'Inspection Readiness Id' ;
    rdfs:comment 'Unique surrogate identifier for the document inspection readiness record. Primary key for this entity in the Databricks Silver Layer.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionReadiness .

ind:etmfVaultStudyId rdf:type rdf:Property ;
    rdfs:label 'Etmf Vault Study Id' ;
    rdfs:comment 'The Veeva Vault eTMF system identifier for the study\'s TMF vault, enabling direct cross-reference to the source system of record for document completeness metrics and readiness scores.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Study .

ind:regulatoryInspectionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Id' ;
    rdfs:comment 'Foreign key linking to regulatory.regulatory_inspection. Business justification: Document inspection readiness assessments are conducted in preparation for specific regulatory inspections. Linking the document readiness record to the regulatory inspection event enables cross-domai' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryInspection .

ind:siteFileId rdf:type rdf:Property ;
    rdfs:label 'Site File Id' ;
    rdfs:comment 'Foreign key linking to document.site_file. Business justification: Inspection readiness assessments are conducted at the site file level — the ISF/regulatory binder maintained at each investigator site is the primary artifact reviewed during GCP inspections. Linking ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SiteFile .

ind:tmfCompletenessId rdf:type rdf:Property ;
    rdfs:label 'Tmf Completeness Id' ;
    rdfs:comment 'Foreign key linking to document.tmf_completeness. Business justification: Inspection readiness assessments are directly informed by TMF completeness assessments. The tmf_completeness_percentage DECIMAL in document_inspection_readiness is a denormalized value from tmf_comple' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TmfCompleteness .

ind:actualInspectionEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual Inspection End Date' ;
    rdfs:comment 'The actual date on which the regulatory authority or sponsor inspection concluded. Used to calculate inspection duration and trigger post-inspection response workflows.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualInspectionStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Inspection Start Date' ;
    rdfs:comment 'The actual date on which the regulatory authority or sponsor inspection commenced. Populated once the inspection begins; used to measure planning accuracy against target inspection date.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:criticalGapsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Gaps Count' ;
    rdfs:comment 'Number of critical-severity document gaps or deficiencies that could result in a regulatory finding or inspection observation if not remediated prior to inspection. Subset of open_findings_count.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:diaTmfZoneCoverage rdf:type rdf:Property ;
    rdfs:label 'Dia Tmf Zone Coverage' ;
    rdfs:comment 'Comma-separated list of DIA TMF Reference Model zones (e.g., Zone 1-Trial Management, Zone 2-Central Trial Documents, Zone 3-Regulatory, Zone 4-IRB/IEC, Zone 5-Site Management, Zone 6-IP, Zone 7-Safety Reporting, Zone 8-Statistics) included in the scope of this readiness assessment.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectingAuthority rdf:type rdf:Property ;
    rdfs:label 'Inspecting Authority' ;
    rdfs:comment 'The regulatory authority or organization conducting or expected to conduct the inspection (e.g., FDA, EMA, MHRA, PMDA). Drives jurisdiction-specific readiness requirements and document standards. [ENUM-REF-CANDIDATE: FDA|EMA|MHRA|PMDA|TGA|Health Canada|ANVISA|CFDA|sponsor|internal — promote to reference product]' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Notification Date' ;
    rdfs:comment 'The date on which the regulatory authority formally notified the sponsor or CRO of the upcoming inspection. Triggers the formal inspection preparation timeline and escalation procedures.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionOutcome rdf:type rdf:Property ;
    rdfs:label 'Inspection Outcome' ;
    rdfs:comment 'The formal outcome classification issued by the regulatory authority following inspection closure. FDA classifications: No Action Indicated (NAI), Voluntary Action Indicated (VAI), Official Action Indicated (OAI). Populated post-inspection; null or \'pending\' during active inspection.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReadinessTier rdf:type rdf:Property ;
    rdfs:label 'Inspection Readiness Tier' ;
    rdfs:comment 'Red-Amber-Green (RAG) traffic-light classification of overall inspection readiness. \'green\' indicates ready for inspection; \'amber\' indicates preparation in progress with manageable gaps; \'red\' indicates significant deficiencies requiring urgent remediation before inspection.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReportDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Report Date' ;
    rdfs:comment 'The date on which the regulatory authority issued the formal inspection report or Form FDA 483 (for FDA inspections). Triggers the response timeline for addressing inspection observations.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReadinessReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Readiness Review Date' ;
    rdfs:comment 'The date on which the most recent internal TMF readiness review was conducted. Used to assess currency of the readiness assessment and trigger periodic re-reviews per SOP.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:majorGapsCount rdf:type rdf:Property ;
    rdfs:label 'Major Gaps Count' ;
    rdfs:comment 'Number of major-severity document gaps identified during TMF readiness review. Major gaps are significant deficiencies that require remediation but are less severe than critical gaps.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorGapsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Gaps Count' ;
    rdfs:comment 'Number of minor-severity document gaps or observations identified during TMF readiness review. Minor gaps are low-risk deficiencies that should be addressed but do not pose immediate inspection risk.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:missingDocumentsCount rdf:type rdf:Property ;
    rdfs:label 'Missing Documents Count' ;
    rdfs:comment 'Number of expected TMF artifacts per the DIA TMF Reference Model that are entirely absent from the eTMF system. Distinct from overdue documents which are expected but not yet filed.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextReadinessReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Readiness Review Date' ;
    rdfs:comment 'The date on which the next scheduled internal TMF readiness review is planned. Supports proactive inspection readiness management and escalation when overdue.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Open Findings Count' ;
    rdfs:comment 'Total number of unresolved inspection readiness findings (gaps, deficiencies, or observations) identified during internal TMF reviews. A key KPI for inspection readiness dashboards.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overdueDocumentsCount rdf:type rdf:Property ;
    rdfs:label 'Overdue Documents Count' ;
    rdfs:comment 'Number of TMF documents that are past their expected filing deadline per the TMF filing timeline or DIA TMF Reference Model expectations. Indicates timeliness risk for inspection readiness.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Previous Inspection Date' ;
    rdfs:comment 'Date of the most recent prior regulatory inspection for this study, if applicable. Used to assess inspection history, recurrence risk, and whether prior findings have been adequately remediated.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:previousInspectionOutcome rdf:type rdf:Property ;
    rdfs:label 'Previous Inspection Outcome' ;
    rdfs:comment 'The formal outcome of the most recent prior regulatory inspection for this study. Provides historical context for current readiness planning and risk assessment.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readinessReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Readiness Reference Code' ;
    rdfs:comment 'Externally-known business identifier for this inspection readiness record, used in communications with sponsors, regulatory authorities, and internal tracking systems (e.g., Veeva Vault eTMF). Format: IR-{StudyCode}-{Sequence}.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readinessScore rdf:type rdf:Property ;
    rdfs:label 'Readiness Score' ;
    rdfs:comment 'Quantitative score (0.00–100.00) representing the overall inspection readiness of the study\'s TMF, calculated based on document completeness, quality metrics, and open findings. Sourced from Veeva Vault eTMF completeness metrics or internal scoring methodology.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readinessStatus rdf:type rdf:Property ;
    rdfs:label 'Readiness Status' ;
    rdfs:comment 'Current lifecycle state of the TMF inspection readiness process for this study. \'not-started\' indicates no preparation has begun; \'in-preparation\' indicates active remediation; \'ready\' indicates the TMF has passed internal review; \'under-inspection\' indicates the regulatory authority is actively inspecting; \'closed\' indicates the inspection cycle is complete.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Target Inspection Date' ;
    rdfs:comment 'The anticipated or scheduled date on which the regulatory authority or sponsor inspection is expected to commence. Used for readiness planning and milestone tracking.' ;
    rdfs:domain ind:InspectionReadiness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tmfScope rdf:type rdf:Property ;
    rdfs:label 'Tmf Scope' ;
    rdfs:comment 'Defines the scope of the TMF covered by this inspection readiness record. \'full-study\' covers the entire TMF; \'site-specific\' covers a single investigator site file; \'sponsor-section\' covers sponsor-held documents only; \'investigator-section\' covers investigator-held documents only.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureId rdf:type rdf:Property ;
    rdfs:label 'Signature Id' ;
    rdfs:comment 'Unique surrogate identifier for each electronic signature record applied to a controlled document. Primary key for the document_signature data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delegationOfAuthorityId rdf:type rdf:Property ;
    rdfs:label 'Delegation Of Authority Id' ;
    rdfs:comment 'Reference to the delegation of authority record when the signer is acting on behalf of another party (e.g., a sub-investigator signing on behalf of the Principal Investigator). Supports sponsor oversight and GCP compliance verification.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DelegationOfAuthority .

ind:signatureEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Signature Employee Id' ;
    rdfs:comment 'Reference to the authenticated user record of the individual who applied the electronic signature. Satisfies the ALCOA+ principle of Attributability — every signature must be traceable to a unique individual.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:signatureVoidedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Signature Voided By User Employee Id' ;
    rdfs:comment 'Reference to the user who performed the void action on this signature record. Required for audit trail completeness when a signature is invalidated.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:workflowId rdf:type rdf:Property ;
    rdfs:label 'Workflow Id' ;
    rdfs:comment 'Foreign key linking to document.document_workflow. Business justification: Electronic signatures are applied within the context of a document workflow step (review, approval, distribution). document_signature has workflow_step_name and workflow_step_sequence as STRING/INT fi' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Workflow .

ind:auditHash rdf:type rdf:Property ;
    rdfs:label 'Audit Hash' ;
    rdfs:comment 'Cryptographic hash (e.g., SHA-256) of the signed document content and signature metadata at the time of signing. Provides tamper-evidence and integrity verification for the electronic signature record, satisfying 21 CFR Part 11 §11.10(a) data integrity requirements.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalCertificateSerial rdf:type rdf:Property ;
    rdfs:label 'Digital Certificate Serial' ;
    rdfs:comment 'Serial number of the digital certificate used when the signature method is digital_certificate or smart_card. Enables certificate chain validation and revocation checking for PKI-based electronic signatures.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hashAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Hash Algorithm' ;
    rdfs:comment 'Cryptographic algorithm used to generate the audit hash for this signature record (e.g., SHA-256, SHA-512). Required to enable future hash verification and to document the cryptographic standard applied at the time of signing.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRegulatorySubmissionApplicable rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Submission Applicable' ;
    rdfs:comment 'Indicates whether this signature is part of a document package intended for regulatory submission (e.g., IND, NDA, BLA, MAA, eCTD). When True, the signature record is subject to heightened integrity and retention requirements.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReminderTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reminder Timestamp' ;
    rdfs:comment 'Date and time of the most recent automated reminder notification sent to the signer. Supports escalation management and overdue signature tracking.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:locale rdf:type rdf:Property ;
    rdfs:label 'Locale' ;
    rdfs:comment 'IETF BCP 47 locale code representing the language and regional settings active at the time of signing (e.g., en-US, de-DE, ja-JP). Relevant for multi-national trials to confirm the signer viewed the document in their preferred language.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meaning rdf:type rdf:Property ;
    rdfs:label 'Meaning' ;
    rdfs:comment 'The legally defined meaning associated with the electronic signature, as required by 21 CFR Part 11. Specifies the intent of the signer (e.g., reviewed = content reviewed for accuracy; approved = authorized for release; acknowledged = receipt confirmed).' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderSentCount rdf:type rdf:Property ;
    rdfs:label 'Reminder Sent Count' ;
    rdfs:comment 'Number of automated reminder notifications sent to the signer for a pending signature request. Used to track escalation activity and measure signature workflow efficiency in TMF completeness dashboards.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Requested Timestamp' ;
    rdfs:comment 'Date and time when the signature request was initiated and sent to the signer. Used to calculate signature turnaround time and to track overdue signature tasks in inspection readiness dashboards.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:signatureMethod rdf:type rdf:Property ;
    rdfs:label 'Signature Method' ;
    rdfs:comment 'Authentication method used to apply the electronic signature. Determines the technical compliance pathway under 21 CFR Part 11 (biometric vs. non-biometric). Required for regulatory inspection to demonstrate identity verification rigor.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureStatus rdf:type rdf:Property ;
    rdfs:label 'Signature Status' ;
    rdfs:comment 'Current lifecycle status of the electronic signature record. Pending = awaiting signer action; Applied = successfully executed; Voided = invalidated due to document revision or administrative action; Superseded = replaced by a newer signature; Rejected = signer declined to sign.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureType rdf:type rdf:Property ;
    rdfs:label 'Signature Type' ;
    rdfs:comment 'Classification of the signature type per applicable regulatory framework. Electronic = standard 21 CFR Part 11 e-signature; Wet Ink Scanned = paper signature digitized; Advanced Electronic = eIDAS AES; Qualified Electronic = eIDAS QES with qualified certificate.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Signed Timestamp' ;
    rdfs:comment 'The precise date and time (with timezone offset) at which the electronic signature was applied by the signer. This is the principal real-world event timestamp for the signature transaction. Must be system-generated and tamper-evident per 21 CFR Part 11 §11.10(e).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:signerFullName rdf:type rdf:Property ;
    rdfs:label 'Signer Full Name' ;
    rdfs:comment 'Full legal name of the individual who applied the electronic signature, captured at the time of signing. Stored as a point-in-time snapshot to preserve the audit trail even if the user record changes.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signerOrganization rdf:type rdf:Property ;
    rdfs:label 'Signer Organization' ;
    rdfs:comment 'Name of the organization or company the signer represents at the time of signing (e.g., sponsor company name, CRO name, investigative site institution). Supports multi-party trial agreements and sponsor delegation tracking.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signerRole rdf:type rdf:Property ;
    rdfs:label 'Signer Role' ;
    rdfs:comment 'Functional role of the signer within the document workflow at the time of signing. Determines the legal weight and workflow position of the signature. [ENUM-REF-CANDIDATE: author|reviewer|approver|sponsor_representative|quality_assurance|investigator|regulatory_affairs|data_manager — promote to reference product if additional roles are required]' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signerTitle rdf:type rdf:Property ;
    rdfs:label 'Signer Title' ;
    rdfs:comment 'Professional title or job designation of the signer at the time of signing (e.g., Principal Investigator, Medical Monitor, Sponsor Representative, Biostatistician). Captured as a point-in-time snapshot for regulatory inspection readiness.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemSignatureReference rdf:type rdf:Property ;
    rdfs:label 'Source System Signature Reference' ;
    rdfs:comment 'Native identifier of the signature record in the originating source system (e.g., Veeva Vault internal signature object ID). Enables bidirectional traceability between the Silver Layer and the operational system for reconciliation and audit.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA timezone identifier representing the local timezone of the signer at the time of signing (e.g., America/New_York, Europe/London). Required to accurately interpret the signed_timestamp in multi-national trial contexts and for regulatory inspection.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Voided Timestamp' ;
    rdfs:comment 'Date and time when the signature was voided or invalidated. Supports the complete lifecycle audit trail for the signature record and regulatory inspection readiness.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workflowStepName rdf:type rdf:Property ;
    rdfs:label 'Workflow Step Name' ;
    rdfs:comment 'Name of the document workflow step within which this signature was collected (e.g., \'Author Review\', \'QA Approval\', \'Sponsor Sign-Off\'). Maps to the Veeva Vault workflow configuration and supports workflow analytics and bottleneck identification.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowStepSequence rdf:type rdf:Property ;
    rdfs:label 'Workflow Step Sequence' ;
    rdfs:comment 'Numeric sequence position of this signature step within the overall document approval workflow. Enables ordered reconstruction of the full signature chain for regulatory inspection and audit trail review.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Document Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: SOP ownership is a named GCP compliance role — the document owner is accountable for SOP currency, review cycles, and training assignment. Regulatory inspectors verify SOP ownership. Replaces denormal' ;
    rdfs:domain ind:DocumentSop ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:owningOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Owning Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: SOP organizational ownership determines training scope, distribution lists, and CAPA routing in clinical operations. Replaces denormalized \'owning_department\' text with a proper org_unit FK enabling d' ;
    rdfs:domain ind:DocumentSop ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:applicableRegion rdf:type rdf:Property ;
    rdfs:label 'Applicable Region' ;
    rdfs:comment 'Geographic region(s) or jurisdiction(s) for which this SOP is applicable (e.g., \'USA\', \'EU\', \'GLOBAL\', \'JPN\'). Supports multi-regional regulatory compliance and site-level applicability determination.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approver rdf:type rdf:Property ;
    rdfs:label 'Approver' ;
    rdfs:comment 'Name or employee identifier of the authorized individual who provided final approval for the current SOP version. Required for 21 CFR Part 11 electronic signature compliance.' ;
    rdfs:domain ind:DocumentSop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:author rdf:type rdf:Property ;
    rdfs:label 'Author' ;
    rdfs:comment 'Name or employee identifier of the individual who drafted or last revised the SOP content. Supports ALCOA+ attributability requirements for controlled documents.' ;
    rdfs:domain ind:DocumentSop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationTriggered rdf:type rdf:Property ;
    rdfs:label 'Deviation Triggered' ;
    rdfs:comment 'Indicates whether this SOP version was created or revised as a direct result of a protocol deviation or quality event. When True, the capa_reference field should be populated. Supports quality trend analysis.' ;
    rdfs:domain ind:DocumentSop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentFormat rdf:type rdf:Property ;
    rdfs:label 'Document Format' ;
    rdfs:comment 'File format of the controlled SOP document as stored in MasterControl (e.g., pdf, word). PDF is the standard format for approved/effective SOPs to prevent unauthorized modification per 21 CFR Part 11.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentLocationUrl rdf:type rdf:Property ;
    rdfs:label 'Document Location Url' ;
    rdfs:comment 'URL or system path to the controlled SOP document in MasterControl or the designated document management repository. Enables direct navigation to the source document for review and compliance verification.' ;
    rdfs:domain ind:DocumentSop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'ISO 639-1/639-2 language code of the SOP document (e.g., \'en\', \'fr\', \'de\', \'ja\'). Supports multi-language SOP libraries for global clinical trial operations across multiple regulatory jurisdictions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mastercontrolDocReference rdf:type rdf:Property ;
    rdfs:label 'Mastercontrol Doc Reference' ;
    rdfs:comment 'Native document identifier assigned by MasterControl (the system of record for controlled documents). Used for cross-system traceability and integration with MasterControl training, CAPA, and audit modules.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purpose rdf:type rdf:Property ;
    rdfs:label 'Purpose' ;
    rdfs:comment 'Brief narrative describing the business purpose and objective of the SOP — why it exists and what regulatory or operational requirement it fulfills. Sourced from the SOP document\'s purpose/objective section.' ;
    rdfs:domain ind:DocumentSop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopStatus rdf:type rdf:Property ;
    rdfs:label 'Sop Status' ;
    rdfs:comment 'Current lifecycle state of the SOP within the controlled document management workflow. Governs whether the SOP is actionable for clinical trial operations. Aligns with LIFECYCLE_STATUS category for MASTER_RESOURCE role. [ENUM-REF-CANDIDATE: draft|under_review|approved|effective|superseded|retired|obsolete — promote to reference product]' ;
    rdfs:domain ind:DocumentSop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopType rdf:type rdf:Property ;
    rdfs:label 'Sop Type' ;
    rdfs:comment 'Type of controlled document within the quality management system hierarchy. Distinguishes SOPs from work instructions, policies, guidance documents, templates, and forms. Supports document hierarchy management.' ;
    rdfs:domain ind:DocumentSop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededSopNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded Sop Number' ;
    rdfs:comment 'SOP number of the prior version or predecessor document that this SOP replaces. Enables document lineage tracing and ensures retired versions are properly cross-referenced. Null if this is the inaugural version.' ;
    rdfs:domain ind:DocumentSop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmfReferenceModelSection rdf:type rdf:Property ;
    rdfs:label 'Tmf Reference Model Section' ;
    rdfs:comment 'DIA TMF Reference Model zone/section identifier to which this SOP is mapped, if applicable (e.g., \'01.01 - Trial Management\'). Supports eTMF filing and inspection readiness alignment with the DIA TMF Reference Model.' ;
    rdfs:domain ind:DocumentSop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Document template ownership is a GCP-required accountability — the owner is responsible for template currency, review cycles, and retirement. Replaces denormalized \'template_owner\' text with an employ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primarySupersededByTemplateId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Template Id' ;
    rdfs:comment 'Reference to the document_template_id of the newer template version that supersedes this one. Null if this is the current active version. Enables version chain traceability for audit and inspection readiness purposes.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Template .

ind:applicableTherapeuticArea rdf:type rdf:Property ;
    rdfs:label 'Applicable Therapeutic Area' ;
    rdfs:comment 'Therapeutic area or disease indication for which this template is specifically designed (e.g., Oncology, Cardiology, Neurology, Rare Disease, Infectious Disease, ALL). Null or \'ALL\' indicates a cross-therapeutic template. Enables targeted template retrieval for study teams.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdiscStandardReference rdf:type rdf:Property ;
    rdfs:label 'Cdisc Standard Reference' ;
    rdfs:comment 'Reference to the applicable CDISC standard that this template supports or implements (e.g., SDTM v1.8, ADaM v1.3, CDASH v2.0, Protocol Representation Model). Ensures templates for CRFs, SAPs, and data collection instruments align with CDISC submission standards.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ectdSectionReference rdf:type rdf:Property ;
    rdfs:label 'Ectd Section Reference' ;
    rdfs:comment 'Reference to the eCTD module and section where documents created from this template are submitted (e.g., Module 5.3.5.1 for clinical study reports, Module 2.7.4 for summary of clinical safety). Applicable for regulatory submission templates. Null for non-submission templates.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEconsentCompatible rdf:type rdf:Property ;
    rdfs:label 'Is Econsent Compatible' ;
    rdfs:comment 'Indicates whether this template is designed and validated for use in electronic consent (eConsent) workflows via Clinpal or equivalent eConsent platforms (True), or is intended for paper-based consent only (False). Relevant for ICF templates in studies using eConsent.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current state of the template in its controlled document lifecycle as managed in Veeva Vault. DRAFT=under authoring, IN_REVIEW=under QA/regulatory review, APPROVED=approved but not yet effective, EFFECTIVE=currently in use for document creation, SUPERSEDED=replaced by a newer version, RETIRED=withdrawn from use, OBSOLETE=archived. [ENUM-REF-CANDIDATE: DRAFT|IN_REVIEW|APPROVED|EFFECTIVE|SUPERSEDED|RETIRED|OBSOLETE — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningDepartment rdf:type rdf:Property ;
    rdfs:label 'Owning Department' ;
    rdfs:comment 'Name of the business department responsible for authoring, maintaining, and approving this template (e.g., Regulatory Affairs, Clinical Operations, Biostatistics, Data Management, Medical Writing, Quality Assurance). Determines the approval workflow and accountability chain.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Months' ;
    rdfs:comment 'Scheduled frequency in months at which this template must undergo periodic review to ensure continued regulatory compliance and business relevance (e.g., 12 for annual review, 24 for biennial). Drives automated review reminders in MasterControl and Veeva Vault.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:templateCode rdf:type rdf:Property ;
    rdfs:label 'Template Code' ;
    rdfs:comment 'Externally-known, human-readable unique code assigned to the template (e.g., ICF-TMPL-00042). Used as the business identifier across systems including Veeva Vault and MasterControl for cross-system referencing and audit trails.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateDescription rdf:type rdf:Property ;
    rdfs:label 'Template Description' ;
    rdfs:comment 'Detailed narrative description of the template\'s purpose, intended use, key sections, and any special instructions for document creators. Provides context for study teams selecting the appropriate template for their document creation needs.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateName rdf:type rdf:Property ;
    rdfs:label 'Template Name' ;
    rdfs:comment 'Human-readable name of the document template (e.g., \'Phase III Oncology Informed Consent Form Template\', \'Clinical Study Report Shell\'). Serves as the primary identity label for business users in Veeva Vault and CTMS.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateType rdf:type rdf:Property ;
    rdfs:label 'Template Type' ;
    rdfs:comment 'Classification of the template by its functional document type within clinical trial operations (e.g., ICF_TEMPLATE, PROTOCOL_TEMPLATE, CSR_SHELL, SAP_TEMPLATE, CRF_ANNOTATION, REGULATORY_COVER_LETTER, DSMB_CHARTER, SITE_AGREEMENT). [ENUM-REF-CANDIDATE: ICF_TEMPLATE|PROTOCOL_TEMPLATE|CSR_SHELL|SAP_TEMPLATE|CRF_ANNOTATION|REGULATORY_COVER_LETTER|DSMB_CHARTER|SITE_AGREEMENT|IB_TEMPLATE|DSUR_TEMPLATE — promote to reference product]' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCurriculumCode rdf:type rdf:Property ;
    rdfs:label 'Training Curriculum Code' ;
    rdfs:comment 'Code referencing the MasterControl training curriculum or course that must be completed before using this template. Applicable when training_required is True. Links template usage to the training management system for compliance tracking.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionAuthorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Version Author Employee Id' ;
    rdfs:comment 'Reference to the Workday HCM workforce record of the individual who authored this document version. Enables workforce analytics and training compliance linkage.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:checksumHash rdf:type rdf:Property ;
    rdfs:label 'Checksum Hash' ;
    rdfs:comment 'The SHA-256 cryptographic hash of the document file content at the time of this version\'s creation. Used to verify document integrity and detect unauthorized alterations, supporting 21 CFR Part 11 audit trail and ALCOA+ integrity requirements.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompletionDeadline rdf:type rdf:Property ;
    rdfs:label 'Training Completion Deadline' ;
    rdfs:comment 'The date by which all required staff must complete training on this document version. Null if training is not required. Used to monitor training compliance and flag overdue training in MasterControl.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vaultDocumentVersionReference rdf:type rdf:Property ;
    rdfs:label 'Vault Document Version Reference' ;
    rdfs:comment 'The native document version identifier assigned by Veeva Vault (eTMF/QMS module). Used to trace this Silver Layer record back to its source system record for reconciliation and audit purposes.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Workflow Employee Id' ;
    rdfs:comment 'Veeva Vault user identifier of the individual currently assigned to complete the active workflow step. Required for 21 CFR Part 11 electronic signature audit trail and accountability under ALCOA+ principles.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:workflowInitiatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Workflow Initiated By User Employee Id' ;
    rdfs:comment 'Veeva Vault user identifier of the individual who initiated the document workflow. Required for ALCOA+ attributability and 21 CFR Part 11 audit trail to establish who triggered the document control process.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:archivalRequired rdf:type rdf:Property ;
    rdfs:label 'Archival Required' ;
    rdfs:comment 'Indicates whether the document must be archived upon workflow completion per ICH GCP retention requirements. Drives post-approval archival workflow initiation in Veeva Vault for long-term TMF retention compliance.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentStepName rdf:type rdf:Property ;
    rdfs:label 'Current Step Name' ;
    rdfs:comment 'Name of the active step within the workflow at the time of record capture (e.g., \'Quality Review\', \'Medical Review\', \'Regulatory Approval\', \'Final Sign-Off\'). Identifies where in the process the document currently resides.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentStepSequence rdf:type rdf:Property ;
    rdfs:label 'Current Step Sequence' ;
    rdfs:comment 'Ordinal position of the current workflow step within the overall workflow template sequence. Enables progress tracking and percentage-complete calculations across multi-step document approval processes.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionRequired rdf:type rdf:Property ;
    rdfs:label 'Distribution Required' ;
    rdfs:comment 'Indicates whether the approved document must be distributed to designated recipients (sites, investigators, sponsors) upon workflow completion. Triggers the distribution workflow step in Veeva Vault upon approval.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:electronicSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Timestamp' ;
    rdfs:comment 'Date and time when the final binding electronic signature was applied to the document within this workflow. Required for 21 CFR Part 11 compliance. Null if electronic_signature_required is False or signature has not yet been applied.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gcpCriticalDocumentFlag rdf:type rdf:Property ;
    rdfs:label 'Gcp Critical Document Flag' ;
    rdfs:comment 'Indicates whether the document is classified as a GCP essential document per ICH E6(R2) Section 8. Critical documents require mandatory workflow completion before study activities can proceed and are prioritized in inspection readiness reviews.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Initiated Timestamp' ;
    rdfs:comment 'Date and time when the document workflow instance was first created and launched in Veeva Vault. Serves as the principal business event timestamp for the workflow lifecycle and the start point for overall cycle time measurement.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rejectionCount rdf:type rdf:Property ;
    rdfs:label 'Rejection Count' ;
    rdfs:comment 'Number of times the document has been rejected and returned for revision within this workflow instance. High rejection counts indicate document quality issues and are tracked for quality metrics and CAPA (Corrective and Preventive Action) analysis.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaBreachIndicator rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Indicator' ;
    rdfs:comment 'Flag indicating whether the workflow or any of its steps has exceeded the defined Service Level Agreement (SLA) timeframe. True when step_completion_date or actual_completion_date exceeds the corresponding due date. Drives escalation and KPI reporting.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stepActionTaken rdf:type rdf:Property ;
    rdfs:label 'Step Action Taken' ;
    rdfs:comment 'The specific action performed by the assignee at the current or last completed workflow step. Captures the decision outcome (approved, rejected) or process action (delegated, escalated) for audit trail completeness.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepAssigneeName rdf:type rdf:Property ;
    rdfs:label 'Step Assignee Name' ;
    rdfs:comment 'Full name of the individual assigned to the current workflow step. Captured at time of assignment for audit trail integrity per ALCOA+ (Attributable, Legible, Contemporaneous, Original, Accurate) requirements.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepAssigneeRole rdf:type rdf:Property ;
    rdfs:label 'Step Assignee Role' ;
    rdfs:comment 'Business role responsible for completing the current workflow step (e.g., \'Principal Investigator (PI)\', \'Clinical Research Associate (CRA)\', \'Regulatory Affairs Manager\', \'Quality Assurance (QA) Reviewer\'). Role-based assignment supports GCP delegation of authority.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepComment rdf:type rdf:Property ;
    rdfs:label 'Step Comment' ;
    rdfs:comment 'Free-text comment or rationale provided by the step assignee when completing, rejecting, or escalating the workflow step. Supports GCP documentation requirements and provides context for rejection decisions.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Step Completion Date' ;
    rdfs:comment 'Actual date on which the current or most recently completed workflow step was actioned and closed. Compared against step_due_date to determine SLA compliance and cycle time analytics.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stepCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Step Completion Timestamp' ;
    rdfs:comment 'Precise date and time at which the workflow step action was recorded in Veeva Vault. Provides sub-day granularity required for 21 CFR Part 11 electronic audit trail and time-stamped electronic signature records.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stepDueDate rdf:type rdf:Property ;
    rdfs:label 'Step Due Date' ;
    rdfs:comment 'Target completion date for the current workflow step as defined by the workflow SLA configuration. Used to calculate SLA breach status and trigger escalation notifications for overdue document reviews.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:templateVersion rdf:type rdf:Property ;
    rdfs:label 'Template Version' ;
    rdfs:comment 'Version identifier of the workflow template at the time this workflow instance was initiated. Ensures reproducibility and audit traceability when templates are updated over time.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSteps rdf:type rdf:Property ;
    rdfs:label 'Total Steps' ;
    rdfs:comment 'Total number of steps defined in the workflow template for this workflow instance. Used in conjunction with current_step_sequence to calculate workflow completion percentage for inspection readiness dashboards.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workflowInstanceReference rdf:type rdf:Property ;
    rdfs:label 'Workflow Instance Reference' ;
    rdfs:comment 'Externally-known unique identifier assigned by Veeva Vault to this specific workflow instance. Used for cross-system traceability and audit trail correlation with the source eTMF system.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowStatus rdf:type rdf:Property ;
    rdfs:label 'Workflow Status' ;
    rdfs:comment 'Current lifecycle state of the document workflow instance within Veeva Vault. Tracks progression from initiation through review, approval decision, and terminal states. Supports GCP-compliant document control audit trails.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowType rdf:type rdf:Property ;
    rdfs:label 'Workflow Type' ;
    rdfs:comment 'Classification of the workflow by its primary business purpose within the document lifecycle. Distinguishes review-only workflows from approval workflows, distribution workflows, archival workflows, and amendment workflows.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etmfExchangeId rdf:type rdf:Property ;
    rdfs:label 'Etmf Exchange Id' ;
    rdfs:comment 'Unique surrogate identifier for each eTMF document exchange transaction record in the Databricks Silver Layer. Primary key for this entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:EtmfExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resubmissionOfExchangeId rdf:type rdf:Property ;
    rdfs:label 'Resubmission Of Exchange Id' ;
    rdfs:comment 'Reference to the original eTMF exchange transaction that this record is resubmitting after a prior rejection. Enables lineage tracking of rejected and corrected exchange transactions.' ;
    rdfs:domain ind:EtmfExchange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EtmfExchange .

ind:archivalFlag rdf:type rdf:Property ;
    rdfs:label 'Archival Flag' ;
    rdfs:comment 'Indicates whether this eTMF exchange represents a final archival transfer of study documents at study close-out. True = archival transfer per ICH GCP retention requirements.' ;
    rdfs:domain ind:EtmfExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentCount rdf:type rdf:Property ;
    rdfs:label 'Document Count' ;
    rdfs:comment 'Total number of individual documents included in the eTMF exchange package. Used for completeness verification and reconciliation upon receipt.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exchangeDate rdf:type rdf:Property ;
    rdfs:label 'Exchange Date' ;
    rdfs:comment 'The principal real-world timestamp when the eTMF document exchange was initiated or executed. Represents the business event time of the transfer, distinct from system audit timestamps. Satisfies TRANSACTION_HEADER BUSINESS_EVENT_TIMESTAMP category.' ;
    rdfs:domain ind:EtmfExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exchangeDirection rdf:type rdf:Property ;
    rdfs:label 'Exchange Direction' ;
    rdfs:comment 'Indicates the direction of the eTMF document transfer: from the Contract Research Organization (CRO) to the sponsor, or from the sponsor to the CRO. Critical for demonstrating sponsor oversight obligations under ICH GCP 5.0.' ;
    rdfs:domain ind:EtmfExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeFrequency rdf:type rdf:Property ;
    rdfs:label 'Exchange Frequency' ;
    rdfs:comment 'The agreed cadence for eTMF document exchanges between CRO and sponsor as defined in the eTMF exchange agreement. Used for scheduling and compliance monitoring.' ;
    rdfs:domain ind:EtmfExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeManifestReference rdf:type rdf:Property ;
    rdfs:label 'Exchange Manifest Reference' ;
    rdfs:comment 'Identifier of the exchange manifest file accompanying the document package. The manifest lists all documents, metadata, and checksums included in the transfer per DIA eTMF Exchange Mechanism Standard.' ;
    rdfs:domain ind:EtmfExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeNotes rdf:type rdf:Property ;
    rdfs:label 'Exchange Notes' ;
    rdfs:comment 'Free-text field for additional context, instructions, or comments associated with this eTMF exchange transaction. May include special handling instructions or regulatory context.' ;
    rdfs:domain ind:EtmfExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Exchange Reference Number' ;
    rdfs:comment 'Externally-known business identifier for the exchange transaction, typically generated by Veeva Vault or the initiating system. Used for cross-system reconciliation between CRO and sponsor. Satisfies TRANSACTION_HEADER BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:EtmfExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeType rdf:type rdf:Property ;
    rdfs:label 'Exchange Type' ;
    rdfs:comment 'Classification of the exchange transaction by business purpose: routine scheduled transfer, ad hoc request, inspection-driven transfer, study close-out package, or interim milestone transfer.' ;
    rdfs:domain ind:EtmfExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inclusionReason rdf:type rdf:Property ;
    rdfs:label 'Inclusion Reason' ;
    rdfs:comment 'The business reason why this specific document was included in this exchange transaction. Supports audit trail requirements and sponsor oversight documentation under ICH GCP 5.0.' ;
    rdfs:domain ind:EtmfExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrityVerified rdf:type rdf:Property ;
    rdfs:label 'Integrity Verified' ;
    rdfs:comment 'Indicates whether the receiving party has verified the cryptographic checksum of the received package matches the sender\'s declared checksum. True = integrity confirmed; False = mismatch detected.' ;
    rdfs:domain ind:EtmfExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packageName rdf:type rdf:Property ;
    rdfs:label 'Package Name' ;
    rdfs:comment 'Human-readable name or label assigned to the document package included in this exchange transaction. Used for identification and tracking of the transferred document bundle.' ;
    rdfs:domain ind:EtmfExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageSizeMb rdf:type rdf:Property ;
    rdfs:label 'Package Size Mb' ;
    rdfs:comment 'Total file size of the eTMF document exchange package in megabytes. Used for transfer capacity planning, SLA monitoring, and troubleshooting failed transfers.' ;
    rdfs:domain ind:EtmfExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Timestamp when the receiving system confirmed technical receipt of the eTMF document package. Distinct from acknowledgement_timestamp which represents formal business acknowledgement.' ;
    rdfs:domain ind:EtmfExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receiverContactName rdf:type rdf:Property ;
    rdfs:label 'Receiver Contact Name' ;
    rdfs:comment 'Name of the responsible individual at the receiving organization who acknowledged or processed the eTMF exchange. Used for accountability and follow-up communications.' ;
    rdfs:domain ind:EtmfExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverVaultReference rdf:type rdf:Property ;
    rdfs:label 'Receiver Vault Reference' ;
    rdfs:comment 'The Veeva Vault instance identifier of the receiving organization (sponsor or CRO). Used for cross-account transfer reconciliation and confirmation of receipt in Veeva Vault eTMF.' ;
    rdfs:domain ind:EtmfExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRegion rdf:type rdf:Property ;
    rdfs:label 'Regulatory Region' ;
    rdfs:comment 'The regulatory jurisdiction(s) applicable to the documents in this eTMF exchange (e.g., US, EU, JP). Determines applicable regulatory standards for document format and retention requirements.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Code' ;
    rdfs:comment 'Standardized code categorizing the reason for rejection of the eTMF document package (e.g., MISSING_DOCS, WRONG_VERSION, METADATA_ERROR). Enables systematic tracking and trending of rejection causes.' ;
    rdfs:domain ind:EtmfExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledExchangeDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Exchange Date' ;
    rdfs:comment 'The planned date on which the eTMF document exchange was scheduled to occur per the eTMF exchange agreement or data management plan. Used for SLA monitoring and deviation tracking.' ;
    rdfs:domain ind:EtmfExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:senderContactName rdf:type rdf:Property ;
    rdfs:label 'Sender Contact Name' ;
    rdfs:comment 'Name of the responsible individual at the sending organization who initiated or authorized the eTMF exchange. Used for accountability and follow-up communications.' ;
    rdfs:domain ind:EtmfExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderVaultReference rdf:type rdf:Property ;
    rdfs:label 'Sender Vault Reference' ;
    rdfs:comment 'The Veeva Vault instance identifier of the sending organization (CRO or sponsor). Used for cross-account transfer reconciliation and audit trail in Veeva Vault eTMF.' ;
    rdfs:domain ind:EtmfExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmfArtifactType rdf:type rdf:Property ;
    rdfs:label 'Tmf Artifact Type' ;
    rdfs:comment 'The DIA TMF Reference Model artifact type designation for the primary document type in this exchange package (e.g., Protocol, Informed Consent Form, Investigator Brochure). Supports TMF completeness tracking. [Moved from etmf_exchange: Artifact type is a property of the specific document being transferred, not of the exchange package as a whole. When a package contains multiple artifact types, this attribute is ambiguous on etmf_exchange and belongs on the exchange_document_item association.]' ;
    rdfs:domain ind:EtmfExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Method' ;
    rdfs:comment 'The technical mechanism used to transfer the eTMF document package between CRO and sponsor. Includes Veeva Vault cross-account transfer, SFTP, API integration, manual upload, or secure email. [ENUM-REF-CANDIDATE: veeva_vault_cross_account|sftp|api|manual_upload|secure_email|cd_media — promote to reference product if additional methods are added]' ;
    rdfs:domain ind:EtmfExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaVaultJobReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Job Reference' ;
    rdfs:comment 'The job or transaction identifier assigned by Veeva Vault for the cross-account eTMF transfer operation. Used for technical reconciliation and support troubleshooting with Veeva.' ;
    rdfs:domain ind:EtmfExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionAtExchange rdf:type rdf:Property ;
    rdfs:label 'Version At Exchange' ;
    rdfs:comment 'The version label of the TMF document that was actually included and transferred in this exchange. Critical for regulatory traceability — the document may have been updated since the exchange, so the version transferred must be recorded on the relationship, not on the document master.' ;
    rdfs:domain ind:EtmfExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryLeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Lead Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: The regulatory lead is the named accountable employee for submission management — a critical role in regulatory operations. Agencies and sponsors track regulatory lead assignments for submission accou' ;
    rdfs:domain ind:RegulatoryBinder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agencyActionDate rdf:type rdf:Property ;
    rdfs:label 'Agency Action Date' ;
    rdfs:comment 'The date on which the health authority issued its formal regulatory action (approval, complete response letter, refusal to file, withdrawal, etc.) on this submission. Marks the end of the primary review cycle.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agencyActionType rdf:type rdf:Property ;
    rdfs:label 'Agency Action Type' ;
    rdfs:comment 'The type of regulatory action taken by the health authority on this submission (e.g., approval, complete response letter (CRL), refuse to file (RTF), withdrawal). Captures the outcome of the regulatory review cycle.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Agency Receipt Date' ;
    rdfs:comment 'The date on which the health authority officially acknowledged receipt of the submission. Marks the start of the regulatory review clock (e.g., PDUFA clock for FDA, Day 0 for EMA). Distinct from submission_date which is the date filed by the sponsor.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:binderNumber rdf:type rdf:Property ;
    rdfs:label 'Binder Number' ;
    rdfs:comment 'Externally-known, human-readable unique identifier assigned to the regulatory binder or eCTD sequence package (e.g., IND-2024-001, NDA-125678-SEQ003). Used for cross-system reference and health authority correspondence.' ;
    rdfs:domain ind:RegulatoryBinder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binderStatus rdf:type rdf:Property ;
    rdfs:label 'Binder Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory binder. Tracks progression from document assembly through health authority review to final disposition. Values: in_preparation (being assembled), submitted (filed with agency), under_review (agency review in progress), approved (marketing authorization or IND clearance granted), withdrawn (submission retracted).' ;
    rdfs:domain ind:RegulatoryBinder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binderTitle rdf:type rdf:Property ;
    rdfs:label 'Binder Title' ;
    rdfs:comment 'Descriptive title of the regulatory binder or submission package (e.g., \'Initial IND Application for Compound XYZ\', \'NDA Module 5 Clinical Study Reports\'). Used for identification and document management.' ;
    rdfs:domain ind:RegulatoryBinder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binderType rdf:type rdf:Property ;
    rdfs:label 'Binder Type' ;
    rdfs:comment 'Classification of the regulatory binder by submission type. Determines the applicable regulatory framework and required document set. [ENUM-REF-CANDIDATE: IND|NDA|BLA|MAA|CTA|annual_report|IND_amendment|NDA_supplement|BLA_supplement|CTA_amendment — promote to reference product]' ;
    rdfs:domain ind:RegulatoryBinder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completenessPercentage rdf:type rdf:Property ;
    rdfs:label 'Completeness Percentage' ;
    rdfs:comment 'The percentage of required documents that have been collected and filed in this regulatory binder relative to the expected document set per DIA TMF Reference Model. Used for inspection readiness dashboards and regulatory milestone tracking. Range: 0.00 to 100.00.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctdModule rdf:type rdf:Property ;
    rdfs:label 'Ctd Module' ;
    rdfs:comment 'Identifies which CTD module(s) are included in this binder (M1=Administrative/Regional, M2=Summaries, M3=Quality, M4=Nonclinical, M5=Clinical, full=complete dossier). Aligns with ICH M4 CTD structure for eCTD submissions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ectdVersion rdf:type rdf:Property ;
    rdfs:label 'Ectd Version' ;
    rdfs:comment 'The eCTD specification version used to structure and validate this submission (e.g., 3.2.2 for legacy eCTD, 4.0 for next-generation eCTD). Determines the XML backbone schema and validation rules applied during submission compilation.' ;
    rdfs:domain ind:RegulatoryBinder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEctdFormat rdf:type rdf:Property ;
    rdfs:label 'Is Ectd Format' ;
    rdfs:comment 'Indicates whether this regulatory binder is assembled and submitted in eCTD (Electronic Common Technical Document) format as required by ICH M8. True = eCTD format; False = non-eCTD (e.g., paper or NeeS format for legacy submissions).' ;
    rdfs:domain ind:RegulatoryBinder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pdufaTargetDate rdf:type rdf:Property ;
    rdfs:label 'Pdufa Target Date' ;
    rdfs:comment 'The FDA PDUFA goal date by which the agency commits to completing its review and taking action on the submission. Applicable to NDA/BLA submissions to FDA. Used for regulatory timeline management and commercial launch planning.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Submission Date' ;
    rdfs:comment 'The internally planned or target date for submitting the regulatory binder to the health authority. Used for project planning, resource allocation, and regulatory milestone tracking. Compared against actual submission_date to measure submission timeliness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPathway rdf:type rdf:Property ;
    rdfs:label 'Review Pathway' ;
    rdfs:comment 'The regulatory review designation or pathway applicable to this submission (e.g., standard, priority review, accelerated approval, breakthrough therapy, orphan drug, conditional marketing authorization). Determines review timelines and agency commitments.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionMedium rdf:type rdf:Property ;
    rdfs:label 'Submission Medium' ;
    rdfs:comment 'The physical or electronic medium used to deliver the submission to the health authority (electronic = eCTD gateway/portal, paper = physical binders, hybrid = combination). FDA mandates electronic submission for most NDA/BLA/IND filings.' ;
    rdfs:domain ind:RegulatoryBinder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionPortal rdf:type rdf:Property ;
    rdfs:label 'Submission Portal' ;
    rdfs:comment 'The electronic gateway or portal used to transmit the submission to the health authority (e.g., FDA ESG - Electronic Submissions Gateway, EMA eSubmission Gateway, PMDA eCTD Gateway). Used for submission tracking and technical troubleshooting.' ;
    rdfs:domain ind:RegulatoryBinder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAgency rdf:type rdf:Property ;
    rdfs:label 'Target Agency' ;
    rdfs:comment 'The regulatory health authority to which this binder is submitted (e.g., FDA, EMA, PMDA, MHRA). Determines applicable regulatory requirements, submission format, and review timelines. [ENUM-REF-CANDIDATE: FDA|EMA|PMDA|MHRA|TGA|Health_Canada|ANVISA|NMPA|COFEPRIS — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaVaultBinderReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Binder Reference' ;
    rdfs:comment 'The unique document or binder object identifier in Veeva Vault (eTMF/Regulatory module) that corresponds to this regulatory binder record. Enables cross-system traceability between the lakehouse silver layer and the operational system of record.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableGcpGuideline rdf:type rdf:Property ;
    rdfs:label 'Applicable Gcp Guideline' ;
    rdfs:comment 'The specific GCP guideline version or regulation that governs the conduct of this site file. Determines essential document requirements, retention obligations, and inspection readiness criteria.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completenessStatus rdf:type rdf:Property ;
    rdfs:label 'Completeness Status' ;
    rdfs:comment 'Overall completeness assessment of the site file relative to the expected essential documents per ICH GCP Section 8 and the DIA TMF Reference Model. Drives inspection readiness scoring and CRA monitoring activities.' ;
    rdfs:domain ind:SiteFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:custodianRole rdf:type rdf:Property ;
    rdfs:label 'Custodian Role' ;
    rdfs:comment 'Role of the designated custodian responsible for the site file. PI (Principal Investigator) is the accountable party per GCP; CRC (Clinical Research Coordinator) typically manages day-to-day file maintenance.' ;
    rdfs:domain ind:SiteFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegationLogOnFile rdf:type rdf:Property ;
    rdfs:label 'Delegation Log On File' ;
    rdfs:comment 'Indicates whether a current, signed Delegation of Authority (DoA) log is present in the site file, documenting all site staff authorized to perform study-related tasks and their qualifications.' ;
    rdfs:domain ind:SiteFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:electronicVaultPath rdf:type rdf:Property ;
    rdfs:label 'Electronic Vault Path' ;
    rdfs:comment 'Folder path or document library location within Veeva Vault eTMF where the electronic site file is stored. Used for direct navigation and audit trail purposes.' ;
    rdfs:domain ind:SiteFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'File Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned to this site file, used in regulatory correspondence, inspection readiness tracking, and eTMF cross-referencing. Typically generated by the CTMS or Veeva Vault.' ;
    rdfs:domain ind:SiteFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileStatus rdf:type rdf:Property ;
    rdfs:label 'File Status' ;
    rdfs:comment 'Current lifecycle state of the site file. Active indicates the file is in use during the study; Under Review indicates a quality or completeness review is in progress; Archived indicates post-study archival; Closed indicates the site has been closed out; Pending Activation indicates the file is being set up prior to site initiation.' ;
    rdfs:domain ind:SiteFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileType rdf:type rdf:Property ;
    rdfs:label 'File Type' ;
    rdfs:comment 'Classification of the site file by its regulatory and operational purpose. ISF (Investigator Site File) is the primary site-level essential document collection; Regulatory Binder holds IRB/IEC submissions and approvals; Pharmacy Binder tracks investigational product accountability; Laboratory Binder holds lab certifications and normal ranges; Investigator Binder holds PI-specific documents.' ;
    rdfs:domain ind:SiteFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialDisclosureOnFile rdf:type rdf:Property ;
    rdfs:label 'Financial Disclosure On File' ;
    rdfs:comment 'Indicates whether signed financial disclosure forms for the investigator and sub-investigators are present in the site file, as required by FDA regulations to identify potential conflicts of interest.' ;
    rdfs:domain ind:SiteFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:icfOnFile rdf:type rdf:Property ;
    rdfs:label 'Icf On File' ;
    rdfs:comment 'Indicates whether the current, IRB/IEC-approved Informed Consent Form (ICF) is present in the site file. A mandatory essential document per ICH GCP Section 8.2.' ;
    rdfs:domain ind:SiteFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigatorCvOnFile rdf:type rdf:Property ;
    rdfs:label 'Investigator Cv On File' ;
    rdfs:comment 'Indicates whether a current, signed curriculum vitae (CV) for the Principal Investigator and all sub-investigators is present in the site file. A mandatory essential document per ICH GCP Section 8.2.' ;
    rdfs:domain ind:SiteFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irbIecApprovalOnFile rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Approval On File' ;
    rdfs:comment 'Indicates whether the current, valid IRB (Institutional Review Board) or IEC (Independent Ethics Committee) approval letter is present in the site file. A mandatory essential document per ICH GCP Section 8.2.' ;
    rdfs:domain ind:SiteFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labCertificationOnFile rdf:type rdf:Property ;
    rdfs:label 'Lab Certification On File' ;
    rdfs:comment 'Indicates whether current laboratory certifications (e.g., CLIA, CAP) and normal reference ranges for the site\'s clinical laboratory are present in the site file, as required by ICH GCP Section 8.' ;
    rdfs:domain ind:SiteFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent regulatory inspection (FDA, EMA, MHRA, or other authority) at which this site file was reviewed. Used for inspection history tracking and readiness planning.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastInspectionOutcome rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Outcome' ;
    rdfs:comment 'Outcome classification of the most recent regulatory inspection of the site file. NAI (No Action Indicated), VAI (Voluntary Action Indicated), and OAI (Official Action Indicated) are standard FDA classification categories. Drives CAPA requirements and sponsor oversight actions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date on which the most recent completeness review or quality check of the site file was performed, typically by a CRA (Clinical Research Associate) during a monitoring visit or central review.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:missingDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Missing Document Count' ;
    rdfs:comment 'Number of essential documents identified as missing or outstanding from the site file at the time of the last review. Drives follow-up actions and inspection readiness remediation.' ;
    rdfs:domain ind:SiteFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openActionItemCount rdf:type rdf:Property ;
    rdfs:label 'Open Action Item Count' ;
    rdfs:comment 'Number of outstanding action items or findings related to the site file that have not yet been resolved. Derived from monitoring visit findings and quality reviews. Used for inspection readiness and site risk assessment.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:physicalLocation rdf:type rdf:Property ;
    rdfs:label 'Physical Location' ;
    rdfs:comment 'Description of the physical storage location of the site file at the investigational site (e.g., room number, cabinet, shelf). Applicable for paper or hybrid files. Required for inspection readiness and retrieval.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolOnFile rdf:type rdf:Property ;
    rdfs:label 'Protocol On File' ;
    rdfs:comment 'Indicates whether the signed and dated study protocol (and all applicable amendments) is present in the site file. A mandatory essential document per ICH GCP Section 8.' ;
    rdfs:domain ind:SiteFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorReviewCompleted rdf:type rdf:Property ;
    rdfs:label 'Sponsor Review Completed' ;
    rdfs:comment 'Indicates whether the sponsor or CRO has completed a formal review of the site file for completeness and GCP compliance. Required as part of sponsor oversight obligations under ICH GCP Section 5.' ;
    rdfs:domain ind:SiteFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorReviewDate rdf:type rdf:Property ;
    rdfs:label 'Sponsor Review Date' ;
    rdfs:comment 'Date on which the sponsor or CRO completed the most recent formal review of the site file. Supports audit trail and oversight documentation requirements.' ;
    rdfs:domain ind:SiteFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalExpectedDocuments rdf:type rdf:Property ;
    rdfs:label 'Total Expected Documents' ;
    rdfs:comment 'Total count of essential documents expected to be present in the site file based on the study protocol, applicable regulations, and DIA TMF Reference Model requirements for this site and study phase.' ;
    rdfs:domain ind:SiteFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFiledDocuments rdf:type rdf:Property ;
    rdfs:label 'Total Filed Documents' ;
    rdfs:comment 'Actual count of documents currently filed and verified within the site file. Used in conjunction with total_expected_documents to derive completeness metrics.' ;
    rdfs:domain ind:SiteFile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteFileDocumentId rdf:type rdf:Property ;
    rdfs:label 'Site File Document Id' ;
    rdfs:comment 'Unique surrogate identifier for each site file document association record in the Investigator Site File (ISF). Primary key for this entity.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SiteFileDocument .

ind:supersededByDocumentSiteFileDocumentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Document Site File Document Id' ;
    rdfs:comment 'Reference to the newer document record that supersedes this filing when filing_status is \'superseded\'. Enables version chain traceability within the ISF.' ;
    rdfs:domain ind:SiteFileDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SiteFileDocument .

ind:discrepancyDescription rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Description' ;
    rdfs:comment 'Description of any discrepancy identified during SDV or document review for this ISF filing (e.g., incorrect version on file, missing signature, illegible copy). Populated when sdv_status is \'discrepancy_found\'.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Resolution Date' ;
    rdfs:comment 'The date on which a previously identified document discrepancy was resolved and the ISF filing was corrected or updated.' ;
    rdfs:domain ind:SiteFileDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date the document was authored, issued, or approved, as stated on the document itself. Distinct from the filing date. Used to confirm the document is the current effective version.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentSourceType rdf:type rdf:Property ;
    rdfs:label 'Document Source Type' ;
    rdfs:comment 'Indicates the nature of the document copy filed in the ISF: original document, certified copy, scanned copy, fax copy, or electronic original. Critical for GCP compliance and inspection readiness per ALCOA+ principles.' ;
    rdfs:domain ind:SiteFileDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedFilingDate rdf:type rdf:Property ;
    rdfs:label 'Expected Filing Date' ;
    rdfs:comment 'The target or deadline date by which a missing or pending document is expected to be filed in the ISF. Used for follow-up tracking and monitoring visit preparation.' ;
    rdfs:domain ind:SiteFileDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'The date the document was physically or electronically filed into the Investigator Site File (ISF). Supports timeliness tracking and inspection readiness assessment.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingMethod rdf:type rdf:Property ;
    rdfs:label 'Filing Method' ;
    rdfs:comment 'Indicates whether the document was filed electronically (eTMF via Veeva Vault), in paper form, or as a hybrid (paper original with electronic scan). Relevant for 21 CFR Part 11 compliance.' ;
    rdfs:domain ind:SiteFileDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingNotes rdf:type rdf:Property ;
    rdfs:label 'Filing Notes' ;
    rdfs:comment 'Free-text notes or comments recorded by the CRA or document controller regarding this specific document filing, such as special circumstances, follow-up instructions, or contextual observations.' ;
    rdfs:domain ind:SiteFileDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current filing status of the document within the ISF. Indicates whether the document has been filed, is missing, is not applicable for this site, is overdue, has been superseded by a newer version, or is pending review. [ENUM-REF-CANDIDATE: filed|missing|not_applicable|overdue|superseded|pending_review — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isfSectionCode rdf:type rdf:Property ;
    rdfs:label 'Isf Section Code' ;
    rdfs:comment 'The DIA TMF Reference Model section/zone code designating where this document is filed within the Investigator Site File (ISF) structure (e.g., \'05.001\' for Protocol and Amendments).' ;
    rdfs:domain ind:SiteFileDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isfSectionName rdf:type rdf:Property ;
    rdfs:label 'Isf Section Name' ;
    rdfs:comment 'Human-readable name of the ISF section or tab where this document is filed, corresponding to the DIA TMF Reference Model artifact classification (e.g., \'Informed Consent Forms\', \'IRB/IEC Approvals\').' ;
    rdfs:domain ind:SiteFileDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:missingDocumentReason rdf:type rdf:Property ;
    rdfs:label 'Missing Document Reason' ;
    rdfs:comment 'Explanation for why a required document is currently missing from the ISF. Captured to support follow-up actions and inspection readiness tracking.' ;
    rdfs:domain ind:SiteFileDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notApplicableReason rdf:type rdf:Property ;
    rdfs:label 'Not Applicable Reason' ;
    rdfs:comment 'Justification text explaining why a document is marked as \'not_applicable\' for this site. Required when filing_status is \'not_applicable\' to support inspection readiness and audit trail.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicabilityPhase rdf:type rdf:Property ;
    rdfs:label 'Applicability Phase' ;
    rdfs:comment 'Clinical trial phase(s) for which this artifact is applicable per the DIA TMF Reference Model (e.g., \'Phase I\', \'Phase II\', \'Phase III\', \'Phase IV\', \'All Phases\', \'Phase I/II\'). Enables phase-specific TMF completeness assessments and filing guidance. [ENUM-REF-CANDIDATE: Phase I|Phase II|Phase III|Phase IV|Phase I/II|Phase II/III|All Phases — promote to reference product]' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archivalTrigger rdf:type rdf:Property ;
    rdfs:label 'Archival Trigger' ;
    rdfs:comment 'The regulatory or business event that triggers the start of the retention period countdown for this artifact type (e.g., \'Database Lock\', \'Marketing Authorization Approval\', \'Study Termination\', \'Last Patient Last Visit\'). Used in archival scheduling and document lifecycle management within the eTMF system.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artifactAbbreviation rdf:type rdf:Property ;
    rdfs:label 'Artifact Abbreviation' ;
    rdfs:comment 'Short-form abbreviation or acronym for the artifact type as used in the DIA TMF Reference Model and industry practice (e.g., \'IB\' for Investigator Brochure, \'ICF\' for Informed Consent Form, \'SAP\' for Statistical Analysis Plan). Used in compact reporting views and eTMF system labels.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artifactCode rdf:type rdf:Property ;
    rdfs:label 'Artifact Code' ;
    rdfs:comment 'Standardized DIA TMF Reference Model artifact code in Zone.Section.Artifact format (e.g., 01.01.01 for Zone 1, Section 1, Artifact 1 — Protocol). Serves as the externally-recognized business identifier for the artifact type across sponsors, CROs, and regulatory agencies.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artifactDescription rdf:type rdf:Property ;
    rdfs:label 'Artifact Description' ;
    rdfs:comment 'Detailed narrative description of the artifact type, its purpose within the TMF, and the business context in which it is generated or collected. Provides filing guidance to Clinical Research Associates (CRAs), Clinical Research Coordinators (CRCs), and TMF managers on what constitutes an acceptable document for this artifact slot.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artifactName rdf:type rdf:Property ;
    rdfs:label 'Artifact Name' ;
    rdfs:comment 'Official DIA TMF Reference Model name for the artifact type (e.g., \'Protocol\', \'Investigator Brochure\', \'Informed Consent Form\'). This is the human-readable identity label used in TMF completeness reports, inspection readiness dashboards, and eTMF system configuration.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:artifactNumber rdf:type rdf:Property ;
    rdfs:label 'Artifact Number' ;
    rdfs:comment 'Sequential numeric identifier of the artifact within its section per the DIA TMF Reference Model (e.g., Artifact 01 within Section 1.1). Provides the third and most granular level of the TMF hierarchy. Used in combination with zone_number and section_number to uniquely locate a document type in the TMF structure.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:artifactStatus rdf:type rdf:Property ;
    rdfs:label 'Artifact Status' ;
    rdfs:comment 'Current lifecycle status of this artifact taxonomy record within the DIA TMF Reference Model (Active = currently in use, Deprecated = removed from the model, Superseded = replaced by a newer artifact definition, Draft = under review for inclusion). Ensures that TMF completeness assessments use only current, valid artifact definitions.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdiscControlledTerm rdf:type rdf:Property ;
    rdfs:label 'Cdisc Controlled Term' ;
    rdfs:comment 'The corresponding CDISC controlled terminology code or term for this artifact type where applicable (e.g., CDISC TMF controlled terminology). Supports CDISC-compliant data submissions and cross-system interoperability between the eTMF and EDC/SDTM data packages submitted to regulatory agencies.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completenessWeight rdf:type rdf:Property ;
    rdfs:label 'Completeness Weight' ;
    rdfs:comment 'Numeric weight assigned to this artifact type for TMF completeness index calculation (expressed as a percentage or score contribution). Required artifacts typically carry higher weights than Recommended or Optional. Used in the TMF completeness KPI dashboard to produce a weighted completeness score for inspection readiness reporting.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diaReferenceModelVersion rdf:type rdf:Property ;
    rdfs:label 'Dia Reference Model Version' ;
    rdfs:comment 'Version of the DIA TMF Reference Model from which this artifact definition is sourced (e.g., \'v3.2\', \'v3.1\'). Enables version-controlled TMF taxonomy management and supports migration assessments when the DIA releases updated Reference Model versions. Critical for audit trail and regulatory inspection documentation.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentOwnerRole rdf:type rdf:Property ;
    rdfs:label 'Document Owner Role' ;
    rdfs:comment 'Standard organizational role responsible for generating, maintaining, and filing documents of this artifact type (e.g., \'Sponsor\', \'Principal Investigator\', \'CRA\', \'CRC\', \'Biostatistician\', \'Regulatory Affairs\'). Used to assign TMF filing responsibilities and drive workflow routing in the eTMF system.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedTiming rdf:type rdf:Property ;
    rdfs:label 'Expected Timing' ;
    rdfs:comment 'Describes the expected timing for filing this artifact relative to trial milestones (e.g., \'Before First Patient First Visit\', \'Within 30 days of site initiation\', \'At study close-out\', \'Ongoing throughout trial\'). Used to assess timeliness of TMF filing and flag overdue documents in inspection readiness dashboards.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingGuidance rdf:type rdf:Property ;
    rdfs:label 'Filing Guidance' ;
    rdfs:comment 'Operational instructions for TMF staff on how, when, and where to file documents of this artifact type within the eTMF system (Veeva Vault). Includes guidance on acceptable document formats, naming conventions, version control expectations, and timing relative to trial milestones. Supports ALCOA+ compliance and inspection readiness.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ichGcpReference rdf:type rdf:Property ;
    rdfs:label 'Ich Gcp Reference' ;
    rdfs:comment 'Specific ICH E6(R2) GCP guideline section(s) that mandate or reference this artifact type (e.g., \'ICH E6(R2) Section 8.2.1\', \'ICH E6(R2) Section 8.3.6\'). Provides the regulatory basis for the artifact\'s required status and supports inspection readiness documentation and regulatory query responses.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCountrySpecific rdf:type rdf:Property ;
    rdfs:label 'Is Country Specific' ;
    rdfs:comment 'Indicates whether this artifact type requires a separate instance per country in which the trial is conducted (True) or is filed at the global trial level (False). Drives country-level TMF completeness calculations and supports multi-jurisdictional regulatory inspection readiness.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEssentialDocument rdf:type rdf:Property ;
    rdfs:label 'Is Essential Document' ;
    rdfs:comment 'Indicates whether this artifact type is classified as an Essential Document per ICH E6(R2) Section 8 (True). Essential documents are those that individually and collectively permit evaluation of the conduct of a trial and the quality of the data produced. This flag drives the core TMF completeness index calculation.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInspectionCritical rdf:type rdf:Property ;
    rdfs:label 'Is Inspection Critical' ;
    rdfs:comment 'Indicates whether this artifact type is considered critical during regulatory inspections by FDA, EMA, MHRA, PMDA, or other health authorities (True). Inspection-critical artifacts are prioritized in pre-inspection TMF readiness reviews and gap remediation activities. Absence of inspection-critical artifacts typically results in a major GCP finding.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInvestigatorHeld rdf:type rdf:Property ;
    rdfs:label 'Is Investigator Held' ;
    rdfs:comment 'Indicates whether this artifact type is held in the Investigator Site File (ISF) at the investigational site (True). Supports site file completeness assessments during monitoring visits (SDV/SIV/COV) and regulatory inspections. CRAs use this flag to verify site file completeness against the DIA TMF Reference Model.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSiteSpecific rdf:type rdf:Property ;
    rdfs:label 'Is Site Specific' ;
    rdfs:comment 'Indicates whether this artifact type requires a separate instance per investigational site (True) or is filed once at the trial or country level (False). Drives the expected document count calculation in TMF completeness metrics — site-specific artifacts multiply by the number of active sites.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSponsorHeld rdf:type rdf:Property ;
    rdfs:label 'Is Sponsor Held' ;
    rdfs:comment 'Indicates whether this artifact type is held in the Sponsor\'s TMF (True) as opposed to the Investigator Site File (ISF) or a shared location. Supports TMF structure design, responsibility allocation between sponsor and investigator, and completeness tracking across the distributed TMF.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Additional regulatory citations beyond ICH GCP that reference or mandate this artifact type, including FDA 21 CFR Part 312, EU CTR 536/2014, EMA GCP Guideline, MHRA GCP Guidance, or PMDA requirements. Supports multi-jurisdictional TMF compliance and inspection readiness for global trials.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementClassification rdf:type rdf:Property ;
    rdfs:label 'Requirement Classification' ;
    rdfs:comment 'DIA TMF Reference Model classification indicating whether this artifact is Required (mandatory per ICH GCP), Recommended (best practice), or Optional (situational) for a compliant TMF. Drives TMF completeness scoring, gap analysis, and inspection readiness assessments. Required artifacts missing from the TMF constitute a GCP finding.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresElectronicSignature rdf:type rdf:Property ;
    rdfs:label 'Requires Electronic Signature' ;
    rdfs:comment 'Indicates whether documents of this artifact type require a compliant electronic signature per 21 CFR Part 11 or EU eIDAS standards (True). Drives e-signature workflow configuration in Veeva Vault eTMF and ensures compliance with electronic records and signatures regulations.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresWetSignature rdf:type rdf:Property ;
    rdfs:label 'Requires Wet Signature' ;
    rdfs:comment 'Indicates whether documents of this artifact type require a handwritten (wet) signature as opposed to an electronic signature (True). Relevant for jurisdictions or document types where electronic signatures are not accepted. Drives document collection workflows and compliance checks in the eTMF system.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sectionName rdf:type rdf:Property ;
    rdfs:label 'Section Name' ;
    rdfs:comment 'Descriptive name of the TMF section within its zone per the DIA TMF Reference Model (e.g., \'Trial Oversight\', \'Central Monitoring\', \'Protocol and Amendments\'). Used in TMF index navigation, filing guidance, and inspection readiness dashboards.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectionNumber rdf:type rdf:Property ;
    rdfs:label 'Section Number' ;
    rdfs:comment 'Numeric section identifier within the TMF zone per the DIA TMF Reference Model (e.g., \'1.1\' for Trial Management — Trial Oversight). Provides the second level of the three-tier TMF hierarchy (Zone > Section > Artifact) used for document filing and completeness assessment.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmfLevel rdf:type rdf:Property ;
    rdfs:label 'Tmf Level' ;
    rdfs:comment 'Indicates the organizational level at which this artifact is filed within the TMF structure: Trial-level (applies to the entire study), Country-level (applies to a specific country), or Site-level (applies to an individual investigational site). Critical for multi-site, multi-country trial TMF organization and completeness tracking per DIA TMF Reference Model.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialPhaseEnd rdf:type rdf:Property ;
    rdfs:label 'Trial Phase End' ;
    rdfs:comment 'The trial lifecycle phase by which this artifact should be finalized and filed (Pre-Trial, Start-Up, Conduct, Close-Out, Post-Trial). Defines the closing boundary of the filing window for this artifact type and supports overdue document identification in TMF completeness tracking.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialPhaseStart rdf:type rdf:Property ;
    rdfs:label 'Trial Phase Start' ;
    rdfs:comment 'The trial lifecycle phase during which this artifact is first expected to be filed (Pre-Trial, Start-Up, Conduct, Close-Out, Post-Trial). Used in conjunction with trial_phase_end to define the filing window for this artifact type and to drive milestone-based TMF completeness assessments.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaVaultDocumentSubtype rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Document Subtype' ;
    rdfs:comment 'The corresponding document subtype classification as configured in Veeva Vault eTMF. Provides the second level of the Veeva Vault document type hierarchy, enabling precise mapping from DIA TMF Reference Model artifacts to the eTMF system\'s document classification taxonomy for automated filing and completeness calculations.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaVaultDocumentType rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Document Type' ;
    rdfs:comment 'The corresponding document type classification as configured in Veeva Vault eTMF, the operational system of record for TMF management. Enables direct mapping between the DIA TMF Reference Model taxonomy and the Veeva Vault document type hierarchy for automated TMF completeness tracking and filing workflow routing.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneName rdf:type rdf:Property ;
    rdfs:label 'Zone Name' ;
    rdfs:comment 'Descriptive name of the TMF zone as defined in the DIA TMF Reference Model (e.g., \'Trial Management\', \'Central Trial Documents\', \'Regulatory\', \'IRB/IEC and Other Approvals\', \'Site Management\', \'Investigational Product\', \'Safety Reporting\'). Used in TMF index views and inspection readiness reports.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneNumber rdf:type rdf:Property ;
    rdfs:label 'Zone Number' ;
    rdfs:comment 'Numeric identifier of the TMF zone to which this artifact belongs per the DIA TMF Reference Model (e.g., Zone 1 = Trial Management, Zone 2 = Central Trial Documents, Zone 3 = Regulatory, Zone 4 = IRB/IEC and Other Approvals, Zone 5 = Site Management, Zone 6 = Investigational Product, Zone 7 = Safety Reporting). Drives TMF structural organization and completeness tracking.' ;
    rdfs:domain ind:TmfArtifact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assessed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: TMF completeness assessments must be traceable to qualified employees for regulatory inspection. The assessor\'s GCP certification and role must be verifiable. Replaces denormalized \'assessed_by\' text ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:priorAssessmentTmfCompletenessId rdf:type rdf:Property ;
    rdfs:label 'Prior Assessment Tmf Completeness Id' ;
    rdfs:comment 'Reference to the immediately preceding TMF completeness assessment record for this study, enabling trend analysis and completeness trajectory tracking over time.' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TmfCompleteness .

ind:assessedByRole rdf:type rdf:Property ;
    rdfs:label 'Assessed By Role' ;
    rdfs:comment 'Functional role of the individual who performed the TMF completeness assessment, such as TMF Manager, QA Specialist, Clinical Research Associate (CRA), Study Manager, or Regulatory Affairs.' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Period End Date' ;
    rdfs:comment 'The end date of the period covered by this TMF completeness assessment. For periodic assessments, this defines the end of the reporting window.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Period Start Date' ;
    rdfs:comment 'The start date of the period covered by this TMF completeness assessment. For periodic assessments, this defines the beginning of the reporting window.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentReference rdf:type rdf:Property ;
    rdfs:label 'Assessment Reference' ;
    rdfs:comment 'Externally-known unique reference number or code assigned to this completeness assessment, used for tracking and cross-referencing in Veeva Vault eTMF and inspection-readiness reports.' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completenessTargetPct rdf:type rdf:Property ;
    rdfs:label 'Completeness Target Pct' ;
    rdfs:comment 'The minimum completeness percentage threshold required for this study at this point in time, as defined in the TMF plan or sponsor SOP. Used to determine whether the study is inspection-ready.' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completenessTrend rdf:type rdf:Property ;
    rdfs:label 'Completeness Trend' ;
    rdfs:comment 'Directional trend of TMF completeness compared to the prior assessment: improving (percentage increased), stable (no significant change), declining (percentage decreased), or not_applicable (first assessment for this study).' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalDocumentGapCount rdf:type rdf:Property ;
    rdfs:label 'Critical Document Gap Count' ;
    rdfs:comment 'Number of missing or overdue artifacts classified as \'critical\' per the DIA TMF Reference Model or sponsor TMF plan (e.g., protocol, ethics approval, signed ICF). Critical gaps pose the highest inspection risk.' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:etmfSystemSnapshotReference rdf:type rdf:Property ;
    rdfs:label 'Etmf System Snapshot Reference' ;
    rdfs:comment 'The unique identifier of the eTMF system snapshot or report generated in Veeva Vault at the time of this assessment. Enables traceability back to the source system record for audit purposes.' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedArtifactCount rdf:type rdf:Property ;
    rdfs:label 'Expected Artifact Count' ;
    rdfs:comment 'Total number of TMF artifacts (documents) expected to be filed for this study at the time of assessment, based on the applicable DIA TMF Reference Model zones and study-specific TMF plan.' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:filedArtifactCount rdf:type rdf:Property ;
    rdfs:label 'Filed Artifact Count' ;
    rdfs:comment 'Total number of TMF artifacts that have been filed (uploaded and indexed) in the eTMF system (Veeva Vault) at the time of assessment.' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingsSummary rdf:type rdf:Property ;
    rdfs:label 'Findings Summary' ;
    rdfs:comment 'Free-text narrative summarizing the key findings, gaps, and observations identified during this TMF completeness assessment. Supports inspection-readiness reporting and CAPA initiation.' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReadinessRisk rdf:type rdf:Property ;
    rdfs:label 'Inspection Readiness Risk' ;
    rdfs:comment 'Qualitative risk rating for inspection readiness based on completeness gaps, overdue artifacts, and zone-level deficiencies. Supports risk-based TMF monitoring and escalation decisions.' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:missingArtifactCount rdf:type rdf:Property ;
    rdfs:label 'Missing Artifact Count' ;
    rdfs:comment 'Number of expected TMF artifacts that have not yet been filed at the time of assessment. Calculated as expected_artifact_count minus filed_artifact_count, excluding overdue artifacts.' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextAssessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Due Date' ;
    rdfs:comment 'The scheduled due date for the next TMF completeness assessment for this study, based on the TMF plan frequency (e.g., monthly, quarterly). Supports proactive inspection readiness monitoring.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallCompletenessPct rdf:type rdf:Property ;
    rdfs:label 'Overall Completeness Pct' ;
    rdfs:comment 'The overall TMF completeness percentage calculated as (number of filed artifacts / number of expected artifacts) × 100. Principal quantitative KPI for inspection readiness monitoring. Expressed as a percentage with two decimal places.' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overdueArtifactCount rdf:type rdf:Property ;
    rdfs:label 'Overdue Artifact Count' ;
    rdfs:comment 'Number of TMF artifacts that are past their required filing deadline (per the TMF plan or DIA TMF Reference Model timelines) and have not yet been filed. A key inspection-readiness risk indicator.' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pendingReviewArtifactCount rdf:type rdf:Property ;
    rdfs:label 'Pending Review Artifact Count' ;
    rdfs:comment 'Number of TMF artifacts that have been filed but are awaiting QC review or approval in Veeva Vault. These are filed but not yet finalized, and may affect the effective completeness rate.' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rejectedArtifactCount rdf:type rdf:Property ;
    rdfs:label 'Rejected Artifact Count' ;
    rdfs:comment 'Number of TMF artifacts that were filed but subsequently rejected during QC review (e.g., wrong version, illegible, incorrect metadata). Rejected artifacts are not counted as filed for completeness purposes.' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remediationActionRequired rdf:type rdf:Property ;
    rdfs:label 'Remediation Action Required' ;
    rdfs:comment 'Indicates whether this assessment identified gaps requiring formal remediation actions (e.g., CAPA initiation, escalation to study team). True = remediation required; False = no remediation required.' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:studyStatusAtAssessment rdf:type rdf:Property ;
    rdfs:label 'Study Status At Assessment' ;
    rdfs:comment 'The operational status of the clinical study at the time this TMF completeness assessment was conducted. Used to contextualize completeness expectations — e.g., a study in close-out has higher completeness requirements than one in start-up.' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zone1CompletenessPct rdf:type rdf:Property ;
    rdfs:label 'Zone 1 Completeness Pct' ;
    rdfs:comment 'Completeness percentage for DIA TMF Reference Model Zone 1 (Trial Management), covering documents related to trial management, oversight, and administration.' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zone2CompletenessPct rdf:type rdf:Property ;
    rdfs:label 'Zone 2 Completeness Pct' ;
    rdfs:comment 'Completeness percentage for DIA TMF Reference Model Zone 2 (Central Trial Documents), covering the protocol, amendments, investigator brochure, and other central study documents.' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zone3CompletenessPct rdf:type rdf:Property ;
    rdfs:label 'Zone 3 Completeness Pct' ;
    rdfs:comment 'Completeness percentage for DIA TMF Reference Model Zone 3 (Regulatory), covering regulatory submissions, approvals, and correspondence with health authorities such as FDA, EMA, and PMDA.' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zone4CompletenessPct rdf:type rdf:Property ;
    rdfs:label 'Zone 4 Completeness Pct' ;
    rdfs:comment 'Completeness percentage for DIA TMF Reference Model Zone 4 (IRB/IEC and Other Approvals), covering ethics committee approvals, informed consent forms (ICF), and other site-level approvals.' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zone5CompletenessPct rdf:type rdf:Property ;
    rdfs:label 'Zone 5 Completeness Pct' ;
    rdfs:comment 'Completeness percentage for DIA TMF Reference Model Zone 5 (Site Management), covering site selection, initiation, monitoring, and close-out documents.' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zone6CompletenessPct rdf:type rdf:Property ;
    rdfs:label 'Zone 6 Completeness Pct' ;
    rdfs:comment 'Completeness percentage for DIA TMF Reference Model Zone 6 (Investigational Product), covering IP manufacturing, labelling, shipping, accountability, and destruction records.' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zone7CompletenessPct rdf:type rdf:Property ;
    rdfs:label 'Zone 7 Completeness Pct' ;
    rdfs:comment 'Completeness percentage for DIA TMF Reference Model Zone 7 (Safety Reporting), covering SAE reports, SUSARs, DSURs, and safety communications filed in the TMF.' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zone8CompletenessPct rdf:type rdf:Property ;
    rdfs:label 'Zone 8 Completeness Pct' ;
    rdfs:comment 'Completeness percentage for DIA TMF Reference Model Zone 8 (Statistics and Data Management), covering the Statistical Analysis Plan (SAP), Data Management Plan (DMP), randomization documentation, and database lock records.' ;
    rdfs:domain ind:TmfCompleteness ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:archiveDate rdf:type rdf:Property ;
    rdfs:label 'Archive Date' ;
    rdfs:comment 'The date on which this document was formally transferred to the long-term archive. Null if the document has not yet been archived.' ;
    rdfs:domain ind:TmfDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:archiveLocation rdf:type rdf:Property ;
    rdfs:label 'Archive Location' ;
    rdfs:comment 'The physical or electronic location identifier where the archived document is stored (e.g., archive facility name, vault path, or storage reference code). Required for document retrieval during regulatory inspections.' ;
    rdfs:domain ind:TmfDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityClassification rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Classification' ;
    rdfs:comment 'Data classification level assigned to this document per the organization\'s information security policy. Restricted = highest sensitivity (e.g., patient data, proprietary formulations); Confidential = sponsor/CRO sensitive; Internal = internal use only; Public = publicly disclosable.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentOrigin rdf:type rdf:Property ;
    rdfs:label 'Document Origin' ;
    rdfs:comment 'Identifies the originating party or organization type that produced this document (e.g., Sponsor, CRO, Site, Regulatory Authority, Laboratory, Vendor). Used for document provenance tracking and TMF completeness analysis. [ENUM-REF-CANDIDATE: sponsor|cro|site|regulatory_authority|laboratory|vendor|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TmfDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isArchived rdf:type rdf:Property ;
    rdfs:label 'Is Archived' ;
    rdfs:comment 'Indicates whether this document has been formally transferred to long-term archival storage per the study close-out and archival process. Archived documents are read-only and subject to retention period controls.' ;
    rdfs:domain ind:TmfDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGcpRequired rdf:type rdf:Property ;
    rdfs:label 'Is Gcp Required' ;
    rdfs:comment 'Indicates whether this document is mandated by ICH GCP guidelines as a required TMF document. Used for TMF completeness assessment and inspection readiness reporting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pageCount rdf:type rdf:Property ;
    rdfs:label 'Page Count' ;
    rdfs:comment 'The total number of pages in the document. Used for document completeness verification, quality control checks, and archival metadata.' ;
    rdfs:domain ind:TmfDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Review Status' ;
    rdfs:comment 'The outcome of the quality control review performed on this document to verify completeness, accuracy, and compliance with ALCOA+ principles and GCP requirements. Drives inspection readiness and CAPA workflows.' ;
    rdfs:domain ind:TmfDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityReviewer rdf:type rdf:Property ;
    rdfs:label 'Quality Reviewer' ;
    rdfs:comment 'Name or user identifier of the individual who performed the most recent quality control review of this document. Supports audit trail requirements under GCP and 21 CFR Part 11.' ;
    rdfs:domain ind:TmfDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Sponsor Document Reference' ;
    rdfs:comment 'The sponsor\'s own document reference number or identifier for this document, as assigned by the pharmaceutical or biotech sponsor. Used for cross-referencing between CRO eTMF and sponsor document management systems.' ;
    rdfs:domain ind:TmfDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmfDocumentDescription rdf:type rdf:Property ;
    rdfs:label 'Tmf Document Description' ;
    rdfs:comment 'Free-text narrative description of the document\'s content, purpose, or scope. Provides additional context beyond the document title for search, classification, and review purposes.' ;
    rdfs:domain ind:TmfDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vaultLibrary rdf:type rdf:Property ;
    rdfs:label 'Vault Library' ;
    rdfs:comment 'The Veeva Vault library or vault name where this document is stored (e.g., \'eTMF Vault\', \'RIM Vault\', \'QMS Vault\'). Relevant for organizations using multiple Vault instances across eTMF, regulatory, and quality domains.' ;
    rdfs:domain ind:TmfDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionDate rdf:type rdf:Property ;
    rdfs:label 'Version Date' ;
    rdfs:comment 'The date on which the current version of the document was authored or formally dated, as stated on the document itself. Distinct from the approval date or effective date.' ;
    rdfs:domain ind:TmfDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualId rdf:type rdf:Property ;
    rdfs:label 'Accrual Id' ;
    rdfs:comment 'Unique system-generated identifier for each financial accrual record posted in the clinical trial accounting system (SAP S/4HANA FI module). Serves as the primary key for this entity.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementInvestigatorGrantId rdf:type rdf:Property ;
    rdfs:label 'Agreement Investigator Grant Id' ;
    rdfs:comment 'Foreign key linking to agreement.investigator_grant. Business justification: Investigator grant accruals are booked monthly based on site activity against the grant schedule. Linking accruals to the specific investigator grant enables grant spend vs. accrual reconciliation — a' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestigatorGrant .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Period-end accruals are posted to a specific cost center in SAP FI. accrual.cost_center_code is a denormalized string; adding cost_center_id FK normalizes this to the authoritative cost_center master.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Accruals are posted to a GL account for period-end cost recognition. accrual.gl_account_code is a denormalized string; adding gl_account_id FK normalizes this to the authoritative gl_account master.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:icsrId rdf:type rdf:Property ;
    rdfs:label 'Icsr Id' ;
    rdfs:comment 'Foreign key linking to safety.icsr. Business justification: ICSR submissions to regulatory agencies (FDA, EMA) generate direct billable costs — regulatory affairs staff time, submission fees, translation. Finance accrues per-submission costs and must link each' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Icsr .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Reference to the actual vendor or site invoice that settles this accrual once received and processed. Populated during the accrual-to-actual reconciliation process; null if no invoice has been matched yet.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SponsorInvoice .

ind:monitoringVisitId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Visit Id' ;
    rdfs:comment 'Foreign key linking to monitoring.monitoring_visit. Business justification: Monitoring cost accruals (CRA fees, travel, per-visit charges) are substantiated by completed monitoring visits. Finance accrual records reference the specific visit to support SOX-controlled accrual ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MonitoringVisit .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to finance.purchase_order. Business justification: Accruals in clinical trials are frequently tied to open purchase orders (goods/services received but not yet invoiced). accrual.purchase_order_number is a denormalized string reference; adding purchas' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:seriousAdverseEventId rdf:type rdf:Property ;
    rdfs:label 'Serious Adverse Event Id' ;
    rdfs:comment 'Foreign key linking to safety.serious_adverse_event. Business justification: SAEs trigger direct, trackable costs: expedited narrative writing, medical monitor review, regulatory submission fees. Finance accrues these SAE-driven costs per event. Clinical finance analysts must ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SeriousAdverseEvent .

ind:studyBudgetId rdf:type rdf:Property ;
    rdfs:label 'Study Budget Id' ;
    rdfs:comment 'Reference to the study or site budget record against which this accrual is tracked. Enables budget-to-actual variance analysis and financial forecasting for the clinical trial.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudyBudget .

ind:vendorId rdf:type rdf:Property ;
    rdfs:label 'Vendor Id' ;
    rdfs:comment 'Reference to the SAP vendor master record for the external service provider (e.g., central laboratory, CRO sub-contractor, courier) whose services are being accrued. Applicable for pass-through and third-party service accruals.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:vendorInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.vendor_invoice. Business justification: accrual.invoice_id (BIGINT) is an unlinked FK column referencing a vendor invoice. Accruals are often created against vendor invoices received but not yet posted, or to reverse when invoices arrive. L' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorInvoice .

ind:visitReportId rdf:type rdf:Property ;
    rdfs:label 'Visit Report Id' ;
    rdfs:comment 'Foreign key linking to monitoring.visit_report. Business justification: Approved visit reports are primary supporting documentation for period-end monitoring cost accruals. Finance teams use the visit report as the accrual substantiation document, linking the accrual entr' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VisitReport .

ind:accrualDescription rdf:type rdf:Property ;
    rdfs:label 'Accrual Description' ;
    rdfs:comment 'Free-text narrative describing the nature and business justification of the accrual entry. Provides context for auditors, finance reviewers, and SOX controls testing. Should reference the specific service, period, and study activity being accrued.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualNumber rdf:type rdf:Property ;
    rdfs:label 'Accrual Number' ;
    rdfs:comment 'Externally-visible, human-readable business identifier for the accrual entry, used in financial reporting, audit trails, and cross-system reconciliation. Follows the format ACR-YYYY-NNNNNN.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualStatus rdf:type rdf:Property ;
    rdfs:label 'Accrual Status' ;
    rdfs:comment 'Current workflow state of the accrual entry within the period-end close process. Draft entries are under preparation; posted entries have been recorded in the GL; reversed entries have been offset; adjusted entries have been corrected; approved entries have passed financial review; cancelled entries are void.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualType rdf:type rdf:Property ;
    rdfs:label 'Accrual Type' ;
    rdfs:comment 'Classification of the nature of the clinical trial cost being accrued. Drives GL account mapping and financial reporting categorization. [ENUM-REF-CANDIDATE: site_services|cra_monitoring|lab_fees|investigator_grant|patient_stipend|pass_through|data_management — promote to reference product]' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The gross accrual amount in the transaction currency representing the estimated clinical trial cost incurred but not yet invoiced for the accrual period. This is the primary financial figure for the accrual entry.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountUsd rdf:type rdf:Property ;
    rdfs:label 'Amount Usd' ;
    rdfs:comment 'The accrual amount converted to US Dollars (USD) using the period-end exchange rate. Used for consolidated financial reporting and sponsor invoicing in USD-denominated contracts.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:basis rdf:type rdf:Property ;
    rdfs:label 'Basis' ;
    rdfs:comment 'The methodology used to calculate and recognize the accrual amount. Enrollment-based accruals are driven by subject counts; visit-based by completed protocol visits; milestone-based by contractual deliverable completion; time-based by elapsed period; unit-based by service units delivered.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'The method used to derive the accrual amount. Manual entries are prepared by finance staff; system_calculated entries are generated by SAP S/4HANA accrual engine; spreadsheet_upload entries are imported from Excel models; ctms_derived entries are sourced from Oracle Siebel CTMS activity data; edl_feed entries originate from the enterprise data lake.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'The SAP S/4HANA company code representing the legal entity within the CRO organization that is recognizing the accrual. Enables multi-entity financial consolidation and intercompany accrual management.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeAccrualAmount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Accrual Amount' ;
    rdfs:comment 'The total accrual amount accumulated from study start through the current accrual period for the same cost category and study/site combination. Supports budget-to-actual tracking and study-level financial forecasting.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The foreign currency exchange rate applied to convert the transaction currency accrual amount to USD for consolidated reporting. Sourced from SAP S/4HANA exchange rate tables at period-end.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year (YYYY) in which the accrual is recognized. Used for annual financial reporting, budget-to-actual analysis, and year-end close procedures in SAP S/4HANA.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAutoReversal rdf:type rdf:Property ;
    rdfs:label 'Is Auto Reversal' ;
    rdfs:comment 'Indicates whether the accrual is configured for automatic reversal in SAP S/4HANA on the reversal date. True = automatic reversal scheduled; False = manual reversal required.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSoxControlled rdf:type rdf:Property ;
    rdfs:label 'Is Sox Controlled' ;
    rdfs:comment 'Indicates whether this accrual entry is subject to Sarbanes-Oxley (SOX) internal controls testing and documentation requirements. True = SOX-controlled accrual requiring documented review and approval; False = non-SOX accrual.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:period rdf:type rdf:Property ;
    rdfs:label 'Period' ;
    rdfs:comment 'The accounting period (YYYY-MM) for which the accrual is recognized. Determines the financial reporting period in which the clinical trial cost is recorded, critical for period-end close accuracy and SOX compliance.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date on which the accrual journal entry was posted to the SAP S/4HANA General Ledger. This is the principal business event date for the accrual transaction and determines the accounting period assignment.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preparedBy rdf:type rdf:Property ;
    rdfs:label 'Prepared By' ;
    rdfs:comment 'Name or employee identifier of the finance analyst or accountant who prepared and submitted the accrual entry. Required for SOX segregation of duties and audit trail documentation.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorPeriodAccrualAmount rdf:type rdf:Property ;
    rdfs:label 'Prior Period Accrual Amount' ;
    rdfs:comment 'The accrual amount recognized in the immediately preceding accounting period for the same cost category and study/site combination. Used to calculate period-over-period variance and support accrual roll-forward analysis.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The date on which the accrual entry is scheduled to be automatically reversed in SAP S/4HANA. Typically set to the first day of the following accounting period to offset the accrual when the actual invoice is received.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'The SAP S/4HANA FI document number of the reversal journal entry that offsets this accrual. Populated after the reversal is executed; null if the accrual has not yet been reversed.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapFiDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Fi Document Number' ;
    rdfs:comment 'The SAP S/4HANA Financial Accounting (FI) document number assigned when the accrual journal entry is posted in the general ledger. Used for cross-referencing between the data lakehouse and the ERP system of record.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingUnits rdf:type rdf:Property ;
    rdfs:label 'Supporting Units' ;
    rdfs:comment 'The quantity of activity units (e.g., enrolled subjects, completed visits, monitoring days, lab samples) used as the basis for calculating the accrual amount. Provides the quantitative driver behind enrollment-based, visit-based, or unit-based accruals.' ;
    rdfs:domain ind:Accrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'The difference between the accrual amount and the actual invoice amount when the invoice is received and matched. A positive variance indicates over-accrual; negative indicates under-accrual. Used for accrual accuracy monitoring and process improvement.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceExplanation rdf:type rdf:Property ;
    rdfs:label 'Variance Explanation' ;
    rdfs:comment 'Free-text explanation of the variance between the accrual amount and the actual invoice amount. Required for material variances exceeding the defined threshold as part of SOX controls and period-end close procedures.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetLineId rdf:type rdf:Property ;
    rdfs:label 'Budget Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each granular budget line item within a study budget. Primary key for the budget_line data product.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetLine .

ind:monitoringPlanId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Plan Id' ;
    rdfs:comment 'Foreign key linking to monitoring.monitoring_plan. Business justification: Budget lines for monitoring activities (on-site visits, remote monitoring, SDV) are scoped and sized from the monitoring plan. Budget analysts reference the monitoring plan to validate planned quantit' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MonitoringPlan .

ind:proposalLineId rdf:type rdf:Property ;
    rdfs:label 'Proposal Line Id' ;
    rdfs:comment 'Foreign key linking to sponsor.proposal_line. Business justification: Each budget_line traces to a proposal_line for cost-vs-bid variance reporting and scope change management. budget_line.contract_line_ref is a plain-text denormalization of this relationship. CRO finan' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProposalLine .

ind:reportingObligationId rdf:type rdf:Property ;
    rdfs:label 'Reporting Obligation Id' ;
    rdfs:comment 'Foreign key linking to safety.safety_reporting_obligation. Business justification: Individual budget lines for regulatory submission activities (e.g., IND safety reporting, EMA expedited reports) are scoped to specific safety reporting obligations. Finance analysts building study bu' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReportingObligation .

ind:treatmentArmId rdf:type rdf:Property ;
    rdfs:label 'Treatment Arm Id' ;
    rdfs:comment 'Foreign key linking to randomization.treatment_arm. Business justification: Study budgets are structured by treatment arm for investigational product costs, comparator drug costs, and arm-specific procedures. Budget variance analysis and sponsor billing reconciliation require' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TreatmentArm .

ind:visitProcedureId rdf:type rdf:Property ;
    rdfs:label 'Visit Procedure Id' ;
    rdfs:comment 'Foreign key linking to study.visit_procedure. Business justification: Each visit procedure (imaging, biopsy, lab panel) has a corresponding budget line for cost tracking and sponsor billing. This is the most granular level of clinical trial cost management, enabling pro' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VisitProcedure .

ind:accrualAmount rdf:type rdf:Property ;
    rdfs:label 'Accrual Amount' ;
    rdfs:comment 'Accrued cost amount for this budget line representing services rendered but not yet invoiced, posted as a period-end accrual in SAP S/4HANA GL. Critical for accurate period financial reporting and SOX compliance.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'Specific clinical trial activity associated with this budget line (e.g., \'Site Initiation Visit\', \'Monitoring Visit\', \'Database Lock\', \'Regulatory Submission\', \'Patient Screening\', \'SAE Reporting\'). Aligns with Oracle Siebel CTMS visit and activity tracking.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Amount' ;
    rdfs:comment 'Total actual costs incurred against this budget line item to date in the transaction currency, as posted in SAP S/4HANA. Used for budget vs. actual variance analysis and financial reporting.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetVersion rdf:type rdf:Property ;
    rdfs:label 'Budget Version' ;
    rdfs:comment 'Version identifier of the budget to which this line belongs (e.g., \'v1.0\', \'v2.0-Amendment-1\'). Supports budget versioning for contract amendments, scope changes, and sponsor re-negotiations. Aligns with SAP S/4HANA budget version management.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'Amount committed via purchase orders or contracts against this budget line but not yet invoiced or paid. Represents financial obligations that reduce available budget. Sourced from SAP S/4HANA commitment management.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Category' ;
    rdfs:comment 'High-level classification of the cost type for this budget line. Drives financial reporting segmentation and sponsor invoicing. Values: direct_labor (CRO staff effort), pass_through (third-party vendor costs billed at cost), investigator_grant (site/PI payments per protocol activity), overhead (indirect/facility costs), patient_stipend (subject reimbursement payments). [ENUM-REF-CANDIDATE: direct_labor|pass_through|investigator_grant|overhead|patient_stipend|other — promote to reference product if additional categories are needed]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costSubcategory rdf:type rdf:Property ;
    rdfs:label 'Cost Subcategory' ;
    rdfs:comment 'Granular sub-classification within the cost category (e.g., \'Clinical Monitoring\', \'Data Management\', \'Biostatistics\', \'Central Lab\', \'Imaging\', \'RTSM\', \'eCRF License\'). Enables detailed cost tracking and variance analysis at the activity level.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'Fiscal accounting period (1–12 or 1–13 depending on fiscal year variant) within the fiscal year to which this budget line is allocated. Enables monthly budget tracking and period-end accrual management in SAP S/4HANA.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'Planned amount converted to the company\'s functional currency (typically USD) using the applicable exchange rate. Required for consolidated financial reporting and SOX compliance across multi-currency global studies.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isMilestoneBased rdf:type rdf:Property ;
    rdfs:label 'Is Milestone Based' ;
    rdfs:comment 'Indicates whether payment for this budget line is triggered by achievement of a defined clinical milestone (True) rather than time-and-materials or unit-based billing (False). Drives milestone payment scheduling and sponsor invoicing logic.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineDescription rdf:type rdf:Property ;
    rdfs:label 'Line Description' ;
    rdfs:comment 'Human-readable description of the budget line item activity or cost element (e.g., \'Site Initiation Visit - Site 001\', \'Investigator Grant - Per Patient Enrolled\', \'Central Lab Processing Fee\'). Used in sponsor budget reports and financial reconciliation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number ordering this item within the parent budget. Enables ordered display and navigation of budget line items in sponsor budget reports and SAP S/4HANA project accounting views.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current lifecycle status of the budget line item. Controls whether the line is available for cost posting and sponsor invoicing. Draft: under preparation; Approved: authorized for spend; Active: costs being incurred; On Hold: temporarily suspended; Cancelled: removed from scope; Closed: fully reconciled.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneDescription rdf:type rdf:Property ;
    rdfs:label 'Milestone Description' ;
    rdfs:comment 'Description of the clinical or contractual milestone that triggers payment for this budget line when is_milestone_based is True (e.g., \'First Patient First Visit\', \'Database Lock\', \'Last Patient Last Visit\', \'Regulatory Submission\'). Null when not milestone-based.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'End date of the time period covered by this budget line item. Defines the temporal boundary for cost incurrence and accrual cutoff. Used in time-phased budget reporting and study close-out.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'Start date of the time period covered by this budget line item. Defines the temporal scope for cost incurrence and accrual recognition. Used in time-phased budget reporting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Amount' ;
    rdfs:comment 'Total budgeted amount for this line item in the transaction currency (planned_quantity × unit_cost). Represents the authorized spend ceiling for this activity. Used for variance analysis and sponsor budget reporting.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'Budgeted quantity of units for this line item (e.g., number of monitoring visits, number of patients enrolled, number of lab kits, number of FTE hours). Combined with unit_cost to derive the total planned amount.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'SAP profit center code associated with this budget line for internal profitability reporting. Enables study-level and sponsor-level margin analysis within SAP S/4HANA Controlling.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Sap Company Code' ;
    rdfs:comment 'SAP company code representing the legal entity responsible for this budget line. Required for multi-entity financial consolidation, intercompany accounting, and SOX entity-level financial reporting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'SAP S/4HANA financial document number associated with the budget posting for this line item. Provides direct traceability from the lakehouse Silver layer back to the source system transaction for audit and reconciliation purposes.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapInternalOrder rdf:type rdf:Property ;
    rdfs:label 'Sap Internal Order' ;
    rdfs:comment 'SAP internal order number used for detailed cost collection and monitoring for this budget line, particularly for pass-through costs and investigator grants. Supplements WBS element for granular cost tracking.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorLineRef rdf:type rdf:Property ;
    rdfs:label 'Sponsor Line Ref' ;
    rdfs:comment 'Sponsor\'s own reference code or line identifier for this budget item as defined in the contract or sponsor budget template. Enables cross-referencing between CRO internal budget and sponsor-facing budget documentation for reconciliation.' ;
    rdfs:domain ind:BudgetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Negotiated or standard cost per unit for this budget line item in the transaction currency. Multiplied by planned_quantity to derive planned_amount. Commercially sensitive as it reflects CRO pricing and investigator grant rates.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryCostEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Cost Employee Id' ;
    rdfs:comment 'Employee ID of the manager responsible for this cost center\'s budget and expenditures. Sourced from Workday HCM. Used for budget approval workflows, SOX segregation of duties controls, and financial accountability reporting. The manager is the primary approver for purchase orders and expense postings against this cost center.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryCostResponsibleManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Cost Responsible Manager Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activityTypeGroup rdf:type rdf:Property ;
    rdfs:label 'Activity Type Group' ;
    rdfs:comment 'SAP activity type group (LGRUPPE) associated with this cost center, defining the types of internal activities (e.g., CRA monitoring hours, biostatistician hours, regulatory writing hours) that can be planned and allocated. Used for activity-based costing in clinical trial project accounting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Amount' ;
    rdfs:comment 'Total approved annual budget allocated to this cost center in the cost center\'s primary currency. Represents the planned expenditure ceiling for the fiscal year as approved through the SAP CO planning cycle. Used for budget vs. actual variance analysis and sponsor cost reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'SAP Business Area (GSBER) associated with this cost center. Represents a distinct area of operations for which an internal balance sheet and P&L can be produced. Used for cross-company-code financial reporting in multi-entity CRO structures.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'SAP Controlling Area (KOKRS) to which this cost center belongs. Defines the organizational unit within which cost accounting is performed. All cost centers within a controlling area share the same fiscal year variant and currency settings.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Method' ;
    rdfs:comment 'Method used to allocate or distribute costs from this cost center to other cost objects (studies, projects, sponsors). \'direct\' = direct assignment; \'assessment\' = SAP assessment cycle; \'distribution\' = SAP distribution cycle; \'activity_based\' = activity type-based allocation; \'statistical\' = statistical key figure-based. Critical for accurate sponsor invoicing and pass-through cost tracking.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'SAP cost center category (KOSAR) that determines which activity types and statistical key figures can be posted. Common categories in clinical research include: E (Production/Operations), F (Research & Development), G (General & Administrative), H (Human Resources), V (Sales & Marketing). [ENUM-REF-CANDIDATE: E|F|G|H|V|M|N|P — promote to reference product]' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'Human-readable descriptive name of the cost center (e.g., \'Oncology Clinical Operations\', \'Regulatory Affairs – EU\', \'Biostatistics & Data Management\'). Displayed in financial reports, dashboards, and sponsor invoicing summaries.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. \'active\' — open for postings; \'inactive\' — temporarily suspended; \'locked\' — blocked for new postings pending review; \'pending_activation\' — created but not yet approved; \'closed\' — permanently deactivated after study close-out or organizational restructuring.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Classification of the cost center by its cost allocation behavior. \'direct\' centers accumulate costs directly attributable to clinical trial studies or sponsors; \'indirect\' centers hold shared service costs; \'overhead\' centers capture organizational overhead; \'project\' centers align to specific study projects; \'administrative\' centers cover G&A functions. Drives cost allocation methodology in SAP CO.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'SAP user ID (ERNAM) of the person who created this cost center record in SAP S/4HANA. Required for SOX audit trail, segregation of duties validation, and ALCOA+ (Attributable) compliance for financial records.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Internal department code from Workday HCM organizational structure mapped to this cost center. Enables reconciliation between HR workforce cost data (Workday) and financial cost center data (SAP S/4HANA) for headcount-based cost allocation and labor cost reporting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'SAP fiscal year variant (PERIV) defining the fiscal year calendar structure for this cost center (e.g., K4 = calendar year Jan-Dec, V3 = April-March). Determines period mapping for financial postings and regulatory reporting timelines.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'Primary General Ledger (GL) account code in SAP FI associated with this cost center for default cost postings. Ensures financial transactions are recorded to the correct GL account in the chart of accounts for GAAP/IFRS financial statement preparation and SOX controls.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyArea rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Area' ;
    rdfs:comment 'The node within the standard cost center hierarchy (SAP standard hierarchy SEGH) to which this cost center is assigned. Enables roll-up reporting by organizational unit, therapeutic area, or functional department. Examples: \'CLINICAL-OPS\', \'REGULATORY\', \'BIOSTATISTICS\'.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric depth of this cost center within the organizational cost center hierarchy (1 = top-level division, higher numbers = more granular sub-units). Used for hierarchical roll-up in financial reporting and budget consolidation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isIntercompany rdf:type rdf:Property ;
    rdfs:label 'Is Intercompany' ;
    rdfs:comment 'Indicates whether this cost center is used for intercompany transactions between legal entities within the CRO group (True) or is a standard intra-company cost center (False). Intercompany cost centers require transfer pricing documentation and elimination in consolidated financial statements per IFRS 10 and SOX.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStatistical rdf:type rdf:Property ;
    rdfs:label 'Is Statistical' ;
    rdfs:comment 'Indicates whether this is a statistical cost center (True) used only for informational/reporting purposes without actual cost postings, or a real cost center (False) that receives actual financial transactions. Statistical cost centers are used for headcount tracking and KPI reporting in SAP CO.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'SAP user ID of the person who last modified this cost center record. Required for SOX audit trail and ALCOA+ (Attributable) compliance. Enables identification of unauthorized changes during internal and external audits.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockIndicator rdf:type rdf:Property ;
    rdfs:label 'Lock Indicator' ;
    rdfs:comment 'Indicates whether this cost center is locked for actual postings (True = locked, no new financial transactions permitted). Corresponds to the SPERRZ field in SAP CSKS. Used during period-end close, audit periods, or when a cost center is under SOX review.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overheadRatePct rdf:type rdf:Property ;
    rdfs:label 'Overhead Rate Pct' ;
    rdfs:comment 'Overhead surcharge rate (as a percentage) applied to direct costs posted to this cost center for indirect cost recovery. Used in SAP CO overhead calculation schemes to compute fully-loaded project costs for sponsor invoicing and contract budget management.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planLockIndicator rdf:type rdf:Property ;
    rdfs:label 'Plan Lock Indicator' ;
    rdfs:comment 'Indicates whether this cost center is locked for planning/budget postings (True = planning locked). Corresponds to the SPERP field in SAP CSKS. Prevents budget modifications after the annual planning cycle is finalized.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Geographic region code for this cost center (e.g., AMER, EMEA, APAC). Used for regional financial consolidation, multi-regional clinical trial cost allocation, and regulatory reporting segmentation across FDA, EMA, PMDA, TGA, and Health Canada jurisdictions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapObjectClass rdf:type rdf:Property ;
    rdfs:label 'Sap Object Class' ;
    rdfs:comment 'SAP object class (OBART) assigned to this cost center, determining which cost accounting objects can receive allocations from it. OCCA = Cost Centers; OACC = Orders; OPRO = Projects/WBS; OSTA = Statistical Objects. Governs the allocation rules in SAP CO.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated name of the cost center used in SAP S/4HANA reporting layouts and condensed financial statements where space is limited. Corresponds to the KTEXT field in SAP CO.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Identifier of the operational source system from which this cost center record was ingested (e.g., SAP_S4HANA_PROD, SAP_S4HANA_QA). Supports data lineage tracking, multi-system reconciliation, and Silver Layer data provenance in the Databricks Lakehouse.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'The date from which this cost center is active and available for financial postings in SAP S/4HANA. Corresponds to the DATAB (valid-from date) field in SAP CSKS table. Financial transactions cannot be posted to this cost center before this date.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'The date after which this cost center is no longer active for financial postings in SAP S/4HANA. Corresponds to the DATBI (valid-to date) field in SAP CSKS table. A value of 9999-12-31 indicates an open-ended cost center with no planned expiry.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wbsElementCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Code' ;
    rdfs:comment 'SAP Work Breakdown Structure (WBS) element code (POSID) associated with this cost center for project accounting. Links cost center expenditures to specific clinical trial project structures in SAP PS (Project System), enabling study-level cost tracking and sponsor billing.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceTmfDocumentId rdf:type rdf:Property ;
    rdfs:label 'Evidence Tmf Document Id' ;
    rdfs:comment 'Foreign key linking to document.tmf_document. Business justification: Billing milestones (e.g., database lock, final CSR delivery) require a specific TMF document as evidence of completion before invoicing. This link supports invoice substantiation, sponsor audit reques' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TmfDocument .

ind:ndaBlaApplicationId rdf:type rdf:Property ;
    rdfs:label 'Nda Bla Application Id' ;
    rdfs:comment 'Foreign key linking to regulatory.nda_bla_application. Business justification: NDA/BLA submission acceptance, PDUFA date, and approval are major billing milestones in CRO regulatory affairs contracts. Linking billing milestones to the NDA/BLA application record enables NDA/BLA M' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NdaBlaApplication .

ind:proposalId rdf:type rdf:Property ;
    rdfs:label 'Proposal Id' ;
    rdfs:comment 'Foreign key linking to sponsor.proposal. Business justification: Billing milestones are derived from the payment schedule defined in the winning proposal. Finance teams set up billing plans by mapping proposal payment milestones to finance_billing_milestone records' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Proposal .

ind:regulatoryApprovalId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Id' ;
    rdfs:comment 'Foreign key linking to regulatory.approval. Business justification: Regulatory approval (NDA, MAA, CTA approval) is the most significant billing milestone trigger in CRO contracts, often representing 20-30% of contract value. Linking billing milestones directly to the' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Approval .

ind:sponsorInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Sponsor Invoice Id' ;
    rdfs:comment 'Reference to the accounts receivable invoice generated when this milestone is triggered. Null until the milestone reaches invoiced status.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SponsorInvoice .

ind:triggeringSubjectRandomizationId rdf:type rdf:Property ;
    rdfs:label 'Triggering Subject Randomization Id' ;
    rdfs:comment 'Foreign key linking to randomization.subject_randomization. Business justification: Billing milestones such as \'First Patient Randomized\' and \'Last Patient Randomized\' are directly triggered by specific randomization events. Linking the triggering randomization record to the billing ' ;
    rdfs:domain ind:FinanceBillingMilestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SubjectRandomization .

ind:accrualPct rdf:type rdf:Property ;
    rdfs:label 'Accrual Pct' ;
    rdfs:comment 'Percentage of the billing milestone amount that has been accrued as revenue in the current period (0.00 to 100.00). Reflects the estimated completion of the milestone trigger criteria for accrual purposes.' ;
    rdfs:domain ind:FinanceBillingMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingAmount rdf:type rdf:Property ;
    rdfs:label 'Billing Amount' ;
    rdfs:comment 'Gross contractual amount to be invoiced to the sponsor upon achievement of this milestone, expressed in the billing currency. Represents the base revenue amount before any adjustments or withholdings.' ;
    rdfs:domain ind:FinanceBillingMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingPlanLineNumber rdf:type rdf:Property ;
    rdfs:label 'Billing Plan Line Number' ;
    rdfs:comment 'SAP S/4HANA billing plan line item number corresponding to this milestone within the project or contract billing schedule. Enables direct traceability to the source system billing plan configuration.' ;
    rdfs:domain ind:FinanceBillingMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAtRisk rdf:type rdf:Property ;
    rdfs:label 'Is At Risk' ;
    rdfs:comment 'Indicates whether this billing milestone is classified as at-risk (True), meaning the sponsor has disputed, placed on hold, or the CRO has assessed a significant probability of non-collection. Flags milestones requiring provision or write-off consideration.' ;
    rdfs:domain ind:FinanceBillingMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Status' ;
    rdfs:comment 'Current lifecycle state of the billing milestone: pending (not yet met), triggered (trigger criteria satisfied, ready for invoicing), invoiced (invoice raised to sponsor), paid (payment received), cancelled (milestone voided), on_hold (temporarily suspended). Drives AR workflow and revenue recognition. [ENUM-REF-CANDIDATE: pending|triggered|invoiced|paid|cancelled|on_hold — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalBillingAmount rdf:type rdf:Property ;
    rdfs:label 'Original Billing Amount' ;
    rdfs:comment 'The original contractual billing amount for this milestone prior to any amendments or scope changes. Enables variance analysis between original contract value and current billing amount to support change order tracking.' ;
    rdfs:domain ind:FinanceBillingMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAmountReceived rdf:type rdf:Property ;
    rdfs:label 'Payment Amount Received' ;
    rdfs:comment 'Actual amount received from the sponsor against this billing milestone invoice. May differ from billing_amount due to partial payments, withholdings, or currency adjustments.' ;
    rdfs:domain ind:FinanceBillingMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedBillingDate rdf:type rdf:Property ;
    rdfs:label 'Planned Billing Date' ;
    rdfs:comment 'Contractually agreed or operationally planned calendar date on which this milestone is expected to be triggered and invoiced to the sponsor. Used for cash flow forecasting and revenue planning.' ;
    rdfs:domain ind:FinanceBillingMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapWbsElement rdf:type rdf:Property ;
    rdfs:label 'Sap Wbs Element' ;
    rdfs:comment 'SAP S/4HANA Work Breakdown Structure element code to which this billing milestone is assigned for project accounting and cost allocation purposes. Enables revenue and cost tracking at the project sub-element level.' ;
    rdfs:domain ind:FinanceBillingMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerCriteria rdf:type rdf:Property ;
    rdfs:label 'Trigger Criteria' ;
    rdfs:comment 'Formal description of the measurable condition(s) that must be satisfied to trigger this billing milestone (e.g., \'50 subjects enrolled across all sites\', \'Final CSR delivered to sponsor\', \'DBL achieved\'). Used by finance and operations teams to evaluate milestone readiness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerThresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Trigger Threshold Unit' ;
    rdfs:comment 'Unit of measure for the trigger threshold value (e.g., subjects, visits, sites, percentage, days, deliverables). Provides context for interpreting the numeric threshold.' ;
    rdfs:domain ind:FinanceBillingMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Trigger Threshold Value' ;
    rdfs:comment 'Quantitative threshold value associated with the trigger criteria (e.g., number of subjects enrolled, number of visits completed, percentage of data cleaned). Applicable for enrollment_based and visit_based milestone types.' ;
    rdfs:domain ind:FinanceBillingMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Amount' ;
    rdfs:comment 'Amount withheld by the sponsor from the milestone payment, typically as a contractual retention or performance guarantee holdback. Reduces the net payment received relative to the invoiced amount.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialForecastId rdf:type rdf:Property ;
    rdfs:label 'Financial Forecast Id' ;
    rdfs:comment 'Unique system-generated identifier for the financial forecast record. Primary key for the financial_forecast data product in the finance domain.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountPlanId rdf:type rdf:Property ;
    rdfs:label 'Account Plan Id' ;
    rdfs:comment 'Foreign key linking to sponsor.account_plan. Business justification: Account plans set annual revenue targets that financial forecasts must align with. Finance teams validate financial_forecast against account_plan revenue targets during annual planning cycles — a stan' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountPlan .

ind:benefitRiskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Benefit Risk Assessment Id' ;
    rdfs:comment 'Foreign key linking to safety.benefit_risk_assessment. Business justification: Benefit-risk assessments recommending study continuation, dose modification, or termination are primary triggers for financial forecast revisions. Clinical finance teams update revenue and cost foreca' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BenefitRiskAssessment .

ind:primaryFinancialPreparerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Financial Preparer Employee Id' ;
    rdfs:comment 'Reference to the Workday HCM employee record of the individual who prepared the forecast. Supports SOX segregation of duties controls and accountability tracking.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:timelineId rdf:type rdf:Property ;
    rdfs:label 'Timeline Id' ;
    rdfs:comment 'Foreign key linking to program.program_timeline. Business justification: Enrollment rate, active sites, and milestone completion assumptions in financial_forecast are derived directly from program_timeline data. Linking enables automated forecast refresh when timelines cha' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timeline .

ind:workforceResourcePlanId rdf:type rdf:Property ;
    rdfs:label 'Workforce Resource Plan Id' ;
    rdfs:comment 'Foreign key linking to workforce.workforce_resource_plan. Business justification: Financial forecasts incorporate workforce resource plan assumptions (enrolled_subjects_assumption, active_sites_assumption, FTE demand). Linking the forecast to its source resource plan supports integ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkforceResourcePlan .

ind:activeSitesAssumption rdf:type rdf:Property ;
    rdfs:label 'Active Sites Assumption' ;
    rdfs:comment 'The assumed number of active investigator sites used as a driver in the financial forecast model. Site activation status directly affects cost burn rates and milestone payment projections.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetCostAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Cost Amount' ;
    rdfs:comment 'The approved budget total cost amount for the same forecast period, sourced from the study budget baseline. Used to compute cost variance between forecast and budget.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Revenue Amount' ;
    rdfs:comment 'The approved budget revenue amount for the same forecast period, sourced from the study budget baseline. Used to compute revenue variance between forecast and budget.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashInflowForecastAmount rdf:type rdf:Property ;
    rdfs:label 'Cash Inflow Forecast Amount' ;
    rdfs:comment 'Projected cash receipts from the sponsor during the forecast period, including milestone payments and invoice collections. Supports cash flow management and treasury planning.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashOutflowForecastAmount rdf:type rdf:Property ;
    rdfs:label 'Cash Outflow Forecast Amount' ;
    rdfs:comment 'Projected cash disbursements to investigators, sites, vendors, and other payees during the forecast period. Supports cash flow management and treasury planning.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'Qualitative assessment of the reliability and accuracy of the forecast, reflecting the preparer\'s confidence based on data quality, enrollment stability, and milestone predictability. Used in management reporting to flag forecasts requiring additional scrutiny.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Amount' ;
    rdfs:comment 'Monetary difference between the forecasted total cost and the budgeted total cost for the period (budget minus forecast). Positive value indicates favorable (under-budget) variance. Expressed in the forecast currency.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:directCostForecastAmount rdf:type rdf:Property ;
    rdfs:label 'Direct Cost Forecast Amount' ;
    rdfs:comment 'Projected total direct costs for the forecast period, including investigator grants, site payments, patient stipends, and clinical operations labor. Expressed in the forecast currency.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrolledSubjectsAssumption rdf:type rdf:Property ;
    rdfs:label 'Enrolled Subjects Assumption' ;
    rdfs:comment 'The assumed cumulative number of subjects enrolled as of the forecast period end date. Used to project visit-based costs, patient stipends, and milestone completion timelines.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enrollmentRateAssumption rdf:type rdf:Property ;
    rdfs:label 'Enrollment Rate Assumption' ;
    rdfs:comment 'The assumed patient enrollment rate (subjects per site per month) used as a key driver in the financial forecast model. Changes in enrollment rate directly impact revenue recognition timing and cost projections.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastBasis rdf:type rdf:Property ;
    rdfs:label 'Forecast Basis' ;
    rdfs:comment 'Methodology used to construct the financial forecast. Indicates whether the forecast was built from granular site/subject data (bottom-up), extrapolated from portfolio trends (top-down), or derived from a statistical model.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastNumber rdf:type rdf:Property ;
    rdfs:label 'Forecast Number' ;
    rdfs:comment 'Externally-known unique business identifier for the forecast document, following the format FC-YYYY-NNNNNN. Used in sponsor financial reporting, internal management reviews, and audit trails.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Period End Date' ;
    rdfs:comment 'The last calendar date of the forecast period being projected. Defines the closing boundary of the financial projection window.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Period Start Date' ;
    rdfs:comment 'The first calendar date of the forecast period being projected. Defines the beginning boundary of the financial projection window.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastStatus rdf:type rdf:Property ;
    rdfs:label 'Forecast Status' ;
    rdfs:comment 'Current lifecycle state of the financial forecast record. Controls whether the forecast is active for reporting and decision-making or has been replaced by a newer version.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastType rdf:type rdf:Property ;
    rdfs:label 'Forecast Type' ;
    rdfs:comment 'Classification of the forecast by periodicity or purpose. Determines the time horizon and granularity of the projection. [ENUM-REF-CANDIDATE: monthly|quarterly|annual|ad_hoc|rolling_12_month|study_to_date — promote to reference product]' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastVersion rdf:type rdf:Property ;
    rdfs:label 'Forecast Version' ;
    rdfs:comment 'Sequential version number of the forecast for a given study and forecast period. Incremented each time a forecast is revised, enabling comparison of forecast iterations over time.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grossMarginForecastAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Forecast Amount' ;
    rdfs:comment 'Projected gross margin for the forecast period, calculated as revenue forecast minus direct cost forecast. Expressed in the forecast currency. Used for sponsor financial reporting and internal profitability management.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossMarginForecastPct rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Forecast Pct' ;
    rdfs:comment 'Projected gross margin as a percentage of forecasted revenue for the period. Expressed as a decimal (e.g., 0.3250 = 32.50%). Used for portfolio-level profitability benchmarking.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indirectCostForecastAmount rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Forecast Amount' ;
    rdfs:comment 'Projected total indirect and overhead costs allocated to the study for the forecast period, including G&A allocations and shared service charges. Expressed in the forecast currency.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBaselineForecast rdf:type rdf:Property ;
    rdfs:label 'Is Baseline Forecast' ;
    rdfs:comment 'Indicates whether this forecast version has been designated as the baseline against which future forecast variances will be measured. Only one forecast per study and period may be flagged as baseline.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneCompletionPct rdf:type rdf:Property ;
    rdfs:label 'Milestone Completion Pct' ;
    rdfs:comment 'Projected percentage of study milestones expected to be completed by the end of the forecast period. Expressed as a decimal (e.g., 0.6500 = 65%). Drives revenue recognition and sponsor invoicing projections.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passThroughCostForecastAmount rdf:type rdf:Property ;
    rdfs:label 'Pass Through Cost Forecast Amount' ;
    rdfs:comment 'Projected total pass-through costs to be reimbursed by the sponsor for the forecast period, such as central lab fees, imaging costs, and regulatory filing fees. Expressed in the forecast currency.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preparationDate rdf:type rdf:Property ;
    rdfs:label 'Preparation Date' ;
    rdfs:comment 'The business date on which the forecast was formally prepared and submitted for review. Distinct from the system audit timestamp; represents the real-world event date for the forecast cycle.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodLabel rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Label' ;
    rdfs:comment 'Human-readable label for the forecast period used in sponsor financial reports and internal management dashboards (e.g., \'Q3 2024\', \'FY2024\', \'October 2024\'). Supports consistent period identification across reporting cycles.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueForecastAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Forecast Amount' ;
    rdfs:comment 'Projected total revenue to be recognized from the sponsor for the forecast period, including service fees, pass-through reimbursements, and milestone payments. Expressed in the forecast currency.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Variance Amount' ;
    rdfs:comment 'Monetary difference between the forecasted revenue and the budgeted revenue for the period (forecast minus budget). Positive value indicates favorable variance; negative indicates unfavorable. Expressed in the forecast currency.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scopeLevel rdf:type rdf:Property ;
    rdfs:label 'Scope Level' ;
    rdfs:comment 'Indicates the organizational or operational scope at which the forecast is prepared. Study-level forecasts project a single protocol; portfolio-level forecasts aggregate across multiple studies for sponsor or management reporting.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Sponsor Submitted Flag' ;
    rdfs:comment 'Indicates whether this forecast has been formally submitted to the sponsor as part of contractual financial reporting obligations. Supports sponsor relationship management and contract compliance tracking.' ;
    rdfs:domain ind:FinancialForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountCurrency rdf:type rdf:Property ;
    rdfs:label 'Account Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code assigned to the GL account (e.g., USD, EUR, GBP). When set, all postings to this account must be in this currency. Relevant for multi-currency clinical trial sponsor invoicing and site payments.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'SAP account group code (KTOKS) that controls the number range and field selection for GL master data maintenance. Groups accounts by functional category such as balance sheet accounts, P&L accounts, cost accounts, or clinical trial-specific categories like investigator grants or pass-through costs.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHierarchyNode rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Node' ;
    rdfs:comment 'Node identifier within the GL account hierarchy (e.g., SAP Financial Statement Version node or account group hierarchy) that positions this account in the reporting structure. Enables roll-up reporting of clinical trial costs by category such as direct study costs, overhead, and pass-through expenses.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountLongDescription rdf:type rdf:Property ;
    rdfs:label 'Account Long Description' ;
    rdfs:comment 'Extended narrative description of the GL account purpose, providing additional context for financial analysts, auditors, and SOX compliance reviewers beyond the short account name.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'Short descriptive name of the GL account as maintained in SAP S/4HANA (SKAT table). Used as the human-readable label in financial reports, trial balance, and study cost allocations.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'The externally-known GL account number as defined in the SAP S/4HANA Chart of Accounts (SKA1/SKB1). This is the primary business identifier used in all journal entries, accruals, and financial postings across clinical trial studies.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the GL account indicating whether it is available for financial postings (active), temporarily blocked from postings (blocked), or flagged for removal from the chart of accounts (marked_for_deletion). Maps to SAP SKB1 blocking indicators.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Fundamental financial classification of the GL account indicating whether it is a balance sheet account (asset, liability, equity) or an income statement account (revenue, expense). Drives financial statement presentation and period-end closing behavior in SAP S/4HANA (field: KTOKS mapped to GVTYP).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualEngineRelevant rdf:type rdf:Property ;
    rdfs:label 'Accrual Engine Relevant' ;
    rdfs:comment 'Indicates whether this GL account participates in SAP Accrual Engine processing for automated period-end accruals. Highly relevant for clinical trial study cost accruals such as investigator fees earned but not yet invoiced, CRO milestone accruals, and pass-through cost estimates.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alternativeAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Alternative Account Number' ;
    rdfs:comment 'Country-specific or group-level alternative account number (SAP SKA1.ALTKT) used for local statutory reporting or consolidation mapping. Enables clinical trial entities operating in multiple jurisdictions to map to local chart of accounts requirements.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceInLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Balance In Local Currency' ;
    rdfs:comment 'Indicates whether this GL account only manages balances in local (company code) currency (SAP SKB1.XSALH). When True, foreign currency transaction details are not separately tracked, which may apply to certain internal clearing accounts used in clinical trial intercompany settlements.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chartOfAccounts rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts' ;
    rdfs:comment 'Four-character SAP Chart of Accounts key (e.g., INT, YCOA) that groups GL accounts under a common numbering scheme. Determines the account structure applicable across all company codes in the clinical trials enterprise.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalCostCategory rdf:type rdf:Property ;
    rdfs:label 'Clinical Cost Category' ;
    rdfs:comment 'Clinical research industry-specific cost classification applied to this GL account for study financial reporting and sponsor invoicing. Categorizes accounts into clinical trial cost buckets such as investigator grants, site management, pass-through costs, patient stipends, laboratory fees, regulatory fees, and CRO management fees. [ENUM-REF-CANDIDATE: investigator_grant|site_management|pass_through|patient_stipend|laboratory|regulatory|cro_management_fee|data_management|biostatistics|overhead — promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentItem rdf:type rdf:Property ;
    rdfs:label 'Commitment Item' ;
    rdfs:comment 'Funds management commitment item linked to this GL account for budget availability control. Used in clinical trial project accounting to track committed expenditures against approved study budgets before actual invoices are posted.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'SAP Controlling Area identifier to which this GL account is assigned. The controlling area defines the organizational unit for management accounting, enabling cost center allocations, internal orders, and project accounting for clinical trial studies.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'Controlling module classification indicating whether this GL account is a primary cost element (originating from FI postings such as investigator fees, pass-through costs) or secondary cost element (internal allocations between cost centers). Drives management accounting behavior in SAP CO.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdOn rdf:type rdf:Property ;
    rdfs:label 'Created On' ;
    rdfs:comment 'Date on which this GL account master record was first created in SAP S/4HANA (SKA1.ERDAT). Provides the audit trail start point for the account lifecycle, supporting SOX change management controls.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldStatusGroup rdf:type rdf:Property ;
    rdfs:label 'Field Status Group' ;
    rdfs:comment 'SAP field status group (SKB1.FSTAG) that controls which fields are required, optional, or suppressed during document entry for this GL account. Ensures mandatory fields such as cost center, internal order, or WBS element are captured for clinical trial project accounting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementVersion rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Version' ;
    rdfs:comment 'SAP Financial Statement Version key that determines how this GL account is grouped and presented in statutory financial statements (balance sheet, income statement). Critical for SOX-compliant financial reporting and regulatory submissions.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:houseBank rdf:type rdf:Property ;
    rdfs:label 'House Bank' ;
    rdfs:comment 'SAP house bank identifier (SKB1.HBKID) linked to this GL account for bank accounts. Relevant for clinical trial treasury accounts used to manage sponsor fund receipts and investigator site payment disbursements.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrsAccountMapping rdf:type rdf:Property ;
    rdfs:label 'Ifrs Account Mapping' ;
    rdfs:comment 'Mapping code linking this GL account to the corresponding IFRS disclosure line item or standard. Supports dual GAAP/IFRS reporting requirements for clinical trial organizations operating across US and international jurisdictions.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestIndicator rdf:type rdf:Property ;
    rdfs:label 'Interest Indicator' ;
    rdfs:comment 'SAP interest indicator (SKB1.ZINRT) that determines whether and how interest is calculated on balances in this GL account. Applicable to clinical trial escrow accounts or deferred revenue accounts holding sponsor advance payments.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPlanningBlocked rdf:type rdf:Property ;
    rdfs:label 'Is Planning Blocked' ;
    rdfs:comment 'Indicates whether cost planning is blocked for this GL account (SAP SKB1.XSPEP). When True, the account cannot be used in financial forecasting or study budget planning activities.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPostingBlocked rdf:type rdf:Property ;
    rdfs:label 'Is Posting Blocked' ;
    rdfs:comment 'Indicates whether financial postings to this GL account are currently blocked at the company code level (SAP SKB1.XSPEB). When True, no journal entries, accruals, or study cost allocations can be posted to this account.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReconciliationAccount rdf:type rdf:Property ;
    rdfs:label 'Is Reconciliation Account' ;
    rdfs:comment 'Indicates whether this GL account is a reconciliation account for a subledger (e.g., accounts payable for investigator site payments, accounts receivable for sponsor invoicing). Reconciliation accounts cannot receive direct manual postings.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxRelevant rdf:type rdf:Property ;
    rdfs:label 'Is Tax Relevant' ;
    rdfs:comment 'Indicates whether postings to this GL account are subject to tax determination. When True, a valid tax code must be entered for all financial transactions posted to this account, supporting VAT/GST compliance for international clinical trial operations.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastChangedBy rdf:type rdf:Property ;
    rdfs:label 'Last Changed By' ;
    rdfs:comment 'SAP user ID of the person who last modified this GL account master record. Supports segregation of duties and SOX audit trail requirements for chart of accounts change management.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastChangedOn rdf:type rdf:Property ;
    rdfs:label 'Last Changed On' ;
    rdfs:comment 'Date on which this GL account master record was most recently modified in SAP S/4HANA (SKA1.LAEDA). Tracks the currency of the account definition for audit and change management purposes.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineItemDisplay rdf:type rdf:Property ;
    rdfs:label 'Line Item Display' ;
    rdfs:comment 'Indicates whether individual line items are stored and displayable for this GL account (SAP SKB1.XKRES). When True, detailed transaction-level audit trails are maintained, supporting SOX compliance and clinical trial cost transparency requirements.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemManagement rdf:type rdf:Property ;
    rdfs:label 'Open Item Management' ;
    rdfs:comment 'Indicates whether open item management is activated for this GL account (SAP SKB1.XOPVW). When True, individual line items remain open until cleared, enabling tracking of outstanding investigator grant payments, sponsor invoice receivables, and unreconciled accruals.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitLossStatementAccount rdf:type rdf:Property ;
    rdfs:label 'Profit Loss Statement Account' ;
    rdfs:comment 'Indicates whether this GL account is a profit and loss (income statement) account as opposed to a balance sheet account. P&L accounts are reset to zero at fiscal year-end during the closing process. Critical for correct financial statement classification in clinical trial reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationAccountType rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Type' ;
    rdfs:comment 'Specifies the subledger type for which this account serves as a reconciliation account. \'vendor\' applies to accounts payable for site and investigator payments; \'customer\' applies to accounts receivable for sponsor invoicing; \'asset\' applies to fixed asset subledger reconciliation.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revaluationRelevant rdf:type rdf:Property ;
    rdfs:label 'Revaluation Relevant' ;
    rdfs:comment 'Indicates whether open items or balances in this GL account are subject to foreign currency revaluation at period-end. Applicable to clinical trial accounts holding balances in non-functional currencies such as EUR-denominated site payments or GBP-denominated CRO contracts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'SAP sort key (SKB1.ZUAWA) that determines the allocation field populated in line items when posting to this account. Controls how line items are sorted and displayed in the GL account line item display for audit and reconciliation purposes.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxRelevant rdf:type rdf:Property ;
    rdfs:label 'Sox Relevant' ;
    rdfs:comment 'Indicates whether this GL account is within scope for Sarbanes-Oxley (SOX) internal controls over financial reporting. SOX-relevant accounts require documented controls, periodic reconciliation, and management sign-off as part of the clinical trials organization\'s SOX compliance program.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'SAP tax category indicator (SKA1.MWSKZ) that controls whether and how tax codes can be entered during posting to this account. Relevant for VAT/GST compliance on cross-border clinical trial site payments and sponsor invoices.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceGroup rdf:type rdf:Property ;
    rdfs:label 'Tolerance Group' ;
    rdfs:comment 'SAP tolerance group assigned to this GL account that defines acceptable variance thresholds for payment differences and clearing. Relevant for managing small discrepancies in investigator site payment reconciliations and sponsor invoice settlements.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each invoice line item record in the clinical trial billing system. Primary key for the invoice_line data product.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:accrualPeriod rdf:type rdf:Property ;
    rdfs:label 'Accrual Period' ;
    rdfs:comment 'Accounting period (YYYY-MM format) in which the accrual for this line item is recognized. Used for period-end financial close, revenue recognition scheduling, and SOX reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCategory rdf:type rdf:Property ;
    rdfs:label 'Billing Category' ;
    rdfs:comment 'High-level classification of the type of charge being billed on this line item. Drives financial reporting segmentation and sponsor audit support. [ENUM-REF-CANDIDATE: professional_fee|pass_through|investigator_grant|lab_fee|patient_stipend|regulatory_fee|travel_expense|data_management_fee — promote to reference product]' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Billing Period End' ;
    rdfs:comment 'End date of the service period covered by this invoice line item. Defines the close of the billing window for time-based or recurring charges.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start' ;
    rdfs:comment 'Start date of the service period covered by this invoice line item. Defines the beginning of the billing window for time-based or recurring charges.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditNoteRef rdf:type rdf:Property ;
    rdfs:label 'Credit Note Ref' ;
    rdfs:comment 'Reference number of the credit note issued to reverse or adjust this invoice line item. Populated when a billing correction or sponsor credit is applied.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Contractual discount or credit applied to this line item, reducing the gross billed amount. May reflect volume discounts, sponsor negotiated rates, or contractual adjustments.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBillable rdf:type rdf:Property ;
    rdfs:label 'Is Billable' ;
    rdfs:comment 'Indicates whether this line item is billable to the sponsor. Non-billable lines may represent internal cost tracking, write-offs, or contractually excluded activities.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineAmount rdf:type rdf:Property ;
    rdfs:label 'Line Amount' ;
    rdfs:comment 'Gross billed amount for this line item before any adjustments, discounts, or taxes. Calculated as quantity multiplied by unit_price. Represents the primary monetary value of the line.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Line Item Number' ;
    rdfs:comment 'Externally visible alphanumeric identifier for this invoice line item as it appears on the sponsor-facing invoice document. Used for sponsor reference and dispute resolution.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Net billed amount for this line item after applying discounts and adjustments but before tax. Equals line_amount minus discount_amount. Used for revenue recognition and accounts receivable.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passThroughInvoiceRef rdf:type rdf:Property ;
    rdfs:label 'Pass Through Invoice Ref' ;
    rdfs:comment 'Reference number of the original vendor invoice being passed through to the sponsor. Enables three-way matching between vendor invoice, CRO accounts payable, and sponsor billing for audit purposes.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passThroughVendor rdf:type rdf:Property ;
    rdfs:label 'Pass Through Vendor' ;
    rdfs:comment 'Name of the third-party vendor whose costs are being passed through to the sponsor on this line item (e.g., central laboratory, imaging vendor, courier). Applicable only for pass-through billing category lines.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Number of units, events, patients, visits, or other countable items being billed on this line item. Combined with unit_price to derive the line amount.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceCode rdf:type rdf:Property ;
    rdfs:label 'Service Code' ;
    rdfs:comment 'Standardized code identifying the specific service, activity, or cost type being billed, aligned with the contract work breakdown structure (WBS) and SAP S/4HANA service catalog.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Service Delivery Date' ;
    rdfs:comment 'Date on which the service, milestone, or deliverable associated with this billing line was completed or delivered. Used as the principal business event date for revenue recognition and audit.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceDescription rdf:type rdf:Property ;
    rdfs:label 'Service Description' ;
    rdfs:comment 'Human-readable description of the service, activity, or cost item being billed on this line. Appears on the sponsor-facing invoice and supports billing reconciliation and audit.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Tax amount applied to this invoice line item based on the applicable tax code and jurisdiction. Includes VAT, GST, or withholding tax as applicable per sponsor country.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'SAP S/4HANA tax code identifying the applicable tax rate and jurisdiction rules for this line item. Determines VAT, GST, or withholding tax treatment based on sponsor country and service type.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Total billed amount for this line item inclusive of taxes. Equals net_amount plus tax_amount. Represents the final amount due from the sponsor for this specific billing item.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Contracted price per unit for the service or cost item on this line, as agreed in the master service agreement or work order. Multiplied by quantity to derive the line amount.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Unique surrogate identifier for each journal entry record in the clinical trial finance data product. Primary key for the journal_entry table in the Databricks Silver Layer.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payrollRecordId rdf:type rdf:Property ;
    rdfs:label 'Payroll Record Id' ;
    rdfs:comment 'Foreign key linking to workforce.payroll_record. Business justification: Payroll journal entries must be traceable to their source payroll records for payroll posting reconciliation and SOX controls. This link supports the named payroll-to-GL reconciliation process and aud' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollRecord .

ind:primaryJournalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Journal Employee Id' ;
    rdfs:comment 'SAP S/4HANA user ID of the individual who posted the journal entry. Mandatory for SOX segregation of duties controls, ALCOA+ attributability requirements, and 21 CFR Part 11 electronic records audit trail. Classified confidential as it identifies internal system users.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accrualBasis rdf:type rdf:Property ;
    rdfs:label 'Accrual Basis' ;
    rdfs:comment 'Indicates the basis on which an accrual journal entry was generated in SAP S/4HANA. Distinguishes manually entered accruals from system-generated recurring accruals and milestone-based accruals tied to clinical trial site payment schedules. Relevant for period-end close and audit.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'The gross credit amount posted on this journal entry line in the transaction currency. Represents decreases to asset/expense accounts or increases to liability/revenue accounts. Core component of double-entry bookkeeping for clinical trial financial operations.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitAmount rdf:type rdf:Property ;
    rdfs:label 'Debit Amount' ;
    rdfs:comment 'The gross debit amount posted on this journal entry line in the transaction currency. Represents increases to asset/expense accounts or decreases to liability/revenue accounts. Core component of double-entry bookkeeping for clinical trial financial operations.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'SAP S/4HANA debit/credit indicator for the journal entry line item. \'D\' denotes a debit posting; \'C\' denotes a credit posting. Fundamental to double-entry bookkeeping and financial statement preparation for clinical trial operations.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTypeCode rdf:type rdf:Property ;
    rdfs:label 'Document Type Code' ;
    rdfs:comment 'SAP S/4HANA document type code classifying the nature of the journal entry (e.g., SA=General Ledger, KR=Vendor Invoice, DR=Customer Invoice, AB=Accounting Document, ZP=Payment Posting). Determines number range assignment and posting rules. [ENUM-REF-CANDIDATE: SA|KR|DR|AB|ZP|RE|KZ|DZ|AA|WA — promote to reference product]' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryType rdf:type rdf:Property ;
    rdfs:label 'Entry Type' ;
    rdfs:comment 'Business classification of the journal entry indicating its purpose in the financial close process. Distinguishes original postings from period-end accruals, reversals, adjustments, reclassifications, and intercompany eliminations for clinical trial cost management.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headerText rdf:type rdf:Property ;
    rdfs:label 'Header Text' ;
    rdfs:comment 'Free-text description at the journal entry header level in SAP S/4HANA providing business context for the posting (e.g., \'Q3 site payment accrual - Study XYZ\', \'Investigator grant milestone 2 - Site 001\'). Supports audit review and financial reporting narrative.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Order Number' ;
    rdfs:comment 'SAP S/4HANA internal order number used to collect costs for a specific clinical trial activity, investigator grant, or pass-through cost category. Complements WBS elements for granular cost tracking at the study or site level.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReversed rdf:type rdf:Property ;
    rdfs:label 'Is Reversed' ;
    rdfs:comment 'Indicates whether this journal entry has been reversed in SAP S/4HANA. True if a reversal document exists; False otherwise. Used to exclude reversed entries from financial reporting and to identify correcting entry pairs for SOX controls.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineItemText rdf:type rdf:Property ;
    rdfs:label 'Line Item Text' ;
    rdfs:comment 'Free-text description at the individual line item level in SAP S/4HANA providing specific context for the debit or credit posting (e.g., \'Pass-through lab cost - Site 005\', \'Patient stipend accrual - Period 6\'). Supports granular audit trail and cost analysis.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount' ;
    rdfs:comment 'The net journal entry amount translated into the company code local currency (functional currency) using the exchange rate applied at posting time. Used for statutory financial reporting and local regulatory compliance.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the company code local (functional) currency into which the transaction currency amounts are translated. Required for multi-currency consolidation and statutory reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current lifecycle state of the journal entry within the SAP S/4HANA financial workflow. Controls whether the entry is visible in financial reporting and period-end close. [ENUM-REF-CANDIDATE: draft|posted|reversed|parked|held|cleared — promote to reference product if additional states are required]' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External or internal reference document number associated with the journal entry (e.g., vendor invoice number, sponsor purchase order number, site payment milestone reference, or pass-through cost receipt number). Enables cross-system reconciliation and audit trail linkage.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorBillable rdf:type rdf:Property ;
    rdfs:label 'Sponsor Billable' ;
    rdfs:comment 'Indicates whether the cost or revenue captured in this journal entry is billable to the pharmaceutical or biotech sponsor under the clinical trial contract. Drives sponsor invoicing, accounts receivable generation, and revenue recognition for the Contract Research Organization (CRO).' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the transaction currency in which the journal entry amounts (debit/credit) are originally recorded. Supports multi-currency clinical trial operations across global sponsor and site jurisdictions.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientStipendId rdf:type rdf:Property ;
    rdfs:label 'Patient Stipend Id' ;
    rdfs:comment 'Unique system-generated identifier for each patient stipend or reimbursement payment record. Primary key for the patient_stipend data product.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatientStipend .

ind:enrollmentId rdf:type rdf:Property ;
    rdfs:label 'Enrollment Id' ;
    rdfs:comment 'Foreign key linking to subject.enrollment. Business justification: Stipend budget management requires tying each payment to the specific enrollment record — critical for re-screened subjects who enroll multiple times and for per-enrollment stipend cap enforcement per' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Enrollment .

ind:reissueOfStipendId rdf:type rdf:Property ;
    rdfs:label 'Reissue Of Stipend Id' ;
    rdfs:comment 'Reference to the original patient_stipend_id that this record replaces or reissues (e.g., due to lost check, failed bank transfer, or payment correction). Enables payment lineage tracking and prevents duplicate disbursement.' ;
    rdfs:domain ind:PatientStipend ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PatientStipend .

ind:fmvCompliant rdf:type rdf:Property ;
    rdfs:label 'Fmv Compliant' ;
    rdfs:comment 'Indicates whether the stipend payment amount is within the approved fair market value range as reviewed by the IRB/IEC. A value of True confirms compliance; False triggers a compliance review workflow.' ;
    rdfs:domain ind:PatientStipend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fmvRate rdf:type rdf:Property ;
    rdfs:label 'Fmv Rate' ;
    rdfs:comment 'Approved fair market value rate for this stipend type as established by the IRB/IEC and sponsor. Used to validate that payment amounts comply with regulatory guidelines preventing undue inducement of study participation.' ;
    rdfs:domain ind:PatientStipend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:irbApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Irb Approval Reference' ;
    rdfs:comment 'Reference number of the IRB/IEC approval that authorized the subject payment plan for this study. Confirms that the stipend structure has been reviewed and approved by the ethics committee as required by GCP.' ;
    rdfs:domain ind:PatientStipend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'Actual amount disbursed to the subject after tax withholding deductions. Equals payment_amount minus tax_withheld_amount. Used for subject-facing payment confirmation and financial reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'Gross stipend or reimbursement amount to be paid to the subject before any applicable tax withholding. Expressed in the payment currency. Used for budget tracking and FMV compliance assessment.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'Calendar date on which the stipend payment was or is scheduled to be disbursed to the subject. Used for financial period accruals, cash flow reporting, and subject retention tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentProcessor rdf:type rdf:Property ;
    rdfs:label 'Payment Processor' ;
    rdfs:comment 'Name of the third-party payment processing vendor or financial institution used to disburse the stipend (e.g., Greenphire ClinCard, BioClinica, bank name). Supports vendor management and reconciliation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'External payment processor or bank reference number assigned upon successful disbursement (e.g., ACH trace number, check number, prepaid card transaction ID). Used for payment reconciliation and dispute resolution.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current lifecycle state of the stipend payment record within the payment workflow. Drives operational processing, financial accruals, and reconciliation activities in SAP S/4HANA.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptReceived rdf:type rdf:Property ;
    rdfs:label 'Receipt Received' ;
    rdfs:comment 'Indicates whether the required supporting receipt or documentation has been received from the subject prior to payment processing. Blocks payment disbursement when receipt_required is True and this flag is False.' ;
    rdfs:domain ind:PatientStipend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptRequired rdf:type rdf:Property ;
    rdfs:label 'Receipt Required' ;
    rdfs:comment 'Indicates whether supporting documentation (e.g., travel receipt, parking receipt) is required to process this reimbursement payment. Applicable primarily to expense reimbursement stipend types.' ;
    rdfs:domain ind:PatientStipend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stipendNumber rdf:type rdf:Property ;
    rdfs:label 'Stipend Number' ;
    rdfs:comment 'Externally-visible, human-readable reference number assigned to this stipend payment record, used for cross-system reconciliation and subject communication. Sourced from SAP S/4HANA accounts payable module.' ;
    rdfs:domain ind:PatientStipend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stipendType rdf:type rdf:Property ;
    rdfs:label 'Stipend Type' ;
    rdfs:comment 'Classification of the stipend or reimbursement category. Determines the nature of the payment for fair market value (FMV) compliance, tax reporting, and budget allocation. [ENUM-REF-CANDIDATE: participation_fee|travel_reimbursement|meal_allowance|lodging_reimbursement|caregiver_allowance|incidental_expense — promote to reference product]' ;
    rdfs:domain ind:PatientStipend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectConsentVerified rdf:type rdf:Property ;
    rdfs:label 'Subject Consent Verified' ;
    rdfs:comment 'Indicates whether the subject\'s valid informed consent (ICF) has been verified as current and on file prior to processing this stipend payment. Ensures payment is only made to consented participants.' ;
    rdfs:domain ind:PatientStipend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxFormType rdf:type rdf:Property ;
    rdfs:label 'Tax Form Type' ;
    rdfs:comment 'Type of tax reporting form applicable to this stipend payment based on jurisdiction and payment classification. Populated only when tax_reportable is True. Supports year-end tax compliance reporting.' ;
    rdfs:domain ind:PatientStipend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportable rdf:type rdf:Property ;
    rdfs:label 'Tax Reportable' ;
    rdfs:comment 'Indicates whether this stipend payment is subject to tax reporting obligations (e.g., IRS Form 1099-MISC in the U.S.). Drives year-end tax reporting processes and subject tax notification workflows.' ;
    rdfs:domain ind:PatientStipend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxWithheldAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Withheld Amount' ;
    rdfs:comment 'Amount of tax withheld from the gross stipend payment prior to disbursement to the subject. Applicable where local tax regulations require withholding on research participation payments.' ;
    rdfs:domain ind:PatientStipend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visitCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Visit Completion Date' ;
    rdfs:comment 'Date on which the associated study visit was completed by the subject, triggering the stipend payment obligation. Establishes the business event date distinct from the payment disbursement date.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryTerms rdf:type rdf:Property ;
    rdfs:label 'Delivery Terms' ;
    rdfs:comment 'International commercial terms (Incoterms) governing delivery obligations, risk transfer, and cost allocation between the CRO and vendor (e.g., EXW, FOB, CIF, DDP). Relevant for clinical supply chain and central lab shipments.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Date' ;
    rdfs:comment 'The date on which goods or services were confirmed as received from the vendor. Used for accrual period determination, invoice matching, and accounts payable processing.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsReceiptStatus rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Status' ;
    rdfs:comment 'Indicates whether goods or services ordered under this PO have been received: not received, partially received, or fully received. Drives accounts payable invoice matching (3-way match) and accrual calculations in SAP S/4HANA.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current accounts payable invoice processing status for this purchase order. Tracks whether vendor invoices have been received, matched, and processed against the PO in SAP S/4HANA FI-AP.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoicedAmount rdf:type rdf:Property ;
    rdfs:label 'Invoiced Amount' ;
    rdfs:comment 'Cumulative amount invoiced by the vendor against this purchase order to date, in PO currency. Used to calculate open commitment (PO value minus invoiced amount) for accrual and financial forecasting.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poDate rdf:type rdf:Property ;
    rdfs:label 'Po Date' ;
    rdfs:comment 'The business date on which the purchase order was formally issued to the vendor. This is the principal real-world event date for the procurement transaction, distinct from the system creation timestamp.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Po Gross Amount' ;
    rdfs:comment 'The total gross value of the purchase order before any discounts, taxes, or adjustments, expressed in the PO currency. Represents the full procurement commitment.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Externally-known, human-readable purchase order number assigned by SAP S/4HANA MM module (e.g., PO-2024-000123). Used in vendor communications, accounts payable matching, and audit trails.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order, tracking progression from draft through approval, issuance, goods/service receipt, and closure or cancellation. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|issued|partially_received|fully_received|closed|cancelled — promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order by procurement instrument type: standard (single delivery), blanket (multiple releases against a ceiling), framework (master agreement call-off), service (service entry sheet-based), or emergency (expedited procurement).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingGroup rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group' ;
    rdfs:comment 'SAP S/4HANA purchasing group (buyer group) code identifying the team or individual buyer responsible for managing this purchase order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrg rdf:type rdf:Property ;
    rdfs:label 'Purchasing Org' ;
    rdfs:comment 'SAP S/4HANA purchasing organization code responsible for negotiating and issuing this purchase order. Represents the organizational unit with procurement authority.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapMmDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Mm Document Number' ;
    rdfs:comment 'The SAP S/4HANA Materials Management (MM) module document reference number for this purchase order (EKKO table key). Enables traceability back to the system of record for audit and reconciliation.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorBillableFlag rdf:type rdf:Property ;
    rdfs:label 'Sponsor Billable Flag' ;
    rdfs:comment 'Indicates whether this purchase order\'s costs are billable to the pharmaceutical or biotech sponsor under the clinical trial agreement. Drives sponsor invoicing and accounts receivable processes.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorCategory rdf:type rdf:Property ;
    rdfs:label 'Vendor Category' ;
    rdfs:comment 'Classification of the vendor type for this purchase order, enabling spend analytics by vendor category across clinical trial operations. [ENUM-REF-CANDIDATE: central_lab|imaging_cro|specialty_vendor|courier|site_services|regulatory_services|it_services|other — promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorQuoteNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Quote Number' ;
    rdfs:comment 'The vendor\'s quotation or proposal reference number that this purchase order is based upon. Enables traceability from PO back to the sourcing event and vendor bid documentation.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionId rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Id' ;
    rdfs:comment 'Unique surrogate identifier for each revenue recognition event record in the clinical trial financial system. Primary key for the revenue_recognition data product.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Reference to the sponsor contract (master service agreement or work order) under which clinical trial services are being delivered and revenue is being recognized. Ties the recognition event to the governing commercial agreement.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudyContract .

ind:originalRecognitionRevenueRecognitionId rdf:type rdf:Property ;
    rdfs:label 'Original Recognition Revenue Recognition Id' ;
    rdfs:comment 'For reversal entries (reversal_flag = True), references the revenue_recognition_id of the original recognition event being reversed. Enables complete audit trail linking reversals to their source entries for SOX compliance.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognition .

ind:performanceObligationId rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Id' ;
    rdfs:comment 'Reference to the distinct performance obligation (e.g., site management, data management, biostatistics, regulatory submission) as defined under ASC 606 / IFRS 15 for the sponsor contract. Each obligation has its own transaction price allocation and recognition schedule.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:accrualFlag rdf:type rdf:Property ;
    rdfs:label 'Accrual Flag' ;
    rdfs:comment 'Indicates whether this recognition event represents an accrual entry (True) or an actual posted recognition (False). Accrual entries are created at period-end for services delivered but not yet formally invoiced or milestone-triggered. Critical for period-close accuracy and SOX controls.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'The estimated percentage of the performance obligation completed as of the recognition date, expressed as a decimal (e.g., 0.6500 = 65.00%). Drives the percentage-of-completion revenue recognition calculation. Derived from cost-to-cost, effort-based, or output-based measures depending on the recognition method.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractModificationFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Modification Flag' ;
    rdfs:comment 'Indicates whether this recognition event was triggered by or resulted from a contract modification (change order, scope amendment) to the sponsor agreement (True) or is a standard recognition event (False). Contract modifications require reassessment of transaction price allocation under ASC 606 / IFRS 15.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractValue rdf:type rdf:Property ;
    rdfs:label 'Contract Value' ;
    rdfs:comment 'The total transaction price allocated to this performance obligation under the sponsor contract, as defined in ASC 606 Step 4. Represents the full expected revenue for the obligation over the contract term. Used as the denominator in percentage-of-completion calculations.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeRecognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Recognized Amount' ;
    rdfs:comment 'The total revenue recognized to date for this performance obligation from contract inception through the current recognition date. Used to calculate remaining revenue to be recognized and to validate percentage-of-completion calculations against contract value.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredRevenueBalance rdf:type rdf:Property ;
    rdfs:label 'Deferred Revenue Balance' ;
    rdfs:comment 'The remaining unrecognized contract liability (deferred revenue) for this performance obligation as of the recognition date. Calculated as contract_value minus cumulative_recognized_amount. Reported on the balance sheet as a liability until earned. Critical for ASC 606 / IFRS 15 contract liability disclosure.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 code for the entity\'s functional currency used for financial statement reporting (e.g., USD for a US-based CRO). Amounts may differ from contract currency due to foreign exchange translation. Required for multi-currency consolidation.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fxRate rdf:type rdf:Property ;
    rdfs:label 'Fx Rate' ;
    rdfs:comment 'The exchange rate applied to convert contract currency amounts to functional currency as of the recognition date. Stored for audit traceability and to support foreign currency gain/loss analysis. Sourced from SAP S/4HANA exchange rate tables.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorPeriodCompletionPercentage rdf:type rdf:Property ;
    rdfs:label 'Prior Period Completion Percentage' ;
    rdfs:comment 'The percentage of completion recorded in the immediately preceding recognition period. Used to calculate the incremental completion percentage and the resulting incremental recognized revenue for the current period. Supports period-over-period variance analysis.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rarDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Rar Document Number' ;
    rdfs:comment 'Human-readable SAP RAR document number (e.g., RAR-2024-000123) assigned by SAP S/4HANA to the revenue accounting document. Used for cross-referencing with SAP financial reports, audit packages, and SOX control evidence.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rarDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Rar Document Reference' ;
    rdfs:comment 'Reference to the SAP RAR (Revenue Accounting and Reporting) performance obligation document that governs this recognition event. Links the lakehouse record to the authoritative SAP S/4HANA source document for SOX audit traceability.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recognitionDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Date' ;
    rdfs:comment 'The accounting date on which revenue is formally recognized in the general ledger. Determines the fiscal period to which the recognized amount is attributed. Aligned with the percentage-of-completion calculation as of this date.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Recognition Method' ;
    rdfs:comment 'The accounting methodology applied to recognize revenue for this event. \'percentage_of_completion\' is the primary method for CRO services under ASC 606 / IFRS 15 over-time recognition. \'milestone\' applies when a distinct contractual milestone triggers recognition. \'straight_line\' applies for time-based service obligations. \'output_method\' and \'input_method\' reflect ASC 606 Step 5 measure-of-progress approaches.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Recognition Status' ;
    rdfs:comment 'Current workflow state of the revenue recognition event. \'draft\' indicates a preliminary calculation pending review; \'pending_review\' indicates awaiting finance controller approval; \'recognized\' indicates posted to the general ledger; \'reversed\' indicates a correcting reversal has been posted; \'cancelled\' indicates the event was voided prior to posting.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Recognized Amount' ;
    rdfs:comment 'The revenue amount recognized in the current recognition period for this event. Represents the incremental revenue posted to the general ledger in this fiscal period. Core financial metric for period-close reporting and sponsor revenue reporting.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recognizedAmountFunctional rdf:type rdf:Property ;
    rdfs:label 'Recognized Amount Functional' ;
    rdfs:comment 'The recognized revenue amount translated into the entity\'s functional currency using the fx_rate as of the recognition date. Used for consolidated financial reporting and SOX-controlled general ledger postings in the functional currency.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this recognition event is a reversal of a prior period recognition (True) or an original recognition entry (False). Reversals occur for corrections, contract modifications, or accrual true-ups. Supports audit trail completeness.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceLine rdf:type rdf:Property ;
    rdfs:label 'Service Line' ;
    rdfs:comment 'The CRO service line category under which the recognized revenue is classified (e.g., clinical_operations for site management and monitoring, data_management for EDC/eCRF services, biostatistics for SAP/analysis, regulatory_affairs for submission support). Supports service-line revenue reporting and margin analysis. [ENUM-REF-CANDIDATE: clinical_operations|data_management|biostatistics|regulatory_affairs|safety|laboratory|medical_writing|project_management — promote to reference product]' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlReference rdf:type rdf:Property ;
    rdfs:label 'Sox Control Reference' ;
    rdfs:comment 'The SOX internal control reference number (e.g., FIN-REV-001) associated with this revenue recognition event. Documents the specific SOX control applied during the recognition process for audit evidence and ICFR (Internal Controls over Financial Reporting) compliance.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unbilledReceivableAmount rdf:type rdf:Property ;
    rdfs:label 'Unbilled Receivable Amount' ;
    rdfs:comment 'The contract asset amount representing revenue recognized but not yet invoiced to the sponsor as of the recognition date. Arises when revenue recognition outpaces billing milestones. Reported on the balance sheet as a contract asset per ASC 606 / IFRS 15.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sitePaymentId rdf:type rdf:Property ;
    rdfs:label 'Site Payment Id' ;
    rdfs:comment 'Unique surrogate identifier for each site payment disbursement record in the clinical trial finance system. Primary key for this transactional entity.' ;
    rdfs:domain ind:SitePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalPaymentSitePaymentId rdf:type rdf:Property ;
    rdfs:label 'Original Payment Site Payment Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original site_payment record that this record reverses or amends. Null for original payments; populated only when reversal_indicator is True.' ;
    rdfs:domain ind:SitePayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SitePayment .

ind:siteAgreementId rdf:type rdf:Property ;
    rdfs:label 'Site Agreement Id' ;
    rdfs:comment 'Reference to the Clinical Trial Agreement (CTA) or investigator grant agreement under which this payment is being made. Establishes the contractual basis for the disbursement.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SiteAgreement .

ind:bankAccountReference rdf:type rdf:Property ;
    rdfs:label 'Bank Account Reference' ;
    rdfs:comment 'Masked or tokenized reference to the investigational site bank account used for this disbursement, as registered in SAP S/4HANA vendor banking details. Full account details are stored in the secure banking master; this field holds a non-sensitive reference token.' ;
    rdfs:domain ind:SitePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCountryCode rdf:type rdf:Property ;
    rdfs:label 'Bank Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the bank where the site\'s receiving account is held. Used for cross-border payment routing, SWIFT/SEPA determination, and withholding tax jurisdiction assessment.' ;
    rdfs:domain ind:SitePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsPaymentRef rdf:type rdf:Property ;
    rdfs:label 'Ctms Payment Ref' ;
    rdfs:comment 'Cross-reference identifier from Oracle Siebel CTMS linking this financial disbursement record to the corresponding milestone completion event tracked in the clinical trial management system. Enables finance-to-operations reconciliation.' ;
    rdfs:domain ind:SitePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdvancePayment rdf:type rdf:Property ;
    rdfs:label 'Is Advance Payment' ;
    rdfs:comment 'Indicates whether this disbursement is an advance payment (True) made to the site prior to milestone completion, requiring future reconciliation against earned milestones, or a standard post-completion payment (False).' ;
    rdfs:domain ind:SitePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Payment Approval Date' ;
    rdfs:comment 'Date on which the site payment was formally approved by the authorized finance approver in the SAP S/4HANA workflow, prior to disbursement. Required for SOX dual-control compliance.' ;
    rdfs:domain ind:SitePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Number' ;
    rdfs:comment 'Externally-known, human-readable payment reference number assigned by SAP S/4HANA Accounts Payable at the time of disbursement. Used for reconciliation with site bank statements and sponsor invoicing. Corresponds to the SAP AP document number.' ;
    rdfs:domain ind:SitePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReferenceNote rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Note' ;
    rdfs:comment 'Free-text reference note or remittance advice text included with the payment to the site, identifying the study, milestone, or invoice being paid. Appears on the bank transfer or check stub.' ;
    rdfs:domain ind:SitePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Classification of the payment by the type of clinical trial activity it compensates: milestone-based, per-procedure fee, per-visit fee, site startup, study closeout, pass-through cost reimbursement, patient stipend, or overhead. [ENUM-REF-CANDIDATE: milestone|per_procedure|per_visit|startup|closeout|pass_through|stipend|overhead — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentValueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Value Date' ;
    rdfs:comment 'The bank value date on which funds are credited to the site\'s bank account, which may differ from the payment_date (posting date) due to banking clearing cycles. Used for cash flow forecasting and bank reconciliation.' ;
    rdfs:domain ind:SitePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Indicates whether this payment record represents a reversal (True) of a previously posted payment, used to correct erroneous disbursements. Reversed payments must be linked to the original via original_payment_id.' ;
    rdfs:domain ind:SitePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapApDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Ap Document Number' ;
    rdfs:comment 'SAP S/4HANA Accounts Payable document number generated when the payment was posted. Serves as the primary cross-reference between the clinical trial finance data product and the ERP system of record for audit and SOX compliance.' ;
    rdfs:domain ind:SitePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPaymentRunReference rdf:type rdf:Property ;
    rdfs:label 'Sap Payment Run Reference' ;
    rdfs:comment 'Identifier of the SAP S/4HANA automatic payment program run (F110) that generated this disbursement. Enables batch-level reconciliation and audit tracing of grouped payment runs.' ;
    rdfs:domain ind:SitePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapVendorCode rdf:type rdf:Property ;
    rdfs:label 'Sap Vendor Code' ;
    rdfs:comment 'SAP S/4HANA vendor master record identifier for the investigational site or principal investigator entity receiving the payment. Used to match the payment to the correct payee in the ERP.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'Amount of withholding tax deducted from the gross payment prior to disbursement, as required by applicable tax jurisdiction rules. Zero if no withholding tax applies.' ;
    rdfs:domain ind:SitePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxCode rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Code' ;
    rdfs:comment 'SAP S/4HANA withholding tax code identifying the applicable tax type and rate configuration for this payment. Used for tax reporting (e.g., IRS Form 1042-S, local equivalents).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxRate rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Rate' ;
    rdfs:comment 'Percentage rate of withholding tax applied to the gross payment amount, as determined by the applicable tax treaty or local tax regulation for the site\'s jurisdiction. Expressed as a decimal (e.g., 0.3000 = 30%).' ;
    rdfs:domain ind:SitePayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingSponsorContactId rdf:type rdf:Property ;
    rdfs:label 'Billing Sponsor Contact Id' ;
    rdfs:comment 'Foreign key linking to sponsor.sponsor_contact. Business justification: Invoices must be routed to the sponsor\'s designated billing contact. sponsor_invoice.billing_contact_name and billing_contact_email are denormalized from sponsor_contact. Accounts receivable teams req' ;
    rdfs:domain ind:SponsorInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SponsorContact .

ind:amountPaid rdf:type rdf:Property ;
    rdfs:label 'Amount Paid' ;
    rdfs:comment 'Total amount received from the sponsor against this invoice to date. May be less than net_amount for partially paid invoices. Expressed in invoice currency.' ;
    rdfs:domain ind:SponsorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'The last date of the service period covered by this invoice. Defines the end of the billing window for accrual and revenue recognition purposes.' ;
    rdfs:domain ind:SponsorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'The first date of the service period covered by this invoice. Together with billing_period_end_date, defines the time window for which clinical trial services are being billed.' ;
    rdfs:domain ind:SponsorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditMemoRefInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Ref Invoice Number' ;
    rdfs:comment 'For credit memos and debit memos, the invoice_number of the original invoice being adjusted. Establishes the audit trail linking adjustments to originating billing documents.' ;
    rdfs:domain ind:SponsorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total pre-tax, pre-discount amount of all billable services and pass-through costs included in this invoice before any adjustments. Expressed in the invoice currency.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDescription rdf:type rdf:Property ;
    rdfs:label 'Invoice Description' ;
    rdfs:comment 'Free-text description of the services, milestones, or deliverables covered by this invoice. Provides context for sponsor review, dispute resolution, and audit documentation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Remaining unpaid balance on this invoice (net_amount - amount_paid). Drives AR aging reports, collections prioritization, and bad debt provisioning. Expressed in invoice currency.' ;
    rdfs:domain ind:SponsorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'SAP payment terms code defining the contractual payment schedule (e.g., NET30, NET45, NET60, 2/10NET30). Determines due date calculation and early payment discount eligibility.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ref rdf:type rdf:Property ;
    rdfs:label 'Ref' ;
    rdfs:comment 'The sponsor\'s own reference or tracking number assigned to this invoice in their accounts payable system. Facilitates cross-system reconciliation and dispute resolution.' ;
    rdfs:domain ind:SponsorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapArDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Ar Document Number' ;
    rdfs:comment 'The SAP S/4HANA accounts receivable document number generated upon posting of this invoice. Serves as the system-of-record identifier for GL reconciliation, audit trails, and SOX compliance.' ;
    rdfs:domain ind:SponsorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorPoNumber rdf:type rdf:Property ;
    rdfs:label 'Sponsor Po Number' ;
    rdfs:comment 'The sponsor\'s internal purchase order number referencing this invoice. Required by most pharmaceutical sponsors for invoice processing and payment authorization. Critical for remittance matching.' ;
    rdfs:domain ind:SponsorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedDate rdf:type rdf:Property ;
    rdfs:label 'Submitted Date' ;
    rdfs:comment 'The date the invoice was formally submitted to the sponsor for payment. Marks the start of the payment terms clock and is used for AR aging and collections tracking.' ;
    rdfs:domain ind:SponsorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Budget Effective Date' ;
    rdfs:comment 'The date from which this budget version becomes financially binding and active for cost tracking and sponsor invoicing purposes.' ;
    rdfs:domain ind:StudyBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Budget Expiry Date' ;
    rdfs:comment 'The date on which this budget version expires or is superseded by a new amendment. Null for the currently active version. Supports version history management.' ;
    rdfs:domain ind:StudyBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetNumber rdf:type rdf:Property ;
    rdfs:label 'Budget Number' ;
    rdfs:comment 'Externally-known, human-readable budget reference number assigned by SAP S/4HANA project accounting. Used in sponsor invoicing, financial reporting, and SOX audit trails.' ;
    rdfs:domain ind:StudyBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle state of the study budget record. Drives workflow approvals, financial controls, and SOX-compliant change management. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|amended|closed|cancelled — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the budget record indicating whether it represents the original approved budget, a formal amendment, a supplemental allocation, or a contingency reserve.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingencyAmount rdf:type rdf:Property ;
    rdfs:label 'Contingency Amount' ;
    rdfs:comment 'Budgeted contingency reserve amount set aside for unforeseen study costs, protocol deviations, or scope changes. Typically expressed as a percentage of total direct costs.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:directCostAmount rdf:type rdf:Property ;
    rdfs:label 'Direct Cost Amount' ;
    rdfs:comment 'Portion of the total approved budget allocated to direct study costs, including clinical operations, site management, data management, and biostatistics activities.' ;
    rdfs:domain ind:StudyBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indirectCostAmount rdf:type rdf:Property ;
    rdfs:label 'Indirect Cost Amount' ;
    rdfs:comment 'Portion of the total approved budget allocated to indirect costs such as administrative overhead, facility costs, and shared service allocations not directly attributable to a single study activity.' ;
    rdfs:domain ind:StudyBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investigatorGrantAmount rdf:type rdf:Property ;
    rdfs:label 'Investigator Grant Amount' ;
    rdfs:comment 'Total budgeted amount for investigator grants payable to Principal Investigators (PIs) and clinical sites for conducting study procedures per the site payment schedule.' ;
    rdfs:domain ind:StudyBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPassThroughBillable rdf:type rdf:Property ;
    rdfs:label 'Is Pass Through Billable' ;
    rdfs:comment 'Indicates whether pass-through costs in this budget are contractually billable to the sponsor at cost without markup. Drives accounts receivable and sponsor invoicing logic.' ;
    rdfs:domain ind:StudyBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overheadAmount rdf:type rdf:Property ;
    rdfs:label 'Overhead Amount' ;
    rdfs:comment 'Overhead allocation applied to the study budget, typically calculated as a percentage of direct costs per the CRO\'s overhead rate agreement with the sponsor.' ;
    rdfs:domain ind:StudyBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passThroughEstimateAmount rdf:type rdf:Property ;
    rdfs:label 'Pass Through Estimate Amount' ;
    rdfs:comment 'Estimated amount for pass-through costs to be billed directly to the sponsor at cost, including central lab fees, imaging, specialty vendors, and IRB/IEC fees. Tracked separately from CRO service fees.' ;
    rdfs:domain ind:StudyBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:patientStipendAmount rdf:type rdf:Property ;
    rdfs:label 'Patient Stipend Amount' ;
    rdfs:comment 'Total budgeted amount for patient stipends and reimbursements, including travel, parking, and participation compensation paid to study subjects per IRB/IEC-approved amounts.' ;
    rdfs:domain ind:StudyBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studyEndDate rdf:type rdf:Property ;
    rdfs:label 'Study End Date' ;
    rdfs:comment 'Planned or actual end date of the clinical study as reflected in the budget planning horizon. Used for financial close-out planning and final accrual calculations.' ;
    rdfs:domain ind:StudyBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyStartDate rdf:type rdf:Property ;
    rdfs:label 'Study Start Date' ;
    rdfs:comment 'Planned or actual start date of the clinical study as reflected in the budget planning horizon. Used for fiscal period allocation and accrual scheduling.' ;
    rdfs:domain ind:StudyBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Budget Amount' ;
    rdfs:comment 'The total approved financial budget envelope for the clinical study in the transaction currency. Represents the gross budget including direct costs, indirect costs, overhead, and pass-through estimates. Serves as the financial baseline for variance analysis and sponsor invoicing.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringCraAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Cra Assignment Id' ;
    rdfs:comment 'Foreign key linking to monitoring.cra_assignment. Business justification: CRO vendor invoices for outsourced monitoring services are billed against specific CRA site assignments. Linking the invoice to the CRA assignment enables invoice validation against contracted scope, ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MonitoringCraAssignment .

ind:remsProgramId rdf:type rdf:Property ;
    rdfs:label 'Rems Program Id' ;
    rdfs:comment 'Foreign key linking to regulatory.rems_program. Business justification: REMS programs involve third-party administrators, call centers, and patient support vendors who submit invoices against the REMS program. Linking vendor invoices to the REMS program enables REMS Opera' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RemsProgram .

ind:earlyPaymentDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Amount' ;
    rdfs:comment 'The cash discount amount available if payment is made within the early payment discount period as defined in the payment terms. Supports working capital optimization and discount capture reporting.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Number' ;
    rdfs:comment 'The SAP material document number for the goods receipt or service entry sheet that confirms delivery of goods or services against the purchase order. Required for three-way match validation in SAP FI-AP.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the vendor invoice by document type. Distinguishes standard invoices, credit/debit memos, pro-forma invoices, recurring service invoices, and pass-through cost invoices billable to sponsors.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlockIndicator rdf:type rdf:Property ;
    rdfs:label 'Payment Block Indicator' ;
    rdfs:comment 'Indicates whether the invoice is blocked from payment processing and the reason for the block. Blocked invoices require resolution before inclusion in payment runs. Supports AP workflow management and SOX controls.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Document Number' ;
    rdfs:comment 'The SAP FI payment document number generated when the vendor invoice is cleared through a payment run. Populated after payment execution; null for unpaid invoices. Used for payment reconciliation and audit trail.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'The date the vendor invoice was physically or electronically received by the clinical trials organization. Used to calculate payment due dates based on payment terms and for aging analysis.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sponsorReimbursementStatus rdf:type rdf:Property ;
    rdfs:label 'Sponsor Reimbursement Status' ;
    rdfs:comment 'Tracks the reimbursement status of pass-through costs with the sponsor. Applicable only when is_pass_through is True. Drives sponsor invoicing, accounts receivable follow-up, and pass-through cost recovery reporting.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Status of the three-way match validation between the purchase order (PO), goods receipt (GR), and vendor invoice. Fully matched invoices are eligible for payment posting. Exceptions require AP team resolution before payment.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Reference Number' ;
    rdfs:comment 'The vendor\'s own internal reference or contract number associated with this invoice, as provided by the vendor. Used for vendor reconciliation, dispute resolution, and cross-referencing with vendor accounts receivable records.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTmfDocumentId rdf:type rdf:Property ;
    rdfs:label 'Validation Tmf Document Id' ;
    rdfs:comment 'Foreign key linking to document.tmf_document. Business justification: Bioanalytical validation reports are TMF documents (DIA TMF Reference Model Zone 3, Section 3.2). Regulatory submissions require direct navigation from the assay record to the filed validation report.' ;
    rdfs:domain ind:BioanalyticalAssay ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TmfDocument .

ind:accuracyPercent rdf:type rdf:Property ;
    rdfs:label 'Accuracy Percent' ;
    rdfs:comment 'Mean accuracy of the assay expressed as percent of nominal concentration (%Nominal) at QC levels during validation. Regulatory acceptance criterion is typically 85–115% (80–120% at LLOQ). Stored as the worst-case value across QC levels.' ;
    rdfs:domain ind:BioanalyticalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analyteCategory rdf:type rdf:Property ;
    rdfs:label 'Analyte Category' ;
    rdfs:comment 'Broad classification of the analyte type measured by the assay. Distinguishes small molecule drugs (PK), large molecule biologics, biomarkers (PD), immunogenicity (anti-drug antibodies), metabolites, and endogenous compounds. Drives regulatory submission strategy and validation requirements.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analyteName rdf:type rdf:Property ;
    rdfs:label 'Analyte Name' ;
    rdfs:comment 'Name of the substance being measured by the assay (e.g., drug compound, metabolite, biomarker, anti-drug antibody). Directly links the assay to the pharmacokinetic (PK), pharmacodynamic (PD), or immunogenicity endpoint it supports.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayCode rdf:type rdf:Property ;
    rdfs:label 'Assay Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to the assay by the bioanalytical laboratory or sponsor (e.g., \'BA-LC-001\', \'ELISA-TNF-003\'). Used as the business identifier across CTMS, EDC, and regulatory submissions. Satisfies MASTER_RESOURCE BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:BioanalyticalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayName rdf:type rdf:Property ;
    rdfs:label 'Assay Name' ;
    rdfs:comment 'Full descriptive name of the bioanalytical assay as used in study protocols, validation reports, and regulatory submissions (e.g., \'LC-MS/MS Assay for Compound XYZ in Human Plasma\'). Satisfies MASTER_RESOURCE IDENTITY_LABEL category.' ;
    rdfs:domain ind:BioanalyticalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayPurpose rdf:type rdf:Property ;
    rdfs:label 'Assay Purpose' ;
    rdfs:comment 'Primary scientific purpose the assay serves within the clinical or nonclinical program. PK (Pharmacokinetics) assays measure drug concentration over time; PD (Pharmacodynamics) assays measure biological effect; Immunogenicity assays detect anti-drug antibodies; DMPK (Drug Metabolism and Pharmacokinetics) assays support metabolite profiling. [ENUM-REF-CANDIDATE: PK|PD|Immunogenicity|Safety Biomarker|Efficacy Biomarker|DMPK|Other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BioanalyticalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayType rdf:type rdf:Property ;
    rdfs:label 'Assay Type' ;
    rdfs:comment 'Analytical technology platform used to perform the assay. Common types include LC-MS/MS (Liquid Chromatography-Tandem Mass Spectrometry), ELISA (Enzyme-Linked Immunosorbent Assay), ECL (Electrochemiluminescence), PCR (Polymerase Chain Reaction), Flow Cytometry, and LBA (Ligand Binding Assay). Satisfies MASTER_RESOURCE CLASSIFICATION_OR_TYPE category. [ENUM-REF-CANDIDATE: LC-MS/MS|ELISA|ECL|PCR|Flow Cytometry|LBA|HPLC|GC-MS|Western Blot|IHC|CLIA|RIA — promote to reference product]' ;
    rdfs:domain ind:BioanalyticalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationCurveModel rdf:type rdf:Property ;
    rdfs:label 'Calibration Curve Model' ;
    rdfs:comment 'Mathematical regression model used to fit the calibration curve for back-calculation of analyte concentrations from instrument response. Common models include Linear (1/x or 1/x² weighting), Quadratic, 4-Parameter Logistic (4PL), and 5-Parameter Logistic (5PL) for LBA methods.' ;
    rdfs:domain ind:BioanalyticalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdiscTestCode rdf:type rdf:Property ;
    rdfs:label 'Cdisc Test Code' ;
    rdfs:comment 'Standardized test code from the CDISC Controlled Terminology for the SDTM PC (Pharmacokinetics Concentrations) or LB (Laboratory Test Results) domain. Enables direct mapping of assay results to CDISC SDTM datasets for regulatory submission.' ;
    rdfs:domain ind:BioanalyticalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cutPointMethod rdf:type rdf:Property ;
    rdfs:label 'Cut Point Method' ;
    rdfs:comment 'Statistical method used to establish the screening and confirmatory cut points for immunogenicity (anti-drug antibody) assays (e.g., \'Parametric 5th percentile\', \'Non-parametric 5th percentile\'). Applicable only to immunogenicity assays; null for PK/PD assays.' ;
    rdfs:domain ind:BioanalyticalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dilutionIntegrityFactor rdf:type rdf:Property ;
    rdfs:label 'Dilution Integrity Factor' ;
    rdfs:comment 'Maximum validated dilution factor that can be applied to samples exceeding the ULOQ while maintaining assay accuracy and precision within acceptance criteria. Samples requiring dilution beyond this factor must be flagged.' ;
    rdfs:domain ind:BioanalyticalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gcpCompliant rdf:type rdf:Property ;
    rdfs:label 'Gcp Compliant' ;
    rdfs:comment 'Indicates whether the assay is performed under Good Clinical Practice (GCP) standards as required for clinical trial sample analysis. True = GCP-compliant; False = non-GCP. Distinct from GLP compliance — clinical samples require GCP; nonclinical samples require GLP.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glpCompliant rdf:type rdf:Property ;
    rdfs:label 'Glp Compliant' ;
    rdfs:comment 'Indicates whether the assay was validated and is performed under Good Laboratory Practice (GLP) regulations. GLP compliance is required for nonclinical safety studies submitted to regulatory agencies. True = GLP-compliant; False = non-GLP.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interRunPrecisionCv rdf:type rdf:Property ;
    rdfs:label 'Inter Run Precision Cv' ;
    rdfs:comment 'Between-run precision expressed as percent coefficient of variation (%CV) across multiple analytical runs during validation. Regulatory acceptance criterion is typically ≤15% (%CV). Stored as the worst-case value across QC levels.' ;
    rdfs:domain ind:BioanalyticalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalStandard rdf:type rdf:Property ;
    rdfs:label 'Internal Standard' ;
    rdfs:comment 'Name or identifier of the internal standard (IS) used in the assay for quantification normalization (e.g., stable isotope-labeled analog, structural analog). Critical for LC-MS/MS and other chromatographic methods to correct for matrix effects and extraction variability.' ;
    rdfs:domain ind:BioanalyticalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intraRunPrecisionCv rdf:type rdf:Property ;
    rdfs:label 'Intra Run Precision Cv' ;
    rdfs:comment 'Within-run precision expressed as percent coefficient of variation (%CV) at the QC concentration levels, as determined during validation. Regulatory acceptance criterion is typically ≤15% (%CV), or ≤20% at LLOQ. Stored as the worst-case value across QC levels.' ;
    rdfs:domain ind:BioanalyticalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lloq rdf:type rdf:Property ;
    rdfs:label 'Lloq' ;
    rdfs:comment 'Lower Limit of Quantification — the lowest analyte concentration that can be reliably quantified with acceptable accuracy and precision per the validated method. Expressed in the unit defined by lloq_uloq_unit. Critical for PK/PD data interpretation and regulatory submission. Satisfies MASTER_RESOURCE MEASUREMENT_OR_VALUE category.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lloqUloqUnit rdf:type rdf:Property ;
    rdfs:label 'Lloq Uloq Unit' ;
    rdfs:comment 'Unit of measurement for the LLOQ and ULOQ values (e.g., \'ng/mL\', \'pg/mL\', \'µg/mL\', \'nM\'). Must be consistent with the unit reported in PK/PD concentration data submitted to regulatory agencies.' ;
    rdfs:domain ind:BioanalyticalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longTermStabilityDays rdf:type rdf:Property ;
    rdfs:label 'Long Term Stability Days' ;
    rdfs:comment 'Number of days for which analyte stability in the biological matrix at long-term storage conditions (typically -20°C or -70°C) has been validated. Samples stored beyond this period require re-validation of stability before results can be reported.' ;
    rdfs:domain ind:BioanalyticalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matrixEffectAssessed rdf:type rdf:Property ;
    rdfs:label 'Matrix Effect Assessed' ;
    rdfs:comment 'Indicates whether matrix effect (ion suppression/enhancement for LC-MS/MS; non-specific binding for LBA) was formally evaluated during validation. True = matrix effect experiments conducted; False = not assessed.' ;
    rdfs:domain ind:BioanalyticalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matrixType rdf:type rdf:Property ;
    rdfs:label 'Matrix Type' ;
    rdfs:comment 'Biological matrix in which the analyte is measured (e.g., plasma, serum, whole blood, urine, cerebrospinal fluid). The assay is validated specifically for the declared matrix; use in a different matrix requires re-validation. [ENUM-REF-CANDIDATE: Plasma|Serum|Whole Blood|Urine|CSF|Tissue|Saliva|Feces|Synovial Fluid|Bronchoalveolar Lavage|Dried Blood Spot — promote to reference product]' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parallelismAssessed rdf:type rdf:Property ;
    rdfs:label 'Parallelism Assessed' ;
    rdfs:comment 'Indicates whether parallelism (serial dilution of incurred samples producing results parallel to the calibration curve) was assessed. Relevant primarily for LBA and immunogenicity assays. True = parallelism assessed; False = not assessed.' ;
    rdfs:domain ind:BioanalyticalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referenceStandardLot rdf:type rdf:Property ;
    rdfs:label 'Reference Standard Lot' ;
    rdfs:comment 'Lot number of the certified reference standard used to prepare calibration standards and quality control (QC) samples. Traceability of the reference standard lot is required for regulatory submissions and audit purposes.' ;
    rdfs:domain ind:BioanalyticalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleVolumeRequiredUl rdf:type rdf:Property ;
    rdfs:label 'Sample Volume Required Ul' ;
    rdfs:comment 'Minimum volume of biological matrix (in microliters) required per sample aliquot for a single assay run. Used for specimen collection planning, biobank management, and feasibility assessment of retrospective analyses.' ;
    rdfs:domain ind:BioanalyticalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:selectivityAssessed rdf:type rdf:Property ;
    rdfs:label 'Selectivity Assessed' ;
    rdfs:comment 'Indicates whether selectivity (absence of interference from endogenous matrix components) was formally assessed during validation. True = selectivity experiments conducted and documented; False = not assessed. Required for full validation per FDA/EMA/ICH M10.' ;
    rdfs:domain ind:BioanalyticalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:species rdf:type rdf:Property ;
    rdfs:label 'Species' ;
    rdfs:comment 'Biological species for which the assay has been validated. Assays validated in human matrices may differ from those validated in preclinical animal species used in DMPK studies. Drives applicability to clinical vs. nonclinical programs. [ENUM-REF-CANDIDATE: Human|Rat|Mouse|Dog|Monkey|Rabbit|Other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BioanalyticalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorAssayCode rdf:type rdf:Property ;
    rdfs:label 'Sponsor Assay Code' ;
    rdfs:comment 'Sponsor-assigned identifier for the assay as referenced in the study protocol, SAP, or regulatory submission. May differ from the CRO\'s internal assay code. Required for cross-referencing sponsor documents with CRO laboratory records.' ;
    rdfs:domain ind:BioanalyticalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityFreezeThawCycles rdf:type rdf:Property ;
    rdfs:label 'Stability Freeze Thaw Cycles' ;
    rdfs:comment 'Number of freeze-thaw cycles for which analyte stability in the biological matrix has been validated. Samples subjected to more freeze-thaw cycles than validated must be flagged or excluded from analysis.' ;
    rdfs:domain ind:BioanalyticalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageCondition rdf:type rdf:Property ;
    rdfs:label 'Storage Condition' ;
    rdfs:comment 'Required storage temperature and conditions for samples analyzed by this assay (e.g., \'-70°C ± 10°C\', \'-20°C\', \'2–8°C\'). Defines the chain-of-custody storage requirement for clinical samples to maintain analyte integrity.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByAssayCode rdf:type rdf:Property ;
    rdfs:label 'Superseded By Assay Code' ;
    rdfs:comment 'Assay code of the newer version that replaces this assay when it is retired or superseded. Supports version lineage tracking and ensures historical sample results can be linked to the correct assay version.' ;
    rdfs:domain ind:BioanalyticalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uloq rdf:type rdf:Property ;
    rdfs:label 'Uloq' ;
    rdfs:comment 'Upper Limit of Quantification — the highest analyte concentration that can be reliably quantified within the validated dynamic range. Samples above ULOQ must be diluted and re-assayed. Expressed in the unit defined by lloq_uloq_unit.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationDate rdf:type rdf:Property ;
    rdfs:label 'Validation Date' ;
    rdfs:comment 'Date on which the bioanalytical method validation was formally completed and the validation report was approved. Marks the point from which the assay is considered fit for regulated use in clinical sample analysis.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:weightingFactor rdf:type rdf:Property ;
    rdfs:label 'Weighting Factor' ;
    rdfs:comment 'Statistical weighting factor applied to the calibration curve regression to minimize heteroscedasticity (e.g., \'1/x\', \'1/x²\', \'none\'). Documented in the validation report and applied consistently during sample analysis.' ;
    rdfs:domain ind:BioanalyticalAssay ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bioanalyticalResultId rdf:type rdf:Property ;
    rdfs:label 'Bioanalytical Result Id' ;
    rdfs:comment 'Unique surrogate identifier for each bioanalytical or biomarker assay result record in the clinical trial laboratory data product. Serves as the primary key for the silver-layer lakehouse table.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BioanalyticalResult .

ind:pkSampleId rdf:type rdf:Property ;
    rdfs:label 'Pk Sample Id' ;
    rdfs:comment 'Reference to the biological specimen record from which this assay result was derived. Supports chain-of-custody traceability from collection through analysis.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PkSample .

ind:actualTimePoint rdf:type rdf:Property ;
    rdfs:label 'Actual Time Point' ;
    rdfs:comment 'The actual elapsed time (in hours post-dose) at which the sample was collected, calculated from the dose administration timestamp and sample collection timestamp. Used in non-compartmental and compartmental PK analysis.' ;
    rdfs:domain ind:BioanalyticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analysisTimestamp rdf:type rdf:Property ;
    rdfs:label 'Analysis Timestamp' ;
    rdfs:comment 'Date and time when the bioanalytical assay was performed and the result was generated by the laboratory instrument or system. Distinct from collection timestamp; used for audit trail and turnaround time tracking.' ;
    rdfs:domain ind:BioanalyticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assayPlatform rdf:type rdf:Property ;
    rdfs:label 'Assay Platform' ;
    rdfs:comment 'Analytical technology platform used to generate this result. Determines method-specific acceptance criteria and regulatory validation requirements. Values include LC-MS/MS (liquid chromatography-tandem mass spectrometry), ELISA, ECL (electrochemiluminescence), PCR, FLOW_CYTOMETRY, NGS (next-generation sequencing). [ENUM-REF-CANDIDATE: LC-MS/MS|ELISA|ECL|PCR|FLOW_CYTOMETRY|NGS|IHC|RIA|WESTERN_BLOT — promote to reference product]' ;
    rdfs:domain ind:BioanalyticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayRunNumber rdf:type rdf:Property ;
    rdfs:label 'Assay Run Number' ;
    rdfs:comment 'Unique identifier assigned by the bioanalytical laboratory to the analytical run (batch) in which this sample was processed. Used to link results to calibration curve and QC sample performance for the run. Maps to PCRUNID in CDISC SDTM PC domain.' ;
    rdfs:domain ind:BioanalyticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationCurveAccepted rdf:type rdf:Property ;
    rdfs:label 'Calibration Curve Accepted' ;
    rdfs:comment 'Indicates whether the calibration curve for the analytical run met pre-defined acceptance criteria (e.g., ≥75% of calibrators within ±15% of nominal, ±20% at LLOQ). A failed calibration curve invalidates all results from the run.' ;
    rdfs:domain ind:BioanalyticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:categoricalResult rdf:type rdf:Property ;
    rdfs:label 'Categorical Result' ;
    rdfs:comment 'Qualitative or categorical result for assays that produce non-numeric outcomes (e.g., POSITIVE/NEGATIVE for immunogenicity, BELOW_LLOQ for concentrations below the lower limit of quantification). Null when numeric_result is populated. Maps to PCSTRESC in CDISC SDTM PC domain.' ;
    rdfs:domain ind:BioanalyticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Collection Timestamp' ;
    rdfs:comment 'Date and time when the biological sample was collected from the subject. The principal real-world event time for this bioanalytical result record. Maps to PCDTC in CDISC SDTM PC domain. Conforms to ISO 8601 format.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dilutionFactor rdf:type rdf:Property ;
    rdfs:label 'Dilution Factor' ;
    rdfs:comment 'The dilution factor applied to the sample prior to analysis when the original concentration exceeded the ULOQ. The reported result incorporates this factor. Maps to PCDILIND/PCDILUTN in CDISC SDTM PC domain.' ;
    rdfs:domain ind:BioanalyticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusion Flag' ;
    rdfs:comment 'Indicates whether this result has been excluded from the primary PK/PD analysis dataset (e.g., due to protocol deviation, sample integrity issue, or statistical outlier determination per the Statistical Analysis Plan).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusionReason rdf:type rdf:Property ;
    rdfs:label 'Exclusion Reason' ;
    rdfs:comment 'Free-text or coded reason for excluding this result from the PK/PD analysis dataset. Required when exclusion_flag is true. Examples: \'Sample collected outside protocol window\', \'Hemolyzed sample\', \'Calibration curve failure\', \'Subject vomited within 2 hours of dose\'.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freezeThawCycles rdf:type rdf:Property ;
    rdfs:label 'Freeze Thaw Cycles' ;
    rdfs:comment 'Number of freeze-thaw cycles the sample underwent prior to analysis. Stability data from method validation defines the maximum allowable cycles; exceedance may invalidate the result.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isrFlag rdf:type rdf:Property ;
    rdfs:label 'Isr Flag' ;
    rdfs:comment 'Indicates whether this sample was selected for Incurred Sample Reanalysis (ISR), a regulatory requirement to demonstrate reproducibility of results in authentic study samples. ISR is mandatory for pivotal PK studies submitted to FDA and EMA.' ;
    rdfs:domain ind:BioanalyticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isrResult rdf:type rdf:Property ;
    rdfs:label 'Isr Result' ;
    rdfs:comment 'Outcome of the Incurred Sample Reanalysis (ISR) assessment. PASS indicates the original and repeat results agree within ±20% of their mean for ≥67% of ISR samples. FAIL triggers investigation. NOT_APPLICABLE when isr_flag is false.' ;
    rdfs:domain ind:BioanalyticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominalTimePoint rdf:type rdf:Property ;
    rdfs:label 'Nominal Time Point' ;
    rdfs:comment 'The protocol-specified time point (in hours post-dose) at which the sample was scheduled to be collected (e.g., 0.5, 1.0, 2.0, 4.0, 8.0, 24.0). Used as the reference for PK modeling and deviation calculation. Maps to PCTPTNUM in CDISC SDTM PC domain.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numericResult rdf:type rdf:Property ;
    rdfs:label 'Numeric Result' ;
    rdfs:comment 'Quantitative measured concentration or signal value for the analyte in this sample. Null when result is categorical (e.g., positive/negative for immunogenicity). Maps to PCSTRESN in CDISC SDTM PC domain. This is the QUANTITATIVE_RESULT for the TRANSACTION_HEADER role.' ;
    rdfs:domain ind:BioanalyticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qcSamplePerformance rdf:type rdf:Property ;
    rdfs:label 'Qc Sample Performance' ;
    rdfs:comment 'Overall acceptance outcome for the QC samples (low, medium, high QC) within the analytical run. PASS indicates ≥67% of QC samples within ±15% of nominal with at least 50% at each level passing. FAIL invalidates the run. MARGINAL triggers scientific review.' ;
    rdfs:domain ind:BioanalyticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultCategory rdf:type rdf:Property ;
    rdfs:label 'Result Category' ;
    rdfs:comment 'High-level classification of the bioanalytical result type: PK_CONCENTRATION (pharmacokinetic drug/metabolite concentration), BIOMARKER (pharmacodynamic or disease biomarker), IMMUNOGENICITY (anti-drug antibody or neutralizing antibody), EXPLORATORY (hypothesis-generating biomarker), PD_MARKER (pharmacodynamic endpoint marker). Drives downstream CDISC domain routing (PC vs PP vs ADPC).' ;
    rdfs:domain ind:BioanalyticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultComment rdf:type rdf:Property ;
    rdfs:label 'Result Comment' ;
    rdfs:comment 'Free-text comment entered by the bioanalytical scientist or laboratory reviewer providing additional context for the result (e.g., instrument flags, unusual chromatography, sample appearance notes). Maps to PCORRES or PCCOMMENT in CDISC SDTM PC domain.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultReportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Result Reported Timestamp' ;
    rdfs:comment 'Date and time when the validated bioanalytical result was formally reported and released by the laboratory to the sponsor or data management team. Marks the transition from laboratory-internal to reportable status.' ;
    rdfs:domain ind:BioanalyticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resultStatus rdf:type rdf:Property ;
    rdfs:label 'Result Status' ;
    rdfs:comment 'Current disposition status of the bioanalytical result indicating whether it is reportable for inclusion in the clinical database, requires repeat analysis, or has been invalidated. Drives data flow into EDC and CDISC SDTM datasets.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultUnit rdf:type rdf:Property ;
    rdfs:label 'Result Unit' ;
    rdfs:comment 'Unit of measure for the numeric result value (e.g., ng/mL, pg/mL, nM, U/mL). Standardized per CDISC controlled terminology. Maps to PCSTRESU in CDISC SDTM PC domain.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleStabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Sample Stability Flag' ;
    rdfs:comment 'Indicates whether the sample met stability criteria at the time of analysis based on validated short-term, long-term, and freeze-thaw stability data. False indicates a potential stability failure that may affect result validity.' ;
    rdfs:domain ind:BioanalyticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeDeviationHours rdf:type rdf:Property ;
    rdfs:label 'Time Deviation Hours' ;
    rdfs:comment 'Deviation of the actual sample collection time from the nominal protocol-specified time point, expressed in hours (actual minus nominal). Positive values indicate late collection; negative values indicate early collection. Used to assess protocol compliance and flag samples for PK analysis exclusion.' ;
    rdfs:domain ind:BioanalyticalResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalValueId rdf:type rdf:Property ;
    rdfs:label 'Critical Value Id' ;
    rdfs:comment 'Unique surrogate identifier for each critical (panic) value threshold record in the laboratory reference master.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CriticalValue .

ind:ctcaeGradeId rdf:type rdf:Property ;
    rdfs:label 'Ctcae Grade Id' ;
    rdfs:comment 'Foreign key linking to safety.ctcae_grade. Business justification: Critical value thresholds are defined in terms of CTCAE grades to determine AE reporting requirements (ae_reporting_required flag). Linking critical_value to ctcae_grade formalizes the threshold-to-gr' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CtcaeGrade .

ind:meddraTermId rdf:type rdf:Property ;
    rdfs:label 'Meddra Term Id' ;
    rdfs:comment 'Foreign key linking to safety.meddra_term. Business justification: Critical lab values trigger AE reporting; the MedDRA coding of the lab finding is required for ICSR and expedited report submissions. Linking critical_value to meddra_term formalizes the MedDRA classi' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MeddraTerm .

ind:supersededByCriticalValueId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Critical Value Id' ;
    rdfs:comment 'Reference to the critical_value_id of the newer threshold record that replaces this one when threshold_status is \'superseded\'. Enables version chain traceability for audit and regulatory inspection.' ;
    rdfs:domain ind:CriticalValue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CriticalValue .

ind:aeReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Ae Reporting Required' ;
    rdfs:comment 'Indicates whether a critical value breach automatically triggers an Adverse Event (AE) or Serious Adverse Event (SAE) report in Oracle Argus Safety. True = AE/SAE workflow initiated; False = clinical notification only.' ;
    rdfs:domain ind:CriticalValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ageGroupApplicability rdf:type rdf:Property ;
    rdfs:label 'Age Group Applicability' ;
    rdfs:comment 'Specifies the patient age group for which this critical value threshold applies. Different thresholds may be defined for pediatric, adult, and geriatric populations.' ;
    rdfs:domain ind:CriticalValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:argusSafetyRuleCode rdf:type rdf:Property ;
    rdfs:label 'Argus Safety Rule Code' ;
    rdfs:comment 'Identifier of the corresponding automated safety rule configured in Oracle Argus Safety that is triggered when this critical value threshold is breached. Enables bidirectional traceability between the lab threshold master and the safety system.' ;
    rdfs:domain ind:CriticalValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bioanalyticalMethod rdf:type rdf:Property ;
    rdfs:label 'Bioanalytical Method' ;
    rdfs:comment 'Name or code of the validated bioanalytical method used to measure the analyte (e.g., LC-MS/MS, ELISA, flow cytometry). Relevant for PK/PD and DMPK analytes where method-specific critical thresholds may apply.' ;
    rdfs:domain ind:CriticalValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalRationale rdf:type rdf:Property ;
    rdfs:label 'Clinical Rationale' ;
    rdfs:comment 'Free-text description of the clinical or scientific rationale for the defined critical value thresholds. Documents the medical justification for regulatory inspection readiness and protocol defense.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalHigh rdf:type rdf:Property ;
    rdfs:label 'Critical High' ;
    rdfs:comment 'The upper critical (panic) value threshold for the analyte. A result at or above this value triggers an immediate clinical notification workflow per the defined notification SLA.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalLow rdf:type rdf:Property ;
    rdfs:label 'Critical Low' ;
    rdfs:comment 'The lower critical (panic) value threshold for the analyte. A result at or below this value triggers an immediate clinical notification workflow per the defined notification SLA.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:edcAlertRuleCode rdf:type rdf:Property ;
    rdfs:label 'Edc Alert Rule Code' ;
    rdfs:comment 'Identifier of the automated edit check or alert rule configured in Medidata Rave EDC that fires when a lab result breaches this critical value threshold. Supports automated critical value flagging at point of data entry.' ;
    rdfs:domain ind:CriticalValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationPathway rdf:type rdf:Property ;
    rdfs:label 'Escalation Pathway' ;
    rdfs:comment 'Defined escalation route for communicating a critical value to the appropriate clinical personnel (e.g., PI direct, CRC then PI, Medical Monitor, Sponsor Safety team, DSMB). Governs the automated notification routing logic. [ENUM-REF-CANDIDATE: pi_direct|crc_then_pi|medical_monitor|sponsor_safety|dsmb|site_medical_director|other — promote to reference product]' ;
    rdfs:domain ind:CriticalValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTier2Minutes rdf:type rdf:Property ;
    rdfs:label 'Escalation Tier 2 Minutes' ;
    rdfs:comment 'Number of minutes after initial notification attempt before escalating to the secondary contact in the escalation pathway if no acknowledgement is received.' ;
    rdfs:domain ind:CriticalValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fastingStateRequired rdf:type rdf:Property ;
    rdfs:label 'Fasting State Required' ;
    rdfs:comment 'Indicates whether this critical value threshold applies only to specimens collected under fasting conditions. True = fasting required for threshold applicability; False = non-fasting or state-independent.' ;
    rdfs:domain ind:CriticalValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labFacilityScope rdf:type rdf:Property ;
    rdfs:label 'Lab Facility Scope' ;
    rdfs:comment 'Defines the applicability of this critical value threshold to laboratory facilities: all facilities, central lab only, local lab only, or a specific named facility. Drives which lab facilities apply this threshold in automated alerting workflows.' ;
    rdfs:domain ind:CriticalValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loincCode rdf:type rdf:Property ;
    rdfs:label 'Loinc Code' ;
    rdfs:comment 'Standardized LOINC code uniquely identifying the laboratory observation or test. Enables interoperability across laboratory systems and regulatory submissions per CDISC standards.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSlaMinutes rdf:type rdf:Property ;
    rdfs:label 'Notification Sla Minutes' ;
    rdfs:comment 'Maximum allowable time in minutes from critical value detection to confirmed clinical notification. Drives automated alerting SLA monitoring and compliance reporting. Typical values range from 15 to 60 minutes per CAP and CLIA requirements.' ;
    rdfs:domain ind:CriticalValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryAuthorityBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Basis' ;
    rdfs:comment 'Regulatory authority or guideline that mandates or informs this critical value threshold definition (e.g., FDA, EMA, PMDA, CAP, CLIA). Supports multi-jurisdictional compliance documentation.' ;
    rdfs:domain ind:CriticalValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresRepeatConfirmation rdf:type rdf:Property ;
    rdfs:label 'Requires Repeat Confirmation' ;
    rdfs:comment 'Indicates whether a repeat specimen analysis is required to confirm the critical value before initiating the notification workflow. True = repeat confirmation required; False = single result triggers notification.' ;
    rdfs:domain ind:CriticalValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sexApplicability rdf:type rdf:Property ;
    rdfs:label 'Sex Applicability' ;
    rdfs:comment 'Specifies the biological sex for which this critical value threshold applies. Some analytes (e.g., hemoglobin, creatinine) have sex-specific reference and critical ranges.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReferenceDocument rdf:type rdf:Property ;
    rdfs:label 'Source Reference Document' ;
    rdfs:comment 'Citation or document reference (e.g., protocol section, lab manual version, CAP guideline) from which this critical value threshold was derived. Supports traceability and regulatory inspection readiness.' ;
    rdfs:domain ind:CriticalValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenType rdf:type rdf:Property ;
    rdfs:label 'Specimen Type' ;
    rdfs:comment 'Type of biological specimen from which the analyte is measured (e.g., blood, urine, plasma, serum). Critical value thresholds may differ by specimen type. [ENUM-REF-CANDIDATE: blood|urine|plasma|serum|csf|tissue|saliva|other — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testSystemCode rdf:type rdf:Property ;
    rdfs:label 'Test System Code' ;
    rdfs:comment 'Internal or sponsor-defined code for the specific laboratory test or panel within the clinical trial management system (e.g., Medidata Rave EDC lab test code). Used for system-to-system mapping.' ;
    rdfs:domain ind:CriticalValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdStatus rdf:type rdf:Property ;
    rdfs:label 'Threshold Status' ;
    rdfs:comment 'Current lifecycle status of the critical value threshold record. Active = in use for alerting; Inactive = retired; Superseded = replaced by a newer version; Under Review = pending clinical or regulatory review.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdType rdf:type rdf:Property ;
    rdfs:label 'Threshold Type' ;
    rdfs:comment 'Defines whether the critical value threshold is an absolute numeric value, a delta change from baseline, or a percent change from a prior result. Determines the comparison logic applied during automated alerting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLabFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Lab Facility Id' ;
    rdfs:comment 'Reference to the laboratory facility for which this accreditation record applies. Links to the laboratory master record.' ;
    rdfs:domain ind:LabAccreditation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabFacility .

ind:qualifierEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Qualifier Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Sponsor lab qualification assessments (ICH E6(R2)) require a named sponsor employee to perform and approve the qualification. Tracing the qualifier_employee supports audit readiness and regulatory ins' ;
    rdfs:domain ind:LabAccreditation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryLabFacilityId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Lab Facility Id' ;
    rdfs:comment 'FK to laboratory.lab_facility' ;
    rdfs:domain ind:LabAccreditation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabFacility .

ind:accreditationScope rdf:type rdf:Property ;
    rdfs:label 'Accreditation Scope' ;
    rdfs:comment 'Narrative or structured description of the test menu and analytical disciplines covered by the accreditation (e.g., clinical chemistry, hematology, microbiology, PK/PD bioanalysis, DMPK assays, flow cytometry). Defines which tests the laboratory is qualified to perform under the accreditation.' ;
    rdfs:domain ind:LabAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationStandardVersion rdf:type rdf:Property ;
    rdfs:label 'Accreditation Standard Version' ;
    rdfs:comment 'Version or edition of the accreditation standard under which the certificate was issued (e.g., ISO 15189:2022, ISO 15189:2012, CAP 2023 Checklist). Relevant for regulatory submissions and gap assessments when standards are updated.' ;
    rdfs:domain ind:LabAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationType rdf:type rdf:Property ;
    rdfs:label 'Accreditation Type' ;
    rdfs:comment 'Classification of the accreditation grant indicating the scope and conditions of the award (e.g., full accreditation, provisional, conditional, limited scope, renewal).' ;
    rdfs:domain ind:LabAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Externally-issued certificate or accreditation number assigned by the accrediting body (e.g., CAP number, CLIA ID, ISO certificate number). This is the primary business identifier used in regulatory submissions and audit documentation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current lifecycle state of the accreditation as maintained by the issuing health authority. Drives facility eligibility for use in trials subject to that authority\'s jurisdiction. Sourced directly from detection-phase relationship_data.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Date on which the accreditation certificate was formally issued or granted by the accrediting body. Represents the effective start of the accreditation period.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labDirectorName rdf:type rdf:Property ;
    rdfs:label 'Lab Director Name' ;
    rdfs:comment 'Full name of the qualified laboratory director responsible for the accredited laboratory facility. Required for regulatory submissions and accreditation documentation. Classified as confidential business data.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labDirectorQualification rdf:type rdf:Property ;
    rdfs:label 'Lab Director Qualification' ;
    rdfs:comment 'Professional qualifications, credentials, or certifications held by the laboratory director (e.g., MD, PhD, FACB, FRCPA). Required to verify director eligibility under CLIA and accrediting body requirements.' ;
    rdfs:domain ind:LabAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labType rdf:type rdf:Property ;
    rdfs:label 'Lab Type' ;
    rdfs:comment 'Classification of the laboratory by operational role in the clinical trial (central laboratory, local/site laboratory, reference laboratory, bioanalytical laboratory, specialty laboratory). Determines applicable accreditation requirements and regulatory expectations.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Previous Certificate Number' ;
    rdfs:comment 'Certificate number from the immediately preceding accreditation cycle. Supports continuity tracking and audit trail for regulatory submissions requiring historical accreditation evidence.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proficiencyTestingProgram rdf:type rdf:Property ;
    rdfs:label 'Proficiency Testing Program' ;
    rdfs:comment 'Name of the external proficiency testing or external quality assessment (EQA) program in which the laboratory participates (e.g., CAP PT, UKNEQAS, EQAS, RCPA QAP). Supports accreditation body verification.' ;
    rdfs:domain ind:LabAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proficiencyTestingStatus rdf:type rdf:Property ;
    rdfs:label 'Proficiency Testing Status' ;
    rdfs:comment 'Current status of the laboratory\'s external proficiency testing (PT) or external quality assessment (EQA) program participation. Proficiency testing is a mandatory component of CLIA and CAP accreditation and demonstrates ongoing analytical competency.' ;
    rdfs:domain ind:LabAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Assessment Date' ;
    rdfs:comment 'Date on which the CRO or sponsor conducted an internal laboratory qualification assessment (distinct from the accrediting body inspection). Supports vendor qualification and oversight requirements under GCP.' ;
    rdfs:domain ind:LabAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationAssessmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Qualification Assessment Outcome' ;
    rdfs:comment 'Outcome of the internal CRO or sponsor laboratory qualification assessment. Determines whether the laboratory may be activated for use in clinical trials managed by the organization.' ;
    rdfs:domain ind:LabAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionType rdf:type rdf:Property ;
    rdfs:label 'Recognition Type' ;
    rdfs:comment 'The specific type of certification or regulatory recognition granted by this health authority to the facility (e.g., CLIA for FDA, GLP for EMA, GCP for PMDA). Sourced directly from detection-phase relationship_data.' ;
    rdfs:domain ind:LabAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionEligible rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Eligible' ;
    rdfs:comment 'Indicates whether this laboratory\'s accreditation record is currently eligible to be cited in regulatory submissions (IND, NDA, BLA, MAA, CTD/eCTD). Derived from accreditation status, expiry, and CAPA closure but stored as an explicit business flag for audit and reporting purposes.' ;
    rdfs:domain ind:LabAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Current status of the accreditation renewal process. Tracks whether the laboratory has initiated, submitted, or completed renewal prior to certificate expiry to ensure uninterrupted trial eligibility.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeIncludesDmpk rdf:type rdf:Property ;
    rdfs:label 'Scope Includes Dmpk' ;
    rdfs:comment 'Indicates whether the accreditation scope explicitly covers drug metabolism and pharmacokinetics (DMPK) assays, relevant for early-phase and ADME studies.' ;
    rdfs:domain ind:LabAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeIncludesPkPd rdf:type rdf:Property ;
    rdfs:label 'Scope Includes Pk Pd' ;
    rdfs:comment 'Indicates whether the accreditation scope explicitly covers pharmacokinetic (PK) and pharmacodynamic (PD) bioanalytical testing, which is required for studies with PK/PD endpoints.' ;
    rdfs:domain ind:LabAccreditation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorApproved rdf:type rdf:Property ;
    rdfs:label 'Sponsor Approved' ;
    rdfs:comment 'Indicates whether the laboratory has been formally approved by the clinical trial sponsor for use in their studies. Sponsor approval is a prerequisite for laboratory qualification in addition to regulatory accreditation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adamParamCode rdf:type rdf:Property ;
    rdfs:label 'Adam Param Code' ;
    rdfs:comment 'CDISC ADaM PARAMCD value for this analyte used in analysis datasets (BDS — Basic Data Structure). Maximum 8 uppercase alphanumeric characters per CDISC ADaM controlled terminology. Used in SAS Drug Development to build ADLB, ADPC, and other analysis datasets for statistical analysis and regulatory submission.' ;
    rdfs:domain ind:LabAnalyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adamParamLabel rdf:type rdf:Property ;
    rdfs:label 'Adam Param Label' ;
    rdfs:comment 'CDISC ADaM PARAM value — the full descriptive label for this analyte in analysis datasets. Corresponds to the PARAM variable in ADLB and ADPC datasets. Used in SAS Drug Development outputs, TLFs (Tables, Listings, and Figures), and the Clinical Study Report (CSR).' ;
    rdfs:domain ind:LabAnalyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analyteCode rdf:type rdf:Property ;
    rdfs:label 'Analyte Code' ;
    rdfs:comment 'Internal enterprise-assigned short code uniquely identifying the analyte within the controlled vocabulary. Used as the primary business key for cross-system referencing and data integration. Follows CDISC LBTESTCD conventions (max 8 uppercase alphanumeric characters).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analyteStatus rdf:type rdf:Property ;
    rdfs:label 'Analyte Status' ;
    rdfs:comment 'Current lifecycle status of the analyte in the enterprise reference master. ACTIVE: approved for use in studies; INACTIVE: no longer used in new studies; DEPRECATED: superseded by another analyte code; PENDING_VALIDATION: under review for addition; RESTRICTED: use requires special authorization (e.g., exploratory biomarkers).' ;
    rdfs:domain ind:LabAnalyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analyteSubcategory rdf:type rdf:Property ;
    rdfs:label 'Analyte Subcategory' ;
    rdfs:comment 'More granular classification within the analyte category. Corresponds to CDISC LBSCAT variable (e.g., \'LIVER FUNCTION\', \'RENAL FUNCTION\', \'LIPID PANEL\', \'COMPLETE BLOOD COUNT\' within CHEMISTRY or HEMATOLOGY). Used for panel grouping, report organization, and SDTM dataset population.' ;
    rdfs:domain ind:LabAnalyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analyteType rdf:type rdf:Property ;
    rdfs:label 'Analyte Type' ;
    rdfs:comment 'Classification of the analyte result type: QUANTITATIVE (numeric value with unit), QUALITATIVE (categorical result such as Positive/Negative), SEMI_QUANTITATIVE (e.g., 1+/2+/3+), or ORDINAL (ranked scale). Determines result entry validation rules in Medidata Rave eCRF and SDTM LBORRES handling logic.' ;
    rdfs:domain ind:LabAnalyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analyteVersion rdf:type rdf:Property ;
    rdfs:label 'Analyte Version' ;
    rdfs:comment 'Version number of the analyte definition record (e.g., \'1.0\', \'2.3\'). Incremented when material changes are made to the analyte specification (unit, LOINC code, CDISC mapping, reference ranges). Supports audit trail requirements under 21 CFR Part 11 and ALCOA+ data integrity principles.' ;
    rdfs:domain ind:LabAnalyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assayMethod rdf:type rdf:Property ;
    rdfs:label 'Assay Method' ;
    rdfs:comment 'The analytical method or technology platform used to measure this analyte (e.g., \'ELISA\', \'LC-MS/MS\', \'Flow Cytometry\', \'Immunoturbidimetry\', \'Colorimetric\', \'PCR\', \'Electrochemiluminescence\'). Documented for bioanalytical method validation traceability and regulatory submission in the CSR and eCTD.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biomarkerFlag rdf:type rdf:Property ;
    rdfs:label 'Biomarker Flag' ;
    rdfs:comment 'Indicates whether this analyte is classified as a biomarker (safety, efficacy, predictive, prognostic, or pharmacodynamic). Biomarker analytes require additional regulatory documentation per FDA Biomarker Qualification Program and EMA qualification opinions, and may trigger special handling in the TMF and regulatory submissions.' ;
    rdfs:domain ind:LabAnalyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:biomarkerType rdf:type rdf:Property ;
    rdfs:label 'Biomarker Type' ;
    rdfs:comment 'When biomarker_flag is true, classifies the biomarker by its regulatory and scientific role per FDA BEST framework: SAFETY (organ toxicity monitoring), EFFICACY (treatment response), PREDICTIVE (patient selection), PROGNOSTIC (disease outcome), PHARMACODYNAMIC (drug effect), SUSCEPTIBILITY, RESPONSE, or DIAGNOSTIC. Drives regulatory submission strategy and SAP content. [ENUM-REF-CANDIDATE: SAFETY|EFFICACY|PREDICTIVE|PROGNOSTIC|PHARMACODYNAMIC|SUSCEPTIBILITY|RESPONSE|DIAGNOSTIC — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LabAnalyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionTubeType rdf:type rdf:Property ;
    rdfs:label 'Collection Tube Type' ;
    rdfs:comment 'Required blood collection tube type or container for this analyte (e.g., \'EDTA\', \'SST\', \'LITHIUM HEPARIN\', \'CITRATE\', \'FLUORIDE OXALATE\'). Drives specimen collection kit configuration in RTSM and lab manuals. Critical for pre-analytical quality and result validity per ISO 15189 and CLSI guidelines.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalValueLower rdf:type rdf:Property ;
    rdfs:label 'Critical Value Lower' ;
    rdfs:comment 'The lower critical (panic) value threshold for this analyte below which an immediate clinical notification is required per laboratory protocol. Results below this threshold trigger critical_value_flag in lab_result and require expedited reporting to the investigator per GCP and CTCAE grading requirements.' ;
    rdfs:domain ind:LabAnalyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalValueUpper rdf:type rdf:Property ;
    rdfs:label 'Critical Value Upper' ;
    rdfs:comment 'The upper critical (panic) value threshold for this analyte above which an immediate clinical notification is required per laboratory protocol. Results above this threshold trigger critical_value_flag in lab_result and require expedited reporting to the investigator per GCP and CTCAE grading requirements.' ;
    rdfs:domain ind:LabAnalyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctcaeGradeMapping rdf:type rdf:Property ;
    rdfs:label 'Ctcae Grade Mapping' ;
    rdfs:comment 'Describes the CTCAE grading rule or reference for this analyte (e.g., \'CTCAE v5.0 — Anemia: Grade 1 <LLN–10.0 g/dL; Grade 2 8.0–<10.0 g/dL; Grade 3 <8.0 g/dL\'). Used by the safety data management team to auto-assign CTCAE grades to lab results in Medidata Rave and Oracle Argus Safety for AE/SAE reporting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultUnit rdf:type rdf:Property ;
    rdfs:label 'Default Unit' ;
    rdfs:comment 'The standard unit of measure in which this analyte result is reported by default (e.g., \'g/dL\', \'mmol/L\', \'U/L\', \'ng/mL\', \'%\'). Aligns with CDISC LBORRESU (original unit) and LBSTRESU (standard unit) conventions. Used to pre-populate EDC fields in Medidata Rave and validate incoming lab data.' ;
    rdfs:domain ind:LabAnalyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionLimitLower rdf:type rdf:Property ;
    rdfs:label 'Detection Limit Lower' ;
    rdfs:comment 'The lowest concentration or value that can be reliably detected by the analytical method for this analyte (Lower Limit of Detection, LLOD). Values below this threshold are reported as \'<LLOD\'. Critical for PK/DMPK bioanalytical assay validation and SDTM LBSTRESC handling of below-detection results per FDA and EMA bioanalytical guidance.' ;
    rdfs:domain ind:LabAnalyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detectionLimitUpper rdf:type rdf:Property ;
    rdfs:label 'Detection Limit Upper' ;
    rdfs:comment 'The highest concentration or value that can be reliably quantified by the analytical method for this analyte (Upper Limit of Quantitation, ULOQ). Values above this threshold require dilution or are reported as \'>ULOQ\'. Essential for PK/DMPK bioanalytical assay validation and concentration-time profile analysis.' ;
    rdfs:domain ind:LabAnalyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lbtest rdf:type rdf:Property ;
    rdfs:label 'Lbtest' ;
    rdfs:comment 'CDISC SDTM standardized long name for the laboratory test (LBTEST variable). The decode value corresponding to LBTESTCD. Used in SDTM LB domain submissions and must match CDISC Controlled Terminology. Enables regulatory reviewers to interpret analyte identity without code lookup.' ;
    rdfs:domain ind:LabAnalyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lbtestcd rdf:type rdf:Property ;
    rdfs:label 'Lbtestcd' ;
    rdfs:comment 'CDISC SDTM standardized short name for the laboratory test (LBTESTCD variable). Maximum 8 uppercase alphanumeric characters per CDISC controlled terminology. Used for SDTM dataset submission to FDA, EMA, and PMDA. Must align with CDISC Controlled Terminology for the LB domain.' ;
    rdfs:domain ind:LabAnalyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxFreezeThawCycles rdf:type rdf:Property ;
    rdfs:label 'Max Freeze Thaw Cycles' ;
    rdfs:comment 'Maximum number of freeze-thaw cycles permitted for specimens used to measure this analyte before result validity is compromised. Enforced during specimen chain-of-custody tracking to flag specimens that have exceeded the allowable cycle count, particularly critical for PK/DMPK and biomarker analytes.' ;
    rdfs:domain ind:LabAnalyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumVolumeMl rdf:type rdf:Property ;
    rdfs:label 'Minimum Volume Ml' ;
    rdfs:comment 'Minimum volume of specimen in milliliters required to perform the assay for this analyte. Used to validate specimen adequacy upon receipt at the central laboratory and to configure collection volume requirements in the lab manual and RTSM kit specifications.' ;
    rdfs:domain ind:LabAnalyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pkPdFlag rdf:type rdf:Property ;
    rdfs:label 'Pk Pd Flag' ;
    rdfs:comment 'Indicates whether this analyte is used in pharmacokinetic (PK) or pharmacodynamic (PD) analyses. When true, the analyte is subject to DMPK bioanalytical method validation requirements and results are processed through the PC/PP SDTM domains and NCA/population PK workflows in SAS Drug Development.' ;
    rdfs:domain ind:LabAnalyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredVolumeMl rdf:type rdf:Property ;
    rdfs:label 'Preferred Volume Ml' ;
    rdfs:comment 'Optimal/preferred volume of specimen in milliliters for reliable analyte measurement, accounting for repeat testing and QC requirements. Drives collection kit tube size selection and subject blood volume burden calculations in protocol feasibility assessments.' ;
    rdfs:domain ind:LabAnalyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPrecision rdf:type rdf:Property ;
    rdfs:label 'Reporting Precision' ;
    rdfs:comment 'Number of decimal places to which results for this analyte should be reported and stored. Ensures consistent numeric precision across EDC data entry in Medidata Rave, SDTM dataset generation, and statistical analysis outputs in SAS Drug Development. Prevents spurious precision in regulatory submissions.' ;
    rdfs:domain ind:LabAnalyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresFasting rdf:type rdf:Property ;
    rdfs:label 'Requires Fasting' ;
    rdfs:comment 'Indicates whether specimen collection for this analyte requires the subject to be in a fasting state. When true, the eCRF in Medidata Rave will prompt collection of fasting status (LBFAST in SDTM) and the collection instructions in the lab manual will specify fasting duration requirements.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stabilityHoursAmbient rdf:type rdf:Property ;
    rdfs:label 'Stability Hours Ambient' ;
    rdfs:comment 'Maximum number of hours the collected specimen remains stable for this analyte at ambient (room) temperature before processing or refrigeration is required. Critical for pre-analytical quality management, shipment planning, and chain-of-custody compliance per ISO 15189 and CAP accreditation standards.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityHoursFrozen rdf:type rdf:Property ;
    rdfs:label 'Stability Hours Frozen' ;
    rdfs:comment 'Maximum number of hours (or equivalent duration) the collected specimen remains stable for this analyte when stored frozen (typically -20°C or -80°C). Governs long-term biobanking, re-analysis eligibility, and sample expiry management in the specimen repository.' ;
    rdfs:domain ind:LabAnalyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stabilityHoursRefrigerated rdf:type rdf:Property ;
    rdfs:label 'Stability Hours Refrigerated' ;
    rdfs:comment 'Maximum number of hours the collected specimen remains stable for this analyte when stored refrigerated (2–8°C). Used to define specimen handling windows in the lab manual, RTSM kit instructions, and central lab processing SOPs.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardUnit rdf:type rdf:Property ;
    rdfs:label 'Standard Unit' ;
    rdfs:comment 'The SI (International System of Units) or CDISC-standardized unit to which all results for this analyte are converted for cross-study analysis and regulatory submission. Corresponds to CDISC LBSTRESU. Enables unit-harmonized pooled analyses and ADaM dataset derivations in SAS Drug Development.' ;
    rdfs:domain ind:LabAnalyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitConversionFactor rdf:type rdf:Property ;
    rdfs:label 'Unit Conversion Factor' ;
    rdfs:comment 'Numeric multiplier applied to convert a result from the default_unit to the standard_unit (e.g., 0.0555 to convert glucose from mg/dL to mmol/L). Used by the data transformation layer in SAS Drug Development and Medidata Rave to auto-standardize incoming lab values for SDTM and ADaM datasets.' ;
    rdfs:domain ind:LabAnalyte ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:whoDdCode rdf:type rdf:Property ;
    rdfs:label 'Who Dd Code' ;
    rdfs:comment 'WHO Drug Dictionary code associated with this analyte when the analyte represents a drug concentration measurement (e.g., for PK analytes measuring parent drug or metabolite levels). Enables linkage between PK analyte results and the study drug coding in safety and efficacy analyses.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableStudyPhases rdf:type rdf:Property ;
    rdfs:label 'Applicable Study Phases' ;
    rdfs:comment 'Clinical trial phases for which this certification qualifies the laboratory to perform testing (e.g., \'Phase I, Phase II, Phase III\', \'All Phases\', \'Phase I only\'). Supports site feasibility and lab qualification assessments.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationName rdf:type rdf:Property ;
    rdfs:label 'Certification Name' ;
    rdfs:comment 'Human-readable name or title of the certification program as designated by the issuing authority (e.g., \'CLIA Certificate of Compliance – Hematology\', \'CAP Proficiency Testing – Chemistry\'). Serves as the identity label for this certification record.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationNotes rdf:type rdf:Property ;
    rdfs:label 'Certification Notes' ;
    rdfs:comment 'Free-text field for additional remarks, conditions, limitations, or special requirements associated with this certification (e.g., \'Limited to in-house testing only\', \'Conditional approval pending equipment validation\').' ;
    rdfs:domain ind:LabCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationScope rdf:type rdf:Property ;
    rdfs:label 'Certification Scope' ;
    rdfs:comment 'Detailed description of the specific test competencies, analyte categories, methodologies, or regulatory compliance programs covered by this certification (e.g., \'Hematology, Coagulation, Clinical Chemistry\', \'GLP compliance for in vitro toxicology studies\'). Distinct from facility-level accreditation scope.' ;
    rdfs:domain ind:LabCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Classification of the certification program. GLP = Good Laboratory Practice; GCP_LAB_QUALIFICATION = laboratory qualification under Good Clinical Practice; CAP_PROFICIENCY = College of American Pathologists proficiency testing; CLIA_SPECIALTY = Clinical Laboratory Improvement Amendments specialty certificate; EQA_SCHEME = External Quality Assurance scheme participation; ISO_15189 = medical laboratory quality standard. [ENUM-REF-CANDIDATE: GLP|GCP_LAB_QUALIFICATION|CAP_PROFICIENCY|CLIA_SPECIALTY|EQA_SCHEME|ISO_15189|OTHER — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eqaParticipationCycle rdf:type rdf:Property ;
    rdfs:label 'Eqa Participation Cycle' ;
    rdfs:comment 'Identifier for the specific EQA participation cycle or survey period (e.g., \'2024-Q1\', \'2024-CYCLE-2\'). Applicable when certification_type = EQA_SCHEME. Supports tracking of periodic proficiency testing compliance.' ;
    rdfs:domain ind:LabCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eqaSchemeName rdf:type rdf:Property ;
    rdfs:label 'Eqa Scheme Name' ;
    rdfs:comment 'Name of the External Quality Assurance scheme in which the laboratory participates under this certification (e.g., UKNEQAS, RIQAS, EQAS, CAP PT). Applicable only when certification_type = EQA_SCHEME.' ;
    rdfs:domain ind:LabCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glpComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Glp Compliance Flag' ;
    rdfs:comment 'Indicates whether this certification specifically confers or requires Good Laboratory Practice (GLP) compliance as defined by FDA 21 CFR Part 58 or OECD GLP Principles. True = GLP-compliant certification; False = non-GLP certification.' ;
    rdfs:domain ind:LabCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryCertification rdf:type rdf:Property ;
    rdfs:label 'Is Primary Certification' ;
    rdfs:comment 'Indicates whether this is the primary or principal certification for the laboratory\'s participation in clinical trials. True = primary certification; False = supplementary or specialty certification. Supports lab qualification assessments.' ;
    rdfs:domain ind:LabCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Name of the regulatory body, accreditation organization, or competent authority that issued the certification (e.g., CMS/CLIA, College of American Pathologists, FDA, EMA, MHRA, COFRAC, DAKKS, UKAS, INAB).' ;
    rdfs:domain ind:LabCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityCountry rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction under which the certification was issued (e.g., USA, GBR, DEU, JPN, AUS). Supports multi-jurisdictional regulatory compliance tracking.' ;
    rdfs:domain ind:LabCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mutualRecognitionFlag rdf:type rdf:Property ;
    rdfs:label 'Mutual Recognition Flag' ;
    rdfs:comment 'Indicates whether this certification is recognized under a mutual recognition agreement between regulatory authorities (e.g., FDA-EMA, OECD GLP MAD). True = recognized under MRA; False = jurisdiction-specific only. Relevant for multi-regional clinical trials.' ;
    rdfs:domain ind:LabCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationLeadDays rdf:type rdf:Property ;
    rdfs:label 'Notification Lead Days' ;
    rdfs:comment 'Number of calendar days before the expiry date at which automated renewal notifications should be triggered. Configurable per certification type and issuing authority requirements (e.g., 90 days for CLIA, 180 days for GLP).' ;
    rdfs:domain ind:LabCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proficiencyTestResult rdf:type rdf:Property ;
    rdfs:label 'Proficiency Test Result' ;
    rdfs:comment 'Outcome of the most recent proficiency testing or EQA survey associated with this certification. SATISFACTORY = passed; UNSATISFACTORY = failed one or more analytes; UNSUCCESSFUL = failed to meet minimum passing threshold; PENDING = results not yet received; NOT_APPLICABLE = no proficiency testing required for this certification type.' ;
    rdfs:domain ind:LabCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Reference' ;
    rdfs:comment 'Reference number or dossier identifier for any regulatory submission (IND, NDA, BLA, MAA, CTD/eCTD) in which this laboratory certification was included as supporting documentation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinstatementDate rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Date' ;
    rdfs:comment 'Date on which a previously suspended certification was reinstated by the issuing authority following successful corrective action. Null if the certification has never been suspended or has not yet been reinstated.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Submitted Date' ;
    rdfs:comment 'Actual date on which the renewal application was submitted to the issuing authority. Used to confirm timely submission and support audit trail requirements.' ;
    rdfs:domain ind:LabCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signatoryName rdf:type rdf:Property ;
    rdfs:label 'Signatory Name' ;
    rdfs:comment 'Name of the authorized signatory from the issuing authority who signed or approved the certificate. Supports audit trail and certificate authenticity verification.' ;
    rdfs:domain ind:LabCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyCode rdf:type rdf:Property ;
    rdfs:label 'Specialty Code' ;
    rdfs:comment 'Standardized code identifying the laboratory specialty or discipline covered by this certification, aligned with CLIA specialty categories or equivalent regulatory classification (e.g., HEMATOLOGY, CHEMISTRY, MICROBIOLOGY, IMMUNOLOGY, TOXICOLOGY, MOLECULAR_PATHOLOGY).' ;
    rdfs:domain ind:LabCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'Date on which the certification was suspended, revoked, or withdrawn. Populated only when certification_status is SUSPENDED, REVOKED, or WITHDRAWN. Supports regulatory compliance and audit trail.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Reason provided by the issuing authority or the laboratory for suspension, revocation, or withdrawal of the certification. Populated only when certification_status is SUSPENDED, REVOKED, or WITHDRAWN.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address line of the laboratory facility. Used for specimen shipment labels, regulatory correspondence, and audit documentation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address line (suite, floor, building) for the laboratory facility. Supplements address_line1 for complete mailing and shipment address.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biobankingCapable rdf:type rdf:Property ;
    rdfs:label 'Biobanking Capable' ;
    rdfs:comment 'Indicates whether the laboratory facility has certified long-term specimen storage (biobanking) capabilities, including controlled-temperature archival storage. Relevant for studies requiring retained samples for future exploratory analyses.' ;
    rdfs:domain ind:LabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Cap Accreditation Number' ;
    rdfs:comment 'Accreditation number issued by the College of American Pathologists (CAP) confirming the laboratory meets rigorous quality standards. Widely recognized by sponsors and regulatory agencies as evidence of laboratory quality. Null if not CAP-accredited.' ;
    rdfs:domain ind:LabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cliaNumber rdf:type rdf:Property ;
    rdfs:label 'Clia Number' ;
    rdfs:comment 'Federal CLIA certificate number issued by CMS to U.S. clinical laboratories authorizing them to perform testing on human specimens. Required for regulatory compliance and sponsor qualification audits. Null for non-U.S. facilities.' ;
    rdfs:domain ind:LabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmpkAnalysisCapable rdf:type rdf:Property ;
    rdfs:label 'Dmpk Analysis Capable' ;
    rdfs:comment 'Indicates whether the laboratory facility is equipped and validated to perform Drug Metabolism and Pharmacokinetics (DMPK) analyses, including metabolite profiling and enzyme characterization studies.' ;
    rdfs:domain ind:LabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediLabCode rdf:type rdf:Property ;
    rdfs:label 'Edi Lab Code' ;
    rdfs:comment 'Standardized laboratory code used in electronic data interchange (EDI) transmissions between the laboratory and EDC/CTMS systems. Aligns with CDISC LAB data standards for lab results transfer.' ;
    rdfs:domain ind:LabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCode rdf:type rdf:Property ;
    rdfs:label 'Facility Code' ;
    rdfs:comment 'Externally-known, human-readable unique business identifier for the laboratory facility (e.g., \'LAB-CENT-001\'). Used in study protocols, eCRFs, and regulatory submissions to reference the facility. Serves as the BUSINESS_IDENTIFIER per MASTER_RESOURCE canonical requirements.' ;
    rdfs:domain ind:LabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Official legal or operating name of the laboratory facility as registered with accreditation bodies and regulatory authorities. Serves as the IDENTITY_LABEL per MASTER_RESOURCE canonical requirements.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the laboratory facility by its operational role in clinical trials. Central labs process specimens from multiple sites; local labs are site-affiliated; bioanalytical labs perform assay development and sample analysis; PK/DMPK labs focus on pharmacokinetics and drug metabolism. Serves as CLASSIFICATION_OR_TYPE per MASTER_RESOURCE canonical requirements.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flowCytometryCapable rdf:type rdf:Property ;
    rdfs:label 'Flow Cytometry Capable' ;
    rdfs:comment 'Indicates whether the laboratory facility has validated flow cytometry capabilities for immunophenotyping and cell-based assays, commonly required in oncology and immunology trials.' ;
    rdfs:domain ind:LabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gcpCertified rdf:type rdf:Property ;
    rdfs:label 'Gcp Certified' ;
    rdfs:comment 'Indicates whether the laboratory facility holds a current Good Clinical Practice (GCP) certification or has been qualified under GCP guidelines by the sponsor or CRO. Required for laboratories participating in regulated clinical trials.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genomicsCapable rdf:type rdf:Property ;
    rdfs:label 'Genomics Capable' ;
    rdfs:comment 'Indicates whether the laboratory facility is equipped to perform genomic analyses (e.g., PCR, NGS, genotyping) relevant to pharmacogenomics endpoints in clinical trials.' ;
    rdfs:domain ind:LabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glpCertified rdf:type rdf:Property ;
    rdfs:label 'Glp Certified' ;
    rdfs:comment 'Indicates whether the laboratory facility is certified under Good Laboratory Practice (GLP) regulations, required for non-clinical safety studies and certain bioanalytical work supporting regulatory submissions.' ;
    rdfs:domain ind:LabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso15189CertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Iso 15189 Certificate Number' ;
    rdfs:comment 'Certificate number issued by a national accreditation body (e.g., UKAS, DAkkS, COFRAC) confirming the laboratory conforms to ISO 15189 requirements for medical laboratories. Recognized internationally for cross-border clinical trial operations.' ;
    rdfs:domain ind:LabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsSystemCode rdf:type rdf:Property ;
    rdfs:label 'Lims System Code' ;
    rdfs:comment 'Unique identifier for this facility within its Laboratory Information Management System (LIMS). Used for electronic data exchange, specimen tracking, and results transmission to EDC systems such as Medidata Rave.' ;
    rdfs:domain ind:LabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limsVendor rdf:type rdf:Property ;
    rdfs:label 'Lims Vendor' ;
    rdfs:comment 'Name of the LIMS software vendor used by the facility (e.g., LabVantage, STARLIMS, LabWare). Relevant for EDC integration planning and data transfer agreement scoping.' ;
    rdfs:domain ind:LabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalDirectorName rdf:type rdf:Property ;
    rdfs:label 'Medical Director Name' ;
    rdfs:comment 'Full name of the licensed physician or doctoral scientist serving as the laboratory\'s Medical Director, as required by CLIA and CAP accreditation. Accountable for overall laboratory quality and regulatory compliance.' ;
    rdfs:domain ind:LabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkAffiliation rdf:type rdf:Property ;
    rdfs:label 'Network Affiliation' ;
    rdfs:comment 'Name of the central laboratory network or parent organization to which this facility belongs (e.g., \'Covance\', \'Q2 Solutions\', \'BioReference\', \'PPD\'). Used for contract management, network-level performance reporting, and escalation routing.' ;
    rdfs:domain ind:LabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:normalHoursOfOperation rdf:type rdf:Property ;
    rdfs:label 'Normal Hours Of Operation' ;
    rdfs:comment 'Description of the laboratory facility\'s standard operating hours (e.g., \'Mon-Fri 07:00-19:00 EST\'). Used for specimen shipment scheduling, turnaround time SLA definition, and site coordinator guidance.' ;
    rdfs:domain ind:LabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current lifecycle state of the laboratory facility indicating whether it is actively accepting specimens for clinical trial studies. Drives eligibility for new study assignments and site qualification workflows. Serves as LIFECYCLE_STATUS per MASTER_RESOURCE canonical requirements.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pkAnalysisCapable rdf:type rdf:Property ;
    rdfs:label 'Pk Analysis Capable' ;
    rdfs:comment 'Indicates whether the laboratory facility is equipped and validated to perform pharmacokinetic (PK) sample analysis, including bioanalytical assays for drug concentration measurement.' ;
    rdfs:domain ind:LabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the laboratory facility\'s physical address. Used for specimen shipment logistics and geographic analysis.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCourier rdf:type rdf:Property ;
    rdfs:label 'Preferred Courier' ;
    rdfs:comment 'Name of the preferred or contracted courier service for specimen shipment to this facility (e.g., \'World Courier\', \'Marken\', \'FedEx Custom Critical\'). Used for logistics planning and chain-of-custody documentation.' ;
    rdfs:domain ind:LabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Email address of the primary operational contact at the laboratory facility. Used for study coordination communications, specimen shipment notifications, and results transmission alerts.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary operational contact person at the laboratory facility (e.g., Laboratory Director or Operations Manager). Used for study coordination, issue escalation, and regulatory correspondence.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Primary telephone number for the laboratory facility\'s operational contact. Used for urgent specimen handling queries, critical value notifications, and logistics coordination.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Sponsor or CRO qualification status of the laboratory facility, reflecting the outcome of vendor qualification audits and ongoing performance reviews. Determines whether the facility may be assigned to new studies.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCertifications rdf:type rdf:Property ;
    rdfs:label 'Regulatory Certifications' ;
    rdfs:comment 'Comma-separated list of additional regulatory certifications held by the facility beyond primary accreditation (e.g., \'FDA-registered, EMA-compliant, PMDA-approved, NY State DOH\'). Supports multi-jurisdictional study eligibility assessment.' ;
    rdfs:domain ind:LabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenCapacityPerDay rdf:type rdf:Property ;
    rdfs:label 'Specimen Capacity Per Day' ;
    rdfs:comment 'Maximum number of specimens the facility can process per business day under normal operating conditions. Used for capacity planning, site feasibility assessments, and study logistics. Serves as MEASUREMENT_OR_VALUE per MASTER_RESOURCE canonical requirements.' ;
    rdfs:domain ind:LabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specimenReceiptCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Specimen Receipt Cutoff Time' ;
    rdfs:comment 'Latest time of day (HH:MM, 24-hour format, local facility time) by which specimens must be received to be processed on the same business day. Critical for study protocol logistics and turnaround time commitments.' ;
    rdfs:domain ind:LabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the laboratory facility\'s local time (e.g., \'America/New_York\', \'Europe/London\'). Used for specimen receipt timestamp normalization, turnaround time calculations, and critical value notification SLA tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundTimeStandardHours rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Standard Hours' ;
    rdfs:comment 'Standard turnaround time in hours from specimen receipt to results availability for routine panels. Used in study feasibility assessments and service level agreement (SLA) monitoring.' ;
    rdfs:domain ind:LabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:turnaroundTimeStatHours rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Stat Hours' ;
    rdfs:comment 'Turnaround time in hours for STAT (urgent) specimen processing. Used for safety monitoring protocols where rapid results are required for subject safety decisions.' ;
    rdfs:domain ind:LabFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:labKitId rdf:type rdf:Property ;
    rdfs:label 'Lab Kit Id' ;
    rdfs:comment 'Unique surrogate identifier for the laboratory collection kit master record. Primary key for the lab_kit entity.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabKit .

ind:biohazardClassification rdf:type rdf:Property ;
    rdfs:label 'Biohazard Classification' ;
    rdfs:comment 'IATA/UN biohazard classification for shipping the collected specimen (Category A UN2814, Category B UN3373, Exempt). Determines packaging and shipping documentation requirements for specimen transport.' ;
    rdfs:domain ind:LabKit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdiscLbspecCode rdf:type rdf:Property ;
    rdfs:label 'Cdisc Lbspec Code' ;
    rdfs:comment 'CDISC SDTM controlled terminology value for specimen type (LBSPEC variable), e.g., BLOOD, URINE, PLASMA, SERUM. Enables direct mapping to SDTM LB domain for regulatory submission datasets.' ;
    rdfs:domain ind:LabKit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionTimepoint rdf:type rdf:Property ;
    rdfs:label 'Collection Timepoint' ;
    rdfs:comment 'Specific timepoint within a visit at which the specimen should be collected (e.g., pre-dose, 1h post-dose, 4h post-dose). Particularly relevant for PK/PD sampling schedules.' ;
    rdfs:domain ind:LabKit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentsDescription rdf:type rdf:Property ;
    rdfs:label 'Components Description' ;
    rdfs:comment 'Free-text or structured description of all components included in the kit (e.g., EDTA tubes, serum separator tubes, cryovials, dry ice packs, biohazard bags, requisition forms, instruction leaflets). Supports site training and deviation investigation.' ;
    rdfs:domain ind:LabKit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastingRequired rdf:type rdf:Property ;
    rdfs:label 'Fasting Required' ;
    rdfs:comment 'Indicates whether the subject must be fasting prior to specimen collection using this kit. Fasting status affects reference ranges and result interpretation for metabolic and lipid panels.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:instructionLeafletVersion rdf:type rdf:Property ;
    rdfs:label 'Instruction Leaflet Version' ;
    rdfs:comment 'Version number of the collection instruction leaflet included in the kit. Ensures site staff follow the correct collection procedure aligned to the current protocol version.' ;
    rdfs:domain ind:LabKit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAncillaryKit rdf:type rdf:Property ;
    rdfs:label 'Is Ancillary Kit' ;
    rdfs:comment 'Indicates whether this kit is an ancillary/backup kit (True) rather than a primary protocol-required kit (False). Ancillary kits are used for repeat collections or unscheduled assessments.' ;
    rdfs:domain ind:LabKit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kitCategory rdf:type rdf:Property ;
    rdfs:label 'Kit Category' ;
    rdfs:comment 'Functional category of the kit indicating the scientific purpose of the specimen collection (e.g., Pharmacokinetics (PK), Pharmacodynamics (PD), safety labs, biomarker, genetic). Aligns kit to the study\'s analytical objectives. [ENUM-REF-CANDIDATE: pk|pd|safety|biomarker|genetic|microbiome|dmpk|other — promote to reference product]' ;
    rdfs:domain ind:LabKit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kitLabelLanguage rdf:type rdf:Property ;
    rdfs:label 'Kit Label Language' ;
    rdfs:comment 'ISO 639 language code for the primary language of the kit label and instruction leaflet (e.g., en, fr, de, ja). Ensures regulatory compliance for multi-country trials requiring local language labelling.' ;
    rdfs:domain ind:LabKit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kitNumber rdf:type rdf:Property ;
    rdfs:label 'Kit Number' ;
    rdfs:comment 'Externally-known unique alphanumeric identifier assigned to the kit, typically printed on the kit label and used for chain-of-custody tracking. Corresponds to the kit barcode or label ID in RTSM/IRT systems such as Medidata Rave RTSM.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kitStatus rdf:type rdf:Property ;
    rdfs:label 'Kit Status' ;
    rdfs:comment 'Current lifecycle status of the kit. Drives inventory management workflows and ensures expired or quarantined kits are not used for specimen collection. [ENUM-REF-CANDIDATE: available|assigned|shipped|received|used|expired|quarantined|destroyed|returned — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kitType rdf:type rdf:Property ;
    rdfs:label 'Kit Type' ;
    rdfs:comment 'Classification of the kit by specimen matrix type (e.g., blood, urine, tissue). Determines the collection containers and preservatives included. [ENUM-REF-CANDIDATE: blood|urine|saliva|tissue|csf|stool|buccal_swab|plasma|serum|other — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kitVersion rdf:type rdf:Property ;
    rdfs:label 'Kit Version' ;
    rdfs:comment 'Version identifier of the kit design or configuration. Used to track protocol amendments that change collection requirements, ensuring sites use the correct kit version per the current protocol.' ;
    rdfs:domain ind:LabKit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labAccreditationStandard rdf:type rdf:Property ;
    rdfs:label 'Lab Accreditation Standard' ;
    rdfs:comment 'Accreditation standard under which the central laboratory processing specimens from this kit is certified (e.g., ISO 15189, CAP, CLIA, GCLP). Required for regulatory submissions and sponsor quality oversight.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Manufacturing lot number assigned by the kit supplier or central laboratory. Enables traceability for quality investigations, recalls, and regulatory inspections. Critical for ALCOA+ compliance.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Date on which the kit was manufactured or assembled by the supplier. Used in conjunction with expiry date to calculate shelf life and manage inventory rotation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preservativeType rdf:type rdf:Property ;
    rdfs:label 'Preservative Type' ;
    rdfs:comment 'Type of preservative or additive included in the kit (e.g., EDTA, heparin, sodium fluoride, formalin, RNAlater). Critical for specimen stability and downstream analytical method compatibility.' ;
    rdfs:domain ind:LabKit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolVisitReference rdf:type rdf:Property ;
    rdfs:label 'Protocol Visit Reference' ;
    rdfs:comment 'Protocol-defined visit name or visit window for which this kit is intended (e.g., Screening, Day 1, Week 4). Ensures the correct kit type is used at the correct study visit per the protocol schedule of assessments.' ;
    rdfs:domain ind:LabKit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityPerShipment rdf:type rdf:Property ;
    rdfs:label 'Quantity Per Shipment' ;
    rdfs:comment 'Standard number of kits included in a single shipment to a site. Used for supply planning, purchase order generation, and site inventory management.' ;
    rdfs:domain ind:LabKit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reorderThreshold rdf:type rdf:Property ;
    rdfs:label 'Reorder Threshold' ;
    rdfs:comment 'Minimum quantity of kits at a site below which a resupply order should be triggered. Supports proactive inventory management to prevent site stock-outs.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requisitionFormIncluded rdf:type rdf:Property ;
    rdfs:label 'Requisition Form Included' ;
    rdfs:comment 'Indicates whether a laboratory requisition form (paper or pre-printed label) is included in the kit. Requisition forms are required by central labs for specimen processing and chain-of-custody documentation.' ;
    rdfs:domain ind:LabKit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnKitRequired rdf:type rdf:Property ;
    rdfs:label 'Return Kit Required' ;
    rdfs:comment 'Indicates whether the used kit or residual materials must be returned to the central laboratory or sponsor after specimen collection. Relevant for chain-of-custody and waste management compliance.' ;
    rdfs:domain ind:LabKit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Free-text field capturing any special handling requirements for the kit or collected specimen (e.g., protect from light, invert tube 8 times, centrifuge within 30 minutes, ship on dry ice). Critical for specimen integrity.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Max C' ;
    rdfs:comment 'Maximum allowable storage temperature in degrees Celsius for the kit. Used alongside minimum temperature to define the acceptable storage range and trigger excursion alerts.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Min C' ;
    rdfs:comment 'Minimum allowable storage temperature in degrees Celsius for the kit. Ensures cold-chain integrity and preservative efficacy. Deviations must be documented per GCP.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierKitCatalogNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Kit Catalog Number' ;
    rdfs:comment 'Supplier\'s own catalog or part number for this kit configuration. Used for reordering, purchase orders in SAP S/4HANA, and supplier quality documentation.' ;
    rdfs:domain ind:LabKit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierName rdf:type rdf:Property ;
    rdfs:label 'Supplier Name' ;
    rdfs:comment 'Name of the vendor or central laboratory that manufactured and supplied the kit. Used for procurement, quality investigations, and supplier qualification tracking.' ;
    rdfs:domain ind:LabKit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tubeCount rdf:type rdf:Property ;
    rdfs:label 'Tube Count' ;
    rdfs:comment 'Total number of collection tubes included in the kit. Used for inventory reconciliation and to verify completeness of kit contents upon receipt at the site.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tubeType rdf:type rdf:Property ;
    rdfs:label 'Tube Type' ;
    rdfs:comment 'Type of collection tube(s) included in the kit (e.g., EDTA K2, SST, lithium heparin, sodium citrate, PAXgene). Determines anticoagulant or additive present, which is critical for assay validity.' ;
    rdfs:domain ind:LabKit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tubeVolumeMl rdf:type rdf:Property ;
    rdfs:label 'Tube Volume Ml' ;
    rdfs:comment 'Nominal volume in millilitres of each collection tube in the kit. Used to confirm adequate sample volume for the required assays and to flag insufficient sample at processing.' ;
    rdfs:domain ind:LabKit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adamDatasetMapping rdf:type rdf:Property ;
    rdfs:label 'Adam Dataset Mapping' ;
    rdfs:comment 'CDISC ADaM dataset name to which this panel\'s results are mapped for statistical analysis (e.g., ADLB for laboratory data, ADPC for PK concentration data, ADPP for PK parameter data). Used by SAS Drug Development for ADaM dataset generation.' ;
    rdfs:domain ind:LabPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdiscLbcatCode rdf:type rdf:Property ;
    rdfs:label 'Cdisc Lbcat Code' ;
    rdfs:comment 'Standardized CDISC SDTM LBCAT value for this panel\'s category as defined in the CDISC controlled terminology (e.g., \'HEMATOLOGY\', \'CHEMISTRY\', \'URINALYSIS\'). Required for SDTM dataset compliance in regulatory submissions.' ;
    rdfs:domain ind:LabPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerType rdf:type rdf:Property ;
    rdfs:label 'Container Type' ;
    rdfs:comment 'Type of collection tube or container required for specimen collection (e.g., EDTA tube, SST tube, Lithium Heparin tube, Urine cup). Critical for pre-analytical quality and chain of custody. [ENUM-REF-CANDIDATE: edta|sst|lithium_heparin|sodium_citrate|fluoride_oxalate|urine_cup|cryovial — promote to reference product]' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalValueFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Value Flag' ;
    rdfs:comment 'Indicates whether any analyte in this panel has defined critical (panic) values that require immediate notification to the investigator or site per laboratory SOP. Drives alert workflows in the EDC and CTMS.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fastingDurationHours rdf:type rdf:Property ;
    rdfs:label 'Fasting Duration Hours' ;
    rdfs:comment 'Minimum number of hours the subject must fast before specimen collection when fasting is required. Null when fasting_required is False.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBiomarkerPanel rdf:type rdf:Property ;
    rdfs:label 'Is Biomarker Panel' ;
    rdfs:comment 'Indicates whether this panel includes exploratory or validated biomarker assessments (e.g., genomic, proteomic, or metabolomic markers). Biomarker panels may require additional consent and specialized sample handling.' ;
    rdfs:domain ind:LabPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPdPanel rdf:type rdf:Property ;
    rdfs:label 'Is Pd Panel' ;
    rdfs:comment 'Indicates whether this panel is a Pharmacodynamics (PD) panel measuring the biological effect of the drug. PD panels may map to CDISC SDTM LB or FA domains depending on the analyte type.' ;
    rdfs:domain ind:LabPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPkPanel rdf:type rdf:Property ;
    rdfs:label 'Is Pk Panel' ;
    rdfs:comment 'Indicates whether this panel is a Pharmacokinetics (PK) panel used to measure drug concentration over time. PK panels map to CDISC SDTM PC domain and require specialized bioanalytical assay management.' ;
    rdfs:domain ind:LabPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyPanel rdf:type rdf:Property ;
    rdfs:label 'Is Safety Panel' ;
    rdfs:comment 'Indicates whether this panel is designated as a safety monitoring panel (e.g., liver function, renal function, hematology) required for adverse event assessment and DSMB/DMC review.' ;
    rdfs:domain ind:LabPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labCertificationStandard rdf:type rdf:Property ;
    rdfs:label 'Lab Certification Standard' ;
    rdfs:comment 'Accreditation or certification standard under which the performing laboratory is certified for this panel (e.g., CAP, ISO 15189, CLIA, GLP, GCLP). Required for regulatory submission credibility. [ENUM-REF-CANDIDATE: cap|iso_15189|clia|glp|gclp|jci|ukas — promote to reference product]' ;
    rdfs:domain ind:LabPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Method Validation Status' ;
    rdfs:comment 'Validation status of the analytical method used for this panel per ICH M10 and FDA/EMA guidance. \'validated\' methods have full regulatory-grade validation; \'qualified\' methods have partial validation; \'exploratory\' methods are research-grade only.' ;
    rdfs:domain ind:LabPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelCategory rdf:type rdf:Property ;
    rdfs:label 'Panel Category' ;
    rdfs:comment 'High-level classification of the panel by clinical discipline or analyte group (e.g., Hematology, Clinical Chemistry, Coagulation, Urinalysis, Immunology, Pharmacokinetics, Biomarker). [ENUM-REF-CANDIDATE: hematology|clinical_chemistry|coagulation|urinalysis|immunology|pharmacokinetics|biomarker|microbiology|serology|endocrinology — promote to reference product]' ;
    rdfs:domain ind:LabPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelCode rdf:type rdf:Property ;
    rdfs:label 'Panel Code' ;
    rdfs:comment 'Externally-known, sponsor- or CRO-assigned alphanumeric code uniquely identifying the lab panel within the study catalog (e.g., CHEM20, CBC, LFT). Used as the business key for cross-system reference and CDISC SDTM LBTESTCD mapping.' ;
    rdfs:domain ind:LabPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelName rdf:type rdf:Property ;
    rdfs:label 'Panel Name' ;
    rdfs:comment 'Full human-readable name of the laboratory test panel or battery (e.g., \'Complete Blood Count\', \'Comprehensive Metabolic Panel\', \'Liver Function Tests\'). Maps to CDISC SDTM LBTEST.' ;
    rdfs:domain ind:LabPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelShortName rdf:type rdf:Property ;
    rdfs:label 'Panel Short Name' ;
    rdfs:comment 'Abbreviated display name for the panel used in eCRF headers, reports, and dashboards where space is constrained (e.g., \'CBC\', \'CMP\', \'LFT\').' ;
    rdfs:domain ind:LabPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelStatus rdf:type rdf:Property ;
    rdfs:label 'Panel Status' ;
    rdfs:comment 'Current lifecycle status of the lab panel definition in the catalog. \'active\' panels are available for protocol inclusion; \'retired\' panels are no longer used in new studies; \'draft\' panels are pending validation.' ;
    rdfs:domain ind:LabPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelSubcategory rdf:type rdf:Property ;
    rdfs:label 'Panel Subcategory' ;
    rdfs:comment 'Secondary classification within the panel category providing finer granularity (e.g., within Clinical Chemistry: \'Liver Function\', \'Renal Function\', \'Lipid Panel\'). Maps to CDISC SDTM LBSCAT.' ;
    rdfs:domain ind:LabPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceRangeSource rdf:type rdf:Property ;
    rdfs:label 'Reference Range Source' ;
    rdfs:comment 'Source of the normal reference ranges applied to results from this panel. Central lab-derived ranges are preferred for regulatory submissions; sponsor-defined ranges may be used for novel biomarkers.' ;
    rdfs:domain ind:LabPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCondition rdf:type rdf:Property ;
    rdfs:label 'Shipping Condition' ;
    rdfs:comment 'Required temperature condition for shipping specimens from the clinical site to the central laboratory. Governs cold chain logistics, packaging requirements, and IATA compliance for biological specimens.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Specimen Collection Method' ;
    rdfs:comment 'Standardized method used to collect the specimen (e.g., Venipuncture, Finger Stick, Midstream Catch, Lumbar Puncture). Maps to CDISC SDTM LBMETHOD. [ENUM-REF-CANDIDATE: venipuncture|finger_stick|midstream_catch|lumbar_puncture|biopsy|swab|catheterization — promote to reference product]' ;
    rdfs:domain ind:LabPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenVolumeMl rdf:type rdf:Property ;
    rdfs:label 'Specimen Volume Ml' ;
    rdfs:comment 'Minimum volume of specimen required in millilitres to perform all analytes in the panel. Used for phlebotomy planning, patient burden assessment, and paediatric study feasibility.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statTurnaroundTimeHours rdf:type rdf:Property ;
    rdfs:label 'Stat Turnaround Time Hours' ;
    rdfs:comment 'Expedited turnaround time in hours for urgent (STAT) requests, typically triggered by safety events or critical value alerts. Distinct from standard SLA turnaround time.' ;
    rdfs:domain ind:LabPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperature rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature' ;
    rdfs:comment 'Required storage temperature condition for the specimen prior to analysis (e.g., ambient, refrigerated 2–8°C, frozen –20°C, frozen –80°C). Governs cold chain logistics and sample chain of custody.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundTimeHours rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Hours' ;
    rdfs:comment 'Contracted or target turnaround time in hours from specimen receipt at the laboratory to result reporting. Used for SLA monitoring, site management, and safety decision timelines. Critical for SAE-related panels.' ;
    rdfs:domain ind:LabPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visitTimepoints rdf:type rdf:Property ;
    rdfs:label 'Visit Timepoints' ;
    rdfs:comment 'Comma-separated list of protocol visit names or codes at which this panel is scheduled (e.g., \'Screening, Day 1, Week 4, Week 8, End of Treatment, Follow-Up\'). Supports protocol schedule of assessments design and EDC form configuration.' ;
    rdfs:domain ind:LabPanel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labQueryId rdf:type rdf:Property ;
    rdfs:label 'Lab Query Id' ;
    rdfs:comment 'Unique surrogate identifier for the laboratory data query record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:LabQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adverseEventId rdf:type rdf:Property ;
    rdfs:label 'Adverse Event Id' ;
    rdfs:comment 'Foreign key linking to safety.adverse_event. Business justification: Lab queries with safety_relevance_flag=true are raised to resolve data discrepancies that affect AE reporting. Linking lab_query to adverse_event formalizes the safety data cleaning process, enabling ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdverseEvent .

ind:primaryLabEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Lab Employee Id' ;
    rdfs:comment 'Reference to the workforce/user record of the individual (data manager, medical monitor, CRA, or system process) who raised this query. Supports ALCOA+ attributability and audit trail requirements.' ;
    rdfs:domain ind:LabQuery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryLabResolvedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Lab Resolved By User Employee Id' ;
    rdfs:comment 'Reference to the data manager or authorized user who closed or cancelled the query after reviewing the response and confirming data quality resolution. Supports ALCOA+ attributability.' ;
    rdfs:domain ind:LabQuery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryLabRespondedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Lab Responded By User Employee Id' ;
    rdfs:comment 'Reference to the user who submitted the query response on behalf of the site or laboratory. Supports ALCOA+ attributability and electronic signature audit trail per 21 CFR Part 11.' ;
    rdfs:domain ind:LabQuery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignedToPartyType rdf:type rdf:Property ;
    rdfs:label 'Assigned To Party Type' ;
    rdfs:comment 'Type of organizational party to whom the query is assigned for response — investigational site, central laboratory, local laboratory, sponsor, or CRO (Contract Research Organization). Determines routing and accountability.' ;
    rdfs:domain ind:LabQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctedValue rdf:type rdf:Property ;
    rdfs:label 'Corrected Value' ;
    rdfs:comment 'The laboratory result value after correction, if a data change was made as a result of this query. Null if no correction was applied. Provides after-state for audit trail per ALCOA+ and 21 CFR Part 11 requirements.' ;
    rdfs:domain ind:LabQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataCorrectionFlag rdf:type rdf:Property ;
    rdfs:label 'Data Correction Flag' ;
    rdfs:comment 'Indicates whether the resolution of this query resulted in a data value change in the source EDC or LIMS record. True = a data correction was made; False = original data confirmed or query cancelled without change. Key metric for data quality reporting.' ;
    rdfs:domain ind:LabQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dblBlockingFlag rdf:type rdf:Property ;
    rdfs:label 'Dbl Blocking Flag' ;
    rdfs:comment 'Indicates whether this open query is blocking the Database Lock (DBL) for the study or subject. True = must be resolved before DBL can proceed; False = non-blocking. Critical for study close-out planning and timeline management.' ;
    rdfs:domain ind:LabQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ecrfFieldName rdf:type rdf:Property ;
    rdfs:label 'Ecrf Field Name' ;
    rdfs:comment 'Specific field name within the eCRF form that contains the queried laboratory data value (e.g., \'LBORRES\', \'LBORRESU\'). Enables precise identification of the data point in question for site response and EDC correction.' ;
    rdfs:domain ind:LabQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecrfFormName rdf:type rdf:Property ;
    rdfs:label 'Ecrf Form Name' ;
    rdfs:comment 'Name of the eCRF form in the EDC (Medidata Rave) on which the queried laboratory data field resides (e.g., \'Laboratory Results\', \'Hematology\'). Supports EDC navigation and query routing to the correct data entry form.' ;
    rdfs:domain ind:LabQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcQueryCode rdf:type rdf:Property ;
    rdfs:label 'Edc Query Code' ;
    rdfs:comment 'Native query identifier assigned by the source EDC system (Medidata Rave) or LIMS. Enables bidirectional traceability between the lakehouse Silver Layer record and the operational system of record for reconciliation and audit.' ;
    rdfs:domain ind:LabQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDatetime rdf:type rdf:Property ;
    rdfs:label 'Escalation Datetime' ;
    rdfs:comment 'Date and time when the query was formally escalated. Null if no escalation has occurred. Used for escalation cycle time analytics and regulatory inspection readiness.' ;
    rdfs:domain ind:LabQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:queryIterationCount rdf:type rdf:Property ;
    rdfs:label 'Query Iteration Count' ;
    rdfs:comment 'Number of times this query has been re-opened or re-issued against the same laboratory result field, indicating the number of response-review cycles. A high iteration count signals persistent data quality issues at the site or lab.' ;
    rdfs:domain ind:LabQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:queryPriority rdf:type rdf:Property ;
    rdfs:label 'Query Priority' ;
    rdfs:comment 'Business priority assigned to the query indicating urgency of resolution. Critical queries (e.g., those linked to SAE data or DBL-blocking issues) require immediate attention. Drives escalation and SLA enforcement.' ;
    rdfs:domain ind:LabQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:querySourceSystem rdf:type rdf:Property ;
    rdfs:label 'Query Source System' ;
    rdfs:comment 'Identifies the operational system of record in which this query originated — EDC (Medidata Rave), a Laboratory Information Management System (LIMS), Oracle Clinical One, or a manually entered query. Supports multi-system data quality governance.' ;
    rdfs:domain ind:LabQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raisedDatetime rdf:type rdf:Property ;
    rdfs:label 'Raised Datetime' ;
    rdfs:comment 'Date and time (ISO 8601 with timezone) when the query was formally raised and entered into the EDC or LIMS. Principal business event timestamp for the query lifecycle. Required for SLA calculation and ALCOA+ contemporaneity compliance.' ;
    rdfs:domain ind:LabQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Outcome action taken to resolve the query: data value was corrected in the EDC/LIMS, original data was confirmed as correct, query was withdrawn by the raiser, or no action was required. Critical for data audit trail and regulatory inspection readiness.' ;
    rdfs:domain ind:LabQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDatetime rdf:type rdf:Property ;
    rdfs:label 'Resolution Datetime' ;
    rdfs:comment 'Date and time (ISO 8601 with timezone) when the query was formally closed or cancelled by the data manager after reviewing the site/lab response. Marks the end of the query lifecycle. Used for cycle time analytics and DBL readiness.' ;
    rdfs:domain ind:LabQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responseDatetime rdf:type rdf:Property ;
    rdfs:label 'Response Datetime' ;
    rdfs:comment 'Date and time (ISO 8601 with timezone) when the site or laboratory submitted their response to the query. Used for SLA compliance measurement and ALCOA+ contemporaneity tracking.' ;
    rdfs:domain ind:LabQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:safetyRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Relevance Flag' ;
    rdfs:comment 'Indicates whether the queried laboratory result is associated with a safety event (SAE, AE, or SUSAR) or a critical value, requiring expedited resolution. True = safety-relevant; False = routine data quality query. Drives prioritization and safety reporting workflows.' ;
    rdfs:domain ind:LabQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether the query response or resolution exceeded the defined SLA target days. True = SLA was breached; False = responded within SLA. Drives escalation workflows and site performance KPI reporting.' ;
    rdfs:domain ind:LabQuery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usubjid rdf:type rdf:Property ;
    rdfs:label 'Usubjid' ;
    rdfs:comment 'CDISC SDTM-compliant unique subject identifier (sponsor-study-subject concatenation) denormalized onto the query record for direct regulatory submission traceability and ALCOA+ audit compliance without requiring a join.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenId rdf:type rdf:Property ;
    rdfs:label 'Specimen Id' ;
    rdfs:comment 'Reference to the biological specimen from which this laboratory result was derived. Links to the specimen/sample chain-of-custody record.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specimen .

ind:collectionDatetime rdf:type rdf:Property ;
    rdfs:label 'Collection Datetime' ;
    rdfs:comment 'Date and time when the specimen was collected from the subject. Maps to CDISC SDTM LBDTC. Principal business event timestamp for the laboratory result. Critical for PK/PD analysis, time-from-dose calculations, and protocol deviation assessment.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataOrigin rdf:type rdf:Property ;
    rdfs:label 'Data Origin' ;
    rdfs:comment 'Source system or method by which this laboratory result was entered into the data management system. EDC: entered via Medidata Rave eCRF; LAB_DIRECT: electronic lab data transfer; MANUAL: manual data entry; MIGRATION: legacy data migration; BIOANALYTICAL: bioanalytical lab system feed.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dblIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Dbl Included Flag' ;
    rdfs:comment 'Indicates whether this result was included in the locked database at the time of Database Lock (DBL). False indicates the result was added or modified post-lock (requires formal database unlock procedure). Critical for regulatory submission integrity.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fastingStatus rdf:type rdf:Property ;
    rdfs:label 'Fasting Status' ;
    rdfs:comment 'Indicates whether the subject was fasting at the time of specimen collection. Maps to CDISC SDTM LBFAST. Critical for metabolic analytes (glucose, lipids) where fasting status affects reference ranges and result interpretation.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lbcat rdf:type rdf:Property ;
    rdfs:label 'Lbcat' ;
    rdfs:comment 'High-level CDISC SDTM category grouping the laboratory test (e.g., HEMATOLOGY, CHEMISTRY, URINALYSIS, COAGULATION, IMMUNOLOGY). Used for data review panels and SDTM LB dataset partitioning.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lbscat rdf:type rdf:Property ;
    rdfs:label 'Lbscat' ;
    rdfs:comment 'CDISC SDTM subcategory providing finer classification within LBCAT (e.g., LIVER FUNCTION TESTS within CHEMISTRY, RED BLOOD CELL within HEMATOLOGY). Supports granular data review and reporting.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:method rdf:type rdf:Property ;
    rdfs:label 'Method' ;
    rdfs:comment 'Analytical method or instrument used to perform the laboratory test (e.g., ENZYMATIC, IMMUNOASSAY, FLOW CYTOMETRY, PCR, HPLC). Maps to CDISC SDTM LBMETHOD. Relevant for bioanalytical assay validation and cross-lab comparability.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:normalRangeLower rdf:type rdf:Property ;
    rdfs:label 'Normal Range Lower' ;
    rdfs:comment 'Lower bound of the laboratory\'s normal reference range for this analyte, in standard units. Maps to CDISC SDTM LBSTNRLO. Used for out-of-range flagging and shift table generation.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:normalRangeUpper rdf:type rdf:Property ;
    rdfs:label 'Normal Range Upper' ;
    rdfs:comment 'Upper bound of the laboratory\'s normal reference range for this analyte, in standard units. Maps to CDISC SDTM LBSTNRHI. Used for out-of-range flagging and shift table generation.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outOfRangeFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Range Flag' ;
    rdfs:comment 'Indicator of whether the result falls outside the normal reference range. Maps to CDISC SDTM LBNRIND. Values: NORMAL (within range), LOW (below lower bound), HIGH (above upper bound), LOW LOW (critically low), HIGH HIGH (critically high).' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queryOpenFlag rdf:type rdf:Property ;
    rdfs:label 'Query Open Flag' ;
    rdfs:comment 'Indicates whether there is at least one open data query (discrepancy) associated with this laboratory result in the EDC system (Medidata Rave). Supports data management workflow and DBL readiness tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resultReceivedDatetime rdf:type rdf:Property ;
    rdfs:label 'Result Received Datetime' ;
    rdfs:comment 'Date and time when the laboratory result was received by the sponsor/CRO data management system (EDC or CTMS). Used for turnaround time monitoring and critical value notification tracking.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resultReportedDatetime rdf:type rdf:Property ;
    rdfs:label 'Result Reported Datetime' ;
    rdfs:comment 'Date and time when the laboratory formally reported and released the result. Distinct from collection and receipt timestamps. Used for lab turnaround time KPI calculation and audit trail.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resultSeqNum rdf:type rdf:Property ;
    rdfs:label 'Result Seq Num' ;
    rdfs:comment 'Sequential number identifying the order of this result record within the subject\'s laboratory data. Maps to CDISC SDTM LBSEQ variable for dataset generation.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resultStandardUnit rdf:type rdf:Property ;
    rdfs:label 'Result Standard Unit' ;
    rdfs:comment 'Standardized unit of measure for the numeric result value after conversion. Maps to CDISC SDTM LBSTRESU. Enables cross-laboratory and cross-study comparisons in statistical analysis.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultValue rdf:type rdf:Property ;
    rdfs:label 'Result Value' ;
    rdfs:comment 'Original reported result value as received from the laboratory, stored as STRING to accommodate numeric, text, and operator-prefixed values (e.g., \'<0.5\', \'>1000\', \'POSITIVE\', \'NEG\'). Maps to CDISC SDTM LBORRES.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resultValueNumeric rdf:type rdf:Property ;
    rdfs:label 'Result Value Numeric' ;
    rdfs:comment 'Standardized numeric result value after unit conversion to the standard unit. NULL for non-numeric results. Maps to CDISC SDTM LBSTRESN. Used for statistical analysis, shift tables, and CTCAE grading.' ;
    rdfs:domain ind:LabResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studyDay rdf:type rdf:Property ;
    rdfs:label 'Study Day' ;
    rdfs:comment 'Relative study day of specimen collection, calculated from the subject\'s reference start date (Day 1 = first dose). Maps to CDISC SDTM LBDY. Negative values indicate pre-treatment assessments. Used for time-course analysis.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Collector Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: PK sample collection requires a qualified, delegated staff member per GCP delegation logs. The existing collected_by plain-text column is a denormalized employee reference. Replacing with collector_em' ;
    rdfs:domain ind:PkSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualTimePostDoseHours rdf:type rdf:Property ;
    rdfs:label 'Actual Time Post Dose Hours' ;
    rdfs:comment 'Calculated elapsed time in hours between the actual dose administration time and the actual sample collection time. Distinct from nominal_time_hours; used as the primary time variable in PK concentration-time profiles and non-compartmental analysis (NCA). Negative values indicate pre-dose collections.' ;
    rdfs:domain ind:PkSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionMethod rdf:type rdf:Property ;
    rdfs:label 'Collection Method' ;
    rdfs:comment 'The method used to collect the biological sample from the subject. Relevant for bioanalytical method validation and potential pre-analytical variability assessment. [ENUM-REF-CANDIDATE: venipuncture|finger_prick|catheter|indwelling_cannula|spot_urine|timed_urine|dried_blood_spot|lumbar_puncture|buccal_swab — promote to reference product]' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doseAdministrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dose Administration Timestamp' ;
    rdfs:comment 'The actual date and time of the reference dose administration used to calculate actual time post-dose for this sample. Sourced from the dosing record in the EDC (Medidata Rave). Required for accurate ATPT calculation per CDISC SDTM PC domain conventions.' ;
    rdfs:domain ind:PkSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:doseNumber rdf:type rdf:Property ;
    rdfs:label 'Dose Number' ;
    rdfs:comment 'The sequential dose number relative to which this PK sample was collected (e.g., 1 for first dose, steady-state dose number). Critical for distinguishing single-dose PK from multiple-dose/steady-state PK profiles in DMPK analysis.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:edcFormReference rdf:type rdf:Property ;
    rdfs:label 'Edc Form Reference' ;
    rdfs:comment 'The reference identifier of the eCRF form in the EDC system (Medidata Rave) where this PK sample collection event was recorded. Enables direct traceability from the silver-layer data product back to the source EDC record for SDV and audit purposes.' ;
    rdfs:domain ind:PkSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labReceiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lab Receipt Timestamp' ;
    rdfs:comment 'The date and time the PK sample was received and logged at the bioanalytical or central laboratory. Used to calculate total sample transit time and to verify cold-chain compliance. Part of the chain-of-custody audit trail.' ;
    rdfs:domain ind:PkSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nominalTimeHours rdf:type rdf:Property ;
    rdfs:label 'Nominal Time Hours' ;
    rdfs:comment 'Numeric representation of the nominal time point in hours relative to dose administration (e.g., -0.0833 for pre-dose, 0.5, 1.0, 2.0). Negative values indicate pre-dose collections. Used for PK modeling, NCA (non-compartmental analysis), and SDTM/ADaM dataset generation in SAS Drug Development.' ;
    rdfs:domain ind:PkSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preDoseFlag rdf:type rdf:Property ;
    rdfs:label 'Pre Dose Flag' ;
    rdfs:comment 'Indicates whether this sample is a pre-dose (trough/baseline) collection. True = pre-dose sample; False = post-dose sample. Pre-dose samples are used to assess trough concentrations, baseline drug levels, and accumulation ratios in multiple-dose PK studies.' ;
    rdfs:domain ind:PkSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingStatus rdf:type rdf:Property ;
    rdfs:label 'Processing Status' ;
    rdfs:comment 'Current processing stage of the PK sample from collection through shipment to the bioanalytical laboratory. Distinct from sample_status (overall lifecycle); this tracks the physical processing workflow. [ENUM-REF-CANDIDATE: pending|processed|centrifuged|aliquoted|frozen|shipped|received_at_lab|failed|destroyed — promote to reference product]' ;
    rdfs:domain ind:PkSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing Timestamp' ;
    rdfs:comment 'The date and time the sample was processed (e.g., centrifuged and aliquoted) after collection. Time from collection to processing is a critical pre-analytical variable that can affect analyte stability and bioanalytical results.' ;
    rdfs:domain ind:PkSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sampleCode rdf:type rdf:Property ;
    rdfs:label 'Sample Code' ;
    rdfs:comment 'Externally-known, human-readable unique identifier for the PK sample, typically printed on the sample tube label and used across CTMS, LIMS, and bioanalytical systems for chain-of-custody tracking. Corresponds to the specimen barcode or accession number.' ;
    rdfs:domain ind:PkSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleConditionOnReceipt rdf:type rdf:Property ;
    rdfs:label 'Sample Condition On Receipt' ;
    rdfs:comment 'Assessment of the physical condition of the PK sample upon receipt at the bioanalytical laboratory. Conditions such as haemolysis, lipaemia, or temperature excursion may affect analyte measurement and trigger sample rejection or result flagging. [ENUM-REF-CANDIDATE: acceptable|haemolysed|lipemic|insufficient_volume|temperature_excursion|damaged|missing — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PkSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleExclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Sample Exclusion Flag' ;
    rdfs:comment 'Indicates whether this PK sample has been excluded from the primary PK analysis dataset. True = excluded; False = included. Exclusions may be due to protocol deviations, sample integrity issues, or bioanalytical failures. Exclusion reason is captured in exclusion_reason.' ;
    rdfs:domain ind:PkSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleStatus rdf:type rdf:Property ;
    rdfs:label 'Sample Status' ;
    rdfs:comment 'Current lifecycle status of the PK sample from scheduled collection through bioanalytical reporting. Drives workflow routing in LIMS and CTMS. [ENUM-REF-CANDIDATE: scheduled|collected|received|in_transit|received_at_lab|analyzed|reported|rejected|missing|cancelled — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:PkSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleType rdf:type rdf:Property ;
    rdfs:label 'Sample Type' ;
    rdfs:comment 'The biological matrix type of the PK sample. Determines the bioanalytical method applied and the reference range for analyte concentration. Plasma and serum are most common for small molecule PK; urine for renal clearance studies; CSF for CNS penetration studies.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingWindowEndHours rdf:type rdf:Property ;
    rdfs:label 'Sampling Window End Hours' ;
    rdfs:comment 'The protocol-defined acceptable latest collection time in hours relative to dose for this nominal time point. Together with sampling_window_start_hours, defines the acceptable window for protocol compliance assessment.' ;
    rdfs:domain ind:PkSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:samplingWindowStartHours rdf:type rdf:Property ;
    rdfs:label 'Sampling Window Start Hours' ;
    rdfs:comment 'The protocol-defined acceptable earliest collection time in hours relative to dose for this nominal time point. Used to assess whether the actual collection time falls within the acceptable PK sampling window for protocol compliance determination.' ;
    rdfs:domain ind:PkSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature C' ;
    rdfs:comment 'The temperature in degrees Celsius at which the PK sample is stored prior to shipment or analysis. Critical for analyte stability monitoring; deviations from protocol-specified storage conditions (e.g., -70°C, -20°C) must be documented and assessed for impact on sample integrity.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCollectedMl rdf:type rdf:Property ;
    rdfs:label 'Volume Collected Ml' ;
    rdfs:comment 'The actual volume of biological sample collected from the subject, expressed in millilitres. Used for sample sufficiency assessment, bioanalytical aliquoting planning, and protocol compliance verification against the required volume specified in the PK sampling schedule.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeRequiredMl rdf:type rdf:Property ;
    rdfs:label 'Volume Required Ml' ;
    rdfs:comment 'The protocol-specified minimum volume of sample required for the PK assay at this time point, expressed in millilitres. Used to assess whether the collected volume meets protocol requirements and to flag insufficient sample events.' ;
    rdfs:domain ind:PkSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withinSamplingWindow rdf:type rdf:Property ;
    rdfs:label 'Within Sampling Window' ;
    rdfs:comment 'Indicates whether the actual sample collection time falls within the protocol-defined acceptable PK sampling window for this nominal time point. True = within window (compliant); False = outside window (potential protocol deviation). Used in PK analysis inclusion/exclusion decisions and protocol deviation reporting.' ;
    rdfs:domain ind:PkSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backupSampleRequired rdf:type rdf:Property ;
    rdfs:label 'Backup Sample Required' ;
    rdfs:comment 'Indicates whether a backup or reserve aliquot must be collected and stored alongside the primary specimen for potential future analysis (e.g., for biomarker or pharmacogenomics research).' ;
    rdfs:domain ind:ProtocolLabSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:centralLabRequired rdf:type rdf:Property ;
    rdfs:label 'Central Lab Required' ;
    rdfs:comment 'Indicates whether this laboratory assessment must be performed at the central laboratory (as opposed to a local laboratory). Drives specimen shipment logistics and result routing.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionTimeConstraint rdf:type rdf:Property ;
    rdfs:label 'Collection Time Constraint' ;
    rdfs:comment 'Time-of-day or dose-relative constraint for specimen collection at this visit (e.g., pre-dose, post-dose, morning only, timed serial PK sampling). Critical for PK/PD and DMPK assessments.' ;
    rdfs:domain ind:ProtocolLabSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionTimeOffsetHours rdf:type rdf:Property ;
    rdfs:label 'Collection Time Offset Hours' ;
    rdfs:comment 'Nominal time offset in hours relative to dose administration for post-dose or timed serial specimen collection (e.g., 0.5, 1, 2, 4, 8, 24 hours post-dose). Applicable primarily to PK/PD and DMPK assessments.' ;
    rdfs:domain ind:ProtocolLabSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionTimeWindowMinutes rdf:type rdf:Property ;
    rdfs:label 'Collection Time Window Minutes' ;
    rdfs:comment 'Acceptable deviation window in minutes around the nominal collection time offset for timed specimen collection. Used to assess protocol deviations for PK/PD sampling.' ;
    rdfs:domain ind:ProtocolLabSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criticalResultReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Critical Result Review Required' ;
    rdfs:comment 'Indicates whether results from this laboratory assessment require expedited medical review upon receipt of a critical or panic value. Triggers safety review workflows and potential SAE/SUSAR reporting obligations.' ;
    rdfs:domain ind:ProtocolLabSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:edcFormName rdf:type rdf:Property ;
    rdfs:label 'Edc Form Name' ;
    rdfs:comment 'Name of the eCRF form in Medidata Rave that corresponds to this laboratory assessment at this visit. Used to drive EDC study build configuration and eCRF lab page activation.' ;
    rdfs:domain ind:ProtocolLabSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastingDurationHoursMin rdf:type rdf:Property ;
    rdfs:label 'Fasting Duration Hours Min' ;
    rdfs:comment 'Minimum number of hours the subject must fast prior to specimen collection when fasting is required. Null when fasting_required is false.' ;
    rdfs:domain ind:ProtocolLabSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isExploratory rdf:type rdf:Property ;
    rdfs:label 'Is Exploratory' ;
    rdfs:comment 'Indicates whether this laboratory assessment is an exploratory or research-use-only endpoint not included in the primary or secondary efficacy analyses. Supports data management and SAP alignment.' ;
    rdfs:domain ind:ProtocolLabSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPdAssessment rdf:type rdf:Property ;
    rdfs:label 'Is Pd Assessment' ;
    rdfs:comment 'Indicates whether this laboratory assessment is a pharmacodynamic (PD) biomarker collection. Supports differentiation of PD endpoints from standard safety laboratory panels.' ;
    rdfs:domain ind:ProtocolLabSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPkAssessment rdf:type rdf:Property ;
    rdfs:label 'Is Pk Assessment' ;
    rdfs:comment 'Indicates whether this laboratory assessment is a pharmacokinetic (PK) or DMPK sample collection. When true, timed serial collection rules and PK-specific processing instructions apply.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyAssessment rdf:type rdf:Property ;
    rdfs:label 'Is Safety Assessment' ;
    rdfs:comment 'Indicates whether this laboratory assessment is designated as a safety laboratory panel per the protocol. Safety assessments trigger critical value review workflows and DSMB/DMC reporting obligations.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localLabAllowed rdf:type rdf:Property ;
    rdfs:label 'Local Lab Allowed' ;
    rdfs:comment 'Indicates whether results from a local (site) laboratory are acceptable for this assessment, either as a primary result or as a backup when central lab results are unavailable.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:panelRequirement rdf:type rdf:Property ;
    rdfs:label 'Panel Requirement' ;
    rdfs:comment 'Indicates whether the laboratory panel is mandatory (required), optional, conditional on a clinical trigger, restricted to the PK cohort, or applicable only to a defined subject subset per the protocol schedule of assessments.' ;
    rdfs:domain ind:ProtocolLabSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingRequired rdf:type rdf:Property ;
    rdfs:label 'Processing Required' ;
    rdfs:comment 'Indicates whether the specimen requires on-site processing (e.g., centrifugation, aliquoting) prior to shipment to the central laboratory. Drives site laboratory capability requirements.' ;
    rdfs:domain ind:ProtocolLabSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repeatAllowed rdf:type rdf:Property ;
    rdfs:label 'Repeat Allowed' ;
    rdfs:comment 'Indicates whether a repeat specimen collection is permitted at this visit if the initial sample is insufficient, haemolysed, or otherwise unacceptable. Drives site instructions and EDC query management.' ;
    rdfs:domain ind:ProtocolLabSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resultTurnaroundDays rdf:type rdf:Property ;
    rdfs:label 'Result Turnaround Days' ;
    rdfs:comment 'Expected number of calendar days from specimen receipt at the laboratory to result reporting. Used for monitoring visit planning, data management timelines, and SLA tracking with the central laboratory.' ;
    rdfs:domain ind:ProtocolLabSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleNotes rdf:type rdf:Property ;
    rdfs:label 'Schedule Notes' ;
    rdfs:comment 'Free-text notes or footnotes from the protocol schedule of assessments providing additional instructions, conditional collection rules, or clarifications for this laboratory assessment at this visit.' ;
    rdfs:domain ind:ProtocolLabSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle status of this protocol laboratory schedule entry. Reflects whether the schedule is in draft, active per the current protocol version, amended, superseded by a protocol amendment, or retired.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Shipment Frequency' ;
    rdfs:comment 'Frequency at which specimens collected at this visit should be shipped to the central laboratory (e.g., immediate same-day shipment for PK samples, weekly batch shipment for routine safety labs).' ;
    rdfs:domain ind:ProtocolLabSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyDayTarget rdf:type rdf:Property ;
    rdfs:label 'Study Day Target' ;
    rdfs:comment 'The nominal study day on which this visit and laboratory assessment is scheduled relative to the reference start date (Day 1 = first dose). Negative values indicate pre-dose screening days. Aligns with CDISC SDTM study day conventions.' ;
    rdfs:domain ind:ProtocolLabSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visitNum rdf:type rdf:Property ;
    rdfs:label 'Visit Num' ;
    rdfs:comment 'Numeric sequence identifier for the study visit as defined in the protocol schedule of assessments. Supports ordering and CDISC SDTM VISITNUM mapping.' ;
    rdfs:domain ind:ProtocolLabSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visitWindowDayMax rdf:type rdf:Property ;
    rdfs:label 'Visit Window Day Max' ;
    rdfs:comment 'Latest allowable study day (relative to target study day) for the visit window, defining the acceptable upper bound for specimen collection. Used for protocol deviation assessment and site monitoring.' ;
    rdfs:domain ind:ProtocolLabSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visitWindowDayMin rdf:type rdf:Property ;
    rdfs:label 'Visit Window Day Min' ;
    rdfs:comment 'Earliest allowable study day (relative to target study day) for the visit window, defining the acceptable lower bound for specimen collection. Used for protocol deviation assessment and site monitoring.' ;
    rdfs:domain ind:ProtocolLabSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageMax rdf:type rdf:Property ;
    rdfs:label 'Age Max' ;
    rdfs:comment 'Maximum age in years of the subject population for which this reference range applies. Null indicates no upper age bound.' ;
    rdfs:domain ind:ReferenceRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ageMin rdf:type rdf:Property ;
    rdfs:label 'Age Min' ;
    rdfs:comment 'Minimum age in years of the subject population for which this reference range applies. Used to stratify ranges by pediatric, adult, or geriatric populations.' ;
    rdfs:domain ind:ReferenceRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ageUnit rdf:type rdf:Property ;
    rdfs:label 'Age Unit' ;
    rdfs:comment 'Unit of measurement for the age range fields (age_min, age_max). Defaults to years for adults; may be months, weeks, or days for neonatal or pediatric populations.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctcaeGrade1Upper rdf:type rdf:Property ;
    rdfs:label 'Ctcae Grade1 Upper' ;
    rdfs:comment 'Upper boundary value corresponding to CTCAE Grade 1 toxicity for this analyte. Used for automated CTCAE grading of laboratory results in safety and adverse event reporting.' ;
    rdfs:domain ind:ReferenceRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctcaeGrade2Upper rdf:type rdf:Property ;
    rdfs:label 'Ctcae Grade2 Upper' ;
    rdfs:comment 'Upper boundary value corresponding to CTCAE Grade 2 toxicity for this analyte. Used for automated CTCAE grading of laboratory results in safety and adverse event reporting.' ;
    rdfs:domain ind:ReferenceRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctcaeGrade3Upper rdf:type rdf:Property ;
    rdfs:label 'Ctcae Grade3 Upper' ;
    rdfs:comment 'Upper boundary value corresponding to CTCAE Grade 3 toxicity for this analyte. Used for automated CTCAE grading of laboratory results in safety and adverse event reporting.' ;
    rdfs:domain ind:ReferenceRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctcaeGrade4Upper rdf:type rdf:Property ;
    rdfs:label 'Ctcae Grade4 Upper' ;
    rdfs:comment 'Upper boundary value corresponding to CTCAE Grade 4 toxicity for this analyte. Used for automated CTCAE grading of laboratory results in safety and adverse event reporting.' ;
    rdfs:domain ind:ReferenceRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ethnicityApplicability rdf:type rdf:Property ;
    rdfs:label 'Ethnicity Applicability' ;
    rdfs:comment 'Ethnic or racial population for which this reference range is specifically calibrated (e.g., ALL for universal, or specific population codes per CDISC). Null or ALL indicates the range applies universally regardless of ethnicity.' ;
    rdfs:domain ind:ReferenceRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentCode rdf:type rdf:Property ;
    rdfs:label 'Instrument Code' ;
    rdfs:comment 'Identifier of the specific laboratory instrument or analyzer for which this reference range was established. Instrument-specific ranges are required when different analyzers produce systematically different results.' ;
    rdfs:domain ind:ReferenceRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowerLimit rdf:type rdf:Property ;
    rdfs:label 'Lower Limit' ;
    rdfs:comment 'The lower boundary of the normal reference range for the analyte. Values below this threshold are flagged as abnormally low. Corresponds to LBORNRLO in CDISC SDTM.' ;
    rdfs:domain ind:ReferenceRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:methodCode rdf:type rdf:Property ;
    rdfs:label 'Method Code' ;
    rdfs:comment 'Code identifying the analytical method or instrument platform used to generate results evaluated against this reference range (e.g., colorimetric, immunoassay, HPLC). Reference ranges may differ by method.' ;
    rdfs:domain ind:ReferenceRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorLowerLimit rdf:type rdf:Property ;
    rdfs:label 'Prior Lower Limit' ;
    rdfs:comment 'The lower normal limit value from the immediately preceding version of this reference range. Retained for audit trail and regulatory inspection readiness per GCP requirements.' ;
    rdfs:domain ind:ReferenceRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorUpperLimit rdf:type rdf:Property ;
    rdfs:label 'Prior Upper Limit' ;
    rdfs:comment 'The upper normal limit value from the immediately preceding version of this reference range. Retained for audit trail and regulatory inspection readiness per GCP requirements.' ;
    rdfs:domain ind:ReferenceRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rangeSource rdf:type rdf:Property ;
    rdfs:label 'Range Source' ;
    rdfs:comment 'Indicates whether this reference range is sponsor-defined (provided by the clinical trial sponsor), lab-standard (established by the laboratory facility), derived from a regulatory guideline, or from published literature.' ;
    rdfs:domain ind:ReferenceRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reagentLotNumber rdf:type rdf:Property ;
    rdfs:label 'Reagent Lot Number' ;
    rdfs:comment 'Lot number of the reagent kit or calibrator associated with this reference range version. Captured when a reagent lot change triggers a reference range update per laboratory SOPs.' ;
    rdfs:domain ind:ReferenceRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperLimit rdf:type rdf:Property ;
    rdfs:label 'Upper Limit' ;
    rdfs:comment 'The upper boundary of the normal reference range for the analyte. Values above this threshold are flagged as abnormally high. Corresponds to LBORNRHI in CDISC SDTM.' ;
    rdfs:domain ind:ReferenceRange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentSpecimenId rdf:type rdf:Property ;
    rdfs:label 'Parent Specimen Id' ;
    rdfs:comment 'Reference to the parent specimen from which this aliquot was derived. Null for primary specimens. Enables full chain-of-custody traceability from primary collection through all downstream aliquots.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specimen .

ind:actualTimepointHours rdf:type rdf:Property ;
    rdfs:label 'Actual Timepoint Hours' ;
    rdfs:comment 'Actual elapsed time in hours from the reference event (e.g., dose administration) to specimen collection. Critical for pharmacokinetic (PK) and pharmacodynamic (PD) analysis and nominal time deviation assessment.' ;
    rdfs:domain ind:Specimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aliquotSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Aliquot Sequence Number' ;
    rdfs:comment 'Sequential number identifying the order of this aliquot within the set of aliquots derived from the same parent specimen (e.g., 1, 2, 3). Null for primary specimens. Used for aliquot management and laboratory workflow.' ;
    rdfs:domain ind:Specimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:barcode rdf:type rdf:Property ;
    rdfs:label 'Barcode' ;
    rdfs:comment 'Unique barcode or label identifier affixed to the specimen container at the point of collection. Used for physical tracking and LIMS accession matching. Serves as the primary operational identifier in the laboratory.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainOfCustodyStatus rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Status' ;
    rdfs:comment 'Current status of the specimen\'s chain of custody documentation. \'Intact\' indicates unbroken custody from collection to current location; \'broken\' indicates a gap requiring investigation. Critical for regulatory and legal defensibility of specimen data.' ;
    rdfs:domain ind:Specimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionBodySite rdf:type rdf:Property ;
    rdfs:label 'Collection Body Site' ;
    rdfs:comment 'Anatomical body location from which the specimen was collected (e.g., left antecubital vein, right arm, lumbar region). Required for specimens where site of collection affects result interpretation.' ;
    rdfs:domain ind:Specimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionDeviationDescription rdf:type rdf:Property ;
    rdfs:label 'Collection Deviation Description' ;
    rdfs:comment 'Free-text description of the collection deviation when collection_deviation_flag is True (e.g., incorrect tube used, delayed processing, missed time window). Supports protocol deviation reporting and CAPA.' ;
    rdfs:domain ind:Specimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Collection Deviation Flag' ;
    rdfs:comment 'Indicates whether a protocol deviation occurred during specimen collection (True) or not (False). Triggers deviation documentation workflow and may affect specimen usability for primary analysis.' ;
    rdfs:domain ind:Specimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionKitLotNumber rdf:type rdf:Property ;
    rdfs:label 'Collection Kit Lot Number' ;
    rdfs:comment 'Lot number of the collection kit used for specimen collection. Required for traceability of kit materials, deviation investigation, and supply chain accountability.' ;
    rdfs:domain ind:Specimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionOnArrival rdf:type rdf:Property ;
    rdfs:label 'Condition On Arrival' ;
    rdfs:comment 'Assessment of the specimen\'s physical condition upon receipt at the laboratory (e.g., acceptable, hemolyzed, lipemic, temperature excursion). Determines whether the specimen is suitable for analysis or requires rejection/re-collection. [ENUM-REF-CANDIDATE: acceptable|hemolyzed|lipemic|icteric|insufficient_volume|temperature_excursion|damaged|other — promote to reference product]' ;
    rdfs:domain ind:Specimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionStatus rdf:type rdf:Property ;
    rdfs:label 'Disposition Status' ;
    rdfs:comment 'Current lifecycle status of the specimen within the laboratory workflow. Drives operational actions and regulatory accountability. [ENUM-REF-CANDIDATE: pending_receipt|received|in_analysis|analyzed|stored|shipped|destroyed|rejected|lost — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Indicates whether this specimen record represents the primary (original) specimen (True) or an aliquot derived from a parent specimen (False). Drives chain-of-custody logic and parent-child specimen relationships.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limsAccessionNumber rdf:type rdf:Property ;
    rdfs:label 'Lims Accession Number' ;
    rdfs:comment 'Accession number assigned by the Laboratory Information Management System (LIMS) upon receipt of the specimen at the central or local laboratory. Used for laboratory workflow tracking and result linkage.' ;
    rdfs:domain ind:Specimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preAnalyticalProcessing rdf:type rdf:Property ;
    rdfs:label 'Pre Analytical Processing' ;
    rdfs:comment 'Description of pre-analytical processing steps performed on the specimen prior to analysis or storage (e.g., centrifugation speed/duration, temperature, time to processing). Critical for result interpretation and protocol compliance.' ;
    rdfs:domain ind:Specimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingDatetime rdf:type rdf:Property ;
    rdfs:label 'Processing Datetime' ;
    rdfs:comment 'Date and time at which pre-analytical processing of the specimen was completed. Used to calculate time-from-collection-to-processing, a key pre-analytical quality metric per laboratory manual requirements.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receiptDatetime rdf:type rdf:Property ;
    rdfs:label 'Receipt Datetime' ;
    rdfs:comment 'Date and time at which the specimen was received at the central or local laboratory. Used to calculate transit time, assess cold-chain compliance, and trigger LIMS accession workflows.' ;
    rdfs:domain ind:Specimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Physical storage location of the specimen within the laboratory or biorepository (e.g., freezer ID, rack, box, position). Required for specimen retrieval, inventory management, and chain-of-custody documentation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenAliquotId rdf:type rdf:Property ;
    rdfs:label 'Specimen Aliquot Id' ;
    rdfs:comment 'Unique surrogate identifier for the specimen aliquot record in the lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:SpecimenAliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aliquotCode rdf:type rdf:Property ;
    rdfs:label 'Aliquot Code' ;
    rdfs:comment 'Human-readable, externally-known unique barcode or label identifier assigned to this aliquot at the time of processing. Used for physical tracking and chain of custody.' ;
    rdfs:domain ind:SpecimenAliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aliquotPurpose rdf:type rdf:Property ;
    rdfs:label 'Aliquot Purpose' ;
    rdfs:comment 'Designated analytical or storage purpose for this aliquot. Drives routing to the appropriate laboratory or storage tier. [ENUM-REF-CANDIDATE: clinical_testing|pk_analysis|biomarker|backup|archive|exploratory — promote to reference product if additional purposes are added]' ;
    rdfs:domain ind:SpecimenAliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aliquotSeqNum rdf:type rdf:Property ;
    rdfs:label 'Aliquot Seq Num' ;
    rdfs:comment 'Sequential integer identifying the order in which this aliquot was derived from the parent specimen (e.g., 1, 2, 3). Supports multi-aliquot tracking per specimen.' ;
    rdfs:domain ind:SpecimenAliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aliquotStatus rdf:type rdf:Property ;
    rdfs:label 'Aliquot Status' ;
    rdfs:comment 'Current lifecycle status of the aliquot. Drives chain of custody accountability and biorepository management workflows. [ENUM-REF-CANDIDATE: pending|in_storage|in_transit|in_testing|consumed|destroyed|lost — promote to reference product]' ;
    rdfs:domain ind:SpecimenAliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blindedFlag rdf:type rdf:Property ;
    rdfs:label 'Blinded Flag' ;
    rdfs:comment 'Indicates whether this aliquot is subject to study blinding (i.e., treatment assignment is masked). Governs access controls and prevents unblinding during active study phases.' ;
    rdfs:domain ind:SpecimenAliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:boxCode rdf:type rdf:Property ;
    rdfs:label 'Box Code' ;
    rdfs:comment 'Identifier of the box or tray within the rack where this aliquot is placed. Part of the three-dimensional storage coordinate system.' ;
    rdfs:domain ind:SpecimenAliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainOfCustodyFlag rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Flag' ;
    rdfs:comment 'Indicates whether a complete, unbroken chain of custody record exists for this aliquot from collection through current status. A value of False triggers a compliance review.' ;
    rdfs:domain ind:SpecimenAliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destructionReason rdf:type rdf:Property ;
    rdfs:label 'Destruction Reason' ;
    rdfs:comment 'Reason for aliquot destruction or discard. Required for regulatory accountability and chain of custody documentation. [ENUM-REF-CANDIDATE: stability_expired|volume_insufficient|testing_complete|sponsor_request|protocol_deviation|lost|contaminated — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freezeThawCount rdf:type rdf:Property ;
    rdfs:label 'Freeze Thaw Count' ;
    rdfs:comment 'Cumulative number of freeze-thaw cycles this aliquot has undergone. Exceeding the validated limit may compromise analyte integrity and render the aliquot unsuitable for testing.' ;
    rdfs:domain ind:SpecimenAliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxFreezeThawAllowed rdf:type rdf:Property ;
    rdfs:label 'Max Freeze Thaw Allowed' ;
    rdfs:comment 'Validated maximum number of freeze-thaw cycles permitted for this aliquot type before analyte stability is compromised. Defined in the bioanalytical method validation plan.' ;
    rdfs:domain ind:SpecimenAliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:positionCode rdf:type rdf:Property ;
    rdfs:label 'Position Code' ;
    rdfs:comment 'Alphanumeric position coordinate within the box (e.g., A1, B12, H08) identifying the exact slot where the aliquot is stored. Enables precise physical retrieval.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolNum rdf:type rdf:Property ;
    rdfs:label 'Protocol Num' ;
    rdfs:comment 'Sponsor-assigned protocol number for the clinical study. Denormalized for direct regulatory reporting and specimen labeling without requiring a study join.' ;
    rdfs:domain ind:SpecimenAliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rackCode rdf:type rdf:Property ;
    rdfs:label 'Rack Code' ;
    rdfs:comment 'Identifier of the rack within the storage unit where this aliquot is placed. Part of the three-dimensional storage coordinate system (rack/box/position).' ;
    rdfs:domain ind:SpecimenAliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Stability Expiry Date' ;
    rdfs:comment 'Date beyond which the aliquot is considered analytically unstable based on validated long-term stability data. Triggers discard or re-evaluation workflows.' ;
    rdfs:domain ind:SpecimenAliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storageUnitCode rdf:type rdf:Property ;
    rdfs:label 'Storage Unit Code' ;
    rdfs:comment 'Reference to the physical storage unit (freezer, refrigerator, liquid nitrogen tank) where this aliquot is currently placed. Supports biorepository location management.' ;
    rdfs:domain ind:SpecimenAliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageUnitType rdf:type rdf:Property ;
    rdfs:label 'Storage Unit Type' ;
    rdfs:comment 'Classification of the storage unit housing this aliquot (e.g., -80°C freezer, -20°C freezer, refrigerator, liquid nitrogen vapor phase). Determines stability expectations. [ENUM-REF-CANDIDATE: freezer|-80_freezer|-20_freezer|refrigerator|ln2_vapor|ln2_liquid|ambient — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SpecimenAliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureExcursionFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Excursion Flag' ;
    rdfs:comment 'Indicates whether this aliquot has experienced a documented temperature excursion outside the validated storage range. Triggers stability impact assessment.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeMl rdf:type rdf:Property ;
    rdfs:label 'Volume Ml' ;
    rdfs:comment 'Volume of the aliquot in millilitres at the time of processing. Used for sufficiency assessment and inventory management.' ;
    rdfs:domain ind:SpecimenAliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeSufficientFlag rdf:type rdf:Property ;
    rdfs:label 'Volume Sufficient Flag' ;
    rdfs:comment 'Indicates whether the remaining aliquot volume is sufficient to complete the assigned assay or testing requirement. Drives re-collection or backup aliquot retrieval workflows.' ;
    rdfs:domain ind:SpecimenAliquot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Unit' ;
    rdfs:comment 'Unit of measure for the aliquot volume. Typically mL for liquid specimens; mg or g for tissue aliquots.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainOfCustodyNumber rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Number' ;
    rdfs:comment 'Unique tracking number assigned to document the chain of custody for the specimen from collection through laboratory receipt. Ensures specimen integrity and traceability for regulatory and legal purposes.' ;
    rdfs:domain ind:SpecimenCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionNumber rdf:type rdf:Property ;
    rdfs:label 'Collection Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for this specimen collection event, typically generated by the EDC or CTMS (e.g., \'SC-0042-001\'). Used for cross-system traceability and chain-of-custody documentation.' ;
    rdfs:domain ind:SpecimenCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionSiteAnatomy rdf:type rdf:Property ;
    rdfs:label 'Collection Site Anatomy' ;
    rdfs:comment 'The anatomical location on the subject\'s body from which the specimen was collected (e.g., \'Left Antecubital Vein\', \'Right Arm\', \'Lumbar Region\'). Corresponds to CDISC SDTM LBLOC.' ;
    rdfs:domain ind:SpecimenCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionStatus rdf:type rdf:Property ;
    rdfs:label 'Collection Status' ;
    rdfs:comment 'Current lifecycle status of the specimen collection event. Indicates whether the collection was completed as planned, partially completed, missed, or cancelled. [ENUM-REF-CANDIDATE: scheduled|collected|missed|cancelled|partial|failed — promote to reference product if additional statuses are needed]' ;
    rdfs:domain ind:SpecimenCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectorName rdf:type rdf:Property ;
    rdfs:label 'Collector Name' ;
    rdfs:comment 'Full name of the CRC or phlebotomist who performed the specimen collection. Denormalized for audit trail and regulatory inspection readiness. Classified as confidential as it identifies site personnel.' ;
    rdfs:domain ind:SpecimenCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasDeviation rdf:type rdf:Property ;
    rdfs:label 'Has Deviation' ;
    rdfs:comment 'Indicates whether a protocol deviation or collection irregularity was recorded for this specimen collection event. True = deviation present; False = no deviation. Triggers downstream deviation management workflow.' ;
    rdfs:domain ind:SpecimenCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hemolysisGrade rdf:type rdf:Property ;
    rdfs:label 'Hemolysis Grade' ;
    rdfs:comment 'Visual or instrument-assessed grade of hemolysis (red blood cell rupture) in the collected blood specimen. Hemolysis can interfere with laboratory assay results and may require recollection.' ;
    rdfs:domain ind:SpecimenCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isUnscheduled rdf:type rdf:Property ;
    rdfs:label 'Is Unscheduled' ;
    rdfs:comment 'Indicates whether this specimen collection was an unscheduled (ad hoc) event not defined in the original study protocol visit schedule. True = unscheduled; False = protocol-scheduled.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lipemiaGrade rdf:type rdf:Property ;
    rdfs:label 'Lipemia Grade' ;
    rdfs:comment 'Visual or instrument-assessed grade of lipemia (excess lipids causing turbidity) in the collected specimen. Lipemia can interfere with photometric assay results.' ;
    rdfs:domain ind:SpecimenCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preAnalyticalInstructions rdf:type rdf:Property ;
    rdfs:label 'Pre Analytical Instructions' ;
    rdfs:comment 'Free-text or coded description of the pre-analytical processing instructions followed after collection (e.g., \'Centrifuge within 30 min at 2000 rpm\', \'Store at -80°C\', \'Protect from light\'). Documents protocol compliance for sample integrity.' ;
    rdfs:domain ind:SpecimenCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing Completed Timestamp' ;
    rdfs:comment 'Date and time at which pre-analytical processing of the specimen was completed at the collection site (e.g., centrifugation, aliquoting). Used to calculate processing turnaround time and assess sample integrity.' ;
    rdfs:domain ind:SpecimenCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recollectionReason rdf:type rdf:Property ;
    rdfs:label 'Recollection Reason' ;
    rdfs:comment 'Reason why a repeat specimen collection is required. Populated when recollection_required = True. [ENUM-REF-CANDIDATE: insufficient_volume|hemolysis|lipemia|clotted|mislabeled|lost_in_transit|expired_kit|other — promote to reference product]' ;
    rdfs:domain ind:SpecimenCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recollectionRequired rdf:type rdf:Property ;
    rdfs:label 'Recollection Required' ;
    rdfs:comment 'Indicates whether a repeat specimen collection is required due to inadequate sample, collection deviation, or laboratory rejection. True = recollection needed; False = no recollection required.' ;
    rdfs:domain ind:SpecimenCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleAdequacy rdf:type rdf:Property ;
    rdfs:label 'Sample Adequacy' ;
    rdfs:comment 'Assessment of whether the collected specimen volume and quality are sufficient to perform all protocol-required laboratory analyses. Determined at the time of collection or upon receipt at the laboratory.' ;
    rdfs:domain ind:SpecimenCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledCollectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Collection Timestamp' ;
    rdfs:comment 'The protocol-defined date and time at which the specimen collection was planned to occur per the study visit schedule. Used to calculate collection timing deviations.' ;
    rdfs:domain ind:SpecimenCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:timeFromDoseHours rdf:type rdf:Property ;
    rdfs:label 'Time From Dose Hours' ;
    rdfs:comment 'Elapsed time in hours between the subject\'s most recent investigational product dose and the specimen collection. Critical for PK (Pharmacokinetics) and DMPK (Drug Metabolism and Pharmacokinetics) sample timing analysis.' ;
    rdfs:domain ind:SpecimenCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manifestId rdf:type rdf:Property ;
    rdfs:label 'Manifest Id' ;
    rdfs:comment 'Externally assigned manifest identifier accompanying the shipment package, used to reconcile specimens at the receiving laboratory. Typically generated by the CTMS or laboratory information system.' ;
    rdfs:domain ind:SpecimenShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShipmentManifest .

ind:actualReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Date' ;
    rdfs:comment 'Date and time at which the receiving laboratory confirmed physical receipt of the shipment. Used to calculate transit duration and assess specimen integrity against stability windows.' ;
    rdfs:domain ind:SpecimenShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:airbillNumber rdf:type rdf:Property ;
    rdfs:label 'Airbill Number' ;
    rdfs:comment 'Air waybill or bill of lading number issued by the carrier for international or air freight shipments. Required for customs clearance and IATA dangerous goods documentation.' ;
    rdfs:domain ind:SpecimenShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionDate rdf:type rdf:Property ;
    rdfs:label 'Collection Date' ;
    rdfs:comment 'Date on which the specimens included in this shipment were collected from study subjects. Used to calculate specimen age at receipt and assess stability compliance.' ;
    rdfs:domain ind:SpecimenShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:courierName rdf:type rdf:Property ;
    rdfs:label 'Courier Name' ;
    rdfs:comment 'Name of the logistics carrier or courier service responsible for transporting the shipment (e.g., World Courier, FedEx Clinical, Marken). Supports vendor performance tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courierServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Courier Service Level' ;
    rdfs:comment 'Service tier selected for the shipment (e.g., overnight, two-day, international priority). Determines expected transit time and cost classification.' ;
    rdfs:domain ind:SpecimenShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsDeclarationNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Number' ;
    rdfs:comment 'Reference number of the customs or import/export declaration filed for international specimen shipments. Required for cross-border regulatory compliance and specimen release at destination.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLabCode rdf:type rdf:Property ;
    rdfs:label 'Destination Lab Code' ;
    rdfs:comment 'Alphanumeric code identifying the receiving central or reference laboratory. Denormalized for manifest documentation and rapid chain-of-custody reporting.' ;
    rdfs:domain ind:SpecimenShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dryIceWeightKg rdf:type rdf:Property ;
    rdfs:label 'Dry Ice Weight Kg' ;
    rdfs:comment 'Weight of dry ice (in kilograms) included in the shipment package. Required for IATA dangerous goods declaration when dry ice is used as a refrigerant. Applicable only when temperature_condition = dry_ice.' ;
    rdfs:domain ind:SpecimenShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excursionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Excursion Duration Minutes' ;
    rdfs:comment 'Total duration in minutes during which the shipment temperature was outside the acceptable range. Used by the laboratory to assess specimen viability and document deviation impact.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:excursionMaxTempC rdf:type rdf:Property ;
    rdfs:label 'Excursion Max Temp C' ;
    rdfs:comment 'Highest temperature (in degrees Celsius) recorded by the temperature monitor/data logger during transit. Populated only when a temperature excursion is detected. Supports specimen impact assessment.' ;
    rdfs:domain ind:SpecimenShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excursionMinTempC rdf:type rdf:Property ;
    rdfs:label 'Excursion Min Temp C' ;
    rdfs:comment 'Lowest temperature (in degrees Celsius) recorded by the temperature monitor/data logger during transit. Populated only when a temperature excursion is detected. Supports specimen impact assessment.' ;
    rdfs:domain ind:SpecimenShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Expected Arrival Date' ;
    rdfs:comment 'Planned date on which the shipment is expected to arrive at the destination laboratory, as agreed with the courier at time of dispatch. Used to trigger overdue alerts.' ;
    rdfs:domain ind:SpecimenShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hazardousMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Flag' ;
    rdfs:comment 'Indicates whether the shipment contains materials classified as hazardous (e.g., Category B biological substances, dry ice). True = hazardous declaration required; False = non-hazardous. Drives IATA dangerous goods documentation requirements.' ;
    rdfs:domain ind:SpecimenShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:importPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Import Permit Number' ;
    rdfs:comment 'Regulatory import permit or authorization number required for cross-border shipment of biological specimens in certain jurisdictions. Ensures compliance with national biosafety and import regulations.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labContactName rdf:type rdf:Property ;
    rdfs:label 'Lab Contact Name' ;
    rdfs:comment 'Name of the designated contact person at the receiving laboratory responsible for accepting and processing the shipment. Used for courier delivery confirmation and discrepancy resolution.' ;
    rdfs:domain ind:SpecimenShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originSiteNumber rdf:type rdf:Property ;
    rdfs:label 'Origin Site Number' ;
    rdfs:comment 'Sponsor-assigned or regulatory site number of the clinical site dispatching the specimens. Denormalized for chain-of-custody documentation and regulatory audit trail without requiring a join.' ;
    rdfs:domain ind:SpecimenShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingType rdf:type rdf:Property ;
    rdfs:label 'Packaging Type' ;
    rdfs:comment 'Type of packaging used for the shipment, indicating the thermal protection and containment method. Relevant for regulatory compliance with IATA P650 and specimen integrity documentation.' ;
    rdfs:domain ind:SpecimenShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolVisitName rdf:type rdf:Property ;
    rdfs:label 'Protocol Visit Name' ;
    rdfs:comment 'Name or label of the study protocol visit (e.g., Day 1, Week 4, End of Treatment) associated with the specimen collection event. Supports SDTM domain mapping and visit-level reconciliation.' ;
    rdfs:domain ind:SpecimenShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptConfirmedBy rdf:type rdf:Property ;
    rdfs:label 'Receipt Confirmed By' ;
    rdfs:comment 'Name or user identifier of the laboratory staff member who confirmed receipt of the shipment. Part of the chain-of-custody audit trail per ALCOA+ principles.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedSpecimenCount rdf:type rdf:Property ;
    rdfs:label 'Received Specimen Count' ;
    rdfs:comment 'Actual number of specimens confirmed by the receiving laboratory upon opening the shipment. Compared against specimen_count to identify discrepancies or missing specimens.' ;
    rdfs:domain ind:SpecimenShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shipmentDate rdf:type rdf:Property ;
    rdfs:label 'Shipment Date' ;
    rdfs:comment 'Date and time at which the shipment was handed over to the courier at the originating clinical site. Principal business event timestamp for this transaction. Recorded in ISO 8601 format with timezone offset.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle state of the specimen shipment. Drives chain-of-custody workflow and exception management. Values: pending (prepared, not yet dispatched), in_transit (with courier), delivered (courier confirmed delivery), received (lab confirmed receipt), rejected (refused at destination), cancelled (shipment voided).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentType rdf:type rdf:Property ;
    rdfs:label 'Shipment Type' ;
    rdfs:comment 'Classification of the shipment by its clinical purpose. Values: routine (standard scheduled collection), urgent (expedited for safety or protocol reasons), pk_sample (Pharmacokinetics samples requiring strict timing), biomarker (exploratory biomarker specimens), backup (duplicate aliquots for archival), reshipment (replacement for a failed prior shipment).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenCount rdf:type rdf:Property ;
    rdfs:label 'Specimen Count' ;
    rdfs:comment 'Total number of individual specimen tubes, aliquots, or containers included in this shipment as declared on the manifest. Used for reconciliation at receipt.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureCondition rdf:type rdf:Property ;
    rdfs:label 'Temperature Condition' ;
    rdfs:comment 'Required temperature storage and transport condition for the shipment as specified in the laboratory manual. Critical for specimen integrity. Values: ambient (15–25°C), refrigerated (2–8°C), frozen (-20°C), dry_ice (-78°C), liquid_nitrogen (-196°C).' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Max C' ;
    rdfs:comment 'Upper bound of the acceptable temperature range (in degrees Celsius) for this shipment as defined in the study laboratory manual. Used to evaluate temperature excursion severity.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Min C' ;
    rdfs:comment 'Lower bound of the acceptable temperature range (in degrees Celsius) for this shipment as defined in the study laboratory manual. Used to evaluate temperature excursion severity.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMonitorCode rdf:type rdf:Property ;
    rdfs:label 'Temperature Monitor Code' ;
    rdfs:comment 'Serial number or identifier of the temperature data logger or indicator device placed in the shipment. Enables retrieval of the full temperature log for excursion investigation and regulatory documentation.' ;
    rdfs:domain ind:SpecimenShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMonitorType rdf:type rdf:Property ;
    rdfs:label 'Temperature Monitor Type' ;
    rdfs:comment 'Type of temperature monitoring device included in the shipment. Data_logger provides continuous electronic recording; indicator_card provides a visual pass/fail indicator; none indicates no monitoring device was used.' ;
    rdfs:domain ind:SpecimenShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Carrier-assigned tracking number for the shipment package, enabling real-time logistics monitoring and proof-of-delivery confirmation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unNumber rdf:type rdf:Property ;
    rdfs:label 'Un Number' ;
    rdfs:comment 'United Nations dangerous goods classification number for the shipment contents (e.g., UN3373 for Category B biological substances, UN1845 for dry ice). Required on shipping labels and documentation when hazardous_material_flag is True.' ;
    rdfs:domain ind:SpecimenShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringActionItemId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Action Item Id' ;
    rdfs:comment 'Unique surrogate identifier for the action item record in the Databricks Silver Layer. Primary key generated by the lakehouse ingestion pipeline from Oracle Siebel CTMS.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MonitoringActionItem .

ind:centralMonitoringAlertId rdf:type rdf:Property ;
    rdfs:label 'Central Monitoring Alert Id' ;
    rdfs:comment 'Foreign key linking to monitoring.central_monitoring_alert. Business justification: A monitoring action item can be raised as a direct result of a central monitoring alert (e.g., KRI breach requiring site-level follow-up action). The monitoring_action_item.source_type field already s' ;
    rdfs:domain ind:Monitoring ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CentralMonitoringAlert .

ind:parentActionItemMonitoringActionItemId rdf:type rdf:Property ;
    rdfs:label 'Parent Action Item Monitoring Action Item Id' ;
    rdfs:comment 'Self-referencing identifier linking this action item to a parent action item when it was created as a sub-task or follow-up from a prior finding. Supports hierarchical action item tracking and recurrence analysis.' ;
    rdfs:domain ind:MonitoringActionItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MonitoringActionItem .

ind:primaryMonitoringEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Monitoring Employee Id' ;
    rdfs:comment 'Reference to the responsible party (site staff, CRA, or sponsor representative) accountable for resolving this action item. Drives automated escalation workflows in Oracle Siebel CTMS for overdue items.' ;
    rdfs:domain ind:MonitoringActionItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryMonitoringEscalatedToUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Monitoring Escalated To User Employee Id' ;
    rdfs:comment 'Reference to the senior stakeholder (e.g., sponsor medical monitor, CRA line manager, regulatory affairs lead) to whom the action item was escalated. Null if not escalated.' ;
    rdfs:domain ind:MonitoringActionItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryMonitoringClosureConfirmedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Monitoring Closure Confirmed By User Employee Id' ;
    rdfs:comment 'Reference to the CRA, monitor, or sponsor representative who reviewed the closure evidence and formally confirmed the action item as resolved. Supports electronic signature audit trail per 21 CFR Part 11.' ;
    rdfs:domain ind:MonitoringActionItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'The calendar date on which the action item was formally closed following verification of corrective action completion and evidence review. Null for open or in-progress items.' ;
    rdfs:domain ind:Monitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closureEvidenceDescription rdf:type rdf:Property ;
    rdfs:label 'Closure Evidence Description' ;
    rdfs:comment 'Narrative description of the evidence provided to confirm resolution of the action item (e.g., updated SOP reference, re-training record, corrected eCRF entry, SDV confirmation). Required for GCP-compliant closure documentation.' ;
    rdfs:domain ind:MonitoringActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureEvidenceDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Closure Evidence Document Ref' ;
    rdfs:comment 'Reference identifier or URL to the supporting document stored in Veeva Vault eTMF that substantiates the closure of this action item (e.g., training certificate, corrected source document scan, updated SOP version).' ;
    rdfs:domain ind:MonitoringActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsRecordReference rdf:type rdf:Property ;
    rdfs:label 'Ctms Record Reference' ;
    rdfs:comment 'Native record identifier from Oracle Siebel CTMS for this action item. Preserved in the Silver Layer to enable bidirectional traceability between the lakehouse and the operational system of record.' ;
    rdfs:domain ind:MonitoringActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedDueDate rdf:type rdf:Property ;
    rdfs:label 'Extended Due Date' ;
    rdfs:comment 'Revised due date granted after a formal extension request and approval. Null if no extension has been granted. Tracks due date changes for audit trail and SLA compliance reporting.' ;
    rdfs:domain ind:MonitoringActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gcpReference rdf:type rdf:Property ;
    rdfs:label 'Gcp Reference' ;
    rdfs:comment 'Specific GCP guideline section, regulatory citation, or SOP reference that the finding violates or that governs the required corrective action (e.g., ICH E6(R2) Section 4.9.0, FDA 21 CFR 312.62). Supports regulatory inspection documentation.' ;
    rdfs:domain ind:Monitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringActionItemCategory rdf:type rdf:Property ;
    rdfs:label 'Monitoring Action Item Category' ;
    rdfs:comment 'Business classification of the action item by the type of finding or compliance gap it addresses. Drives routing logic, escalation thresholds, and regulatory reporting groupings in Oracle Siebel CTMS. [ENUM-REF-CANDIDATE: protocol_deviation|sdv_finding|regulatory_compliance|safety_reporting|data_quality|consent|supply_chain|training — promote to reference product]' ;
    rdfs:domain ind:MonitoringActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringActionItemDescription rdf:type rdf:Property ;
    rdfs:label 'Monitoring Action Item Description' ;
    rdfs:comment 'Full narrative description of the monitoring finding, protocol deviation, or compliance gap that necessitated this action item. Includes observed facts, regulatory reference, and expected corrective action per GCP documentation standards (ALCOA+).' ;
    rdfs:domain ind:MonitoringActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringActionItemStatus rdf:type rdf:Property ;
    rdfs:label 'Monitoring Action Item Status' ;
    rdfs:comment 'Current workflow state of the action item lifecycle in Oracle Siebel CTMS. Overdue status is set automatically when the due date passes without closure. Closed status requires documented evidence of resolution.' ;
    rdfs:domain ind:MonitoringActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringVisitType rdf:type rdf:Property ;
    rdfs:label 'Monitoring Visit Type' ;
    rdfs:comment 'Type of monitoring visit during which the action item was identified. Denormalized from the monitoring visit record for reporting efficiency. Supports analysis of finding patterns by visit type (e.g., higher deviation rates at initiation visits).' ;
    rdfs:domain ind:MonitoringActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raisedDate rdf:type rdf:Property ;
    rdfs:label 'Raised Date' ;
    rdfs:comment 'The calendar date on which the action item was formally raised and entered into Oracle Siebel CTMS. Serves as the principal business event date for SLA calculation, aging analysis, and regulatory inspection timelines.' ;
    rdfs:domain ind:MonitoringActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseDate rdf:type rdf:Property ;
    rdfs:label 'Response Date' ;
    rdfs:comment 'Date on which the site formally submitted their response to the action item. Used to measure site responsiveness KPIs and to determine whether the response was received within the required timeframe.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsiblePartyRole rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Role' ;
    rdfs:comment 'Functional role category of the party accountable for resolving the action item. Distinguishes between site staff (PI, CRC), CRA, sponsor, or functional team (data management, safety). Used for workload distribution and escalation routing. [ENUM-REF-CANDIDATE: site_staff|cra|sponsor|pi|crc|data_management|safety — promote to reference product]' ;
    rdfs:domain ind:MonitoringActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorAlertCentralMonitoringAlertId rdf:type rdf:Property ;
    rdfs:label 'Prior Alert Central Monitoring Alert Id' ;
    rdfs:comment 'Reference to the most recent prior central_monitoring_alert record for the same KRI and site, enabling trend analysis and repeat breach tracking. Null when is_repeat_alert is False.' ;
    rdfs:domain ind:CentralMonitoringAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CentralMonitoringAlert .

ind:randDeviationId rdf:type rdf:Property ;
    rdfs:label 'Rand Deviation Id' ;
    rdfs:comment 'Foreign key linking to randomization.rand_deviation. Business justification: Centralized monitoring of randomization KRIs (allocation imbalance, IRT error rates, unexpected arm distribution) generates central_monitoring_alerts that must be traceable to specific rand_deviation ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RandDeviation .

ind:riskIndicatorId rdf:type rdf:Property ;
    rdfs:label 'Risk Indicator Id' ;
    rdfs:comment 'Reference to the specific Key Risk Indicator (KRI) or centralized statistical monitoring (CSM) signal that triggered this alert. Null when the alert is manually triggered without a specific KRI linkage.' ;
    rdfs:domain ind:Monitoring ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskIndicator .

ind:alertCategory rdf:type rdf:Property ;
    rdfs:label 'Alert Category' ;
    rdfs:comment 'Broad business domain category of the alert, used for routing, reporting, and escalation prioritization. DATA_QUALITY: data entry or consistency issues. SAFETY: adverse event or safety reporting concerns. ENROLLMENT: subject recruitment or screen failure anomalies. PROTOCOL_COMPLIANCE: protocol deviation patterns. REGULATORY: regulatory document or submission concerns. OPERATIONAL: site operational performance issues.' ;
    rdfs:domain ind:CentralMonitoringAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertGeneratedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Alert Generated Timestamp' ;
    rdfs:comment 'Date and time when the alert was generated by the centralized statistical monitoring (CSM) system or manually created by a central monitor. This is the principal real-world business event time. BUSINESS_EVENT_TIMESTAMP category.' ;
    rdfs:domain ind:CentralMonitoringAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:alertNumber rdf:type rdf:Property ;
    rdfs:label 'Alert Number' ;
    rdfs:comment 'Human-readable, externally-known business identifier for the alert, formatted as CMA-{YYYY}-{NNNNNN}. Used in communications, reports, and audit trails to uniquely reference an alert across systems. Sourced from Oracle Siebel CTMS. BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:CentralMonitoringAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertSeverity rdf:type rdf:Property ;
    rdfs:label 'Alert Severity' ;
    rdfs:comment 'Risk-stratified severity level of the alert, driving escalation urgency and response timelines. CRITICAL: immediate action required, potential patient safety or data integrity risk. HIGH: significant risk requiring prompt review within defined SLA. MEDIUM: moderate risk requiring scheduled review. LOW: informational, monitor for trend.' ;
    rdfs:domain ind:CentralMonitoringAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertStatus rdf:type rdf:Property ;
    rdfs:label 'Alert Status' ;
    rdfs:comment 'Current lifecycle state of the alert within the review and disposition workflow. OPEN: generated and awaiting assignment. UNDER_REVIEW: assigned reviewer is actively assessing. ESCALATED: elevated to on-site visit or senior oversight. CLOSED: reviewed and dispositioned. CANCELLED: determined to be erroneous or duplicate. LIFECYCLE_STATUS category.' ;
    rdfs:domain ind:Monitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertType rdf:type rdf:Property ;
    rdfs:label 'Alert Type' ;
    rdfs:comment 'Classification of the alert by the nature of the triggering condition. KRI_THRESHOLD_BREACH: a Key Risk Indicator exceeded its amber or red threshold. DATA_ANOMALY: a data pattern inconsistency detected by the centralized statistical monitoring (CSM) system. STATISTICAL_OUTLIER: site-level metric is a statistical outlier relative to the study population. MANUAL: alert raised by a central monitor without an automated trigger. ENROLLMENT_SIGNAL: enrollment rate deviation. SAFETY_SIGNAL: potential safety concern flagged centrally. CLASSIFICATION_OR_TYPE category.' ;
    rdfs:domain ind:CentralMonitoringAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'Date on which the alert was assigned to a reviewer for investigation. Used to measure assignment SLA compliance from alert generation to assignment.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consecutiveBreachCount rdf:type rdf:Property ;
    rdfs:label 'Consecutive Breach Count' ;
    rdfs:comment 'Number of consecutive computation cycles in which the triggering KRI has breached its threshold at this site prior to and including this alert. A higher count indicates a persistent risk pattern and informs escalation urgency.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disposition rdf:type rdf:Property ;
    rdfs:label 'Disposition' ;
    rdfs:comment 'Action decision made following review of the alert. ESCALATE_ONSITE_VISIT: alert severity warrants an unscheduled or triggered on-site monitoring visit. REMOTE_FOLLOW_UP: issue to be addressed via remote monitoring or site communication. NO_ACTION_REQUIRED: alert reviewed and no further action needed. CAPA_INITIATED: a Corrective and Preventive Action (CAPA) has been opened. PROTOCOL_DEVIATION_RAISED: a protocol deviation record has been created. [ENUM-REF-CANDIDATE: ESCALATE_ONSITE_VISIT|REMOTE_FOLLOW_UP|NO_ACTION_REQUIRED|CAPA_INITIATED|PROTOCOL_DEVIATION_RAISED — promote to reference product]' ;
    rdfs:domain ind:CentralMonitoringAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRepeatAlert rdf:type rdf:Property ;
    rdfs:label 'Is Repeat Alert' ;
    rdfs:comment 'Indicates whether this alert is a recurrence of a previously closed alert for the same KRI and site within the current study. True when a prior alert for the same KRI-site combination was closed and the KRI has breached again, signaling unresolved systemic issues.' ;
    rdfs:domain ind:CentralMonitoringAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kriCode rdf:type rdf:Property ;
    rdfs:label 'Kri Code' ;
    rdfs:comment 'Standardized code identifying the specific Key Risk Indicator (KRI) that breached its threshold and triggered this alert (e.g., KRI-AE-001 for adverse event reporting timeliness). Denormalized from the risk_indicator product for alert-level reporting without requiring a join. Null for manually triggered alerts.' ;
    rdfs:domain ind:CentralMonitoringAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kriName rdf:type rdf:Property ;
    rdfs:label 'Kri Name' ;
    rdfs:comment 'Human-readable name of the Key Risk Indicator (KRI) that triggered the alert (e.g., \'Adverse Event Reporting Timeliness\', \'Query Resolution Rate\'). Denormalized for alert reporting and dashboard display without requiring a join to the risk_indicator product.' ;
    rdfs:domain ind:CentralMonitoringAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observedValue rdf:type rdf:Property ;
    rdfs:label 'Observed Value' ;
    rdfs:comment 'The actual computed value of the Key Risk Indicator (KRI) or data signal at the time the alert was generated. Compared against threshold_value to confirm the breach. QUANTITATIVE_RESULT category per TRANSACTION_HEADER non-monetary role.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referencePeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Reference Period End' ;
    rdfs:comment 'End date of the data analysis window used by the centralized statistical monitoring (CSM) system to compute the KRI value that triggered this alert. Together with reference_period_start, defines the exact data window under review.' ;
    rdfs:domain ind:Monitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referencePeriodStart rdf:type rdf:Property ;
    rdfs:label 'Reference Period Start' ;
    rdfs:comment 'Start date of the data analysis window used by the centralized statistical monitoring (CSM) system to compute the KRI value that triggered this alert. Defines the temporal scope of the anomaly.' ;
    rdfs:domain ind:Monitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewNarrative rdf:type rdf:Property ;
    rdfs:label 'Review Narrative' ;
    rdfs:comment 'Free-text narrative entered by the reviewer documenting the findings, rationale for the review outcome, and justification for the chosen disposition. Supports audit trail and regulatory inspection readiness per ALCOA+ principles.' ;
    rdfs:domain ind:CentralMonitoringAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Review Outcome' ;
    rdfs:comment 'Conclusion reached by the reviewer after investigating the alert. CONFIRMED: the anomaly or KRI breach is genuine and requires action. FALSE_POSITIVE: the alert was triggered in error or the signal is not clinically meaningful. INCONCLUSIVE: insufficient data to determine; requires further monitoring. PENDING: review not yet completed.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source System Record Reference' ;
    rdfs:comment 'Native record identifier from the originating operational system (Oracle Siebel CTMS or CSM engine) for this alert. Enables lineage tracing and reconciliation between the Silver Layer and the system of record.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerSource rdf:type rdf:Property ;
    rdfs:label 'Trigger Source' ;
    rdfs:comment 'System or process that generated the alert. AUTOMATED_CSM: centralized statistical monitoring (CSM) engine. MANUAL_ENTRY: entered directly by a central monitor. EDC_INTEGRATION: triggered by Electronic Data Capture (EDC) system data feed (e.g., Medidata Rave). CTMS_RULE: rule-based trigger from Oracle Siebel CTMS. SAFETY_SYSTEM: triggered from Oracle Argus Safety integration.' ;
    rdfs:domain ind:CentralMonitoringAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:craQualificationId rdf:type rdf:Property ;
    rdfs:label 'Cra Qualification Id' ;
    rdfs:comment 'Foreign key linking to workforce.cra_qualification. Business justification: GCP ICH E6(R2) requires that only qualified monitors are assigned to sites. Linking cra_assignment to cra_qualification enables regulatory inspection-readiness verification that the assigned CRA held ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CraQualification .

ind:primaryMonitoringCraEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Monitoring Cra Employee Id' ;
    rdfs:comment 'Reference to the CRA (Clinical Research Associate) employee record assigned to monitor this site-study combination. Sourced from Workday HCM workforce records and linked into Oracle Siebel CTMS.' ;
    rdfs:domain ind:MonitoringCraAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:programResourcePlanId rdf:type rdf:Property ;
    rdfs:label 'Program Resource Plan Id' ;
    rdfs:comment 'Foreign key linking to program.program_resource_plan. Business justification: CRA assignments are the operational execution of the program resource plan. Resource planning teams reconcile planned FTE counts in program_resource_plan against actual cra_assignment records. This li' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgramResourcePlan .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'Free-text field for capturing additional context, special instructions, or qualifications relevant to this CRA-site assignment. May include site-specific monitoring considerations, language requirements, or sponsor-specific directives.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Externally-known, human-readable unique identifier for the CRA assignment record as generated by Oracle Siebel CTMS (e.g., ASSGN-2024-00123). Used for cross-system reference, audit trails, and communication with sponsors and site teams.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle state of the CRA assignment. \'pending\' indicates awaiting activation; \'active\' is the operational state; \'on_hold\' reflects temporary suspension; \'transferred\' indicates handover to another CRA; \'completed\' reflects study close-out; \'cancelled\' indicates the assignment was voided.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Classification of the CRA\'s role within this site-study assignment. \'primary\' indicates the main responsible CRA; \'backup\' covers absence; \'lead\' oversees a cluster of sites; \'co_monitor\' shares responsibilities; \'regional_lead\' manages a geographic territory. Drives visit authorization and workload planning in Oracle Siebel CTMS.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsAssignmentRef rdf:type rdf:Property ;
    rdfs:label 'Ctms Assignment Ref' ;
    rdfs:comment 'Native assignment record identifier from Oracle Siebel CTMS. Preserved for cross-system traceability and reconciliation between the Databricks Silver layer and the operational source system.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gcpTrainingCurrent rdf:type rdf:Property ;
    rdfs:label 'Gcp Training Current' ;
    rdfs:comment 'Indicates whether the assigned CRA holds a current, valid Good Clinical Practice (GCP) training certification at the time of assignment. Regulatory requirement per ICH E6(R2) and FDA 21 CFR Part 312. Sourced from MasterControl training records.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastVisitDate rdf:type rdf:Property ;
    rdfs:label 'Last Visit Date' ;
    rdfs:comment 'Date of the most recently completed monitoring visit conducted by this CRA at the assigned site under this study. Used to calculate visit overdue status and schedule the next visit.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monitoringApproach rdf:type rdf:Property ;
    rdfs:label 'Monitoring Approach' ;
    rdfs:comment 'Primary monitoring methodology authorized for this CRA-site assignment under the risk-based monitoring (RBM) plan. \'on_site\' requires physical presence; \'remote\' uses EDC and electronic review; \'hybrid\' combines both; \'centralized\' is performed by a central team without site visits.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextPlannedVisitDate rdf:type rdf:Property ;
    rdfs:label 'Next Planned Visit Date' ;
    rdfs:comment 'Scheduled date for the next monitoring visit by this CRA at the assigned site. Populated by Oracle Siebel CTMS visit scheduling logic based on visit frequency and last visit date. Supports proactive workload planning.' ;
    rdfs:domain ind:MonitoringCraAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openProtocolDeviationCount rdf:type rdf:Property ;
    rdfs:label 'Open Protocol Deviation Count' ;
    rdfs:comment 'Number of currently open protocol deviations identified by this CRA at the assigned site that have not yet been resolved or closed. Supports escalation decisions and CAPA tracking.' ;
    rdfs:domain ind:MonitoringCraAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remoteAccessAuthorized rdf:type rdf:Property ;
    rdfs:label 'Remote Access Authorized' ;
    rdfs:comment 'Indicates whether this CRA has been granted remote access authorization to the site\'s EDC system (Medidata Rave) and source data systems for remote monitoring activities under this assignment.' ;
    rdfs:domain ind:MonitoringCraAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdvScopePct rdf:type rdf:Property ;
    rdfs:label 'Sdv Scope Pct' ;
    rdfs:comment 'Percentage of source data fields subject to Source Data Verification (SDV) for this CRA-site assignment as defined in the monitoring plan. Reflects the risk-based SDV strategy; lower values indicate targeted/risk-based SDV rather than 100% verification.' ;
    rdfs:domain ind:MonitoringCraAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sdvStrategy rdf:type rdf:Property ;
    rdfs:label 'Sdv Strategy' ;
    rdfs:comment 'Qualitative classification of the SDV strategy applied to this assignment. \'full\' requires 100% SDV; \'targeted\' focuses on specific data fields; \'risk_based\' applies adaptive SDV based on KRI signals; \'critical_data_only\' limits SDV to primary endpoints and safety data.' ;
    rdfs:domain ind:MonitoringCraAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCountAssigned rdf:type rdf:Property ;
    rdfs:label 'Site Count Assigned' ;
    rdfs:comment 'Number of investigational sites assigned to this CRA under the current study at the time of this assignment record. Supports workload benchmarking and capacity management per CRA.' ;
    rdfs:domain ind:MonitoringCraAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteInitiationAuthorized rdf:type rdf:Property ;
    rdfs:label 'Site Initiation Authorized' ;
    rdfs:comment 'Indicates whether this CRA is authorized to conduct the Site Initiation Visit (SIV) for the assigned site under this study. Authorization is contingent on GCP training currency and protocol training completion.' ;
    rdfs:domain ind:MonitoringCraAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'Geographic or organizational territory code assigned to the CRA for this study, as defined in Oracle Siebel CTMS territory management. Used for regional workload balancing, travel planning, and site coverage reporting.' ;
    rdfs:domain ind:MonitoringCraAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryName rdf:type rdf:Property ;
    rdfs:label 'Territory Name' ;
    rdfs:comment 'Human-readable name of the geographic or organizational territory associated with this CRA assignment (e.g., \'Northeast US\', \'Western Europe\'). Supports territory-based reporting and resource planning.' ;
    rdfs:domain ind:MonitoringCraAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalVisitsCompleted rdf:type rdf:Property ;
    rdfs:label 'Total Visits Completed' ;
    rdfs:comment 'Cumulative count of monitoring visits completed by this CRA at the assigned site under this study assignment. Supports workload reporting, performance evaluation, and site coverage tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transferReason rdf:type rdf:Property ;
    rdfs:label 'Transfer Reason' ;
    rdfs:comment 'Free-text description of the reason for transferring this CRA assignment to another CRA. Populated when assignment_status transitions to \'transferred\'. Supports audit trail and continuity documentation per GCP requirements.' ;
    rdfs:domain ind:MonitoringCraAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitFrequencyWeeks rdf:type rdf:Property ;
    rdfs:label 'Visit Frequency Weeks' ;
    rdfs:comment 'Target interval in weeks between monitoring visits for this CRA-site assignment as specified in the monitoring plan. Used for visit scheduling, overdue visit detection, and compliance reporting.' ;
    rdfs:domain ind:MonitoringCraAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workloadAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Workload Allocation Pct' ;
    rdfs:comment 'Percentage of the CRA\'s total monitoring workload capacity allocated to this specific site-study assignment (0.00–100.00). Used for capacity planning, resource utilization reporting, and ensuring no CRA is over-allocated across concurrent assignments.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationRecordId rdf:type rdf:Property ;
    rdfs:label 'Escalation Record Id' ;
    rdfs:comment 'Unique surrogate identifier for the escalation record within the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:EscalationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decisionId rdf:type rdf:Property ;
    rdfs:label 'Decision Id' ;
    rdfs:comment 'Foreign key linking to program.program_decision. Business justification: Critical monitoring escalations (e.g., repeated GCP violations, subject safety signals) trigger formal program-level decisions (hold, termination, protocol amendment). Traceability from escalation_rec' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Decision .

ind:primaryEscalationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Escalation Employee Id' ;
    rdfs:comment 'Reference to the CRA (Clinical Research Associate) who initiated and raised this escalation record.' ;
    rdfs:domain ind:EscalationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:siteRiskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Site Risk Assessment Id' ;
    rdfs:comment 'Foreign key linking to monitoring.site_risk_assessment. Business justification: An escalation can be triggered when a site risk assessment reveals the site has moved to a high-risk tier or has critical KRI breaches exceeding thresholds. The escalation_record captures formal escal' ;
    rdfs:domain ind:Monitoring ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SiteRiskAssessment .

ind:sponsorEscalationId rdf:type rdf:Property ;
    rdfs:label 'Sponsor Escalation Id' ;
    rdfs:comment 'Foreign key linking to sponsor.escalation. Business justification: A site-level monitoring escalation (critical GCP finding, patient safety issue) triggers a formal sponsor-side escalation record for governance review. Linking monitoring.escalation_record to sponsor.' ;
    rdfs:domain ind:EscalationRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Escalation .

ind:susarId rdf:type rdf:Property ;
    rdfs:label 'Susar Id' ;
    rdfs:comment 'Foreign key linking to safety.susar. Business justification: Escalations for SUSAR reporting non-compliance (site failed to notify within 7/15-day clock) must reference the specific SUSAR. Regulatory agencies require audit trails linking site-level escalations ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Susar .

ind:unblindingRequestId rdf:type rdf:Property ;
    rdfs:label 'Unblinding Request Id' ;
    rdfs:comment 'Foreign key linking to randomization.unblinding_request. Business justification: Emergency unblinding requests that exceed approval timelines, involve subject safety crises, or require sponsor escalation trigger escalation_records. Direct traceability between escalation_record and' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UnblindingRequest .

ind:visitFindingId rdf:type rdf:Property ;
    rdfs:label 'Visit Finding Id' ;
    rdfs:comment 'Foreign key linking to monitoring.visit_finding. Business justification: An escalation can be triggered directly by a visit finding (critical or major finding requiring immediate escalation). While escalation_record already has monitoring_action_item_id, not all escalation' ;
    rdfs:domain ind:Monitoring ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VisitFinding .

ind:acknowledgementReference rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Reference' ;
    rdfs:comment 'The reference number or tracking ID issued by the health authority upon acknowledgement of the notification submission. Used for follow-up correspondence.' ;
    rdfs:domain ind:EscalationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysOverdueAtEscalation rdf:type rdf:Property ;
    rdfs:label 'Days Overdue At Escalation' ;
    rdfs:comment 'Number of calendar days the action item, CAPA, or deviation was overdue at the time the escalation was formally raised. Used for SLA breach analysis and KPI reporting.' ;
    rdfs:domain ind:EscalationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationDescription rdf:type rdf:Property ;
    rdfs:label 'Escalation Description' ;
    rdfs:comment 'Detailed narrative describing the finding, issue, or non-compliance that necessitated the escalation, including context, timeline of prior resolution attempts, and impact on subject safety or data integrity.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDueDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Due Date' ;
    rdfs:comment 'Target date by which the escalated issue must be resolved or a response received from the notified party, as defined in the monitoring plan or SOP.' ;
    rdfs:domain ind:EscalationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Hierarchical level of the escalation indicating the parties involved: CRA to Lead CRA, Lead CRA to Sponsor Medical Monitor, Sponsor to IRB/IEC, or Sponsor to Regulatory Authority. Reflects the escalation chain defined in the monitoring plan. [ENUM-REF-CANDIDATE: cra_to_lead_cra|lead_cra_to_sponsor_medical_monitor|sponsor_to_irb_iec|sponsor_to_regulatory_authority|management_escalation|dsmb_notification — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationNumber rdf:type rdf:Property ;
    rdfs:label 'Escalation Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the escalation record as assigned by Oracle Siebel CTMS. Used in communications with sponsors, IRB/IEC, and regulatory bodies.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTitle rdf:type rdf:Property ;
    rdfs:label 'Escalation Title' ;
    rdfs:comment 'Short, human-readable title summarizing the nature of the escalation, used for display in CTMS dashboards and escalation registers.' ;
    rdfs:domain ind:EscalationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTriggerType rdf:type rdf:Property ;
    rdfs:label 'Escalation Trigger Type' ;
    rdfs:comment 'Classification of the root cause or event that triggered this escalation. Drives routing logic and notification workflows in Oracle Siebel CTMS. [ENUM-REF-CANDIDATE: overdue_action_item|overdue_capa|critical_gcp_finding|protocol_deviation|unresolved_query|risk_indicator_breach|safety_concern|regulatory_non_compliance — promote to reference product]' ;
    rdfs:domain ind:EscalationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'Target date by which the follow-up verification action must be completed, when follow_up_required is True.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gcpFindingCategory rdf:type rdf:Property ;
    rdfs:label 'Gcp Finding Category' ;
    rdfs:comment 'Severity classification of the GCP finding that triggered the escalation, aligned with ICH E6(R2) and FDA/EMA inspection classification standards. Critical findings require immediate sponsor or regulatory notification.' ;
    rdfs:domain ind:EscalationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationMethod rdf:type rdf:Property ;
    rdfs:label 'Notification Method' ;
    rdfs:comment 'The channel or mechanism used to deliver the notification to this health authority (e.g., eCTD gateway submission, official email, regulatory portal upload). May differ per authority.' ;
    rdfs:domain ind:EscalationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationStatus rdf:type rdf:Property ;
    rdfs:label 'Notification Status' ;
    rdfs:comment 'Current lifecycle state of the notification for this specific health authority. Tracks whether the authority has acknowledged receipt, allowing compliance teams to chase outstanding acknowledgements.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notifiedParties rdf:type rdf:Property ;
    rdfs:label 'Notified Parties' ;
    rdfs:comment 'Free-text or structured list of all parties formally notified of this escalation (e.g., Lead CRA, Sponsor Medical Monitor, IRB/IEC, Regulatory Authority, DSMB/DMC). Supports audit trail requirements under ALCOA+.' ;
    rdfs:domain ind:EscalationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorResolutionAttempts rdf:type rdf:Property ;
    rdfs:label 'Prior Resolution Attempts' ;
    rdfs:comment 'Number of documented resolution attempts made before the issue was formally escalated. Supports root cause analysis and process improvement.' ;
    rdfs:domain ind:EscalationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'Categorical outcome of the escalation resolution process. Drives downstream CAPA creation, site management decisions, and regulatory reporting workflows.' ;
    rdfs:domain ind:EscalationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskBasedMonitoringFlag rdf:type rdf:Property ;
    rdfs:label 'Risk Based Monitoring Flag' ;
    rdfs:comment 'Indicates whether this escalation was triggered through the risk-based monitoring (RBM) program, as opposed to routine on-site monitoring. Supports RBM effectiveness analytics.' ;
    rdfs:domain ind:EscalationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipAccountabilityLogId rdf:type rdf:Property ;
    rdfs:label 'Ip Accountability Log Id' ;
    rdfs:comment 'Unique surrogate identifier for each Investigational Product (IP) accountability verification record captured during a monitoring visit. Primary key for this entity.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IpAccountabilityLog .

ind:destructionRecordId rdf:type rdf:Property ;
    rdfs:label 'Destruction Record Id' ;
    rdfs:comment 'Foreign key linking to supply.destruction_record. Business justification: The ip_accountability_log has a destruction_records_reviewed flag; linking directly to the specific destruction_record reviewed provides the GCP audit trail required for IP accountability verification' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DestructionRecord .

ind:randomizationKitAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Randomization Kit Assignment Id' ;
    rdfs:comment 'Foreign key linking to randomization.kit_assignment. Business justification: IP accountability reconciliation during monitoring visits requires direct comparison of dispensed/returned quantities against kit assignment records. CRAs verify ip_accountability_log against kit_assi' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KitAssignment .

ind:accountabilityFindingSeverity rdf:type rdf:Property ;
    rdfs:label 'Accountability Finding Severity' ;
    rdfs:comment 'The severity classification of any IP accountability finding identified during the CRA verification. \'None\' indicates full compliance; \'Critical\' indicates a finding that may impact subject safety or data integrity and requires immediate escalation to the sponsor.' ;
    rdfs:domain ind:IpAccountabilityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchLotNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Lot Number' ;
    rdfs:comment 'The manufacturing batch or lot number of the investigational product as recorded on the IP label and dispensing records. Critical for traceability and recall management under GCP and GMP requirements.' ;
    rdfs:domain ind:IpAccountabilityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:craComments rdf:type rdf:Property ;
    rdfs:label 'Cra Comments' ;
    rdfs:comment 'Free-text comments entered by the CRA regarding the overall IP accountability verification, including observations about site practices, documentation quality, and any additional context not captured in structured fields.' ;
    rdfs:domain ind:IpAccountabilityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionRecordsReviewed rdf:type rdf:Property ;
    rdfs:label 'Destruction Records Reviewed' ;
    rdfs:comment 'Indicates whether the CRA reviewed IP destruction certificates or records during the monitoring visit to confirm that destroyed IP quantities are properly documented and authorized.' ;
    rdfs:domain ind:IpAccountabilityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyNotes rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Notes' ;
    rdfs:comment 'Free-text narrative describing the nature of any IP accountability discrepancy identified during the CRA verification, including potential explanations, site staff comments, and initial investigation findings. Required when reconciliation_status is \'discrepancy_identified\'.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyQuantity rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Quantity' ;
    rdfs:comment 'The numeric difference between the calculated IP balance (received minus dispensed minus returned minus destroyed) and the physical quantity on hand. A non-zero value indicates an accountability discrepancy requiring investigation and documentation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispensingLogReviewed rdf:type rdf:Property ;
    rdfs:label 'Dispensing Log Reviewed' ;
    rdfs:comment 'Indicates whether the CRA reviewed the site\'s IP dispensing log during the monitoring visit to verify accuracy and completeness of dispensing records against subject randomization and dosing data.' ;
    rdfs:domain ind:IpAccountabilityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipForm rdf:type rdf:Property ;
    rdfs:label 'Ip Form' ;
    rdfs:comment 'The pharmaceutical dosage form of the investigational product (e.g., tablet, capsule, injection). Relevant for storage condition verification and dispensing record review. [ENUM-REF-CANDIDATE: tablet|capsule|injection|infusion|topical|inhaler|powder|solution|suspension|patch|other — promote to reference product]' ;
    rdfs:domain ind:IpAccountabilityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipLabelComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Ip Label Compliance Verified' ;
    rdfs:comment 'Indicates whether the CRA verified that IP labels comply with applicable regulatory requirements (e.g., correct language, required statements, batch/lot number, expiry date, storage conditions) per the approved labeling.' ;
    rdfs:domain ind:IpAccountabilityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Ip Storage Location' ;
    rdfs:comment 'The physical location identifier or description of where the investigational product is stored at the site (e.g., pharmacy refrigerator unit ID, locked cabinet reference). Verified by the CRA during the monitoring visit.' ;
    rdfs:domain ind:IpAccountabilityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipStrength rdf:type rdf:Property ;
    rdfs:label 'Ip Strength' ;
    rdfs:comment 'The dose strength of the investigational product as labeled (e.g., \'100 mg\', \'5 mg/mL\'). Used to verify that the correct strength was dispensed per the protocol and randomization assignment.' ;
    rdfs:domain ind:IpAccountabilityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logNumber rdf:type rdf:Property ;
    rdfs:label 'Log Number' ;
    rdfs:comment 'Externally-known business identifier for this IP accountability log record, typically assigned by the Clinical Trial Management System (CTMS) or Electronic Data Capture (EDC) system (e.g., \'IPAL-2024-00123\'). Used for cross-system referencing and audit trail.' ;
    rdfs:domain ind:IpAccountabilityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityDestroyed rdf:type rdf:Property ;
    rdfs:label 'Quantity Destroyed' ;
    rdfs:comment 'The total quantity of investigational product units destroyed at the site or returned to sponsor for destruction, as documented in the destruction records. Required for full IP accountability reconciliation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityDispensed rdf:type rdf:Property ;
    rdfs:label 'Quantity Dispensed' ;
    rdfs:comment 'The total quantity of investigational product units dispensed to study subjects at the site, as recorded in the dispensing log. Used in the IP accountability reconciliation calculation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'The physical count of investigational product units remaining in site inventory at the time of the CRA verification visit. Compared against the calculated balance (received minus dispensed minus returned minus destroyed) to identify discrepancies.' ;
    rdfs:domain ind:IpAccountabilityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityReceived rdf:type rdf:Property ;
    rdfs:label 'Quantity Received' ;
    rdfs:comment 'The total quantity of investigational product units received at the site from the sponsor or depot, as recorded in the site\'s IP receipt log. Expressed in the unit of dispensing (e.g., number of tablets, vials, kits). Used as the starting balance for reconciliation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityReturned rdf:type rdf:Property ;
    rdfs:label 'Quantity Returned' ;
    rdfs:comment 'The total quantity of investigational product units returned by subjects to the site (unused or partially used), as recorded in the return log. Included in the reconciliation to account for all IP.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'The unit of measure used for all IP quantity fields (received, dispensed, returned, destroyed, on hand) in this record (e.g., \'tablet\', \'vial\', \'kit\'). Ensures consistent interpretation of quantity values across reconciliation. [ENUM-REF-CANDIDATE: tablet|capsule|vial|kit|syringe|patch|unit|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnLogReviewed rdf:type rdf:Property ;
    rdfs:label 'Return Log Reviewed' ;
    rdfs:comment 'Indicates whether the CRA reviewed the site\'s IP return log during the monitoring visit to verify that all returned IP units are documented with subject ID, return date, and quantity.' ;
    rdfs:domain ind:IpAccountabilityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Review Period End Date' ;
    rdfs:comment 'The end date of the period covered by this IP accountability review (i.e., the date up to which IP transactions are being reconciled). Typically corresponds to the current monitoring visit date.' ;
    rdfs:domain ind:IpAccountabilityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Period Start Date' ;
    rdfs:comment 'The start date of the period covered by this IP accountability review (i.e., the date from which IP transactions are being reconciled). Typically corresponds to the date of the previous monitoring visit or last accountability check.' ;
    rdfs:domain ind:IpAccountabilityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rtsmIrtReconciled rdf:type rdf:Property ;
    rdfs:label 'Rtsm Irt Reconciled' ;
    rdfs:comment 'Indicates whether the site\'s physical IP accountability records have been reconciled against the RTSM/IRT system (e.g., Medidata Rave RTSM) dispensing and randomization data. Discrepancies between physical records and RTSM/IRT are a critical GCP finding.' ;
    rdfs:domain ind:IpAccountabilityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageConditionVerified rdf:type rdf:Property ;
    rdfs:label 'Storage Condition Verified' ;
    rdfs:comment 'Indicates whether the CRA verified that the investigational product was stored under the protocol-specified conditions (e.g., temperature range, light protection, humidity) at the time of the monitoring visit. A value of True confirms compliance; False triggers a finding.' ;
    rdfs:domain ind:IpAccountabilityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureExcursionDetails rdf:type rdf:Property ;
    rdfs:label 'Temperature Excursion Details' ;
    rdfs:comment 'Free-text description of any temperature excursion identified, including the duration, magnitude, affected IP units, and any corrective actions taken by site staff. Populated only when temperature_excursion_occurred is True.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureExcursionOccurred rdf:type rdf:Property ;
    rdfs:label 'Temperature Excursion Occurred' ;
    rdfs:comment 'Indicates whether a temperature excursion (storage outside the protocol-specified temperature range) was identified during the CRA review of temperature monitoring records. True triggers mandatory sponsor notification and potential IP quarantine.' ;
    rdfs:domain ind:IpAccountabilityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'Precise date and time at which the CRA completed the IP accountability verification, including timezone offset. Supports ALCOA+ (Attributable, Legible, Contemporaneous, Original, Accurate) audit trail requirements under 21 CFR Part 11.' ;
    rdfs:domain ind:IpAccountabilityLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:studyPortfolioId rdf:type rdf:Property ;
    rdfs:label 'Study Portfolio Id' ;
    rdfs:comment 'Foreign key linking to sponsor.study_portfolio. Business justification: Portfolio-level monitoring oversight requires linking monitoring plans to the sponsor\'s study portfolio for cross-study KPI reporting, portfolio risk management, and governance reviews. Sponsor portfo' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudyPortfolio .

ind:applicableRegions rdf:type rdf:Property ;
    rdfs:label 'Applicable Regions' ;
    rdfs:comment 'Comma-separated list of regulatory regions or jurisdictions to which this monitoring plan applies (e.g., USA, EU, JPN, AUS, CAN). Determines which regulatory authority requirements (FDA, EMA, PMDA, TGA, Health Canada) govern monitoring activities.' ;
    rdfs:domain ind:MonitoringPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaResolutionDays rdf:type rdf:Property ;
    rdfs:label 'Capa Resolution Days' ;
    rdfs:comment 'Maximum number of calendar days within which a Corrective and Preventive Action (CAPA) identified during monitoring must be resolved and closed by the site or sponsor. Defined in the monitoring plan to ensure timely remediation.' ;
    rdfs:domain ind:MonitoringPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:centralizedMonitoringIncluded rdf:type rdf:Property ;
    rdfs:label 'Centralized Monitoring Included' ;
    rdfs:comment 'Indicates whether centralized statistical monitoring (e.g., Key Risk Indicator (KRI) dashboards, data trend analysis) is included as a component of the monitoring strategy for this study.' ;
    rdfs:domain ind:MonitoringPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closeoutVisitRequired rdf:type rdf:Property ;
    rdfs:label 'Closeout Visit Required' ;
    rdfs:comment 'Indicates whether a formal Site Close-Out Visit (COV) is mandated for all sites under this monitoring plan upon study completion or site termination.' ;
    rdfs:domain ind:MonitoringPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:craQualificationRequirements rdf:type rdf:Property ;
    rdfs:label 'Cra Qualification Requirements' ;
    rdfs:comment 'Description of minimum qualifications, certifications, and experience required for Clinical Research Associates (CRAs) assigned to monitor sites under this plan (e.g., therapeutic area experience, GCP certification, sponsor-specific training).' ;
    rdfs:domain ind:MonitoringPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalDataElements rdf:type rdf:Property ;
    rdfs:label 'Critical Data Elements' ;
    rdfs:comment 'Comma-separated list or narrative description of data fields designated as critical per ICH E6(R2), such as primary efficacy endpoints, informed consent dates, eligibility criteria, and safety data. These elements receive mandatory SDV regardless of overall SDV scope.' ;
    rdfs:domain ind:MonitoringPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalProcesses rdf:type rdf:Property ;
    rdfs:label 'Critical Processes' ;
    rdfs:comment 'Description of study processes designated as critical per ICH E6(R2), such as randomization, informed consent, Investigational Product (IP) accountability, and Serious Adverse Event (SAE) reporting. These processes receive heightened monitoring focus.' ;
    rdfs:domain ind:MonitoringPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyRequirements rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Requirements' ;
    rdfs:comment 'Description of applicable data privacy and patient data protection requirements governing monitoring activities under this plan, including GDPR, HIPAA, and local data protection laws relevant to the study regions.' ;
    rdfs:domain ind:MonitoringPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTriggerCriteria rdf:type rdf:Property ;
    rdfs:label 'Escalation Trigger Criteria' ;
    rdfs:comment 'Defined conditions or thresholds that trigger escalation of monitoring intensity, additional site visits, or Corrective and Preventive Action (CAPA) initiation. Examples include KRI breaches, repeated protocol deviations, or SAE under-reporting.' ;
    rdfs:domain ind:MonitoringPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gcpTrainingRequired rdf:type rdf:Property ;
    rdfs:label 'Gcp Training Required' ;
    rdfs:comment 'Indicates whether current Good Clinical Practice (GCP) training certification is a prerequisite for all Clinical Research Associates (CRAs) executing monitoring activities under this plan.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:highRiskVisitFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'High Risk Visit Frequency Days' ;
    rdfs:comment 'Monitoring visit interval in calendar days applicable to sites classified as High risk tier. Typically shorter than the standard interval to ensure heightened oversight.' ;
    rdfs:domain ind:MonitoringPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:icfReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Icf Review Required' ;
    rdfs:comment 'Indicates whether review of signed Informed Consent Forms (ICFs) for all enrolled subjects is a mandatory component of each monitoring visit under this plan.' ;
    rdfs:domain ind:MonitoringPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interimVisitFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Interim Visit Frequency Days' ;
    rdfs:comment 'Standard interval in calendar days between scheduled interim monitoring visits for an average-risk site. Actual frequency may be adjusted based on site risk tier and Key Risk Indicator (KRI) triggers.' ;
    rdfs:domain ind:MonitoringPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ipAccountabilityRequired rdf:type rdf:Property ;
    rdfs:label 'Ip Accountability Required' ;
    rdfs:comment 'Indicates whether Investigational Product (IP) accountability checks (dispensing, return, destruction reconciliation) are mandated as part of on-site monitoring visits under this plan.' ;
    rdfs:domain ind:MonitoringPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kriToleranceLimits rdf:type rdf:Property ;
    rdfs:label 'Kri Tolerance Limits' ;
    rdfs:comment 'Narrative or structured description of the Key Risk Indicator (KRI) thresholds and tolerance limits defined in this monitoring plan. Specifies the upper/lower bounds for metrics such as query rate, protocol deviation rate, and enrollment rate that trigger escalation actions.' ;
    rdfs:domain ind:MonitoringPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowRiskVisitFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Low Risk Visit Frequency Days' ;
    rdfs:comment 'Monitoring visit interval in calendar days applicable to sites classified as Low risk tier. Typically longer than the standard interval, reflecting reduced oversight requirements.' ;
    rdfs:domain ind:MonitoringPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:missingDataThreshold rdf:type rdf:Property ;
    rdfs:label 'Missing Data Threshold' ;
    rdfs:comment 'Maximum acceptable percentage of missing or incomplete data fields in the Electronic Case Report Form (eCRF) before a site is flagged for corrective action under the centralized monitoring program.' ;
    rdfs:domain ind:MonitoringPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Externally-known unique business identifier for the monitoring plan, typically formatted as MP-[StudyCode]-[SequenceNumber]. Used in Trial Master File (TMF) references and regulatory submissions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the monitoring plan. Draft indicates work-in-progress; Under Review indicates pending approval; Approved is the active operative version; Superseded indicates replaced by a newer version; Retired indicates no longer applicable.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolDeviationThreshold rdf:type rdf:Property ;
    rdfs:label 'Protocol Deviation Threshold' ;
    rdfs:comment 'Maximum acceptable protocol deviation rate (expressed as a percentage of total subject visits or data points) before escalation actions are triggered at a site. Defined per the RBM strategy.' ;
    rdfs:domain ind:MonitoringPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:queryRateThreshold rdf:type rdf:Property ;
    rdfs:label 'Query Rate Threshold' ;
    rdfs:comment 'Maximum acceptable data query rate (expressed as a percentage of total data points entered) before centralized monitoring flags a site for additional review or on-site visit. Supports Electronic Data Capture (EDC) quality oversight.' ;
    rdfs:domain ind:MonitoringPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rbmStrategy rdf:type rdf:Property ;
    rdfs:label 'Rbm Strategy' ;
    rdfs:comment 'Overarching Risk-Based Monitoring (RBM) strategy classification applied to the study. Determines the balance between on-site, remote, and centralized monitoring activities based on study risk profile per ICH E6(R2) and FDA/EMA guidance.' ;
    rdfs:domain ind:MonitoringPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteMonitoringAllowed rdf:type rdf:Property ;
    rdfs:label 'Remote Monitoring Allowed' ;
    rdfs:comment 'Indicates whether remote (off-site) monitoring activities are permitted under this monitoring plan as a complement or alternative to on-site visits, per the approved RBM strategy.' ;
    rdfs:domain ind:MonitoringPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdvPercentageThreshold rdf:type rdf:Property ;
    rdfs:label 'Sdv Percentage Threshold' ;
    rdfs:comment 'Minimum percentage of source data records or data points that must be verified per site visit or monitoring cycle, as defined in the Risk-Based Monitoring (RBM) strategy. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:MonitoringPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sdvScope rdf:type rdf:Property ;
    rdfs:label 'Sdv Scope' ;
    rdfs:comment 'Defines the breadth of Source Data Verification (SDV) to be performed across the study. 100% SDV requires verification of all data points; Risk-Based SDV targets high-risk data fields; Critical Data Only restricts SDV to protocol-defined critical data elements; No SDV applies to centralized monitoring-only studies.' ;
    rdfs:domain ind:Monitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteInitiationVisitRequired rdf:type rdf:Property ;
    rdfs:label 'Site Initiation Visit Required' ;
    rdfs:comment 'Indicates whether a formal Site Initiation Visit (SIV) is mandated for all sites under this monitoring plan prior to first patient enrollment.' ;
    rdfs:domain ind:MonitoringPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siteRiskTierMethodology rdf:type rdf:Property ;
    rdfs:label 'Site Risk Tier Methodology' ;
    rdfs:comment 'Methodology used to assign risk tiers (e.g., High, Medium, Low) to investigational sites. Determines how site-level risk scores are calculated to drive adaptive monitoring frequency and intensity.' ;
    rdfs:domain ind:MonitoringPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitReportSubmissionDays rdf:type rdf:Property ;
    rdfs:label 'Visit Report Submission Days' ;
    rdfs:comment 'Maximum number of calendar days after a monitoring visit within which the CRA must submit the completed monitoring visit report to the sponsor or CRO. Typically 5–10 business days per GCP standards.' ;
    rdfs:domain ind:MonitoringPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionItemsCount rdf:type rdf:Property ;
    rdfs:label 'Action Items Count' ;
    rdfs:comment 'Total number of action items raised for the site as a result of this monitoring visit. Supports action item tracking, escalation management, and site accountability.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'Actual duration of the monitoring visit expressed in days (may be fractional for partial-day visits). Supports resource planning, CRA productivity metrics, and visit efficiency analysis.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecrfPagesReviewed rdf:type rdf:Property ;
    rdfs:label 'Ecrf Pages Reviewed' ;
    rdfs:comment 'Total number of Electronic Case Report Form (eCRF) pages reviewed during the monitoring visit. Supports workload measurement and data quality tracking.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:icfComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Icf Compliance Verified' ;
    rdfs:comment 'Indicates whether Informed Consent Form (ICF) compliance was reviewed and verified for enrolled subjects during this monitoring visit. Covers version currency, signature completeness, and re-consent requirements.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipAccountabilityVerified rdf:type rdf:Property ;
    rdfs:label 'Ip Accountability Verified' ;
    rdfs:comment 'Indicates whether Investigational Product (IP) accountability (receipt, dispensing, return, destruction records) was verified during this monitoring visit, as required by GCP.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextVisitPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Next Visit Planned Date' ;
    rdfs:comment 'Tentative planned date for the next monitoring visit to this site, as agreed during this visit or determined by the monitoring plan. Supports CRA scheduling and site management.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextVisitType rdf:type rdf:Property ;
    rdfs:label 'Next Visit Type' ;
    rdfs:comment 'Type of the next monitoring visit recommended or planned for this site as determined during this visit. Supports forward scheduling and monitoring plan management.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objective rdf:type rdf:Property ;
    rdfs:label 'Objective' ;
    rdfs:comment 'Narrative description of the primary objectives and scope of the monitoring visit (e.g., ICF review, SDV of safety data, protocol deviation follow-up, IP accountability). Embedded from visit type classification.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piMeetingConducted rdf:type rdf:Property ;
    rdfs:label 'Pi Meeting Conducted' ;
    rdfs:comment 'Indicates whether a formal meeting with the Principal Investigator (PI) was conducted during this monitoring visit. Required for certain visit types per GCP and sponsor SOPs.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:protocolDeviationsIdentified rdf:type rdf:Property ;
    rdfs:label 'Protocol Deviations Identified' ;
    rdfs:comment 'Number of protocol deviations identified during this monitoring visit. Drives deviation management workflows, CAPA initiation, and regulatory reporting obligations.' ;
    rdfs:domain ind:Monitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:queriesClosed rdf:type rdf:Property ;
    rdfs:label 'Queries Closed' ;
    rdfs:comment 'Number of previously open data queries resolved and closed during this monitoring visit. Supports query resolution tracking and site data quality metrics.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:queriesOpened rdf:type rdf:Property ;
    rdfs:label 'Queries Opened' ;
    rdfs:comment 'Number of data queries raised against the site during or as a result of this monitoring visit. Tracks data quality issues identified and drives query management workflows.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportDueDate rdf:type rdf:Property ;
    rdfs:label 'Report Due Date' ;
    rdfs:comment 'The contractually or SOP-defined deadline by which the CRA must submit the monitoring visit report following visit completion. Typically within 10 business days per GCP guidelines.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current status of the monitoring visit report in its authoring and approval workflow. Tracks progression from draft through TMF filing. [ENUM-REF-CANDIDATE: not-started|draft|submitted|reviewed|approved|filed — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Report Submission Date' ;
    rdfs:comment 'The actual date on which the CRA submitted the monitoring visit report. Compared against report_due_date to measure report timeliness compliance.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sdvSubjectsReviewed rdf:type rdf:Property ;
    rdfs:label 'Sdv Subjects Reviewed' ;
    rdfs:comment 'Number of enrolled subjects whose source data was reviewed and verified during this monitoring visit. Supports SDV coverage tracking and RBM metrics.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subjectsEnrolledAtVisit rdf:type rdf:Property ;
    rdfs:label 'Subjects Enrolled At Visit' ;
    rdfs:comment 'Total number of subjects enrolled at the investigational site at the time of this monitoring visit. Provides enrollment context for SDV coverage calculations and site performance assessment.' ;
    rdfs:domain ind:MonitoringVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visitMode rdf:type rdf:Property ;
    rdfs:label 'Visit Mode' ;
    rdfs:comment 'Indicates whether the monitoring visit was conducted on-site at the investigational site, remotely (e.g., via EDC/eTMF access), or as a hybrid combination. Supports Risk-Based Monitoring (RBM) strategy tracking.' ;
    rdfs:domain ind:Monitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitStatus rdf:type rdf:Property ;
    rdfs:label 'Visit Status' ;
    rdfs:comment 'Current lifecycle state of the monitoring visit within the CTMS workflow. Drives operational dashboards, CRA workload planning, and TMF completeness tracking. [ENUM-REF-CANDIDATE: planned|scheduled|in-progress|completed|cancelled|rescheduled — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kriId rdf:type rdf:Property ;
    rdfs:label 'Kri Id' ;
    rdfs:comment 'Foreign key linking to program.program_kri. Business justification: Study/site-level KRIs (risk_indicator) are operationally mapped to program-level KRIs (program_kri) for aggregation into program_kri_readings. RBM frameworks require this traceability to compute progr' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Kri .

ind:amberThreshold rdf:type rdf:Property ;
    rdfs:label 'Amber Threshold' ;
    rdfs:comment 'Numeric threshold value at which the KRI triggers an amber (warning) alert, indicating elevated risk requiring heightened monitoring attention. Defined in the RBM monitoring plan.' ;
    rdfs:domain ind:RiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:computationDate rdf:type rdf:Property ;
    rdfs:label 'Computation Date' ;
    rdfs:comment 'Calendar date on which the KRI value was most recently computed for the site. Used to assess data currency and trigger recomputation schedules in the RBM monitoring plan.' ;
    rdfs:domain ind:RiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:computationFrequency rdf:type rdf:Property ;
    rdfs:label 'Computation Frequency' ;
    rdfs:comment 'Scheduled frequency at which the KRI is recomputed for each site (e.g., weekly for enrollment KRIs, monthly for data quality KRIs). Defined in the RBM monitoring plan.' ;
    rdfs:domain ind:RiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:computationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Computation Timestamp' ;
    rdfs:comment 'Precise date and time at which the KRI value was computed, including timezone offset. Supports audit trail requirements under 21 CFR Part 11 and ALCOA+ principles.' ;
    rdfs:domain ind:RiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:computedValue rdf:type rdf:Property ;
    rdfs:label 'Computed Value' ;
    rdfs:comment 'Current computed numeric value of the KRI for the associated site, derived from the source system data as of the last computation run. This is the principal quantitative fact of the risk indicator record.' ;
    rdfs:domain ind:RiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Operational system of record from which the KRI input data is extracted for computation (e.g., Medidata Rave EDC for data quality KRIs, Oracle Argus Safety for safety KRIs, Oracle Siebel CTMS for enrollment KRIs).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denominatorValue rdf:type rdf:Property ;
    rdfs:label 'Denominator Value' ;
    rdfs:comment 'Raw denominator component of the KRI computation (e.g., total subjects screened, total expected data points, total SAEs reported). Stored alongside the numerator to enable independent verification of the computed value.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indicatorDescription rdf:type rdf:Property ;
    rdfs:label 'Indicator Description' ;
    rdfs:comment 'Detailed narrative description of what the KRI measures, its business rationale, and how it supports risk detection within the RBM framework.' ;
    rdfs:domain ind:RiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorName rdf:type rdf:Property ;
    rdfs:label 'Indicator Name' ;
    rdfs:comment 'Human-readable name of the KRI as defined in the RBM monitoring plan (e.g., \'Screen Failure Rate\', \'Missing Data Rate\', \'SAE Reporting Timeliness\'). Used in dashboards, monitoring visit reports, and sponsor communications.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorStatus rdf:type rdf:Property ;
    rdfs:label 'Indicator Status' ;
    rdfs:comment 'Current lifecycle status of the KRI definition within the monitoring plan. Active KRIs are computed and monitored; draft KRIs are under review; retired KRIs are no longer in use.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorType rdf:type rdf:Property ;
    rdfs:label 'Indicator Type' ;
    rdfs:comment 'Quantitative type of the KRI value, indicating whether the computed metric is a rate, absolute count, percentage, ratio, or duration in days. Governs how the value is interpreted against thresholds.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCentralizedMonitoring rdf:type rdf:Property ;
    rdfs:label 'Is Centralized Monitoring' ;
    rdfs:comment 'Indicates whether this KRI is part of the Centralized Statistical Monitoring (CSM) program, as opposed to a site-level operational indicator. Supports differentiation of CSM KRIs from operational monitoring metrics.' ;
    rdfs:domain ind:RiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numeratorValue rdf:type rdf:Property ;
    rdfs:label 'Numerator Value' ;
    rdfs:comment 'Raw numerator component of the KRI computation (e.g., number of screen failures, number of missing data points, number of overdue SAE reports). Stored to support audit and recomputation validation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorComputedValue rdf:type rdf:Property ;
    rdfs:label 'Prior Computed Value' ;
    rdfs:comment 'KRI computed value from the immediately preceding computation cycle for the same site. Enables trend analysis and detection of rapid deterioration or improvement in site risk profile.' ;
    rdfs:domain ind:RiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redThreshold rdf:type rdf:Property ;
    rdfs:label 'Red Threshold' ;
    rdfs:comment 'Numeric threshold value at which the KRI triggers a red (critical) alert, indicating a significant risk requiring immediate escalation and corrective action per the RBM monitoring plan.' ;
    rdfs:domain ind:RiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskIndicatorCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Indicator Category' ;
    rdfs:comment 'Business category classifying the domain of risk the KRI monitors. Supports stratified risk reporting across enrollment, data quality, safety, protocol compliance, and Investigational Product (IP) accountability domains.' ;
    rdfs:domain ind:RiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScoreContribution rdf:type rdf:Property ;
    rdfs:label 'Risk Score Contribution' ;
    rdfs:comment 'Weighted contribution of this KRI to the overall site risk score, expressed as a percentage (0–100). Reflects the KRI\'s relative importance in the composite site risk scoring model.' ;
    rdfs:domain ind:RiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sdvImpact rdf:type rdf:Property ;
    rdfs:label 'Sdv Impact' ;
    rdfs:comment 'Defines the impact of this KRI\'s alert status on the Source Data Verification (SDV) strategy for the site. A red alert may trigger targeted or increased SDV; a green status may support reduced SDV per the risk-adaptive monitoring plan.' ;
    rdfs:domain ind:RiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorDefined rdf:type rdf:Property ;
    rdfs:label 'Sponsor Defined' ;
    rdfs:comment 'Indicates whether this KRI was defined by the sponsor (True) or by the CRO as part of its standard RBM methodology (False). Supports differentiation of sponsor-mandated versus CRO-standard risk indicators.' ;
    rdfs:domain ind:RiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trendDirection rdf:type rdf:Property ;
    rdfs:label 'Trend Direction' ;
    rdfs:comment 'Directional trend of the KRI value compared to the prior computation cycle. Supports proactive risk management by identifying sites where risk is worsening before threshold breach.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weight rdf:type rdf:Property ;
    rdfs:label 'Weight' ;
    rdfs:comment 'Numeric weight assigned to this KRI in the composite site risk scoring model, reflecting its relative importance compared to other KRIs in the monitoring plan. Used in weighted risk score calculations.' ;
    rdfs:domain ind:RiskIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sdvRecordId rdf:type rdf:Property ;
    rdfs:label 'Sdv Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each Source Data Verification (SDV) record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:SdvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discrepancyCategory rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Category' ;
    rdfs:comment 'Categorical classification of the discrepancy type when sdv_outcome is \'discrepancy_found\'. Supports root cause analysis, CAPA workflows, and site quality trending. [ENUM-REF-CANDIDATE: transcription_error|missing_data|date_error|unit_error|coding_error|other — promote to reference product]' ;
    rdfs:domain ind:SdvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecrfPageNumber rdf:type rdf:Property ;
    rdfs:label 'Ecrf Page Number' ;
    rdfs:comment 'The page or section reference within the eCRF form where the verified data point is located. Supports precise audit trail navigation and source document traceability in Medidata Rave.' ;
    rdfs:domain ind:SdvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalDataPoint rdf:type rdf:Property ;
    rdfs:label 'Is Critical Data Point' ;
    rdfs:comment 'Indicates whether this eCRF field is designated as a critical data point per the study\'s Risk-Based Monitoring (RBM) plan or Data Management Plan (DMP). Critical data points are prioritized for SDV under ICH E6(R2) Addendum.' ;
    rdfs:domain ind:SdvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSdvWaived rdf:type rdf:Property ;
    rdfs:label 'Is Sdv Waived' ;
    rdfs:comment 'Indicates whether SDV was formally waived for this data point per the approved RBM plan or protocol amendment. A waiver must be documented and justified in the monitoring plan. Supports RBM audit trail.' ;
    rdfs:domain ind:SdvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notVerifiableReason rdf:type rdf:Property ;
    rdfs:label 'Not Verifiable Reason' ;
    rdfs:comment 'Reason why the data point could not be verified against source documents when sdv_outcome is \'not_verifiable\'. Supports site follow-up actions and regulatory audit readiness. [ENUM-REF-CANDIDATE: source_unavailable|illegible|missing_record|access_denied|other — promote to reference product]' ;
    rdfs:domain ind:SdvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rbmRiskScore rdf:type rdf:Property ;
    rdfs:label 'Rbm Risk Score' ;
    rdfs:comment 'The risk score assigned to this data point or subject visit by the Risk-Based Monitoring (RBM) algorithm at the time SDV was triggered. Supports RBM strategy documentation and audit trail for targeted SDV decisions.' ;
    rdfs:domain ind:SdvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Impact Flag' ;
    rdfs:comment 'Indicates whether the SDV discrepancy has potential regulatory impact (e.g., affects primary endpoint data, safety data, or regulatory submission data). Triggers escalation to the sponsor and regulatory team.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdvCoveragePercentage rdf:type rdf:Property ;
    rdfs:label 'Sdv Coverage Percentage' ;
    rdfs:comment 'The percentage of eligible data points for this subject visit that have been verified as part of this SDV activity. Supports monitoring KPI reporting and RBM coverage tracking at the visit level.' ;
    rdfs:domain ind:SdvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sdvMethod rdf:type rdf:Property ;
    rdfs:label 'Sdv Method' ;
    rdfs:comment 'The SDV sampling strategy applied to this data point: 100% SDV (all data points verified), targeted (specific critical fields), risk-based (driven by RBM algorithm), or triggered (initiated by a specific risk signal or query). Supports RBM strategy documentation.' ;
    rdfs:domain ind:SdvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdvOutcome rdf:type rdf:Property ;
    rdfs:label 'Sdv Outcome' ;
    rdfs:comment 'The result of the SDV activity for this specific data point: verified (eCRF matches source), discrepancy_found (mismatch identified), not_verifiable (source document unavailable or illegible), or pending (SDV not yet completed). Core status field for ALCOA+ compliance.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdvPerformedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sdv Performed Timestamp' ;
    rdfs:comment 'The date and time at which the CRA performed the SDV activity for this specific data point. Principal business event timestamp. Supports ALCOA+ Contemporaneous principle and 21 CFR Part 11 audit trail.' ;
    rdfs:domain ind:SdvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sdvReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sdv Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this SDV record, used in monitoring visit reports, audit trails, and regulatory submissions. Generated by Oracle Siebel CTMS.' ;
    rdfs:domain ind:SdvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdvType rdf:type rdf:Property ;
    rdfs:label 'Sdv Type' ;
    rdfs:comment 'Indicates whether the SDV was performed on-site at the investigational site, remotely via electronic access to source data, or as part of centralized statistical monitoring. Supports risk-based monitoring (RBM) strategy tracking.' ;
    rdfs:domain ind:SdvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentValue rdf:type rdf:Property ;
    rdfs:label 'Source Document Value' ;
    rdfs:comment 'The value as recorded in the original source document (e.g., medical record, lab report, nurse notes) against which the eCRF field value was verified. Supports ALCOA+ Attributable and Original principles.' ;
    rdfs:domain ind:SdvRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primarySiteEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Site Employee Id' ;
    rdfs:comment 'Reference to the Clinical Research Associate (CRA) or Risk Manager who conducted this site risk assessment.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:aeReportingTimelinessPercent rdf:type rdf:Property ;
    rdfs:label 'Ae Reporting Timeliness Percent' ;
    rdfs:comment 'Percentage of Adverse Events (AEs) reported within the protocol-defined and regulatory-required timeframes during the assessment period. A critical patient safety KRI.' ;
    rdfs:domain ind:SiteRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalKriBreachesCount rdf:type rdf:Property ;
    rdfs:label 'Critical Kri Breaches Count' ;
    rdfs:comment 'Number of KRI breaches classified as critical severity (i.e., exceeding the upper alert threshold). Critical breaches may trigger immediate unscheduled monitoring visits or escalation.' ;
    rdfs:domain ind:SiteRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataEntryLagDays rdf:type rdf:Property ;
    rdfs:label 'Data Entry Lag Days' ;
    rdfs:comment 'Average number of days between the date of clinical observation and the date of entry into the Electronic Data Capture (EDC) system (Medidata Rave) during the assessment period. A key KRI for data quality monitoring.' ;
    rdfs:domain ind:SiteRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enrollmentRatePercent rdf:type rdf:Property ;
    rdfs:label 'Enrollment Rate Percent' ;
    rdfs:comment 'Actual subject enrollment as a percentage of the planned enrollment target for the assessment period. Significant under-enrollment is a KRI that may indicate site performance issues.' ;
    rdfs:domain ind:SiteRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kriBreachesCount rdf:type rdf:Property ;
    rdfs:label 'Kri Breaches Count' ;
    rdfs:comment 'Total number of individual Key Risk Indicators (KRIs) that exceeded their defined threshold limits during the assessment period. A key input to the overall risk score calculation.' ;
    rdfs:domain ind:SiteRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:majorProtocolDeviationCount rdf:type rdf:Property ;
    rdfs:label 'Major Protocol Deviation Count' ;
    rdfs:comment 'Number of major (significant) protocol deviations recorded at the site during the assessment period. Major deviations may affect subject safety or data integrity and are a high-weight KRI.' ;
    rdfs:domain ind:SiteRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outstandingQueriesCount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Queries Count' ;
    rdfs:comment 'Number of open, unresolved data queries in the EDC system (Medidata Rave) at the end of the assessment period. Reflects site responsiveness and data management performance.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallRiskScore rdf:type rdf:Property ;
    rdfs:label 'Overall Risk Score' ;
    rdfs:comment 'Composite numeric risk score for the site calculated from weighted Key Risk Indicator (KRI) values. Higher scores indicate greater risk. Used to determine risk tier classification and adaptive monitoring intensity.' ;
    rdfs:domain ind:SiteRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousRiskScore rdf:type rdf:Property ;
    rdfs:label 'Previous Risk Score' ;
    rdfs:comment 'Overall risk score from the immediately preceding assessment cycle. Enables trend analysis and score delta calculation to detect improving or deteriorating site performance.' ;
    rdfs:domain ind:SiteRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousRiskTier rdf:type rdf:Property ;
    rdfs:label 'Previous Risk Tier' ;
    rdfs:comment 'Risk tier assigned during the immediately preceding assessment cycle. Used to identify tier escalations or de-escalations and trigger CAPA workflows when a site moves to a higher risk tier.' ;
    rdfs:domain ind:SiteRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queryRatePercent rdf:type rdf:Property ;
    rdfs:label 'Query Rate Percent' ;
    rdfs:comment 'Percentage of Electronic Case Report Form (eCRF) fields that generated data queries during the assessment period. High query rates indicate data quality issues and are a primary KRI in the RBM framework.' ;
    rdfs:domain ind:SiteRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedMonitoringIntensity rdf:type rdf:Property ;
    rdfs:label 'Recommended Monitoring Intensity' ;
    rdfs:comment 'Assessor\'s recommendation for adjusting the monitoring visit frequency and SDV scope based on the current risk tier and KRI findings. Drives adaptive monitoring plan updates in Oracle Siebel CTMS.' ;
    rdfs:domain ind:SiteRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedSdvScopePercent rdf:type rdf:Property ;
    rdfs:label 'Recommended Sdv Scope Percent' ;
    rdfs:comment 'Recommended percentage of eCRF data fields to be subject to Source Data Verification (SDV) in the next monitoring cycle, adjusted based on the current risk tier.' ;
    rdfs:domain ind:SiteRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedVisitFrequency rdf:type rdf:Property ;
    rdfs:label 'Recommended Visit Frequency' ;
    rdfs:comment 'Specific recommended visit frequency for the next monitoring cycle, derived from the risk tier and monitoring intensity recommendation. Used to update the site monitoring schedule in Oracle Siebel CTMS.' ;
    rdfs:domain ind:SiteRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Notes' ;
    rdfs:comment 'Free-text narrative field capturing the assessor\'s qualitative observations, contextual factors, and rationale for the risk score and recommended monitoring adjustments not captured by structured KRI fields.' ;
    rdfs:domain ind:SiteRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskManagementPlanVersion rdf:type rdf:Property ;
    rdfs:label 'Risk Management Plan Version' ;
    rdfs:comment 'Version identifier of the study-level Risk Management Plan (RMP) under which this assessment was conducted. Ensures traceability of KRI thresholds and scoring methodology to the applicable plan version.' ;
    rdfs:domain ind:SiteRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenFailureRatePercent rdf:type rdf:Property ;
    rdfs:label 'Screen Failure Rate Percent' ;
    rdfs:comment 'Percentage of screened subjects who failed to meet eligibility criteria and were not enrolled during the assessment period. Elevated screen failure rates are a KRI for patient recruitment quality.' ;
    rdfs:domain ind:SiteRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sdvCompletionPercent rdf:type rdf:Property ;
    rdfs:label 'Sdv Completion Percent' ;
    rdfs:comment 'Percentage of Source Data Verification (SDV) tasks completed against the planned SDV scope for the assessment period. Reflects monitoring coverage and data integrity assurance.' ;
    rdfs:domain ind:SiteRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subjectDropoutRatePercent rdf:type rdf:Property ;
    rdfs:label 'Subject Dropout Rate Percent' ;
    rdfs:comment 'Percentage of enrolled subjects who discontinued participation during the assessment period. High dropout rates are a KRI that may indicate site management or patient engagement issues.' ;
    rdfs:domain ind:SiteRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visitChecklistId rdf:type rdf:Property ;
    rdfs:label 'Visit Checklist Id' ;
    rdfs:comment 'Primary key for visit_checklist' ;
    rdfs:domain ind:VisitChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checklistItemId rdf:type rdf:Property ;
    rdfs:label 'Checklist Item Id' ;
    rdfs:comment 'Reference to the specific checklist item definition (e.g., regulatory binder review, ICF verification, IP accountability) from the template. Each row in this product represents one item completion record.' ;
    rdfs:domain ind:Monitoring ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChecklistItem .

ind:primaryVisitEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Visit Employee Id' ;
    rdfs:comment 'Reference to the Clinical Research Associate (CRA) who executed and signed off on this monitoring checklist during the visit.' ;
    rdfs:domain ind:Monitoring ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionRequired rdf:type rdf:Property ;
    rdfs:label 'Action Required' ;
    rdfs:comment 'Indicates whether a follow-up action item has been raised for this checklist item (True) due to a finding or non-compliance. Triggers action item creation workflow in Oracle Siebel CTMS.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistNumber rdf:type rdf:Property ;
    rdfs:label 'Checklist Number' ;
    rdfs:comment 'Externally-known business identifier for the checklist record, typically generated by Oracle Siebel CTMS (e.g., CHK-2024-00123). Used for cross-system reference and audit trail.' ;
    rdfs:domain ind:VisitChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistStatus rdf:type rdf:Property ;
    rdfs:label 'Checklist Status' ;
    rdfs:comment 'Current lifecycle status of the overall monitoring checklist record. Tracks progression from initial creation through CRA sign-off. \'void\' indicates the checklist was invalidated (e.g., visit cancelled).' ;
    rdfs:domain ind:VisitChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistVersion rdf:type rdf:Property ;
    rdfs:label 'Checklist Version' ;
    rdfs:comment 'Version identifier of the checklist template used for this visit instance (e.g., \'v3.1\'). Versioned per SOP updates managed in MasterControl. Ensures the correct template version is applied per effective date.' ;
    rdfs:domain ind:VisitChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:craComment rdf:type rdf:Property ;
    rdfs:label 'Cra Comment' ;
    rdfs:comment 'Free-text comment entered by the CRA for this checklist item, capturing observations, context, or follow-up notes that do not constitute a formal finding. Supports inspection readiness and knowledge transfer.' ;
    rdfs:domain ind:VisitChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:craSignoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cra Signoff Timestamp' ;
    rdfs:comment 'Date and time at which the CRA electronically signed off on this checklist item or the overall checklist, per 21 CFR Part 11 electronic signature requirements. Captures the precise moment of attestation.' ;
    rdfs:domain ind:VisitChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:findingSeverity rdf:type rdf:Property ;
    rdfs:label 'Finding Severity' ;
    rdfs:comment 'Severity classification of any finding identified during assessment of this checklist item. Aligns with GCP inspection-readiness severity tiers. \'none\' when item is compliant.' ;
    rdfs:domain ind:VisitChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isApplicable rdf:type rdf:Property ;
    rdfs:label 'Is Applicable' ;
    rdfs:comment 'Indicates whether this checklist item is applicable for the specific visit instance (True) or has been marked not applicable (N/A) by the CRA with justification. Supports conditional checklist logic.' ;
    rdfs:domain ind:VisitChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemCategory rdf:type rdf:Property ;
    rdfs:label 'Item Category' ;
    rdfs:comment 'Functional category of the checklist item being assessed. Groups items for reporting and compliance tracking. [ENUM-REF-CANDIDATE: regulatory_binder|icf_compliance|ip_accountability|ecrf_data_entry|safety_reporting|lab_samples|site_staff|tmf_documents|protocol_adherence|subject_eligibility — promote to reference product]' ;
    rdfs:domain ind:VisitChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Item Completed Date' ;
    rdfs:comment 'Date on which the CRA completed the assessment of this specific checklist item. May differ from visit_date for multi-day visits or remote follow-up assessments. Supports ALCOA+ contemporaneous documentation.' ;
    rdfs:domain ind:VisitChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:itemDescription rdf:type rdf:Property ;
    rdfs:label 'Item Description' ;
    rdfs:comment 'Detailed description of what the CRA must verify or perform for this checklist item, including acceptance criteria and reference to applicable SOP or regulatory requirement.' ;
    rdfs:domain ind:VisitChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemName rdf:type rdf:Property ;
    rdfs:label 'Item Name' ;
    rdfs:comment 'Human-readable name of the specific checklist item being assessed (e.g., \'Regulatory Binder Current\', \'ICF Version Verification\', \'IP Accountability Log Review\'). Sourced from the checklist template.' ;
    rdfs:domain ind:VisitChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemSequence rdf:type rdf:Property ;
    rdfs:label 'Item Sequence' ;
    rdfs:comment 'Ordinal sequence number of this checklist item within its category, defining the display and execution order for the CRA during the monitoring visit. Sourced from the checklist template definition.' ;
    rdfs:domain ind:VisitChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rbmTriggered rdf:type rdf:Property ;
    rdfs:label 'Rbm Triggered' ;
    rdfs:comment 'Indicates whether this checklist item was triggered or prioritized by the risk-based monitoring (RBM) strategy (True), as opposed to being a standard routine item. Supports RBM effectiveness reporting.' ;
    rdfs:domain ind:VisitChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdvPerformed rdf:type rdf:Property ;
    rdfs:label 'Sdv Performed' ;
    rdfs:comment 'Indicates whether Source Data Verification (SDV) was performed as part of this checklist item assessment (True). Relevant for eCRF and data entry checklist items under risk-based monitoring (RBM) strategies.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisorReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Supervisor Review Timestamp' ;
    rdfs:comment 'Date and time at which the CRA supervisor or line manager reviewed and approved the completed checklist. Supports quality oversight and two-level sign-off workflows per GCP requirements.' ;
    rdfs:domain ind:VisitChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:visitDeviationFindingId rdf:type rdf:Property ;
    rdfs:label 'Visit Deviation Finding Id' ;
    rdfs:comment 'Unique surrogate identifier for each protocol deviation finding record captured during monitoring or data review activities in Oracle Siebel CTMS.' ;
    rdfs:domain ind:VisitDeviationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eligibilityCriterionId rdf:type rdf:Property ;
    rdfs:label 'Eligibility Criterion Id' ;
    rdfs:comment 'Foreign key linking to study.eligibility_criterion. Business justification: IE criteria violations are among the most serious protocol deviations tracked in visit_deviation_finding. Linking to eligibility_criterion enables structured CAPA tracking, IRB/IEC reportability deter' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EligibilityCriterion .

ind:subjectDeviationId rdf:type rdf:Property ;
    rdfs:label 'Subject Deviation Id' ;
    rdfs:comment 'Foreign key linking to subject.subject_deviation. Business justification: Monitoring-identified deviation findings must be reconciled with subject-level deviation records for CAPA tracking and regulatory reporting (ICH E6 R2). Linking visit_deviation_finding to subject_devi' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SubjectDeviation .

ind:classificationType rdf:type rdf:Property ;
    rdfs:label 'Classification Type' ;
    rdfs:comment 'Indicates whether the deviation was identified and approved prospectively (before the deviation occurred, as a planned exception) or retrospectively (after the deviation occurred). Prospective deviations may be pre-approved by the sponsor or IRB/IEC; retrospective deviations require post-hoc review.' ;
    rdfs:domain ind:VisitDeviationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'The method by which the protocol deviation was identified. Supports risk-based monitoring (RBM) effectiveness analysis and helps identify whether centralized monitoring or on-site monitoring is more effective at detecting specific deviation types.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identificationDate rdf:type rdf:Property ;
    rdfs:label 'Identification Date' ;
    rdfs:comment 'The calendar date on which the protocol deviation was first identified, either during an on-site monitoring visit, remote monitoring review, or data management query. Used to calculate detection lag and reporting deadline compliance.' ;
    rdfs:domain ind:VisitDeviationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identifiedBy rdf:type rdf:Property ;
    rdfs:label 'Identified By' ;
    rdfs:comment 'Name or role identifier of the person who identified the protocol deviation (e.g., CRA name, data manager, site staff). Supports accountability tracking and ALCOA+ attributability requirements.' ;
    rdfs:domain ind:VisitDeviationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbIecReportDate rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Report Date' ;
    rdfs:comment 'The date on which the protocol deviation was formally reported to the Institutional Review Board (IRB) or Independent Ethics Committee (IEC). Null if irb_iec_reportable is False or reporting is pending.' ;
    rdfs:domain ind:VisitDeviationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryAuthorityReportable rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Reportable' ;
    rdfs:comment 'Indicates whether this deviation must be reported to a regulatory authority (e.g., FDA, EMA, MHRA, PMDA) as an important protocol deviation (IPD) or substantial protocol amendment trigger. Applies primarily to major deviations affecting subject safety.' ;
    rdfs:domain ind:VisitDeviationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdtmDvCategory rdf:type rdf:Property ;
    rdfs:label 'Sdtm Dv Category' ;
    rdfs:comment 'The CDISC SDTM DV domain category (DVCAT) for the deviation, used for regulatory submission dataset classification. Populated during CDISC data transformation in SAS Drug Development for NDA/BLA/MAA submissions.' ;
    rdfs:domain ind:VisitDeviationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmDvTerm rdf:type rdf:Property ;
    rdfs:label 'Sdtm Dv Term' ;
    rdfs:comment 'The standardized CDISC SDTM DV domain term (DVTERM) describing the deviation, used for regulatory submission datasets. Enables direct mapping to SDTM DV domain for NDA/BLA/MAA submissions processed through SAS Drug Development.' ;
    rdfs:domain ind:VisitDeviationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorReportDate rdf:type rdf:Property ;
    rdfs:label 'Sponsor Report Date' ;
    rdfs:comment 'The date on which the protocol deviation was formally reported to the study sponsor. Null if sponsor_reportable is False or reporting is pending. Used to track compliance with sponsor notification timelines.' ;
    rdfs:domain ind:VisitDeviationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sponsorReportable rdf:type rdf:Property ;
    rdfs:label 'Sponsor Reportable' ;
    rdfs:comment 'Indicates whether this deviation must be formally reported to the study sponsor per the Clinical Trial Agreement (CTA) and sponsor SOPs. All major deviations and important protocol deviations (IPDs) are typically sponsor-reportable.' ;
    rdfs:domain ind:VisitDeviationFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalFindingVisitFindingId rdf:type rdf:Property ;
    rdfs:label 'Original Finding Visit Finding Id' ;
    rdfs:comment 'Reference to the original finding record when this finding is a repeat or recurrence. Enables lineage tracking of recurring issues across multiple monitoring visits at the same site. Null if this is not a repeat finding.' ;
    rdfs:domain ind:VisitFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VisitFinding .

ind:temperatureExcursionId rdf:type rdf:Property ;
    rdfs:label 'Temperature Excursion Id' ;
    rdfs:comment 'Foreign key linking to supply.temperature_excursion. Business justification: When a CRA identifies an IP storage finding during a monitoring visit, the visit_finding record must reference the specific temperature_excursion record for CAPA traceability and regulatory reporting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TemperatureExcursion .

ind:craVerificationComment rdf:type rdf:Property ;
    rdfs:label 'Cra Verification Comment' ;
    rdfs:comment 'Narrative comment entered by the CRA when verifying the adequacy of the site\'s corrective action. Documents the CRA\'s assessment of whether the resolution is satisfactory and the finding can be closed.' ;
    rdfs:domain ind:VisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingSubcategory rdf:type rdf:Property ;
    rdfs:label 'Finding Subcategory' ;
    rdfs:comment 'Granular sub-classification within the finding category providing more specific context (e.g., \'missing source document\', \'late SAE reporting\', \'temperature excursion\', \'unsigned ICF\'). Supports detailed root cause analysis and CAPA trending.' ;
    rdfs:domain ind:VisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveAction rdf:type rdf:Property ;
    rdfs:label 'Preventive Action' ;
    rdfs:comment 'Description of the preventive measures implemented or planned to prevent recurrence of this finding. Captured as part of the CAPA workflow and documented in the monitoring visit report follow-up.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedDate rdf:type rdf:Property ;
    rdfs:label 'Resolved Date' ;
    rdfs:comment 'The actual date on which the finding was resolved and the corrective action was verified as complete by the CRA. Null if the finding has not yet been resolved. Used to calculate resolution cycle time for KPI reporting.' ;
    rdfs:domain ind:VisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sdvCompleted rdf:type rdf:Property ;
    rdfs:label 'Sdv Completed' ;
    rdfs:comment 'Indicates whether the required Source Data Verification (SDV) for this finding has been completed by the CRA. Applicable only when sdv_required is True.' ;
    rdfs:domain ind:VisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siteResponse rdf:type rdf:Property ;
    rdfs:label 'Site Response' ;
    rdfs:comment 'Narrative response provided by the site (Principal Investigator or Clinical Research Coordinator) acknowledging the finding and describing the corrective actions taken or planned. Captured in the CTMS and included in the monitoring visit report.' ;
    rdfs:domain ind:VisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteResponseDate rdf:type rdf:Property ;
    rdfs:label 'Site Response Date' ;
    rdfs:comment 'The date on which the site provided its formal response to the finding. Used to measure site responsiveness and compliance with response timelines defined in the monitoring plan.' ;
    rdfs:domain ind:VisitFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionItemsOutstandingCount rdf:type rdf:Property ;
    rdfs:label 'Action Items Outstanding Count' ;
    rdfs:comment 'Number of action items from previous monitoring visit reports that remain unresolved at the time of this visit. Key indicator of site compliance and follow-up effectiveness.' ;
    rdfs:domain ind:VisitReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionItemsRaisedCount rdf:type rdf:Property ;
    rdfs:label 'Action Items Raised Count' ;
    rdfs:comment 'Total number of action items raised in this monitoring visit report requiring follow-up by the site or sponsor. Drives escalation workflows in the CTMS.' ;
    rdfs:domain ind:VisitReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:craSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cra Signature Timestamp' ;
    rdfs:comment 'Timestamp of the CRA\'s electronic signature on the monitoring visit report, confirming authorship and accuracy of the report content. Required for 21 CFR Part 11 compliant electronic records.' ;
    rdfs:domain ind:VisitReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:icfReviewConducted rdf:type rdf:Property ;
    rdfs:label 'Icf Review Conducted' ;
    rdfs:comment 'Indicates whether the CRA reviewed Informed Consent Form (ICF) processes and documentation for enrolled subjects during this monitoring visit. Critical GCP compliance check.' ;
    rdfs:domain ind:VisitReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipAccountabilityReviewed rdf:type rdf:Property ;
    rdfs:label 'Ip Accountability Reviewed' ;
    rdfs:comment 'Indicates whether the CRA reviewed investigational product (IP) accountability records, including dispensing logs, return records, and storage conditions, during this monitoring visit.' ;
    rdfs:domain ind:VisitReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipStorageCompliant rdf:type rdf:Property ;
    rdfs:label 'Ip Storage Compliant' ;
    rdfs:comment 'Indicates whether investigational product (IP) storage conditions (temperature, security, labeling) were found to be compliant with protocol and regulatory requirements during this visit.' ;
    rdfs:domain ind:VisitReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labSamplesReviewed rdf:type rdf:Property ;
    rdfs:label 'Lab Samples Reviewed' ;
    rdfs:comment 'Indicates whether the CRA reviewed laboratory sample collection, processing, storage, and shipment records during this monitoring visit.' ;
    rdfs:domain ind:VisitReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextVisitRecommendedDate rdf:type rdf:Property ;
    rdfs:label 'Next Visit Recommended Date' ;
    rdfs:comment 'CRA\'s recommended date for the next monitoring visit based on site risk assessment, enrollment activity, and outstanding issues identified during this visit. Supports monitoring schedule planning in the CTMS.' ;
    rdfs:domain ind:VisitReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openQueriesCount rdf:type rdf:Property ;
    rdfs:label 'Open Queries Count' ;
    rdfs:comment 'Number of data queries outstanding (open) in the EDC system at the time of the monitoring visit. Reflects data quality status and site responsiveness.' ;
    rdfs:domain ind:VisitReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:protocolDeviationSeverity rdf:type rdf:Property ;
    rdfs:label 'Protocol Deviation Severity' ;
    rdfs:comment 'Highest severity level of protocol deviations identified during this monitoring visit. Determines escalation requirements and regulatory reporting obligations.' ;
    rdfs:domain ind:VisitReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queriesRaisedCount rdf:type rdf:Property ;
    rdfs:label 'Queries Raised Count' ;
    rdfs:comment 'Number of new data queries raised by the CRA during this monitoring visit. Supports EDC query management tracking and site data quality metrics.' ;
    rdfs:domain ind:VisitReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:queriesResolvedCount rdf:type rdf:Property ;
    rdfs:label 'Queries Resolved Count' ;
    rdfs:comment 'Number of previously open data queries resolved during or as a result of this monitoring visit. Tracks site responsiveness and data cleaning progress.' ;
    rdfs:domain ind:VisitReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryDocumentsReviewed rdf:type rdf:Property ;
    rdfs:label 'Regulatory Documents Reviewed' ;
    rdfs:comment 'Indicates whether the CRA reviewed the site\'s regulatory binder (including IRB/IEC approvals, investigator CVs, and delegation logs) during this monitoring visit.' ;
    rdfs:domain ind:VisitReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Report Approved Date' ;
    rdfs:comment 'The date on which the CRA supervisor or Clinical Trial Manager formally approved the monitoring visit report. Marks the report as finalized for eTMF filing.' ;
    rdfs:domain ind:VisitReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportAuthoredDate rdf:type rdf:Property ;
    rdfs:label 'Report Authored Date' ;
    rdfs:comment 'The date on which the CRA completed authoring the monitoring visit report. Regulatory guidelines require reports to be issued within a defined number of days post-visit; this field enables compliance tracking.' ;
    rdfs:domain ind:VisitReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sdvCoveragePercent rdf:type rdf:Property ;
    rdfs:label 'Sdv Coverage Percent' ;
    rdfs:comment 'Percentage of eligible data points or subjects for which SDV was completed during this visit. Reflects the Risk-Based Monitoring (RBM) strategy applied and supports regulatory audit readiness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sdvDiscrepanciesFound rdf:type rdf:Property ;
    rdfs:label 'Sdv Discrepancies Found' ;
    rdfs:comment 'Number of discrepancies identified between source documents and electronic Case Report Form (eCRF) data entries during SDV activities. Key quality metric for data integrity assessment.' ;
    rdfs:domain ind:VisitReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sdvSourceDocumentsReviewed rdf:type rdf:Property ;
    rdfs:label 'Sdv Source Documents Reviewed' ;
    rdfs:comment 'Number of source documents reviewed during Source Data Verification (SDV) activities conducted during this monitoring visit. Supports SDV coverage reporting and risk-based monitoring metrics.' ;
    rdfs:domain ind:VisitReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteOverallRating rdf:type rdf:Property ;
    rdfs:label 'Site Overall Rating' ;
    rdfs:comment 'CRA\'s overall qualitative rating of the site\'s performance and GCP compliance as assessed during this monitoring visit. Used for risk-based monitoring (RBM) strategy adjustments and escalation decisions.' ;
    rdfs:domain ind:VisitReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectsActiveCount rdf:type rdf:Property ;
    rdfs:label 'Subjects Active Count' ;
    rdfs:comment 'Number of subjects currently active (on-study) at the site at the time of the monitoring visit. Supports site workload assessment and monitoring frequency planning.' ;
    rdfs:domain ind:VisitReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subjectsCompletedCount rdf:type rdf:Property ;
    rdfs:label 'Subjects Completed Count' ;
    rdfs:comment 'Number of subjects who have completed the study at the site as of the visit date. Used for site performance reporting and study progress tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subjectsDiscontinuedCount rdf:type rdf:Property ;
    rdfs:label 'Subjects Discontinued Count' ;
    rdfs:comment 'Number of subjects who have discontinued from the study at the site as of the visit date. Supports dropout rate analysis and protocol deviation investigation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subjectsEnrolledCount rdf:type rdf:Property ;
    rdfs:label 'Subjects Enrolled Count' ;
    rdfs:comment 'Total number of subjects enrolled at the site as of the visit date. Captured in the visit report to track enrollment progress against site targets.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subjectsScreenedCount rdf:type rdf:Property ;
    rdfs:label 'Subjects Screened Count' ;
    rdfs:comment 'Total number of subjects screened at the site as of the visit date. Used to calculate screen failure rates and assess site recruitment performance.' ;
    rdfs:domain ind:VisitReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supervisorSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Supervisor Signature Timestamp' ;
    rdfs:comment 'Timestamp of the CRA supervisor\'s electronic signature on the monitoring visit report, confirming review and approval. Required for 21 CFR Part 11 compliant electronic records and eTMF filing.' ;
    rdfs:domain ind:VisitReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:visitEndDate rdf:type rdf:Property ;
    rdfs:label 'Visit End Date' ;
    rdfs:comment 'The date on which the monitoring visit concluded. Populated for multi-day visits to capture total visit duration. Used for resource planning and visit effort reporting.' ;
    rdfs:domain ind:VisitReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:visitReportNumber rdf:type rdf:Property ;
    rdfs:label 'Visit Report Number' ;
    rdfs:comment 'Externally-known, human-readable identifier for the monitoring visit report as assigned by the Clinical Trial Management System (CTMS) or eTMF. Used for cross-system reference and regulatory traceability (e.g., MVR-2024-0042).' ;
    rdfs:domain ind:VisitReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitSummaryNarrative rdf:type rdf:Property ;
    rdfs:label 'Visit Summary Narrative' ;
    rdfs:comment 'Free-text narrative summary authored by the CRA describing the overall conduct of the monitoring visit, key observations, site status, and general impressions. Core content of the monitoring visit report per GCP requirements.' ;
    rdfs:domain ind:VisitReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringVisitScheduleId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Visit Schedule Id' ;
    rdfs:comment 'Unique surrogate identifier for the planned monitoring visit schedule record within Oracle Siebel CTMS.' ;
    rdfs:domain ind:MonitoringVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linkedMonitoringVisitId rdf:type rdf:Property ;
    rdfs:label 'Linked Monitoring Visit Id' ;
    rdfs:comment 'Reference to the actual monitoring visit record created when this scheduled visit is executed. Null until the visit is initiated. Enables traceability from plan to execution.' ;
    rdfs:domain ind:MonitoringVisitSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MonitoringVisit .

ind:rescheduledFromMonitoringVisitScheduleId rdf:type rdf:Property ;
    rdfs:label 'Rescheduled From Monitoring Visit Schedule Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original visit schedule record from which this record was rescheduled. Enables audit trail of rescheduling history.' ;
    rdfs:domain ind:MonitoringVisitSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MonitoringVisitSchedule .

ind:ctmsScheduleRef rdf:type rdf:Property ;
    rdfs:label 'Ctms Schedule Ref' ;
    rdfs:comment 'The native record identifier or reference number for this visit schedule as stored in Oracle Siebel CTMS. Used for cross-system reconciliation between the lakehouse silver layer and the source CTMS.' ;
    rdfs:domain ind:MonitoringVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentTriggerCount rdf:type rdf:Property ;
    rdfs:label 'Enrollment Trigger Count' ;
    rdfs:comment 'The cumulative number of subjects enrolled at the site that triggers this visit when scheduling_basis is Enrollment-Based (e.g., visit triggered after every 5 subjects enrolled).' ;
    rdfs:domain ind:MonitoringVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Frequency Interval Days' ;
    rdfs:comment 'The number of days between consecutive monitoring visits as defined in the monitoring plan. Drives calendar-based scheduling and CRA workload forecasting. Null for non-calendar-based visits.' ;
    rdfs:domain ind:MonitoringVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isOverdue rdf:type rdf:Property ;
    rdfs:label 'Is Overdue' ;
    rdfs:comment 'Indicates whether the planned monitoring visit has passed its window_latest_date without being completed or rescheduled. Used for escalation tracking and site risk assessment.' ;
    rdfs:domain ind:MonitoringVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRbmTriggered rdf:type rdf:Property ;
    rdfs:label 'Is Rbm Triggered' ;
    rdfs:comment 'Indicates whether this visit was triggered by the Risk-Based Monitoring (RBM) system (e.g., KRI breach, centralized monitoring signal) rather than by a pre-set calendar schedule.' ;
    rdfs:domain ind:MonitoringVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Notification Due Date' ;
    rdfs:comment 'The date by which the site (Principal Investigator and Clinical Research Coordinator) must be notified of the upcoming monitoring visit, per the monitoring plan\'s advance notice requirements.' ;
    rdfs:domain ind:MonitoringVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Date' ;
    rdfs:comment 'The actual date on which the visit notification was sent to the investigational site. Used to verify compliance with advance notice requirements in the monitoring plan.' ;
    rdfs:domain ind:MonitoringVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedDurationDays rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Days' ;
    rdfs:comment 'The expected duration of the monitoring visit in days as planned in the monitoring schedule. Used for CRA capacity planning and resource allocation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedVisitDate rdf:type rdf:Property ;
    rdfs:label 'Planned Visit Date' ;
    rdfs:comment 'The target calendar date on which the monitoring visit is planned to occur, representing the principal business event date for scheduling and CRA workload forecasting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reschedulingReason rdf:type rdf:Property ;
    rdfs:label 'Rescheduling Reason' ;
    rdfs:comment 'Free-text explanation for why the planned monitoring visit was rescheduled. Required when schedule_status is \'Rescheduled\'. Supports audit and compliance review.' ;
    rdfs:domain ind:MonitoringVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Number' ;
    rdfs:comment 'Externally-known business identifier for this visit schedule record as assigned in Oracle Siebel CTMS (e.g., VS-2024-0042). Used for cross-system reference and audit trail.' ;
    rdfs:domain ind:MonitoringVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingBasis rdf:type rdf:Property ;
    rdfs:label 'Scheduling Basis' ;
    rdfs:comment 'The basis or rationale used to determine when this visit should occur: Calendar-Based (fixed interval), Risk-Based Trigger (driven by KRI/risk indicator breach), Milestone-Based (linked to study milestone such as first patient enrolled), Enrollment-Based (triggered by subject enrollment count), or Regulatory-Required (mandated by regulatory authority).' ;
    rdfs:domain ind:MonitoringVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdvTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Sdv Target Percentage' ;
    rdfs:comment 'The planned percentage of source data to be verified during this monitoring visit as defined in the monitoring plan. Reflects the risk-based SDV strategy for this visit.' ;
    rdfs:domain ind:MonitoringVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'The username or system account identifier of the user who last modified this visit schedule record in Oracle Siebel CTMS. Required for audit trail per 21 CFR Part 11 and ALCOA+ (Attributable).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitObjectives rdf:type rdf:Property ;
    rdfs:label 'Visit Objectives' ;
    rdfs:comment 'Free-text description of the specific objectives and scope of work planned for this monitoring visit, as defined in the monitoring plan or visit notification (e.g., ICF review, IP accountability, protocol deviation follow-up).' ;
    rdfs:domain ind:MonitoringVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Visit Sequence Number' ;
    rdfs:comment 'Sequential ordinal number of this planned visit within the site\'s monitoring schedule for the study (e.g., 1 = first interim visit, 2 = second interim visit). Used for ordering and CRA workload planning.' ;
    rdfs:domain ind:MonitoringVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windowEarliestDate rdf:type rdf:Property ;
    rdfs:label 'Window Earliest Date' ;
    rdfs:comment 'The earliest acceptable date on which the monitoring visit may be conducted while still satisfying the monitoring plan window requirements. Used to define the permissible scheduling window.' ;
    rdfs:domain ind:MonitoringVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:windowLatestDate rdf:type rdf:Property ;
    rdfs:label 'Window Latest Date' ;
    rdfs:comment 'The latest acceptable date on which the monitoring visit may be conducted while still satisfying the monitoring plan window requirements. Visits beyond this date are considered overdue.' ;
    rdfs:domain ind:MonitoringVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:windowToleranceDays rdf:type rdf:Property ;
    rdfs:label 'Window Tolerance Days' ;
    rdfs:comment 'The number of days of allowable deviation on either side of the planned visit date that defines the acceptable scheduling window (e.g., ±14 days). Used to compute window_earliest_date and window_latest_date.' ;
    rdfs:domain ind:MonitoringVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:medicalMonitorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Medical Monitor Employee Id' ;
    rdfs:comment 'Reference to the qualified physician or medical officer responsible for medical oversight and safety monitoring across all studies within this clinical development program.' ;
    rdfs:domain ind:ClinicalProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:breakthroughTherapyDesignation rdf:type rdf:Property ;
    rdfs:label 'Breakthrough Therapy Designation' ;
    rdfs:comment 'Indicates whether the FDA has granted Breakthrough Therapy Designation (BTD) to the investigational product under this program. BTD expedites development and review of drugs for serious conditions. True = designation granted.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetCurrency rdf:type rdf:Property ;
    rdfs:label 'Budget Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the program budget (e.g., USD, EUR, GBP). Required for multi-currency financial reporting and SAP S/4HANA integration.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalProgramDescription rdf:type rdf:Property ;
    rdfs:label 'Clinical Program Description' ;
    rdfs:comment 'Free-text narrative description of the clinical development program\'s scientific rationale, strategic objectives, and key development hypotheses. Used in portfolio governance documents, regulatory strategy briefs, and sponsor communications.' ;
    rdfs:domain ind:ClinicalProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentPhase rdf:type rdf:Property ;
    rdfs:label 'Development Phase' ;
    rdfs:comment 'Current or primary clinical development phase of the program per ICH E8 classification (Phase I through Phase IV). Drives regulatory strategy, resource planning, and portfolio governance decisions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsmbRequired rdf:type rdf:Property ;
    rdfs:label 'Dsmb Required' ;
    rdfs:comment 'Indicates whether a Data Safety Monitoring Board (DSMB) or Data Monitoring Committee (DMC) is required for this clinical development program based on risk profile, study design, or regulatory requirements. True = DSMB/DMC required.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fastTrackDesignation rdf:type rdf:Property ;
    rdfs:label 'Fast Track Designation' ;
    rdfs:comment 'Indicates whether the FDA has granted Fast Track Designation to the investigational product under this program, facilitating development and expediting review for serious conditions with unmet medical need. True = designation granted.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:globalStudyCount rdf:type rdf:Property ;
    rdfs:label 'Global Study Count' ;
    rdfs:comment 'Total number of individual clinical studies (trials) planned or active under this clinical development program. Provides a program-level scope indicator for portfolio governance and resource planning.' ;
    rdfs:domain ind:ClinicalProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modality rdf:type rdf:Property ;
    rdfs:label 'Modality' ;
    rdfs:comment 'Scientific modality or drug class of the investigational product (e.g., Small Molecule, Biologic, Cell Therapy, Gene Therapy). Determines applicable regulatory guidelines, manufacturing requirements, and safety monitoring frameworks. [ENUM-REF-CANDIDATE: Small Molecule|Biologic|Cell Therapy|Gene Therapy|Oligonucleotide|Vaccine|Combination — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orphanDrugDesignation rdf:type rdf:Property ;
    rdfs:label 'Orphan Drug Designation' ;
    rdfs:comment 'Indicates whether the investigational product has received Orphan Drug Designation (ODD) from FDA or EMA for a rare disease indication under this program. Confers market exclusivity and development incentives. True = designation granted.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pediatricInvestigationPlan rdf:type rdf:Property ;
    rdfs:label 'Pediatric Investigation Plan' ;
    rdfs:comment 'Indicates whether a Pediatric Investigation Plan (PIP) has been agreed with EMA or a Pediatric Study Plan (PSP) with FDA for this program. Required for most new medicinal products under EU Pediatric Regulation and FDA PREA.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portfolioPriority rdf:type rdf:Property ;
    rdfs:label 'Portfolio Priority' ;
    rdfs:comment 'Strategic priority ranking of the clinical development program within the sponsor\'s pipeline portfolio. Used for resource allocation, investment decisions, and executive portfolio governance reviews.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primeDesignation rdf:type rdf:Property ;
    rdfs:label 'Prime Designation' ;
    rdfs:comment 'Indicates whether the EMA has granted PRIority MEdicines (PRIME) designation to the investigational product under this program, providing enhanced support for development of medicines that target unmet medical needs. True = designation granted.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programBudget rdf:type rdf:Property ;
    rdfs:label 'Program Budget' ;
    rdfs:comment 'Total approved budget allocated to the clinical development program across all studies and activities, expressed in the program\'s base currency. Used for financial governance, variance tracking, and portfolio investment reporting.' ;
    rdfs:domain ind:ClinicalProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Sponsor-assigned alphanumeric code uniquely identifying the clinical development program across all internal systems (CTMS, eTMF, EDC). Serves as the externally-known business identifier referenced in regulatory submissions and cross-system integrations.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programShortName rdf:type rdf:Property ;
    rdfs:label 'Program Short Name' ;
    rdfs:comment 'Abbreviated or working title for the clinical development program used in internal communications, reports, and dashboards where space is limited.' ;
    rdfs:domain ind:ClinicalProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStartDate rdf:type rdf:Property ;
    rdfs:label 'Program Start Date' ;
    rdfs:comment 'Official start date of the clinical development program, typically aligned with first IND/CTA filing or first-in-human study initiation. Used for program duration tracking and portfolio milestone reporting.' ;
    rdfs:domain ind:ClinicalProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle status of the clinical development program. \'Active\' indicates ongoing studies; \'On Hold\' indicates temporary suspension; \'Completed\' indicates all studies concluded; \'Terminated\' indicates early discontinuation; \'Planning\' indicates pre-initiation stage.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the program by disease area or regulatory pathway type (e.g., Oncology, Rare Disease, CNS, Cardiovascular, Infectious Disease, Pediatric, Biosimilar). Determines applicable regulatory frameworks and development strategies. [ENUM-REF-CANDIDATE: Oncology|Rare Disease|CNS|Cardiovascular|Infectious Disease|Pediatric|Biosimilar|Metabolic|Immunology|Gene Therapy — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectedEndDate rdf:type rdf:Property ;
    rdfs:label 'Projected End Date' ;
    rdfs:comment 'Anticipated completion date for the entire clinical development program, encompassing all studies through regulatory submission. Used for portfolio planning, resource forecasting, and milestone tracking.' ;
    rdfs:domain ind:ClinicalProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordVersion rdf:type rdf:Property ;
    rdfs:label 'Record Version' ;
    rdfs:comment 'Incrementing version number for the clinical program record, supporting optimistic concurrency control and change history tracking in the Databricks Silver Layer. Incremented on each update.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryStrategySummary rdf:type rdf:Property ;
    rdfs:label 'Regulatory Strategy Summary' ;
    rdfs:comment 'High-level narrative describing the regulatory development strategy for the program, including target submission pathways (NDA, BLA, MAA), key regulatory agency interactions, and any special designations (Breakthrough Therapy, Fast Track, Orphan Drug, PRIME). Classified as confidential due to competitive sensitivity.' ;
    rdfs:domain ind:ClinicalProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Target Submission Date' ;
    rdfs:comment 'Planned date for submission of the primary marketing authorization application (NDA/BLA/MAA) to the lead regulatory agency. Key portfolio milestone used for resource planning and executive reporting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetSubmissionType rdf:type rdf:Property ;
    rdfs:label 'Target Submission Type' ;
    rdfs:comment 'Type of regulatory marketing application targeted upon program completion (e.g., NDA - New Drug Application, BLA - Biologics License Application, MAA - Marketing Authorization Application). Drives regulatory strategy and submission planning.' ;
    rdfs:domain ind:ClinicalProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Code' ;
    rdfs:comment 'SAP S/4HANA Work Breakdown Structure (WBS) element code for the clinical program, enabling hierarchical project cost tracking, procurement, and financial reporting at the program level.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveIntelligenceId rdf:type rdf:Property ;
    rdfs:label 'Competitive Intelligence Id' ;
    rdfs:comment 'Unique surrogate identifier for each competitive intelligence record tracked at the program level.' ;
    rdfs:domain ind:CompetitiveIntelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Analyst Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Competitive intelligence analysts are named employees whose assignments are tracked for portfolio strategy reporting and workload management. assigned_analyst is a denormalized plain-text field; a FK ' ;
    rdfs:domain ind:CompetitiveIntelligence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedRegions rdf:type rdf:Property ;
    rdfs:label 'Approved Regions' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country or region codes where the competing asset has received marketing authorization (e.g., USA, GBR, JPN, AUS). Informs global competitive landscape assessment.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biomarkerStrategy rdf:type rdf:Property ;
    rdfs:label 'Biomarker Strategy' ;
    rdfs:comment 'Description of the competitor\'s biomarker selection or companion diagnostic strategy (e.g., PD-L1 expression, BRCA mutation, HER2 amplification). Informs the program\'s own biomarker-driven development strategy and TPP.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalTrialRegistryCode rdf:type rdf:Property ;
    rdfs:label 'Clinical Trial Registry Code' ;
    rdfs:comment 'Public clinical trial registry identifier for the competitor\'s pivotal or key study (e.g., ClinicalTrials.gov NCT number, EudraCT/EUCTR number). Enables direct cross-referencing with public trial data.' ;
    rdfs:domain ind:CompetitiveIntelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialThreatLevel rdf:type rdf:Property ;
    rdfs:label 'Commercial Threat Level' ;
    rdfs:comment 'Assessed level of commercial threat posed by the competing asset to the program\'s investigational product. Drives portfolio prioritization and investment decisions. Classified as confidential due to strategic sensitivity.' ;
    rdfs:domain ind:CompetitiveIntelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorAssetCode rdf:type rdf:Property ;
    rdfs:label 'Competitor Asset Code' ;
    rdfs:comment 'Internal development code or compound identifier for the competing asset (e.g., sponsor compound code, CAS number, or WHO INN code) as referenced in public registries.' ;
    rdfs:domain ind:CompetitiveIntelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorAssetName rdf:type rdf:Property ;
    rdfs:label 'Competitor Asset Name' ;
    rdfs:comment 'Brand name, International Nonproprietary Name (INN), or internal code name of the competing investigational or approved asset being tracked.' ;
    rdfs:domain ind:CompetitiveIntelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorCompanyName rdf:type rdf:Property ;
    rdfs:label 'Competitor Company Name' ;
    rdfs:comment 'Name of the pharmaceutical or biotech company developing the competing asset. Used to identify the competitive landscape at the sponsor level.' ;
    rdfs:domain ind:CompetitiveIntelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataReadoutDate rdf:type rdf:Property ;
    rdfs:label 'Data Readout Date' ;
    rdfs:comment 'Anticipated or actual date of key clinical data readout (e.g., pivotal trial top-line results, interim analysis) for the competing asset. Critical for program timeline planning and go/no-go decision windows.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryCode rdf:type rdf:Property ;
    rdfs:label 'Entry Code' ;
    rdfs:comment 'Unique business identifier code assigned to this competitive intelligence record, used for cross-referencing in program strategy documents and Target Product Profile (TPP) reviews.' ;
    rdfs:domain ind:CompetitiveIntelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goNoGoRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Go No Go Relevance Flag' ;
    rdfs:comment 'Indicates whether this competitive intelligence entry has been flagged as directly relevant to a program-level go/no-go decision. When True, the entry must be reviewed by the program governance committee.' ;
    rdfs:domain ind:CompetitiveIntelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:indicationOverlapDescription rdf:type rdf:Property ;
    rdfs:label 'Indication Overlap Description' ;
    rdfs:comment 'Narrative description of the degree and nature of therapeutic indication overlap between the competing asset and the program\'s investigational product. Supports TPP differentiation and regulatory strategy.' ;
    rdfs:domain ind:CompetitiveIntelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicationOverlapLevel rdf:type rdf:Property ;
    rdfs:label 'Indication Overlap Level' ;
    rdfs:comment 'Categorical assessment of how closely the competitor\'s target indication overlaps with the program\'s indication. Full = same patient population; Partial = overlapping subpopulation; Adjacent = related but distinct indication; None = no overlap.' ;
    rdfs:domain ind:CompetitiveIntelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intelligenceSourceName rdf:type rdf:Property ;
    rdfs:label 'Intelligence Source Name' ;
    rdfs:comment 'Specific name of the source from which this competitive intelligence was obtained (e.g., ASCO 2024 Annual Meeting, FDA Approval Letter, PubMed PMID 12345678, Bloomberg Intelligence Report). Supports traceability and ALCOA+ compliance.' ;
    rdfs:domain ind:CompetitiveIntelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intelligenceSourceType rdf:type rdf:Property ;
    rdfs:label 'Intelligence Source Type' ;
    rdfs:comment 'Category of the primary source from which this competitive intelligence was obtained. Supports source credibility assessment and ALCOA+ data provenance tracking. [ENUM-REF-CANDIDATE: public_registry|conference_abstract|publication|press_release|analyst_report|regulatory_filing|kol_interview|other — promote to reference product]' ;
    rdfs:domain ind:CompetitiveIntelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intelligenceSourceUrl rdf:type rdf:Property ;
    rdfs:label 'Intelligence Source Url' ;
    rdfs:comment 'URL or hyperlink to the primary source document or registry entry from which this competitive intelligence was obtained. Enables direct verification and audit trail.' ;
    rdfs:domain ind:CompetitiveIntelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyDifferentiators rdf:type rdf:Property ;
    rdfs:label 'Key Differentiators' ;
    rdfs:comment 'Narrative summary of the key clinical, safety, or commercial differentiators of the competing asset relative to the program\'s investigational product. Directly informs TPP refinement and go/no-go decision rationale.' ;
    rdfs:domain ind:CompetitiveIntelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Updated Date' ;
    rdfs:comment 'Date on which the content of this competitive intelligence record was last substantively updated with new information. Distinct from last_reviewed_date (which may confirm no change).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineOfTherapy rdf:type rdf:Property ;
    rdfs:label 'Line Of Therapy' ;
    rdfs:comment 'Treatment line for which the competing asset is being developed or approved. Informs competitive positioning and TPP refinement. [ENUM-REF-CANDIDATE: first_line|second_line|third_line_plus|maintenance|adjuvant|neoadjuvant|any — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mechanismOfAction rdf:type rdf:Property ;
    rdfs:label 'Mechanism Of Action' ;
    rdfs:comment 'Pharmacological mechanism by which the competing asset exerts its therapeutic effect (e.g., PD-1 inhibitor, VEGFR antagonist, CAR-T). Informs differentiation strategy and Target Product Profile (TPP) refinement.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipLicensingNotes rdf:type rdf:Property ;
    rdfs:label 'Partnership Licensing Notes' ;
    rdfs:comment 'Notes on known partnerships, licensing agreements, or co-development arrangements associated with the competing asset. Informs competitive landscape and business development strategy.' ;
    rdfs:domain ind:CompetitiveIntelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingReimbursementNotes rdf:type rdf:Property ;
    rdfs:label 'Pricing Reimbursement Notes' ;
    rdfs:comment 'Notes on the competitor\'s known or anticipated pricing, reimbursement status, and health technology assessment (HTA) outcomes. Informs commercial threat assessment and program value proposition. Classified as confidential due to strategic sensitivity.' ;
    rdfs:domain ind:CompetitiveIntelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDesignations rdf:type rdf:Property ;
    rdfs:label 'Regulatory Designations' ;
    rdfs:comment 'Special regulatory designations granted to the competing asset (e.g., Breakthrough Therapy, Fast Track, Orphan Drug, PRIME, Accelerated Approval). Informs competitive regulatory strategy.' ;
    rdfs:domain ind:CompetitiveIntelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Status' ;
    rdfs:comment 'Current regulatory status of the competing asset across major health authorities. Tracks IND/CTA filing, NDA/BLA/MAA submission, and approval status. [ENUM-REF-CANDIDATE: ind_filed|cta_filed|phase_3_ongoing|nda_bla_filed|maa_filed|approved|withdrawn|discontinued — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'Scheduled frequency at which this competitive intelligence entry should be reviewed and updated. Drives operational cadence for the competitive intelligence monitoring process.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyProfileSummary rdf:type rdf:Property ;
    rdfs:label 'Safety Profile Summary' ;
    rdfs:comment 'Narrative summary of the known or reported safety and tolerability profile of the competing asset, including key adverse events (AEs) and serious adverse events (SAEs). Informs the program\'s risk-benefit assessment and DSMB charter.' ;
    rdfs:domain ind:CompetitiveIntelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPatientPopulation rdf:type rdf:Property ;
    rdfs:label 'Target Patient Population' ;
    rdfs:comment 'Description of the patient population targeted by the competing asset (e.g., biomarker-selected, line of therapy, disease stage). Used to assess competitive differentiation in patient recruitment and market positioning.' ;
    rdfs:domain ind:CompetitiveIntelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tppImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Tpp Impact Assessment' ;
    rdfs:comment 'Narrative assessment of how this competitive intelligence entry impacts the program\'s Target Product Profile (TPP) — including potential need for differentiation in efficacy, safety, dosing, or patient population. Directly supports go/no-go decision-making.' ;
    rdfs:domain ind:CompetitiveIntelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossStudyDependencyId rdf:type rdf:Property ;
    rdfs:label 'Cross Study Dependency Id' ;
    rdfs:comment 'Unique surrogate identifier for the cross-study dependency record within the clinical development program. Primary key for this association entity.' ;
    rdfs:domain ind:CrossStudyDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCrossClinicalProgramId rdf:type rdf:Property ;
    rdfs:label 'Primary Cross Clinical Program Id' ;
    rdfs:comment 'Reference to the clinical development program under which this cross-study dependency is governed. Links the dependency to its overarching portfolio governance context.' ;
    rdfs:domain ind:CrossStudyDependency ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClinicalProgram .

ind:primaryCrossPredecessorStudyId rdf:type rdf:Property ;
    rdfs:label 'Primary Cross Predecessor Study Id' ;
    rdfs:comment 'Reference to the study whose outcome, data, or completion gates the successor study. The predecessor study must reach a defined milestone or status before the successor can proceed.' ;
    rdfs:domain ind:CrossStudyDependency ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Study .

ind:actualResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Resolution Date' ;
    rdfs:comment 'Date on which the dependency was actually resolved, waived, or formally closed. Populated when dependency_status transitions to \'resolved\' or \'waived\'. Enables schedule variance analysis.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:crossProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Program Flag' ;
    rdfs:comment 'Indicates whether this dependency spans studies in different clinical development programs (True) or is contained within a single program (False). Cross-program dependencies require portfolio-level governance escalation.' ;
    rdfs:domain ind:CrossStudyDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataPackageRequired rdf:type rdf:Property ;
    rdfs:label 'Data Package Required' ;
    rdfs:comment 'Description of the specific data package, dataset, or analysis output from the predecessor study required to satisfy this dependency (e.g., \'Interim PK/PD analysis dataset in CDISC ADaM format\', \'DSMB safety summary report\', \'Dose-response modeling results\'). Relevant for data dependencies.' ;
    rdfs:domain ind:CrossStudyDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyCode rdf:type rdf:Property ;
    rdfs:label 'Dependency Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for this dependency record, used in program planning documents, integrated development plans, and CTMS tracking. Format: DEP- followed by 4-12 alphanumeric characters.' ;
    rdfs:domain ind:CrossStudyDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyDescription rdf:type rdf:Property ;
    rdfs:label 'Dependency Description' ;
    rdfs:comment 'Detailed narrative describing the nature, rationale, and conditions of the dependency between the predecessor and successor studies. Captures what specific data, outcome, or event from the predecessor is required and why.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyDirection rdf:type rdf:Property ;
    rdfs:label 'Dependency Direction' ;
    rdfs:comment 'Indicates whether the dependency flows in one direction only (predecessor gates successor) or bidirectionally (studies mutually constrain each other, e.g., platform trials with shared safety data). Bidirectional dependencies require special governance handling.' ;
    rdfs:domain ind:CrossStudyDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyName rdf:type rdf:Property ;
    rdfs:label 'Dependency Name' ;
    rdfs:comment 'Short human-readable label for the dependency, used in program planning dashboards, integrated timelines, and governance reports (e.g., \'Phase 1 PK Data Required for Phase 2 Dose Selection\').' ;
    rdfs:domain ind:CrossStudyDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyOwner rdf:type rdf:Property ;
    rdfs:label 'Dependency Owner' ;
    rdfs:comment 'Name or role of the individual or team accountable for monitoring and resolving this dependency (e.g., Program Director, Clinical Operations Lead, Regulatory Affairs Lead). Supports accountability in program governance.' ;
    rdfs:domain ind:CrossStudyDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyStatus rdf:type rdf:Property ;
    rdfs:label 'Dependency Status' ;
    rdfs:comment 'Current lifecycle state of the dependency. \'active\' = dependency is in force and being tracked; \'resolved\' = predecessor condition has been met and dependency is satisfied; \'waived\' = dependency formally waived by program governance with documented rationale; \'on_hold\' = dependency tracking paused pending external decision; \'pending_review\' = dependency under governance review for waiver or modification.' ;
    rdfs:domain ind:CrossStudyDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependencyType rdf:type rdf:Property ;
    rdfs:label 'Dependency Type' ;
    rdfs:comment 'Classification of the nature of the dependency between studies. \'data\' = successor requires data outputs (e.g., PK/PD, biomarker) from predecessor; \'safety\' = successor requires safety review or DSMB/DMC clearance from predecessor; \'regulatory\' = successor requires regulatory milestone (IND, NDA, MAA) from predecessor; \'supply\' = successor requires drug supply or manufacturing readiness from predecessor; \'sequential_design\' = adaptive or platform trial design where predecessor results inform successor design; \'operational\' = site, staff, or resource dependency.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatingConditionDetail rdf:type rdf:Property ;
    rdfs:label 'Gating Condition Detail' ;
    rdfs:comment 'Precise, measurable condition or threshold that must be met in the predecessor study to release the successor (e.g., \'Minimum 80% of Phase 1 subjects must complete PK sampling\', \'No Grade 3+ DLTs observed at target dose level\'). Supports objective dependency resolution assessment.' ;
    rdfs:domain ind:CrossStudyDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatingMilestone rdf:type rdf:Property ;
    rdfs:label 'Gating Milestone' ;
    rdfs:comment 'Specific milestone or event in the predecessor study that must be achieved to satisfy this dependency (e.g., \'Database Lock\', \'DSMB Safety Review Completion\', \'Regulatory Clearance of IND Amendment\', \'Last Patient Last Visit\'). Aligns with CTMS milestone tracking.' ;
    rdfs:domain ind:CrossStudyDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governanceReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Governance Review Required' ;
    rdfs:comment 'Indicates whether this dependency requires formal review and sign-off by a program governance committee (e.g., Program Steering Committee, Joint Development Committee) before the successor study can proceed.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactIfUnmet rdf:type rdf:Property ;
    rdfs:label 'Impact If Unmet' ;
    rdfs:comment 'Narrative description of the business, regulatory, or patient safety impact if this dependency is not satisfied before the successor study proceeds. Used in risk management and program governance decision-making.' ;
    rdfs:domain ind:CrossStudyDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationPlan rdf:type rdf:Property ;
    rdfs:label 'Mitigation Plan' ;
    rdfs:comment 'Documented contingency or mitigation strategy to be executed if this dependency cannot be resolved by the planned date. Describes alternative approaches to allow the successor study to proceed with acceptable risk.' ;
    rdfs:domain ind:CrossStudyDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Resolution Date' ;
    rdfs:comment 'Target date by which the dependency is expected to be resolved (i.e., the predecessor gating milestone is expected to be achieved). Used in integrated program timeline planning and critical path analysis.' ;
    rdfs:domain ind:CrossStudyDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryAgencyNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency Notification Required' ;
    rdfs:comment 'Indicates whether resolution or waiver of this dependency requires notification to or approval from a regulatory agency (FDA, EMA, PMDA, etc.) before the successor study proceeds. Drives regulatory submission planning.' ;
    rdfs:domain ind:CrossStudyDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleImpactDays rdf:type rdf:Property ;
    rdfs:label 'Schedule Impact Days' ;
    rdfs:comment 'Estimated number of calendar days by which the successor study initiation would be delayed if this dependency is not resolved by the planned resolution date. Used in critical path and scenario planning.' ;
    rdfs:domain ind:CrossStudyDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:successorEarliestStartDate rdf:type rdf:Property ;
    rdfs:label 'Successor Earliest Start Date' ;
    rdfs:comment 'Earliest permissible initiation date for the successor study, derived from the expected resolution of this dependency. Drives integrated program scheduling and site activation planning.' ;
    rdfs:domain ind:CrossStudyDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplyDependencyDetail rdf:type rdf:Property ;
    rdfs:label 'Supply Dependency Detail' ;
    rdfs:comment 'Specific description of the drug supply, manufacturing batch, or IRT/RTSM configuration requirement from the predecessor study that must be fulfilled before the successor study can be supplied. Relevant for supply dependencies.' ;
    rdfs:domain ind:CrossStudyDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverRationale rdf:type rdf:Property ;
    rdfs:label 'Waiver Rationale' ;
    rdfs:comment 'Documented justification for formally waiving this dependency, including the scientific, regulatory, or operational basis for proceeding without satisfying the original gating condition. Required when dependency_status = \'waived\'.' ;
    rdfs:domain ind:CrossStudyDependency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governanceMeetingId rdf:type rdf:Property ;
    rdfs:label 'Governance Meeting Id' ;
    rdfs:comment 'Unique surrogate identifier for each program governance meeting record in the lakehouse silver layer.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GovernanceMeeting .

ind:chairEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Chair Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Governance meeting chairs are named employees accountable for quorum, decision authority, and minutes approval. Regulatory inspections require traceable meeting governance. chair_name is a denormalize' ;
    rdfs:domain ind:Program ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:priorMeetingGovernanceMeetingId rdf:type rdf:Property ;
    rdfs:label 'Prior Meeting Governance Meeting Id' ;
    rdfs:comment 'Reference to the immediately preceding governance meeting in the same committee series. Enables meeting chain linkage for action item carry-forward tracking and minutes continuity.' ;
    rdfs:domain ind:GovernanceMeeting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GovernanceMeeting .

ind:sponsorChairSponsorContactId rdf:type rdf:Property ;
    rdfs:label 'Sponsor Chair Sponsor Contact Id' ;
    rdfs:comment 'Foreign key linking to sponsor.sponsor_contact. Business justification: Governance meetings have a sponsor co-chair who is a specific sponsor contact. governance_meeting has chair_name as a denormalized plain text field. Role-prefixed FK sponsor_chair_sponsor_contact_id e' ;
    rdfs:domain ind:GovernanceMeeting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SponsorContact .

ind:actionItemCount rdf:type rdf:Property ;
    rdfs:label 'Action Item Count' ;
    rdfs:comment 'Total number of action items raised during the governance meeting. Supports tracking of follow-up obligations and governance accountability metrics.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agendaDistributedDate rdf:type rdf:Property ;
    rdfs:label 'Agenda Distributed Date' ;
    rdfs:comment 'Date on which the meeting agenda was formally distributed to attendees. Regulatory and governance best practice requires agenda distribution within a defined period before the meeting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agendaTopics rdf:type rdf:Property ;
    rdfs:label 'Agenda Topics' ;
    rdfs:comment 'Structured summary or pipe-delimited list of the principal agenda items discussed at the meeting (e.g., \'Study Progress Review | Safety Data Review | Enrollment Update | Budget Review\'). Supports meeting content search and analytics.' ;
    rdfs:domain ind:GovernanceMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agendaVersion rdf:type rdf:Property ;
    rdfs:label 'Agenda Version' ;
    rdfs:comment 'Version identifier of the final agenda document circulated prior to the meeting (e.g., v1.0, v2.1). Supports document control and traceability to the eTMF.' ;
    rdfs:domain ind:GovernanceMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attendeeCount rdf:type rdf:Property ;
    rdfs:label 'Attendee Count' ;
    rdfs:comment 'Total number of individuals who attended the governance meeting, including voting members, non-voting observers, and invited guests. Used for quorum verification and minutes accuracy.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chairRole rdf:type rdf:Property ;
    rdfs:label 'Chair Role' ;
    rdfs:comment 'Organizational role or title of the meeting chair (e.g., \'Chief Medical Officer\', \'Program Director\', \'Independent Committee Chair\'). Provides governance accountability context.' ;
    rdfs:domain ind:GovernanceMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionCount rdf:type rdf:Property ;
    rdfs:label 'Decision Count' ;
    rdfs:comment 'Total number of formal decisions recorded during the governance meeting. Used for governance KPI reporting and meeting productivity analytics.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'Precise date and time (with timezone offset) at which the governance meeting concluded. Used to calculate meeting duration and for minutes accuracy.' ;
    rdfs:domain ind:GovernanceMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:keyDecisions rdf:type rdf:Property ;
    rdfs:label 'Key Decisions' ;
    rdfs:comment 'Narrative summary of the principal decisions made during the governance meeting (e.g., protocol amendment approval, site expansion authorization, budget reallocation). Extracted from approved minutes for analytics and reporting.' ;
    rdfs:domain ind:GovernanceMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingFormat rdf:type rdf:Property ;
    rdfs:label 'Meeting Format' ;
    rdfs:comment 'Modality of the meeting: in_person (all attendees physically co-located), virtual (all attendees remote via teleconference/videoconference), or hybrid (mix of in-person and remote attendees).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingTitle rdf:type rdf:Property ;
    rdfs:label 'Meeting Title' ;
    rdfs:comment 'Descriptive title of the governance meeting as it appears on the agenda and minutes document (e.g., \'Q3 2024 Program Review Board Meeting – PROG-001\').' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minutesApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Minutes Approved Date' ;
    rdfs:comment 'Date on which the meeting minutes were formally approved by the committee chair or designated approver. Required for regulatory audit trail and eTMF completeness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minutesApproverName rdf:type rdf:Property ;
    rdfs:label 'Minutes Approver Name' ;
    rdfs:comment 'Full name of the individual who formally approved the meeting minutes. Supports ALCOA+ compliance (Attributable, Legible, Contemporaneous, Original, Accurate) for regulatory audit readiness.' ;
    rdfs:domain ind:GovernanceMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openActionItemsFromPrior rdf:type rdf:Property ;
    rdfs:label 'Open Action Items From Prior' ;
    rdfs:comment 'Number of action items from previous governance meetings that remained open and were reviewed at this meeting. Key governance health indicator.' ;
    rdfs:domain ind:GovernanceMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quorumAchieved rdf:type rdf:Property ;
    rdfs:label 'Quorum Achieved' ;
    rdfs:comment 'Indicates whether the required quorum of voting members was present at the meeting, making decisions and resolutions formally binding. True = quorum met; False = quorum not met.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quorumRequired rdf:type rdf:Property ;
    rdfs:label 'Quorum Required' ;
    rdfs:comment 'Minimum number of voting members required to be present for the meeting to be quorate and for decisions to be binding, as defined in the committee charter.' ;
    rdfs:domain ind:GovernanceMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryImplicationFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Implication Flag' ;
    rdfs:comment 'Indicates whether any decision or discussion item from this meeting has a direct regulatory implication (e.g., protocol amendment requiring IND/CTA update, safety signal requiring expedited reporting). True = regulatory action may be required.' ;
    rdfs:domain ind:GovernanceMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyTopicDiscussed rdf:type rdf:Property ;
    rdfs:label 'Safety Topic Discussed' ;
    rdfs:comment 'Indicates whether any safety-related topic (e.g., SAE review, SUSAR assessment, DSMB recommendation, risk-benefit evaluation) was discussed during the meeting. Supports safety governance audit trail.' ;
    rdfs:domain ind:GovernanceMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'Precise date and time (with timezone offset) at which the governance meeting commenced. Used for quorum determination and minutes accuracy.' ;
    rdfs:domain ind:GovernanceMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:votingMemberCount rdf:type rdf:Property ;
    rdfs:label 'Voting Member Count' ;
    rdfs:comment 'Number of voting committee members who were present at the meeting. Used to confirm quorum achievement and validate the binding nature of decisions made.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByIndicationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Indication Id' ;
    rdfs:comment 'Reference to the indication_id of the record that replaces this indication when it is retired or split. Enables taxonomy lineage tracking and ensures downstream systems can migrate to the current indication record.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Indication .

ind:acceleratedApprovalFlag rdf:type rdf:Property ;
    rdfs:label 'Accelerated Approval Flag' ;
    rdfs:comment 'Indicates whether this indication is eligible for FDA Accelerated Approval or EMA Conditional Marketing Authorization based on surrogate or intermediate clinical endpoints. Drives endpoint selection strategy in study protocol design.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:biomarkerDrivenFlag rdf:type rdf:Property ;
    rdfs:label 'Biomarker Driven Flag' ;
    rdfs:comment 'Indicates whether this indication requires biomarker-based patient selection or stratification (e.g., PD-L1 expression, EGFR mutation, HER2 amplification). True = biomarker-driven enrollment criteria apply. Impacts site selection, patient recruitment, and companion diagnostic requirements.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breakthroughTherapyFlag rdf:type rdf:Property ;
    rdfs:label 'Breakthrough Therapy Flag' ;
    rdfs:comment 'Indicates whether any program targeting this indication has received or is eligible for FDA Breakthrough Therapy Designation (BTD). True = BTD granted or under consideration. Influences regulatory strategy, timeline planning, and sponsor communications.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:companionDiagnosticRequired rdf:type rdf:Property ;
    rdfs:label 'Companion Diagnostic Required' ;
    rdfs:comment 'Indicates whether a companion diagnostic (CDx) test is required for patient selection or treatment decisions in studies targeting this indication. True = CDx required. Triggers regulatory co-development requirements under FDA 21 CFR Part 809 and EMA guidelines.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ctaFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Cta Filed Flag' ;
    rdfs:comment 'Indicates whether a Clinical Trial Authorization (CTA) has been filed with the EMA or other ex-US health authorities for at least one program targeting this indication. True = CTA filed. Supports ex-US regulatory status tracking.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSteward rdf:type rdf:Property ;
    rdfs:label 'Data Steward' ;
    rdfs:comment 'Name or identifier of the business data steward responsible for maintaining the accuracy and governance of this indication record. Supports data ownership accountability under ALCOA+ and enterprise data governance frameworks.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diseaseCategory rdf:type rdf:Property ;
    rdfs:label 'Disease Category' ;
    rdfs:comment 'Sub-classification of the disease within the therapeutic area (e.g., \'Solid Tumors\', \'Hematologic Malignancies\', \'Autoimmune\', \'Metabolic Syndrome\'). Provides a second level of indication taxonomy for portfolio segmentation and study grouping. [ENUM-REF-CANDIDATE: Solid Tumors|Hematologic Malignancies|Autoimmune|Metabolic Syndrome|Neurodegenerative|Infectious|Inflammatory|Genetic — promote to reference product]' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diseaseStage rdf:type rdf:Property ;
    rdfs:label 'Disease Stage' ;
    rdfs:comment 'Standard disease staging classification applicable to this indication (e.g., \'Stage III-IV\', \'Relapsed/Refractory\', \'Early Stage\', \'Metastatic\'). Used for patient stratification, eligibility criteria design, and cross-study comparability.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastTrackFlag rdf:type rdf:Property ;
    rdfs:label 'Fast Track Flag' ;
    rdfs:comment 'Indicates whether programs targeting this indication are eligible for or have received FDA Fast Track Designation. True = Fast Track applicable. Affects regulatory submission planning and FDA interaction frequency.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstApprovalDate rdf:type rdf:Property ;
    rdfs:label 'First Approval Date' ;
    rdfs:comment 'Date of the first regulatory marketing approval (NDA, BLA, MAA, or equivalent) granted for any product in this indication. Null if no approval has been granted. Used for competitive intelligence and portfolio milestone tracking.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstInHumanDate rdf:type rdf:Property ;
    rdfs:label 'First In Human Date' ;
    rdfs:comment 'Date on which the first-in-human (FIH) clinical study for this indication was initiated. Marks the transition from preclinical to clinical development and is a key milestone in program lifecycle tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:icd10Code rdf:type rdf:Property ;
    rdfs:label 'Icd10 Code' ;
    rdfs:comment 'ICD-10 alphanumeric code assigned to this indication per the WHO International Classification of Diseases, 10th Revision. Used for regulatory submissions, safety reporting, and cross-study standardization.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icd11Code rdf:type rdf:Property ;
    rdfs:label 'Icd11 Code' ;
    rdfs:comment 'ICD-11 alphanumeric code assigned to this indication per the WHO International Classification of Diseases, 11th Revision. Supports forward compatibility with emerging regulatory and health authority requirements.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Ind Filed Flag' ;
    rdfs:comment 'Indicates whether an Investigational New Drug (IND) application has been filed with the FDA for at least one program targeting this indication. True = IND filed. Relevant for US regulatory status tracking and program readiness assessment.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:indicationCode rdf:type rdf:Property ;
    rdfs:label 'Indication Code' ;
    rdfs:comment 'Internally assigned alphanumeric code uniquely identifying the therapeutic indication within the organization\'s indication taxonomy. Used as the business-facing identifier across CTMS, EDC, and regulatory systems.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicationName rdf:type rdf:Property ;
    rdfs:label 'Indication Name' ;
    rdfs:comment 'Full, standardized human-readable name of the therapeutic indication or disease area (e.g., \'Non-Small Cell Lung Cancer\', \'Type 2 Diabetes Mellitus\'). Serves as the primary display label across all downstream systems.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicationStatus rdf:type rdf:Property ;
    rdfs:label 'Indication Status' ;
    rdfs:comment 'Current lifecycle status of the indication record within the organization\'s indication taxonomy. \'active\' = currently used in programs/studies; \'retired\' = no longer in use, superseded; \'under_review\' = pending taxonomy committee review; \'pending_approval\' = awaiting governance approval for addition.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOrphanDisease rdf:type rdf:Property ;
    rdfs:label 'Is Orphan Disease' ;
    rdfs:comment 'Indicates whether this indication qualifies as an orphan disease (rare disease) under applicable regulatory frameworks. True = orphan/rare disease designation applicable. Drives eligibility for FDA Orphan Drug Designation (ODD), EMA Orphan Medicinal Product designation, and associated regulatory incentives.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPediatricIndication rdf:type rdf:Property ;
    rdfs:label 'Is Pediatric Indication' ;
    rdfs:comment 'Indicates whether this indication includes or is specifically targeted at a pediatric patient population. True = pediatric indication. Triggers compliance requirements under FDA Pediatric Research Equity Act (PREA), EMA Pediatric Investigation Plan (PIP), and ICH E11 guidelines.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meddraPtCode rdf:type rdf:Property ;
    rdfs:label 'Meddra Pt Code' ;
    rdfs:comment 'Eight-digit MedDRA Preferred Term (PT) code mapped to this indication. Enables standardized adverse event coding, safety signal detection, and regulatory submission alignment across ICH member regions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meddraPtName rdf:type rdf:Property ;
    rdfs:label 'Meddra Pt Name' ;
    rdfs:comment 'Human-readable MedDRA Preferred Term (PT) label corresponding to the meddra_pt_code. Provides the standardized MedDRA terminology name for display and reporting purposes.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meddraSocName rdf:type rdf:Property ;
    rdfs:label 'Meddra Soc Name' ;
    rdfs:comment 'Human-readable MedDRA System Organ Class (SOC) label corresponding to the meddra_soc_code (e.g., \'Neoplasms benign, malignant and unspecified\'). Used for therapeutic area classification in portfolio analytics.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orphanDesignationNumber rdf:type rdf:Property ;
    rdfs:label 'Orphan Designation Number' ;
    rdfs:comment 'Official regulatory designation number assigned by the FDA or EMA for orphan drug status for this indication (e.g., FDA ODD number or EMA EU/3/xx/xxx). Populated only when is_orphan_disease is True and a formal designation has been granted.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientPopulationDescription rdf:type rdf:Property ;
    rdfs:label 'Patient Population Description' ;
    rdfs:comment 'Narrative description of the target patient population for this indication, including key inclusion/exclusion criteria characteristics, disease stage, line of therapy, and biomarker requirements. Informs site feasibility assessments and patient recruitment strategies.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prevalenceEstimate rdf:type rdf:Property ;
    rdfs:label 'Prevalence Estimate' ;
    rdfs:comment 'Estimated number of patients affected by this indication in the target population (absolute count). Used for feasibility assessments, patient recruitment planning, and orphan disease threshold determination (e.g., <200,000 in the US for FDA ODD).' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prevalencePopulationRegion rdf:type rdf:Property ;
    rdfs:label 'Prevalence Population Region' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country or region code for which the prevalence estimate applies (e.g., \'USA\', \'EUE\', \'GBR\'). Contextualizes the prevalence_estimate for regulatory and recruitment planning purposes.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryPrecedentNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Precedent Notes' ;
    rdfs:comment 'Free-text field capturing known regulatory precedents, prior approvals, breakthrough therapy designations, fast track designations, or other regulatory history relevant to this indication. Informs regulatory strategy for new programs targeting this indication.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyVersion rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Version' ;
    rdfs:comment 'Version number of the internal indication taxonomy under which this record was classified (e.g., \'2.1\'). Enables traceability of indication classification changes across taxonomy governance cycles and supports audit requirements.' ;
    rdfs:domain ind:Indication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unmetMedicalNeedLevel rdf:type rdf:Property ;
    rdfs:label 'Unmet Medical Need Level' ;
    rdfs:comment 'Assessment of the unmet medical need for this indication based on existing treatment options and disease burden. Drives prioritization in portfolio governance, regulatory strategy, and program investment decisions.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedIndication rdf:type rdf:Property ;
    rdfs:label 'Affected Indication' ;
    rdfs:comment 'The therapeutic indication or disease area within the program that is specifically affected by this amendment, using MedDRA terminology where applicable.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedStudyCount rdf:type rdf:Property ;
    rdfs:label 'Affected Study Count' ;
    rdfs:comment 'Number of individual clinical studies within the program that are impacted by this amendment, used for cross-study coordination and workload assessment.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approverRole rdf:type rdf:Property ;
    rdfs:label 'Approver Role' ;
    rdfs:comment 'The organizational role or title of the individual who approved the amendment (e.g., Program Director, Chief Medical Officer, Sponsor VP Clinical Development).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Impact Flag' ;
    rdfs:comment 'Indicates whether this amendment results in a change to the program-level budget, triggering a financial change order process in SAP S/4HANA.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactAssessmentSummary rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Summary' ;
    rdfs:comment 'Summary of the assessed impact of the amendment on program scope, timelines, budget, regulatory strategy, and affected studies, as evaluated during the governance review process.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationDeadline rdf:type rdf:Property ;
    rdfs:label 'Implementation Deadline' ;
    rdfs:comment 'Target date by which the changes specified in the amendment must be fully implemented across all affected studies, sites, and operational systems.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:previousVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Previous Version Number' ;
    rdfs:comment 'Version number of the Clinical Development Plan (CDP) that this amendment supersedes, enabling complete version chain reconstruction for audit and regulatory review.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDeadline rdf:type rdf:Property ;
    rdfs:label 'Review Deadline' ;
    rdfs:comment 'Target date by which the governance review and approval of the amendment must be completed, used for escalation tracking and program milestone management.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Impact Flag' ;
    rdfs:comment 'Indicates whether this amendment has implications for subject safety, risk management, or Data Safety Monitoring Board (DSMB) / Data Monitoring Committee (DMC) review requirements.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Scope Impact Flag' ;
    rdfs:comment 'Indicates whether this amendment results in a material change to the program scope, such as addition or removal of studies, indications, or patient populations.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timelineImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Timeline Impact Flag' ;
    rdfs:comment 'Indicates whether this amendment results in a change to program-level milestone dates or study timelines within the Clinical Development Plan (CDP).' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assumptionId rdf:type rdf:Property ;
    rdfs:label 'Assumption Id' ;
    rdfs:comment 'Unique surrogate identifier for the program assumption record within the clinical development program planning framework.' ;
    rdfs:domain ind:Assumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assumptionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assumption Employee Id' ;
    rdfs:comment 'Reference to the Workday HCM workforce record of the individual (typically a Program Director, Clinical Lead, or Regulatory Affairs Lead) accountable for maintaining, validating, and updating this assumption.' ;
    rdfs:domain ind:Assumption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assumptionValidatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assumption Validated By Employee Id' ;
    rdfs:comment 'Reference to the Workday HCM workforce record of the individual who performed or approved the most recent validation of this assumption.' ;
    rdfs:domain ind:Assumption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ownerId rdf:type rdf:Property ;
    rdfs:label 'Owner Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:Program ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentAssumptionId rdf:type rdf:Property ;
    rdfs:label 'Parent Assumption Id' ;
    rdfs:comment 'Self-referencing identifier linking this assumption to a higher-level parent assumption, enabling hierarchical assumption structures within the clinical development plan (e.g., a site-level enrollment assumption nested under a program-level enrollment assumption).' ;
    rdfs:domain ind:Assumption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assumption .

ind:applicableGeography rdf:type rdf:Property ;
    rdfs:label 'Applicable Geography' ;
    rdfs:comment 'Geographic scope to which this assumption applies, expressed as ISO 3166-1 alpha-3 country codes or regional designations (e.g., \'USA\', \'GBR\', \'JPN\', \'Global\'). Relevant for enrollment rate, regulatory timeline, and site activation assumptions.' ;
    rdfs:domain ind:Assumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assumptionCategory rdf:type rdf:Property ;
    rdfs:label 'Assumption Category' ;
    rdfs:comment 'Categorical classification of the planning assumption type that drives program timeline and resource planning. [ENUM-REF-CANDIDATE: enrollment_rate|regulatory_timeline|safety_profile|competitive_landscape|manufacturing_readiness|biomarker_prevalence|dropout_rate — promote to reference product]' ;
    rdfs:domain ind:Assumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assumptionCode rdf:type rdf:Property ;
    rdfs:label 'Assumption Code' ;
    rdfs:comment 'Externally-known, human-readable unique code assigned to this planning assumption for cross-referencing in clinical development plans, program governance documents, and regulatory submissions.' ;
    rdfs:domain ind:Assumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assumptionDescription rdf:type rdf:Property ;
    rdfs:label 'Assumption Description' ;
    rdfs:comment 'Full narrative description of the planning assumption, including the basis for the assumption, supporting evidence, and its role in the clinical development plan timeline and resource projections.' ;
    rdfs:domain ind:Assumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assumptionStatus rdf:type rdf:Property ;
    rdfs:label 'Assumption Status' ;
    rdfs:comment 'Current lifecycle state of the planning assumption within the program governance workflow. Drives whether the assumption is actively used in program planning or has been retired/replaced.' ;
    rdfs:domain ind:Assumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assumptionValue rdf:type rdf:Property ;
    rdfs:label 'Assumption Value' ;
    rdfs:comment 'The specific quantitative or qualitative value of the assumption (e.g., \'2.5 patients/site/month\', \'18 months for FDA review\', \'15% screen failure rate\'). Stored as STRING to accommodate diverse assumption types across categories.' ;
    rdfs:domain ind:Assumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceRationale rdf:type rdf:Property ;
    rdfs:label 'Confidence Rationale' ;
    rdfs:comment 'Narrative explanation supporting the assigned confidence level, including references to historical study data, literature, competitive intelligence, or expert opinion used to substantiate the assumption.' ;
    rdfs:domain ind:Assumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invalidationTrigger rdf:type rdf:Property ;
    rdfs:label 'Invalidation Trigger' ;
    rdfs:comment 'Specific, pre-defined condition or threshold that, if observed, would constitute invalidation of this assumption and trigger a program plan revision (e.g., \'Enrollment rate falls below 1.0 patients/site/month for 3 consecutive months\').' ;
    rdfs:domain ind:Assumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDependencyTrigger rdf:type rdf:Property ;
    rdfs:label 'Is Dependency Trigger' ;
    rdfs:comment 'Indicates whether invalidation of this assumption would trigger a mandatory revision of dependent program plan elements, milestones, or other assumptions. True = this is a critical dependency assumption requiring escalation upon invalidation.' ;
    rdfs:domain ind:Assumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lowerBoundValue rdf:type rdf:Property ;
    rdfs:label 'Lower Bound Value' ;
    rdfs:comment 'Pessimistic or minimum plausible value for the assumption used in downside scenario planning and sensitivity analysis (e.g., \'1.5 patients/site/month\' as the low-end enrollment rate estimate).' ;
    rdfs:domain ind:Assumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryAgency rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency' ;
    rdfs:comment 'Primary regulatory agency relevant to this assumption, particularly for regulatory timeline and submission assumptions. Drives agency-specific planning parameters in the clinical development plan. [ENUM-REF-CANDIDATE: FDA|EMA|PMDA|MHRA|TGA|Health_Canada|WHO|Other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskMitigationPlan rdf:type rdf:Property ;
    rdfs:label 'Risk Mitigation Plan' ;
    rdfs:comment 'Description of the contingency or mitigation actions to be executed if this assumption is invalidated, including fallback strategies, alternative approaches, and escalation paths within the program governance framework.' ;
    rdfs:domain ind:Assumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensitivityToProgram rdf:type rdf:Property ;
    rdfs:label 'Sensitivity To Program' ;
    rdfs:comment 'Assessment of the degree to which invalidation of this assumption would materially impact the program timeline, budget, or probability of success. High sensitivity assumptions trigger mandatory program plan revision if invalidated.' ;
    rdfs:domain ind:Assumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Further granular classification within the assumption category (e.g., within \'enrollment_rate\': \'screen_failure_rate\', \'site_activation_rate\'). Enables detailed segmentation for sensitivity analysis and program risk management.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Ref' ;
    rdfs:comment 'Reference identifier or URL to supporting documentation in Veeva Vault eTMF or document management system (e.g., Clinical Development Plan version, Feasibility Report, Regulatory Intelligence Report) that substantiates this assumption.' ;
    rdfs:domain ind:Assumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperBoundValue rdf:type rdf:Property ;
    rdfs:label 'Upper Bound Value' ;
    rdfs:comment 'Optimistic or maximum plausible value for the assumption used in upside scenario planning and sensitivity analysis (e.g., \'4.0 patients/site/month\' as the high-end enrollment rate estimate).' ;
    rdfs:domain ind:Assumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valueUnit rdf:type rdf:Property ;
    rdfs:label 'Value Unit' ;
    rdfs:comment 'Unit of measure for the assumption value where applicable (e.g., \'patients/site/month\', \'months\', \'percentage\', \'mg/kg\'). Ensures unambiguous interpretation of quantitative assumptions in program planning models.' ;
    rdfs:domain ind:Assumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionRationale rdf:type rdf:Property ;
    rdfs:label 'Version Rationale' ;
    rdfs:comment 'Narrative explanation for why this version of the assumption was created, including the trigger event (e.g., \'Updated based on Phase 2 interim enrollment data\', \'Revised following FDA Type B meeting feedback\', \'Adjusted per DSMB recommendation\').' ;
    rdfs:domain ind:Assumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetId rdf:type rdf:Property ;
    rdfs:label 'Budget Id' ;
    rdfs:comment 'Unique system-generated identifier for the program-level budget envelope record. Primary key for this entity.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:budgetApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Budget Approved By Employee Id' ;
    rdfs:comment 'Reference to the individual or governance body representative who formally approved this budget version. Supports SOX audit trail and segregation of duties compliance.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:budgetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Budget Employee Id' ;
    rdfs:comment 'Reference to the individual (typically a Program Finance Lead or Program Director) who owns accountability for this program budget envelope. Links to workforce/employee master data in Workday HCM.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:priorVersionBudgetId rdf:type rdf:Property ;
    rdfs:label 'Prior Version Budget Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediately preceding budget version that this record supersedes. Enables full budget revision history chain traversal for audit and variance analysis.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:approvalGovernanceBody rdf:type rdf:Property ;
    rdfs:label 'Approval Governance Body' ;
    rdfs:comment 'Name of the governance committee or body that approved this budget version (e.g., \'Portfolio Review Committee\', \'R&D Finance Committee\', \'Executive Leadership Team\'). Supports audit trail and governance accountability.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biostatisticsBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Biostatistics Budget Amount' ;
    rdfs:comment 'Budget allocation for the biostatistics functional area, covering Statistical Analysis Plan (SAP) development, analysis execution, TLF production, and Clinical Study Report (CSR) statistical sections.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCode rdf:type rdf:Property ;
    rdfs:label 'Budget Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this budget envelope within the organization\'s financial management system (SAP S/4HANA). Used for cross-system reconciliation and financial reporting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetName rdf:type rdf:Property ;
    rdfs:label 'Budget Name' ;
    rdfs:comment 'Human-readable descriptive name for this budget envelope (e.g., \'Phase II/III Oncology Program Budget FY2024\'). Used in financial reports and governance presentations.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalOpsBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Clinical Ops Budget Amount' ;
    rdfs:comment 'Budget allocation for clinical operations functional area, covering site management, monitoring (CRA activities), patient recruitment, and site payments across the program.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:croBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Cro Budget Amount' ;
    rdfs:comment 'Budget allocation for Contract Research Organization (CRO) services and outsourced activities across the program. Represents the total envelope for external CRO spend governed by master service agreements.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataManagementBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Data Management Budget Amount' ;
    rdfs:comment 'Budget allocation for the data management functional area, covering EDC setup (Medidata Rave), eCRF design, data cleaning, database lock (DBL), and CDISC/SDTM/ADaM transformation activities.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Lab Budget Amount' ;
    rdfs:comment 'Budget allocation for central and local laboratory services across the program, including sample analysis, biomarker testing, PK/PD assays, and laboratory kit supply.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phase1BudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Phase1 Budget Amount' ;
    rdfs:comment 'Budget allocation designated for Phase I clinical studies within this program. Supports phase-level financial planning and portfolio governance reporting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phase2BudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Phase2 Budget Amount' ;
    rdfs:comment 'Budget allocation designated for Phase II clinical studies within this program. Supports phase-level financial planning and portfolio governance reporting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phase3BudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Phase3 Budget Amount' ;
    rdfs:comment 'Budget allocation designated for Phase III clinical studies within this program. Typically the largest phase allocation given pivotal trial scale and regulatory submission requirements.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phase4BudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Phase4 Budget Amount' ;
    rdfs:comment 'Budget allocation designated for Phase IV post-marketing studies and commitments within this program. Covers post-approval safety studies and label expansion activities.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Regulatory Budget Amount' ;
    rdfs:comment 'Budget allocation for the regulatory affairs functional area, covering IND/NDA/BLA/MAA submission preparation, agency interactions, eCTD compilation, and regulatory strategy activities.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter code for the corporate reporting currency used for consolidated financial reporting (e.g., USD for a US-headquartered sponsor). Distinct from currency_code which is the budget\'s operating currency.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'Narrative explanation for why this budget version was created as a revision of a prior version (e.g., protocol amendment, scope expansion, enrollment rate change, regulatory requirement). Required for revised and supplemental budget types.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Safety Budget Amount' ;
    rdfs:comment 'Budget allocation for the safety and pharmacovigilance functional area, covering SAE/SUSAR reporting, signal detection, DSMB/DMC support, and Oracle Argus Safety system operations.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyChainBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Supply Chain Budget Amount' ;
    rdfs:comment 'Budget allocation for investigational product (IP) manufacturing, packaging, labeling, distribution, and RTSM/IRT system operations across the program.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalApprovedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Approved Amount' ;
    rdfs:comment 'Total approved financial envelope for the entire clinical development program across all studies, phases, and functional areas. Represents the gross authorized spend ceiling approved by governance.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programCommunicationId rdf:type rdf:Property ;
    rdfs:label 'Program Communication Id' ;
    rdfs:comment 'Unique surrogate identifier for each formal program-level communication record in the Clinical Trials Management System (CTMS). Primary key for this entity.' ;
    rdfs:domain ind:ProgramCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relatedAmendmentProgramAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Related Amendment Program Amendment Id' ;
    rdfs:comment 'Reference to a program amendment that this communication was issued to announce, support, or respond to. Enables traceability between formal communications and protocol/CDP change control events.' ;
    rdfs:domain ind:ProgramCommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:relatedMilestoneProgramMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Related Milestone Program Milestone Id' ;
    rdfs:comment 'Reference to the program milestone that triggered or is the subject of this communication (e.g., milestone notification, delay escalation). Supports milestone-to-communication traceability for portfolio governance.' ;
    rdfs:domain ind:ProgramCommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgramMilestone .

ind:acknowledgementDeadline rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Deadline' ;
    rdfs:comment 'The date by which acknowledgement from recipients must be received. Used to trigger overdue escalations and SLA monitoring. Derived from communication type SLA rules but stored as a business field for operational tracking.' ;
    rdfs:domain ind:ProgramCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgementStatus rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Status' ;
    rdfs:comment 'Current status of recipient acknowledgement for this communication. Tracks whether all required recipients have confirmed receipt and understanding. Overdue status triggers escalation workflows.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:body rdf:type rdf:Property ;
    rdfs:label 'Body' ;
    rdfs:comment 'Full narrative text or structured content of the communication. Captures the complete message transmitted to stakeholders, including context, decisions, actions required, and supporting rationale.' ;
    rdfs:domain ind:ProgramCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The medium or interface through which the communication was transmitted to recipients (e.g., email, formal letter, governance meeting presentation, regulatory authority portal submission). Supports audit trail and stakeholder management analytics.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationDate rdf:type rdf:Property ;
    rdfs:label 'Communication Date' ;
    rdfs:comment 'The real-world date on which the communication was formally issued or transmitted to the intended recipient audience. This is the principal business event date, distinct from the record creation timestamp.' ;
    rdfs:domain ind:ProgramCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:communicationNumber rdf:type rdf:Property ;
    rdfs:label 'Communication Number' ;
    rdfs:comment 'Externally-known, human-readable unique reference number assigned to this communication (e.g., COMM-ONC-2024-000123). Used for tracking, filing in the eTMF, and cross-referencing in governance meeting minutes.' ;
    rdfs:domain ind:ProgramCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationStatus rdf:type rdf:Property ;
    rdfs:label 'Communication Status' ;
    rdfs:comment 'Current lifecycle state of the program communication record. Tracks progression from authoring through issuance and stakeholder acknowledgement. [ENUM-REF-CANDIDATE: draft|pending_review|approved|issued|acknowledged|cancelled — promote to reference product if additional states are required]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationType rdf:type rdf:Property ;
    rdfs:label 'Communication Type' ;
    rdfs:comment 'Classification of the formal communication by its business purpose. Drives routing, escalation rules, and eTMF filing zone assignment. [ENUM-REF-CANDIDATE: program_update|milestone_notification|risk_escalation|regulatory_intelligence_update|program_termination_notice|safety_notification|governance_decision|budget_alert — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpActionRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action Required' ;
    rdfs:comment 'Indicates whether this communication has generated one or more follow-up actions (e.g., protocol amendment, CAPA, regulatory submission, governance escalation) that must be tracked to closure.' ;
    rdfs:domain ind:ProgramCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownerName rdf:type rdf:Property ;
    rdfs:label 'Owner Name' ;
    rdfs:comment 'Full name of the internal staff member accountable for authoring and issuing this communication. Retained as a denormalized field to preserve the historical record at time of issuance, independent of workforce system changes.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientAudience rdf:type rdf:Property ;
    rdfs:label 'Recipient Audience' ;
    rdfs:comment 'The intended audience or stakeholder group to whom the communication is addressed. Drives distribution list management and regulatory filing obligations. [ENUM-REF-CANDIDATE: sponsor|health_authority|internal_leadership|dsmb_dmc|investigator_network|cro_partner|all_stakeholders|irb_iec|patient_advocacy — promote to reference product]' ;
    rdfs:domain ind:ProgramCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientNames rdf:type rdf:Property ;
    rdfs:label 'Recipient Names' ;
    rdfs:comment 'Comma-separated list of named individuals or organizational units who received this communication. Supports audit trail and acknowledgement tracking. Classified as confidential due to business-sensitive stakeholder identity.' ;
    rdfs:domain ind:ProgramCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseReceived rdf:type rdf:Property ;
    rdfs:label 'Response Received' ;
    rdfs:comment 'Indicates whether a substantive response (beyond simple acknowledgement) has been received from the recipient, such as a health authority query response, sponsor feedback, or governance committee decision.' ;
    rdfs:domain ind:ProgramCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyEventReference rdf:type rdf:Property ;
    rdfs:label 'Safety Event Reference' ;
    rdfs:comment 'Cross-reference to the SAE, SUSAR, or safety signal case number in Oracle Argus Safety when this communication is safety-related. Enables traceability between program communications and the pharmacovigilance system.' ;
    rdfs:domain ind:ProgramCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectSummary rdf:type rdf:Property ;
    rdfs:label 'Subject Summary' ;
    rdfs:comment 'Concise subject line or title summarizing the content and purpose of the communication. Used for search, indexing, and eTMF filing. Equivalent to the subject field in formal correspondence.' ;
    rdfs:domain ind:ProgramCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:makerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Maker Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Go/no-go decisions on clinical programs must be traceable to named employees for regulatory submissions and governance audit trails. decision_maker_name is a denormalized plain-text field; a FK enable' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primarySupersededByDecisionId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Decision Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the subsequent program_decision record that replaced or superseded this decision. Null if this decision is current and active. Enables decision lineage and version chain traceability.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Decision .

ind:actionItemsSummary rdf:type rdf:Property ;
    rdfs:label 'Action Items Summary' ;
    rdfs:comment 'Summary of follow-up action items, next steps, or deliverables assigned as a result of this decision (e.g., protocol amendment required, regulatory submission to be filed, additional safety data to be collected). Supports program execution tracking.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityName rdf:type rdf:Property ;
    rdfs:label 'Authority Name' ;
    rdfs:comment 'Name of the governance body, committee, or executive role that holds formal authority for this decision (e.g., \'Portfolio Review Committee\', \'Chief Medical Officer\', \'Executive Leadership Team\'). Distinct from the governance_body_id FK — captures the display name for reporting and regulatory dossier traceability.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitRiskAssessment rdf:type rdf:Property ;
    rdfs:label 'Benefit Risk Assessment' ;
    rdfs:comment 'Structured narrative of the benefit-risk evaluation conducted in support of this decision, aligned with ICH E8(R1) and FDA/EMA benefit-risk frameworks. Particularly critical for go/no-go and phase transition decisions. Business-confidential.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionNumber rdf:type rdf:Property ;
    rdfs:label 'Decision Number' ;
    rdfs:comment 'Externally-known, human-readable unique reference number assigned to this program decision record, used in governance minutes, regulatory dossiers, and TMF cross-references.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionStatus rdf:type rdf:Property ;
    rdfs:label 'Decision Status' ;
    rdfs:comment 'Current lifecycle state of the decision record within the governance workflow: draft (being prepared), pending_review (submitted for ratification), ratified (formally approved and binding), superseded (replaced by a subsequent decision), or voided (invalidated).' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionType rdf:type rdf:Property ;
    rdfs:label 'Decision Type' ;
    rdfs:comment 'Classification of the strategic decision category. Captures the nature of the governance action: go/no-go milestone, phase transition approval (e.g., Phase I to Phase II), indication expansion, program termination, regulatory strategy pivot, or portfolio investment decision. [ENUM-REF-CANDIDATE: go_no_go|phase_transition|indication_expansion|program_termination|regulatory_strategy_pivot|portfolio_investment — promote to reference product]' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissentingOpinionFlag rdf:type rdf:Property ;
    rdfs:label 'Dissenting Opinion Flag' ;
    rdfs:comment 'Indicates whether any member of the decision-making body formally recorded a dissenting opinion against the decision outcome. True if a dissent was registered. Supports governance transparency and audit trail integrity.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dissentingOpinionSummary rdf:type rdf:Property ;
    rdfs:label 'Dissenting Opinion Summary' ;
    rdfs:comment 'Narrative summary of any dissenting opinions recorded by governance body members. Null if dissenting_opinion_flag is False. Business-confidential governance record.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsmbRecommendation rdf:type rdf:Property ;
    rdfs:label 'Dsmb Recommendation' ;
    rdfs:comment 'The formal recommendation issued by the Data Safety Monitoring Board (DSMB) or Data Monitoring Committee (DMC) that informed this decision, where applicable. Values: continue, modify, pause, terminate, not_applicable.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indication rdf:type rdf:Property ;
    rdfs:label 'Indication' ;
    rdfs:comment 'Specific disease or medical condition targeted by the program at the time of this decision (e.g., Non-Small Cell Lung Cancer, Type 2 Diabetes). Supports indication-level portfolio governance and regulatory strategy tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentAmount rdf:type rdf:Property ;
    rdfs:label 'Investment Amount' ;
    rdfs:comment 'The approved or committed financial investment amount associated with this decision (e.g., budget approved for next phase, termination cost). Expressed in the program\'s base currency. Business-confidential financial data.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investmentCurrency rdf:type rdf:Property ;
    rdfs:label 'Investment Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the investment_amount field (e.g., USD, EUR, GBP). Required for multi-currency portfolio financial reporting.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:makerRole rdf:type rdf:Property ;
    rdfs:label 'Maker Role' ;
    rdfs:comment 'Organizational role or title of the individual who made or ratified the decision (e.g., \'Chief Medical Officer\', \'VP Clinical Development\', \'Program Steering Committee Chair\'). Supports governance accountability reporting.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseFrom rdf:type rdf:Property ;
    rdfs:label 'Phase From' ;
    rdfs:comment 'The clinical development phase the program was in at the time of the decision (the originating phase). Relevant for phase transition decisions. [ENUM-REF-CANDIDATE: preclinical|phase_1|phase_1b|phase_2|phase_2b|phase_3|phase_3b|phase_4|nda_bla_submission|post_marketing — promote to reference product]' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseTo rdf:type rdf:Property ;
    rdfs:label 'Phase To' ;
    rdfs:comment 'The target clinical development phase the program is transitioning into as a result of this decision. Null if the decision is not a phase transition. [ENUM-REF-CANDIDATE: preclinical|phase_1|phase_1b|phase_2|phase_2b|phase_3|phase_3b|phase_4|nda_bla_submission|post_marketing — promote to reference product]' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAgencyConsulted rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency Consulted' ;
    rdfs:comment 'Name(s) of regulatory agencies (e.g., FDA, EMA, PMDA, MHRA) that were formally consulted (e.g., via Type B meeting, scientific advice) prior to or as part of this decision. Supports regulatory strategy documentation.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionImpact rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Impact' ;
    rdfs:comment 'Indicates the regulatory submission consequence of this decision (e.g., requires IND amendment, impacts NDA/BLA filing strategy, triggers MAA update, requires eCTD update, or no regulatory submission impact). [ENUM-REF-CANDIDATE: none|ind_amendment|nda_bla_impact|maa_impact|ectd_update|ind_withdrawal|other — promote to reference product]' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentSummary rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Summary' ;
    rdfs:comment 'Narrative summary of the key risks (clinical, regulatory, commercial, operational) assessed as part of the decision-making process. Supports portfolio risk governance and CAPA linkage. Business-confidential strategic content.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetySignalFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Signal Flag' ;
    rdfs:comment 'Indicates whether a safety signal, serious adverse event (SAE), or suspected unexpected serious adverse reaction (SUSAR) was a contributing factor in this decision. True if safety data influenced the decision outcome.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorConcurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Sponsor Concurrence Date' ;
    rdfs:comment 'Date on which the sponsor formally concurred with or ratified this program decision. Null if sponsor_concurrence_flag is False or not applicable.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sponsorConcurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Sponsor Concurrence Flag' ;
    rdfs:comment 'Indicates whether the pharmaceutical or biotech sponsor formally concurred with this program decision. True if sponsor sign-off was obtained. Relevant for CRO-managed programs where sponsor approval is a governance requirement.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportingDataSummary rdf:type rdf:Property ;
    rdfs:label 'Supporting Data Summary' ;
    rdfs:comment 'Structured summary of the key clinical, safety, biostatistical, and/or commercial data that informed the decision (e.g., interim analysis results, safety signal assessment, market research findings). Business-confidential program intelligence.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementPreferredProviderAgreementId rdf:type rdf:Property ;
    rdfs:label 'Agreement Preferred Provider Agreement Id' ;
    rdfs:comment 'Foreign key linking to agreement.preferred_provider_agreement. Business justification: PPAs explicitly establish governance committees (governance_committee_name, governance_review_frequency in preferred_provider_agreement). Linking program_governance to the governing PPA enables PPA go' ;
    rdfs:domain ind:Governance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PreferredProviderAgreement .

ind:escalationBodyGovernanceId rdf:type rdf:Property ;
    rdfs:label 'Escalation Body Governance Id' ;
    rdfs:comment 'Reference to the higher-level governance body to which unresolved issues or decisions exceeding this body\'s authority are escalated. Supports governance hierarchy modeling.' ;
    rdfs:domain ind:Governance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Governance .

ind:applicableRegulations rdf:type rdf:Property ;
    rdfs:label 'Applicable Regulations' ;
    rdfs:comment 'Comma-separated list of regulatory frameworks and guidelines governing this body\'s operations (e.g., \'ICH E6(R2), 21 CFR Part 312, EU CTR 536/2014, ISO 14155\'). Supports compliance tracking and inspection readiness.' ;
    rdfs:domain ind:Governance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyCode rdf:type rdf:Property ;
    rdfs:label 'Body Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the governance body within the program portfolio, used in CTMS and reporting systems (e.g., \'JDC-ONC-001\', \'PRB-CARD-002\').' ;
    rdfs:domain ind:Governance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyName rdf:type rdf:Property ;
    rdfs:label 'Body Name' ;
    rdfs:comment 'Official name of the governance body or oversight committee established to manage the clinical development program (e.g., \'Oncology Program Steering Committee\', \'Phase II/III Joint Development Committee\').' ;
    rdfs:domain ind:Governance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyType rdf:type rdf:Property ;
    rdfs:label 'Body Type' ;
    rdfs:comment 'Classification of the governance body by its structural role and authority level within the program. [ENUM-REF-CANDIDATE: Joint Development Committee|Program Review Board|Portfolio Review Committee|Steering Committee|Data Monitoring Committee|Operating Committee|Executive Oversight Committee|Scientific Advisory Board — promote to reference product]' ;
    rdfs:domain ind:Governance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:charterApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Charter Approval Date' ;
    rdfs:comment 'Date on which the current version of the governance body charter was formally approved by authorized signatories.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:charterReference rdf:type rdf:Property ;
    rdfs:label 'Charter Reference' ;
    rdfs:comment 'Document identifier or eTMF reference number for the formal charter that defines the governance body\'s mandate, authority, and operating procedures. Typically stored in Veeva Vault eTMF.' ;
    rdfs:domain ind:Governance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityRequirement rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Requirement' ;
    rdfs:comment 'Level of confidentiality required for governance body deliberations, documents, and decisions. Full confidentiality is typically required for DMC/DSMB bodies with access to unblinded data.' ;
    rdfs:domain ind:Governance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictOfInterestPolicy rdf:type rdf:Property ;
    rdfs:label 'Conflict Of Interest Policy' ;
    rdfs:comment 'Reference to the conflict of interest policy or disclosure requirements applicable to governance body members, including the document identifier or policy version. Critical for independent committees such as DMC/DSMB.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:croCoChair rdf:type rdf:Property ;
    rdfs:label 'Cro Co Chair' ;
    rdfs:comment 'Name or identifier of the CRO\'s designated co-chair for the governance body. Represents the CRO\'s senior leadership in sponsor-CRO governance structures such as Joint Development Committees.' ;
    rdfs:domain ind:Governance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Decision Authority Level' ;
    rdfs:comment 'Classification of the governance body\'s decision-making power: whether its decisions are advisory recommendations, binding resolutions, or require escalation to a higher authority.' ;
    rdfs:domain ind:Governance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionAuthorityScope rdf:type rdf:Property ;
    rdfs:label 'Decision Authority Scope' ;
    rdfs:comment 'Narrative description of the types of decisions the governance body is authorized to make, including escalation thresholds, budget authority limits, protocol amendment approvals, and go/no-go decision rights as defined in the charter.' ;
    rdfs:domain ind:Governance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'Date on which the governance body was formally dissolved or disbanded. Null if the body is still active. Marks the end of the body\'s authority and oversight responsibilities.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:formationDate rdf:type rdf:Property ;
    rdfs:label 'Formation Date' ;
    rdfs:comment 'Date on which the governance body was formally established and constituted for the clinical development program. Marks the effective start of the body\'s authority.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:governanceStatus rdf:type rdf:Property ;
    rdfs:label 'Governance Status' ;
    rdfs:comment 'Current lifecycle status of the governance body, indicating whether it is actively operating, temporarily suspended, or formally dissolved.' ;
    rdfs:domain ind:Governance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governanceTier rdf:type rdf:Property ;
    rdfs:label 'Governance Tier' ;
    rdfs:comment 'Hierarchical tier of the governance body within the program\'s governance framework. Strategic bodies set direction and approve major decisions; Operational bodies manage execution; Tactical bodies handle day-to-day coordination.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:independenceRequirement rdf:type rdf:Property ;
    rdfs:label 'Independence Requirement' ;
    rdfs:comment 'Classification of the independence requirement for governance body membership, particularly relevant for Data Monitoring Committees (DMC/DSMB) where regulatory guidance mandates independence from the sponsor and study team.' ;
    rdfs:domain ind:Governance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCharterReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Charter Review Date' ;
    rdfs:comment 'Date of the most recent formal review of the governance body charter. Used to track compliance with the defined review cycle and flag overdue reviews.' ;
    rdfs:domain ind:Governance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:memberCompositionSummary rdf:type rdf:Property ;
    rdfs:label 'Member Composition Summary' ;
    rdfs:comment 'Narrative summary describing the composition of the governance body membership, including functional roles represented (e.g., Clinical, Regulatory, Biostatistics, Finance, Medical Affairs, Sponsor, CRO) and any independence requirements.' ;
    rdfs:domain ind:Governance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minutesArchivalLocation rdf:type rdf:Property ;
    rdfs:label 'Minutes Archival Location' ;
    rdfs:comment 'System or repository location where governance body meeting minutes are archived (e.g., Veeva Vault eTMF folder path, document management system reference). Supports TMF completeness and inspection readiness.' ;
    rdfs:domain ind:Governance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minutesRequired rdf:type rdf:Property ;
    rdfs:label 'Minutes Required' ;
    rdfs:comment 'Indicates whether formal meeting minutes are required to be produced and archived for each governance body meeting, as mandated by the charter or regulatory requirements.' ;
    rdfs:domain ind:Governance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextCharterReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Charter Review Date' ;
    rdfs:comment 'Scheduled date for the next formal review of the governance body charter. Calculated from last review date plus review cycle. Supports proactive compliance management.' ;
    rdfs:domain ind:Governance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingProceduresRef rdf:type rdf:Property ;
    rdfs:label 'Operating Procedures Ref' ;
    rdfs:comment 'Reference to the Standard Operating Procedures (SOPs) or working procedures that govern the governance body\'s operations, meeting conduct, and decision-making processes. Links to MasterControl SOP repository.' ;
    rdfs:domain ind:Governance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programPhase rdf:type rdf:Property ;
    rdfs:label 'Program Phase' ;
    rdfs:comment 'Clinical development phase(s) covered by the program under this governance body\'s oversight. Indicates the stage of drug development being governed. [ENUM-REF-CANDIDATE: Phase I|Phase I/II|Phase II|Phase II/III|Phase III|Phase IV|Pre-Clinical — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quorumPercentage rdf:type rdf:Property ;
    rdfs:label 'Quorum Percentage' ;
    rdfs:comment 'Minimum percentage of total voting membership required for quorum, expressed as a decimal (e.g., 66.67 for two-thirds majority). Used when quorum is defined proportionally rather than by fixed count.' ;
    rdfs:domain ind:Governance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sponsorCoChair rdf:type rdf:Property ;
    rdfs:label 'Sponsor Co Chair' ;
    rdfs:comment 'Name or identifier of the sponsor organization\'s designated co-chair for the governance body. Typically a senior sponsor representative in Joint Development Committee structures.' ;
    rdfs:domain ind:Governance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorOrganization rdf:type rdf:Property ;
    rdfs:label 'Sponsor Organization' ;
    rdfs:comment 'Name of the pharmaceutical or biotech sponsor organization that has established or co-chairs this governance body. Identifies the primary sponsor entity in multi-sponsor or co-development programs.' ;
    rdfs:domain ind:Governance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Indicator Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: KRI ownership is assigned to named employees accountable for monitoring and reporting in risk-based oversight frameworks. indicator_owner is a denormalized plain-text field; a FK enables KRI accountab' ;
    rdfs:domain ind:Kri ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:previousVersionKriId rdf:type rdf:Property ;
    rdfs:label 'Previous Version Kri Id' ;
    rdfs:comment 'Reference to the prior version of this KRI/KPI definition record, enabling a full version history chain for audit and regulatory inspection purposes.' ;
    rdfs:domain ind:Kri ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Kri .

ind:applicableDevelopmentPhase rdf:type rdf:Property ;
    rdfs:label 'Applicable Development Phase' ;
    rdfs:comment 'The clinical development phase(s) for which this indicator definition is applicable (e.g., Phase_I, Phase_II, Phase_III, Phase_IV, all_phases). Allows phase-specific KRI/KPI frameworks within the same program.' ;
    rdfs:domain ind:Kri ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkSource rdf:type rdf:Property ;
    rdfs:label 'Benchmark Source' ;
    rdfs:comment 'The source of the industry benchmark or historical baseline used to set the target and warning thresholds (e.g., \'TransCelerate Industry Benchmark 2023\', \'Internal Historical Average 2020-2023\', \'FDA Guidance\', \'Sponsor SOPs\'). Provides auditability for threshold-setting decisions.' ;
    rdfs:domain ind:Kri ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkValue rdf:type rdf:Property ;
    rdfs:label 'Benchmark Value' ;
    rdfs:comment 'The industry or historical benchmark value for this indicator against which the target threshold was calibrated. Enables comparison of program performance against external standards.' ;
    rdfs:domain ind:Kri ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capaRequiredOnBreach rdf:type rdf:Property ;
    rdfs:label 'Capa Required On Breach' ;
    rdfs:comment 'Indicates whether a Corrective and Preventive Action (CAPA) must be initiated in MasterControl when this indicator breaches its critical threshold. Supports GCP compliance and quality management workflows.' ;
    rdfs:domain ind:Kri ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalThreshold rdf:type rdf:Property ;
    rdfs:label 'Critical Threshold' ;
    rdfs:comment 'The threshold value at which the indicator triggers a red alert, indicating a critical risk or performance failure requiring immediate escalation to program governance or sponsor. Drives CAPA initiation.' ;
    rdfs:domain ind:Kri ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSourceObject rdf:type rdf:Property ;
    rdfs:label 'Data Source Object' ;
    rdfs:comment 'The specific module, dataset, form, or table within the source system from which indicator data is extracted (e.g., \'AE Form\' in Medidata Rave, \'Case Safety Report\' in Oracle Argus Safety, \'Visit Tracking\' in Oracle Siebel CTMS). Supports precise data lineage documentation.' ;
    rdfs:domain ind:Kri ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'The operational system of record from which the raw data for this indicator is sourced (e.g., Medidata Rave, Oracle Argus Safety, Oracle Siebel CTMS, SAP S/4HANA). Enables data lineage tracing and source system reconciliation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsmbReportable rdf:type rdf:Property ;
    rdfs:label 'Dsmb Reportable' ;
    rdfs:comment 'Indicates whether a critical threshold breach for this indicator must be reported to the Data Safety Monitoring Board (DSMB) or Data Monitoring Committee (DMC). Drives automated DSMB notification workflows.' ;
    rdfs:domain ind:Kri ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationOwner rdf:type rdf:Property ;
    rdfs:label 'Escalation Owner' ;
    rdfs:comment 'Name or role of the individual or committee to whom a critical threshold breach is escalated (e.g., \'Program Steering Committee\', \'DSMB\', \'Sponsor Medical Monitor\'). Distinct from the indicator owner who manages routine monitoring.' ;
    rdfs:domain ind:Kri ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governanceCommittee rdf:type rdf:Property ;
    rdfs:label 'Governance Committee' ;
    rdfs:comment 'The governance body (e.g., Program Review Board, Portfolio Governance Committee, DSMB/DMC, Joint Steering Committee) in whose meetings this indicator is reviewed. Links the KRI/KPI to the appropriate oversight forum.' ;
    rdfs:domain ind:Kri ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorCategory rdf:type rdf:Property ;
    rdfs:label 'Indicator Category' ;
    rdfs:comment 'Business domain category grouping this indicator for portfolio governance reporting (e.g., safety, data_quality, enrollment, site_performance, regulatory, supply_chain, finance, operational). Enables domain-level roll-up in governance dashboards. [ENUM-REF-CANDIDATE: safety|data_quality|enrollment|site_performance|regulatory|supply_chain|finance|operational|workforce|biostatistics — promote to reference product]' ;
    rdfs:domain ind:Kri ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorCode rdf:type rdf:Property ;
    rdfs:label 'Indicator Code' ;
    rdfs:comment 'Unique business-facing alphanumeric code identifying this KRI/KPI definition within the program portfolio (e.g., PRG-KRI-001, PRG-KPI-042). Used as the externally-known identifier in governance reports and portfolio dashboards.' ;
    rdfs:domain ind:Kri ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorSubtype rdf:type rdf:Property ;
    rdfs:label 'Indicator Subtype' ;
    rdfs:comment 'Further classification within the indicator category (e.g., \'SAE Reporting\' under safety, \'Protocol Deviation\' under data_quality, \'Screen Failure Rate\' under enrollment). Provides granular segmentation for drill-down analytics.' ;
    rdfs:domain ind:Kri ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalPath rdf:type rdf:Property ;
    rdfs:label 'Is Critical Path' ;
    rdfs:comment 'Indicates whether this indicator is on the critical path for program delivery milestones. Critical path KRIs/KPIs receive priority escalation and are featured in executive portfolio dashboards.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryCommitment rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Commitment' ;
    rdfs:comment 'Indicates whether this KRI/KPI is a formal regulatory commitment to a health authority (e.g., FDA, EMA) as part of a Risk Management Plan, IND, or study protocol. Regulatory commitment indicators require mandatory reporting and cannot be retired without authority approval.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyIndicator rdf:type rdf:Property ;
    rdfs:label 'Is Safety Indicator' ;
    rdfs:comment 'Indicates whether this indicator is classified as a safety-related KRI (e.g., SAE reporting timeliness, SUSAR submission compliance, AE data completeness). Safety indicators receive heightened governance scrutiny and may trigger DSMB notification.' ;
    rdfs:domain ind:Kri ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementDirection rdf:type rdf:Property ;
    rdfs:label 'Measurement Direction' ;
    rdfs:comment 'Indicates whether a higher value is favorable (e.g., consent rate), a lower value is favorable (e.g., protocol deviation rate), or the value should remain within a target range. Governs how threshold breaches are evaluated in governance logic.' ;
    rdfs:domain ind:Kri ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'Unit of measure for the indicator value (e.g., \'percentage\', \'days\', \'count\', \'rate per 100 patient-years\', \'USD\'). Required for correct threshold interpretation and cross-program comparability.' ;
    rdfs:domain ind:Kri ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricDefinition rdf:type rdf:Property ;
    rdfs:label 'Metric Definition' ;
    rdfs:comment 'Precise business definition of what this indicator measures, including the numerator and denominator logic where applicable (e.g., \'Number of SAEs reported within 24 hours divided by total SAEs reported in the period, expressed as a percentage\'). Ensures consistent interpretation across sites and studies.' ;
    rdfs:domain ind:Kri ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodType rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Type' ;
    rdfs:comment 'Defines whether the indicator is measured over a rolling window (e.g., last 30 days), cumulatively from study start, at a specific point in time, or study-to-date. Critical for consistent interpretation of computed values.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleFunction rdf:type rdf:Property ;
    rdfs:label 'Responsible Function' ;
    rdfs:comment 'The organizational function or department accountable for monitoring and responding to this indicator (e.g., \'Clinical Operations\', \'Biostatistics\', \'Pharmacovigilance\', \'Data Management\', \'Regulatory Affairs\'). Drives escalation routing in governance workflows.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycle rdf:type rdf:Property ;
    rdfs:label 'Review Cycle' ;
    rdfs:comment 'Frequency at which the indicator definition itself (thresholds, metric definition, ownership) is formally reviewed and potentially updated by the governance committee. Distinct from measurement_frequency which governs data collection cadence.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetThreshold rdf:type rdf:Property ;
    rdfs:label 'Target Threshold' ;
    rdfs:comment 'The desired or optimal value for this indicator representing expected performance under normal operating conditions. Serves as the baseline against which warning and critical thresholds are calibrated.' ;
    rdfs:domain ind:Kri ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdOperator rdf:type rdf:Property ;
    rdfs:label 'Threshold Operator' ;
    rdfs:comment 'Logical operator defining how the measured value is compared to the warning and critical thresholds (e.g., \'gt\' = greater than triggers alert, \'lt\' = less than triggers alert, \'between\' = value must remain within a range). Required for automated threshold evaluation logic.' ;
    rdfs:domain ind:Kri ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warningThreshold rdf:type rdf:Property ;
    rdfs:label 'Warning Threshold' ;
    rdfs:comment 'The threshold value at which the indicator triggers a yellow/amber alert, indicating early risk signal requiring heightened monitoring or investigation. Distinct from the critical threshold which triggers escalation.' ;
    rdfs:domain ind:Kri ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kriReadingId rdf:type rdf:Property ;
    rdfs:label 'Kri Reading Id' ;
    rdfs:comment 'Unique surrogate identifier for each periodic KRI/KPI reading record captured at the program level. Serves as the primary key for this transactional observation event.' ;
    rdfs:domain ind:KriReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByReadingKriReadingId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Reading Kri Reading Id' ;
    rdfs:comment 'Reference to the corrected KRI reading record that supersedes this one when reading_status is \'superseded\'. Enables full audit chain reconstruction for regulatory inspection, ensuring the history of corrections is traceable per ALCOA+ and 21 CFR Part 11 requirements.' ;
    rdfs:domain ind:KriReading ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KriReading .

ind:actionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Action Required Flag' ;
    rdfs:comment 'Indicates whether this KRI reading requires a documented corrective or mitigation action. True = a CAPA or risk mitigation action must be initiated; False = no action required beyond continued monitoring.' ;
    rdfs:domain ind:KriReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amberThresholdLower rdf:type rdf:Property ;
    rdfs:label 'Amber Threshold Lower' ;
    rdfs:comment 'The lower boundary of the caution (amber) performance range for this KRI at the time of reading. Values within the amber band trigger heightened monitoring and management attention without requiring immediate escalation.' ;
    rdfs:domain ind:KriReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amberThresholdUpper rdf:type rdf:Property ;
    rdfs:label 'Amber Threshold Upper' ;
    rdfs:comment 'The upper boundary of the caution (amber) performance range for this KRI at the time of reading. Denormalized from the KRI definition to preserve the threshold configuration in effect at reading time.' ;
    rdfs:domain ind:KriReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:computationMethod rdf:type rdf:Property ;
    rdfs:label 'Computation Method' ;
    rdfs:comment 'Indicates whether the observed value was computed automatically by an analytics pipeline, entered manually by a data manager or CRA, or produced through a semi-automated process requiring human validation. Relevant for data quality assessment and audit purposes under 21 CFR Part 11.' ;
    rdfs:domain ind:KriReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmed Timestamp' ;
    rdfs:comment 'The date and time at which this KRI reading was formally confirmed by the governance reviewer. Represents a distinct lifecycle event timestamp required for 21 CFR Part 11 electronic records compliance and audit trail completeness.' ;
    rdfs:domain ind:KriReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Indicates whether a data quality concern was identified with the underlying source data used to compute this reading (e.g., incomplete EDC data, site data not yet reconciled, known system outage). True = data quality caveat applies; False = data considered complete and reliable.' ;
    rdfs:domain ind:KriReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataQualityNote rdf:type rdf:Property ;
    rdfs:label 'Data Quality Note' ;
    rdfs:comment 'Free-text description of the specific data quality issue identified when data_quality_flag is True. Documents the nature of the concern (e.g., \'Site 007 data not yet entered in EDC\', \'CTMS extract delayed by 3 days\') to support audit review and reading interpretation.' ;
    rdfs:domain ind:KriReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSnapshotReference rdf:type rdf:Property ;
    rdfs:label 'Data Snapshot Reference' ;
    rdfs:comment 'Identifier or version label of the source data snapshot used to compute this KRI reading (e.g., EDC data extract version, CTMS report run ID, database lock reference). Ensures full traceability of the observed value back to the underlying data state, supporting ALCOA+ principles.' ;
    rdfs:domain ind:KriReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:greenThresholdLower rdf:type rdf:Property ;
    rdfs:label 'Green Threshold Lower' ;
    rdfs:comment 'The lower boundary of the acceptable (green) performance range for this KRI at the time of reading. Denormalized from the KRI definition to preserve the threshold configuration that was in effect at the time of this specific reading, supporting historical audit and trend analysis.' ;
    rdfs:domain ind:KriReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:greenThresholdUpper rdf:type rdf:Property ;
    rdfs:label 'Green Threshold Upper' ;
    rdfs:comment 'The upper boundary of the acceptable (green) performance range for this KRI at the time of reading. Denormalized from the KRI definition to preserve the threshold configuration in effect at reading time.' ;
    rdfs:domain ind:KriReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kriCategory rdf:type rdf:Property ;
    rdfs:label 'Kri Category' ;
    rdfs:comment 'High-level domain category classifying the KRI for portfolio-level aggregation and governance reporting. Enables committee members to filter and group indicators by risk domain. [ENUM-REF-CANDIDATE: safety|data_quality|enrollment|site_performance|regulatory|supply_chain|finance|other — promote to reference product]' ;
    rdfs:domain ind:KriReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorReadingValue rdf:type rdf:Property ;
    rdfs:label 'Prior Reading Value' ;
    rdfs:comment 'The observed value from the immediately preceding review cycle for this KRI. Stored on the current reading record to enable direct trend comparison without requiring a self-join, supporting governance committee dashboards and period-over-period analysis.' ;
    rdfs:domain ind:KriReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readingDate rdf:type rdf:Property ;
    rdfs:label 'Reading Date' ;
    rdfs:comment 'The calendar date on which this KRI observation was captured or the data snapshot was taken. Represents the principal business event date for this measurement, distinct from the record creation timestamp. Aligns with the review cycle cadence (weekly, monthly, quarterly).' ;
    rdfs:domain ind:KriReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:readingReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Reading Reference Code' ;
    rdfs:comment 'Human-readable business identifier for this KRI reading event, typically formatted as KRI-RDG-{PROGRAM_CODE}-{YYYYMMDD}. Used in governance reports, dashboards, and audit trails to uniquely reference a specific reading without exposing the surrogate key.' ;
    rdfs:domain ind:KriReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingStatus rdf:type rdf:Property ;
    rdfs:label 'Reading Status' ;
    rdfs:comment 'Lifecycle status of this KRI reading record. \'draft\' = computed but not yet reviewed; \'under_review\' = submitted for governance committee review; \'confirmed\' = formally accepted by the governance body; \'superseded\' = replaced by a corrected reading; \'voided\' = invalidated due to data quality issues.' ;
    rdfs:domain ind:KriReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCyclePeriod rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Period' ;
    rdfs:comment 'The governance review period this reading belongs to, expressed as a standardized period label (e.g., \'2024-Q1\', \'2024-W23\', \'2024-03\'). Enables time-series alignment across multiple KRIs within the same review cycle for governance committee reporting.' ;
    rdfs:domain ind:KriReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycleType rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Type' ;
    rdfs:comment 'Frequency classification of the review cycle during which this reading was generated. Determines the expected cadence for trend analysis and threshold breach escalation.' ;
    rdfs:domain ind:KriReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerCommentary rdf:type rdf:Property ;
    rdfs:label 'Reviewer Commentary' ;
    rdfs:comment 'Free-text narrative commentary provided by the governance committee reviewer or program lead explaining the context of the observed value, root cause of any threshold breach, mitigating factors, or planned actions. Captured at the time of formal review.' ;
    rdfs:domain ind:KriReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'The planned or aspirational target value for this KRI in the current review cycle, as defined in the program plan or Statistical Analysis Plan (SAP). Distinct from threshold boundaries — represents the desired performance level, enabling variance-from-target analysis.' ;
    rdfs:domain ind:KriReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trendMagnitude rdf:type rdf:Property ;
    rdfs:label 'Trend Magnitude' ;
    rdfs:comment 'The absolute numeric change between the current observed_value and the prior_reading_value, expressed in the same unit_of_measure. Positive values indicate increase; negative values indicate decrease. Enables quantitative trend severity assessment beyond directional classification.' ;
    rdfs:domain ind:KriReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceFromTarget rdf:type rdf:Property ;
    rdfs:label 'Variance From Target' ;
    rdfs:comment 'The arithmetic difference between the observed_value and the target_value (observed minus target). Negative values indicate underperformance; positive values indicate overperformance relative to target. Stored as a raw operational field to support governance reporting without requiring recalculation.' ;
    rdfs:domain ind:KriReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predecessorMilestoneProgramMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Milestone Program Milestone Id' ;
    rdfs:comment 'Reference to the program_milestone record that must be achieved before this milestone can begin. Captures sequential dependency relationships for critical path analysis and schedule management.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgramMilestone .

ind:actualDate rdf:type rdf:Property ;
    rdfs:label 'Actual Date' ;
    rdfs:comment 'Calendar date on which the milestone was actually achieved. Populated only when milestone_status is \'achieved\'. Used to calculate schedule variance against planned and baseline dates.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'Formally approved baseline date for the milestone, which may differ from the original planned date following a formal re-baseline event. Used for earned value management and schedule performance tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decisionRationale rdf:type rdf:Property ;
    rdfs:label 'Decision Rationale' ;
    rdfs:comment 'Narrative explanation of the rationale behind the go/no-go decision or milestone outcome, including key data readouts, safety findings, or strategic considerations that influenced the decision.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayReasonCode rdf:type rdf:Property ;
    rdfs:label 'Delay Reason Code' ;
    rdfs:comment 'Standardized categorical code classifying the primary root cause of a milestone delay. Enables trend analysis across programs and portfolio-level risk reporting. Populated only when milestone is delayed. [ENUM-REF-CANDIDATE: operational|regulatory|safety|enrollment|data_quality|resource|external — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Evidence Document Ref' ;
    rdfs:comment 'Reference identifier or hyperlink to the supporting evidence document in the eTMF or document management system (e.g., Veeva Vault) that confirms milestone achievement (e.g., IND approval letter, regulatory submission receipt, DSMB meeting minutes).' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Date' ;
    rdfs:comment 'Current best estimate of when the milestone will be achieved, updated as the program progresses. Reflects the most recent forecast based on operational data and risk assessments.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goNoGoDate rdf:type rdf:Property ;
    rdfs:label 'Go No Go Date' ;
    rdfs:comment 'Date on which the formal go/no-go decision was made by the program governance committee or sponsor. Populated only for decision-gate milestone types.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goNoGoDecision rdf:type rdf:Property ;
    rdfs:label 'Go No Go Decision' ;
    rdfs:comment 'Formal program governance decision recorded at decision-gate milestones (e.g., Phase I/II transition, Phase II/III transition). Captures whether the program proceeds, is stopped, or advances with conditions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingPhase rdf:type rdf:Property ;
    rdfs:label 'Governing Phase' ;
    rdfs:comment 'The clinical development phase during which this milestone is expected to occur or to which it belongs. Enables phase-level portfolio analytics and cross-program benchmarking. [ENUM-REF-CANDIDATE: preclinical|phase_I|phase_II|phase_III|phase_IV|registration|post_approval — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether this milestone record is currently active and in scope for portfolio governance reporting. Set to False for cancelled or superseded milestones that are retained for historical audit purposes.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lagDays rdf:type rdf:Property ;
    rdfs:label 'Lag Days' ;
    rdfs:comment 'Number of calendar days of lag or lead time applied to the dependency relationship with the predecessor milestone. Positive values indicate lag (waiting period); negative values indicate lead (overlap allowed).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milestoneCode rdf:type rdf:Property ;
    rdfs:label 'Milestone Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this milestone within the program (e.g., MS-IND-001, MS-PH1-START). Used as the business identifier in CTMS, portfolio dashboards, and regulatory submissions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationAction rdf:type rdf:Property ;
    rdfs:label 'Mitigation Action' ;
    rdfs:comment 'Description of the corrective or preventive action plan in place to address identified risks or delays for this milestone. Supports CAPA tracking and portfolio governance reporting.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDate rdf:type rdf:Property ;
    rdfs:label 'Planned Date' ;
    rdfs:comment 'Originally planned calendar date for achieving this milestone as defined in the program development plan. Serves as the baseline for variance analysis and portfolio governance reporting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Current risk rating for on-time achievement of this milestone, based on the latest risk assessment. Drives portfolio-level risk reporting and proactive mitigation planning.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Schedule Variance Days' ;
    rdfs:comment 'Difference in calendar days between the actual (or forecast) date and the baseline date. Positive values indicate delay; negative values indicate early achievement. Supports portfolio governance and KPI reporting.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Further granular classification within the milestone type (e.g., within \'regulatory\': IND Filing, NDA Submission, BLA Submission, MAA Submission; within \'clinical_phase\': Phase I Start, Phase II Start, Phase III Start, Phase IV Start). [ENUM-REF-CANDIDATE: IND_filing|NDA_submission|BLA_submission|MAA_submission|phase_I_start|phase_II_start|phase_III_start|phase_IV_start|DSMB_review|DBL|go_no_go — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceCommentary rdf:type rdf:Property ;
    rdfs:label 'Variance Commentary' ;
    rdfs:comment 'Free-text explanation of the root cause and impact of any schedule variance between planned and actual/forecast dates. Required when schedule_variance_days exceeds threshold. Supports portfolio governance escalation and executive reporting.' ;
    rdfs:domain ind:ProgramMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTargetDate rdf:type rdf:Property ;
    rdfs:label 'Approval Target Date' ;
    rdfs:comment 'Planned date for receipt of regulatory approval (e.g., FDA approval, EMA CHMP positive opinion) for the primary indication. Used for commercial launch planning and portfolio milestone reporting.' ;
    rdfs:domain ind:ProgramPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:breakthroughDesignation rdf:type rdf:Property ;
    rdfs:label 'Breakthrough Designation' ;
    rdfs:comment 'Indicates whether the investigational product has received FDA Breakthrough Therapy Designation (BTD) or EMA PRIME (PRIority MEdicines) designation for the target indication. Enables more intensive FDA/EMA guidance and rolling review.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compoundCode rdf:type rdf:Property ;
    rdfs:label 'Compound Code' ;
    rdfs:comment 'The sponsor\'s internal compound or asset code for the investigational product covered by this development plan (e.g., \'XYZ-001\', \'ABC-123\'). Used as the primary asset identifier across portfolio management systems.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'The date on which this version of the Clinical Development Plan (CDP) is expected to conclude or be superseded. Null for open-ended plans. Used for planning horizon calculations and version lifecycle management.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fihTargetDate rdf:type rdf:Property ;
    rdfs:label 'Fih Target Date' ;
    rdfs:comment 'Planned date for the first-in-human (FIH) dose administration for the program. A key program milestone used for portfolio milestone tracking and IND/CTA filing planning.' ;
    rdfs:domain ind:ProgramPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goNoGoCriteria rdf:type rdf:Property ;
    rdfs:label 'Go No Go Criteria' ;
    rdfs:comment 'Documented criteria that will be used to make go/no-go decisions at key program milestones (e.g., Phase II proof-of-concept readout, interim analysis results). Defines the evidence thresholds required to advance the program.' ;
    rdfs:domain ind:ProgramPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:innName rdf:type rdf:Property ;
    rdfs:label 'Inn Name' ;
    rdfs:comment 'The International Nonproprietary Name (INN) or proposed INN (pINN) for the investigational product, as assigned or applied for from the WHO INN Programme. Used in regulatory submissions and scientific publications.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadRegulatoryAgency rdf:type rdf:Property ;
    rdfs:label 'Lead Regulatory Agency' ;
    rdfs:comment 'The primary regulatory authority for the lead market submission under this development plan (e.g., FDA for US, EMA for EU, PMDA for Japan). Determines the primary regulatory strategy and submission format (eCTD). [ENUM-REF-CANDIDATE: FDA|EMA|PMDA|MHRA|TGA|Health_Canada|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaSubmissionTargetDate rdf:type rdf:Property ;
    rdfs:label 'Nda Submission Target Date' ;
    rdfs:comment 'Planned date for the primary regulatory submission (NDA/BLA/MAA) to the lead regulatory authority. A key program milestone driving backward planning for Phase III completion, Clinical Study Report (CSR) preparation, and eCTD assembly.' ;
    rdfs:domain ind:ProgramPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the plan document indicating its stage in the approval lifecycle: initial (first draft), revised (updated after review), amended (post-approval change), approved (formally endorsed), or final (locked version submitted to regulatory authority).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Planned Budget Usd' ;
    rdfs:comment 'The total approved budget envelope for the entire clinical development program as defined in this plan version, expressed in US Dollars (USD). Represents the high-level financial commitment approved by governance. Classified as confidential due to commercial sensitivity.' ;
    rdfs:domain ind:ProgramPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedStudyCount rdf:type rdf:Property ;
    rdfs:label 'Planned Study Count' ;
    rdfs:comment 'The total number of clinical studies (Phase I through Phase III/IV) planned under this development program as defined in the CDP. Used for portfolio capacity planning and milestone tracking.' ;
    rdfs:domain ind:ProgramPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningHorizonYears rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Years' ;
    rdfs:comment 'The total number of years covered by this Clinical Development Plan (CDP), from first-in-human (FIH) or current phase through anticipated regulatory approval. Drives long-range resource planning and portfolio forecasting.' ;
    rdfs:domain ind:ProgramPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:poaTargetDate rdf:type rdf:Property ;
    rdfs:label 'Poa Target Date' ;
    rdfs:comment 'Planned date for the proof-of-concept (POC) or proof-of-activity (POA) readout, typically at the end of Phase II. A critical go/no-go decision milestone for program continuation and investment decisions.' ;
    rdfs:domain ind:ProgramPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryPathway rdf:type rdf:Property ;
    rdfs:label 'Regulatory Pathway' ;
    rdfs:comment 'The regulatory development pathway designated for the program asset. Drives planning assumptions for review timelines and submission strategy. [ENUM-REF-CANDIDATE: standard|accelerated|breakthrough|orphan|fast_track|priority_review|rolling_review — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'The date from which this version of the Clinical Development Plan (CDP) becomes effective and governs program activities. Corresponds to the plan approval date for approved versions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:strategyNarrative rdf:type rdf:Property ;
    rdfs:label 'Strategy Narrative' ;
    rdfs:comment 'Free-text narrative describing the overall clinical development strategy for the program, including scientific rationale, competitive landscape considerations, regulatory strategy, and key decision points. Classified as confidential due to proprietary strategic content.' ;
    rdfs:domain ind:ProgramPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tppReference rdf:type rdf:Property ;
    rdfs:label 'Tpp Reference' ;
    rdfs:comment 'Document identifier or version reference for the Target Product Profile (TPP) that defines the desired product characteristics (efficacy, safety, dosing) guiding the development plan. The TPP is the strategic anchor for all clinical and regulatory decisions.' ;
    rdfs:domain ind:ProgramPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:croOrganizationId rdf:type rdf:Property ;
    rdfs:label 'Cro Organization Id' ;
    rdfs:comment 'Reference to the Contract Research Organization (CRO) responsible for delivering the planned resources, if applicable. Null for internally resourced programs.' ;
    rdfs:domain ind:ProgramResourcePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organization .

ind:planOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Plan Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Resource plan ownership is assigned to named employees accountable for FTE demand forecasting and workforce planning governance. plan_owner is a denormalized plain-text field; a FK enables resource pl' ;
    rdfs:domain ind:ProgramResourcePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:predecessorPlanProgramResourcePlanId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Plan Program Resource Plan Id' ;
    rdfs:comment 'Reference to the prior version of this resource plan that this record supersedes, enabling version lineage tracking across plan revisions.' ;
    rdfs:domain ind:ProgramResourcePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgramResourcePlan .

ind:actualFteCount rdf:type rdf:Property ;
    rdfs:label 'Actual Fte Count' ;
    rdfs:comment 'The actual number of FTEs currently assigned and active for this functional area and role within the program, sourced from Workday HCM actuals.' ;
    rdfs:domain ind:ProgramResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastedCostUsd rdf:type rdf:Property ;
    rdfs:label 'Forecasted Cost Usd' ;
    rdfs:comment 'Current rolling forecast of total resource cost in US Dollars for this functional area and role, updated as FTE forecasts and rate assumptions change.' ;
    rdfs:domain ind:ProgramResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastedFteCount rdf:type rdf:Property ;
    rdfs:label 'Forecasted Fte Count' ;
    rdfs:comment 'The current rolling forecast of FTEs required for this functional area and role, updated as program scope, study timelines, or enrollment assumptions change.' ;
    rdfs:domain ind:ProgramResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastedHours rdf:type rdf:Property ;
    rdfs:label 'Forecasted Hours' ;
    rdfs:comment 'Current rolling forecast of total labor hours for this functional area and role, updated as program scope or study timelines evolve.' ;
    rdfs:domain ind:ProgramResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this resource plan within the program portfolio, used in CTMS and Workday HCM workforce planning references.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Human-readable name describing the program resource plan, e.g., \'PROG-2024-ONCOLOGY-RESOURCE-PLAN-v2\'.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCostUsd rdf:type rdf:Property ;
    rdfs:label 'Planned Cost Usd' ;
    rdfs:comment 'Planned total resource cost in US Dollars for this functional area and role over the planning period, derived from planned FTE counts and applicable rate cards. Sourced from SAP S/4HANA project accounting.' ;
    rdfs:domain ind:ProgramResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedFteCount rdf:type rdf:Property ;
    rdfs:label 'Planned Fte Count' ;
    rdfs:comment 'The baseline planned number of Full-Time Equivalents (FTEs) required for this functional area and role over the planning period, as established at plan approval.' ;
    rdfs:domain ind:ProgramResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedHours rdf:type rdf:Property ;
    rdfs:label 'Planned Hours' ;
    rdfs:comment 'Total planned labor hours for this functional area and role over the planning period, complementing FTE counts for granular capacity planning and budget alignment.' ;
    rdfs:domain ind:ProgramResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningGranularity rdf:type rdf:Property ;
    rdfs:label 'Planning Granularity' ;
    rdfs:comment 'Time granularity at which the resource plan is structured — monthly, quarterly, or annual — determining the resolution of FTE and cost forecasts.' ;
    rdfs:domain ind:ProgramResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period End Date' ;
    rdfs:comment 'End date of the resource planning horizon covered by this plan, defining the outer boundary of the workforce forecast window.' ;
    rdfs:domain ind:ProgramResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period Start Date' ;
    rdfs:comment 'Start date of the resource planning horizon covered by this plan, typically aligned to the program fiscal year or study execution window.' ;
    rdfs:domain ind:ProgramResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resourceCategory rdf:type rdf:Property ;
    rdfs:label 'Resource Category' ;
    rdfs:comment 'Classification of the resource type indicating whether the planned workforce is internal full-time employees, contract staff, Contract Research Organization (CRO) staff, or other vendor-supplied resources.' ;
    rdfs:domain ind:ProgramResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceGapFte rdf:type rdf:Property ;
    rdfs:label 'Resource Gap Fte' ;
    rdfs:comment 'The net difference between forecasted FTE demand and actual FTE supply (forecasted_fte_count minus actual_fte_count), indicating staffing shortfall (positive) or surplus (negative) for portfolio governance decisions.' ;
    rdfs:domain ind:ProgramResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resourceRole rdf:type rdf:Property ;
    rdfs:label 'Resource Role' ;
    rdfs:comment 'Specific workforce role within the functional area being planned, e.g., Clinical Research Associate (CRA), Clinical Research Coordinator (CRC), Biostatistician, Data Manager, Regulatory Affairs Specialist, Medical Monitor.' ;
    rdfs:domain ind:ProgramResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCount rdf:type rdf:Property ;
    rdfs:label 'Site Count' ;
    rdfs:comment 'Total number of investigational sites across all studies in the program contributing to the resource demand captured in this plan.' ;
    rdfs:domain ind:ProgramResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:studyCount rdf:type rdf:Property ;
    rdfs:label 'Study Count' ;
    rdfs:comment 'Number of active studies within the program that are aggregated into this resource plan, providing context for the scale of cross-study resource demand.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Risk Employee Id' ;
    rdfs:comment 'Reference to the workforce member (typically a Program Director, Clinical Lead, or Regulatory Affairs Lead) accountable for monitoring and managing this risk to resolution. Aligns with RACI accountability frameworks in GCP-compliant program governance.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedStudies rdf:type rdf:Property ;
    rdfs:label 'Affected Studies' ;
    rdfs:comment 'Comma-separated list of study protocol numbers or identifiers within the program that are impacted by this risk. Supports cross-study impact analysis and portfolio governance reporting. (Formal study-level linkage is established via the program_risk_study association product.)' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingencyPlan rdf:type rdf:Property ;
    rdfs:label 'Contingency Plan' ;
    rdfs:comment 'Documented fallback actions to be executed if the risk materializes despite mitigation efforts (e.g., \'If IND placed on clinical hold, initiate Type B meeting with FDA within 30 days\'). Supports business continuity and regulatory response planning.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTarget rdf:type rdf:Property ;
    rdfs:label 'Escalation Target' ;
    rdfs:comment 'The governance body or individual to whom the risk has been escalated (e.g., Program Steering Committee, Sponsor Medical Monitor, DSMB, FDA). Supports audit trail and governance accountability.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialExposureUsd rdf:type rdf:Property ;
    rdfs:label 'Financial Exposure Usd' ;
    rdfs:comment 'Estimated financial exposure or potential cost impact if the risk materializes, expressed in US dollars. Used for financial risk quantification, budget contingency planning, and sponsor reporting. Classified as confidential due to commercial sensitivity.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:identifier rdf:type rdf:Property ;
    rdfs:label 'Identifier' ;
    rdfs:comment 'Human-readable, externally-known unique code assigned to this risk record within the program risk register (e.g., PRSK-ONC-000123). Used in governance reports, DSMB/DMC submissions, and sponsor communications.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactRating rdf:type rdf:Property ;
    rdfs:label 'Impact Rating' ;
    rdfs:comment 'Qualitative assessment of the severity of consequences if the risk materializes, considering impact on program timeline, patient safety, regulatory approval, and financial outcomes.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactScore rdf:type rdf:Property ;
    rdfs:label 'Impact Score' ;
    rdfs:comment 'Numeric value corresponding to the impact rating (e.g., 1=very low, 2=low, 3=medium, 4=high, 5=very high). Combined with probability_score to compute the composite risk score.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mitigationStatus rdf:type rdf:Property ;
    rdfs:label 'Mitigation Status' ;
    rdfs:comment 'Current implementation status of the mitigation strategy: not_started, in_progress, completed, or on_hold. Enables tracking of mitigation execution progress separate from the overall risk status.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationStrategy rdf:type rdf:Property ;
    rdfs:label 'Mitigation Strategy' ;
    rdfs:comment 'Detailed description of the planned or implemented actions to reduce the probability or impact of the risk (e.g., \'Engage additional regulatory consultant for IND submission review\', \'Activate backup sites to offset enrollment shortfall\'). Core field for proactive risk management per ICH Q9.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientSafetyImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Patient Safety Impact Flag' ;
    rdfs:comment 'Indicates whether this risk has a direct or potential impact on patient safety, including SAE/SUSAR reporting obligations, DSMB/DMC review triggers, or clinical hold risk. Ensures safety risks receive mandatory expedited review.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:probabilityRating rdf:type rdf:Property ;
    rdfs:label 'Probability Rating' ;
    rdfs:comment 'Qualitative likelihood rating that the risk event will materialize during the program lifecycle. Typically assessed on a 5-point scale (very low to very high) per the program\'s risk management framework. Used in risk scoring and prioritization.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityScore rdf:type rdf:Property ;
    rdfs:label 'Probability Score' ;
    rdfs:comment 'Numeric value corresponding to the probability rating (e.g., 1=very low, 2=low, 3=medium, 4=high, 5=very high). Used in quantitative risk score calculation and portfolio-level risk heat map generation.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualImpactRating rdf:type rdf:Property ;
    rdfs:label 'Residual Impact Rating' ;
    rdfs:comment 'Reassessed impact rating after mitigation controls have been applied. Used alongside residual_probability_rating to compute the residual risk score and confirm risk acceptability.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualProbabilityRating rdf:type rdf:Property ;
    rdfs:label 'Residual Probability Rating' ;
    rdfs:comment 'Reassessed probability rating after mitigation controls have been applied. Compared against the initial probability_rating to demonstrate risk reduction effectiveness.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Status' ;
    rdfs:comment 'Current lifecycle state of the risk record: open (active and unresolved), mitigated (controls applied and risk reduced), closed (risk no longer applicable or resolved), accepted (risk acknowledged and formally accepted by program leadership without further mitigation).' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Composite numeric risk score, typically calculated as probability_score × impact_score (range 1–25 on a 5×5 matrix). Drives risk prioritization, escalation thresholds, and portfolio risk heat map reporting.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Target Resolution Date' ;
    rdfs:comment 'Target date by which the risk is expected to be mitigated, closed, or formally accepted. Used for milestone tracking and program governance reporting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timelineImpactDays rdf:type rdf:Property ;
    rdfs:label 'Timeline Impact Days' ;
    rdfs:comment 'Estimated number of calendar days by which the program or study timeline could be delayed if this risk materializes. Used for critical path analysis, milestone risk assessment, and sponsor portfolio reporting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toleranceThreshold rdf:type rdf:Property ;
    rdfs:label 'Tolerance Threshold' ;
    rdfs:comment 'Maximum acceptable risk score defined by the program governance framework. Risks with residual_risk_score exceeding this threshold require escalation to senior leadership or the sponsor. Supports risk acceptance decision-making.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programStatusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Program Status History Id' ;
    rdfs:comment 'Unique surrogate identifier for each program status transition record in the lifecycle audit trail.' ;
    rdfs:domain ind:ProgramStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryProgramEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Program Employee Id' ;
    rdfs:comment 'System user identifier of the person or automated process that recorded this status transition in the CTMS or data platform. Supports 21 CFR Part 11 electronic signature and audit trail requirements.' ;
    rdfs:domain ind:ProgramStatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Full name of the individual who approved this status transition. Required for regulatory inspection readiness. Classified confidential as it identifies internal personnel.' ;
    rdfs:domain ind:ProgramStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentPhaseAtTransition rdf:type rdf:Property ;
    rdfs:label 'Development Phase At Transition' ;
    rdfs:comment 'The clinical development phase of the program at the time of this status transition. Captures the phase context for historical analysis, as a program may span multiple phases over its lifecycle. [ENUM-REF-CANDIDATE: Preclinical|Phase I|Phase II|Phase III|Phase IV|NDA/BLA|Post-Approval — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProgramStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Expected Resolution Date' ;
    rdfs:comment 'Anticipated date by which the current status is expected to be resolved or transitioned again (e.g., expected lift of a clinical hold, expected resumption from On Hold). Supports program planning and portfolio forecasting.' ;
    rdfs:domain ind:ProgramStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:governanceBody rdf:type rdf:Property ;
    rdfs:label 'Governance Body' ;
    rdfs:comment 'The organizational body or committee that authorized or mandated the status transition. Examples include Portfolio Review Board, Executive Committee, Data Safety Monitoring Board (DSMB), Data Monitoring Committee (DMC), or a regulatory authority. [ENUM-REF-CANDIDATE: PORTFOLIO_REVIEW_BOARD|EXECUTIVE_COMMITTEE|DSMB|DMC|REGULATORY_AUTHORITY|SPONSOR|PROGRAM_TEAM — promote to reference product]' ;
    rdfs:domain ind:ProgramStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdLiftConditions rdf:type rdf:Property ;
    rdfs:label 'Hold Lift Conditions' ;
    rdfs:comment 'Description of the conditions or actions required to lift the current hold and transition the program back to active status. Populated when hold_type is not null. Supports program planning and regulatory response management.' ;
    rdfs:domain ind:ProgramStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdType rdf:type rdf:Property ;
    rdfs:label 'Hold Type' ;
    rdfs:comment 'Specifies the type of hold applied when the new_status is \'On Hold\' or \'Suspended\'. Distinguishes between FDA clinical holds, partial clinical holds, voluntary sponsor holds, and internal program holds. Null when new_status is not a hold state.' ;
    rdfs:domain ind:ProgramStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactedStudyCount rdf:type rdf:Property ;
    rdfs:label 'Impacted Study Count' ;
    rdfs:comment 'Number of individual clinical studies within the program that are directly impacted by this status transition. Supports portfolio impact assessment and resource planning.' ;
    rdfs:domain ind:ProgramStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCurrent rdf:type rdf:Property ;
    rdfs:label 'Is Current' ;
    rdfs:comment 'Indicates whether this record represents the most recent (current) status of the program (True) or is a historical record (False). Enables efficient querying of current program status without full history scan.' ;
    rdfs:domain ind:ProgramStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSystemGenerated rdf:type rdf:Property ;
    rdfs:label 'Is System Generated' ;
    rdfs:comment 'Indicates whether this status transition was automatically generated by a system process (True) or manually entered by a user (False). Supports audit trail integrity and distinguishes automated workflow transitions from human decisions.' ;
    rdfs:domain ind:ProgramStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The program lifecycle status immediately after this transition. Captures the \'to\' state in the state-change pair. [ENUM-REF-CANDIDATE: Concept|Planning|Active|On Hold|Suspended|Terminated|Completed — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationRequired rdf:type rdf:Property ;
    rdfs:label 'Notification Required' ;
    rdfs:comment 'Indicates whether this status transition requires formal notification to a regulatory authority (e.g., FDA, EMA). Drives regulatory affairs workflow and ensures compliance with reporting obligations.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Notification Submitted Date' ;
    rdfs:comment 'Date on which the required regulatory notification for this status transition was submitted to the relevant authority. Populated when notification_required is True. Supports compliance tracking and submission timelines.' ;
    rdfs:domain ind:ProgramStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The program lifecycle status immediately before this transition. Captures the \'from\' state in the state-change pair. [ENUM-REF-CANDIDATE: Concept|Planning|Active|On Hold|Suspended|Terminated|Completed — promote to reference product]' ;
    rdfs:domain ind:ProgramStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordedByName rdf:type rdf:Property ;
    rdfs:label 'Recorded By Name' ;
    rdfs:comment 'Full name of the individual who recorded this status transition. Required for regulatory inspection readiness and audit trail completeness per ALCOA+ principles. Classified confidential as it identifies internal personnel.' ;
    rdfs:domain ind:ProgramStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordedByRole rdf:type rdf:Property ;
    rdfs:label 'Recorded By Role' ;
    rdfs:comment 'Functional role of the individual or system that recorded the status transition. Supports accountability tracking and governance reporting. [ENUM-REF-CANDIDATE: PROGRAM_LEAD|MEDICAL_MONITOR|REGULATORY_AFFAIRS|PORTFOLIO_MANAGER|SYSTEM|SPONSOR_REPRESENTATIVE — promote to reference product]' ;
    rdfs:domain ind:ProgramStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCorrespondenceRef rdf:type rdf:Property ;
    rdfs:label 'Regulatory Correspondence Ref' ;
    rdfs:comment 'Reference number or identifier of the regulatory correspondence (e.g., FDA clinical hold letter, EMA opinion reference) associated with this status transition. Enables direct linkage to regulatory submissions and responses.' ;
    rdfs:domain ind:ProgramStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionDate rdf:type rdf:Property ;
    rdfs:label 'Transition Date' ;
    rdfs:comment 'The calendar date on which the program status formally changed. Used for milestone tracking, governance reporting, and regulatory inspection readiness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transitionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Transition Reason Code' ;
    rdfs:comment 'Standardized code categorizing the business reason for the status transition. Enables programmatic filtering and trend analysis across programs. [ENUM-REF-CANDIDATE: GOV_DECISION|REG_ACTION|SPONSOR_DIRECTIVE|SAFETY_SIGNAL|PORTFOLIO_REVIEW|MILESTONE_ACHIEVED|PROTOCOL_FAILURE|FUNDING_CHANGE — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Transition Reason Description' ;
    rdfs:comment 'Free-text narrative explaining the specific business rationale for the status transition. Provides context beyond the standardized reason code for governance review and regulatory inspection.' ;
    rdfs:domain ind:ProgramStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionSequence rdf:type rdf:Property ;
    rdfs:label 'Transition Sequence' ;
    rdfs:comment 'Ordinal sequence number of this status transition within the program lifecycle, starting at 1. Enables chronological ordering and gap detection in the audit trail.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transition Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) at which the status transition was recorded in the system. Supports 21 CFR Part 11 audit trail requirements for electronic records.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:triggeringEventDate rdf:type rdf:Property ;
    rdfs:label 'Triggering Event Date' ;
    rdfs:comment 'Date on which the triggering event (governance decision, regulatory action, sponsor directive) formally occurred. May differ from transition_date if there is a lag between the event and system recording.' ;
    rdfs:domain ind:ProgramStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:triggeringEventReference rdf:type rdf:Property ;
    rdfs:label 'Triggering Event Reference' ;
    rdfs:comment 'External reference identifier for the event that triggered the transition (e.g., governance meeting number, regulatory correspondence reference, DSMB meeting ID, sponsor directive document number). Enables traceability to source documents.' ;
    rdfs:domain ind:ProgramStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringEventType rdf:type rdf:Property ;
    rdfs:label 'Triggering Event Type' ;
    rdfs:comment 'Classification of the event that triggered the status transition. Distinguishes between governance decisions, regulatory actions, sponsor directives, Data Safety Monitoring Board (DSMB) recommendations, and other formal triggers. [ENUM-REF-CANDIDATE: GOVERNANCE_DECISION|REGULATORY_ACTION|SPONSOR_DIRECTIVE|DSMB_RECOMMENDATION|SAFETY_REVIEW|PORTFOLIO_DECISION|MILESTONE_GATE — promote to reference product]' ;
    rdfs:domain ind:ProgramStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStudyId rdf:type rdf:Property ;
    rdfs:label 'Program Study Id' ;
    rdfs:comment 'Unique surrogate identifier for the program-study association record within the clinical development program portfolio.' ;
    rdfs:domain ind:ProgramStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addedToProgramDate rdf:type rdf:Property ;
    rdfs:label 'Added To Program Date' ;
    rdfs:comment 'Calendar date on which the study was formally added to the clinical development program scope, as recorded in the CTMS or program governance system. Supports program timeline analysis and audit trail.' ;
    rdfs:domain ind:ProgramStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:associationCode rdf:type rdf:Property ;
    rdfs:label 'Association Code' ;
    rdfs:comment 'Externally-known business identifier code for this program-study linkage, used in CTMS, portfolio dashboards, and regulatory dossier cross-references (e.g., PRG-001-STU-003).' ;
    rdfs:domain ind:ProgramStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:associationStatus rdf:type rdf:Property ;
    rdfs:label 'Association Status' ;
    rdfs:comment 'Current lifecycle status of the program-study association. Active indicates the study is currently contributing to the program; removed indicates the study has been formally withdrawn from the program scope; pending indicates the association is under governance review.' ;
    rdfs:domain ind:ProgramStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossStudyDependency rdf:type rdf:Property ;
    rdfs:label 'Cross Study Dependency' ;
    rdfs:comment 'Free-text description of any formal dependencies between this study and other studies within the program (e.g., \'Requires completion of Study 001 dose-escalation before initiating\', \'Shares DSMB charter with Study 003\'). Supports program-level coordination and risk management.' ;
    rdfs:domain ind:ProgramStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csrSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Csr Submission Date' ;
    rdfs:comment 'Date on which the Clinical Study Report (CSR) for this study was submitted to the regulatory authority or included in the program\'s regulatory dossier. Supports eTMF completeness tracking and regulatory submission planning.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ctdModuleReference rdf:type rdf:Property ;
    rdfs:label 'Ctd Module Reference' ;
    rdfs:comment 'Reference to the CTD/eCTD module and section where this study\'s data will be submitted in the regulatory dossier (e.g., M5.3.5.1 for controlled clinical studies). Supports regulatory submission planning and dossier assembly.' ;
    rdfs:domain ind:ProgramStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eudractNumber rdf:type rdf:Property ;
    rdfs:label 'Eudract Number' ;
    rdfs:comment 'European Union Drug Regulating Authorities Clinical Trials (EudraCT) registration number for this study within the program. Required for EU regulatory compliance under EU CTR 536/2014.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governanceApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Governance Approval Date' ;
    rdfs:comment 'Date on which the program governance committee (e.g., Portfolio Review Board, Development Committee) formally approved the inclusion of this study in the program. Supports audit trail and governance compliance.' ;
    rdfs:domain ind:ProgramStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:indicationMeddraCode rdf:type rdf:Property ;
    rdfs:label 'Indication Meddra Code' ;
    rdfs:comment 'MedDRA Preferred Term (PT) code for the therapeutic indication addressed by this study within the program. Enables standardized cross-study indication mapping and regulatory reporting alignment.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integratedAnalysisFlag rdf:type rdf:Property ;
    rdfs:label 'Integrated Analysis Flag' ;
    rdfs:comment 'Indicates whether this study\'s data is included in a program-level integrated analysis (e.g., Integrated Summary of Safety (ISS) or Integrated Summary of Efficacy (ISE)) for the regulatory dossier. True = included in integrated analysis.' ;
    rdfs:domain ind:ProgramStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGcpCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Gcp Compliant' ;
    rdfs:comment 'Indicates whether this study is conducted in full compliance with ICH E6(R2) Good Clinical Practice (GCP) guidelines, as required for regulatory submission. True = GCP-compliant; False = non-GCP (e.g., non-clinical or exploratory research not intended for regulatory submission).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegistrational rdf:type rdf:Property ;
    rdfs:label 'Is Registrational' ;
    rdfs:comment 'Indicates whether this study is designated as a registrational study intended to support a marketing authorization application (NDA, BLA, MAA). True = registrational; False = non-registrational (e.g., exploratory, mechanistic).' ;
    rdfs:domain ind:ProgramStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nctNumber rdf:type rdf:Property ;
    rdfs:label 'Nct Number' ;
    rdfs:comment 'ClinicalTrials.gov National Clinical Trial (NCT) registration number for this study. Required for WHO ICTRP compliance and public disclosure obligations under FDAAA 801 and ICMJE policies.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEndpointCategory rdf:type rdf:Property ;
    rdfs:label 'Primary Endpoint Category' ;
    rdfs:comment 'High-level category of the study\'s primary endpoint as it relates to the program\'s evidence generation strategy. Supports program-level endpoint coverage analysis and regulatory dossier planning.' ;
    rdfs:domain ind:ProgramStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programMilestoneDependency rdf:type rdf:Property ;
    rdfs:label 'Program Milestone Dependency' ;
    rdfs:comment 'Description of the program-level milestone or go/no-go decision gate that this study\'s results are expected to inform or unlock (e.g., \'Phase II readout gates Phase III initiation\', \'Bridging study required before NDA submission\'). Supports program governance and portfolio decision-making.' ;
    rdfs:domain ind:ProgramStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDossierContribution rdf:type rdf:Property ;
    rdfs:label 'Regulatory Dossier Contribution' ;
    rdfs:comment 'Indicates whether this study\'s data is intended to contribute to the regulatory submission dossier (NDA, BLA, MAA, or CTD/eCTD package) for the program\'s therapeutic indication. True = study data will be included in the regulatory filing.' ;
    rdfs:domain ind:ProgramStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:removedFromProgramDate rdf:type rdf:Property ;
    rdfs:label 'Removed From Program Date' ;
    rdfs:comment 'Calendar date on which the study was formally removed or withdrawn from the clinical development program scope. Null if the study remains active within the program.' ;
    rdfs:domain ind:ProgramStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sharedDsmbFlag rdf:type rdf:Property ;
    rdfs:label 'Shared Dsmb Flag' ;
    rdfs:comment 'Indicates whether this study shares a Data Safety Monitoring Board (DSMB) or Data Monitoring Committee (DMC) with other studies in the program. True = shared DSMB/DMC; False = study-specific DSMB/DMC or no DSMB required.' ;
    rdfs:domain ind:ProgramStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sharedSapFlag rdf:type rdf:Property ;
    rdfs:label 'Shared Sap Flag' ;
    rdfs:comment 'Indicates whether this study\'s Statistical Analysis Plan (SAP) is shared or integrated with other studies in the program (e.g., integrated summary of safety/efficacy). True = shared SAP; False = study-specific SAP.' ;
    rdfs:domain ind:ProgramStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorProtocolNumber rdf:type rdf:Property ;
    rdfs:label 'Sponsor Protocol Number' ;
    rdfs:comment 'Sponsor-assigned protocol number for this study as it appears in the program\'s regulatory filings and CTMS. Serves as the primary cross-system identifier linking the study to the program in sponsor systems.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyRole rdf:type rdf:Property ;
    rdfs:label 'Study Role' ;
    rdfs:comment 'Designates the functional role of the study within the clinical development program. Pivotal studies are designed to provide primary evidence for regulatory approval; supportive studies provide corroborating evidence; exploratory studies generate hypotheses; bridging studies extend data to new populations; PK/PD studies characterize pharmacokinetics and pharmacodynamics.' ;
    rdfs:domain ind:ProgramStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticIndication rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Indication' ;
    rdfs:comment 'The disease, condition, or therapeutic indication that this study addresses within the program. Aligns with the program\'s target indication and supports cross-study indication consistency tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamMemberId rdf:type rdf:Property ;
    rdfs:label 'Team Member Id' ;
    rdfs:comment 'Unique surrogate identifier for the program team member assignment record within the clinical development program.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:predecessorMemberTeamMemberId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Member Team Member Id' ;
    rdfs:comment 'Reference to the previous program team member assignment record that this assignment supersedes, enabling role transition tracking and continuity of program knowledge.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TeamMember .

ind:primaryTeamEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Team Employee Id' ;
    rdfs:comment 'Reference to the workforce member (employee or contractor) assigned to this program-level role. Sourced from Workday HCM personnel records.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignmentCode rdf:type rdf:Property ;
    rdfs:label 'Assignment Code' ;
    rdfs:comment 'Externally-known unique business identifier for this program team member assignment, used in CTMS and program governance communications (e.g., PTM-PROG001-PD).' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'The date on which the workforce member\'s program-level role assignment is scheduled to end or was formally concluded. Null for open-ended assignments.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Date' ;
    rdfs:comment 'The date on which the workforce member formally commenced their program-level role assignment. Used for tenure calculation and resource planning.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confidentialityAgreementDate rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Agreement Date' ;
    rdfs:comment 'The date on which the team member signed the confidentiality or non-disclosure agreement for this program. Used for compliance tracking and audit purposes.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confidentialityAgreementSigned rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Agreement Signed' ;
    rdfs:comment 'Indicates whether the team member has executed a confidentiality or non-disclosure agreement covering the clinical program. Required for access to sponsor proprietary data and investigational product information.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictOfInterestDate rdf:type rdf:Property ;
    rdfs:label 'Conflict Of Interest Date' ;
    rdfs:comment 'The date on which the team member completed their conflict of interest declaration for this program. Used for compliance audit trails and regulatory inspection readiness.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conflictOfInterestDeclared rdf:type rdf:Property ;
    rdfs:label 'Conflict Of Interest Declared' ;
    rdfs:comment 'Indicates whether the team member has completed a conflict of interest declaration for this program assignment, as required by GCP and sponsor governance policies.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ctmsUserReference rdf:type rdf:Property ;
    rdfs:label 'Ctms User Reference' ;
    rdfs:comment 'The user identifier for this team member in Oracle Siebel CTMS, enabling system access traceability and audit trail linkage per 21 CFR Part 11 electronic records requirements.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegationAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Delegation Authority Level' ;
    rdfs:comment 'The level of decision-making and approval authority delegated to this team member within the program. Governs sign-off rights on protocol amendments, regulatory submissions, and budget approvals.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Classification of the workforce member\'s employment relationship with the organization (e.g., Employee, Contractor, Consultant, Secondee). Impacts billing, compliance, and access rights.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etmfAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Etmf Access Flag' ;
    rdfs:comment 'Indicates whether this team member has been granted access to the program\'s Electronic Trial Master File (eTMF) in Veeva Vault for document review and regulatory submission activities.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fteAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Fte Allocation Percentage' ;
    rdfs:comment 'The percentage of the workforce member\'s full-time equivalent capacity allocated to this program. Used for resource planning, capacity management, and financial cost allocation. Valid range: 0.00 to 100.00.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gcpCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Gcp Certification Expiry Date' ;
    rdfs:comment 'The date on which the team member\'s current GCP certification expires. Used to trigger recertification workflows and ensure ongoing regulatory compliance.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gcpCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Gcp Certification Status' ;
    rdfs:comment 'Current status of the team member\'s Good Clinical Practice (GCP) training certification as required by ICH E6(R2). Mandatory for personnel involved in clinical trial conduct.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Handover Document Ref' ;
    rdfs:comment 'Reference identifier for the formal role handover or transition document stored in Veeva Vault eTMF, ensuring continuity of program knowledge and regulatory traceability.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBackupContact rdf:type rdf:Property ;
    rdfs:label 'Is Backup Contact' ;
    rdfs:comment 'Indicates whether this team member serves as the designated backup contact for their program role, covering primary contact absences or transitions.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this team member is the designated primary contact for their role on the program. Only one team member per role should be flagged as primary at any given time.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programRole rdf:type rdf:Property ;
    rdfs:label 'Program Role' ;
    rdfs:comment 'The designated program-level leadership role held by this team member within the clinical development program. Governs accountability, decision rights, and cross-study coordination responsibilities. [ENUM-REF-CANDIDATE: Program Director|Medical Director|Regulatory Lead|Biostatistics Lead|Clinical Operations Lead|Data Management Lead|Safety Lead|Alliance Manager|Finance Lead|Quality Lead — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityScope rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Scope' ;
    rdfs:comment 'The primary regulatory authority or authorities within whose jurisdiction this team member\'s program role operates. Determines applicable GCP guidelines and submission responsibilities. [ENUM-REF-CANDIDATE: FDA|EMA|PMDA|MHRA|TGA|Health Canada|ANVISA|CDSCO|Multi-Regional — promote to reference product]' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleCategory rdf:type rdf:Property ;
    rdfs:label 'Role Category' ;
    rdfs:comment 'Functional category grouping the program role for portfolio reporting and resource planning (e.g., Clinical, Medical, Regulatory, Biostatistics). [ENUM-REF-CANDIDATE: Clinical|Medical|Regulatory|Biostatistics|Data Management|Finance|Quality|Operations — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticAreaExpertise rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Area Expertise' ;
    rdfs:comment 'The primary therapeutic area(s) of expertise for this team member relevant to the program (e.g., Oncology, Cardiology, Neurology). Used for competency matching and resource allocation decisions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workEmail rdf:type rdf:Property ;
    rdfs:label 'Work Email' ;
    rdfs:comment 'The professional email address of the team member used for program communications, escalations, and regulatory correspondence. Classified as restricted PII per GDPR and HIPAA.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPhone rdf:type rdf:Property ;
    rdfs:label 'Work Phone' ;
    rdfs:comment 'The professional phone number of the team member for program-level contact and escalation purposes. Classified as restricted PII per GDPR and HIPAA.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsOfExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience' ;
    rdfs:comment 'Total years of clinical research experience for this team member, used for competency assessment, role eligibility validation, and regulatory inspection readiness.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timelineEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Timeline Employee Id' ;
    rdfs:comment 'Reference to the individual (typically a Program Director or Program Manager) accountable for maintaining and updating the program timeline. Supports governance accountability and escalation routing.' ;
    rdfs:domain ind:Timeline ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:baselineEndDate rdf:type rdf:Property ;
    rdfs:label 'Baseline End Date' ;
    rdfs:comment 'The approved baseline end date for the clinical development program, representing the originally planned program completion date. Used as the denominator for schedule variance and milestone tracking.' ;
    rdfs:domain ind:Timeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineStartDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Start Date' ;
    rdfs:comment 'The approved baseline start date for the clinical development program, established at the time of initial timeline approval. Serves as the reference anchor for schedule variance calculations.' ;
    rdfs:domain ind:Timeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:criticalPathDriver rdf:type rdf:Property ;
    rdfs:label 'Critical Path Driver' ;
    rdfs:comment 'The primary activity, milestone, or dependency currently driving the critical path (e.g., \'Last Patient Last Visit\', \'Regulatory Submission\', \'Database Lock\'). Used for targeted risk mitigation and escalation.' ;
    rdfs:domain ind:Timeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalPathSummary rdf:type rdf:Property ;
    rdfs:label 'Critical Path Summary' ;
    rdfs:comment 'Narrative or structured summary identifying the critical path activities and milestones that determine the program\'s minimum duration. Highlights the sequence of dependent tasks with zero float that drive the forecast end date.' ;
    rdfs:domain ind:Timeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csrTargetDate rdf:type rdf:Property ;
    rdfs:label 'Csr Target Date' ;
    rdfs:comment 'The target date for completion of the Clinical Study Report (CSR) for the program\'s pivotal study or integrated summary. Required for regulatory submission planning per ICH E3 guidelines.' ;
    rdfs:domain ind:Timeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastEndDate rdf:type rdf:Property ;
    rdfs:label 'Forecast End Date' ;
    rdfs:comment 'The current forecast completion date for the program, updated based on rolling re-projections from study-level timelines, enrollment rates, and regulatory milestones. Key input to portfolio governance and submission planning.' ;
    rdfs:domain ind:Timeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastStartDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Start Date' ;
    rdfs:comment 'The current forecast start date for the program, reflecting the latest re-planning based on actual progress, site performance, and enrollment data. May differ from baseline if program initiation was delayed.' ;
    rdfs:domain ind:Timeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneCountAtRisk rdf:type rdf:Property ;
    rdfs:label 'Milestone Count At Risk' ;
    rdfs:comment 'Number of program-level milestones currently flagged as at-risk of missing their forecast date. Key input to program risk dashboards and DSMB/DMC reporting.' ;
    rdfs:domain ind:Timeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milestoneCountCompleted rdf:type rdf:Property ;
    rdfs:label 'Milestone Count Completed' ;
    rdfs:comment 'Number of program-level milestones that have been achieved as of the last timeline update. Used to calculate program completion percentage and track progress against the baseline.' ;
    rdfs:domain ind:Timeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milestoneCountTotal rdf:type rdf:Property ;
    rdfs:label 'Milestone Count Total' ;
    rdfs:comment 'Total number of program-level milestones tracked within this timeline version. Provides a structural summary of timeline complexity for governance reporting.' ;
    rdfs:domain ind:Timeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextGovernanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Governance Review Date' ;
    rdfs:comment 'The scheduled date of the next program governance committee review at which this timeline will be assessed and potentially updated. Drives workflow notifications and reporting preparation.' ;
    rdfs:domain ind:Timeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatorySubmissionTargetDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Target Date' ;
    rdfs:comment 'The target date for the primary regulatory submission (NDA/BLA/MAA) derived from this program timeline. Critical milestone for sponsor portfolio planning and regulatory agency interactions.' ;
    rdfs:domain ind:Timeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskSummary rdf:type rdf:Property ;
    rdfs:label 'Risk Summary' ;
    rdfs:comment 'Narrative summary of the primary schedule risks and mitigation strategies for the program timeline, as assessed at the last governance review. Supports DSMB/DMC reporting and sponsor escalation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timelineCode rdf:type rdf:Property ;
    rdfs:label 'Timeline Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for this program timeline record, used in CTMS, eTMF, and sponsor communications to uniquely reference the schedule baseline.' ;
    rdfs:domain ind:Timeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timelineName rdf:type rdf:Property ;
    rdfs:label 'Timeline Name' ;
    rdfs:comment 'Human-readable descriptive name for the program timeline (e.g., \'Phase II/III Integrated Development Timeline v2\'), used in governance reports and portfolio dashboards.' ;
    rdfs:domain ind:Timeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timelineStatus rdf:type rdf:Property ;
    rdfs:label 'Timeline Status' ;
    rdfs:comment 'Current schedule health status of the program timeline, indicating whether the program is on-track, at-risk of delay, actively delayed, completed, or cancelled. Used in portfolio governance reporting and escalation workflows.' ;
    rdfs:domain ind:Timeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timelineType rdf:type rdf:Property ;
    rdfs:label 'Timeline Type' ;
    rdfs:comment 'Classification of the timeline record indicating whether it represents the approved baseline, current forecast, a scenario plan, or an archived historical version.' ;
    rdfs:domain ind:Timeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Version Effective Date' ;
    rdfs:comment 'The date from which this timeline version became the operative schedule for the program. Enables point-in-time reconstruction of the program schedule for regulatory submissions and audits.' ;
    rdfs:domain ind:Timeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:versionSupersededDate rdf:type rdf:Property ;
    rdfs:label 'Version Superseded Date' ;
    rdfs:comment 'The date on which this timeline version was superseded by a newer version. Null for the currently active version. Supports historical timeline reconstruction and version chain integrity.' ;
    rdfs:domain ind:Timeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskMitigationId rdf:type rdf:Property ;
    rdfs:label 'Risk Mitigation Id' ;
    rdfs:comment 'Unique surrogate identifier for each risk mitigation action record within the program risk management framework. Primary key for this entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:RiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRiskEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Risk Employee Id' ;
    rdfs:comment 'Reference to the individual (employee or contractor) accountable for executing and completing this mitigation action. Serves as the PARTY_REFERENCE category for this TRANSACTION_HEADER entity. Typically a Program Manager, Risk Manager, or functional lead.' ;
    rdfs:domain ind:RiskMitigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryRiskActionOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Risk Action Owner Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:RiskMitigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryRiskEffectivenessReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Risk Effectiveness Reviewer Employee Id' ;
    rdfs:comment 'Reference to the individual who conducted the formal effectiveness review of this mitigation action. Typically a QA lead, Program Manager, or independent reviewer per GCP requirements.' ;
    rdfs:domain ind:RiskMitigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionDescription rdf:type rdf:Property ;
    rdfs:label 'Action Description' ;
    rdfs:comment 'Detailed narrative describing the specific mitigation action to be taken, including the approach, scope, and expected mechanism by which the action reduces the identified risk.' ;
    rdfs:domain ind:RiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionOwnerRole rdf:type rdf:Property ;
    rdfs:label 'Action Owner Role' ;
    rdfs:comment 'Functional role or job title of the mitigation action owner at the time of assignment (e.g., Program Manager, Clinical Operations Lead, Biostatistics Lead). Supports accountability reporting and escalation routing.' ;
    rdfs:domain ind:RiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current execution lifecycle state of the mitigation action. Drives risk dashboard reporting and escalation workflows. \'overdue\' is set when planned_completion_date has passed without completion. Serves as the LIFECYCLE_STATUS category for this TRANSACTION_HEADER entity.' ;
    rdfs:domain ind:RiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionTitle rdf:type rdf:Property ;
    rdfs:label 'Action Title' ;
    rdfs:comment 'Short, human-readable title summarizing the mitigation action (e.g., \'Implement enhanced site monitoring protocol\'). Used as the IDENTITY_LABEL in risk registers and dashboards.' ;
    rdfs:domain ind:RiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDateRevised rdf:type rdf:Property ;
    rdfs:label 'Due Date Revised' ;
    rdfs:comment 'Updated target completion date if the original planned_completion_date was formally extended. Captures approved timeline changes and distinguishes legitimate extensions from overdue actions.' ;
    rdfs:domain ind:RiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessNotes rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Notes' ;
    rdfs:comment 'Free-text narrative from the effectiveness reviewer documenting the rationale for the effectiveness rating, evidence reviewed, and any observations about residual risk or further actions needed.' ;
    rdfs:domain ind:RiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Rating' ;
    rdfs:comment 'Post-execution assessment of how effectively the mitigation action reduced or eliminated the identified risk. Populated after action completion and formal effectiveness review. Drives decisions on whether additional mitigation is required.' ;
    rdfs:domain ind:RiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessReviewDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Date' ;
    rdfs:comment 'The date on which the formal effectiveness assessment of the completed mitigation action was conducted. Required for CAPA closure and regulatory inspection readiness.' ;
    rdfs:domain ind:RiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationApproach rdf:type rdf:Property ;
    rdfs:label 'Implementation Approach' ;
    rdfs:comment 'Narrative description of the specific method, process, or procedure to be used in executing the mitigation action. May reference SOPs, work instructions, or system configurations (e.g., EDC edit checks, RTSM alerts).' ;
    rdfs:domain ind:RiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedMilestone rdf:type rdf:Property ;
    rdfs:label 'Linked Milestone' ;
    rdfs:comment 'Name or code of the program milestone (e.g., \'First Patient In\', \'Database Lock\', \'NDA Submission\') to which this mitigation action is tied. Enables milestone-level risk tracking and critical path analysis.' ;
    rdfs:domain ind:RiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationActionCode rdf:type rdf:Property ;
    rdfs:label 'Mitigation Action Code' ;
    rdfs:comment 'Externally-known business identifier for the mitigation action, used in risk registers, audit trails, and regulatory submissions. Follows the pattern MIT-<PROGRAM_CODE>-<SEQUENCE>. Serves as the BUSINESS_IDENTIFIER category for this TRANSACTION_HEADER entity.' ;
    rdfs:domain ind:RiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrencePreventionNotes rdf:type rdf:Property ;
    rdfs:label 'Recurrence Prevention Notes' ;
    rdfs:comment 'Free-text notes describing measures put in place to prevent recurrence of the risk after mitigation. Supports lessons-learned capture and cross-program knowledge transfer within the clinical development portfolio.' ;
    rdfs:domain ind:RiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Acceptance Date' ;
    rdfs:comment 'The date on which the residual risk was formally accepted by the authorized governance body. Null if residual risk has not yet been accepted or if further mitigation is required.' ;
    rdfs:domain ind:RiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:residualRiskAccepted rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Accepted' ;
    rdfs:comment 'Indicates whether the residual risk level after mitigation has been formally accepted by the program risk governance body (e.g., DSMB, DMC, or Sponsor). True = accepted; False = further mitigation required.' ;
    rdfs:domain ind:RiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Level' ;
    rdfs:comment 'The assessed level of risk remaining after the mitigation action has been fully implemented and its effectiveness confirmed. Used to determine whether the residual risk is acceptable or requires further mitigation per the program risk acceptance criteria.' ;
    rdfs:domain ind:RiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskDomain rdf:type rdf:Property ;
    rdfs:label 'Risk Domain' ;
    rdfs:comment 'The functional domain of the parent risk that this mitigation action addresses. Enables domain-specific risk reporting and cross-program benchmarking. [ENUM-REF-CANDIDATE: safety|regulatory|data_quality|operational|financial|supply_chain|site|subject_recruitment — promote to reference product]' ;
    rdfs:domain ind:RiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingSystems rdf:type rdf:Property ;
    rdfs:label 'Supporting Systems' ;
    rdfs:comment 'Comma-separated list of operational systems involved in executing or monitoring this mitigation action (e.g., Medidata Rave, Oracle Argus Safety, Veeva Vault). Supports system-level impact analysis and integration planning.' ;
    rdfs:domain ind:RiskMitigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentTherapeuticAreaId rdf:type rdf:Property ;
    rdfs:label 'Parent Therapeutic Area Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent therapeutic area record, enabling a hierarchical taxonomy (e.g., Hematologic Oncology rolls up to Oncology). Null for top-level therapeutic areas. Supports portfolio roll-up analytics and cross-program governance.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TherapeuticArea .

ind:abbreviation rdf:type rdf:Property ;
    rdfs:label 'Abbreviation' ;
    rdfs:comment 'Commonly used abbreviation for the therapeutic area (e.g., ONCO, CNS, CV, ID). Used in report headers, KPI dashboards, and study identifiers where space is constrained.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeProgramCount rdf:type rdf:Property ;
    rdfs:label 'Active Program Count' ;
    rdfs:comment 'Number of active clinical development programs currently classified under this therapeutic area. Provides a snapshot metric for portfolio governance dashboards and resource capacity planning. Note: This is a denormalized operational count maintained by the data pipeline, not a calculated aggregate.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:biomarkerFocus rdf:type rdf:Property ;
    rdfs:label 'Biomarker Focus' ;
    rdfs:comment 'Key biomarkers or biomarker categories relevant to clinical development programs in this therapeutic area (e.g., PD-L1 expression for Oncology, HbA1c for Diabetes, MMSE for CNS). Supports precision medicine strategy, patient stratification, and biostatistical analysis planning.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdiscTaStandard rdf:type rdf:Property ;
    rdfs:label 'Cdisc Ta Standard' ;
    rdfs:comment 'CDISC Therapeutic Area (TA) data standard applicable to studies in this therapeutic area (e.g., TAUG-Oncology, TAUG-Diabetes, TAUG-Alzheimer\'s). Governs SDTM and ADaM dataset structures for regulatory submissions to FDA and EMA, ensuring CDISC compliance in SAS Drug Development pipelines.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveLandscapeSummary rdf:type rdf:Property ;
    rdfs:label 'Competitive Landscape Summary' ;
    rdfs:comment 'Brief narrative summary of the competitive landscape for this therapeutic area, including key approved therapies, major competitors in development, and unmet medical need assessment. Classified as confidential as it informs proprietary portfolio strategy decisions.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsTaCode rdf:type rdf:Property ;
    rdfs:label 'Ctms Ta Code' ;
    rdfs:comment 'Therapeutic area code as configured in Oracle Siebel CTMS for study classification, site feasibility assessment, and portfolio reporting. Serves as the cross-reference key between the enterprise data lakehouse and the operational CTMS system.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyClassification rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Classification' ;
    rdfs:comment 'Data privacy classification level for patient data collected in clinical trials within this therapeutic area, reflecting sensitivity of health information (e.g., \'highly_sensitive\' for HIV, mental health, genetic data; \'sensitive\' for oncology; \'standard\' for general conditions). Governs GDPR Article 9 special category data handling and HIPAA PHI protections.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diseaseArea rdf:type rdf:Property ;
    rdfs:label 'Disease Area' ;
    rdfs:comment 'Specific disease area or indication cluster within the therapeutic area (e.g., within Oncology: Breast Cancer, Lung Cancer; within CNS: Alzheimer\'s Disease, Parkinson\'s Disease). Provides a finer-grained classification below therapeutic area for program-level analytics and regulatory alignment.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcTaIdentifier rdf:type rdf:Property ;
    rdfs:label 'Edc Ta Identifier' ;
    rdfs:comment 'Therapeutic area identifier as configured in Medidata Rave EDC for study build classification and eCRF library alignment. Enables traceability between the reference master and EDC study configurations for CDISC SDTM mapping.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalDiseaseBurdenRank rdf:type rdf:Property ;
    rdfs:label 'Global Disease Burden Rank' ;
    rdfs:comment 'Relative ranking of this therapeutic area by global disease burden (e.g., based on WHO Global Burden of Disease data). Used in portfolio prioritization, business development decisions, and sponsor pipeline strategy assessments.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:governanceOwner rdf:type rdf:Property ;
    rdfs:label 'Governance Owner' ;
    rdfs:comment 'Name or role of the business owner responsible for maintaining and governing this therapeutic area classification (e.g., VP Therapeutic Area Head, Chief Medical Officer). Accountable for taxonomy accuracy and alignment with sponsor portfolio strategy.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Full delimited path from the root therapeutic area to this node (e.g., \'Oncology > Solid Tumors > Non-Small Cell Lung Cancer\'). Facilitates breadcrumb navigation in portfolio governance tools and enables efficient subtree queries without recursive joins.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOncology rdf:type rdf:Property ;
    rdfs:label 'Is Oncology' ;
    rdfs:comment 'Indicates whether this therapeutic area is classified as oncology or hematology-oncology. Triggers specific regulatory considerations (FDA Oncology Center of Excellence, EMA oncology guidelines, CTCAE grading requirements) and specialized safety monitoring protocols.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRareDisease rdf:type rdf:Property ;
    rdfs:label 'Is Rare Disease' ;
    rdfs:comment 'Indicates whether this therapeutic area is classified as a rare disease area (orphan disease), triggering specific regulatory designations (FDA Orphan Drug, EMA Orphan Medicinal Product), expedited review pathways, and specialized patient recruitment strategies.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patientPopulationType rdf:type rdf:Property ;
    rdfs:label 'Patient Population Type' ;
    rdfs:comment 'Primary patient population type targeted by clinical programs in this therapeutic area. Drives regulatory requirements (e.g., pediatric investigation plans under EMA PUMA, FDA PREA), protocol design, and IRB/IEC considerations.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioPriorityTier rdf:type rdf:Property ;
    rdfs:label 'Portfolio Priority Tier' ;
    rdfs:comment 'Sponsor-assigned portfolio priority tier for this therapeutic area, reflecting strategic investment level and resource allocation priority (e.g., Tier 1 = core franchise, Tier 2 = growth area, Tier 3 = exploratory). Used in portfolio governance reviews and budget planning.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRegulatoryAgency rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Agency' ;
    rdfs:comment 'Primary health authority with jurisdiction over clinical development programs in this therapeutic area for the sponsor\'s primary market. Determines applicable regulatory frameworks, submission formats (eCTD), and GCP inspection standards. [ENUM-REF-CANDIDATE: FDA|EMA|PMDA|MHRA|TGA|Health Canada|multi-agency — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRegulatoryPathway rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Pathway' ;
    rdfs:comment 'Primary regulatory submission pathway most commonly associated with programs in this therapeutic area (e.g., NDA for small molecules, BLA for biologics, MAA for EU submissions). Guides regulatory strategy planning and submission resource allocation. [ENUM-REF-CANDIDATE: NDA|BLA|MAA|IND|510k|PMA|other — promote to reference product if additional pathways are needed]' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryClassification rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification' ;
    rdfs:comment 'Regulatory classification or designation relevant to this therapeutic area from applicable health authorities (e.g., Orphan Drug designation eligibility for Rare Disease, Breakthrough Therapy eligibility for Oncology, Priority Review eligibility). Informs regulatory strategy and submission planning.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetySystemTaCode rdf:type rdf:Property ;
    rdfs:label 'Safety System Ta Code' ;
    rdfs:comment 'Therapeutic area code as configured in Oracle Argus Safety for adverse event case routing, signal detection configuration, and regulatory case submission (ICSRs). Ensures consistent therapeutic area classification across safety reporting workflows.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorPortfolioCategory rdf:type rdf:Property ;
    rdfs:label 'Sponsor Portfolio Category' ;
    rdfs:comment 'Sponsor-defined portfolio category or franchise label aligned to this therapeutic area (e.g., Oncology Franchise, Rare Disease Unit, Immunoscience). Maps the standardized therapeutic area taxonomy to the sponsor\'s internal portfolio governance structure for cross-program analytics and budget allocation.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticAreaCode rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Area Code' ;
    rdfs:comment 'Short, standardized alphanumeric code uniquely identifying the therapeutic area within the sponsor portfolio (e.g., ONCO, IMMUNO, CNS, CARDIO, INFECT, RARE). Used as a business key in CTMS, EDC study builds, and regulatory submissions.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticAreaDescription rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Area Description' ;
    rdfs:comment 'Detailed narrative description of the therapeutic area, including the disease scope, patient population, and key biological mechanisms addressed. Used in regulatory submissions, portfolio governance documents, and sponsor-facing communications.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticAreaName rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Area Name' ;
    rdfs:comment 'Full human-readable name of the therapeutic area (e.g., Oncology, Immunology, Central Nervous System, Cardiovascular, Infectious Disease, Rare Disease). Used as the primary display label across portfolio governance dashboards and regulatory documents.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticAreaStatus rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Area Status' ;
    rdfs:comment 'Current lifecycle status of the therapeutic area record within the reference master. \'active\' indicates the area is in use for program classification; \'deprecated\' indicates it has been superseded by a revised taxonomy entry; \'under_review\' indicates pending governance approval for changes.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalTrialPhase rdf:type rdf:Property ;
    rdfs:label 'Typical Trial Phase' ;
    rdfs:comment 'Most common clinical trial phase(s) conducted within this therapeutic area, reflecting the maturity of the pipeline and typical development strategy (e.g., Phase III for established Oncology indications, Phase I/II for Rare Disease). Supports portfolio planning and resource forecasting.' ;
    rdfs:domain ind:TherapeuticArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timelineEventId rdf:type rdf:Property ;
    rdfs:label 'Timeline Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each timeline event record within a clinical development program. Primary key for the timeline_event data product.' ;
    rdfs:domain ind:TimelineEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:predecessorEventTimelineEventId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Event Timeline Event Id' ;
    rdfs:comment 'Self-referencing identifier of the immediately preceding timeline event that must be completed before this event can begin. Supports critical path management and dependency chain analysis.' ;
    rdfs:domain ind:TimelineEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TimelineEvent .

ind:approvedFlag rdf:type rdf:Property ;
    rdfs:label 'Approved Flag' ;
    rdfs:comment 'Indicates whether this timeline event and its associated dates have been formally approved by the program governance board (True) or are still pending approval (False). Supports governance workflow controls.' ;
    rdfs:domain ind:TimelineEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baselineVersion rdf:type rdf:Property ;
    rdfs:label 'Baseline Version' ;
    rdfs:comment 'The version identifier of the program schedule baseline against which this event\'s planned date is measured (e.g., BL-01, BL-02). Supports baseline comparison and re-baselining audit trails.' ;
    rdfs:domain ind:TimelineEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalPathFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Path Flag' ;
    rdfs:comment 'Indicates whether this event lies on the critical path of the program schedule (True). Critical path events directly impact the overall program completion date and receive heightened monitoring priority.' ;
    rdfs:domain ind:TimelineEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:delayReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Delay Reason Description' ;
    rdfs:comment 'Free-text narrative providing additional context for the delay reason code, capturing specific circumstances contributing to the schedule variance. Supports root cause analysis and lessons learned.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyStartDate rdf:type rdf:Property ;
    rdfs:label 'Early Start Date' ;
    rdfs:comment 'The earliest possible date this event can begin based on predecessor completion and resource availability, as calculated in the critical path network. Used for schedule optimization and float analysis.' ;
    rdfs:domain ind:TimelineEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventCategory rdf:type rdf:Property ;
    rdfs:label 'Event Category' ;
    rdfs:comment 'High-level functional category grouping the event for portfolio analytics and cross-domain reporting. Enables filtering by clinical, regulatory, safety, biostatistics, data management, or operational workstreams.' ;
    rdfs:domain ind:TimelineEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCode rdf:type rdf:Property ;
    rdfs:label 'Event Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the timeline event, used in program plans, Gantt charts, and regulatory submissions. Follows the EVT- prefix convention in Oracle Siebel CTMS.' ;
    rdfs:domain ind:TimelineEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventName rdf:type rdf:Property ;
    rdfs:label 'Event Name' ;
    rdfs:comment 'Human-readable name of the timeline event (e.g., \'First Patient First Visit\', \'Database Lock\', \'NDA Submission\', \'Advisory Committee Meeting\'). Used in program dashboards and milestone reports.' ;
    rdfs:domain ind:TimelineEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floatDays rdf:type rdf:Property ;
    rdfs:label 'Float Days' ;
    rdfs:comment 'The number of calendar days by which this event can be delayed without impacting the program critical path. Zero float indicates a critical path event. Supports proactive schedule risk management.' ;
    rdfs:domain ind:TimelineEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lateFinishDate rdf:type rdf:Property ;
    rdfs:label 'Late Finish Date' ;
    rdfs:comment 'The latest date by which this event must be completed without delaying the overall program end date. Used in critical path analysis to determine schedule float and prioritize risk mitigation.' ;
    rdfs:domain ind:TimelineEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneFlag rdf:type rdf:Property ;
    rdfs:label 'Milestone Flag' ;
    rdfs:comment 'Indicates whether this timeline event is designated as a key program milestone (True) versus a routine scheduled deliverable (False). Milestone events are tracked at the executive and sponsor governance level.' ;
    rdfs:domain ind:TimelineEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatorySubmissionType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Type' ;
    rdfs:comment 'For events of type regulatory_submission, specifies the submission dossier type (e.g., IND, NDA, BLA, MAA, eCTD). Nullable for non-regulatory event types. Aligns with FDA, EMA, PMDA submission classifications. [ENUM-REF-CANDIDATE: IND|NDA|BLA|MAA|eCTD|sNDA|sBLA — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleRole rdf:type rdf:Property ;
    rdfs:label 'Responsible Role' ;
    rdfs:comment 'The functional role or organizational unit accountable for delivering this timeline event (e.g., Clinical Operations, Biostatistics, Regulatory Affairs, Data Management). Used for workload planning and accountability tracking.' ;
    rdfs:domain ind:TimelineEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceEventReference rdf:type rdf:Property ;
    rdfs:label 'Source Event Reference' ;
    rdfs:comment 'The native identifier of this timeline event in the originating operational system (e.g., Siebel CTMS milestone ID, Oracle Clinical One event ID). Enables traceability back to the system of record.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousVersionBlindingConfigId rdf:type rdf:Property ;
    rdfs:label 'Previous Version Blinding Config Id' ;
    rdfs:comment 'Reference to the immediately preceding version of this blinding configuration, enabling version chain traceability for regulatory audit and TMF completeness.' ;
    rdfs:domain ind:BlindingConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BlindingConfig .

ind:blindingMethod rdf:type rdf:Property ;
    rdfs:label 'Blinding Method' ;
    rdfs:comment 'Physical or procedural technique used to maintain blinding integrity: identical_packaging (active and placebo packaged identically), dummy_tablets (inert tablets matching active), double_dummy (two sets of dummy treatments for crossover), over_encapsulation (active drug encapsulated to match placebo), matching_placebo, or other. [ENUM-REF-CANDIDATE: identical_packaging|dummy_tablets|double_dummy|over_encapsulation|matching_placebo|other — promote to reference product]' ;
    rdfs:domain ind:BlindingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blindingRationale rdf:type rdf:Property ;
    rdfs:label 'Blinding Rationale' ;
    rdfs:comment 'Narrative justification for the selected blinding type and method as documented in the study protocol, explaining why the chosen approach is scientifically and ethically appropriate.' ;
    rdfs:domain ind:BlindingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blindingType rdf:type rdf:Property ;
    rdfs:label 'Blinding Type' ;
    rdfs:comment 'Classification of the blinding design applied to the study: open_label (all parties aware of treatment), single_blind (subject unaware), double_blind (subject and investigator unaware), triple_blind (subject, investigator, and sponsor/CRA unaware). Governs access control rules for treatment assignment data.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configCode rdf:type rdf:Property ;
    rdfs:label 'Config Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this blinding configuration, used in RTSM/IRT system references and regulatory documentation (e.g., BLIND-001, BC-STUDY-A-DBL).' ;
    rdfs:domain ind:BlindingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configName rdf:type rdf:Property ;
    rdfs:label 'Config Name' ;
    rdfs:comment 'Human-readable name describing this blinding configuration, used in CTMS and study documentation (e.g., \'Double-Blind Double-Dummy Phase III Config\').' ;
    rdfs:domain ind:BlindingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configStatus rdf:type rdf:Property ;
    rdfs:label 'Config Status' ;
    rdfs:comment 'Current lifecycle state of the blinding configuration: draft (under development), active (in use for the study), superseded (replaced by a newer version), retired (no longer applicable).' ;
    rdfs:domain ind:BlindingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:craBlinded rdf:type rdf:Property ;
    rdfs:label 'Cra Blinded' ;
    rdfs:comment 'Indicates whether Clinical Research Associates (CRAs) performing site monitoring are blinded to treatment assignment. True = CRA cannot see treatment arm during Source Data Verification (SDV).' ;
    rdfs:domain ind:BlindingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dsmbUnblinded rdf:type rdf:Property ;
    rdfs:label 'Dsmb Unblinded' ;
    rdfs:comment 'Indicates whether the Data Safety Monitoring Board (DSMB) / Data Monitoring Committee (DMC) has access to unblinded treatment data for interim safety reviews. True = DSMB operates with unblinded data.' ;
    rdfs:domain ind:BlindingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:edcAccessRestricted rdf:type rdf:Property ;
    rdfs:label 'Edc Access Restricted' ;
    rdfs:comment 'Indicates whether the EDC system (e.g., Medidata Rave) enforces field-level or form-level access restrictions to prevent blinded users from viewing treatment assignment data in the eCRF.' ;
    rdfs:domain ind:BlindingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'Date on which this blinding configuration ceases to be binding. Null indicates the configuration remains in effect indefinitely or until superseded.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emergencyUnblindingAllowed rdf:type rdf:Property ;
    rdfs:label 'Emergency Unblinding Allowed' ;
    rdfs:comment 'Indicates whether emergency unblinding is permitted at the site level for individual subjects in life-threatening situations, as governed by the protocol and IRB/IEC approval.' ;
    rdfs:domain ind:BlindingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interimAnalysisUnblinding rdf:type rdf:Property ;
    rdfs:label 'Interim Analysis Unblinding' ;
    rdfs:comment 'Indicates whether treatment assignment data is unblinded for interim analysis purposes (e.g., for DSMB/DMC review or adaptive design decisions). True = unblinded interim analysis is planned.' ;
    rdfs:domain ind:BlindingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigatorBlinded rdf:type rdf:Property ;
    rdfs:label 'Investigator Blinded' ;
    rdfs:comment 'Indicates whether the Principal Investigator (PI) and site staff are blinded to treatment assignment. True = investigator does not know the subject\'s treatment arm.' ;
    rdfs:domain ind:BlindingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irtSystemEnforced rdf:type rdf:Property ;
    rdfs:label 'Irt System Enforced' ;
    rdfs:comment 'Indicates whether blinding access controls are enforced programmatically within the IRT/IVRS/RTSM system (e.g., Medidata Rave RTSM). True = system prevents unauthorized access to treatment codes.' ;
    rdfs:domain ind:BlindingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kitLabelBlinded rdf:type rdf:Property ;
    rdfs:label 'Kit Label Blinded' ;
    rdfs:comment 'Indicates whether investigational product kit labels are blinded (i.e., do not reveal treatment assignment). True = kit labels show only kit number and dispensing instructions, not treatment identity.' ;
    rdfs:domain ind:BlindingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:randomizationCodeMasked rdf:type rdf:Property ;
    rdfs:label 'Randomization Code Masked' ;
    rdfs:comment 'Indicates whether the randomization code (treatment arm identifier) is masked/encrypted in the RTSM and EDC systems for blinded users. True = treatment codes are not visible to blinded roles.' ;
    rdfs:domain ind:BlindingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:saeUnblindingPolicy rdf:type rdf:Property ;
    rdfs:label 'Sae Unblinding Policy' ;
    rdfs:comment 'Policy governing whether treatment assignment is unblinded when a Serious Adverse Event (SAE) or Suspected Unexpected Serious Adverse Reaction (SUSAR) is reported: always_unblind, unblind_if_susar (only for SUSARs), maintain_blind (blinding maintained for SAE reporting), case_by_case (medical monitor decision).' ;
    rdfs:domain ind:BlindingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorBlinded rdf:type rdf:Property ;
    rdfs:label 'Sponsor Blinded' ;
    rdfs:comment 'Indicates whether sponsor personnel are blinded to treatment assignment. True = sponsor staff cannot access unblinded treatment data during the study.' ;
    rdfs:domain ind:BlindingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statisticianBlinded rdf:type rdf:Property ;
    rdfs:label 'Statistician Blinded' ;
    rdfs:comment 'Indicates whether the biostatistician is blinded to treatment assignment during analysis. True = statistician works with blinded data until Database Lock (DBL) and unblinding per the Statistical Analysis Plan (SAP).' ;
    rdfs:domain ind:BlindingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subjectBlinded rdf:type rdf:Property ;
    rdfs:label 'Subject Blinded' ;
    rdfs:comment 'Indicates whether the study subject (patient) is blinded to their treatment assignment. True = subject does not know their treatment arm.' ;
    rdfs:domain ind:BlindingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unblindingAuthorizationRoles rdf:type rdf:Property ;
    rdfs:label 'Unblinding Authorization Roles' ;
    rdfs:comment 'Comma-separated list of organizational roles authorized to initiate or approve unblinding (e.g., \'Medical Monitor, Pharmacovigilance Lead, DSMB Chair\'). Governs system-enforced access controls in RTSM/IRT.' ;
    rdfs:domain ind:BlindingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unblindingDocumentationRequired rdf:type rdf:Property ;
    rdfs:label 'Unblinding Documentation Required' ;
    rdfs:comment 'Indicates whether each unblinding event must be formally documented with reason, date, and authorizing personnel, as required for regulatory audit trail and TMF completeness.' ;
    rdfs:domain ind:BlindingConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unblindingProcedure rdf:type rdf:Property ;
    rdfs:label 'Unblinding Procedure' ;
    rdfs:comment 'Defined procedure by which treatment assignment may be revealed: emergency_envelope (physical sealed envelope at site), irt_system (automated unblinding via IRT/IVRS/RTSM), sponsor_pharmacovigilance (unblinding for SAE/SUSAR reporting), dsmb_request (unblinding at DSMB request), study_completion (unblinding at end of study/DBL). [ENUM-REF-CANDIDATE: emergency_envelope|irt_system|sponsor_pharmacovigilance|dsmb_request|study_completion|investigator_request — promote to reference product]' ;
    rdfs:domain ind:Randomization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsmbUnblindPackageId rdf:type rdf:Property ;
    rdfs:label 'Dsmb Unblind Package Id' ;
    rdfs:comment 'Unique surrogate identifier for the DSMB/DMC unblinded data package record in the lakehouse silver layer.' ;
    rdfs:domain ind:DsmbUnblindPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unblindedStatisticianStudyAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Unblinded Statistician Study Assignment Id' ;
    rdfs:comment 'Foreign key linking to workforce.study_assignment. Business justification: The unblinded statistician preparing DSMB packages must be formally assigned to the study with an authorized unblinded role. Linking to study_assignment confirms this authorization — a DMC charter and' ;
    rdfs:domain ind:DsmbUnblindPackage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudyAssignment .

ind:accessLogReference rdf:type rdf:Property ;
    rdfs:label 'Access Log Reference' ;
    rdfs:comment 'Reference identifier linking to the access control log or audit trail record in the eTMF/document management system (e.g., Veeva Vault) that tracks who accessed the unblinded package and when.' ;
    rdfs:domain ind:DsmbUnblindPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blindingLevel rdf:type rdf:Property ;
    rdfs:label 'Blinding Level' ;
    rdfs:comment 'Indicates the extent of unblinding in this package. Full unblind reveals all treatment arm assignments; partial unblind may reveal only aggregate or safety data by arm; pooled only provides no arm-level assignment.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryRecipientNames rdf:type rdf:Property ;
    rdfs:label 'Delivery Recipient Names' ;
    rdfs:comment 'Comma-separated list of DSMB/DMC member names who received the unblinded data package. Supports audit trail for controlled unblinded data access.' ;
    rdfs:domain ind:DsmbUnblindPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'Date and time when the unblinded data package was transmitted or made available to the DSMB members.' ;
    rdfs:domain ind:DsmbUnblindPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destructionConfirmed rdf:type rdf:Property ;
    rdfs:label 'Destruction Confirmed' ;
    rdfs:comment 'Indicates whether the DSMB/DMC has confirmed destruction of the unblinded data package following the meeting, per blinding integrity and data security requirements.' ;
    rdfs:domain ind:DsmbUnblindPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destructionConfirmedBy rdf:type rdf:Property ;
    rdfs:label 'Destruction Confirmed By' ;
    rdfs:comment 'Name or identifier of the individual who confirmed destruction of the unblinded data package post-meeting.' ;
    rdfs:domain ind:DsmbUnblindPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionConfirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Destruction Confirmed Timestamp' ;
    rdfs:comment 'Date and time when destruction of the unblinded data package was confirmed post-meeting.' ;
    rdfs:domain ind:DsmbUnblindPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destructionRequired rdf:type rdf:Property ;
    rdfs:label 'Destruction Required' ;
    rdfs:comment 'Indicates whether the unblinded data package must be destroyed after the DSMB meeting per the DMC charter or blinding integrity procedures.' ;
    rdfs:domain ind:DsmbUnblindPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dmcCharterVersion rdf:type rdf:Property ;
    rdfs:label 'Dmc Charter Version' ;
    rdfs:comment 'Version of the DMC/DSMB charter under which this unblinded package was prepared and reviewed, ensuring compliance with the agreed operating procedures.' ;
    rdfs:domain ind:DsmbUnblindPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interimAnalysisNumber rdf:type rdf:Property ;
    rdfs:label 'Interim Analysis Number' ;
    rdfs:comment 'Sequential number of the interim analysis associated with this unblinded package (e.g., 1 for first interim, 2 for second interim). Aligns with the Statistical Analysis Plan (SAP) interim analysis schedule.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageCode rdf:type rdf:Property ;
    rdfs:label 'Package Code' ;
    rdfs:comment 'Externally-known, human-readable unique reference code for the unblinded data package, typically formatted as DSMB-{StudyCode}-{Year}-V{Version}. Used for tracking and audit trail purposes across systems.' ;
    rdfs:domain ind:DsmbUnblindPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageLocationUri rdf:type rdf:Property ;
    rdfs:label 'Package Location Uri' ;
    rdfs:comment 'Secure URI or vault path where the unblinded data package is stored in the eTMF or secure document repository (e.g., Veeva Vault). Access is restricted to authorized unblinded personnel only.' ;
    rdfs:domain ind:DsmbUnblindPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageNotes rdf:type rdf:Property ;
    rdfs:label 'Package Notes' ;
    rdfs:comment 'Free-text field for capturing any additional notes, caveats, or contextual information about this unblinded data package, such as known data quality issues or deviations from the SAP.' ;
    rdfs:domain ind:DsmbUnblindPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagePreparedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Package Prepared Timestamp' ;
    rdfs:comment 'Date and time when the unblinded data package was finalized and locked for delivery to the DSMB. Represents the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:DsmbUnblindPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packageStatus rdf:type rdf:Property ;
    rdfs:label 'Package Status' ;
    rdfs:comment 'Current lifecycle status of the DSMB unblinded data package. Tracks progression from preparation through delivery, review, and post-meeting destruction. [ENUM-REF-CANDIDATE: draft|finalized|delivered|received|under_review|destroyed|superseded — promote to reference product]' ;
    rdfs:domain ind:DsmbUnblindPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageVersion rdf:type rdf:Property ;
    rdfs:label 'Package Version' ;
    rdfs:comment 'Sequential version number of the unblinded data package for a given DSMB meeting. Incremented when a corrected or supplemental package is issued prior to or after the meeting.' ;
    rdfs:domain ind:DsmbUnblindPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receiptConfirmed rdf:type rdf:Property ;
    rdfs:label 'Receipt Confirmed' ;
    rdfs:comment 'Indicates whether the DSMB/DMC has formally confirmed receipt of the unblinded data package prior to the meeting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiptConfirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Confirmed Timestamp' ;
    rdfs:comment 'Date and time when the DSMB/DMC formally confirmed receipt of the unblinded data package.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recommendationDate rdf:type rdf:Property ;
    rdfs:label 'Recommendation Date' ;
    rdfs:comment 'Date on which the DSMB/DMC issued its formal recommendation following review of the unblinded data package.' ;
    rdfs:domain ind:DsmbUnblindPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:saeCount rdf:type rdf:Property ;
    rdfs:label 'Sae Count' ;
    rdfs:comment 'Total number of Serious Adverse Events (SAEs) reported as of the data cut-off date, included in the unblinded safety summary for DSMB review.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sapVersionReference rdf:type rdf:Property ;
    rdfs:label 'Sap Version Reference' ;
    rdfs:comment 'Version identifier of the Statistical Analysis Plan (SAP) that governed the interim analysis included in this unblinded package.' ;
    rdfs:domain ind:Randomization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sponsor Notification Timestamp' ;
    rdfs:comment 'Date and time when the sponsor was formally notified of the DSMB/DMC recommendation.' ;
    rdfs:domain ind:Randomization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subjectsEvaluableCount rdf:type rdf:Property ;
    rdfs:label 'Subjects Evaluable Count' ;
    rdfs:comment 'Number of subjects with sufficient data to be included in the interim analysis population (e.g., Intent-to-Treat or Per Protocol population) as of the data cut-off date.' ;
    rdfs:domain ind:DsmbUnblindPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:treatmentArmLabelsIncluded rdf:type rdf:Property ;
    rdfs:label 'Treatment Arm Labels Included' ;
    rdfs:comment 'Comma-separated list of unblinded treatment arm labels (e.g., \'Drug A 10mg, Drug A 20mg, Placebo\') included in this package. Captures which arms were unblinded for the DSMB review.' ;
    rdfs:domain ind:DsmbUnblindPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unblindedStatisticianName rdf:type rdf:Property ;
    rdfs:label 'Unblinded Statistician Name' ;
    rdfs:comment 'Full name of the independent unblinded statistician who prepared the interim analysis. Captured for audit trail and regulatory inspection readiness.' ;
    rdfs:domain ind:DsmbUnblindPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unblindedStatisticianOrg rdf:type rdf:Property ;
    rdfs:label 'Unblinded Statistician Org' ;
    rdfs:comment 'Name of the organization or CRO unit to which the unblinded statistician belongs, confirming independence from the blinded study team and sponsor.' ;
    rdfs:domain ind:DsmbUnblindPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispensingDate rdf:type rdf:Property ;
    rdfs:label 'Dispensing Date' ;
    rdfs:comment 'The calendar date on which the investigational product kit was dispensed to the subject. Relevant for kit_assignment transaction types. Used for supply chain reconciliation and compliance with protocol dispensing windows.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:doseLevel rdf:type rdf:Property ;
    rdfs:label 'Dose Level' ;
    rdfs:comment 'The dose level assigned or changed during this IRT transaction (e.g., 10mg, 20mg, 40mg). Relevant for dose-change and titration transaction types. Captured as a string to accommodate protocol-defined dose descriptors.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicSignatureFlag rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Flag' ;
    rdfs:comment 'Indicates whether the IRT transaction was executed with a valid electronic signature as required by 21 CFR Part 11 and EU Annex 11. True if an e-signature was captured; False if not applicable or not captured.' ;
    rdfs:domain ind:IrtTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'Free-text or coded reason describing why the IRT transaction failed or was cancelled. Populated only when transaction_outcome is failure or transaction_status is cancelled/failed. Supports root cause analysis and CAPA.' ;
    rdfs:domain ind:IrtTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irtConfigVersion rdf:type rdf:Property ;
    rdfs:label 'Irt Config Version' ;
    rdfs:comment 'The validated configuration version of the IRT/RTSM system build active at the time of the transaction. Required for regulatory audit trail to confirm the correct randomization schedule and supply rules were applied.' ;
    rdfs:domain ind:IrtTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irtSystemName rdf:type rdf:Property ;
    rdfs:label 'Irt System Name' ;
    rdfs:comment 'The name of the IRT/IVRS/RTSM system that generated this transaction (e.g., Medidata Rave RTSM, Oracle IRT, Almac IXRS). Supports multi-system study environments and source system traceability.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irtSystemReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Irt System Reference Number' ;
    rdfs:comment 'The externally-known unique transaction reference number assigned by the IRT/IVRS/RTSM system (e.g., Medidata Rave RTSM transaction ID). Used for cross-system reconciliation and audit trail.' ;
    rdfs:domain ind:IrtTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irtSystemVersion rdf:type rdf:Property ;
    rdfs:label 'Irt System Version' ;
    rdfs:comment 'The validated version of the IRT/RTSM system at the time the transaction was executed. Required for regulatory submission traceability and system validation documentation per 21 CFR Part 11.' ;
    rdfs:domain ind:Randomization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorRole rdf:type rdf:Property ;
    rdfs:label 'Operator Role' ;
    rdfs:comment 'The functional role of the operator who performed the IRT transaction (e.g., Clinical Research Coordinator (CRC), Clinical Research Associate (CRA), Principal Investigator (PI), pharmacist). Supports access control auditing and GCP compliance.' ;
    rdfs:domain ind:IrtTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queryFlag rdf:type rdf:Property ;
    rdfs:label 'Query Flag' ;
    rdfs:comment 'Indicates whether an open data discrepancy query exists against this IRT transaction record in the EDC system. Supports data management workflows and database lock readiness assessment.' ;
    rdfs:domain ind:IrtTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:randomizationMethod rdf:type rdf:Property ;
    rdfs:label 'Randomization Method' ;
    rdfs:comment 'The algorithm or method used to generate the randomization assignment for this transaction (e.g., stratified block, minimization, dynamic). Captured from the RTSM configuration at the time of the transaction.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:randomizationNumber rdf:type rdf:Property ;
    rdfs:label 'Randomization Number' ;
    rdfs:comment 'The unique randomization code assigned to the subject by the RTSM system at the time of randomization. Determines treatment arm allocation and links to the randomization schedule. Central to blinding integrity.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdvFlag rdf:type rdf:Property ;
    rdfs:label 'Sdv Flag' ;
    rdfs:comment 'Indicates whether this IRT transaction record has been subject to Source Data Verification (SDV) by a Clinical Research Associate (CRA). True if SDV has been completed; False if pending.' ;
    rdfs:domain ind:IrtTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stratificationFactor1 rdf:type rdf:Property ;
    rdfs:label 'Stratification Factor 1' ;
    rdfs:comment 'The value of the first stratification factor used in the randomization algorithm at the time of this transaction (e.g., disease severity, geographic region, age group). Captured from the RTSM at the point of randomization.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stratificationFactor2 rdf:type rdf:Property ;
    rdfs:label 'Stratification Factor 2' ;
    rdfs:comment 'The value of the second stratification factor used in the randomization algorithm at the time of this transaction (e.g., prior therapy, biomarker status). Nullable if the study uses fewer than two stratification factors.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stratificationFactor3 rdf:type rdf:Property ;
    rdfs:label 'Stratification Factor 3' ;
    rdfs:comment 'The value of the third stratification factor used in the randomization algorithm at the time of this transaction. Nullable if the study uses fewer than three stratification factors.' ;
    rdfs:domain ind:IrtTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionOutcome rdf:type rdf:Property ;
    rdfs:label 'Transaction Outcome' ;
    rdfs:comment 'The technical outcome of the IRT transaction as reported by the RTSM system, indicating whether the transaction was successfully processed or encountered an error condition. Distinct from transaction_status which reflects the business lifecycle state.' ;
    rdfs:domain ind:IrtTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle state of the IRT transaction indicating whether it was successfully processed, failed, cancelled, or is pending confirmation in the RTSM system.' ;
    rdfs:domain ind:IrtTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'The precise date and time (with timezone offset) at which the IRT/IVRS/RTSM transaction event occurred in the source system. This is the principal real-world business event time, distinct from record audit timestamps. Conforms to yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:IrtTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Classification of the IRT transaction indicating the business event performed. Drives downstream processing logic for supply management and randomization audit. [ENUM-REF-CANDIDATE: randomization|re_randomization|kit_assignment|dose_change|titration|cancellation|unblinding|screen_failure|withdrawal — promote to reference product]' ;
    rdfs:domain ind:IrtTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unblindingReason rdf:type rdf:Property ;
    rdfs:label 'Unblinding Reason' ;
    rdfs:comment 'The documented reason for emergency unblinding of a subject\'s treatment assignment (e.g., SAE requiring knowledge of treatment, DSMB review). Populated only when blinding_status is unblinded.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kitAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Kit Assignment Id' ;
    rdfs:comment 'Primary key for kit_assignment' ;
    rdfs:domain ind:KitAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispensedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Dispensed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: GCP requires investigational product dispensing to be traceable to a qualified, delegated employee. \'dispensed_by\' is denormalized. The FK enables dispensing accountability reports and confirms the di' ;
    rdfs:domain ind:KitAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:randCodeId rdf:type rdf:Property ;
    rdfs:label 'Rand Code Id' ;
    rdfs:comment 'Foreign key linking to randomization.rand_code. Business justification: A kit assignment corresponds to a specific randomization code slot. kit_assignment currently stores randomization_number (STRING) as a denormalized reference to the rand_code. Adding rand_code_id FK p' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RandCode .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether the subject demonstrated acceptable dosing compliance for this kit assignment based on the quantity dispensed versus quantity returned. True if compliance meets protocol-defined threshold; False if a compliance issue is identified.' ;
    rdfs:domain ind:KitAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispensingConfirmed rdf:type rdf:Property ;
    rdfs:label 'Dispensing Confirmed' ;
    rdfs:comment 'Indicates whether the kit dispensing has been confirmed and acknowledged in the IRT/RTSM system by the site staff. True when confirmed; False when pending confirmation. Supports site monitoring and data quality checks.' ;
    rdfs:domain ind:KitAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispensingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispensing Timestamp' ;
    rdfs:comment 'The precise date and time at which the IMP kit dispensing transaction was recorded in the IRT/RTSM system. Supports ALCOA+ compliance (Attributable, Legible, Contemporaneous, Original, Accurate) for audit trail purposes.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dosageForm rdf:type rdf:Property ;
    rdfs:label 'Dosage Form' ;
    rdfs:comment 'The pharmaceutical dosage form of the IMP contained in the kit (e.g., Tablet, Capsule, Injection). Aligns with CDISC SDTM EX domain EXDOSFRM and supports IMP accountability and regulatory submissions. [ENUM-REF-CANDIDATE: Tablet|Capsule|Injection|Infusion|Patch|Oral Solution|Other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kitBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Kit Batch Number' ;
    rdfs:comment 'The manufacturing batch or lot number of the IMP kit. Required for IMP accountability, pharmacovigilance investigations, and regulatory submissions. Enables traceability from subject exposure back to the manufacturing batch.' ;
    rdfs:domain ind:KitAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Kit Expiry Date' ;
    rdfs:comment 'The expiration date of the IMP kit as labeled by the manufacturer or packaging facility. Ensures that expired kits are not dispensed to subjects and supports IMP accountability and supply chain management.' ;
    rdfs:domain ind:KitAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnDate rdf:type rdf:Property ;
    rdfs:label 'Return Date' ;
    rdfs:comment 'The date on which the subject returned unused IMP units from this kit assignment to the investigational site. Null if no return has occurred or is not applicable.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnStatus rdf:type rdf:Property ;
    rdfs:label 'Return Status' ;
    rdfs:comment 'Indicates the current return status of the IMP kit: whether return is pending, the kit has been returned, the return requirement has been waived, or return is not applicable (e.g., fully consumed). Supports IMP accountability and site monitoring.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeOfAdministration rdf:type rdf:Property ;
    rdfs:label 'Route Of Administration' ;
    rdfs:comment 'The route by which the IMP in the kit is administered to the subject (e.g., Oral, Intravenous, Subcutaneous). Aligns with CDISC SDTM EX domain EXROUTE and is required for regulatory submissions. [ENUM-REF-CANDIDATE: Oral|Intravenous|Subcutaneous|Intramuscular|Topical|Inhaled|Other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stratificationCellId rdf:type rdf:Property ;
    rdfs:label 'Stratification Cell Id' ;
    rdfs:comment 'Foreign key linking to randomization.stratification_cell. Business justification: Each rand_code slot belongs to a specific stratification cell that determines its allocation. rand_code currently stores stratification_cell_code (STRING) and stratification_cell_description (STRING) ' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StratificationCell .

ind:unblindedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Unblinded By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Emergency unblinding of a randomization code must be traceable to the authorizing employee — a critical GCP patient safety and audit trail requirement. \'unblinded_by\' is denormalized. The FK enables u' ;
    rdfs:domain ind:RandCode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allocationRatioDenominator rdf:type rdf:Property ;
    rdfs:label 'Allocation Ratio Denominator' ;
    rdfs:comment 'Denominator of the randomization allocation ratio (e.g., 3 in a 2:1 ratio, representing total parts). Together with the numerator, documents the intended allocation balance.' ;
    rdfs:domain ind:Randomization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationRatioNumerator rdf:type rdf:Property ;
    rdfs:label 'Allocation Ratio Numerator' ;
    rdfs:comment 'Numerator of the randomization allocation ratio for the treatment arm assigned to this code (e.g., 2 in a 2:1 ratio). Used to verify list balance and document the randomization scheme.' ;
    rdfs:domain ind:Randomization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assigned Timestamp' ;
    rdfs:comment 'Date and time when this randomization code was consumed and assigned to a subject via the IRT/RTSM system. The principal business event timestamp for this entity. Null if not yet assigned.' ;
    rdfs:domain ind:RandCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:blockNumber rdf:type rdf:Property ;
    rdfs:label 'Block Number' ;
    rdfs:comment 'Block identifier within the randomization list to which this code belongs. Used for permuted-block randomization schemes to verify block completeness and balance.' ;
    rdfs:domain ind:Randomization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockSize rdf:type rdf:Property ;
    rdfs:label 'Block Size' ;
    rdfs:comment 'Number of randomization slots in the block containing this code. For variable block size designs, records the actual block size assigned to this slot.' ;
    rdfs:domain ind:Randomization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:codeNumber rdf:type rdf:Property ;
    rdfs:label 'Code Number' ;
    rdfs:comment 'The externally-known alphanumeric randomization code identifier as generated by the RTSM/IRT system (e.g., \'RC-0042\'). This is the business-facing code printed on the randomization schedule and referenced in regulatory submissions.' ;
    rdfs:domain ind:RandCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispensingVisitNumber rdf:type rdf:Property ;
    rdfs:label 'Dispensing Visit Number' ;
    rdfs:comment 'Protocol-defined visit number at which the IMP kit linked to this randomization code is to be dispensed to the subject. Aligns with the study schedule of assessments.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irtSystemSource rdf:type rdf:Property ;
    rdfs:label 'Irt System Source' ;
    rdfs:comment 'Identifies the IRT/RTSM system that generated and managed this randomization code (e.g., Medidata Rave RTSM, Oracle Clinical One). Supports multi-system reconciliation and data lineage.' ;
    rdfs:domain ind:RandCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEmergencyUnblindingEligible rdf:type rdf:Property ;
    rdfs:label 'Is Emergency Unblinding Eligible' ;
    rdfs:comment 'Indicates whether this randomization code is eligible for emergency unblinding by site staff via the IRT system (True) or requires sponsor/DSMB authorization (False). Governs site-level unblinding access controls.' ;
    rdfs:domain ind:RandCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRescueMedicationEligible rdf:type rdf:Property ;
    rdfs:label 'Is Rescue Medication Eligible' ;
    rdfs:comment 'Indicates whether the treatment arm assigned to this code permits rescue medication dispensing (True) or not (False). Drives IRT/RTSM dispensing logic for rescue kits.' ;
    rdfs:domain ind:RandCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnblinded rdf:type rdf:Property ;
    rdfs:label 'Is Unblinded' ;
    rdfs:comment 'Indicates whether the treatment arm assignment for this code has been formally unblinded (True) or remains blinded (False). Set to True upon emergency or end-of-study unblinding events.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kitCode rdf:type rdf:Property ;
    rdfs:label 'Kit Code' ;
    rdfs:comment 'Pre-assigned IMP kit code linked to this randomization slot for dispensing via IRT/RTSM. Connects the randomization event to the supply chain kit that must be dispensed to the subject.' ;
    rdfs:domain ind:RandCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listVersionNumber rdf:type rdf:Property ;
    rdfs:label 'List Version Number' ;
    rdfs:comment 'Version number of the randomization list from which this code was generated (e.g., \'1.0\', \'2.1\'). Tracks list amendments due to protocol changes and supports regulatory audit trail.' ;
    rdfs:domain ind:RandCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolAmendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Protocol Amendment Number' ;
    rdfs:comment 'Protocol amendment version under which this randomization code was generated or last modified. Tracks list changes driven by protocol amendments for regulatory traceability.' ;
    rdfs:domain ind:RandCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:randomizationSeed rdf:type rdf:Property ;
    rdfs:label 'Randomization Seed' ;
    rdfs:comment 'Cryptographic seed value used by the randomization algorithm to generate this code list. Classified as confidential to protect blinding integrity. Required for regulatory reproducibility validation.' ;
    rdfs:domain ind:Randomization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementCodeNumber rdf:type rdf:Property ;
    rdfs:label 'Replacement Code Number' ;
    rdfs:comment 'Code number of the replacement randomization slot issued when this code was cancelled or replaced. Enables traceability of code replacement chains in the audit trail.' ;
    rdfs:domain ind:RandCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequencePosition rdf:type rdf:Property ;
    rdfs:label 'Sequence Position' ;
    rdfs:comment 'Sequential ordinal position of this code within its randomization list. Determines the order in which codes are consumed during subject enrollment.' ;
    rdfs:domain ind:RandCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemCodeReference rdf:type rdf:Property ;
    rdfs:label 'Source System Code Reference' ;
    rdfs:comment 'Native primary key or unique identifier of this randomization code record in the originating IRT/RTSM source system (Medidata Rave RTSM or Oracle Clinical One). Enables reconciliation and data lineage tracing back to the system of record.' ;
    rdfs:domain ind:RandCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unblindingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Unblinding Timestamp' ;
    rdfs:comment 'Date and time when the treatment arm assignment was formally unblinded. Null if the code remains blinded. Captured per ALCOA+ principles for regulatory audit trail.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignedTreatmentArmId rdf:type rdf:Property ;
    rdfs:label 'Assigned Treatment Arm Id' ;
    rdfs:comment 'Foreign key linking to randomization.treatment_arm. Business justification: A randomization deviation captures the treatment arm that was ASSIGNED (what should have been given). rand_deviation stores treatment_arm_assigned (STRING) as a denormalized reference. Adding assigned' ;
    rdfs:domain ind:RandDeviation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TreatmentArm .

ind:detectedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Detected By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: GCP deviation management requires traceability to the employee who detected the randomization deviation. \'detected_by_user\' is denormalized. The FK supports CAPA root cause analysis and regulatory rep' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:workforceCapaId rdf:type rdf:Property ;
    rdfs:label 'Workforce Capa Id' ;
    rdfs:comment 'Foreign key linking to workforce.workforce_capa. Business justification: Randomization deviations caused by staff errors trigger workforce CAPAs addressing training gaps or process failures. Linking rand_deviation to workforce_capa enables CAPA effectiveness tracking and r' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkforceCapa .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Narrative description of the immediate corrective action taken to address the randomization deviation and mitigate its impact on the subject and study data.' ;
    rdfs:domain ind:RandDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecrfFormReference rdf:type rdf:Property ;
    rdfs:label 'Ecrf Form Reference' ;
    rdfs:comment 'Reference to the specific eCRF form or field in the EDC system (Medidata Rave) where the deviation-related data was captured or where the error originated. Supports data reconciliation and SDV activities.' ;
    rdfs:domain ind:RandDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kitNumberAssigned rdf:type rdf:Property ;
    rdfs:label 'Kit Number Assigned' ;
    rdfs:comment 'The IRT/RTSM-assigned investigational product kit number that should have been dispensed to the subject per the randomization schedule. Used to reconcile supply chain and randomization records.' ;
    rdfs:domain ind:RandDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kitNumberDispensed rdf:type rdf:Property ;
    rdfs:label 'Kit Number Dispensed' ;
    rdfs:comment 'The actual investigational product kit number dispensed to the subject. Compared against kit_number_assigned to identify wrong kit dispensing deviations.' ;
    rdfs:domain ind:RandDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationImpact rdf:type rdf:Property ;
    rdfs:label 'Population Impact' ;
    rdfs:comment 'Assessment of the impact of the randomization deviation on the subject\'s inclusion in key analysis populations (Intent-to-Treat (ITT) and Per Protocol (PP)). Critical for biostatistical analysis and SAP compliance.' ;
    rdfs:domain ind:RandDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stratificationFactorCaptured rdf:type rdf:Property ;
    rdfs:label 'Stratification Factor Captured' ;
    rdfs:comment 'The stratification factor value that was actually captured or entered in the IRT/RTSM system at the time of randomization. Used to identify incorrect stratification deviations by comparison with the correct protocol-defined value.' ;
    rdfs:domain ind:RandDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stratificationFactorCorrect rdf:type rdf:Property ;
    rdfs:label 'Stratification Factor Correct' ;
    rdfs:comment 'The correct stratification factor value as per the protocol and source data, against which the captured value is compared. Populated during deviation investigation to document the discrepancy.' ;
    rdfs:domain ind:RandDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentArmAssigned rdf:type rdf:Property ;
    rdfs:label 'Treatment Arm Assigned' ;
    rdfs:comment 'The treatment arm or group to which the subject was assigned at randomization (e.g., Active Drug, Placebo, Dose Level A). Captures the intended allocation per the randomization schedule.' ;
    rdfs:domain ind:RandDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentArmDispensed rdf:type rdf:Property ;
    rdfs:label 'Treatment Arm Dispensed' ;
    rdfs:comment 'The treatment arm or group actually dispensed to the subject, which may differ from the assigned arm in cases of wrong treatment dispensed deviations. Comparison with treatment_arm_assigned identifies dispensing errors.' ;
    rdfs:domain ind:RandDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByListRandListId rdf:type rdf:Property ;
    rdfs:label 'Superseded By List Rand List Id' ;
    rdfs:comment 'Reference to the newer randomization list that supersedes this one. Null if this is the current active version. Supports version chain traceability.' ;
    rdfs:domain ind:RandList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RandList .

ind:activationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activation Timestamp' ;
    rdfs:comment 'Date and time when the randomization list was activated in the IRT/IVRS/RTSM system and made available for subject assignment.' ;
    rdfs:domain ind:RandList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:allocatedSlots rdf:type rdf:Property ;
    rdfs:label 'Allocated Slots' ;
    rdfs:comment 'Number of randomization slots that have been assigned to subjects at the time of record. Used to monitor enrollment capacity and list utilization.' ;
    rdfs:domain ind:RandList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockSizeSequence rdf:type rdf:Property ;
    rdfs:label 'Block Size Sequence' ;
    rdfs:comment 'Encoded representation of the block sizes used in permuted block randomization (e.g., \'2,4,4,2\'). Classified as confidential to protect blinding integrity during the study.' ;
    rdfs:domain ind:RandList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsmbAccessGranted rdf:type rdf:Property ;
    rdfs:label 'Dsmb Access Granted' ;
    rdfs:comment 'Indicates whether the Data Safety Monitoring Board (DSMB) / Data Monitoring Committee (DMC) has been granted access to the unblinded version of this randomization list for interim safety reviews.' ;
    rdfs:domain ind:RandList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:generatedBy rdf:type rdf:Property ;
    rdfs:label 'Generated By' ;
    rdfs:comment 'Name or user identifier of the biostatistician or system process that generated the randomization list. Supports ALCOA+ attributability requirement.' ;
    rdfs:domain ind:RandList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generationMethod rdf:type rdf:Property ;
    rdfs:label 'Generation Method' ;
    rdfs:comment 'Algorithm or statistical method used to generate the randomization list (e.g., permuted block, minimization, stratified). Documented in the SAP and protocol.' ;
    rdfs:domain ind:RandList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irtListType rdf:type rdf:Property ;
    rdfs:label 'Irt List Type' ;
    rdfs:comment 'Scope of the randomization list as configured in the IRT/IVRS/RTSM system — whether it applies globally across all sites, to specific sites, strata, or countries.' ;
    rdfs:domain ind:RandList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBlinded rdf:type rdf:Property ;
    rdfs:label 'Is Blinded' ;
    rdfs:comment 'Indicates whether treatment assignments in this list are masked (True) or open-label (False). Drives access control and unblinding procedures in the IRT/IVRS/RTSM system.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStratified rdf:type rdf:Property ;
    rdfs:label 'Is Stratified' ;
    rdfs:comment 'Indicates whether this randomization list uses stratified randomization (True) or unstratified simple/block randomization (False).' ;
    rdfs:domain ind:RandList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kitAssignmentEnabled rdf:type rdf:Property ;
    rdfs:label 'Kit Assignment Enabled' ;
    rdfs:comment 'Indicates whether this randomization list is linked to investigational product kit assignment in the RTSM/supply chain module. When True, kit numbers are assigned at the point of randomization.' ;
    rdfs:domain ind:RandList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:listDescription rdf:type rdf:Property ;
    rdfs:label 'List Description' ;
    rdfs:comment 'Free-text description of the randomization list, including any special conditions, amendments, or notes relevant to its use in the study.' ;
    rdfs:domain ind:RandList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listNumber rdf:type rdf:Property ;
    rdfs:label 'List Number' ;
    rdfs:comment 'Externally-known unique identifier or code for this randomization list as referenced in the IRT/IVRS/RTSM system and the Statistical Analysis Plan (SAP). Used for regulatory traceability.' ;
    rdfs:domain ind:RandList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listStatus rdf:type rdf:Property ;
    rdfs:label 'List Status' ;
    rdfs:comment 'Current lifecycle status of the randomization list. Controls whether the list is available for subject assignment in the IRT/IVRS/RTSM system. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|superseded|retired — promote to reference product if additional statuses are needed]' ;
    rdfs:domain ind:RandList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listVersion rdf:type rdf:Property ;
    rdfs:label 'List Version' ;
    rdfs:comment 'Version identifier of the randomization list (e.g., v1.0, v2.0). Incremented when the list is regenerated or amended, supporting audit trail and regulatory traceability.' ;
    rdfs:domain ind:RandList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapReference rdf:type rdf:Property ;
    rdfs:label 'Sap Reference' ;
    rdfs:comment 'Document identifier or section reference in the Statistical Analysis Plan (SAP) that specifies the randomization methodology for this list. Ensures traceability to the approved statistical methodology.' ;
    rdfs:domain ind:RandList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemListReference rdf:type rdf:Property ;
    rdfs:label 'Source System List Reference' ;
    rdfs:comment 'Native identifier of this randomization list in the originating IRT/IVRS/RTSM system (Medidata Rave RTSM or Oracle Clinical One). Used for cross-system reconciliation.' ;
    rdfs:domain ind:RandList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stratificationFactors rdf:type rdf:Property ;
    rdfs:label 'Stratification Factors' ;
    rdfs:comment 'Comma-separated list of stratification factors applied when generating this randomization list (e.g., \'site, disease_severity, age_group\'). Reflects the protocol-defined stratification variables.' ;
    rdfs:domain ind:Randomization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededTimestamp rdf:type rdf:Property ;
    rdfs:label 'Superseded Timestamp' ;
    rdfs:comment 'Date and time when this randomization list was superseded by a newer version. Null if the list is still active. Supports version lifecycle audit trail.' ;
    rdfs:domain ind:RandList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalSlots rdf:type rdf:Property ;
    rdfs:label 'Total Slots' ;
    rdfs:comment 'Total number of randomization positions (slots) in this list, representing the maximum number of subjects that can be assigned using this list.' ;
    rdfs:domain ind:RandList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:treatmentArmCount rdf:type rdf:Property ;
    rdfs:label 'Treatment Arm Count' ;
    rdfs:comment 'Number of distinct treatment arms (including placebo/control) covered by this randomization list. Validates alignment with the protocol-defined study design.' ;
    rdfs:domain ind:Randomization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'Date and time when the randomization list completed User Acceptance Testing (UAT) validation. Null if validation has not yet been performed.' ;
    rdfs:domain ind:RandList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:biostatisticianEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Biostatistician Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: ICH E9 and GCP require the randomization scheme to be traceable to the qualified biostatistician who designed it. This is a regulatory audit trail requirement. \'biostatistician_name\' is a denormalized' ;
    rdfs:domain ind:RandScheme ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allocationAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Allocation Algorithm' ;
    rdfs:comment 'The statistical randomization algorithm used to assign subjects to treatment arms. \'simple\' = unrestricted random; \'block\' = fixed block sizes; \'stratified_block\' = blocks within strata; \'minimization\' = dynamic balancing; \'adaptive\' = response-adaptive; \'covariate_adaptive\' = covariate-adaptive randomization.' ;
    rdfs:domain ind:RandScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockSizeList rdf:type rdf:Property ;
    rdfs:label 'Block Size List' ;
    rdfs:comment 'Comma-separated list of permissible block sizes used in block or stratified-block randomization (e.g., \'4,6,8\'). Variable block sizes reduce predictability. Null for non-block algorithms.' ;
    rdfs:domain ind:RandScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generationMethodDescription rdf:type rdf:Property ;
    rdfs:label 'Generation Method Description' ;
    rdfs:comment 'Narrative description of the randomization list generation methodology, including algorithm parameters, SAS/R procedure used, and any special considerations. Included in the Randomization Plan and CSR.' ;
    rdfs:domain ind:RandScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generationSoftware rdf:type rdf:Property ;
    rdfs:label 'Generation Software' ;
    rdfs:comment 'Name and version of the software used to generate the randomization list (e.g., \'SAS 9.4\', \'R 4.2.1\', \'Oracle Clinical One 21.3\'). Required for regulatory submission and reproducibility validation.' ;
    rdfs:domain ind:RandScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irtSchemeReference rdf:type rdf:Property ;
    rdfs:label 'Irt Scheme Reference' ;
    rdfs:comment 'The scheme identifier or configuration reference as recorded in the IRT/RTSM system (e.g., Oracle Clinical One scheme ID or Medidata Rave RTSM list ID). Enables cross-system traceability.' ;
    rdfs:domain ind:RandScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCentralized rdf:type rdf:Property ;
    rdfs:label 'Is Centralized' ;
    rdfs:comment 'Indicates whether randomization is performed centrally via IRT/IVRS/RTSM (True) or locally at the site (False). Centralized randomization is the standard for GCP-compliant multi-center trials.' ;
    rdfs:domain ind:RandScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStratifiedBySite rdf:type rdf:Property ;
    rdfs:label 'Is Stratified By Site' ;
    rdfs:comment 'Indicates whether randomization is stratified by investigative site. Site stratification is common in multi-center trials to ensure balance across sites.' ;
    rdfs:domain ind:RandScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVariableBlock rdf:type rdf:Property ;
    rdfs:label 'Is Variable Block' ;
    rdfs:comment 'Indicates whether variable (random) block sizes are used rather than a fixed block size. Variable blocks reduce the ability to predict upcoming assignments and are preferred for double-blind studies.' ;
    rdfs:domain ind:RandScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:listGenerationDate rdf:type rdf:Property ;
    rdfs:label 'List Generation Date' ;
    rdfs:comment 'Date on which the randomization list was generated using the specified software and seed. Required for audit trail and regulatory submission documentation.' ;
    rdfs:domain ind:RandScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimizationObjectiveFunction rdf:type rdf:Property ;
    rdfs:label 'Minimization Objective Function' ;
    rdfs:comment 'For minimization or covariate-adaptive algorithms, the mathematical objective function used to minimize imbalance across covariates (e.g., \'range\', \'variance\', \'weighted_range\'). Null for non-minimization schemes.' ;
    rdfs:domain ind:RandScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimizationProbability rdf:type rdf:Property ;
    rdfs:label 'Minimization Probability' ;
    rdfs:comment 'For minimization algorithms, the probability (0.0–1.0) of assigning a subject to the arm that minimizes imbalance (e.g., 0.8000 = 80% biased coin). Null for non-minimization schemes.' ;
    rdfs:domain ind:RandScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:randomSeed rdf:type rdf:Property ;
    rdfs:label 'Random Seed' ;
    rdfs:comment 'Numeric seed value used to initialize the pseudo-random number generator for reproducible list generation. Classified confidential to protect blinding integrity; disclosed only at database lock (DBL) or unblinding. Required for regulatory audit and CSR appendix.' ;
    rdfs:domain ind:RandScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:schemeCode rdf:type rdf:Property ;
    rdfs:label 'Scheme Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this randomization scheme within the RTSM/IRT system (e.g., Oracle Clinical One or Medidata Rave RTSM). Used as the business key for cross-system reference.' ;
    rdfs:domain ind:RandScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeName rdf:type rdf:Property ;
    rdfs:label 'Scheme Name' ;
    rdfs:comment 'Human-readable descriptive name of the randomization scheme (e.g., \'Phase III Stratified Block Randomization v2\'). Used in reports, TMF documentation, and biostatistics deliverables.' ;
    rdfs:domain ind:RandScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeStatus rdf:type rdf:Property ;
    rdfs:label 'Scheme Status' ;
    rdfs:comment 'Current lifecycle status of the randomization scheme. \'draft\' = under development; \'approved\' = biostatistics/QA sign-off obtained; \'active\' = in use for subject allocation; \'suspended\' = temporarily halted (e.g., DSMB hold); \'retired\' = superseded or study closed.' ;
    rdfs:domain ind:RandScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeVersion rdf:type rdf:Property ;
    rdfs:label 'Scheme Version' ;
    rdfs:comment 'Version identifier of the randomization scheme (e.g., \'1.0\', \'2.1\'). Incremented when the scheme is amended post-approval. Supports audit trail and regulatory submission traceability.' ;
    rdfs:domain ind:RandScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strataCount rdf:type rdf:Property ;
    rdfs:label 'Strata Count' ;
    rdfs:comment 'Total number of distinct strata defined by the combination of stratification factors. Used to validate that the randomization list covers all strata and to monitor enrollment balance.' ;
    rdfs:domain ind:RandScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRandomizationSlots rdf:type rdf:Property ;
    rdfs:label 'Total Randomization Slots' ;
    rdfs:comment 'Total number of randomization positions (slots) generated in the scheme list. Represents the maximum number of subjects that can be randomized under this scheme version.' ;
    rdfs:domain ind:RandScheme ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:randValidationRunId rdf:type rdf:Property ;
    rdfs:label 'Rand Validation Run Id' ;
    rdfs:comment 'Unique surrogate identifier for each randomization validation run record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadTesterStudyAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Lead Tester Study Assignment Id' ;
    rdfs:comment 'Foreign key linking to workforce.study_assignment. Business justification: IRT/RTSM validation runs require the lead tester to be formally assigned to the study. Linking to study_assignment confirms the tester\'s authorized study role — a regulatory validation requirement (21' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudyAssignment .

ind:precedingRunId rdf:type rdf:Property ;
    rdfs:label 'Preceding Run Id' ;
    rdfs:comment 'Self-referencing identifier linking this validation run to the prior run it supersedes or follows (e.g., a re-validation run references the failed run it addresses). Enables validation run lineage tracking.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RandValidationRun .

ind:primaryRandEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Rand Employee Id' ;
    rdfs:comment 'Reference to the primary individual (typically a CRA, CRC, or IRT specialist) responsible for executing and documenting this validation run.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:validationProtocolId rdf:type rdf:Property ;
    rdfs:label 'Validation Protocol Id' ;
    rdfs:comment 'Reference to the approved validation protocol document (stored in Veeva Vault or eTMF) that governs the test scenarios, acceptance criteria, and sign-off requirements for this run.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Protocol .

ind:criticalDefectsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Defects Count' ;
    rdfs:comment 'Number of critical-severity defects identified during this validation run that directly impact randomization integrity, blinding, or patient safety. Critical defects must be resolved before go-live.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:electronicSignatureRef rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Ref' ;
    rdfs:comment 'Reference identifier for the 21 CFR Part 11-compliant electronic signature applied to the validation run sign-off record in the eTMF or document management system (e.g., Veeva Vault signature ID).' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irtSystemCode rdf:type rdf:Property ;
    rdfs:label 'Irt System Code' ;
    rdfs:comment 'Reference to the IRT/IVRS/RTSM system instance (e.g., Medidata Rave RTSM, Oracle Clinical One) being validated in this run.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kitAssignmentTested rdf:type rdf:Property ;
    rdfs:label 'Kit Assignment Tested' ;
    rdfs:comment 'Indicates whether IRT-driven investigational product kit assignment and supply chain allocation scenarios were included and validated in this run. Required for RTSM/supply domain integration.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadTesterName rdf:type rdf:Property ;
    rdfs:label 'Lead Tester Name' ;
    rdfs:comment 'Full name of the lead tester who executed this validation run, captured at time of execution for audit trail integrity per ALCOA+ principles.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTesterRole rdf:type rdf:Property ;
    rdfs:label 'Lead Tester Role' ;
    rdfs:comment 'Professional role of the lead tester at the time of validation execution. Used to verify that testing was performed by qualified personnel per GCP requirements. [ENUM-REF-CANDIDATE: CRA|CRC|IRT_specialist|biostatistician|data_manager|QA_analyst — promote to reference product]' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorDefectsCount rdf:type rdf:Property ;
    rdfs:label 'Major Defects Count' ;
    rdfs:comment 'Number of major-severity defects identified during this validation run that significantly impact system functionality but may be accepted with documented risk mitigation.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorDefectsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Defects Count' ;
    rdfs:comment 'Number of minor-severity defects identified during this validation run that have low impact on system functionality and may be deferred to a future release.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openItemsDescription rdf:type rdf:Property ;
    rdfs:label 'Open Items Description' ;
    rdfs:comment 'Narrative description of any open defects, deviations, or risk-accepted items documented at the time of sign-off for conditionally approved runs. Required for regulatory audit readiness.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallSignOffStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Sign Off Status' ;
    rdfs:comment 'Final sign-off decision for this validation run: pending (awaiting review), approved (run accepted, system cleared for go-live), rejected (run not accepted, re-validation required), conditionally_approved (accepted with documented open items). Required before first subject randomization.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:randAlgorithmVersion rdf:type rdf:Property ;
    rdfs:label 'Rand Algorithm Version' ;
    rdfs:comment 'Version identifier of the randomization algorithm configuration (e.g., block randomization list version, minimization algorithm version) being validated.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reRandomizationTested rdf:type rdf:Property ;
    rdfs:label 'Re Randomization Tested' ;
    rdfs:comment 'Indicates whether subject re-randomization scenarios (e.g., after screen failure or protocol amendment) were included and validated in this run.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revalidationRequired rdf:type rdf:Property ;
    rdfs:label 'Revalidation Required' ;
    rdfs:comment 'Indicates whether a subsequent re-validation run is required following this run, typically triggered by critical defects, system changes, or protocol amendments.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:runCode rdf:type rdf:Property ;
    rdfs:label 'Run Code' ;
    rdfs:comment 'Externally-known business identifier for the validation run, used in TMF documentation, sign-off records, and regulatory submissions. Format: VAL-{STUDY}-{YEAR}-{SEQ}.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runDate rdf:type rdf:Property ;
    rdfs:label 'Run Date' ;
    rdfs:comment 'The calendar date on which the validation run was executed. Used for regulatory timeline tracking and GCP compliance documentation.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:runEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run End Timestamp' ;
    rdfs:comment 'Precise date and time when execution of the validation run was completed or terminated. Used to calculate run duration and for audit trail purposes.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Start Timestamp' ;
    rdfs:comment 'Precise date and time when execution of the validation run commenced, including timezone offset. Required for ALCOA+ audit trail compliance.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:comment 'Current lifecycle status of the validation run: planned (scheduled but not started), in_progress (execution underway), passed (all scenarios met acceptance criteria), failed (one or more critical scenarios failed), conditionally_passed (minor defects accepted with documented risk), cancelled (run abandoned before completion).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Classification of the validation run: UAT (User Acceptance Testing), dry_run (pre-go-live rehearsal), parallel_test (concurrent with legacy system), regression (post-change re-test), smoke_test (basic sanity check), re_validation (after defect remediation). [ENUM-REF-CANDIDATE: UAT|dry_run|parallel_test|regression|smoke_test|re_validation — promote to reference product]' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenariosBlocked rdf:type rdf:Property ;
    rdfs:label 'Scenarios Blocked' ;
    rdfs:comment 'Number of test scenarios that could not be executed due to a blocking defect or environmental issue, preventing completion of the planned test coverage.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scenariosExecuted rdf:type rdf:Property ;
    rdfs:label 'Scenarios Executed' ;
    rdfs:comment 'Number of test scenarios actually executed during this validation run. May differ from planned if the run was interrupted or scenarios were deferred.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scenariosFailed rdf:type rdf:Property ;
    rdfs:label 'Scenarios Failed' ;
    rdfs:comment 'Number of executed test scenarios that did not meet acceptance criteria, resulting in a defect or deviation record.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scenariosPassed rdf:type rdf:Property ;
    rdfs:label 'Scenarios Passed' ;
    rdfs:comment 'Number of executed test scenarios that met all defined acceptance criteria without deviation.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signOffApproverName rdf:type rdf:Property ;
    rdfs:label 'Sign Off Approver Name' ;
    rdfs:comment 'Full name of the approver who signed off on this validation run, captured at time of approval for ALCOA+ audit trail integrity.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffDate rdf:type rdf:Property ;
    rdfs:label 'Sign Off Date' ;
    rdfs:comment 'Date on which the final sign-off decision was recorded for this validation run. Must precede the first subject randomization date per GCP and 21 CFR Part 11 requirements.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stratificationFactorsTested rdf:type rdf:Property ;
    rdfs:label 'Stratification Factors Tested' ;
    rdfs:comment 'Comma-separated list of stratification factors (e.g., age_group, disease_severity, geographic_region, prior_treatment) included in the test scenarios to verify correct stratified randomization behavior.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testEnvironment rdf:type rdf:Property ;
    rdfs:label 'Test Environment' ;
    rdfs:comment 'The system environment in which the validation run was executed: development, QA (Quality Assurance), staging, production_mirror, or production. Determines regulatory weight of the validation evidence.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testScriptVersion rdf:type rdf:Property ;
    rdfs:label 'Test Script Version' ;
    rdfs:comment 'Version identifier of the test script document used during this validation run. Ensures traceability between executed tests and the approved test script version in the TMF.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalScenariosPlanned rdf:type rdf:Property ;
    rdfs:label 'Total Scenarios Planned' ;
    rdfs:comment 'Total number of test scenarios defined in the validation test script for this run, covering all randomization and IRT functional requirements.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:treatmentArmsTested rdf:type rdf:Property ;
    rdfs:label 'Treatment Arms Tested' ;
    rdfs:comment 'Number of treatment arms (including placebo/control) included in the validation test scenarios, confirming that all arms of the randomization scheme were exercised.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unblindingProcedureTested rdf:type rdf:Property ;
    rdfs:label 'Unblinding Procedure Tested' ;
    rdfs:comment 'Indicates whether emergency unblinding procedures (e.g., SAE-triggered unblinding via IRT) were included in the validation test scenarios.' ;
    rdfs:domain ind:RandValidationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualEnrolledCount rdf:type rdf:Property ;
    rdfs:label 'Actual Enrolled Count' ;
    rdfs:comment 'Current count of subjects who have been randomized and enrolled into this stratification cell. Updated in real time from the IRT/RTSM system (Medidata Rave RTSM / Oracle Clinical One) upon each randomization event.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:balanceTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Balance Tolerance Pct' ;
    rdfs:comment 'Acceptable percentage deviation from the target enrollment count before the cell is flagged as imbalanced. Defined in the SAP and used by the RTSM system to trigger balance alerts.' ;
    rdfs:domain ind:StratificationCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cellBalanceStatus rdf:type rdf:Property ;
    rdfs:label 'Cell Balance Status' ;
    rdfs:comment 'Current enrollment balance status of this stratification cell relative to its target. \'balanced\' indicates enrollment is within acceptable tolerance; \'under_enrolled\' or \'over_enrolled\' indicate deviation from target; \'closed\' indicates the cell is no longer accepting subjects; \'suspended\' indicates temporary halt.' ;
    rdfs:domain ind:StratificationCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cellCode rdf:type rdf:Property ;
    rdfs:label 'Cell Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this stratification cell within the study randomization scheme. Used in IRT/IVRS/RTSM systems such as Medidata Rave RTSM and Oracle Clinical One for cell-level kit assignment and allocation tracking.' ;
    rdfs:domain ind:StratificationCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cellDescription rdf:type rdf:Property ;
    rdfs:label 'Cell Description' ;
    rdfs:comment 'Detailed narrative description of the stratification cell, including the clinical rationale for the factor level combination and any protocol-specific notes.' ;
    rdfs:domain ind:StratificationCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cellLabel rdf:type rdf:Property ;
    rdfs:label 'Cell Label' ;
    rdfs:comment 'Human-readable composite label describing the full combination of stratification factor levels that define this cell (e.g., \'Age>=65 / Male / ECOG 0-1\'). Used in study reports, CSR tables, and enrollment dashboards.' ;
    rdfs:domain ind:StratificationCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cellSequence rdf:type rdf:Property ;
    rdfs:label 'Cell Sequence' ;
    rdfs:comment 'Ordinal sequence number of this cell within the randomization scheme, used for consistent ordering in reports, listings, and IRT/RTSM system configuration.' ;
    rdfs:domain ind:StratificationCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cellStatus rdf:type rdf:Property ;
    rdfs:label 'Cell Status' ;
    rdfs:comment 'Operational lifecycle status of the stratification cell within the randomization scheme. \'active\' means the cell is open for randomization; \'inactive\' means it has been deactivated; \'closed\' means enrollment is complete; \'suspended\' means temporarily halted; \'draft\' means not yet activated.' ;
    rdfs:domain ind:StratificationCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentCloseDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Close Date' ;
    rdfs:comment 'Date on which this stratification cell was closed to further subject randomization, either due to reaching the enrollment cap or protocol-driven closure.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentOpenDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Open Date' ;
    rdfs:comment 'Date on which this stratification cell was opened for subject randomization and enrollment, as recorded in the RTSM system.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isActiveForEnrollment rdf:type rdf:Property ;
    rdfs:label 'Is Active For Enrollment' ;
    rdfs:comment 'Indicates whether this stratification cell is currently open and accepting new subject randomizations. Controlled by the RTSM system and updated when enrollment caps or protocol amendments are applied.' ;
    rdfs:domain ind:StratificationCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRandomizationDate rdf:type rdf:Property ;
    rdfs:label 'Last Randomization Date' ;
    rdfs:comment 'Date of the most recent subject randomization event recorded within this stratification cell. Used to monitor cell activity and detect stalled enrollment.' ;
    rdfs:domain ind:StratificationCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumEnrollmentCount rdf:type rdf:Property ;
    rdfs:label 'Maximum Enrollment Count' ;
    rdfs:comment 'Maximum number of subjects permitted in this stratification cell per treatment arm. Enrollment is capped at this value to prevent over-representation of a stratum.' ;
    rdfs:domain ind:StratificationCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumEnrollmentCount rdf:type rdf:Property ;
    rdfs:label 'Minimum Enrollment Count' ;
    rdfs:comment 'Minimum number of subjects required in this stratification cell to maintain statistical validity of the study, as specified in the SAP. Triggers an alert if actual enrollment falls below this threshold.' ;
    rdfs:domain ind:StratificationCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:randomizedCount rdf:type rdf:Property ;
    rdfs:label 'Randomized Count' ;
    rdfs:comment 'Number of subjects who have received a randomization code assignment within this stratification cell, which may differ from enrolled count if subjects are randomized but not yet dosed.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rtsmCellReference rdf:type rdf:Property ;
    rdfs:label 'Rtsm Cell Reference' ;
    rdfs:comment 'External cell identifier as configured in the RTSM system (e.g., Medidata Rave RTSM or Oracle Clinical One IRT). Used for reconciliation between the data lakehouse and the operational RTSM system.' ;
    rdfs:domain ind:StratificationCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenedCount rdf:type rdf:Property ;
    rdfs:label 'Screened Count' ;
    rdfs:comment 'Number of subjects who have been screened and assessed for eligibility within this stratification cell, used to monitor the screening-to-enrollment funnel per stratum.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sdtmStratumValue rdf:type rdf:Property ;
    rdfs:label 'Sdtm Stratum Value' ;
    rdfs:comment 'CDISC SDTM-compliant stratum value code for this cell, mapped to the STRATCD variable in the RAND domain. Required for regulatory submission datasets and SDTM-to-ADaM derivations.' ;
    rdfs:domain ind:StratificationCell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetEnrollmentCount rdf:type rdf:Property ;
    rdfs:label 'Target Enrollment Count' ;
    rdfs:comment 'Protocol-specified target number of subjects to be enrolled in this stratification cell per treatment arm, as defined in the Statistical Analysis Plan (SAP) and randomization schedule.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:withdrawnCount rdf:type rdf:Property ;
    rdfs:label 'Withdrawn Count' ;
    rdfs:comment 'Number of subjects who were enrolled in this stratification cell but subsequently withdrew or were discontinued, used to assess cell-level dropout impact on balance.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adamVariable rdf:type rdf:Property ;
    rdfs:label 'Adam Variable' ;
    rdfs:comment 'The CDISC ADaM variable name in the ADSL dataset corresponding to this stratification factor (e.g., \'STRAT1\', \'BSEVSEV\'). Used in primary and sensitivity analyses per the Statistical Analysis Plan.' ;
    rdfs:domain ind:StratificationFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:covariateAdjustmentMethod rdf:type rdf:Property ;
    rdfs:label 'Covariate Adjustment Method' ;
    rdfs:comment 'Statistical method used to adjust for this stratification factor in the primary analysis: \'ancova\' for Analysis of Covariance, \'cmh\' for Cochran-Mantel-Haenszel test, \'logistic_regression\' for binary endpoints, \'none\' if not used as a covariate in analysis.' ;
    rdfs:domain ind:StratificationFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceType rdf:type rdf:Property ;
    rdfs:label 'Data Source Type' ;
    rdfs:comment 'Identifies the system or method from which the stratification factor value is captured at randomization: \'ecrf\' from the EDC eCRF, \'ivrs\' from Interactive Voice Response System, \'irt\' from IRT/RTSM, \'central_lab\' from laboratory results, \'manual_entry\' for site-entered values.' ;
    rdfs:domain ind:StratificationFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ecrfFieldReference rdf:type rdf:Property ;
    rdfs:label 'Ecrf Field Reference' ;
    rdfs:comment 'The eCRF form and field identifier in the EDC system (e.g., Medidata Rave) from which the stratification factor value is sourced at the time of randomization (e.g., \'SCREENING.DISVSEV\'). Enables traceability from randomization to source data.' ;
    rdfs:domain ind:StratificationFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorCode rdf:type rdf:Property ;
    rdfs:label 'Factor Code' ;
    rdfs:comment 'Short, system-level alphanumeric code uniquely identifying the stratification factor within the scheme (e.g., REGION, DISEASE_STAGE, GENDER). Used as the programmatic key in RTSM/IRT configuration and SDTM mapping.' ;
    rdfs:domain ind:StratificationFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorDescription rdf:type rdf:Property ;
    rdfs:label 'Factor Description' ;
    rdfs:comment 'Detailed narrative description of the stratification factor, including its clinical rationale, how it is assessed, and its role in balancing treatment arms as documented in the Statistical Analysis Plan.' ;
    rdfs:domain ind:StratificationFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorName rdf:type rdf:Property ;
    rdfs:label 'Factor Name' ;
    rdfs:comment 'Human-readable name of the stratification factor as displayed in the RTSM/IRT interface and statistical analysis plan (e.g., \'Geographic Region\', \'Baseline Disease Severity\', \'Prior Treatment Status\').' ;
    rdfs:domain ind:StratificationFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorStatus rdf:type rdf:Property ;
    rdfs:label 'Factor Status' ;
    rdfs:comment 'Lifecycle status of the stratification factor within the scheme design workflow: \'draft\' during initial configuration, \'approved\' after biostatistics/RTSM sign-off, \'active\' when live in the IRT system, \'suspended\' during protocol amendment review, \'retired\' when permanently decommissioned.' ;
    rdfs:domain ind:StratificationFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorType rdf:type rdf:Property ;
    rdfs:label 'Factor Type' ;
    rdfs:comment 'Classification of the factor\'s measurement scale: \'categorical\' for nominal groupings (e.g., region), \'continuous_binned\' for numeric ranges converted to categories (e.g., age groups), \'ordinal\' for ranked categories (e.g., disease severity), \'binary\' for two-level factors (e.g., yes/no prior treatment).' ;
    rdfs:domain ind:StratificationFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irtParameterName rdf:type rdf:Property ;
    rdfs:label 'Irt Parameter Name' ;
    rdfs:comment 'The exact parameter name as configured in the IRT/IVRS/RTSM system (e.g., Medidata Rave RTSM or Oracle Clinical One) for this stratification factor. Used for system integration and UAT validation.' ;
    rdfs:domain ind:StratificationFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryFactor rdf:type rdf:Property ;
    rdfs:label 'Is Primary Factor' ;
    rdfs:comment 'Indicates whether this factor is designated as a primary stratification factor (True) versus a secondary or exploratory factor (False) in the Statistical Analysis Plan. Primary factors are used in the primary efficacy analysis.' ;
    rdfs:domain ind:StratificationFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUsedInPrimaryAnalysis rdf:type rdf:Property ;
    rdfs:label 'Is Used In Primary Analysis' ;
    rdfs:comment 'Indicates whether this stratification factor is included as a covariate in the primary statistical analysis model (True) or is used only for randomization balance without inclusion in the primary analysis (False). Relevant for ANCOVA and CMH test specifications in the SAP.' ;
    rdfs:domain ind:StratificationFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:levelCount rdf:type rdf:Property ;
    rdfs:label 'Level Count' ;
    rdfs:comment 'Total number of enumerated levels (strata) defined for this stratification factor. Drives the dimensionality of the stratification matrix and the number of randomization lists required. For example, a 3-region factor has level_count = 3.' ;
    rdfs:domain ind:StratificationFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxImbalanceThreshold rdf:type rdf:Property ;
    rdfs:label 'Max Imbalance Threshold' ;
    rdfs:comment 'The maximum allowable imbalance (as a percentage or absolute count, per unit_of_imbalance) between treatment arms within any stratum defined by this factor before a balancing action is triggered in the minimization algorithm.' ;
    rdfs:domain ind:StratificationFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimizationVariant rdf:type rdf:Property ;
    rdfs:label 'Minimization Variant' ;
    rdfs:comment 'Specific variant of the minimization algorithm applied for this factor: \'pocock_simon\' for the Pocock-Simon method, \'weighted_minimization\' for factor-weighted minimization, \'biased_coin\' for biased-coin minimization, \'deterministic\' for deterministic minimization, \'none\' if minimization is not applicable.' ;
    rdfs:domain ind:StratificationFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimizationWeight rdf:type rdf:Property ;
    rdfs:label 'Minimization Weight' ;
    rdfs:comment 'Numeric weight assigned to this stratification factor in a minimization or weighted minimization algorithm (e.g., Pocock-Simon). Values typically range from 0.0 to 1.0, with higher weights indicating greater influence on treatment allocation balance. Null if minimization is not used.' ;
    rdfs:domain ind:StratificationFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:missingValueHandling rdf:type rdf:Property ;
    rdfs:label 'Missing Value Handling' ;
    rdfs:comment 'Defines the RTSM system behavior when the stratification factor value is missing or unknown at the time of randomization: \'block_randomization\' to prevent randomization, \'assign_default_level\' to use a pre-specified default level, \'flag_and_hold\' to alert the site, \'exclude_from_minimization\' to proceed without this factor.' ;
    rdfs:domain ind:StratificationFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:randomizationAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Randomization Algorithm' ;
    rdfs:comment 'The randomization algorithm applied in conjunction with this stratification factor: \'permuted_block\' for block randomization within strata, \'minimization\' for adaptive minimization, \'stratified_block\' for stratified permuted block, \'dynamic_allocation\' for covariate-adaptive methods.' ;
    rdfs:domain ind:StratificationFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtsmFactorCode rdf:type rdf:Property ;
    rdfs:label 'Rtsm Factor Code' ;
    rdfs:comment 'The native identifier assigned to this stratification factor within the source RTSM/IRT system (e.g., Medidata Rave RTSM internal factor ID or Oracle Clinical One factor GUID). Used for system integration, reconciliation, and audit trail linkage.' ;
    rdfs:domain ind:StratificationFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtsmSystem rdf:type rdf:Property ;
    rdfs:label 'Rtsm System' ;
    rdfs:comment 'Identifies the RTSM/IRT/IVRS system in which this stratification factor is configured and operationalized for subject randomization and kit assignment.' ;
    rdfs:domain ind:StratificationFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Integer defining the display and processing sequence of this stratification factor within the randomization scheme. Lower values appear first in RTSM screens, SAP tables, and stratification matrix axes.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitOfImbalance rdf:type rdf:Property ;
    rdfs:label 'Unit Of Imbalance' ;
    rdfs:comment 'Specifies whether the max_imbalance_threshold is expressed as a \'percentage\' of subjects within the stratum or as an absolute \'subject_count\'. Determines how the RTSM system evaluates balance during randomization.' ;
    rdfs:domain ind:StratificationFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationRule rdf:type rdf:Property ;
    rdfs:label 'Validation Rule' ;
    rdfs:comment 'Business rule or logical expression applied to validate the stratification factor value at the time of randomization (e.g., \'BMIBL >= 18 AND BMIBL < 30\'). Prevents invalid factor assignments and ensures data integrity per ALCOA+ principles.' ;
    rdfs:domain ind:StratificationFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalRandomizationSubjectRandomizationId rdf:type rdf:Property ;
    rdfs:label 'Original Randomization Subject Randomization Id' ;
    rdfs:comment 'For re-randomization events, the subject_randomization_id of the original randomization record that this event supersedes. Null for initial randomization events. Enables lineage tracing across re-randomization chains.' ;
    rdfs:domain ind:SubjectRandomization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SubjectRandomization .

ind:randomizingStudyAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Randomizing Study Assignment Id' ;
    rdfs:comment 'Foreign key linking to workforce.study_assignment. Business justification: GCP requires that the person performing randomization is formally assigned to the study with an authorized role. Linking to study_assignment confirms the randomizing user\'s active, authorized study ro' ;
    rdfs:domain ind:SubjectRandomization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudyAssignment .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'The date and time at which a randomization event was cancelled or voided in the IRT/RTSM system. Null for active or completed randomizations. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eligibilityConfirmed rdf:type rdf:Property ;
    rdfs:label 'Eligibility Confirmed' ;
    rdfs:comment 'Indicates whether all inclusion/exclusion criteria were confirmed as met prior to this randomization event (True = confirmed eligible; False = eligibility not confirmed or waived). Supports protocol deviation detection and ITT/PP population analysis.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:randomizationDate rdf:type rdf:Property ;
    rdfs:label 'Randomization Date' ;
    rdfs:comment 'The calendar date of the randomization event (yyyy-MM-dd). Derived from randomization_timestamp for day-level reporting, enrollment tracking, and CDISC SDTM DM.RANDDT mapping. Stored separately to support date-only queries without timestamp precision.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:randomizationStatus rdf:type rdf:Property ;
    rdfs:label 'Randomization Status' ;
    rdfs:comment 'Current lifecycle status of this randomization event. \'randomized\' indicates a successful initial allocation; \'re-randomized\' indicates a subsequent allocation event; \'cancelled\' indicates the randomization was voided; \'pending\' indicates the IRT transaction is in progress; \'failed\' indicates an IRT system error prevented completion.' ;
    rdfs:domain ind:SubjectRandomization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:randomizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Randomization Timestamp' ;
    rdfs:comment 'The exact date and time (with timezone offset) at which the subject was randomized by the IRT/IVRS/RTSM system. This is the principal business event timestamp and the ALCOA+ contemporaneous record of the allocation event. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:randomizationType rdf:type rdf:Property ;
    rdfs:label 'Randomization Type' ;
    rdfs:comment 'Classifies whether this record represents an initial randomization event, a re-randomization (subject re-entering the study), or a replacement randomization (e.g., IRT error correction). Drives downstream analysis population flags (ITT, PP).' ;
    rdfs:domain ind:SubjectRandomization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:randomizingUserRole rdf:type rdf:Property ;
    rdfs:label 'Randomizing User Role' ;
    rdfs:comment 'The role of the user or system that performed the randomization (e.g., CRC - Clinical Research Coordinator, PI - Principal Investigator, IRT_system for automated randomizations). Supports delegation log compliance and audit trail.' ;
    rdfs:domain ind:SubjectRandomization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rerandomizationReason rdf:type rdf:Property ;
    rdfs:label 'Rerandomization Reason' ;
    rdfs:comment 'The documented reason for re-randomizing the subject. Null for initial randomization events. Required for protocol deviation tracking and regulatory submission narratives.' ;
    rdfs:domain ind:SubjectRandomization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceWithinBlock rdf:type rdf:Property ;
    rdfs:label 'Sequence Within Block' ;
    rdfs:comment 'The position of this subject\'s allocation within the randomization block. Confidential to preserve blinding integrity. Used post-DBL for randomization quality review and biostatistical verification.' ;
    rdfs:domain ind:SubjectRandomization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stratificationFactor1Value rdf:type rdf:Property ;
    rdfs:label 'Stratification Factor 1 Value' ;
    rdfs:comment 'The value of the first protocol-defined stratification factor captured at the time of randomization (e.g., disease severity: mild/moderate/severe). Stored individually to support stratification balance analytics and CDISC SDTM SUPPRAND dataset generation.' ;
    rdfs:domain ind:SubjectRandomization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stratificationFactor2Value rdf:type rdf:Property ;
    rdfs:label 'Stratification Factor 2 Value' ;
    rdfs:comment 'The value of the second protocol-defined stratification factor captured at the time of randomization (e.g., geographic region: North America/Europe/Asia-Pacific). Supports stratification balance reporting and CDISC SDTM SUPPRAND.' ;
    rdfs:domain ind:SubjectRandomization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stratificationFactor3Value rdf:type rdf:Property ;
    rdfs:label 'Stratification Factor 3 Value' ;
    rdfs:comment 'The value of the third protocol-defined stratification factor captured at the time of randomization (e.g., prior treatment: yes/no). Nullable when fewer than three stratification factors are defined in the protocol.' ;
    rdfs:domain ind:SubjectRandomization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:armEndDate rdf:type rdf:Property ;
    rdfs:label 'Arm End Date' ;
    rdfs:comment 'Date on which this treatment arm was closed to new randomizations or formally ended per protocol or protocol amendment. Nullable for arms that remain open. Used for enrollment closure tracking and database lock (DBL) preparation.' ;
    rdfs:domain ind:TreatmentArm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:armSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Arm Sequence Number' ;
    rdfs:comment 'Ordinal sequence number defining the display order of this treatment arm in study reports, listings, and tables. Used for consistent ordering in CSR outputs, SDTM datasets, and regulatory submission documents.' ;
    rdfs:domain ind:TreatmentArm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:armStartDate rdf:type rdf:Property ;
    rdfs:label 'Arm Start Date' ;
    rdfs:comment 'Date on which this treatment arm became active and eligible for subject randomization, as defined in the protocol or IRT/RTSM configuration. Used for enrollment timeline tracking and regulatory reporting.' ;
    rdfs:domain ind:TreatmentArm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:armStatus rdf:type rdf:Property ;
    rdfs:label 'Arm Status' ;
    rdfs:comment 'Current lifecycle status of the treatment arm. Controls whether subjects can be randomized to this arm, whether supply kits can be assigned, and whether the arm is available for data entry in the EDC. Managed in Oracle Clinical One and Medidata Rave RTSM.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:armType rdf:type rdf:Property ;
    rdfs:label 'Arm Type' ;
    rdfs:comment 'Classification of the treatment arm by its role in the study design. Drives regulatory reporting, safety analysis population definitions, and CDISC SDTM ARMCD mapping. [ENUM-REF-CANDIDATE: experimental|active_comparator|placebo|open_label_extension|run_in|follow_up — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blindingRole rdf:type rdf:Property ;
    rdfs:label 'Blinding Role' ;
    rdfs:comment 'Blinding designation for this treatment arm indicating the level of masking applied. Critical for maintaining blinding integrity in the study. Restricted access to prevent unblinding of sponsor, investigator, or subject. Managed in Medidata Rave RTSM and Oracle Clinical One.' ;
    rdfs:domain ind:TreatmentArm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossoverSequence rdf:type rdf:Property ;
    rdfs:label 'Crossover Sequence' ;
    rdfs:comment 'For crossover study designs, defines the treatment sequence this arm represents (e.g., \'AB\', \'BA\', \'ABC\'). Used in CDISC SDTM SEARM (Sequence Arm) variable and period-specific analysis in ADaM datasets.' ;
    rdfs:domain ind:TreatmentArm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosingFrequency rdf:type rdf:Property ;
    rdfs:label 'Dosing Frequency' ;
    rdfs:comment 'Frequency of investigational product administration for subjects in this arm (e.g., \'QD - Once Daily\', \'BID - Twice Daily\', \'QW - Once Weekly\'). Mapped to CDISC Controlled Terminology FREQ variable in the EX domain.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcArmCode rdf:type rdf:Property ;
    rdfs:label 'Edc Arm Code' ;
    rdfs:comment 'Treatment arm code as configured in the Electronic Data Capture (EDC) system (Medidata Rave EDC or Oracle Clinical One). Used for eCRF field population, data validation rules, and SDTM mapping. Ensures consistency between EDC and IRT arm definitions.' ;
    rdfs:domain ind:TreatmentArm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irtArmCode rdf:type rdf:Property ;
    rdfs:label 'Irt Arm Code' ;
    rdfs:comment 'Treatment arm code as configured in the Interactive Response Technology (IRT) / Interactive Voice Response System (IVRS) / Randomization and Trial Supply Management (RTSM) system (Medidata Rave RTSM). Used for kit assignment, supply reconciliation, and randomization code generation. May differ from the SDTM arm code.' ;
    rdfs:domain ind:TreatmentArm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBlindedToInvestigator rdf:type rdf:Property ;
    rdfs:label 'Is Blinded To Investigator' ;
    rdfs:comment 'Indicates whether the treatment arm assignment is masked from the Principal Investigator (PI) and site staff. Critical for double-blind study integrity and GCP compliance documentation.' ;
    rdfs:domain ind:TreatmentArm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBlindedToSubject rdf:type rdf:Property ;
    rdfs:label 'Is Blinded To Subject' ;
    rdfs:comment 'Indicates whether the treatment arm assignment is masked from the study subject. Supports blinding integrity documentation required by ICH E9 and GCP. Distinct from investigator or sponsor blinding.' ;
    rdfs:domain ind:TreatmentArm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isControlArm rdf:type rdf:Property ;
    rdfs:label 'Is Control Arm' ;
    rdfs:comment 'Indicates whether this treatment arm serves as the control arm (placebo or active comparator) in the study. Used in statistical analysis to define the reference group for primary and secondary endpoint comparisons.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxSubjectCount rdf:type rdf:Property ;
    rdfs:label 'Max Subject Count' ;
    rdfs:comment 'Maximum number of subjects permitted in this treatment arm. Enforced by IRT/RTSM to prevent over-enrollment. May be set for adaptive designs or safety-driven enrollment caps.' ;
    rdfs:domain ind:TreatmentArm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minSubjectCount rdf:type rdf:Property ;
    rdfs:label 'Min Subject Count' ;
    rdfs:comment 'Minimum number of subjects required in this treatment arm to maintain statistical validity and meet protocol-defined endpoints. Used by DSMB/DMC for interim analysis decisions and by biostatistics for power calculations.' ;
    rdfs:domain ind:TreatmentArm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sdtmArmValue rdf:type rdf:Property ;
    rdfs:label 'Sdtm Arm Value' ;
    rdfs:comment 'The exact ARM variable value as it will appear in the CDISC SDTM DM (Demographics) and ARM domains for regulatory submission. Must conform to CDISC Controlled Terminology and be consistent across all SDTM datasets submitted in the eCTD package.' ;
    rdfs:domain ind:TreatmentArm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Target Allocation Pct' ;
    rdfs:comment 'Target percentage of randomized subjects to be allocated to this treatment arm as specified in the Statistical Analysis Plan (SAP) and protocol. Used for enrollment monitoring, supply forecasting, and IRT/RTSM configuration. Example: 33.33 for a 1:1:1 three-arm study.' ;
    rdfs:domain ind:TreatmentArm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentDescription rdf:type rdf:Property ;
    rdfs:label 'Treatment Description' ;
    rdfs:comment 'Detailed narrative description of the investigational treatment, comparator, or placebo administered in this arm, including drug name, formulation, dose, route of administration, and dosing schedule as specified in the protocol.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:washoutPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Washout Period Days' ;
    rdfs:comment 'Number of days required for washout between treatment periods for this arm in crossover or multi-period study designs. Defined in the protocol based on pharmacokinetic (PK) half-life data. Used for visit scheduling and IRT/RTSM period management.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unblindingApprovalId rdf:type rdf:Property ;
    rdfs:label 'Unblinding Approval Id' ;
    rdfs:comment 'Unique surrogate identifier for each unblinding approval record in the randomization domain. Primary key for this entity.' ;
    rdfs:domain ind:UnblindingApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approverStudyAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Approver Study Assignment Id' ;
    rdfs:comment 'Foreign key linking to workforce.study_assignment. Business justification: Unblinding approvers must be formally authorized study team members. Linking to study_assignment confirms the approver\'s active, authorized role on the study at time of approval — a GCP blinding integ' ;
    rdfs:domain ind:UnblindingApproval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudyAssignment .

ind:primaryUnblindingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Unblinding Employee Id' ;
    rdfs:comment 'Reference to the workforce/personnel record of the individual who rendered the approval decision. Enables linkage to credentials, training records, and delegation of authority documentation.' ;
    rdfs:domain ind:Randomization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'Numeric level within the multi-tier approval hierarchy (e.g., 1 = first-line approver such as PI, 2 = second-line such as Medical Monitor, 3 = final authority such as Sponsor Medical Officer). Supports multi-level approval workflow tracking required by GCP.' ;
    rdfs:domain ind:UnblindingApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Number' ;
    rdfs:comment 'Externally-known, human-readable unique identifier for this approval record, used in regulatory submissions, audit trails, and cross-system references (e.g., UBA-STUDY01-202401). Serves as the BUSINESS_IDENTIFIER for this transaction.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blindingMaintained rdf:type rdf:Property ;
    rdfs:label 'Blinding Maintained' ;
    rdfs:comment 'Indicates whether the overall study blinding integrity was maintained following this unblinding event (True = blinding maintained for the broader study population; False = blinding compromised at study level). Critical for assessing impact on study validity.' ;
    rdfs:domain ind:UnblindingApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'The exact date and time (with timezone) at which the approver rendered their decision on the unblinding request. This is the principal business event timestamp for this transaction, critical for GCP audit trail and 21 CFR Part 11 electronic signature compliance.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:delegationOfAuthority rdf:type rdf:Property ;
    rdfs:label 'Delegation Of Authority' ;
    rdfs:comment 'Indicates whether the approver was acting under a formal delegation of authority (True = delegated authority; False = primary role holder). Relevant when a PI delegates unblinding approval authority to a sub-investigator or designee.' ;
    rdfs:domain ind:UnblindingApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyUnblinding rdf:type rdf:Property ;
    rdfs:label 'Emergency Unblinding' ;
    rdfs:comment 'Indicates whether this unblinding approval was processed under emergency procedures (True = emergency unblinding bypassing standard multi-level approval; False = standard approval workflow). Emergency unblinding events require expedited regulatory notification.' ;
    rdfs:domain ind:UnblindingApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationTargetRole rdf:type rdf:Property ;
    rdfs:label 'Escalation Target Role' ;
    rdfs:comment 'The role to which the unblinding decision has been escalated when approval_status is \'escalated\'. Identifies the next authority in the approval chain. [ENUM-REF-CANDIDATE: sponsor_medical_officer|dsmb_chair|irb_chair|regulatory_authority|cro_medical_director — promote to reference product]' ;
    rdfs:domain ind:UnblindingApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gcpComplianceConfirmed rdf:type rdf:Property ;
    rdfs:label 'Gcp Compliance Confirmed' ;
    rdfs:comment 'Indicates whether the approver explicitly confirmed that the unblinding procedure was conducted in accordance with Good Clinical Practice (GCP) guidelines and the applicable protocol SOP (True = confirmed; False = not confirmed or exception noted).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSent rdf:type rdf:Property ;
    rdfs:label 'Notification Sent' ;
    rdfs:comment 'Indicates whether the required regulatory and sponsor notifications were dispatched following this approval decision (True = notifications sent; False = pending notification). Supports compliance tracking for expedited safety reporting timelines.' ;
    rdfs:domain ind:UnblindingApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Timestamp' ;
    rdfs:comment 'The date and time at which regulatory and sponsor notifications were dispatched following the approval decision. Populated when notification_sent is True. Used to verify compliance with expedited reporting timelines (e.g., 7-day/15-day SAE reporting).' ;
    rdfs:domain ind:UnblindingApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Response Time Hours' ;
    rdfs:comment 'Elapsed time in hours between the submission of the unblinding request and the rendering of this approval decision. Used for KPI monitoring of emergency unblinding response times and SOP compliance.' ;
    rdfs:domain ind:UnblindingApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentArmRevealed rdf:type rdf:Property ;
    rdfs:label 'Treatment Arm Revealed' ;
    rdfs:comment 'The treatment arm or randomization code that was disclosed to the approver upon approval of the unblinding request (e.g., \'Active Drug A 10mg\', \'Placebo\'). Populated only after approval is granted and unblinding is executed. Classified as confidential as it contains blinded study information.' ;
    rdfs:domain ind:Randomization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unblindingReasonCategory rdf:type rdf:Property ;
    rdfs:label 'Unblinding Reason Category' ;
    rdfs:comment 'Categorical classification of the reason driving the unblinding request being reviewed. Supports regulatory reporting and trend analysis of unblinding events. [ENUM-REF-CANDIDATE: emergency_medical|sae_reporting|regulatory_requirement|dsmb_review|study_completion|protocol_deviation — promote to reference product]' ;
    rdfs:domain ind:UnblindingApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approver1EmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver 1 Employee Id' ;
    rdfs:comment 'Reference to the workforce/user record of the first-level approver in the approval chain (typically the Medical Monitor or Sponsor representative). Captures the identity of the approver for GCP audit trail.' ;
    rdfs:domain ind:UnblindingRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approver2EmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver 2 Employee Id' ;
    rdfs:comment 'Reference to the workforce/user record of the second-level approver (e.g., CRO Medical Director or DSMB member). Populated only when a second approval level is required per the study protocol.' ;
    rdfs:domain ind:UnblindingRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:requestorStudyAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Requestor Study Assignment Id' ;
    rdfs:comment 'Foreign key linking to workforce.study_assignment. Business justification: Unblinding requests must originate from authorized study team members. Linking to study_assignment confirms the requestor\'s active, authorized role on the study — a GCP and blinding integrity requirem' ;
    rdfs:domain ind:UnblindingRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudyAssignment .

ind:triggeringLabResultId rdf:type rdf:Property ;
    rdfs:label 'Triggering Lab Result Id' ;
    rdfs:comment 'Foreign key linking to laboratory.lab_result. Business justification: Emergency unblinding requests triggered by critical lab findings (e.g., severe hepatotoxicity, critical hematology values) must document the specific lab result that justified unblinding per ICH E6 GC' ;
    rdfs:domain ind:UnblindingRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabResult .

ind:approvalLevelCount rdf:type rdf:Property ;
    rdfs:label 'Approval Level Count' ;
    rdfs:comment 'Total number of approval levels required for this unblinding request based on the study protocol and urgency classification. Drives the multi-step approval workflow routing in the RTSM system.' ;
    rdfs:domain ind:UnblindingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approver1Decision rdf:type rdf:Property ;
    rdfs:label 'Approver 1 Decision' ;
    rdfs:comment 'Decision rendered by the first-level approver on the unblinding request. Approved advances the request; rejected terminates it; escalated routes to a higher authority; deferred postpones pending additional information.' ;
    rdfs:domain ind:UnblindingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approver1Rationale rdf:type rdf:Property ;
    rdfs:label 'Approver 1 Rationale' ;
    rdfs:comment 'Free-text rationale provided by the first-level approver explaining their decision. Required for GCP compliance and regulatory audit trail, particularly for rejections and escalations.' ;
    rdfs:domain ind:UnblindingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approver1Role rdf:type rdf:Property ;
    rdfs:label 'Approver 1 Role' ;
    rdfs:comment 'Clinical or organizational role of the first-level approver at the time of their decision. Captured at decision time for audit trail integrity. [ENUM-REF-CANDIDATE: medical_monitor|sponsor_representative|cro_medical_director|irb_chair|dsmb_member|other — promote to reference product]' ;
    rdfs:domain ind:UnblindingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approver1Timestamp rdf:type rdf:Property ;
    rdfs:label 'Approver 1 Timestamp' ;
    rdfs:comment 'Date and time when the first-level approver rendered their decision. Used to calculate approval cycle time and assess compliance with urgency SLAs.' ;
    rdfs:domain ind:UnblindingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approver2Decision rdf:type rdf:Property ;
    rdfs:label 'Approver 2 Decision' ;
    rdfs:comment 'Decision rendered by the second-level approver on the unblinding request. Follows the same decision taxonomy as level 1. Null when a second approval level is not required.' ;
    rdfs:domain ind:UnblindingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approver2Timestamp rdf:type rdf:Property ;
    rdfs:label 'Approver 2 Timestamp' ;
    rdfs:comment 'Date and time when the second-level approver rendered their decision. Null when a second approval level is not required.' ;
    rdfs:domain ind:UnblindingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:blindingBrokenFlag rdf:type rdf:Property ;
    rdfs:label 'Blinding Broken Flag' ;
    rdfs:comment 'Indicates whether the blinding was actually broken as a result of this request (True) or whether the request was resolved without revealing the treatment assignment (False). Used for protocol deviation tracking and blinding integrity reporting.' ;
    rdfs:domain ind:UnblindingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clinicalJustification rdf:type rdf:Property ;
    rdfs:label 'Clinical Justification' ;
    rdfs:comment 'Free-text narrative provided by the requestor describing the clinical rationale for unblinding. For SAE-driven requests, includes the nature of the adverse event, patient condition, and why knowledge of treatment assignment is medically necessary. Required for GCP compliance and audit trail.' ;
    rdfs:domain ind:UnblindingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentApprovalLevel rdf:type rdf:Property ;
    rdfs:label 'Current Approval Level' ;
    rdfs:comment 'The approval step currently pending action within the multi-level approval chain. Increments as each approver completes their review. Used for workflow routing and escalation monitoring.' ;
    rdfs:domain ind:UnblindingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dsmbDmcReferralFlag rdf:type rdf:Property ;
    rdfs:label 'Dsmb Dmc Referral Flag' ;
    rdfs:comment 'Indicates whether this unblinding request was referred to or reviewed by the DSMB/DMC (True) or not (False). Applicable for interim analysis unblinding or escalated emergency cases requiring independent oversight.' ;
    rdfs:domain ind:UnblindingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:finalOutcome rdf:type rdf:Property ;
    rdfs:label 'Final Outcome' ;
    rdfs:comment 'The definitive resolution of the unblinding request after all approval levels have been completed. Approved means the treatment assignment was revealed; rejected means the request was denied; withdrawn means the requestor retracted the request; escalated means the request was referred to a higher authority (e.g., DSMB/DMC).' ;
    rdfs:domain ind:UnblindingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbIecNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Notification Timestamp' ;
    rdfs:comment 'Date and time when the IRB/IEC was formally notified of the unblinding event. Null if notification is not required or has not yet been sent. Used for regulatory compliance tracking.' ;
    rdfs:domain ind:UnblindingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Human-readable, externally-known business identifier for the unblinding request, typically generated by the RTSM/IRT system (e.g., Oracle Clinical One or Medidata Rave). Used in regulatory correspondence, audit trails, and DSMB/DMC communications.' ;
    rdfs:domain ind:UnblindingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle state of the unblinding request workflow. Tracks progression from initial submission through multi-level approval to final resolution. Drives GCP audit trail and DSMB/DMC oversight reporting.' ;
    rdfs:domain ind:UnblindingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorName rdf:type rdf:Property ;
    rdfs:label 'Requestor Name' ;
    rdfs:comment 'Full name of the individual who submitted the unblinding request, captured at the time of submission for audit trail integrity per 21 CFR Part 11 and ALCOA+ requirements. Preserved even if the workforce record is later modified.' ;
    rdfs:domain ind:UnblindingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorRole rdf:type rdf:Property ;
    rdfs:label 'Requestor Role' ;
    rdfs:comment 'Clinical role of the individual who submitted the unblinding request at the time of submission. Captured at request time to preserve audit integrity even if the person\'s role changes later. [ENUM-REF-CANDIDATE: pi|sub_investigator|crc|sponsor_medical_monitor|cra|other — promote to reference product]' ;
    rdfs:domain ind:UnblindingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredByTimestamp rdf:type rdf:Property ;
    rdfs:label 'Required By Timestamp' ;
    rdfs:comment 'Date and time by which the unblinding decision is clinically required, as specified by the requestor. Used to enforce urgency SLAs and escalation triggers. For emergency requests, this may be within hours of submission.' ;
    rdfs:domain ind:UnblindingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceSystemRequestCode rdf:type rdf:Property ;
    rdfs:label 'Source System Request Code' ;
    rdfs:comment 'The native identifier of this unblinding request in the originating operational system (Oracle Clinical One or Medidata Rave RTSM). Used for cross-system reconciliation and data lineage tracing in the lakehouse.' ;
    rdfs:domain ind:UnblindingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'Date and time when the unblinding request was formally submitted by the requestor in the RTSM/IRT system. This is the principal business event timestamp for this transaction. Critical for measuring response time against urgency SLAs and for regulatory audit trail.' ;
    rdfs:domain ind:UnblindingRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:urgencyLevel rdf:type rdf:Property ;
    rdfs:label 'Urgency Level' ;
    rdfs:comment 'Clinical urgency classification of the unblinding request. Emergency indicates immediate patient safety risk requiring unblinding within hours; urgent indicates within 24 hours; routine indicates planned/scheduled unblinding with no immediate safety concern.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyMeetingId rdf:type rdf:Property ;
    rdfs:label 'Agency Meeting Id' ;
    rdfs:comment 'Unique surrogate identifier for the agency meeting record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AgencyMeeting .

ind:sponsorLeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sponsor Lead Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: The sponsor lead attending FDA/EMA meetings (Type B, pre-NDA) is a workforce employee. Meeting preparation accountability, action item ownership, and inspection readiness tracking require this link. \'' ;
    rdfs:domain ind:AgencyMeeting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agencyAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Agency Acknowledgement Date' ;
    rdfs:comment 'The date on which the health authority formally acknowledged receipt of the meeting request. Marks the start of the regulatory response clock for PDUFA-governed timelines.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agencyContactName rdf:type rdf:Property ;
    rdfs:label 'Agency Contact Name' ;
    rdfs:comment 'Full name of the primary agency contact or project manager at the health authority assigned to this meeting. Used for correspondence tracking and relationship management.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyDivision rdf:type rdf:Property ;
    rdfs:label 'Agency Division' ;
    rdfs:comment 'Specific division, office, or therapeutic area unit within the health authority responsible for the meeting (e.g., FDA Office of Oncology Products, EMA Committee for Medicinal Products for Human Use (CHMP), PMDA Office of New Drug I).' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyFeedbackSummary rdf:type rdf:Property ;
    rdfs:label 'Agency Feedback Summary' ;
    rdfs:comment 'High-level summary of the health authority\'s feedback, positions, and recommendations arising from the meeting. Classified as confidential due to strategic regulatory sensitivity. Full details are captured in finalized meeting minutes.' ;
    rdfs:domain ind:AgencyMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyResponseDate rdf:type rdf:Property ;
    rdfs:label 'Agency Response Date' ;
    rdfs:comment 'The date on which the health authority provided its formal response to the meeting request (granting, denying, or proposing alternatives). Used to measure agency response time against PDUFA commitments.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:briefingDocumentDueDate rdf:type rdf:Property ;
    rdfs:label 'Briefing Document Due Date' ;
    rdfs:comment 'The deadline by which the sponsor must submit the meeting briefing document (background package) to the health authority prior to the meeting. Typically 30 days before the meeting for FDA Type B meetings.' ;
    rdfs:domain ind:AgencyMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:briefingDocumentSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Briefing Document Submission Date' ;
    rdfs:comment 'The actual date on which the meeting briefing document (background package) was submitted to the health authority via eCTD or other regulatory submission channel in Veeva Vault.' ;
    rdfs:domain ind:AgencyMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:briefingDocumentVersion rdf:type rdf:Property ;
    rdfs:label 'Briefing Document Version' ;
    rdfs:comment 'Version identifier of the meeting briefing document submitted to the health authority, as tracked in Veeva Vault document management. Enables traceability of the exact document version reviewed by the agency.' ;
    rdfs:domain ind:AgencyMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Meeting Date' ;
    rdfs:comment 'The date confirmed by the health authority for the meeting to take place. This is the operationally binding date used for scheduling, briefing document preparation, and attendee coordination.' ;
    rdfs:domain ind:AgencyMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmedMeetingTime rdf:type rdf:Property ;
    rdfs:label 'Confirmed Meeting Time' ;
    rdfs:comment 'The precise date and time (with timezone) confirmed by the health authority for the meeting, used for scheduling teleconferences and videoconferences across global time zones.' ;
    rdfs:domain ind:AgencyMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:etmfSectionReference rdf:type rdf:Property ;
    rdfs:label 'Etmf Section Reference' ;
    rdfs:comment 'The eTMF section or zone reference where the agency meeting documents (request, briefing document, minutes) are filed, per the DIA Reference Model for the TMF. Ensures regulatory inspection readiness and document traceability.' ;
    rdfs:domain ind:AgencyMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpSubmissionDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Submission Due Date' ;
    rdfs:comment 'The deadline by which the sponsor must submit any follow-up regulatory documents or responses to the health authority as agreed during or after the meeting.' ;
    rdfs:domain ind:AgencyMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpSubmissionRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Submission Required' ;
    rdfs:comment 'Indicates whether the agency meeting outcome requires a follow-up regulatory submission (e.g., protocol amendment, IND amendment, additional data package) as a result of agency feedback or commitments made during the meeting.' ;
    rdfs:domain ind:AgencyMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meetingObjectives rdf:type rdf:Property ;
    rdfs:label 'Meeting Objectives' ;
    rdfs:comment 'Free-text description of the primary scientific, regulatory, or strategic objectives for the agency meeting, as stated in the meeting request. Captures the key questions and discussion topics the sponsor seeks to resolve.' ;
    rdfs:domain ind:AgencyMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingStage rdf:type rdf:Property ;
    rdfs:label 'Meeting Stage' ;
    rdfs:comment 'The clinical development stage at which the agency meeting is requested, indicating the regulatory milestone context (e.g., Pre-IND, End-of-Phase 2, Pre-NDA/BLA submission). Aligns with FDA Type B meeting sub-categories.' ;
    rdfs:domain ind:AgencyMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minutesDraftDate rdf:type rdf:Property ;
    rdfs:label 'Minutes Draft Date' ;
    rdfs:comment 'The date on which the draft meeting minutes were prepared by the sponsor following the agency meeting. FDA requires sponsors to submit draft minutes within 30 days of the meeting.' ;
    rdfs:domain ind:AgencyMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minutesFinalizedDate rdf:type rdf:Property ;
    rdfs:label 'Minutes Finalized Date' ;
    rdfs:comment 'The date on which the meeting minutes were finalized and agreed upon by both the sponsor and the health authority. Finalized minutes represent the official record of agency agreements and commitments.' ;
    rdfs:domain ind:AgencyMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minutesSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Minutes Submitted Date' ;
    rdfs:comment 'The date on which the sponsor submitted the draft meeting minutes to the health authority for review and comment.' ;
    rdfs:domain ind:AgencyMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ndaBlaNumber rdf:type rdf:Property ;
    rdfs:label 'Nda Bla Number' ;
    rdfs:comment 'The FDA-assigned NDA or BLA application number if the meeting is related to a marketing application. Applicable for pre-NDA/BLA, post-approval, or labeling meetings.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openActionItemsCount rdf:type rdf:Property ;
    rdfs:label 'Open Action Items Count' ;
    rdfs:comment 'Number of action items from the agency meeting that remain open or unresolved. Used for regulatory follow-up tracking and inspection readiness monitoring.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outcomeClassification rdf:type rdf:Property ;
    rdfs:label 'Outcome Classification' ;
    rdfs:comment 'Classification of the overall outcome of the agency meeting with respect to the sponsor\'s objectives. Agreement Reached = agency aligned with sponsor\'s proposed approach; Partial Agreement = some questions resolved; No Agreement = agency did not concur; Pending Agency Response = written response awaited; Information Only = meeting was informational with no formal positions taken.' ;
    rdfs:domain ind:AgencyMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pdufaResponseDeadline rdf:type rdf:Property ;
    rdfs:label 'Pdufa Response Deadline' ;
    rdfs:comment 'The regulatory deadline by which the FDA must respond to the meeting request under Prescription Drug User Fee Act (PDUFA) commitments. Type A: 30 days; Type B: 70 days; Type C: 90 days from receipt of meeting request.' ;
    rdfs:domain ind:AgencyMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'The name of the investigational medicinal product or biological entity that is the subject of the agency meeting. May be a proprietary name, INN (International Nonproprietary Name), or internal code name. Classified as confidential due to competitive sensitivity.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Proposed Meeting Date' ;
    rdfs:comment 'The date proposed by the sponsor in the meeting request for when the meeting should occur. May differ from the agency-confirmed date.' ;
    rdfs:domain ind:AgencyMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:questionsSubmittedCount rdf:type rdf:Property ;
    rdfs:label 'Questions Submitted Count' ;
    rdfs:comment 'The number of formal questions submitted to the health authority in the meeting request or briefing document. Used to track scope and complexity of the meeting agenda.' ;
    rdfs:domain ind:AgencyMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'The date on which the formal meeting request was submitted to the health authority. This is the principal business event timestamp that initiates the regulatory clock for agency response timelines under PDUFA commitments.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryContactEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Contact Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: The regulatory affairs employee accountable for an application lifecycle (IND, NDA, MAA) is tracked for workload management, PDUFA deadline accountability, and inspection readiness. \'regulatory_contac' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acceleratedApproval rdf:type rdf:Property ;
    rdfs:label 'Accelerated Approval' ;
    rdfs:comment 'Indicates whether this application is approved or being reviewed under the FDA Accelerated Approval pathway, based on a surrogate or intermediate clinical endpoint reasonably likely to predict clinical benefit. Requires post-approval confirmatory trials.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agencyCountryCode rdf:type rdf:Property ;
    rdfs:label 'Agency Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the health authority jurisdiction (e.g., USA, GBR, JPN, CAN, AUS). Supports multi-regional dossier tracking and jurisdiction-specific compliance reporting.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualReportLastSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Annual Report Last Submitted Date' ;
    rdfs:comment 'Date the most recent IND Annual Report was submitted to FDA. Used to calculate the next due date and to confirm compliance with 21 CFR 312.33 annual reporting obligations.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Externally assigned application number issued by the health authority (e.g., IND 123456, NDA 210001, BLA 761234, EMA/H/C/004321, CTA-2024-001). This is the official dossier identifier used in all agency correspondence and is the BUSINESS_IDENTIFIER for this entity.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory application. \'active\' = application is open and under review or in use; \'approved\' = marketing authorization or IND in good standing with approval; \'withdrawn\' = sponsor voluntarily withdrew; \'refused\' = agency issued a refuse-to-file or complete response letter with no resubmission; \'on_clinical_hold\' = FDA-issued clinical hold per 21 CFR 312.42; \'inactive\' = IND placed in inactive status.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationType rdf:type rdf:Property ;
    rdfs:label 'Application Type' ;
    rdfs:comment 'Classification of the regulatory application by submission type. IND = Investigational New Drug; NDA = New Drug Application; BLA = Biologics License Application; MAA = Marketing Authorization Application; CTA = Clinical Trial Authorization; IMPD = Investigational Medicinal Product Dossier.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakthroughTherapy rdf:type rdf:Property ;
    rdfs:label 'Breakthrough Therapy' ;
    rdfs:comment 'Indicates whether FDA has granted Breakthrough Therapy Designation (BTD) for this application, enabling intensive FDA guidance and rolling review. Granted when preliminary clinical evidence shows substantial improvement over available therapy for serious conditions.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clinicalHoldDate rdf:type rdf:Property ;
    rdfs:label 'Clinical Hold Date' ;
    rdfs:comment 'Date on which the FDA issued the clinical hold order for this application. Null if no clinical hold has been imposed. Used to track hold duration and response timelines.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clinicalHoldStatus rdf:type rdf:Property ;
    rdfs:label 'Clinical Hold Status' ;
    rdfs:comment 'Current clinical hold status issued by FDA under 21 CFR 312.42. \'none\' = no hold; \'partial\' = hold on specific studies or patient populations; \'full\' = all clinical investigations halted; \'lifted\' = hold previously issued but now removed.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierLanguage rdf:type rdf:Property ;
    rdfs:label 'Dossier Language' ;
    rdfs:comment 'ISO 639-2 three-letter language code of the primary language in which the regulatory dossier is submitted (e.g., ENG for English, JPN for Japanese, DEU for German). Relevant for multi-regional submissions requiring translation.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indAnnualReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Ind Annual Report Due Date' ;
    rdfs:comment 'Next due date for the IND Annual Report submission to FDA, calculated as 60 days before the anniversary of the IND effective date. Tracks compliance with mandatory annual reporting obligations.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:indType rdf:type rdf:Property ;
    rdfs:label 'Ind Type' ;
    rdfs:comment 'Subclassification of the IND by purpose. Commercial IND is sponsor-held for drug development; Research IND is investigator-initiated; Treatment IND allows expanded access; Emergency IND is for single-patient emergency use.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialFilingDate rdf:type rdf:Property ;
    rdfs:label 'Initial Filing Date' ;
    rdfs:comment 'Date the application was first submitted to the health authority. For INDs, this is the date the IND package was received by FDA. For NDAs/BLAs, this is the date of original submission. This is the principal BUSINESS_EVENT_TIMESTAMP for this entity.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadAgency rdf:type rdf:Property ;
    rdfs:label 'Lead Agency' ;
    rdfs:comment 'Primary regulatory health authority to which this application is filed. Determines the regulatory pathway, submission format, and review timelines applicable to this dossier. [ENUM-REF-CANDIDATE: FDA|EMA|PMDA|MHRA|Health Canada|TGA|ANVISA|NMPA|Other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecyclePhase rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Phase' ;
    rdfs:comment 'Current development phase associated with this regulatory application. Tracks the application from pre-IND through post-approval lifecycle. Supports portfolio planning and regulatory strategy alignment. [ENUM-REF-CANDIDATE: pre_ind|phase_1|phase_2|phase_3|nda_bla_maa|post_approval|discontinued — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pdufaGoalDate rdf:type rdf:Property ;
    rdfs:label 'Pdufa Goal Date' ;
    rdfs:comment 'FDA-assigned PDUFA action date by which the agency commits to completing its review of an NDA or BLA. Applicable only to marketing applications under PDUFA. Drives internal milestone planning and commercial readiness timelines.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorityReview rdf:type rdf:Property ;
    rdfs:label 'Priority Review' ;
    rdfs:comment 'Indicates whether the FDA has granted Priority Review designation to this NDA or BLA, reducing the standard review clock from 12 months to 6 months. Applicable to drugs offering major advances in treatment or providing treatment where no adequate therapy exists.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'Classification of the investigational or approved product by modality. Determines the applicable regulatory pathway, CMC requirements, and review division assignment at the agency.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollingReview rdf:type rdf:Property ;
    rdfs:label 'Rolling Review' ;
    rdfs:comment 'Indicates whether the health authority has granted rolling review, allowing submission and review of completed sections of the dossier before the full application is submitted. Applicable under FDA Fast Track and EMA PRIME/rolling review procedures.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionFormat rdf:type rdf:Property ;
    rdfs:label 'Submission Format' ;
    rdfs:comment 'Technical format used for dossier submission to the health authority. eCTD (Electronic Common Technical Document) is the standard for FDA, EMA, PMDA; NeeS (Non-eCTD Electronic Submission) is a transitional format; paper submissions are legacy.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaVaultDossierReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Dossier Reference' ;
    rdfs:comment 'Cross-reference identifier linking this application record to the corresponding eTMF/regulatory dossier in Veeva Vault (the system of record for regulatory submissions and document management). Enables traceability between the lakehouse silver layer and the source system.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalId rdf:type rdf:Property ;
    rdfs:label 'Approval Id' ;
    rdfs:comment 'Primary key for approval' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalAgencyHealthAuthorityId rdf:type rdf:Property ;
    rdfs:label 'Approval Agency Health Authority Id' ;
    rdfs:comment 'FK to regulatory.health_authority' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HealthAuthority .

ind:approvalHealthAuthorityId rdf:type rdf:Property ;
    rdfs:label 'Approval Health Authority Id' ;
    rdfs:comment 'FK to regulatory.health_authority' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HealthAuthority .

ind:primaryApprovalHealthAuthorityId rdf:type rdf:Property ;
    rdfs:label 'Primary Approval Health Authority Id' ;
    rdfs:comment 'Reference to the health authority or regulatory agency (e.g., FDA, EMA, PMDA, MHRA, Health Canada, TGA) that issued this approval decision.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HealthAuthority .

ind:agencyDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Agency Decision Date' ;
    rdfs:comment 'The official date on which the health authority issued its approval decision or authorization. This is the principal real-world event date for the approval transaction, as recorded in the agency approval letter.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agencyDecisionRationale rdf:type rdf:Property ;
    rdfs:label 'Agency Decision Rationale' ;
    rdfs:comment 'Summary of the health authority\'s stated rationale or basis for the approval decision, as documented in the approval letter, assessment report, or public review document. Captures key scientific and regulatory justification.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDose rdf:type rdf:Property ;
    rdfs:label 'Approved Dose' ;
    rdfs:comment 'The approved dose or dose range as specified in the regulatory approval (e.g., \'10 mg once daily\', \'200 mg/m² every 3 weeks\'). Captures the label-approved dosing regimen for the approved indication and population.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedIndication rdf:type rdf:Property ;
    rdfs:label 'Approved Indication' ;
    rdfs:comment 'The specific disease, condition, or therapeutic indication for which the health authority has granted approval. Reflects the exact label language or CTA scope as approved (e.g., \'Treatment of moderate-to-severe plaque psoriasis in adults\').' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedPopulation rdf:type rdf:Property ;
    rdfs:label 'Approved Population' ;
    rdfs:comment 'Description of the patient population covered by the approval, including age group, disease severity, prior treatment requirements, or other eligibility criteria as specified in the approved label or CTA (e.g., \'Adults ≥18 years with inadequate response to prior therapy\').' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugName rdf:type rdf:Property ;
    rdfs:label 'Drug Name' ;
    rdfs:comment 'The International Nonproprietary Name (INN) or brand name of the drug, biologic, or investigational medicinal product covered by this approval. Denormalized for regulatory reporting and label management.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ectdSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Ectd Sequence Number' ;
    rdfs:comment 'The eCTD sequence number of the submission cycle that received this approval decision. Enables direct linkage to the specific eCTD dossier version in Veeva Vault that was reviewed and approved by the agency.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:innCode rdf:type rdf:Property ;
    rdfs:label 'Inn Code' ;
    rdfs:comment 'The WHO-assigned International Nonproprietary Name (INN) code or identifier for the active substance covered by this approval. Supports WHO-DD coding and cross-study drug identification.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbIecReference rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Reference' ;
    rdfs:comment 'Reference number or identifier of the corresponding IRB (Institutional Review Board) or IEC (Independent Ethics Committee) approval associated with this regulatory authorization. Supports ethics and regulatory approval alignment tracking.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConditionalApproval rdf:type rdf:Property ;
    rdfs:label 'Is Conditional Approval' ;
    rdfs:comment 'Indicates whether this approval was granted conditionally (True) or as a full unconditional approval (False). Conditional approvals require the sponsor to fulfill specific post-marketing commitments or confirmatory studies.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRenewalRequired rdf:type rdf:Property ;
    rdfs:label 'Is Renewal Required' ;
    rdfs:comment 'Indicates whether this approval requires periodic renewal or re-authorization (True) or is granted indefinitely (False). Relevant for CTAs, annual IND reports, and time-limited authorizations in certain jurisdictions.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:letterDate rdf:type rdf:Property ;
    rdfs:label 'Letter Date' ;
    rdfs:comment 'The date printed on the official agency approval letter or decision notice. May differ from the agency decision date if the letter was issued after the formal decision was recorded.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:letterReference rdf:type rdf:Property ;
    rdfs:label 'Letter Reference' ;
    rdfs:comment 'Official reference number or document identifier of the agency approval letter or decision notice (e.g., FDA approval letter reference, EMA decision reference). Used to locate the source document in the eTMF or regulatory binder in Veeva Vault.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mahName rdf:type rdf:Property ;
    rdfs:label 'Mah Name' ;
    rdfs:comment 'Legal name of the Marketing Authorization Holder (MAH) as registered with the health authority. May differ from the sponsor name if the MAH is a subsidiary, licensee, or partner organization. Applicable primarily to NDA/BLA/MAA approvals.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postMarketingCommitments rdf:type rdf:Property ;
    rdfs:label 'Post Marketing Commitments' ;
    rdfs:comment 'Description of post-marketing study commitments, confirmatory trials, or pharmacovigilance obligations required by the health authority as a condition of approval. Includes Phase IV studies, REMS, and risk management plans.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolAmendmentVersion rdf:type rdf:Property ;
    rdfs:label 'Protocol Amendment Version' ;
    rdfs:comment 'The version of the study protocol or protocol amendment that was in effect at the time of this approval. Relevant for CTA authorizations and protocol amendment approvals to ensure the correct protocol version is linked.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCtaClinicalTrialAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Parent Cta Clinical Trial Authorization Id' ;
    rdfs:comment 'Reference to the original or preceding CTA record from which this substantial modification, renewal, or extension derives. Enables reconstruction of the full authorization history chain for a trial in a given member state.' ;
    rdfs:domain ind:ClinicalTrialAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClinicalTrialAuthorization .

ind:authorizationDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Date' ;
    rdfs:comment 'Date on which the national competent authority formally granted the Clinical Trial Authorization. This is the principal regulatory event date and the start of the authorized trial period. Corresponds to TRANSACTION_HEADER BUSINESS_EVENT_TIMESTAMP.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationType rdf:type rdf:Property ;
    rdfs:label 'Authorization Type' ;
    rdfs:comment 'Classification of the CTA record by authorization event type: initial authorization, substantial modification (protocol amendment requiring NCA approval), renewal, geographic extension, or withdrawal. Drives workflow and regulatory reporting logic.' ;
    rdfs:domain ind:ClinicalTrialAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsDescription rdf:type rdf:Property ;
    rdfs:label 'Conditions Description' ;
    rdfs:comment 'Narrative description of any conditions, restrictions, or obligations attached to the Clinical Trial Authorization by the national competent authority. Populated only when conditions_attached is True.' ;
    rdfs:domain ind:ClinicalTrialAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Cta Reference Number' ;
    rdfs:comment 'Externally-assigned reference number issued by the national competent authority (NCA) or EU CTIS portal upon authorization of the clinical trial. This is the official business identifier used in all regulatory correspondence and submissions.' ;
    rdfs:domain ind:ClinicalTrialAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctdSectionReference rdf:type rdf:Property ;
    rdfs:label 'Ctd Section Reference' ;
    rdfs:comment 'Reference to the relevant Common Technical Document (CTD) or eCTD dossier section submitted in support of this CTA application (e.g., Module 5 clinical study reports). Supports regulatory dossier traceability.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctisTrialNumber rdf:type rdf:Property ;
    rdfs:label 'Ctis Trial Number' ;
    rdfs:comment 'Unique trial identifier assigned within the EU Clinical Trials Information System (CTIS) under EU CTR 536/2014. Used for multi-country EU submissions and authorization tracking via the centralized CTIS portal.' ;
    rdfs:domain ind:ClinicalTrialAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicsCommitteeOpinion rdf:type rdf:Property ;
    rdfs:label 'Ethics Committee Opinion' ;
    rdfs:comment 'Outcome of the ethics committee (IRB/IEC) review associated with this CTA in the member state. Tracks whether a favorable opinion was obtained, which is a prerequisite for trial commencement in most jurisdictions.' ;
    rdfs:domain ind:ClinicalTrialAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicsOpinionDate rdf:type rdf:Property ;
    rdfs:label 'Ethics Opinion Date' ;
    rdfs:comment 'Date on which the ethics committee (IRB/IEC) issued its opinion for this CTA in the member state. Used to confirm that ethics approval preceded trial commencement and to track parallel review timelines.' ;
    rdfs:domain ind:ClinicalTrialAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprDataTransferMechanism rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Transfer Mechanism' ;
    rdfs:comment 'Legal mechanism under GDPR used to authorize the transfer of personal data of EU trial subjects to non-EU countries in connection with this CTA. Required for EU-based trials involving cross-border data flows.' ;
    rdfs:domain ind:ClinicalTrialAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberStateCode rdf:type rdf:Property ;
    rdfs:label 'Member State Code' ;
    rdfs:comment 'ISO 3166-1 alpha-2 or alpha-3 country code of the EU member state or non-EU country in which this Clinical Trial Authorization was granted by the national competent authority. Enables multi-country authorization tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modificationScope rdf:type rdf:Property ;
    rdfs:label 'Modification Scope' ;
    rdfs:comment 'Brief description of the scope of the substantial modification covered by this CTA record (e.g., protocol amendment, IMP change, new investigational site addition, safety update). Populated for substantial_modification authorization types.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalPortalReference rdf:type rdf:Property ;
    rdfs:label 'National Portal Reference' ;
    rdfs:comment 'Reference number or identifier assigned by the national regulatory portal (e.g., MHRA IRAS number, BfArM reference, ANSM reference, Health Canada CTD number) for this CTA. Complements the CTIS trial ID for country-specific tracking.' ;
    rdfs:domain ind:ClinicalTrialAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substantialModificationNumber rdf:type rdf:Property ;
    rdfs:label 'Substantial Modification Number' ;
    rdfs:comment 'Sequential identifier for substantial modifications to the original CTA, as assigned by the sponsor or NCA. Populated only for authorization_type = substantial_modification. Enables tracking of the amendment history chain.' ;
    rdfs:domain ind:ClinicalTrialAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialPhase rdf:type rdf:Property ;
    rdfs:label 'Trial Phase' ;
    rdfs:comment 'Regulatory phase of the clinical trial covered by this authorization (Phase I through Phase IV), as defined by ICH E8 and applicable NCA guidelines. Determines applicable regulatory requirements, safety reporting thresholds, and monitoring intensity. [ENUM-REF-CANDIDATE: Phase I|Phase I/II|Phase II|Phase IIa|Phase IIb|Phase III|Phase III/IV|Phase IV — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrialAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentId rdf:type rdf:Property ;
    rdfs:label 'Commitment Id' ;
    rdfs:comment 'Primary key for commitment' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceleratedApprovalCondition rdf:type rdf:Property ;
    rdfs:label 'Accelerated Approval Condition' ;
    rdfs:comment 'Indicates whether this commitment is a confirmatory trial required as a condition of accelerated approval (True) or a standard post-approval commitment (False). Accelerated approval conditions carry heightened regulatory scrutiny.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agencyCommitmentNumber rdf:type rdf:Property ;
    rdfs:label 'Agency Commitment Number' ;
    rdfs:comment 'The official commitment or post-marketing requirement number assigned by the health authority (e.g., FDA PMR/PMC number, EMA obligation number) at the time of approval. Used for regulatory correspondence and agency tracking.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:associatedProtocolNumber rdf:type rdf:Property ;
    rdfs:label 'Associated Protocol Number' ;
    rdfs:comment 'The clinical study protocol number associated with the post-marketing study or confirmatory trial being conducted to fulfill this commitment. Enables traceability to the study protocol.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentCategory rdf:type rdf:Property ;
    rdfs:label 'Commitment Category' ;
    rdfs:comment 'Regulatory category distinguishing legally binding Post-Marketing Requirements (PMR) mandated by the FDA versus voluntary Post-Marketing Commitments (PMC), or conditions of approval imposed by other agencies such as EMA or PMDA.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferralReason rdf:type rdf:Property ;
    rdfs:label 'Deferral Reason' ;
    rdfs:comment 'Narrative explanation for any agency-approved deferral or extension of the commitment due date. Documents the justification submitted to and accepted by the health authority.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBinding rdf:type rdf:Property ;
    rdfs:label 'Is Binding' ;
    rdfs:comment 'Indicates whether this commitment is legally binding (True = Post-Marketing Requirement mandated by law, e.g., FDA PMR under FDAAA) or voluntary (False = Post-Marketing Commitment, e.g., FDA PMC). Critical for prioritization and enforcement risk assessment.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPediatric rdf:type rdf:Property ;
    rdfs:label 'Is Pediatric' ;
    rdfs:comment 'Indicates whether this commitment involves a pediatric study required under the Pediatric Research Equity Act (PREA) or EMA Paediatric Regulation. Enables filtering and reporting on pediatric obligations.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReportSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Last Report Submitted Date' ;
    rdfs:comment 'The date on which the most recent progress report or status update for this commitment was submitted to the health authority. Used to calculate next reporting due date.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneDate rdf:type rdf:Property ;
    rdfs:label 'Milestone Date' ;
    rdfs:comment 'The date on which the most recent commitment milestone was achieved or is targeted. Used in conjunction with milestone_description to track incremental progress toward fulfillment.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Report Due Date' ;
    rdfs:comment 'The date by which the next scheduled progress report or status update on this commitment must be submitted to the health authority. Calculated based on reporting frequency and last submission date.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalDueDate rdf:type rdf:Property ;
    rdfs:label 'Original Due Date' ;
    rdfs:comment 'The initial due date as specified in the original approval letter or agency decision, before any agency-approved extensions or deferrals. Preserved for audit trail and compliance tracking.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseReason rdf:type rdf:Property ;
    rdfs:label 'Release Reason' ;
    rdfs:comment 'Narrative explanation for why the health authority released or waived this commitment (e.g., scientific evidence no longer supports the requirement, alternative data satisfied the obligation). Populated only when commitment_status is released.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remsProgramName rdf:type rdf:Property ;
    rdfs:label 'Rems Program Name' ;
    rdfs:comment 'Name of the FDA-required Risk Evaluation and Mitigation Strategy (REMS) program associated with this commitment, if the commitment type is REMS. Null for non-REMS commitments.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'The frequency at which progress updates or status reports on this commitment must be submitted to the health authority (e.g., annual, semi-annual, quarterly, one-time final report). Drives scheduling of regulatory submissions.' ;
    rdfs:domain ind:Commitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondenceId rdf:type rdf:Property ;
    rdfs:label 'Correspondence Id' ;
    rdfs:comment 'Primary key for correspondence' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relatedCorrespondenceId rdf:type rdf:Property ;
    rdfs:label 'Related Correspondence Id' ;
    rdfs:comment 'Self-referencing identifier linking this correspondence to a prior or related correspondence record (e.g., a response linked to the original information request, or a follow-up linked to a meeting minutes record). Enables correspondence thread tracking.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Correspondence .

ind:agencyReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Agency Reference Number' ;
    rdfs:comment 'The official reference number assigned by the health authority (FDA, EMA, PMDA, MHRA, Health Canada) to this correspondence or the associated submission. Used for tracking agency-side docket and regulatory intelligence.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Clinical Hold Flag' ;
    rdfs:comment 'Indicates whether this correspondence is associated with an FDA clinical hold order (full or partial) under 21 CFR Part 312.42. When True, triggers immediate escalation and study suspension workflows.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correspondenceNumber rdf:type rdf:Property ;
    rdfs:label 'Correspondence Number' ;
    rdfs:comment 'Internally assigned unique reference number for this correspondence record, used for tracking and cross-referencing within the CTMS and eTMF (e.g., CORR-2024-00123). Serves as the business identifier for audit trails.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctdSection rdf:type rdf:Property ;
    rdfs:label 'Ctd Section' ;
    rdfs:comment 'The CTD/eCTD dossier section to which this correspondence relates (e.g., Module 2.7.4 Summary of Clinical Safety, Module 5.3.5 Reports of Controlled Clinical Studies). Enables dossier-level regulatory intelligence.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Response Required Flag' ;
    rdfs:comment 'Indicates whether a formal response to the health authority is required for this correspondence. When True, activates response tracking, due date monitoring, and escalation workflows.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Response Submitted Flag' ;
    rdfs:comment 'Indicates whether the required response has been submitted to the health authority. Used in conjunction with response_required_flag and response_due_date for compliance monitoring and inspection readiness.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subjectMatter rdf:type rdf:Property ;
    rdfs:label 'Subject Matter' ;
    rdfs:comment 'Free-text or structured description of the primary subject or topic of the correspondence (e.g., \'Protocol Amendment Review\', \'Clinical Hold Notification\', \'Safety Data Request\'). Used for regulatory intelligence and search.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmissionMethod rdf:type rdf:Property ;
    rdfs:label 'Transmission Method' ;
    rdfs:comment 'The method by which the correspondence was transmitted to or received from the health authority (eCTD electronic submission gateway, email, fax, postal mail, hand delivery). Required for audit trail and ALCOA+ compliance.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Country Registration Id' ;
    rdfs:comment 'Unique surrogate identifier for each country-level product registration record in the regulatory lakehouse silver layer.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CountryRegistration .

ind:annualReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Annual Report Due Date' ;
    rdfs:comment 'Next due date for the periodic safety update report (PSUR), development safety update report (DSUR), or annual product report required by the health authority in this country to maintain the registration.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conditionalApproval rdf:type rdf:Property ;
    rdfs:label 'Conditional Approval' ;
    rdfs:comment 'Indicates whether this registration was granted under conditional or accelerated approval, requiring post-marketing confirmatory studies or commitments. True if conditional approval conditions are still outstanding.' ;
    rdfs:domain ind:CountryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ctdModuleScope rdf:type rdf:Property ;
    rdfs:label 'Ctd Module Scope' ;
    rdfs:comment 'Scope of the Common Technical Document (CTD) dossier submitted for this registration: full (complete Modules 1-5), abridged (generic/hybrid referencing originator data), hybrid (mixed), or bibliographic (literature-based). Determines the regulatory review pathway.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierFormat rdf:type rdf:Property ;
    rdfs:label 'Dossier Format' ;
    rdfs:comment 'Format of the regulatory dossier submitted for this registration: eCTD (Electronic Common Technical Document), NeeS (Non-eCTD Electronic Submission), paper, or VNeeS (Veterinary NeeS). Determines submission and archival requirements.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAnnualReportDate rdf:type rdf:Property ;
    rdfs:label 'Last Annual Report Date' ;
    rdfs:comment 'Date on which the most recent annual product report, PSUR, or equivalent periodic safety report was submitted to the health authority for this country registration.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Last Renewal Date' ;
    rdfs:comment 'Date on which the most recent registration renewal was granted by the health authority. Establishes the start of the current registration period for expiry and renewal due date calculations.' ;
    rdfs:domain ind:CountryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastVariationDate rdf:type rdf:Property ;
    rdfs:label 'Last Variation Date' ;
    rdfs:comment 'Date of the most recently approved post-approval variation or amendment to this country registration. Used to track the currency of the approved dossier and labeling.' ;
    rdfs:domain ind:CountryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:localAgentContact rdf:type rdf:Property ;
    rdfs:label 'Local Agent Contact' ;
    rdfs:comment 'Primary contact details (phone, email, or address) for the local regulatory agent or marketing authorization holder in the registered country. Used for regulatory correspondence and inspection coordination.' ;
    rdfs:domain ind:CountryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localAgentName rdf:type rdf:Property ;
    rdfs:label 'Local Agent Name' ;
    rdfs:comment 'Name of the local regulatory agent, marketing authorization holder (MAH), or in-country representative responsible for maintaining the registration and liaising with the national health authority. Required in many jurisdictions for foreign sponsors.' ;
    rdfs:domain ind:CountryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketExclusivityExpiry rdf:type rdf:Property ;
    rdfs:label 'Market Exclusivity Expiry' ;
    rdfs:comment 'Date on which the data exclusivity or market exclusivity period expires in this country, after which generic or biosimilar applications may reference the originator dossier. Critical for lifecycle and competitive intelligence planning.' ;
    rdfs:domain ind:CountryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:patentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Patent Expiry Date' ;
    rdfs:comment 'Date on which the primary product patent expires in this country. Used in conjunction with market exclusivity for lifecycle management and generic entry forecasting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Date on which the health authority formally granted or issued the product registration or marketing authorization. Represents the effective start of the registration.' ;
    rdfs:domain ind:CountryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current lifecycle status of the country registration: active (valid and in force), expired (past expiry date without renewal), suspended (temporarily halted by authority), withdrawn (voluntarily or involuntarily removed), pending (application submitted, awaiting decision), cancelled (application withdrawn before approval).' ;
    rdfs:domain ind:CountryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationType rdf:type rdf:Property ;
    rdfs:label 'Registration Type' ;
    rdfs:comment 'Classification of the regulatory procedure used to obtain this registration: national (single-country), mutual recognition (MRP), decentralized (DCP), centralized (EMA), or bilateral agreement. [ENUM-REF-CANDIDATE: national|mutual_recognition|decentralized|centralized|bilateral|abridged|hybrid — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:CountryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryProcedureNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Procedure Number' ;
    rdfs:comment 'Procedure number assigned by the health authority for the specific regulatory review procedure (e.g., EMA centralized procedure number EMEA/H/C/XXXXXX, MRP/DCP reference number). Distinct from the final registration number.' ;
    rdfs:domain ind:CountryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementStatus rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Status' ;
    rdfs:comment 'Current reimbursement or health technology assessment (HTA) status of the registered product in this country. Indicates whether the product is covered by national health insurance or payer systems, supporting market access planning.' ;
    rdfs:domain ind:CountryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Submission Date' ;
    rdfs:comment 'Actual date on which the renewal application was submitted to the health authority. Used to confirm timely submission relative to the renewal due date.' ;
    rdfs:domain ind:CountryRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:strength rdf:type rdf:Property ;
    rdfs:label 'Strength' ;
    rdfs:comment 'Approved strength or concentration of the active substance as registered in this country (e.g., 10 mg, 100 mg/mL, 500 mg/5 mL). Expressed as a free-text string to accommodate varied unit formats across jurisdictions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionLanguage rdf:type rdf:Property ;
    rdfs:label 'Submission Language' ;
    rdfs:comment 'ISO 639-1/639-2 language code of the primary language in which the registration dossier was submitted to the health authority (e.g., en, fr, de, ja). Relevant for translation management and local labeling compliance.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctdDossierId rdf:type rdf:Property ;
    rdfs:label 'Ctd Dossier Id' ;
    rdfs:comment 'Unique system-generated identifier for the CTD dossier record. Primary key for this entity.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CtdDossier .

ind:actualSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Submission Date' ;
    rdfs:comment 'Date on which the CTD dossier was actually submitted to the regulatory agency. Null until submission occurs.' ;
    rdfs:domain ind:CtdDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ctdFormat rdf:type rdf:Property ;
    rdfs:label 'Ctd Format' ;
    rdfs:comment 'Submission format of the CTD dossier. eCTD (Electronic Common Technical Document) is the standard for FDA, EMA, and PMDA. NeeS (Non-eCTD Electronic Submission) and paper formats are legacy options.' ;
    rdfs:domain ind:CtdDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierNumber rdf:type rdf:Property ;
    rdfs:label 'Dossier Number' ;
    rdfs:comment 'Externally-known unique business identifier for the CTD dossier, used in regulatory correspondence and Veeva Vault tracking. Format: CTD-{AppCode}-{Year}-{Seq}.' ;
    rdfs:domain ind:CtdDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierStatus rdf:type rdf:Property ;
    rdfs:label 'Dossier Status' ;
    rdfs:comment 'Current lifecycle status of the CTD dossier. Tracks progression from authoring through regulatory submission and archival.' ;
    rdfs:domain ind:CtdDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierTitle rdf:type rdf:Property ;
    rdfs:label 'Dossier Title' ;
    rdfs:comment 'Human-readable title of the CTD dossier, typically including the drug name, application type, and submission sequence (e.g., \'DrugX NDA Initial Submission CTD Dossier\').' ;
    rdfs:domain ind:CtdDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierType rdf:type rdf:Property ;
    rdfs:label 'Dossier Type' ;
    rdfs:comment 'Classification of the dossier submission type. Initial submissions establish the application; amendments and supplements update specific modules; annual reports fulfill periodic reporting obligations.' ;
    rdfs:domain ind:CtdDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierVersion rdf:type rdf:Property ;
    rdfs:label 'Dossier Version' ;
    rdfs:comment 'Version number of the CTD dossier (e.g., 1.0, 2.1). Incremented with each major revision or amendment cycle.' ;
    rdfs:domain ind:CtdDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dtdVersion rdf:type rdf:Property ;
    rdfs:label 'Dtd Version' ;
    rdfs:comment 'Version of the eCTD Document Type Definition (DTD) or XML schema used for the dossier backbone (e.g., 3.2.2 for FDA, 4.0 for EMA). Determines structural compliance requirements.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapAnalysisDate rdf:type rdf:Property ;
    rdfs:label 'Gap Analysis Date' ;
    rdfs:comment 'Date on which the most recent dossier gap analysis was completed. Used to assess the currency of the gap analysis relative to dossier updates.' ;
    rdfs:domain ind:CtdDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gapAnalysisStatus rdf:type rdf:Property ;
    rdfs:label 'Gap Analysis Status' ;
    rdfs:comment 'Status of the formal gap analysis conducted to identify missing or incomplete content units within the CTD dossier prior to submission.' ;
    rdfs:domain ind:CtdDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCompiledDate rdf:type rdf:Property ;
    rdfs:label 'Last Compiled Date' ;
    rdfs:comment 'Date on which the CTD dossier was most recently compiled and packaged for submission or review. Tracks the currency of the assembled dossier.' ;
    rdfs:domain ind:CtdDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:module1Status rdf:type rdf:Property ;
    rdfs:label 'Module1 Status' ;
    rdfs:comment 'Completeness status of CTD Module 1 (Regional Administrative Information), which contains region-specific forms, cover letters, and labeling. Content varies by target agency.' ;
    rdfs:domain ind:CtdDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:module2Status rdf:type rdf:Property ;
    rdfs:label 'Module2 Status' ;
    rdfs:comment 'Completeness status of CTD Module 2 (CTD Summaries), including the Quality Overall Summary (QOS), Nonclinical Overview, Clinical Overview, Nonclinical Written and Tabulated Summaries, and Clinical Summary.' ;
    rdfs:domain ind:CtdDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:module3Status rdf:type rdf:Property ;
    rdfs:label 'Module3 Status' ;
    rdfs:comment 'Completeness status of CTD Module 3 (Quality), covering drug substance, drug product, and related quality documentation per ICH M4Q.' ;
    rdfs:domain ind:CtdDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:module4Status rdf:type rdf:Property ;
    rdfs:label 'Module4 Status' ;
    rdfs:comment 'Completeness status of CTD Module 4 (Nonclinical Study Reports), including pharmacology, pharmacokinetics, and toxicology study reports per ICH M4S.' ;
    rdfs:domain ind:CtdDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:module5Status rdf:type rdf:Property ;
    rdfs:label 'Module5 Status' ;
    rdfs:comment 'Completeness status of CTD Module 5 (Clinical Study Reports), including all clinical pharmacology, efficacy, and safety study reports per ICH M4E.' ;
    rdfs:domain ind:CtdDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openGapCount rdf:type rdf:Property ;
    rdfs:label 'Open Gap Count' ;
    rdfs:comment 'Number of identified content gaps (missing or incomplete documents/sections) that remain unresolved in the current dossier version. Key metric for submission readiness.' ;
    rdfs:domain ind:CtdDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallCompletenessStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Completeness Status' ;
    rdfs:comment 'Aggregate readiness assessment of the entire CTD dossier across all five modules. Used for dossier gap analysis and submission readiness reviews.' ;
    rdfs:domain ind:CtdDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorSubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Prior Submission Reference' ;
    rdfs:comment 'Reference number of the prior submission or dossier version that this submission amends or supplements. Enables lineage tracking across submission cycles.' ;
    rdfs:domain ind:CtdDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishingTool rdf:type rdf:Property ;
    rdfs:label 'Publishing Tool' ;
    rdfs:comment 'Name and version of the publishing software used to compile and validate the eCTD dossier (e.g., Lorenz docuBridge, Extedo eCTD Manager, Veeva Vault RIM Publisher). Critical for reproducibility and troubleshooting.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishingToolVersion rdf:type rdf:Property ;
    rdfs:label 'Publishing Tool Version' ;
    rdfs:comment 'Version number of the publishing tool used to compile this dossier. Required for audit trail and reproducibility of the eCTD package.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Total Document Count' ;
    rdfs:comment 'Total number of individual content units (documents, datasets, study reports) included in this CTD dossier version. Used for completeness tracking and submission package verification.' ;
    rdfs:domain ind:CtdDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationReportDate rdf:type rdf:Property ;
    rdfs:label 'Validation Report Date' ;
    rdfs:comment 'Date on which the most recent eCTD technical validation report was generated for this dossier.' ;
    rdfs:domain ind:CtdDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationReportStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Report Status' ;
    rdfs:comment 'Status of the eCTD technical validation report generated by the publishing tool. Agencies require a passing validation report before accepting eCTD submissions.' ;
    rdfs:domain ind:CtdDossier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyCode rdf:type rdf:Property ;
    rdfs:label 'Agency Code' ;
    rdfs:comment 'Short, standardized alphanumeric code uniquely identifying the health authority (e.g., FDA, EMA, PMDA, MHRA, HC, TGA, ANVISA, NMPA). Used as a business key in regulatory workflows, submission routing, and eCTD gateway configuration.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyStatus rdf:type rdf:Property ;
    rdfs:label 'Agency Status' ;
    rdfs:comment 'Current operational lifecycle status of the health authority record. Active indicates the agency is currently accepting submissions; inactive indicates it is no longer operational; merged indicates it has been absorbed into another agency; superseded indicates it has been replaced by a successor body.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualSafetyReportType rdf:type rdf:Property ;
    rdfs:label 'Annual Safety Report Type' ;
    rdfs:comment 'Type of periodic safety report required by this health authority for ongoing clinical trials (e.g., DSUR - Development Safety Update Report per ICH E2F for EMA/MHRA, IND Annual Report per 21 CFR 312.33 for FDA, PBRER for post-marketing). Drives safety reporting schedule configuration.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityType rdf:type rdf:Property ;
    rdfs:label 'Authority Type' ;
    rdfs:comment 'Classification of the health authority by its jurisdictional scope: national (single country, e.g., FDA, PMDA), supranational (multi-country, e.g., EMA), regional (sub-national or regional body), or reference_agency (recognized reference authority used by other agencies for reliance procedures).' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalTrialRegistryRequired rdf:type rdf:Property ;
    rdfs:label 'Clinical Trial Registry Required' ;
    rdfs:comment 'Indicates whether the health authority requires mandatory registration of clinical trials in a public registry (e.g., ClinicalTrials.gov for FDA, EU Clinical Trials Register for EMA, JAPIC for PMDA) as a condition of authorization or publication. Drives trial registration workflow in CTMS.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactDivisionName rdf:type rdf:Property ;
    rdfs:label 'Contact Division Name' ;
    rdfs:comment 'Name of the primary regulatory division or office within the health authority responsible for receiving submissions and correspondence for the sponsor\'s therapeutic area (e.g., FDA CDER Office of New Drugs, EMA Human Medicines Division, PMDA New Drug Division). Used to address regulatory correspondence and meeting requests.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctdFormatRequired rdf:type rdf:Property ;
    rdfs:label 'Ctd Format Required' ;
    rdfs:comment 'Indicates whether the health authority mandates submission of dossiers in the ICH Common Technical Document (CTD) format. True for ICH member agencies (FDA, EMA, PMDA, MHRA, Health Canada); may be false for non-ICH jurisdictions with proprietary submission formats.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ectdGatewayCode rdf:type rdf:Property ;
    rdfs:label 'Ectd Gateway Code' ;
    rdfs:comment 'Unique identifier assigned to the health authority\'s eCTD submission gateway endpoint (e.g., FDA ESG sender ID, EMA DUNS number for eSubmission). Required for configuring automated eCTD transmission via Veeva Vault and validating submission acknowledgement receipts.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ectdSpecificationVersion rdf:type rdf:Property ;
    rdfs:label 'Ectd Specification Version' ;
    rdfs:comment 'Version of the eCTD technical specification required by this health authority for electronic submissions (e.g., 3.2.2, 4.0). Governs the XML backbone structure, validation criteria, and submission package format for IND, NDA, BLA, and MAA applications.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicSubmissionRequired rdf:type rdf:Property ;
    rdfs:label 'Electronic Submission Required' ;
    rdfs:comment 'Indicates whether the health authority mandates electronic submission (eCTD or equivalent) for regulatory applications. True for FDA, EMA, PMDA, MHRA; may be false for agencies still accepting paper or hybrid submissions. Governs Veeva Vault submission package configuration.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeScheduleEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule Effective Date' ;
    rdfs:comment 'Date from which the current regulatory fee schedule for this health authority is effective. Fee schedules are typically updated annually (e.g., FDA PDUFA fees effective October 1 each fiscal year). Used to ensure correct fee amounts are applied in SAP S/4HANA budget planning.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Complete official name of the health authority organization (e.g., U.S. Food and Drug Administration, European Medicines Agency, Pharmaceuticals and Medical Devices Agency). Used in regulatory correspondence, submission cover letters, and CTD/eCTD dossier headers.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gcpGuidelineVersion rdf:type rdf:Property ;
    rdfs:label 'Gcp Guideline Version' ;
    rdfs:comment 'Version of the GCP guideline mandated or recognized by this health authority (e.g., ICH E6(R2), ICH E6(R3), EU CTR GCP Annex). Governs clinical trial conduct standards, monitoring requirements, and inspection readiness criteria applicable to studies submitted to this agency.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ichMember rdf:type rdf:Property ;
    rdfs:label 'Ich Member' ;
    rdfs:comment 'Indicates whether the health authority is a full member or observer of the International Council for Harmonisation of Technical Requirements for Pharmaceuticals for Human Use (ICH). ICH membership determines applicability of harmonized guidelines (CTD, eCTD, GCP, safety reporting) and mutual recognition procedures.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:indApplicationType rdf:type rdf:Property ;
    rdfs:label 'Ind Application Type' ;
    rdfs:comment 'Local equivalent application type for initiating clinical trials under this health authority\'s jurisdiction (e.g., IND for FDA, CTA for EMA/MHRA/Health Canada, JIND for PMDA, CTN for TGA). Drives submission template selection and regulatory timeline planning. [ENUM-REF-CANDIDATE: IND|CTA|JIND|CTN|ANVISA_CTA|NMPA_IND — promote to reference product]' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indReviewClockDays rdf:type rdf:Property ;
    rdfs:label 'Ind Review Clock Days' ;
    rdfs:comment 'Number of calendar days the health authority has to review and respond to a clinical trial authorization application before the sponsor may proceed (e.g., 30 days for FDA IND, 30 days for EMA CTA under EU CTR). Critical for study start-up timeline planning.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indSubmissionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Ind Submission Fee Amount' ;
    rdfs:comment 'Standard regulatory fee amount charged by this health authority for an IND or CTA application in the currency specified by submission_fee_currency. May be zero for agencies that do not charge IND/CTA fees (e.g., FDA does not charge IND fees). Used for regulatory budget planning.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localLanguageRequired rdf:type rdf:Property ;
    rdfs:label 'Local Language Required' ;
    rdfs:comment 'Indicates whether the health authority requires submission documents (or portions thereof) to be translated into the local national language in addition to English. True for agencies such as PMDA (Japanese), NMPA (Chinese), ANVISA (Portuguese). Drives translation cost and timeline planning.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mutualRecognitionAgreements rdf:type rdf:Property ;
    rdfs:label 'Mutual Recognition Agreements' ;
    rdfs:comment 'Comma-separated list of mutual recognition agreement frameworks in which this health authority participates (e.g., FDA-EMA Parallel Scientific Advice, MHRA-EMA MRA, ACSS - Australia-Canada-Singapore-Switzerland). Informs regulatory reliance strategy and submission optimization.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaApplicationType rdf:type rdf:Property ;
    rdfs:label 'Nda Application Type' ;
    rdfs:comment 'Local equivalent marketing authorization application type for this health authority (e.g., NDA/BLA for FDA, MAA for EMA, J-NDA for PMDA, ANDS for Health Canada). Used to configure submission workflows, fee schedules, and review clock tracking in Veeva Vault. [ENUM-REF-CANDIDATE: NDA|BLA|MAA|J-NDA|ANDS|ARTG — promote to reference product]' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaSubmissionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Nda Submission Fee Amount' ;
    rdfs:comment 'Standard regulatory submission fee amount charged by this health authority for a full marketing authorization application (NDA/BLA/MAA) in the currency specified by submission_fee_currency. Used for regulatory budget planning and SAP S/4HANA accounts payable. Updated annually per agency fee schedules.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nonFatalSadrReportingClockHours rdf:type rdf:Property ;
    rdfs:label 'Non Fatal Sadr Reporting Clock Hours' ;
    rdfs:comment 'Mandatory expedited safety reporting timeline in hours for non-fatal, non-life-threatening SUSARs to this health authority (e.g., 15 calendar days / 360 hours for FDA and EMA). Used alongside the fatal SUSAR clock to configure Oracle Argus Safety reporting deadlines.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paperSubmissionAccepted rdf:type rdf:Property ;
    rdfs:label 'Paper Submission Accepted' ;
    rdfs:comment 'Indicates whether the health authority still accepts paper-based regulatory submissions as an alternative or supplement to electronic submissions. Relevant for agencies in transition to full eCTD mandates or for specific submission types (e.g., original INDs, amendments).' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityReviewClockDays rdf:type rdf:Property ;
    rdfs:label 'Priority Review Clock Days' ;
    rdfs:comment 'Number of calendar days in the expedited or priority review clock for marketing authorization applications under this health authority (e.g., 180 days for FDA priority NDA review, 150 days for EMA accelerated assessment). Supports regulatory strategy planning for breakthrough and priority designations.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewProcedureType rdf:type rdf:Property ;
    rdfs:label 'Review Procedure Type' ;
    rdfs:comment 'Primary review procedure applicable under this health authority (e.g., Standard Review, Priority Review, Accelerated Assessment, Breakthrough Therapy, PRIME, Conditional Approval, Orphan Drug). Determines review timelines and regulatory strategy. [ENUM-REF-CANDIDATE: standard|priority|accelerated|breakthrough|prime|conditional|orphan — promote to reference product]' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sadrReportingClockHours rdf:type rdf:Property ;
    rdfs:label 'Sadr Reporting Clock Hours' ;
    rdfs:comment 'Mandatory expedited safety reporting timeline in hours for fatal or life-threatening SUSARs to this health authority (e.g., 7 calendar days / 168 hours for FDA, 7 days for EMA). Drives automated deadline calculation in Oracle Argus Safety for SUSAR and ICSR submissions.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardReviewClockDays rdf:type rdf:Property ;
    rdfs:label 'Standard Review Clock Days' ;
    rdfs:comment 'Number of calendar days in the standard regulatory review clock for marketing authorization applications under this health authority (e.g., 365 days for FDA standard NDA review, 210 days for EMA MAA). Used for regulatory milestone planning and submission timeline modeling.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Submission Fee Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for regulatory submission fees charged by this health authority (e.g., USD for FDA PDUFA fees, EUR for EMA fees, JPY for PMDA fees). Used in SAP S/4HANA for regulatory fee budget planning and accounts payable processing.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialRegistryName rdf:type rdf:Property ;
    rdfs:label 'Trial Registry Name' ;
    rdfs:comment 'Name of the primary public clinical trial registry mandated by this health authority for trial registration (e.g., ClinicalTrials.gov for FDA, EU Clinical Trials Register for EMA, JAPIC CTI for PMDA, ANZCTR for TGA). Used to configure trial registration workflows in Oracle Siebel CTMS.' ;
    rdfs:domain ind:HealthAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentApplicationId rdf:type rdf:Property ;
    rdfs:label 'Parent Application Id' ;
    rdfs:comment 'Reference to the parent regulatory application record when this IND is a sub-application or cross-references a master NDA/BLA/MAA application. Enables hierarchical navigation of the regulatory application portfolio.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Application .

ind:responsibleRegulatoryLeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Regulatory Lead Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: The regulatory lead managing an IND is accountable for annual reports, clinical hold responses, and protocol submissions. IND lifecycle management requires a traceable workforce employee. \'responsible' ;
    rdfs:domain ind:IndApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'The cumulative number of IND amendments (protocol amendments, information amendments, safety reports) submitted to the FDA under this IND. Tracks the volume of regulatory activity and dossier complexity.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Application Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction in which this application is filed (e.g., USA for FDA, GBR for MHRA, JPN for PMDA). Enables multi-country regulatory portfolio analytics.' ;
    rdfs:domain ind:IndApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalHoldLiftedDate rdf:type rdf:Property ;
    rdfs:label 'Clinical Hold Lifted Date' ;
    rdfs:comment 'The date on which the FDA lifted the clinical hold and authorized resumption of clinical trials under this IND. Nullable for INDs that have never been on clinical hold or where the hold remains active.' ;
    rdfs:domain ind:IndApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clinicalHoldReason rdf:type rdf:Property ;
    rdfs:label 'Clinical Hold Reason' ;
    rdfs:comment 'Description of the FDA\'s stated reason for imposing a clinical hold on this IND. Captures the safety concern, protocol deficiency, or regulatory non-compliance issue cited by the agency. Nullable for INDs not on clinical hold.' ;
    rdfs:domain ind:IndApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugSubstanceName rdf:type rdf:Property ;
    rdfs:label 'Drug Substance Name' ;
    rdfs:comment 'International Nonproprietary Name (INN) or chemical name of the active pharmaceutical ingredient (API) covered under this IND. Used for regulatory cross-referencing and WHO-DD coding.' ;
    rdfs:domain ind:IndApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ectdSubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Ectd Submission Flag' ;
    rdfs:comment 'Indicates whether this IND application is submitted in eCTD format via the FDA Electronic Submissions Gateway. True indicates eCTD format; False indicates paper or non-eCTD electronic submission. FDA mandates eCTD for most IND submissions.' ;
    rdfs:domain ind:IndApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equivalentApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Equivalent Application Number' ;
    rdfs:comment 'The application number assigned by a non-FDA regulatory agency for an equivalent authorization (e.g., EMA CTA number, MHRA CTA reference, PMDA CTN). Used to cross-reference the IND with parallel international submissions.' ;
    rdfs:domain ind:IndApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaApplicationReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Fda Application Receipt Date' ;
    rdfs:comment 'The date on which the FDA officially acknowledged receipt of the IND application. Starts the 30-day review clock per 21 CFR Part 312.40. May differ from the initial submission date if there were transmission delays.' ;
    rdfs:domain ind:IndApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fdaDivision rdf:type rdf:Property ;
    rdfs:label 'Fda Division' ;
    rdfs:comment 'The FDA Center and Division responsible for reviewing this IND application (e.g., CDER/Division of Oncology Products 1, CBER/Division of Vaccines). Determines the regulatory review team and applicable FDA guidance documents.' ;
    rdfs:domain ind:IndApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inactivationDate rdf:type rdf:Property ;
    rdfs:label 'Inactivation Date' ;
    rdfs:comment 'The date on which the IND was placed into inactive status, either by sponsor notification or FDA action. Nullable for active INDs. Represents the EFFECTIVE_UNTIL boundary for the active IND period.' ;
    rdfs:domain ind:IndApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:indSerialNumberLatest rdf:type rdf:Property ;
    rdfs:label 'Ind Serial Number Latest' ;
    rdfs:comment 'The most recent serial number assigned to the latest IND submission sequence (original or amendment). IND submissions are numbered sequentially starting from 0000. Used to track the current version of the IND dossier in Veeva Vault eTMF.' ;
    rdfs:domain ind:IndApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Initial Submission Date' ;
    rdfs:comment 'The date on which the original IND application was first submitted to the FDA. This is the principal business event date for the IND lifecycle and triggers the 30-day FDA review clock per 21 CFR Part 312.40.' ;
    rdfs:domain ind:IndApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationalProductCode rdf:type rdf:Property ;
    rdfs:label 'Investigational Product Code' ;
    rdfs:comment 'Internal sponsor code or development compound number assigned to the investigational product (e.g., ABC-123). Used for cross-referencing across clinical, regulatory, and supply chain systems including RTSM and Oracle Clinical One.' ;
    rdfs:domain ind:IndApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationalProductName rdf:type rdf:Property ;
    rdfs:label 'Investigational Product Name' ;
    rdfs:comment 'The name of the investigational drug, biologic, or compound covered under this IND application. May be a code name, generic name, or proprietary name as designated by the sponsor. Corresponds to the investigational product tracked in Medidata Rave and Oracle Clinical One.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseCoverage rdf:type rdf:Property ;
    rdfs:label 'Phase Coverage' ;
    rdfs:comment 'The clinical development phase(s) authorized under this IND application. An IND may cover a single phase or span multiple phases. Phase 1 covers first-in-human safety studies; Phase 2 covers efficacy and dose-ranging; Phase 3 covers confirmatory trials; Phase 4 covers post-marketing studies. [ENUM-REF-CANDIDATE: phase_1|phase_1_2|phase_2|phase_2_3|phase_3|phase_4|all_phases — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IndApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolCount rdf:type rdf:Property ;
    rdfs:label 'Protocol Count' ;
    rdfs:comment 'The total number of clinical study protocols currently authorized and active under this IND application. An IND may cover multiple protocols across different phases and indications.' ;
    rdfs:domain ind:IndApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyReportingObligation rdf:type rdf:Property ;
    rdfs:label 'Safety Reporting Obligation' ;
    rdfs:comment 'Defines the IND-level safety reporting obligation tier. Standard obligations apply to all INDs. Expedited 7-day reporting applies to fatal or life-threatening unexpected SUSARs. Expedited 15-day reporting applies to other unexpected serious adverse reactions. Drives Oracle Argus Safety workflow configuration.' ;
    rdfs:domain ind:IndApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Sponsor Contact Email' ;
    rdfs:comment 'Email address of the designated sponsor contact person for FDA correspondence related to this IND application. Used for regulatory notifications and agency communication tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorType rdf:type rdf:Property ;
    rdfs:label 'Sponsor Type' ;
    rdfs:comment 'Classification of the sponsor organization type. Distinguishes between commercial pharmaceutical/biotech companies, academic institutions, government agencies, and Contract Research Organizations (CROs) acting as sponsor.' ;
    rdfs:domain ind:IndApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intelligenceId rdf:type rdf:Property ;
    rdfs:label 'Intelligence Id' ;
    rdfs:comment 'Primary key for intelligence' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedToEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned To Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory intelligence items (new guidelines, draft guidance) are assigned to specific workforce employees for impact assessment and action. Intelligence action tracking and regulatory strategy updat' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Action Completed Date' ;
    rdfs:comment 'Date on which all recommended regulatory actions for this intelligence item were completed and verified. Used to close out the intelligence record and confirm compliance readiness.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionDueDate rdf:type rdf:Property ;
    rdfs:label 'Action Due Date' ;
    rdfs:comment 'Target date by which the recommended regulatory actions must be completed or initiated to ensure compliance with the new or updated regulation or guidance.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:captureDate rdf:type rdf:Property ;
    rdfs:label 'Capture Date' ;
    rdfs:comment 'Date on which this regulatory intelligence item was first identified and entered into the tracking system by the regulatory affairs team. Supports timeliness KPI measurement.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cdiscImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Cdisc Impact Flag' ;
    rdfs:comment 'Indicates whether this regulatory intelligence item has a direct impact on Clinical Data Interchange Standards Consortium (CDISC) data standards (SDTM, ADaM) or submission data requirements.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commentDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Comment Deadline Date' ;
    rdfs:comment 'Deadline date by which public comments or industry responses must be submitted to the issuing agency for draft guidance documents or proposed regulations. Null for final documents.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentStatusType rdf:type rdf:Property ;
    rdfs:label 'Document Status Type' ;
    rdfs:comment 'Publication status of the underlying regulatory document (e.g., draft for comment, final, revised, withdrawn). Distinguishes between draft guidance requiring monitoring and final guidance requiring action.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ichGuidelineCode rdf:type rdf:Property ;
    rdfs:label 'Ich Guideline Code' ;
    rdfs:comment 'International Council for Harmonisation (ICH) guideline code associated with this intelligence item, if applicable (e.g., E6(R2), E8(R1), Q9, M4, S1). Enables cross-referencing with ICH harmonization activities.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactLevel rdf:type rdf:Property ;
    rdfs:label 'Impact Level' ;
    rdfs:comment 'Assessed severity of the impact this regulatory intelligence item has on the organization\'s portfolio, ongoing submissions, or clinical operations. Drives prioritization of regulatory strategy response.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactScope rdf:type rdf:Property ;
    rdfs:label 'Impact Scope' ;
    rdfs:comment 'Geographic or operational scope of the regulatory intelligence impact, indicating whether it affects global operations, a specific region, a single country, a specific product, or an individual study.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactSummary rdf:type rdf:Property ;
    rdfs:label 'Impact Summary' ;
    rdfs:comment 'Narrative assessment of how this regulatory intelligence item impacts the organization\'s portfolio, ongoing or planned submissions, clinical operations, or regulatory strategy. Authored by the regulatory affairs team.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactedSubmissionTypes rdf:type rdf:Property ;
    rdfs:label 'Impacted Submission Types' ;
    rdfs:comment 'Comma-separated list of regulatory submission types affected by this intelligence item (e.g., IND, NDA, BLA, MAA, CTA, SUSAR, DSUR). Enables targeted impact assessment across the submission portfolio.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactedTrialPhases rdf:type rdf:Property ;
    rdfs:label 'Impacted Trial Phases' ;
    rdfs:comment 'Comma-separated list of clinical trial phases impacted by this regulatory change (e.g., Phase I, Phase II, Phase III, Phase IV). Supports scoping of impact to active studies.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intelligenceCategory rdf:type rdf:Property ;
    rdfs:label 'Intelligence Category' ;
    rdfs:comment 'High-level category classifying the nature of the regulatory intelligence item (e.g., guideline update, new regulation, policy change, enforcement action, agency communication). [ENUM-REF-CANDIDATE: guideline_update|new_regulation|policy_change|enforcement_action|agency_communication|industry_standard|safety_signal|other — promote to reference product]' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intelligenceStatus rdf:type rdf:Property ;
    rdfs:label 'Intelligence Status' ;
    rdfs:comment 'Current workflow status of the intelligence record, tracking its lifecycle from initial capture through assessment and action. [ENUM-REF-CANDIDATE: draft|under_review|assessed|actioned|closed|archived — promote to reference product if additional statuses are needed]' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPublicCommentOpportunity rdf:type rdf:Property ;
    rdfs:label 'Is Public Comment Opportunity' ;
    rdfs:comment 'Indicates whether this intelligence item represents a draft guidance or proposed regulation for which the organization has an opportunity to submit public comments to the issuing agency.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keywords rdf:type rdf:Property ;
    rdfs:label 'Keywords' ;
    rdfs:comment 'Comma-separated list of searchable keywords or tags associated with this intelligence record (e.g., \'decentralized trials\', \'eCOA\', \'real-world evidence\', \'pediatric\'). Supports full-text search and categorization in analytics.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolAmendmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Protocol Amendment Required Flag' ;
    rdfs:comment 'Indicates whether this regulatory intelligence item necessitates a protocol amendment for one or more active clinical studies to maintain compliance with the updated regulation or guidance.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicCommentSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Public Comment Submitted Flag' ;
    rdfs:comment 'Indicates whether the organization has submitted a formal public comment or industry response to the issuing agency for this draft guidance or proposed regulation.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'Date on which the regulatory guidance, regulation, or policy was officially published by the issuing health authority. Used to establish the regulatory intelligence timeline.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recommendedActions rdf:type rdf:Property ;
    rdfs:label 'Recommended Actions' ;
    rdfs:comment 'Narrative description of the recommended actions the regulatory affairs team should take in response to this intelligence item (e.g., update submission strategy, revise protocol, amend IND, submit public comment). Supports proactive regulatory strategy adaptation.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Related Application Number' ;
    rdfs:comment 'IND, NDA, BLA, MAA, or CTA application number most directly impacted by this intelligence item, enabling linkage to the regulatory.application product for portfolio impact tracking.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceName rdf:type rdf:Property ;
    rdfs:label 'Source Name' ;
    rdfs:comment 'Specific name of the publication, website, journal, or agency communication from which this intelligence was sourced (e.g., \'FDA.gov Guidance Documents\', \'EMA News\', \'Regulatory Affairs Professionals Society Journal\').' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceUrl rdf:type rdf:Property ;
    rdfs:label 'Source Url' ;
    rdfs:comment 'Direct hyperlink to the original regulatory document, guidance, or publication on the issuing agency\'s website or publication portal, enabling direct access for verification.' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionStrategyImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Submission Strategy Impact Flag' ;
    rdfs:comment 'Indicates whether this regulatory intelligence item requires a revision to the organization\'s regulatory submission strategy for one or more applications (IND, NDA, BLA, MAA, CTA).' ;
    rdfs:domain ind:Intelligence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelingDocumentId rdf:type rdf:Property ;
    rdfs:label 'Labeling Document Id' ;
    rdfs:comment 'Unique surrogate identifier for the labeling document record in the regulatory domain. Primary key for the labeling_document data product.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabelingDocument .

ind:currentVersionFlag rdf:type rdf:Property ;
    rdfs:label 'Current Version Flag' ;
    rdfs:comment 'Indicates whether this record represents the currently active and approved version of the labeling document. True = current version in effect. Enables efficient filtering for active labeling without date-range logic. Only one record per document_number should have this flag set to True.' ;
    rdfs:domain ind:LabelingDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Distribution Required Flag' ;
    rdfs:comment 'Indicates whether this labeling document version requires mandatory distribution to investigative sites and principal investigators. True = distribution to all active sites is required upon approval. Triggers site notification workflows in CTMS.' ;
    rdfs:domain ind:LabelingDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:healthAuthorityApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Health Authority Approval Date' ;
    rdfs:comment 'The date on which the relevant health authority (FDA, EMA, PMDA, MHRA, Health Canada, TGA) formally approved or acknowledged this labeling document version. Null for documents not requiring direct health authority approval (e.g., internal IB editions).' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ibEditionNumber rdf:type rdf:Property ;
    rdfs:label 'Ib Edition Number' ;
    rdfs:comment 'For Investigator Brochure (IB) document types, the sequential edition number (e.g., Edition 1, Edition 2). Distinct from version_number; the IB edition is the regulatory-facing identifier used in IND/CTA submissions and site communications. Null for non-IB document types.' ;
    rdfs:domain ind:LabelingDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:icfUpdateRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Icf Update Required Flag' ;
    rdfs:comment 'Indicates whether changes in this labeling document version necessitate an update to the Informed Consent Form (ICF) at investigative sites. True = ICF amendment required. Triggers IRB/IEC re-submission workflows and subject re-consent processes.' ;
    rdfs:domain ind:LabelingDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'The regulatory region or market grouping for which this labeling document applies. Complements country_code for regional labeling strategies and multi-regional submission planning.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rsiFlag rdf:type rdf:Property ;
    rdfs:label 'Rsi Flag' ;
    rdfs:comment 'Indicates whether this labeling document serves as the Reference Safety Information (RSI) for the purpose of SUSAR (Suspected Unexpected Serious Adverse Reaction) expectedness assessment. True = this document is the designated RSI. Critical for pharmacovigilance and expedited safety reporting.' ;
    rdfs:domain ind:LabelingDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyUpdateFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Update Flag' ;
    rdfs:comment 'Indicates whether this version of the labeling document was issued primarily due to a safety update (e.g., new adverse event data, updated risk information, SUSAR findings). True = safety-driven revision. Triggers expedited regulatory notification timelines.' ;
    rdfs:domain ind:LabelingDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:veevaVaultLifecycleState rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Lifecycle State' ;
    rdfs:comment 'The document lifecycle state as recorded in Veeva Vault\'s document management workflow. Mirrors the Vault-native state for reconciliation and audit purposes. Distinct from approval_status which reflects the business/regulatory approval state.' ;
    rdfs:domain ind:LabelingDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Project Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: The project manager for an NDA/BLA owns PDUFA goal date tracking, rolling review coordination, and advisory committee preparation — all named regulatory operations processes. \'project_manager_name\' is' ;
    rdfs:domain ind:NdaBlaApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:advisoryCommitteeDate rdf:type rdf:Property ;
    rdfs:label 'Advisory Committee Date' ;
    rdfs:comment 'Scheduled or actual date of the FDA Advisory Committee (AdCom) meeting convened to review this application. Null if no advisory committee meeting is planned or held.' ;
    rdfs:domain ind:NdaBlaApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:advisoryCommitteeFlag rdf:type rdf:Property ;
    rdfs:label 'Advisory Committee Flag' ;
    rdfs:comment 'Indicates whether an FDA Advisory Committee (AdCom) meeting has been scheduled or held for this application. Advisory committee recommendations are a key input to the FDA approval decision.' ;
    rdfs:domain ind:NdaBlaApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:advisoryCommitteeRecommendation rdf:type rdf:Property ;
    rdfs:label 'Advisory Committee Recommendation' ;
    rdfs:comment 'Outcome vote or recommendation issued by the FDA Advisory Committee following their review meeting. Null if no meeting held. Informs but does not bind the FDA approval decision.' ;
    rdfs:domain ind:NdaBlaApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalPathway rdf:type rdf:Property ;
    rdfs:label 'Approval Pathway' ;
    rdfs:comment 'Regulatory approval pathway under which the application is reviewed: standard review, accelerated approval (FDA), conditional marketing authorization (EMA), exceptional circumstances (EMA), or rolling review. Determines review timelines and post-approval commitments.' ;
    rdfs:domain ind:NdaBlaApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completeResponseLetterDate rdf:type rdf:Property ;
    rdfs:label 'Complete Response Letter Date' ;
    rdfs:comment 'Date on which the FDA issued a Complete Response Letter (CRL) indicating the application cannot be approved in its current form and specifying deficiencies to be addressed. Null if no CRL issued.' ;
    rdfs:domain ind:NdaBlaApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ctdModuleStatus rdf:type rdf:Property ;
    rdfs:label 'Ctd Module Status' ;
    rdfs:comment 'Overall completeness status of the CTD dossier modules (1–5) at time of submission. Tracks whether all required CTD modules have been submitted to the health authority.' ;
    rdfs:domain ind:NdaBlaApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityType rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Type' ;
    rdfs:comment 'Type of regulatory market exclusivity granted upon approval: NCE (5-year new chemical entity), biologic (12-year), orphan drug (7-year), pediatric (6-month extension), new indication (3-year), or none.' ;
    rdfs:domain ind:NdaBlaApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthAuthority rdf:type rdf:Property ;
    rdfs:label 'Health Authority' ;
    rdfs:comment 'Regulatory health authority to which the application was submitted (e.g., FDA, EMA, PMDA, MHRA, Health Canada, TGA). Determines applicable regulatory framework, timelines, and submission format requirements. [ENUM-REF-CANDIDATE: FDA|EMA|PMDA|MHRA|Health_Canada|TGA|ANVISA|NMPA|Swissmedic|COFEPRIS — promote to reference product]' ;
    rdfs:domain ind:NdaBlaApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inn rdf:type rdf:Property ;
    rdfs:label 'Inn' ;
    rdfs:comment 'WHO-assigned International Nonproprietary Name (INN) for the active substance. Provides a globally unique, non-proprietary identifier for the drug substance used across regulatory submissions and scientific literature.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketExclusivityExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Market Exclusivity Expiry Date' ;
    rdfs:comment 'Date on which the regulatory market exclusivity period expires (e.g., 5-year NCE exclusivity, 12-year biologic exclusivity, 7-year orphan drug exclusivity). Critical for commercial lifecycle and generic/biosimilar entry planning.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orphanDrugFlag rdf:type rdf:Property ;
    rdfs:label 'Orphan Drug Flag' ;
    rdfs:comment 'Indicates whether the drug or biologic has received Orphan Drug Designation (ODD) from FDA (Orphan Drug Act) or EMA (EC Regulation 141/2000), conferring market exclusivity and fee waivers.' ;
    rdfs:domain ind:NdaBlaApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postMarketingCommitmentFlag rdf:type rdf:Property ;
    rdfs:label 'Post Marketing Commitment Flag' ;
    rdfs:comment 'Indicates whether the approval includes required post-marketing commitments (PMCs) or post-marketing requirements (PMRs), such as confirmatory trials for accelerated approval or pediatric studies under PREA.' ;
    rdfs:domain ind:NdaBlaApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Review Flag' ;
    rdfs:comment 'Indicates whether the FDA has granted Priority Review designation to this application, reducing the standard review period from 12 months to 6 months. Applicable to FDA NDA/BLA only.' ;
    rdfs:domain ind:NdaBlaApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refuseToFileDate rdf:type rdf:Property ;
    rdfs:label 'Refuse To File Date' ;
    rdfs:comment 'Date on which the FDA issued a Refuse to File (RTF) action, indicating the application was not sufficiently complete for substantive review. Null if no RTF was issued.' ;
    rdfs:domain ind:NdaBlaApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rems Required Flag' ;
    rdfs:comment 'Indicates whether the FDA has required a Risk Evaluation and Mitigation Strategy (REMS) as a condition of approval to ensure the drug\'s benefits outweigh its risks.' ;
    rdfs:domain ind:NdaBlaApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resubmissionClass rdf:type rdf:Property ;
    rdfs:label 'Resubmission Class' ;
    rdfs:comment 'FDA classification of the resubmission following a CRL: Class 1 (2-month review goal) for minor responses, Class 2 (6-month review goal) for major responses requiring extensive review.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Resubmission Date' ;
    rdfs:comment 'Date on which the sponsor resubmitted the application following a Complete Response Letter (CRL) or other agency deficiency communication. Null if no resubmission has occurred.' ;
    rdfs:domain ind:NdaBlaApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewDivision rdf:type rdf:Property ;
    rdfs:label 'Review Division' ;
    rdfs:comment 'FDA Office or Division (e.g., Office of Oncology Products, Division of Psychiatry) or EMA Committee (CHMP, COMP) responsible for reviewing this application. Used for regulatory relationship management and escalation routing.' ;
    rdfs:domain ind:NdaBlaApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollingReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Rolling Review Flag' ;
    rdfs:comment 'Indicates whether the health authority has granted rolling review, allowing submission and review of completed CTD modules before the full dossier is complete. Applicable to FDA (Fast Track) and EMA rolling review procedures.' ;
    rdfs:domain ind:NdaBlaApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Submission Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction where the application was submitted (e.g., USA, GBR, JPN, CAN, AUS). Supports multi-regional regulatory tracking.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureId rdf:type rdf:Property ;
    rdfs:label 'Procedure Id' ;
    rdfs:comment 'Primary key for procedure' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableProductTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Product Types' ;
    rdfs:comment 'Pipe-delimited list of product types for which this procedure is applicable (e.g., \'small_molecule|biologic|vaccine|gene_therapy|medical_device|combination_product\'). Guides procedure selection during submission planning based on the investigational product category.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentReportType rdf:type rdf:Property ;
    rdfs:label 'Assessment Report Type' ;
    rdfs:comment 'Type of public assessment report published by the health authority upon completion of review under this procedure (e.g., EPAR for EMA Centralized Procedure, PAR for MHRA, Assessment Report for PMDA, Review Memo for FDA). Used for regulatory intelligence and post-approval transparency tracking.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clockStopAllowed rdf:type rdf:Property ;
    rdfs:label 'Clock Stop Allowed' ;
    rdfs:comment 'Indicates whether the health authority may issue a clock stop (List of Outstanding Issues / Major Objection) that pauses the review clock under this procedure. True for EMA centralized procedure (Day 120/180 clock stops); False for FDA standard review. Critical for realistic timeline modeling.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ctdModulesRequired rdf:type rdf:Property ;
    rdfs:label 'Ctd Modules Required' ;
    rdfs:comment 'Pipe-delimited list of CTD modules required for a complete submission under this procedure (e.g., \'module1|module2|module3|module4|module5\' for a full NDA/MAA; \'module1|module2|module3\' for a CMC-only variation). Guides dossier completeness assessment and gap analysis.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataExclusivityPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Data Exclusivity Period Years' ;
    rdfs:comment 'Number of years of data exclusivity granted upon approval under this procedure (e.g., 5 years for FDA NCE exclusivity, 8 years data exclusivity + 2 years market exclusivity for EMA). Used in lifecycle management and competitive intelligence planning.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expeditedPathwayAvailable rdf:type rdf:Property ;
    rdfs:label 'Expedited Pathway Available' ;
    rdfs:comment 'Indicates whether an expedited or accelerated review pathway is available under this procedure (e.g., FDA Priority Review, Breakthrough Therapy, Accelerated Approval; EMA Accelerated Assessment, PRIME scheme). Drives regulatory strategy and timeline planning.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expeditedReviewClockDays rdf:type rdf:Property ;
    rdfs:label 'Expedited Review Clock Days' ;
    rdfs:comment 'Number of calendar days for expedited or priority review under this procedure (e.g., 180 days for FDA priority review NDA, 150 days for EMA accelerated assessment). Null if no expedited pathway exists for this procedure. Used for PDUFA goal date and accelerated timeline planning.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fee Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the submission fee associated with this procedure (e.g., USD for FDA, EUR for EMA, GBP for MHRA, JPY for PMDA). Null if no fee applies. Used in financial planning and budget forecasting for regulatory submissions.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guidanceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Guidance Document Reference' ;
    rdfs:comment 'Reference to the primary agency guidance document or procedural guidance that describes this procedure in detail (e.g., FDA Guidance for Industry: Submitting an NDA, EMA Procedural Guidance for MAA, ICH M4 CTD Guidance). Used for regulatory operations training and compliance.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localAgentRequired rdf:type rdf:Property ;
    rdfs:label 'Local Agent Required' ;
    rdfs:comment 'Indicates whether a local regulatory agent or representative is required in the target jurisdiction to submit under this procedure (e.g., EU Qualified Person for Pharmacovigilance, Japan local agent for PMDA submissions). Impacts resourcing and regulatory operations planning.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketExclusivityPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Market Exclusivity Period Years' ;
    rdfs:comment 'Number of years of market exclusivity (protection from generic/biosimilar competition) granted upon approval under this procedure (e.g., 12 years for FDA biologic exclusivity, 10 years for EMA). Distinct from data exclusivity. Used in lifecycle and portfolio strategy planning.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mutualRecognitionAgreementApplicable rdf:type rdf:Property ;
    rdfs:label 'Mutual Recognition Agreement Applicable' ;
    rdfs:comment 'Indicates whether a Mutual Recognition Agreement (MRA) between jurisdictions is applicable to this procedure, potentially enabling reliance on another agency\'s assessment to streamline review. Relevant for FDA-EMA, FDA-Health Canada, and similar bilateral agreements.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orphanDesignationApplicable rdf:type rdf:Property ;
    rdfs:label 'Orphan Designation Applicable' ;
    rdfs:comment 'Indicates whether orphan drug designation (FDA) or orphan medicinal product designation (EMA) can be applied in conjunction with this procedure, potentially conferring fee waivers, market exclusivity, and protocol assistance.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pediatricPlanRequired rdf:type rdf:Property ;
    rdfs:label 'Pediatric Plan Required' ;
    rdfs:comment 'Indicates whether a Pediatric Investigation Plan (EMA PIP) or Pediatric Study Plan (FDA PSP) must be submitted or agreed upon as part of this procedure. Drives pediatric regulatory commitment tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postApprovalVariationProcedure rdf:type rdf:Property ;
    rdfs:label 'Post Approval Variation Procedure' ;
    rdfs:comment 'Classification of the post-approval variation procedure applicable after initial approval under this procedure (e.g., EMA Type IA/IB/II Variation, FDA Prior Approval Supplement, Changes Being Effected CBE-30, CBE-0, Annual Report). Used to plan lifecycle management submissions. [ENUM-REF-CANDIDATE: Type_IA|Type_IB|Type_II|Prior_Approval_Supplement|CBE30|CBE0|Annual_Report|None — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preSubmissionMeetingAvailable rdf:type rdf:Property ;
    rdfs:label 'Pre Submission Meeting Available' ;
    rdfs:comment 'Indicates whether the health authority offers a formal pre-submission meeting (e.g., FDA Type B Pre-NDA meeting, EMA Scientific Advice) for this procedure type. Used in regulatory strategy planning to schedule agency interactions before dossier filing.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proceduralRequirements rdf:type rdf:Property ;
    rdfs:label 'Procedural Requirements' ;
    rdfs:comment 'Free-text description of key procedural requirements, mandatory steps, and conditions that must be met to initiate and complete a submission under this procedure (e.g., pre-submission validation, mandatory scientific advice, specific data package requirements, language requirements). Supports regulatory operations planning.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureCode rdf:type rdf:Property ;
    rdfs:label 'Procedure Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying the regulatory procedure or pathway (e.g., EU-CENTRAL, FDA-NDA-STANDARD, FDA-NDA-PRIORITY, EMA-DCP, EMA-MRP, PMDA-NATIONAL). Used as the business key for cross-system reference and submission classification.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureName rdf:type rdf:Property ;
    rdfs:label 'Procedure Name' ;
    rdfs:comment 'Full human-readable name of the regulatory procedure or pathway (e.g., \'Centralized Procedure\', \'Decentralized Procedure\', \'Mutual Recognition Procedure\', \'National Procedure\', \'Abbreviated New Drug Application Procedure\'). Used in reports, dossier planning, and regulatory correspondence.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureStatus rdf:type rdf:Property ;
    rdfs:label 'Procedure Status' ;
    rdfs:comment 'Current lifecycle status of this regulatory procedure definition. Active: currently applicable and in use for submission planning. Inactive: no longer accepted by the agency. Deprecated: superseded by a newer procedure. Under_revision: procedure definition is being updated.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureType rdf:type rdf:Property ;
    rdfs:label 'Procedure Type' ;
    rdfs:comment 'High-level classification of the regulatory procedure pathway. Centralized: single EMA review for all EU member states. Decentralized: simultaneous national applications. Mutual Recognition: extension of existing national approval. National: single country review. Abbreviated: generic/biosimilar pathway. Hybrid: combination of full and abbreviated data.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rapporteurRequired rdf:type rdf:Property ;
    rdfs:label 'Rapporteur Required' ;
    rdfs:comment 'Indicates whether a Rapporteur and Co-Rapporteur must be appointed by the CHMP/CVMP for this procedure (applicable to EMA Centralized Procedure). The Rapporteur leads the scientific assessment and prepares the Assessment Report.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referenceMemberStateRequired rdf:type rdf:Property ;
    rdfs:label 'Reference Member State Required' ;
    rdfs:comment 'Indicates whether a Reference Member State (RMS) must be designated for this procedure (applicable to EMA Decentralized Procedure and Mutual Recognition Procedure). The RMS leads the scientific assessment on behalf of all Concerned Member States.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFrameworkReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework Reference' ;
    rdfs:comment 'Primary legal or regulatory framework citation governing this procedure (e.g., \'21 CFR Part 314\' for FDA NDA, \'Regulation (EC) No 726/2004\' for EMA Centralized Procedure, \'EU CTR 536/2014\' for clinical trial authorization). Provides traceability to the authoritative regulatory source.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remsApplicable rdf:type rdf:Property ;
    rdfs:label 'Rems Applicable' ;
    rdfs:comment 'Indicates whether a Risk Evaluation and Mitigation Strategy (REMS) or Risk Management Plan (RMP) may be required as a condition of approval under this procedure. Relevant for FDA REMS and EMA RMP requirements.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rollingReviewAllowed rdf:type rdf:Property ;
    rdfs:label 'Rolling Review Allowed' ;
    rdfs:comment 'Indicates whether the health authority permits rolling review (submission of completed CTD modules before the full dossier is ready) under this procedure. Applicable to FDA Rolling Review and EMA Rolling Review for medicines of major public health interest.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Standard Fee Amount' ;
    rdfs:comment 'Standard regulatory submission fee amount for this procedure in the currency specified by fee_currency_code (e.g., FDA NDA standard application fee per current PDUFA year). Used for regulatory budget planning and financial forecasting. Classified confidential as fee schedules may be commercially sensitive.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionFeeApplicable rdf:type rdf:Property ;
    rdfs:label 'Submission Fee Applicable' ;
    rdfs:comment 'Indicates whether a regulatory submission fee is required for this procedure (e.g., FDA PDUFA user fee, EMA fee). Drives financial planning and fee waiver eligibility assessment for orphan or small business designations.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validationCriteria rdf:type rdf:Property ;
    rdfs:label 'Validation Criteria' ;
    rdfs:comment 'Description of the formal validation or completeness check criteria applied by the health authority upon receipt of a submission under this procedure (e.g., FDA 60-day filing review criteria, EMA Day 0 validation checklist). Used to prepare complete dossiers and avoid refuse-to-file actions.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaVaultProcedureReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Procedure Reference' ;
    rdfs:comment 'Reference identifier for this regulatory procedure record in Veeva Vault (eTMF/regulatory submissions module). Enables traceability between the silver layer data product and the source system of record for regulatory document management and submission tracking.' ;
    rdfs:domain ind:Procedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAffairsLeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Affairs Lead Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: The regulatory affairs lead managing a protocol amendment is a workforce employee. Amendment workload tracking, agency submission accountability, and GCP inspection readiness all require this traceabl' ;
    rdfs:domain ind:RegulatoryProtocolAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedSections rdf:type rdf:Property ;
    rdfs:label 'Affected Sections' ;
    rdfs:comment 'Comma-delimited list or narrative description of the specific protocol sections modified by this amendment (e.g., \'Section 4.1 Inclusion Criteria, Section 6.2 Dosing Schedule\'). Supports impact assessment and site notification planning.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Agency Acknowledgment Date' ;
    rdfs:comment 'Date on which the health authority formally acknowledged receipt of the protocol amendment submission. Initiates the regulatory review period clock per applicable regulations.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agencyApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Agency Approval Date' ;
    rdfs:comment 'Date on which the health authority granted formal approval or no-objection for the protocol amendment. For non-substantial amendments, this may be the date of implicit approval after the notification period.' ;
    rdfs:domain ind:RegulatoryProtocolAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agencyResponseComments rdf:type rdf:Property ;
    rdfs:label 'Agency Response Comments' ;
    rdfs:comment 'Summary of conditions, queries, or comments provided by the health authority in their formal response to the amendment submission. Drives follow-up actions and response preparation.' ;
    rdfs:domain ind:RegulatoryProtocolAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyResponseType rdf:type rdf:Property ;
    rdfs:label 'Agency Response Type' ;
    rdfs:comment 'Type of formal response received from the health authority regarding the amendment submission. [ENUM-REF-CANDIDATE: approved|approved_with_conditions|clinical_hold|information_requested|rejected|no_objection|withdrawn — promote to reference product]' ;
    rdfs:domain ind:RegulatoryProtocolAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsmbNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Dsmb Notification Required Flag' ;
    rdfs:comment 'Indicates whether the Data Safety Monitoring Board (DSMB) or Data Monitoring Committee (DMC) must be notified of this protocol amendment, typically required for amendments affecting safety monitoring, stopping rules, or interim analysis plans.' ;
    rdfs:domain ind:RegulatoryProtocolAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ethicsApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Ethics Approval Date' ;
    rdfs:comment 'Date on which the IRB/IEC granted approval for the protocol amendment. Required before implementation at sites under the jurisdiction of that ethics committee.' ;
    rdfs:domain ind:RegulatoryProtocolAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ethicsSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Ethics Submission Date' ;
    rdfs:comment 'Date on which the protocol amendment was submitted to the Institutional Review Board (IRB) or Independent Ethics Committee (IEC) for review and approval.' ;
    rdfs:domain ind:RegulatoryProtocolAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:globalSubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Global Submission Flag' ;
    rdfs:comment 'Indicates whether this amendment was submitted simultaneously to multiple health authorities as part of a global regulatory strategy, requiring coordinated timelines across FDA, EMA, PMDA, and other agencies.' ;
    rdfs:domain ind:RegulatoryProtocolAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:icfVersionImpacted rdf:type rdf:Property ;
    rdfs:label 'Icf Version Impacted' ;
    rdfs:comment 'Version identifier of the Informed Consent Form (ICF) that must be updated as a result of this amendment. Links to the ICF version management workflow in Clinpal and the document management system.' ;
    rdfs:domain ind:RegulatoryProtocolAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Planned Implementation Date' ;
    rdfs:comment 'Target date for operational implementation of the amendment at clinical sites, used for project planning and site readiness tracking in Oracle Siebel CTMS.' ;
    rdfs:domain ind:RegulatoryProtocolAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Prior Approval Required Flag' ;
    rdfs:comment 'Indicates whether this amendment requires prior approval from the health authority before implementation (true for substantial amendments) versus notification-only (false for non-substantial/administrative amendments).' ;
    rdfs:domain ind:RegulatoryProtocolAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconsentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reconsent Required Flag' ;
    rdfs:comment 'Indicates whether enrolled subjects must provide updated informed consent (ICF re-consent) as a result of this amendment. Triggers ICF version update workflow in Clinpal and site notification via Oracle Siebel CTMS.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siteNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Site Notification Date' ;
    rdfs:comment 'Date on which clinical sites were formally notified of the approved protocol amendment and required to begin implementation, including updated training and revised procedures. Tracked in Oracle Siebel CTMS.' ;
    rdfs:domain ind:RegulatoryProtocolAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subjectImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Subject Impact Flag' ;
    rdfs:comment 'Indicates whether the amendment affects subjects currently enrolled in the study, requiring re-consent, protocol deviation assessment, or updated procedures for ongoing participants.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Reference Number' ;
    rdfs:comment 'Official reference number assigned by the health authority upon receipt of the amendment submission (e.g., FDA IND amendment serial number, EMA submission tracking number). Used for all subsequent regulatory correspondence.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urgentSafetyMeasureFlag rdf:type rdf:Property ;
    rdfs:label 'Urgent Safety Measure Flag' ;
    rdfs:comment 'Indicates whether this amendment was implemented as an urgent safety measure prior to regulatory approval, as permitted under GCP and EU CTR for immediate risk mitigation. Requires retrospective notification to health authorities.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorActionItemRegulatoryActionItemId rdf:type rdf:Property ;
    rdfs:label 'Prior Action Item Regulatory Action Item Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the previous action item from which this one was derived (e.g., a re-opened or recurring item). Enables lineage tracking across action item generations. Nullable for original items.' ;
    rdfs:domain ind:RegulatoryActionItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryActionItem .

ind:regulatoryCorrespondenceId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Correspondence Id' ;
    rdfs:comment 'Foreign key linking to regulatory.correspondence. Business justification: Action items can arise from regulatory correspondence (Complete Response Letters, Information Requests, deficiency letters). The source_event_type field on regulatory_action_item can be \'correspondenc' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Correspondence .

ind:actionItemDescription rdf:type rdf:Property ;
    rdfs:label 'Action Item Description' ;
    rdfs:comment 'Detailed narrative describing the specific regulatory task, finding, or commitment that must be addressed. Captures the full context of what is required, including any agency-specified language from meeting minutes or inspection reports.' ;
    rdfs:domain ind:RegulatoryActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyMandatedDueDate rdf:type rdf:Property ;
    rdfs:label 'Agency Mandated Due Date' ;
    rdfs:comment 'The specific response deadline formally communicated by the health authority (e.g., FDA 30-day information request clock, EMA Day 120 response). Distinct from the internal due_date which may be set earlier to allow review time. Nullable when no formal agency deadline exists.' ;
    rdfs:domain ind:RegulatoryActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agencySubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Agency Submission Date' ;
    rdfs:comment 'The date on which the completed response or deliverable was formally submitted to the health authority. Distinct from completion_date (internal closure) — captures the actual agency-facing delivery date for regulatory clock tracking.' ;
    rdfs:domain ind:RegulatoryActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignedOwnerEmail rdf:type rdf:Property ;
    rdfs:label 'Assigned Owner Email' ;
    rdfs:comment 'Email address of the individual responsible for completing this action item. Used for automated notifications, escalation alerts, and audit trail. Classified as confidential PII per GDPR and HIPAA.' ;
    rdfs:domain ind:RegulatoryActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedOwnerName rdf:type rdf:Property ;
    rdfs:label 'Assigned Owner Name' ;
    rdfs:comment 'Full name of the individual (typically a Regulatory Affairs professional or CRA) responsible for completing this action item. Captured as a denormalized field for operational task management and audit trail purposes.' ;
    rdfs:domain ind:RegulatoryActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned Team' ;
    rdfs:comment 'Name of the regulatory affairs team or functional group responsible for this action item (e.g., \'Global Regulatory Strategy\', \'Submissions Team\', \'Safety Reporting\'). Supports team-level workload reporting and capacity planning.' ;
    rdfs:domain ind:RegulatoryActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'The date on which this action item was formally opened and entered into the regulatory task register. Represents the business event timestamp for the creation of the obligation.' ;
    rdfs:domain ind:RegulatoryActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryArea rdf:type rdf:Property ;
    rdfs:label 'Regulatory Area' ;
    rdfs:comment 'Functional regulatory domain to which this action item belongs (e.g., clinical, safety, CMC). Enables domain-specific filtering and assignment routing within the regulatory affairs team. [ENUM-REF-CANDIDATE: clinical|safety|cmc|regulatory_affairs|data_management|biostatistics|quality|other — promote to reference product]' ;
    rdfs:domain ind:RegulatoryActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryProcedureReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Procedure Reference' ;
    rdfs:comment 'Reference to the specific regulatory procedure, guideline, or regulation that this action item must satisfy (e.g., \'21 CFR 312.32\', \'EMA/CHMP/ICH/295148/2004\', \'ICH E6(R2) Section 5.18\'). Provides the regulatory basis for the required action.' ;
    rdfs:domain ind:RegulatoryActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDocumentTitle rdf:type rdf:Property ;
    rdfs:label 'Response Document Title' ;
    rdfs:comment 'Title of the formal response document prepared to address this action item (e.g., \'Response to FDA Information Request Letter dated 2024-03-15\'). Supports eTMF filing and regulatory correspondence tracking.' ;
    rdfs:domain ind:RegulatoryActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceEventType rdf:type rdf:Property ;
    rdfs:label 'Source Event Type' ;
    rdfs:comment 'Classification of the business event that originated this action item. Drives workflow routing and reporting dashboards. [ENUM-REF-CANDIDATE: agency_meeting|inspection_finding|regulatory_correspondence|internal_review|dsmb_recommendation|other — promote to reference product if additional values are needed]' ;
    rdfs:domain ind:RegulatoryActionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostContactEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Host Contact Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: The inspection host contact is a workforce employee who coordinates inspector access, document retrieval, and CAPA responses during GCP/GMP inspections. \'host_contact_name\' is a denormalized workforce' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:priorInspectionRegulatoryInspectionId rdf:type rdf:Property ;
    rdfs:label 'Prior Inspection Regulatory Inspection Id' ;
    rdfs:comment 'Self-referencing identifier linking this inspection to a previous inspection of the same site or sponsor. Populated when is_repeat_inspection is True, enabling inspection history chain analysis.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryInspection .

ind:announcementDate rdf:type rdf:Property ;
    rdfs:label 'Announcement Date' ;
    rdfs:comment 'Date on which the inspecting authority formally notified the site, sponsor, or CRO of the upcoming inspection. Used to calculate preparation lead time and assess readiness adequacy.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Capa Response Due Date' ;
    rdfs:comment 'Deadline by which the sponsor or site must submit a Corrective and Preventive Action (CAPA) plan in response to the inspection findings. Typically defined by the inspecting authority in the inspection report or cover letter.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capaSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Capa Submission Date' ;
    rdfs:comment 'Actual date on which the CAPA plan was submitted to the inspecting authority in response to inspection findings. Compared against capa_response_due_date to assess timeliness of regulatory response.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:focusAreas rdf:type rdf:Property ;
    rdfs:label 'Focus Areas' ;
    rdfs:comment 'Free-text or semi-structured description of the specific areas, processes, or systems targeted by the inspection (e.g., informed consent process, SAE reporting, randomization procedures, data integrity, TMF completeness). Supports targeted readiness preparation.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCategory rdf:type rdf:Property ;
    rdfs:label 'Inspection Category' ;
    rdfs:comment 'Categorizes the trigger or purpose of the inspection: Routine (scheduled surveillance), For-Cause (triggered by a specific concern or complaint), Pre-Approval (prior to NDA/BLA/MAA approval), Pre-License (prior to license issuance), or Follow-Up (verifying CAPA closure from a prior inspection).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRepeatInspection rdf:type rdf:Property ;
    rdfs:label 'Is Repeat Inspection' ;
    rdfs:comment 'Indicates whether this inspection is a follow-up or repeat inspection of the same site or sponsor, typically triggered by unresolved findings from a prior inspection (True = repeat; False = first inspection).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnannounced rdf:type rdf:Property ;
    rdfs:label 'Is Unannounced' ;
    rdfs:comment 'Indicates whether the inspection was conducted without prior notice to the site or sponsor (True = unannounced/for-cause; False = announced). Unannounced inspections typically indicate heightened regulatory scrutiny.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryContactName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Contact Name' ;
    rdfs:comment 'Name of the internal regulatory affairs contact or liaison responsible for managing communications with the inspecting authority for this inspection event.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Report Receipt Date' ;
    rdfs:comment 'Date on which the official inspection report (e.g., FDA Establishment Inspection Report, EMA GCP Inspection Report) was received from the inspecting authority. Triggers the CAPA response timeline.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'The planned or announced date on which the inspection is scheduled to begin, as communicated by the inspecting authority or agreed upon internally. Serves as the BUSINESS_EVENT_TIMESTAMP (date precision) for planning purposes.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Total Findings Count' ;
    rdfs:comment 'Total number of all inspection findings across all severity levels (critical + major + minor). Provides a single summary metric for inspection severity assessment and benchmarking across studies and sites.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upstreamMilestoneRegulatoryMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Upstream Milestone Regulatory Milestone Id' ;
    rdfs:comment 'Self-referencing identifier of the predecessor regulatory milestone that must be completed before this milestone can begin, enabling dependency chain tracking and critical path analysis.' ;
    rdfs:domain ind:RegulatoryMilestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryMilestone .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'Precise timestamp when the milestone status was set to \'completed\', capturing the exact moment of milestone achievement for audit trail and regulatory timeline reporting purposes.' ;
    rdfs:domain ind:RegulatoryMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completionNotes rdf:type rdf:Property ;
    rdfs:label 'Completion Notes' ;
    rdfs:comment 'Free-text notes recorded at the time of milestone completion, capturing any conditions, caveats, agency feedback, or follow-up actions associated with the milestone outcome.' ;
    rdfs:domain ind:RegulatoryMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsMilestoneRef rdf:type rdf:Property ;
    rdfs:label 'Ctms Milestone Ref' ;
    rdfs:comment 'Cross-reference identifier from Oracle Siebel CTMS for the corresponding milestone or project task record, enabling reconciliation between the regulatory milestone tracker and the operational CTMS project plan.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAgencyCommitted rdf:type rdf:Property ;
    rdfs:label 'Is Agency Committed' ;
    rdfs:comment 'Flag indicating whether the planned or agency action date for this milestone has been formally committed to or communicated by the regulatory agency (e.g., PDUFA date confirmed, EMA Day 120 clock set). Distinguishes agency-set dates from sponsor-estimated dates.' ;
    rdfs:domain ind:RegulatoryMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneCategory rdf:type rdf:Property ;
    rdfs:label 'Milestone Category' ;
    rdfs:comment 'High-level grouping of the milestone within the drug development lifecycle: pre_clinical (pre-IND activities), clinical (study execution phases), regulatory (submission and review activities), commercial (post-approval activities).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityDesignation rdf:type rdf:Property ;
    rdfs:label 'Priority Designation' ;
    rdfs:comment 'Special regulatory designation granted by the agency that may affect review timelines and milestone dates (e.g., FDA Priority Review, Breakthrough Therapy, Fast Track, Accelerated Approval, Orphan Drug). [ENUM-REF-CANDIDATE: standard|priority_review|breakthrough|fast_track|accelerated_approval|orphan|prime|conditional_approval|none — promote to reference product]' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityOfSuccessPct rdf:type rdf:Property ;
    rdfs:label 'Probability Of Success Pct' ;
    rdfs:comment 'Estimated probability (0.00–100.00%) that this regulatory milestone will be achieved on or before the planned date, used in risk-adjusted scenario planning and portfolio forecasting.' ;
    rdfs:domain ind:RegulatoryMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryStrategyNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Strategy Notes' ;
    rdfs:comment 'Confidential free-text field capturing regulatory strategy considerations, agency meeting outcomes, or scenario planning assumptions relevant to this milestone. Classified as confidential due to commercially sensitive strategic content.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedPlannedDate rdf:type rdf:Property ;
    rdfs:label 'Revised Planned Date' ;
    rdfs:comment 'Most recently updated target date for the milestone following a formal re-baseline of the regulatory project plan, reflecting approved schedule changes.' ;
    rdfs:domain ind:RegulatoryMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scenarioLabel rdf:type rdf:Property ;
    rdfs:label 'Scenario Label' ;
    rdfs:comment 'Label identifying the planning scenario under which this milestone date was projected, supporting regulatory timeline scenario planning and what-if analysis: base_case (most likely), optimistic (best case), pessimistic (worst case), risk_adjusted (probability-weighted).' ;
    rdfs:domain ind:RegulatoryMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceDays rdf:type rdf:Property ;
    rdfs:label 'Variance Days' ;
    rdfs:comment 'Signed integer representing the difference in calendar days between the actual (or forecast) date and the planned date. Positive values indicate delay; negative values indicate early completion. Enables regulatory timeline KPI reporting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:veevaVaultDocReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Doc Reference' ;
    rdfs:comment 'Cross-reference identifier linking this milestone to the corresponding document, dossier, or workflow object in Veeva Vault (eTMF/regulatory submissions module), enabling traceability between milestone tracking and the source document management system.' ;
    rdfs:domain ind:RegulatoryMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remsAdministratorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Rems Administrator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: The REMS administrator is a workforce employee accountable for program compliance rates, assessment submissions, and FDA interactions. FDA requires a named responsible individual for REMS programs. Bo' ;
    rdfs:domain ind:RemsProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessmentSchedule rdf:type rdf:Property ;
    rdfs:label 'Assessment Schedule' ;
    rdfs:comment 'FDA-mandated schedule for submitting REMS program assessments (e.g., 18 months, 3 years, 7 years post-approval, or annual). Defined in the approved REMS document.' ;
    rdfs:domain ind:RemsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRatePercent rdf:type rdf:Property ;
    rdfs:label 'Compliance Rate Percent' ;
    rdfs:comment 'Most recently reported overall REMS program compliance rate as a percentage, reflecting adherence to ETASU and dispensing controls across enrolled prescribers and pharmacies. Sourced from the latest REMS assessment submission.' ;
    rdfs:domain ind:RemsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrolledPatientCount rdf:type rdf:Property ;
    rdfs:label 'Enrolled Patient Count' ;
    rdfs:comment 'Current total number of patients enrolled in the REMS program registry as of the most recent reporting period.' ;
    rdfs:domain ind:RemsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enrolledPharmacyCount rdf:type rdf:Property ;
    rdfs:label 'Enrolled Pharmacy Count' ;
    rdfs:comment 'Current total number of pharmacies certified and enrolled in the REMS program as authorized dispensing sites.' ;
    rdfs:domain ind:RemsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enrolledPrescriberCount rdf:type rdf:Property ;
    rdfs:label 'Enrolled Prescriber Count' ;
    rdfs:comment 'Current total number of healthcare providers certified and enrolled in the REMS program as authorized prescribers.' ;
    rdfs:domain ind:RemsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:etasuDescription rdf:type rdf:Property ;
    rdfs:label 'Etasu Description' ;
    rdfs:comment 'Narrative description of the specific ETASU elements required by the REMS program, including prescriber certification, pharmacy enrollment, patient registry, lab monitoring, or dispensing restrictions.' ;
    rdfs:domain ind:RemsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:euRiskMinimizationDescription rdf:type rdf:Property ;
    rdfs:label 'Eu Risk Minimization Description' ;
    rdfs:comment 'Narrative description of the EU additional risk minimization measures in place for this product, as required by EMA Risk Management Plan (RMP) obligations.' ;
    rdfs:domain ind:RemsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:euRiskMinimizationType rdf:type rdf:Property ;
    rdfs:label 'Eu Risk Minimization Type' ;
    rdfs:comment 'Type of equivalent EU additional risk minimization measure applicable to this product (e.g., Direct Healthcare Professional Communication (DHPC), educational material, controlled access program, pregnancy prevention program). Captured for global regulatory alignment. [ENUM-REF-CANDIDATE: dhpc|educational_material|controlled_access|pregnancy_prevention|patient_alert_card|none — promote to reference product]' ;
    rdfs:domain ind:RemsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalComplianceRatePercent rdf:type rdf:Property ;
    rdfs:label 'Goal Compliance Rate Percent' ;
    rdfs:comment 'FDA-agreed target compliance rate percentage for the REMS program, used as the benchmark against which actual compliance is measured in assessments.' ;
    rdfs:domain ind:RemsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hasCommunicationPlan rdf:type rdf:Property ;
    rdfs:label 'Has Communication Plan' ;
    rdfs:comment 'Indicates whether the REMS program includes a Communication Plan element targeting healthcare providers with safety information.' ;
    rdfs:domain ind:RemsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasEtasu rdf:type rdf:Property ;
    rdfs:label 'Has Etasu' ;
    rdfs:comment 'Indicates whether the REMS program includes Elements to Assure Safe Use (ETASU), such as prescriber certification, pharmacy certification, or patient enrollment requirements.' ;
    rdfs:domain ind:RemsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasMedicationGuide rdf:type rdf:Property ;
    rdfs:label 'Has Medication Guide' ;
    rdfs:comment 'Indicates whether the REMS program includes a Medication Guide element that must be dispensed to patients at each prescription fill.' ;
    rdfs:domain ind:RemsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labMonitoringRequired rdf:type rdf:Property ;
    rdfs:label 'Lab Monitoring Required' ;
    rdfs:comment 'Indicates whether the REMS requires mandatory laboratory testing (e.g., pregnancy tests, liver function tests) before or during product use.' ;
    rdfs:domain ind:RemsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAssessmentFdaResponseDate rdf:type rdf:Property ;
    rdfs:label 'Last Assessment Fda Response Date' ;
    rdfs:comment 'Date on which FDA provided its formal response or determination on the most recently submitted REMS assessment.' ;
    rdfs:domain ind:RemsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastAssessmentSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Last Assessment Submission Date' ;
    rdfs:comment 'Date on which the most recent REMS program assessment was submitted to FDA.' ;
    rdfs:domain ind:RemsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Modification Date' ;
    rdfs:comment 'Date on which the most recent FDA-approved modification or amendment to the REMS program was implemented.' ;
    rdfs:domain ind:RemsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modificationReason rdf:type rdf:Property ;
    rdfs:label 'Modification Reason' ;
    rdfs:comment 'Description of the reason for the most recent modification to the REMS program (e.g., new safety signal, FDA-required update, sponsor-initiated improvement).' ;
    rdfs:domain ind:RemsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientEnrollmentRequired rdf:type rdf:Property ;
    rdfs:label 'Patient Enrollment Required' ;
    rdfs:comment 'Indicates whether patients must be enrolled in the REMS program registry before receiving the product.' ;
    rdfs:domain ind:RemsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pharmacyCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Certification Required' ;
    rdfs:comment 'Indicates whether pharmacies must enroll and be certified before dispensing the product under this REMS program.' ;
    rdfs:domain ind:RemsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prescriberCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Prescriber Certification Required' ;
    rdfs:comment 'Indicates whether healthcare providers must complete a certification or training program before being authorized to prescribe the product under this REMS.' ;
    rdfs:domain ind:RemsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remsContactEmail rdf:type rdf:Property ;
    rdfs:label 'Rems Contact Email' ;
    rdfs:comment 'Email address of the sponsor\'s primary regulatory contact responsible for REMS program management and FDA communications.' ;
    rdfs:domain ind:RemsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Parent Submission Id' ;
    rdfs:comment 'Reference to the original or preceding safety report submission record when this record is a follow-up or amendment. Enables lineage tracking across submission versions for the same safety event.' ;
    rdfs:domain ind:SafetyReportSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:argusSafetyCaseReference rdf:type rdf:Property ;
    rdfs:label 'Argus Safety Case Reference' ;
    rdfs:comment 'Case identifier in Oracle Argus Safety system that is the source of the safety data underlying this submission. Provides traceability from the regulatory submission back to the adverse event case in the pharmacovigilance system of record.' ;
    rdfs:domain ind:SafetyReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:causalityAssessment rdf:type rdf:Property ;
    rdfs:label 'Causality Assessment' ;
    rdfs:comment 'Sponsor or investigator assessment of the causal relationship between the investigational product and the adverse reaction reported in this submission. Drives the reporting obligation classification.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctisNumber rdf:type rdf:Property ;
    rdfs:label 'Ctis Number' ;
    rdfs:comment 'EU Clinical Trials Information System (CTIS) authorization number under EU CTR 536/2014, replacing EudraCT for trials authorized under the new regulation. Used for SUSAR submissions via the CTIS portal.' ;
    rdfs:domain ind:SafetyReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataLockDate rdf:type rdf:Property ;
    rdfs:label 'Data Lock Date' ;
    rdfs:comment 'The date on which the safety database was locked for the purpose of generating this periodic safety report. No new safety data is included after this date. Equivalent to the reporting period end date for periodic reports.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dibd rdf:type rdf:Property ;
    rdfs:label 'Dibd' ;
    rdfs:comment 'Development International Birth Date (DIBD) — the date of the first authorization to conduct a clinical trial with the investigational product in any country. Used as the anchor date for calculating DSUR submission deadlines (due 60 days after DIBD anniversary).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expeditedReportTimelineDays rdf:type rdf:Property ;
    rdfs:label 'Expedited Report Timeline Days' ;
    rdfs:comment 'Regulatory reporting timeline in calendar days applicable to this expedited submission (typically 7 days for fatal/life-threatening unexpected SARs or 15 days for other unexpected serious adverse reactions). Null for periodic reports.' ;
    rdfs:domain ind:SafetyReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isExpedited rdf:type rdf:Property ;
    rdfs:label 'Is Expedited' ;
    rdfs:comment 'Indicates whether this safety report is an expedited submission (True) subject to 7-day or 15-day reporting timelines, as opposed to a periodic report. Expedited reports include SUSARs and IND safety reports for unexpected serious adverse reactions.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFollowUp rdf:type rdf:Property ;
    rdfs:label 'Is Follow Up' ;
    rdfs:comment 'Indicates whether this submission is a follow-up (True) to a previously submitted safety report for the same event or reporting period, as opposed to an initial/original submission (False). Follow-up submissions provide updated or additional information.' ;
    rdfs:domain ind:SafetyReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:listednessAssessment rdf:type rdf:Property ;
    rdfs:label 'Listedness Assessment' ;
    rdfs:comment 'Assessment of whether the adverse reaction is listed (expected) or unlisted (unexpected) in the current Investigator\'s Brochure (IB) or Reference Safety Information (RSI). Unlisted/unexpected reactions meeting seriousness criteria trigger SUSAR reporting obligations.' ;
    rdfs:domain ind:SafetyReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryActionDescription rdf:type rdf:Property ;
    rdfs:label 'Regulatory Action Description' ;
    rdfs:comment 'Free-text description of the regulatory action required or taken as a result of this safety report submission (e.g., IB update, protocol amendment, clinical hold notification, Dear Investigator Letter). Populated when regulatory_action_required is True.' ;
    rdfs:domain ind:SafetyReportSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryActionRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Action Required' ;
    rdfs:comment 'Indicates whether this safety report submission has triggered or requires a regulatory action such as a protocol amendment, IB update, informed consent revision, or clinical hold. Supports inspection readiness and CAPA tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Classification of the safety report being submitted. IND_SAFETY_REPORT = expedited IND safety report (15-day/7-day); DSUR = Development Safety Update Report; PSUR_PBRER = Periodic Safety Update Report / Periodic Benefit-Risk Evaluation Report; SUSAR = Suspected Unexpected Serious Adverse Reaction; IND_ANNUAL_REPORT = annual IND progress report; CIOMS = Council for International Organizations of Medical Sciences line listing.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportVersion rdf:type rdf:Property ;
    rdfs:label 'Report Version' ;
    rdfs:comment 'Version identifier of the safety report document (e.g., 1.0, 2.0, 1.1 for amendments). Tracks original submissions versus follow-up or amended versions submitted to the same agency.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'End date of the data collection period covered by this safety report, also known as the data lock point (DLP). Defines the cut-off date for safety data included in the report.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'Start date of the data collection period covered by this safety report (e.g., the beginning of the DSUR or PSUR/PBRER data lock window). Applicable to periodic reports; may be null for expedited reports.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seriousnessCriteria rdf:type rdf:Property ;
    rdfs:label 'Seriousness Criteria' ;
    rdfs:comment 'ICH E2A seriousness criterion that triggered the expedited reporting obligation for this submission. Applicable to SUSAR and IND safety reports. FATAL = resulted in death; LIFE_THREATENING = immediately life-threatening; HOSPITALIZATION = required or prolonged inpatient hospitalization; DISABILITY = persistent or significant disability/incapacity; CONGENITAL_ANOMALY = congenital anomaly/birth defect; MEDICALLY_SIGNIFICANT = other medically important condition.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialDesignationId rdf:type rdf:Property ;
    rdfs:label 'Special Designation Id' ;
    rdfs:comment 'Unique surrogate identifier for a special regulatory designation record in the Clinical Trials lakehouse silver layer.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpecialDesignation .

ind:agencyLetterDate rdf:type rdf:Property ;
    rdfs:label 'Agency Letter Date' ;
    rdfs:comment 'Date of the official agency letter communicating the designation decision (grant, denial, or revocation). Used for regulatory correspondence tracking and TMF filing in Veeva Vault.' ;
    rdfs:domain ind:SpecialDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmatoryTrialRequired rdf:type rdf:Property ;
    rdfs:label 'Confirmatory Trial Required' ;
    rdfs:comment 'Indicates whether a post-approval confirmatory clinical trial is required as a condition of the designation or approval pathway (e.g., mandatory for FDA Accelerated Approval under 21 CFR Part 314 Subpart H). Drives post-marketing commitment tracking.' ;
    rdfs:domain ind:SpecialDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:denialDate rdf:type rdf:Property ;
    rdfs:label 'Denial Date' ;
    rdfs:comment 'Calendar date on which the health authority formally denied the designation request. Null if the designation was not denied. Used to track agency response timelines and inform resubmission strategy.' ;
    rdfs:domain ind:SpecialDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:denialReason rdf:type rdf:Property ;
    rdfs:label 'Denial Reason' ;
    rdfs:comment 'Summary of the health authority\'s stated rationale for denying the designation request. Captured from the agency\'s denial letter to inform resubmission strategy and regulatory intelligence. Null if not denied.' ;
    rdfs:domain ind:SpecialDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designationConditions rdf:type rdf:Property ;
    rdfs:label 'Designation Conditions' ;
    rdfs:comment 'Free-text description of any conditions, post-designation obligations, or commitments attached to the granted designation by the health authority (e.g., annual progress reports, specific clinical milestones, post-marketing studies for Accelerated Approval). Critical for compliance tracking.' ;
    rdfs:domain ind:SpecialDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designationNumber rdf:type rdf:Property ;
    rdfs:label 'Designation Number' ;
    rdfs:comment 'Externally assigned unique reference number issued by the health authority for this special designation (e.g., FDA Orphan Drug designation number OD-XXXXXX, Breakthrough Therapy designation reference). Serves as the official business identifier for tracking and correspondence.' ;
    rdfs:domain ind:SpecialDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designationStatus rdf:type rdf:Property ;
    rdfs:label 'Designation Status' ;
    rdfs:comment 'Current lifecycle status of the special designation. Tracks the progression from initial request through agency review to grant, denial, withdrawal, or revocation. [ENUM-REF-CANDIDATE: Requested|Granted|Denied|Withdrawn|Expired|Revoked|Under Review — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designationType rdf:type rdf:Property ;
    rdfs:label 'Designation Type' ;
    rdfs:comment 'Classification of the special regulatory designation granted by the health authority. Determines the expedited development pathway and associated regulatory obligations. [ENUM-REF-CANDIDATE: Breakthrough Therapy|Fast Track|Accelerated Approval|Priority Review|Orphan Drug|PRIME|Adaptive Pathways|SAKIGAKE — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeWaiverApplicable rdf:type rdf:Property ;
    rdfs:label 'Fee Waiver Applicable' ;
    rdfs:comment 'Indicates whether the special designation confers eligibility for a regulatory fee waiver or reduction (e.g., FDA Orphan Drug designation entitles sponsors to a waiver of the NDA/BLA application user fee under PDUFA). True if fee waiver applies.' ;
    rdfs:domain ind:SpecialDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grantDate rdf:type rdf:Property ;
    rdfs:label 'Grant Date' ;
    rdfs:comment 'Calendar date on which the health authority officially granted the special designation. Null if the designation has not yet been granted. This is the principal business event date for the designation lifecycle.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketExclusivityYears rdf:type rdf:Property ;
    rdfs:label 'Market Exclusivity Years' ;
    rdfs:comment 'Number of years of market exclusivity conferred by the designation upon product approval (e.g., 7 years for FDA Orphan Drug, 10 years for EU Orphan Medicinal Product). Null for designations that do not confer market exclusivity (e.g., Breakthrough Therapy, Fast Track).' ;
    rdfs:domain ind:SpecialDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orphanDiseasePrevalence rdf:type rdf:Property ;
    rdfs:label 'Orphan Disease Prevalence' ;
    rdfs:comment 'Stated prevalence or incidence of the rare disease or condition as submitted to the health authority in support of an Orphan Drug Designation request (e.g., \'fewer than 200,000 patients in the US\' per 21 CFR Part 316, or \'≤5 in 10,000 in the EU\' per EC Regulation 141/2000). Applicable only to Orphan Drug designation type.' ;
    rdfs:domain ind:SpecialDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionPlanned rdf:type rdf:Property ;
    rdfs:label 'Resubmission Planned' ;
    rdfs:comment 'Indicates whether the sponsor plans to resubmit the designation request following a denial or withdrawal. Drives regulatory planning and resource allocation.' ;
    rdfs:domain ind:SpecialDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resubmissionTargetDate rdf:type rdf:Property ;
    rdfs:label 'Resubmission Target Date' ;
    rdfs:comment 'Planned date for resubmitting the designation request to the health authority after a denial or withdrawal. Null if resubmission is not planned or not yet scheduled.' ;
    rdfs:domain ind:SpecialDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rollingReviewEligible rdf:type rdf:Property ;
    rdfs:label 'Rolling Review Eligible' ;
    rdfs:comment 'Indicates whether the designation enables rolling review of the marketing application (submission of completed CTD modules before the full dossier is ready). Applicable to FDA Fast Track and EMA PRIME designations.' ;
    rdfs:domain ind:SpecialDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surrogateEndpointUsed rdf:type rdf:Property ;
    rdfs:label 'Surrogate Endpoint Used' ;
    rdfs:comment 'Indicates whether the designation was granted or the approval pathway relies on a surrogate or intermediate clinical endpoint rather than a traditional clinical outcome endpoint. Relevant for Accelerated Approval and Breakthrough Therapy designations.' ;
    rdfs:domain ind:SpecialDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxCreditApplicable rdf:type rdf:Property ;
    rdfs:label 'Tax Credit Applicable' ;
    rdfs:comment 'Indicates whether the designation qualifies the sponsor for the Orphan Drug Tax Credit (50% of qualified clinical testing expenses in the US under IRC Section 45C). Applicable only to FDA Orphan Drug designations.' ;
    rdfs:domain ind:SpecialDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:strategyId rdf:type rdf:Property ;
    rdfs:label 'Strategy Id' ;
    rdfs:comment 'Primary key for strategy' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adaptivePathwayApplicable rdf:type rdf:Property ;
    rdfs:label 'Adaptive Pathway Applicable' ;
    rdfs:comment 'Indicates whether an adaptive licensing or adaptive pathway approach (EMA Adaptive Pathways Pilot, FDA Accelerated Approval) is incorporated into this regulatory strategy, allowing staged approval based on interim data.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agencyInteractionPlan rdf:type rdf:Property ;
    rdfs:label 'Agency Interaction Plan' ;
    rdfs:comment 'Narrative description of planned agency interactions (e.g., Pre-IND meeting, Type B End-of-Phase 2 meeting, Pre-NDA meeting, Scientific Advice, PRIME eligibility request) including meeting types, timing, and objectives as documented in the strategy.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveLandscapeNotes rdf:type rdf:Property ;
    rdfs:label 'Competitive Landscape Notes' ;
    rdfs:comment 'Confidential notes on the competitive regulatory landscape including competitor approval timelines, orphan drug designations, patent cliffs, and market exclusivity considerations that influence the regulatory strategy.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctdEctdFormatRequired rdf:type rdf:Property ;
    rdfs:label 'Ctd Ectd Format Required' ;
    rdfs:comment 'Indicates whether the submission dossier must be prepared in CTD/eCTD format as required by ICH M4 and the target agencies. True for most major agency submissions (FDA, EMA, PMDA); may be False for certain early-phase or regional submissions.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:healthAuthorityScientificAdvicePlanned rdf:type rdf:Property ;
    rdfs:label 'Health Authority Scientific Advice Planned' ;
    rdfs:comment 'Indicates whether formal scientific advice or protocol assistance from a health authority (e.g., EMA Scientific Advice, FDA Formal Meeting) is planned as part of this regulatory strategy.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyRegulatoryRisks rdf:type rdf:Property ;
    rdfs:label 'Key Regulatory Risks' ;
    rdfs:comment 'Narrative summary of identified regulatory risks that could impact approval timelines or probability of success (e.g., unresolved safety signals, insufficient efficacy data, CMC concerns, precedent gaps). Supports risk-based regulatory planning.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meddraIndicationCode rdf:type rdf:Property ;
    rdfs:label 'Meddra Indication Code' ;
    rdfs:comment 'MedDRA Preferred Term (PT) code corresponding to the target indication, enabling standardized cross-study and cross-agency reporting and signal detection alignment.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pediatricInvestigationPlanRequired rdf:type rdf:Property ;
    rdfs:label 'Pediatric Investigation Plan Required' ;
    rdfs:comment 'Indicates whether a Pediatric Investigation Plan (EMA PIP) or Pediatric Study Plan (FDA PSP) is required as part of this regulatory strategy, per pediatric regulatory obligations.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Planned Approval Date' ;
    rdfs:comment 'Anticipated date of regulatory approval from the lead agency based on standard or expedited review timelines. Used for commercial launch planning and portfolio milestone tracking.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedIndSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Ind Submission Date' ;
    rdfs:comment 'Target date for submission of the IND application to the FDA as planned in this regulatory strategy. Drives pre-IND meeting scheduling and CMC/nonclinical package readiness timelines.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedNdaBlaMaaSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Nda Bla Maa Submission Date' ;
    rdfs:comment 'Target date for submission of the marketing authorization application (NDA, BLA, or MAA) as planned in this regulatory strategy. Key milestone for program planning and resource allocation.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryPrecedents rdf:type rdf:Property ;
    rdfs:label 'Regulatory Precedents' ;
    rdfs:comment 'Summary of relevant regulatory precedents from previously approved products in the same therapeutic class or indication that inform the strategy (e.g., approved comparators, agency guidance documents, advisory committee outcomes).' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remsRequired rdf:type rdf:Property ;
    rdfs:label 'Rems Required' ;
    rdfs:comment 'Indicates whether a Risk Evaluation and Mitigation Strategy (REMS) is anticipated or required by FDA as a condition of approval, based on the safety profile of the investigational product.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rollingReviewPlanned rdf:type rdf:Property ;
    rdfs:label 'Rolling Review Planned' ;
    rdfs:comment 'Indicates whether a rolling review submission strategy is planned, allowing completed sections of the dossier to be submitted to the agency before the full application is complete. Applicable for FDA Fast Track and EMA Rolling Review.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:strategyCode rdf:type rdf:Property ;
    rdfs:label 'Strategy Code' ;
    rdfs:comment 'Externally-known, human-readable unique code assigned to this regulatory strategy document within the Veeva Vault regulatory submissions module (e.g., REG-STR-2024-0042). Used for cross-system referencing and TMF indexing.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyStatus rdf:type rdf:Property ;
    rdfs:label 'Strategy Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory strategy document. Tracks progression from initial drafting through internal review, formal approval, and eventual supersession or retirement when a new version is issued.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionSequenceStrategy rdf:type rdf:Property ;
    rdfs:label 'Submission Sequence Strategy' ;
    rdfs:comment 'Planned sequencing approach for multi-regional submissions: simultaneous (all agencies at once), sequential lead-first (lead agency then others), rolling (submit sections as available), or staggered (phased by region). Drives submission timeline planning.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAgencies rdf:type rdf:Property ;
    rdfs:label 'Target Agencies' ;
    rdfs:comment 'Comma-separated list of all global health authorities targeted for submission under this strategy (e.g., \'FDA, EMA, PMDA, MHRA, Health Canada\'). Supports multi-regional submission planning and sequencing.' ;
    rdfs:domain ind:Strategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submitterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Submitter Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: The regulatory affairs employee who prepares and submits dossiers must be traceable for submission workload reporting, audit trails, and GCP inspection readiness. \'regulatory_contact_name\' is a denorm' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agencyAcknowledgementNumber rdf:type rdf:Property ;
    rdfs:label 'Agency Acknowledgement Number' ;
    rdfs:comment 'Official reference number or acknowledgement identifier issued by the health authority upon receipt of the submission (e.g., FDA STN number, EMA submission number). Used for all subsequent agency correspondence.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyDecision rdf:type rdf:Property ;
    rdfs:label 'Agency Decision' ;
    rdfs:comment 'The formal regulatory decision issued by the health authority in response to this submission (e.g., approved, complete response letter (CRL), refuse to file (RTF), approvable, not approvable, withdrawn). Drives downstream regulatory strategy. [ENUM-REF-CANDIDATE: approved|complete_response|refuse_to_file|approvable|not_approvable|withdrawn|pending — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverLetterTitle rdf:type rdf:Property ;
    rdfs:label 'Cover Letter Title' ;
    rdfs:comment 'The official title or subject line of the cover letter accompanying this submission, as filed with the health authority. Provides a human-readable summary of the submission purpose for regulatory correspondence tracking.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugProductName rdf:type rdf:Property ;
    rdfs:label 'Drug Product Name' ;
    rdfs:comment 'The proprietary or non-proprietary name of the investigational drug, biologic, or device that is the subject of this regulatory submission. Provides direct product context for the submission record.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ectdOperation rdf:type rdf:Property ;
    rdfs:label 'Ectd Operation' ;
    rdfs:comment 'The eCTD lifecycle operation applied to documents in this submission sequence: new (first submission of a document), replace (supersedes a prior version), append (adds to an existing document), or delete (removes a document from the dossier). Governs dossier evolution per ICH M8.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingFeePaid rdf:type rdf:Property ;
    rdfs:label 'Filing Fee Paid' ;
    rdfs:comment 'Indicates whether the applicable regulatory filing fee (e.g., FDA PDUFA application fee, EMA fee) has been paid for this submission. Non-payment can result in refuse-to-file action.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isResubmission rdf:type rdf:Property ;
    rdfs:label 'Is Resubmission' ;
    rdfs:comment 'Indicates whether this submission is a resubmission following a prior agency rejection, complete response letter (CRL), or refuse-to-file (RTF) action. Triggers specific regulatory review timelines under PDUFA.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Prior Sequence Number' ;
    rdfs:comment 'The eCTD sequence number of the immediately preceding submission in the dossier lifecycle that this submission amends, replaces, or responds to. Enables reconstruction of the full dossier evolution chain.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'Narrative or coded reason for this submission event (e.g., initial IND filing, protocol amendment for safety update, response to FDA information request, annual IND report, post-approval labeling change). Provides business context for the submission trigger.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryProcedureType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Procedure Type' ;
    rdfs:comment 'Specific regulatory procedure under which this submission is filed (e.g., standard review, priority review, accelerated approval, breakthrough therapy, orphan drug, centralized procedure, mutual recognition procedure, decentralized procedure). [ENUM-REF-CANDIDATE: standard_review|priority_review|accelerated_approval|breakthrough_therapy|orphan_drug|centralized|mutual_recognition|decentralized|rolling_review — promote to reference product]' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetActionDate rdf:type rdf:Property ;
    rdfs:label 'Target Action Date' ;
    rdfs:comment 'The regulatory deadline by which the health authority is expected to take action on the submission (e.g., PDUFA goal date for FDA NDA/BLA reviews, EMA opinion deadline). Critical for regulatory milestone tracking and resource planning.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionContentUnitId rdf:type rdf:Property ;
    rdfs:label 'Submission Content Unit Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual content unit (document, dataset, or study report) included within a CTD/eCTD submission sequence. Primary key for this entity.' ;
    rdfs:domain ind:Regulatory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SubmissionContentUnit .

ind:veevaVaultVersionId rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Version Id' ;
    rdfs:comment 'Specific version identifier of the document in Veeva Vault at the time it was included in this submission sequence. Ensures the exact approved version is captured for audit and regulatory traceability.' ;
    rdfs:domain ind:SubmissionContentUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Version .

ind:cdiscStandard rdf:type rdf:Property ;
    rdfs:label 'Cdisc Standard' ;
    rdfs:comment 'CDISC data standard applicable to this content unit when the document type is a dataset or define file (e.g., SDTM for tabulation datasets, ADaM for analysis datasets, SEND for nonclinical datasets, define-xml for data definitions). Blank for non-dataset documents.' ;
    rdfs:domain ind:SubmissionContentUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdiscVersion rdf:type rdf:Property ;
    rdfs:label 'Cdisc Version' ;
    rdfs:comment 'Version of the CDISC standard applied to this dataset content unit (e.g., SDTM 3.3, ADaM 1.3). Required for FDA and EMA dataset submissions to ensure conformance with the declared standard version.' ;
    rdfs:domain ind:SubmissionContentUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentNotes rdf:type rdf:Property ;
    rdfs:label 'Content Notes' ;
    rdfs:comment 'Free-text notes or comments regarding this content unit, such as rationale for document inclusion, known limitations, pending updates, or agency-specific instructions. Used by regulatory affairs teams for dossier management.' ;
    rdfs:domain ind:SubmissionContentUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentUnitNumber rdf:type rdf:Property ;
    rdfs:label 'Content Unit Number' ;
    rdfs:comment 'Externally-known unique business identifier for this content unit within the submission sequence, typically assigned by the publishing tool (e.g., Lorenz docuBridge, Extedo eCTD Manager) or Veeva Vault. Used for cross-referencing in cover letters and agency correspondence.' ;
    rdfs:domain ind:SubmissionContentUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filePath rdf:type rdf:Property ;
    rdfs:label 'File Path' ;
    rdfs:comment 'Relative file path of the content unit within the eCTD submission folder structure (e.g., m5/53-clin-stud-rep/535-rep-effic-safety-stud/5351-stud-rep-uncontrol/). Used for dossier navigation and publishing validation.' ;
    rdfs:domain ind:SubmissionContentUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Size of the content unit file in bytes. Used for submission package size validation, agency gateway transmission compliance, and storage management. Agencies impose maximum file size limits for electronic submissions.' ;
    rdfs:domain ind:SubmissionContentUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gapAnalysisFlag rdf:type rdf:Property ;
    rdfs:label 'Gap Analysis Flag' ;
    rdfs:comment 'Indicates whether this content unit has been identified as a gap (missing or incomplete) during dossier gap analysis. When True, the CTD section requires a new or updated document before submission can proceed.' ;
    rdfs:domain ind:SubmissionContentUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Included Timestamp' ;
    rdfs:comment 'Date and time when this content unit was formally included in the submission sequence package, as recorded by the publishing tool or Veeva Vault. Represents the principal business event time for this transaction line.' ;
    rdfs:domain ind:SubmissionContentUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isBookmarked rdf:type rdf:Property ;
    rdfs:label 'Is Bookmarked' ;
    rdfs:comment 'Indicates whether this PDF content unit contains required PDF bookmarks as mandated by agency technical specifications. Bookmark compliance is validated during eCTD technical review.' ;
    rdfs:domain ind:SubmissionContentUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHyperlinked rdf:type rdf:Property ;
    rdfs:label 'Is Hyperlinked' ;
    rdfs:comment 'Indicates whether this content unit contains internal eCTD hyperlinks to other documents within the dossier. Hyperlink integrity is a key validation criterion for FDA and EMA submissions.' ;
    rdfs:domain ind:SubmissionContentUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSearchablePdf rdf:type rdf:Property ;
    rdfs:label 'Is Searchable Pdf' ;
    rdfs:comment 'Indicates whether this PDF content unit is text-searchable (OCR-processed or natively digital), as required by FDA and EMA for narrative documents submitted in PDF format.' ;
    rdfs:domain ind:SubmissionContentUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leafIdentifier rdf:type rdf:Property ;
    rdfs:label 'Leaf Identifier' ;
    rdfs:comment 'Unique XML leaf element identifier assigned to this content unit within the eCTD backbone XML file. Used for cross-referencing between eCTD sequences and for lifecycle operations (replace/delete) that reference prior leaf IDs.' ;
    rdfs:domain ind:SubmissionContentUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorLeafIdentifier rdf:type rdf:Property ;
    rdfs:label 'Prior Leaf Identifier' ;
    rdfs:comment 'Leaf ID of the previously submitted content unit that this document replaces, appends, or deletes. Required for eCTD lifecycle operations to maintain document lineage across submission sequences.' ;
    rdfs:domain ind:SubmissionContentUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAgencyCode rdf:type rdf:Property ;
    rdfs:label 'Target Agency Code' ;
    rdfs:comment 'Code identifying the health authority for which this content unit is specifically prepared or applicable (e.g., FDA, EMA, PMDA). Some documents are agency-specific (e.g., Module 1 administrative documents differ by region). [ENUM-REF-CANDIDATE: FDA|EMA|PMDA|MHRA|HC|TGA|ANVISA|NMPA — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SubmissionContentUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Validation Error Message' ;
    rdfs:comment 'Descriptive error or warning message returned by the eCTD validation tool or agency gateway when validation_status is \'failed\' or \'warning\'. Used for remediation and resubmission planning.' ;
    rdfs:domain ind:SubmissionContentUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionSequenceId rdf:type rdf:Property ;
    rdfs:label 'Submission Sequence Id' ;
    rdfs:comment 'Unique surrogate identifier for each eCTD submission sequence record within the regulatory application dossier.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:veevaVaultSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Submission Id' ;
    rdfs:comment 'External identifier of this submission sequence record within Veeva Vault RIM Submissions module, the system of record for regulatory dossier management. Enables cross-system traceability between the lakehouse silver layer and the operational eTMF/RIM system.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:ctdSectionList rdf:type rdf:Property ;
    rdfs:label 'Ctd Section List' ;
    rdfs:comment 'Comma-delimited list of specific CTD section identifiers (e.g., \'3.2.P.1, 3.2.P.2, 5.3.5.1\') included or modified in this submission sequence. Enables granular tracking of which dossier sections evolved with each sequence.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierPackageName rdf:type rdf:Property ;
    rdfs:label 'Dossier Package Name' ;
    rdfs:comment 'Human-readable name or label assigned to the eCTD submission package for this sequence (e.g., \'NDA 123456 Seq 0012 — CMC Amendment\'). Used for identification in Veeva Vault and internal tracking systems.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dossierPackageSizeMb rdf:type rdf:Property ;
    rdfs:label 'Dossier Package Size Mb' ;
    rdfs:comment 'Total file size in megabytes of the eCTD submission package for this sequence. Used for submission gateway capacity planning and agency file size compliance checks.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ectdValidationDate rdf:type rdf:Property ;
    rdfs:label 'Ectd Validation Date' ;
    rdfs:comment 'Date on which the eCTD technical validation was performed for this submission sequence. Used to confirm validation was completed prior to submission deadline.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ectdValidationErrorCount rdf:type rdf:Property ;
    rdfs:label 'Ectd Validation Error Count' ;
    rdfs:comment 'Total number of technical validation errors identified during eCTD validation of this submission sequence. A value of zero is required for a passing validation status.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ectdValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Ectd Validation Status' ;
    rdfs:comment 'Result of the eCTD technical validation check performed against the agency\'s published validation criteria prior to or upon submission. \'pass\' indicates full conformance; \'warning\' indicates non-critical issues; \'fail\' indicates the sequence was rejected for technical non-conformance.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ectdValidationTool rdf:type rdf:Property ;
    rdfs:label 'Ectd Validation Tool' ;
    rdfs:comment 'Name and version of the eCTD validation software used to validate this submission sequence (e.g., \'Lorenz docuBridge v5.2\', \'Extedo eCTD Manager v8.1\', \'Veeva Vault RIM Submissions v23.1\'). Required for audit trail and reproducibility.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ectdValidationWarningCount rdf:type rdf:Property ;
    rdfs:label 'Ectd Validation Warning Count' ;
    rdfs:comment 'Total number of non-critical technical validation warnings identified during eCTD validation of this submission sequence. Warnings do not block submission but must be reviewed and justified.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewClockStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Clock Start Date' ;
    rdfs:comment 'Date on which the regulatory authority\'s formal review clock begins for this submission sequence (e.g., PDUFA Day 1 for FDA, Day 0 for EMA). Derived from agency acknowledgement and used for PDUFA/review deadline tracking.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewClockTargetDate rdf:type rdf:Property ;
    rdfs:label 'Review Clock Target Date' ;
    rdfs:comment 'Target date by which the regulatory authority is expected to complete review of this submission sequence, calculated from the review clock start date per applicable PDUFA or EMA timelines. Critical for regulatory milestone planning.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionSubtype rdf:type rdf:Property ;
    rdfs:label 'Submission Subtype' ;
    rdfs:comment 'Further classification of the submission type providing regulatory-specific granularity (e.g., Prior Approval Supplement, Changes Being Effected, Complete Response, Major Amendment, Minor Amendment). [ENUM-REF-CANDIDATE: prior_approval_supplement|changes_being_effected|complete_response|major_amendment|minor_amendment|annual_report — promote to reference product]' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionUnit rdf:type rdf:Property ;
    rdfs:label 'Submission Unit' ;
    rdfs:comment 'The specific regulatory submission unit or grouping within the eCTD backbone that this sequence belongs to (e.g., \'IND Safety Report\', \'NDA Module 5 Clinical Study Report\', \'BLA CMC Supplement\'). Aligns with Veeva Vault RIM submission unit taxonomy.' ;
    rdfs:domain ind:SubmissionSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionTaken rdf:type rdf:Property ;
    rdfs:label 'Action Taken' ;
    rdfs:comment 'Action taken with the investigational product in response to the adverse event, as recorded by the investigator. Drives dose modification tracking and safety signal analysis.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeStatus rdf:type rdf:Property ;
    rdfs:label 'Ae Status' ;
    rdfs:comment 'Current lifecycle status of the adverse event record, reflecting whether the event is still active, has resolved, or resulted in death. Drives workflow routing in Oracle Argus Safety and expedited reporting decisions.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeTermVerbatim rdf:type rdf:Property ;
    rdfs:label 'Ae Term Verbatim' ;
    rdfs:comment 'The exact verbatim text of the adverse event as reported by the investigator or subject on the eCRF, prior to MedDRA coding. Preserved for ALCOA+ compliance and audit trail integrity.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:argusCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Argus Case Number' ;
    rdfs:comment 'Externally-known case identifier assigned by Oracle Argus Safety upon initial AE entry. This is the business-facing identifier used in regulatory submissions, safety narratives, and cross-system reconciliation with the source system of record.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awarenessDate rdf:type rdf:Property ;
    rdfs:label 'Awareness Date' ;
    rdfs:comment 'The date on which the sponsor (or CRO acting on behalf of the sponsor) first became aware of the adverse event. This is the clock-start date for regulatory expedited reporting timelines per ICH E2A.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:concomitantMedicationRelated rdf:type rdf:Property ;
    rdfs:label 'Concomitant Medication Related' ;
    rdfs:comment 'Indicates whether the adverse event may be related to concomitant medications taken by the subject, as assessed by the investigator. Supports differential causality analysis and confounding factor assessment.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ctcaeGrade rdf:type rdf:Property ;
    rdfs:label 'Ctcae Grade' ;
    rdfs:comment 'Severity grade assigned per the National Cancer Institute Common Terminology Criteria for Adverse Events (CTCAE), ranging from 1 (mild) to 5 (death). The primary severity measure used in oncology and other therapeutic areas for safety reporting and DSMB/DMC reviews.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dsmbReported rdf:type rdf:Property ;
    rdfs:label 'Dsmb Reported' ;
    rdfs:comment 'Indicates whether this adverse event has been reported to the Data Safety Monitoring Board (DSMB) or Data Monitoring Committee (DMC) for independent safety review. Supports DSMB/DMC meeting preparation and safety oversight documentation.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:edcSubjectSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Edc Subject Sequence Number' ;
    rdfs:comment 'The AE sequence number assigned within the EDC system (Medidata Rave eCRF) for the subject, used to reconcile the safety database record with the source eCRF entry during SDV and data review.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExpected rdf:type rdf:Property ;
    rdfs:label 'Is Expected' ;
    rdfs:comment 'Indicates whether the adverse event is listed in the current Investigator\'s Brochure (IB) or product labeling as an expected/anticipated reaction. Unexpected serious adverse reactions trigger SUSAR reporting obligations.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSerious rdf:type rdf:Property ;
    rdfs:label 'Is Serious' ;
    rdfs:comment 'Indicates whether the adverse event meets the regulatory definition of a Serious Adverse Event (SAE) per ICH E2A criteria (death, life-threatening, hospitalization, disability, congenital anomaly, or other medically important condition). Triggers expedited regulatory reporting obligations.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSusar rdf:type rdf:Property ;
    rdfs:label 'Is Susar' ;
    rdfs:comment 'Indicates whether this adverse event has been classified as a Suspected Unexpected Serious Adverse Reaction (SUSAR), requiring expedited regulatory reporting to health authorities (FDA, EMA, MHRA, etc.) within defined timelines (7 or 15 calendar days).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTeae rdf:type rdf:Property ;
    rdfs:label 'Is Teae' ;
    rdfs:comment 'Indicates whether the adverse event is treatment-emergent, defined as an event that first occurred or worsened in severity after the first dose of investigational product. Used in TEAE incidence tables in the CSR and SAP-defined safety analyses.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meddraLltCode rdf:type rdf:Property ;
    rdfs:label 'Meddra Llt Code' ;
    rdfs:comment 'MedDRA Lowest Level Term (LLT) numeric code assigned during medical coding, representing the most granular level of the MedDRA hierarchy closest to the verbatim term.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meddraLltName rdf:type rdf:Property ;
    rdfs:label 'Meddra Llt Name' ;
    rdfs:comment 'MedDRA Lowest Level Term (LLT) text description corresponding to the LLT code. Used in safety listings, narratives, and regulatory submissions.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalHistoryRelated rdf:type rdf:Property ;
    rdfs:label 'Medical History Related' ;
    rdfs:comment 'Indicates whether the adverse event is considered related to or a continuation of a pre-existing medical history condition, as assessed by the investigator. Supports pre-existing condition confounding analysis.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:narrative rdf:type rdf:Property ;
    rdfs:label 'Narrative' ;
    rdfs:comment 'Free-text medical narrative describing the clinical course of the adverse event, including relevant medical history, treatment, and outcome. Required for SAE/SUSAR regulatory submissions and DSMB/DMC safety reviews.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onsetDate rdf:type rdf:Property ;
    rdfs:label 'Onset Date' ;
    rdfs:comment 'The date on which the adverse event first began, as reported by the investigator. This is the principal real-world event date used for duration calculations, expedited reporting timelines, and TEAE determination.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Due Date' ;
    rdfs:comment 'The deadline by which an expedited safety report (e.g., SUSAR, IND Safety Report) must be submitted to the relevant health authority. Calculated from the date of first awareness per ICH E2A timelines (7-day for fatal/life-threatening, 15-day for other SUSARs).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submitted Date' ;
    rdfs:comment 'The actual date on which the expedited safety report was submitted to the health authority. Used to calculate compliance with regulatory reporting timelines and track submission performance KPIs.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyDayOnset rdf:type rdf:Property ;
    rdfs:label 'Study Day Onset' ;
    rdfs:comment 'The study day (relative to first dose date) on which the adverse event began. Calculated per CDISC convention (Day 1 = first dose date). Used in time-to-event analyses and safety exposure-adjusted incidence calculations.' ;
    rdfs:domain ind:AdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aeFollowUpId rdf:type rdf:Property ;
    rdfs:label 'Ae Follow Up Id' ;
    rdfs:comment 'Unique surrogate identifier for each adverse event follow-up record in the Silver layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:argusFollowUpCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Argus Follow Up Case Number' ;
    rdfs:comment 'The follow-up case number assigned by Oracle Argus Safety for this follow-up iteration, used to track the follow-up submission within the pharmacovigilance system.' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalDetailsNarrative rdf:type rdf:Property ;
    rdfs:label 'Clinical Details Narrative' ;
    rdfs:comment 'Free-text narrative describing the new or updated clinical information provided in this follow-up, including any additional diagnostic findings, treatment changes, or clinical course updates. Used in ICSR narrative construction.' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dechallengeResult rdf:type rdf:Property ;
    rdfs:label 'Dechallenge Result' ;
    rdfs:comment 'Updated result of dechallenge (withdrawal of the investigational product) as reported in this follow-up — whether the adverse event improved or resolved after stopping the drug. Key input to causality assessment.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcFollowUpFormReference rdf:type rdf:Property ;
    rdfs:label 'Edc Follow Up Form Reference' ;
    rdfs:comment 'Identifier of the follow-up eCRF (Electronic Case Report Form) entry in Medidata Rave EDC that corresponds to this follow-up record, enabling traceability between the lakehouse and the source EDC system.' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expeditedReportRequired rdf:type rdf:Property ;
    rdfs:label 'Expedited Report Required' ;
    rdfs:comment 'Indicates whether this follow-up triggers an expedited regulatory report (7-day or 15-day ICSR) to health authorities based on updated seriousness, causality, or SUSAR status.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Date' ;
    rdfs:comment 'The calendar date on which the follow-up information was received or documented by the sponsor or CRO. This is the principal real-world event date for this follow-up record.' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Follow Up Sequence Number' ;
    rdfs:comment 'Sequential number indicating the order of this follow-up relative to other follow-ups for the same adverse event (e.g., 1 = first follow-up, 2 = second follow-up). Supports chronological ordering of clinical updates.' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followUpStatus rdf:type rdf:Property ;
    rdfs:label 'Follow Up Status' ;
    rdfs:comment 'Current workflow status of this follow-up record within Oracle Argus Safety and the regulatory submission pipeline.' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpType rdf:type rdf:Property ;
    rdfs:label 'Follow Up Type' ;
    rdfs:comment 'Categorizes the primary nature of the information being updated in this follow-up record (e.g., new clinical details, revised outcome, updated causality assessment). [ENUM-REF-CANDIDATE: clinical_update|outcome_update|causality_update|regulatory_update|narrative_update — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hospitalizationEndDate rdf:type rdf:Property ;
    rdfs:label 'Hospitalization End Date' ;
    rdfs:comment 'Date on which the subject was discharged from hospitalization related to the adverse event, as reported or updated in this follow-up. Null if still hospitalized.' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hospitalizationStartDate rdf:type rdf:Property ;
    rdfs:label 'Hospitalization Start Date' ;
    rdfs:comment 'Date on which the subject was hospitalized due to the adverse event, as reported or updated in this follow-up. Relevant when hospitalization is a seriousness criterion.' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigatorAssessment rdf:type rdf:Property ;
    rdfs:label 'Investigator Assessment' ;
    rdfs:comment 'Free-text summary of the Principal Investigator\'s (PI) updated clinical assessment of the adverse event as provided in this follow-up, including any revised diagnosis or clinical interpretation.' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rechallengeResult rdf:type rdf:Property ;
    rdfs:label 'Rechallenge Result' ;
    rdfs:comment 'Updated result of rechallenge (re-administration of the investigational product) as reported in this follow-up — whether the adverse event recurred upon re-exposure. Key input to causality assessment.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Deadline Date' ;
    rdfs:comment 'Calculated deadline date by which the follow-up ICSR must be submitted to the applicable regulatory authority, based on the awareness date and applicable reporting timeline (7 or 15 calendar days).' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:updatedActionTaken rdf:type rdf:Property ;
    rdfs:label 'Updated Action Taken' ;
    rdfs:comment 'Revised action taken with the investigational product in response to the adverse event as reported in this follow-up (e.g., dose reduced, drug withdrawn). Aligns with ICH E2B(R3) field C.2.r.4.' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedAeTermVerbatim rdf:type rdf:Property ;
    rdfs:label 'Updated Ae Term Verbatim' ;
    rdfs:comment 'Revised verbatim (as-reported) term for the adverse event as provided by the investigator in this follow-up, prior to MedDRA coding. May differ from the original term if the clinical picture has evolved.' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedCausalityAssessment rdf:type rdf:Property ;
    rdfs:label 'Updated Causality Assessment' ;
    rdfs:comment 'Revised causality relationship between the investigational product and the adverse event as determined in this follow-up, per WHO causality assessment criteria.' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedCtcaeGrade rdf:type rdf:Property ;
    rdfs:label 'Updated Ctcae Grade' ;
    rdfs:comment 'Revised severity grade assigned to the adverse event in this follow-up, per the NCI Common Terminology Criteria for Adverse Events (CTCAE). Grade 1=Mild, 2=Moderate, 3=Severe, 4=Life-threatening, 5=Death.' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedExpectedness rdf:type rdf:Property ;
    rdfs:label 'Updated Expectedness' ;
    rdfs:comment 'Revised assessment of whether the adverse event is expected (listed in the Investigator\'s Brochure or product labeling) as of this follow-up. Expectedness is a key determinant of SUSAR classification.' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedIsSerious rdf:type rdf:Property ;
    rdfs:label 'Updated Is Serious' ;
    rdfs:comment 'Revised determination of whether the adverse event meets ICH E2A seriousness criteria as of this follow-up. A change from non-serious to serious triggers expedited regulatory reporting obligations.' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:updatedIsSusar rdf:type rdf:Property ;
    rdfs:label 'Updated Is Susar' ;
    rdfs:comment 'Revised determination of whether the adverse event qualifies as a Suspected Unexpected Serious Adverse Reaction (SUSAR) as of this follow-up. A change to SUSAR status triggers expedited 7-day or 15-day reporting obligations.' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:updatedMeddraPtCode rdf:type rdf:Property ;
    rdfs:label 'Updated Meddra Pt Code' ;
    rdfs:comment 'Revised MedDRA Preferred Term (PT) code assigned to the adverse event in this follow-up, reflecting any re-coding based on updated clinical information.' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedMeddraPtName rdf:type rdf:Property ;
    rdfs:label 'Updated Meddra Pt Name' ;
    rdfs:comment 'Revised MedDRA Preferred Term (PT) name corresponding to the updated PT code assigned in this follow-up.' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedMeddraSocCode rdf:type rdf:Property ;
    rdfs:label 'Updated Meddra Soc Code' ;
    rdfs:comment 'Revised MedDRA System Organ Class (SOC) code for the adverse event as re-coded in this follow-up.' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedMeddraSocName rdf:type rdf:Property ;
    rdfs:label 'Updated Meddra Soc Name' ;
    rdfs:comment 'Revised MedDRA System Organ Class (SOC) name corresponding to the updated SOC code assigned in this follow-up.' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedOutcome rdf:type rdf:Property ;
    rdfs:label 'Updated Outcome' ;
    rdfs:comment 'Revised outcome status of the adverse event as reported in this follow-up, reflecting the subject\'s current clinical condition relative to the event.' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedSeriousnessCriteria rdf:type rdf:Property ;
    rdfs:label 'Updated Seriousness Criteria' ;
    rdfs:comment 'Revised seriousness criteria met by the adverse event as of this follow-up (e.g., death, life-threatening, hospitalization, disability, congenital anomaly, medically significant). May be a pipe-delimited list of applicable criteria. [ENUM-REF-CANDIDATE: death|life_threatening|hospitalization|prolonged_hospitalization|disability|congenital_anomaly|medically_significant — promote to reference product]' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedSeverity rdf:type rdf:Property ;
    rdfs:label 'Updated Severity' ;
    rdfs:comment 'Updated narrative severity classification of the adverse event as assessed at the time of this follow-up, aligned with ICH E2A severity definitions.' ;
    rdfs:domain ind:AeFollowUp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeMeddraCodingId rdf:type rdf:Property ;
    rdfs:label 'Ae Meddra Coding Id' ;
    rdfs:comment 'Unique surrogate identifier for each MedDRA coding record assigned to an adverse event. Primary key for the ae_meddra_coding data product in the safety domain.' ;
    rdfs:domain ind:AeMeddraCoding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Ae Employee Id' ;
    rdfs:comment 'Reference to the user (medical coder or safety scientist) who assigned or confirmed the MedDRA code. Supports attributability requirements under ALCOA+ and 21 CFR Part 11 electronic signature traceability.' ;
    rdfs:domain ind:AeMeddraCoding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryAeCoderEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Ae Coder Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:AeMeddraCoding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:argusCaseReference rdf:type rdf:Property ;
    rdfs:label 'Argus Case Reference' ;
    rdfs:comment 'The case identifier from Oracle Argus Safety that corresponds to this MedDRA coding record. Serves as the source system business key for traceability back to the originating safety case in the system of record.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:argusEventReference rdf:type rdf:Property ;
    rdfs:label 'Argus Event Reference' ;
    rdfs:comment 'The event-level identifier from Oracle Argus Safety for the specific adverse event record within a case that this MedDRA coding applies to. Enables precise traceability to the source system event record.' ;
    rdfs:domain ind:AeMeddraCoding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codedDate rdf:type rdf:Property ;
    rdfs:label 'Coded Date' ;
    rdfs:comment 'Calendar date on which the MedDRA code was assigned to the verbatim adverse event term. Used for coding timeliness metrics and regulatory submission audit trails.' ;
    rdfs:domain ind:AeMeddraCoding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:codedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Coded Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone) at which the MedDRA code was assigned. Provides granular audit trail for 21 CFR Part 11 electronic records compliance. Sourced from Oracle Argus Safety system timestamp.' ;
    rdfs:domain ind:AeMeddraCoding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:codingComment rdf:type rdf:Property ;
    rdfs:label 'Coding Comment' ;
    rdfs:comment 'Free-text comment entered by the coder to document coding rationale, ambiguities, or special considerations for this MedDRA assignment. Supports coding consistency reviews and regulatory inspection readiness.' ;
    rdfs:domain ind:AeMeddraCoding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Date' ;
    rdfs:comment 'Date on which the MedDRA coding assignment was confirmed (QC-approved) by a second reviewer or coding supervisor. Null if coding has not yet been confirmed. Supports dual-coder QC workflows.' ;
    rdfs:domain ind:AeMeddraCoding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dictionaryLanguage rdf:type rdf:Property ;
    rdfs:label 'Dictionary Language' ;
    rdfs:comment 'Three-letter ISO 639-2 language code of the MedDRA dictionary used for coding (e.g., \'ENG\' for English, \'JPN\' for Japanese). Relevant for multi-regional studies where local language MedDRA versions may be used (e.g., PMDA submissions in Japan).' ;
    rdfs:domain ind:AeMeddraCoding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hlgtCode rdf:type rdf:Property ;
    rdfs:label 'Hlgt Code' ;
    rdfs:comment 'Eight-digit MedDRA numeric code for the High Level Group Term (HLGT), which sits between the HLT and SOC in the MedDRA hierarchy. Used for broad safety grouping in regulatory submissions.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hlgtName rdf:type rdf:Property ;
    rdfs:label 'Hlgt Name' ;
    rdfs:comment 'Descriptive text of the MedDRA High Level Group Term (HLGT) corresponding to hlgt_code. Supports broad-level safety grouping in aggregate analyses and CSR appendices.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hltCode rdf:type rdf:Property ;
    rdfs:label 'Hlt Code' ;
    rdfs:comment 'Eight-digit MedDRA numeric code for the High Level Term (HLT) in the MedDRA hierarchy above the PT. Used for grouping related PTs in aggregate safety analyses and signal detection.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hltName rdf:type rdf:Property ;
    rdfs:label 'Hlt Name' ;
    rdfs:comment 'Descriptive text of the MedDRA High Level Term (HLT) corresponding to hlt_code. Supports mid-level grouping in safety tabulations and DSMB/DMC review packages.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSae rdf:type rdf:Property ;
    rdfs:label 'Is Sae' ;
    rdfs:comment 'Indicates whether the adverse event associated with this MedDRA coding record meets the regulatory definition of a Serious Adverse Event (SAE) per ICH E2A criteria (death, life-threatening, hospitalization, disability, congenital anomaly, or other medically important condition). Drives expedited reporting timelines.' ;
    rdfs:domain ind:AeMeddraCoding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lltCode rdf:type rdf:Property ;
    rdfs:label 'Llt Code' ;
    rdfs:comment 'Eight-digit MedDRA numeric code for the Lowest Level Term (LLT) assigned to the verbatim adverse event term. The LLT is the most granular level of the MedDRA hierarchy and is the primary coding target. Sourced from Oracle Argus Safety MedDRA dictionary.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lltName rdf:type rdf:Property ;
    rdfs:label 'Llt Name' ;
    rdfs:comment 'Descriptive text of the MedDRA Lowest Level Term (LLT) corresponding to llt_code. Provides the human-readable label for the most granular MedDRA coding level. Sourced from Oracle Argus Safety MedDRA dictionary.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousPtCode rdf:type rdf:Property ;
    rdfs:label 'Previous Pt Code' ;
    rdfs:comment 'The MedDRA PT code that was previously assigned before a recoding event. Populated only when coding_method = \'recoded\'. Enables before/after comparison for coding change impact analysis and regulatory audit.' ;
    rdfs:domain ind:AeMeddraCoding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousSocCode rdf:type rdf:Property ;
    rdfs:label 'Previous Soc Code' ;
    rdfs:comment 'The MedDRA SOC code that was previously assigned before a recoding event. Populated only when coding_method = \'recoded\'. Enables assessment of whether a recoding changed the SOC-level classification, which may affect regulatory safety tables.' ;
    rdfs:domain ind:AeMeddraCoding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySocFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Soc Flag' ;
    rdfs:comment 'Indicates whether this SOC assignment is the primary (true) or secondary (false) SOC for the PT. MedDRA PTs may be linked to multiple SOCs; the primary SOC is used for standard regulatory safety tables. Sourced from Oracle Argus Safety.' ;
    rdfs:domain ind:AeMeddraCoding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ptName rdf:type rdf:Property ;
    rdfs:label 'Pt Name' ;
    rdfs:comment 'Descriptive text of the MedDRA Preferred Term (PT) corresponding to pt_code. Used as the standard term in regulatory submissions, CIOMS forms, and safety narratives.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socName rdf:type rdf:Property ;
    rdfs:label 'Soc Name' ;
    rdfs:comment 'Descriptive text of the MedDRA System Organ Class (SOC) corresponding to soc_code. Used as the primary grouping header in all regulatory safety tabulations, PSUR/PBRER narratives, and DSMB reports.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitRiskTmfDocumentId rdf:type rdf:Property ;
    rdfs:label 'Benefit Risk Tmf Document Id' ;
    rdfs:comment 'Foreign key linking to document.tmf_document. Business justification: Benefit-risk assessments are formal documents required by ICH E8/E9 and filed in the TMF. Medical monitors and regulatory teams reference the TMF-filed document during inspections and when compiling D' ;
    rdfs:domain ind:BenefitRiskAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TmfDocument .

ind:approvalSignatureReference rdf:type rdf:Property ;
    rdfs:label 'Approval Signature Reference' ;
    rdfs:comment 'Reference to the electronic signature record (e.g., Veeva Vault or MasterControl e-signature ID) confirming the medical officer\'s formal approval of this benefit-risk assessment, per 21 CFR Part 11 requirements.' ;
    rdfs:domain ind:BenefitRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:argusAssessmentReference rdf:type rdf:Property ;
    rdfs:label 'Argus Assessment Reference' ;
    rdfs:comment 'Reference number assigned by Oracle Argus Safety to the benefit-risk assessment record, enabling traceability back to the source safety system.' ;
    rdfs:domain ind:BenefitRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentIdentifier rdf:type rdf:Property ;
    rdfs:label 'Assessment Identifier' ;
    rdfs:comment 'Externally-known alphanumeric identifier for this benefit-risk assessment, used in regulatory submissions, DSUR sections, and sponsor communications (e.g., BRA-2024-001).' ;
    rdfs:domain ind:BenefitRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentTrigger rdf:type rdf:Property ;
    rdfs:label 'Assessment Trigger' ;
    rdfs:comment 'The business event or regulatory requirement that initiated this benefit-risk assessment: DSMB/DMC recommendation, validated safety signal, regulatory authority request, scheduled periodic review, protocol amendment, or unplanned safety finding. [ENUM-REF-CANDIDATE: dsmb_recommendation|signal_validation|regulatory_request|periodic_review|protocol_amendment|safety_finding|interim_analysis|market_authorization — promote to reference product]' ;
    rdfs:domain ind:BenefitRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentVersion rdf:type rdf:Property ;
    rdfs:label 'Assessment Version' ;
    rdfs:comment 'Sequential version number of this benefit-risk assessment, incremented when the assessment is revised following new safety data, regulatory feedback, or DSMB/DMC recommendation.' ;
    rdfs:domain ind:BenefitRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benefitRiskConclusion rdf:type rdf:Property ;
    rdfs:label 'Benefit Risk Conclusion' ;
    rdfs:comment 'The formal overall benefit-risk conclusion reached by the sponsor medical officer: favorable (benefits outweigh risks), unfavorable (risks outweigh benefits), inconclusive (insufficient data), or conditional (favorable subject to risk minimization measures).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitRiskRationale rdf:type rdf:Property ;
    rdfs:label 'Benefit Risk Rationale' ;
    rdfs:comment 'Detailed narrative justification for the overall benefit-risk conclusion, explaining the weighing of benefits against risks in the context of the target patient population and therapeutic indication.' ;
    rdfs:domain ind:BenefitRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitSummary rdf:type rdf:Property ;
    rdfs:label 'Benefit Summary' ;
    rdfs:comment 'Narrative summary of the clinical benefits observed for the investigational product, including efficacy endpoints, patient-reported outcomes, and comparative effectiveness data reviewed during this assessment.' ;
    rdfs:domain ind:BenefitRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsurSectionReference rdf:type rdf:Property ;
    rdfs:label 'Dsur Section Reference' ;
    rdfs:comment 'Reference to the specific DSUR section or report number in which this benefit-risk assessment is included, enabling traceability between the assessment and the regulatory submission document.' ;
    rdfs:domain ind:BenefitRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyEfficacyEndpoint rdf:type rdf:Property ;
    rdfs:label 'Key Efficacy Endpoint' ;
    rdfs:comment 'The primary efficacy endpoint or outcome measure that anchors the benefit side of this benefit-risk assessment (e.g., overall survival, progression-free survival, HbA1c reduction).' ;
    rdfs:domain ind:BenefitRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyRiskDescription rdf:type rdf:Property ;
    rdfs:label 'Key Risk Description' ;
    rdfs:comment 'Description of the most clinically significant identified risk(s) for the investigational product, including MedDRA-coded adverse event terms, severity, and frequency that most influence the benefit-risk balance.' ;
    rdfs:domain ind:BenefitRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pbrerSectionReference rdf:type rdf:Property ;
    rdfs:label 'Pbrer Section Reference' ;
    rdfs:comment 'Reference to the PBRER section or report number in which this benefit-risk assessment is included, applicable for post-authorization or late-phase studies.' ;
    rdfs:domain ind:BenefitRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolAmendmentRequired rdf:type rdf:Property ;
    rdfs:label 'Protocol Amendment Required' ;
    rdfs:comment 'Indicates whether this benefit-risk assessment has determined that a protocol amendment is required as a risk minimization measure or in response to new safety findings.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryRequestReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Request Reference' ;
    rdfs:comment 'Reference number or identifier of the regulatory authority request (e.g., FDA query, EMA question) that triggered this benefit-risk assessment, when the trigger is a regulatory request.' ;
    rdfs:domain ind:BenefitRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskMinimizationMeasures rdf:type rdf:Property ;
    rdfs:label 'Risk Minimization Measures' ;
    rdfs:comment 'Description of the recommended risk minimization measures (RMMs) arising from this assessment, such as protocol amendments, dose modifications, enhanced monitoring, informed consent updates, or additional safety warnings.' ;
    rdfs:domain ind:BenefitRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyContinuationRecommended rdf:type rdf:Property ;
    rdfs:label 'Study Continuation Recommended' ;
    rdfs:comment 'Indicates whether the benefit-risk assessment recommends continuation of the study. A value of False may trigger a clinical hold, study suspension, or early termination process.' ;
    rdfs:domain ind:BenefitRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subjectsExposedCount rdf:type rdf:Property ;
    rdfs:label 'Subjects Exposed Count' ;
    rdfs:comment 'Total number of subjects exposed to the investigational product as of the data cutoff date, forming the safety population denominator for this benefit-risk assessment.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:susarCount rdf:type rdf:Property ;
    rdfs:label 'Susar Count' ;
    rdfs:comment 'Total number of SUSARs reported as of the data cutoff date. SUSARs are a critical regulatory metric influencing the benefit-risk conclusion and expedited reporting obligations.' ;
    rdfs:domain ind:BenefitRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:veevaDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Veeva Document Reference' ;
    rdfs:comment 'Document identifier in Veeva Vault (eTMF/regulatory submissions module) for the formal benefit-risk assessment report document, enabling retrieval of the source document from the electronic Trial Master File.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:causalityAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Causality Assessment Id' ;
    rdfs:comment 'Unique surrogate identifier for each causality assessment record in the Silver layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:CausalityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorAssessmentCausalityAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Prior Assessment Causality Assessment Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediately preceding causality assessment record that this revision supersedes. Null for original (first) assessments. Enables full revision chain reconstruction.' ;
    rdfs:domain ind:CausalityAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CausalityAssessment .

ind:alternativeExplanation rdf:type rdf:Property ;
    rdfs:label 'Alternative Explanation' ;
    rdfs:comment 'Free-text description of alternative causes considered by the assessor (e.g., concomitant medications, underlying disease, concurrent procedures). Documents the differential diagnosis reasoning supporting the causality determination.' ;
    rdfs:domain ind:CausalityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:argusWorkflowState rdf:type rdf:Property ;
    rdfs:label 'Argus Workflow State' ;
    rdfs:comment 'The workflow routing state of the causality assessment within Oracle Argus Safety at the time of data extraction (e.g., Open, Closed, Submitted, Archived). Supports reconciliation between the lakehouse Silver layer and the source system. [ENUM-REF-CANDIDATE: open|closed|submitted|archived|pending_review|locked — promote to reference product]' ;
    rdfs:domain ind:CausalityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:causalityCategory rdf:type rdf:Property ;
    rdfs:label 'Causality Category' ;
    rdfs:comment 'The assessor\'s determination of the causal relationship between the investigational product and the adverse event. Standard WHO/ICH causality categories used in Oracle Argus Safety and regulatory submissions. \'Not assessable\' applies when insufficient information is available.' ;
    rdfs:domain ind:CausalityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:causalityCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Causality Category Code' ;
    rdfs:comment 'Standardized short code for the causality category used in CDISC SDTM AE domain submissions and Oracle Argus Safety exports (UN=Unrelated, UL=Unlikely, PO=Possible, PR=Probable, DE=Definite, NA=Not Assessable).' ;
    rdfs:domain ind:CausalityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concomitantMedicationFlag rdf:type rdf:Property ;
    rdfs:label 'Concomitant Medication Flag' ;
    rdfs:comment 'Indicates whether this causality assessment pertains to a concomitant medication (True) rather than the primary investigational product (False). Enables differentiation of IP-related versus concomitant drug-related assessments within the same AE case.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:concomitantMedicationName rdf:type rdf:Property ;
    rdfs:label 'Concomitant Medication Name' ;
    rdfs:comment 'Name of the concomitant medication being assessed for causal relationship when concomitant_medication_flag is True. Populated from WHO Drug Dictionary (WHO-DD) preferred drug name.' ;
    rdfs:domain ind:CausalityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsmbReviewDate rdf:type rdf:Property ;
    rdfs:label 'Dsmb Review Date' ;
    rdfs:comment 'The date on which the DSMB/DMC formally reviewed this causality assessment during a scheduled or ad hoc safety review meeting.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dsmbReviewed rdf:type rdf:Property ;
    rdfs:label 'Dsmb Reviewed' ;
    rdfs:comment 'Indicates whether this causality assessment was reviewed by the Data Safety Monitoring Board (DSMB) or Data Monitoring Committee (DMC) as part of a formal safety review. Supports DSMB/DMC meeting documentation and regulatory oversight.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedness rdf:type rdf:Property ;
    rdfs:label 'Expectedness' ;
    rdfs:comment 'Determination of whether the adverse event is listed in the current Investigator\'s Brochure (IB) or Reference Safety Information (RSI) as a known effect of the investigational product. Drives SUSAR classification and expedited reporting obligations.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRevised rdf:type rdf:Property ;
    rdfs:label 'Is Revised' ;
    rdfs:comment 'Indicates whether this causality assessment is a revision of a previously submitted assessment. True when the assessor has changed their causality determination after initial submission, triggering regulatory follow-up reporting obligations.' ;
    rdfs:domain ind:CausalityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rationaleNarrative rdf:type rdf:Property ;
    rdfs:label 'Rationale Narrative' ;
    rdfs:comment 'Free-text clinical narrative provided by the assessor explaining the reasoning behind the causality determination. Includes consideration of temporal relationship, biological plausibility, dechallenge/rechallenge results, and alternative explanations. Required for regulatory submissions.' ;
    rdfs:domain ind:CausalityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential revision version number for this causality assessment. Starts at 1 for the original assessment and increments with each revision. Enables audit trail tracking of assessment changes over the case lifecycle.' ;
    rdfs:domain ind:CausalityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signalDetectionFlag rdf:type rdf:Property ;
    rdfs:label 'Signal Detection Flag' ;
    rdfs:comment 'Indicates whether this causality assessment has been flagged for inclusion in pharmacovigilance signal detection analysis within Oracle Argus Safety. Supports aggregate safety review and cumulative causality trend monitoring.' ;
    rdfs:domain ind:CausalityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorCausalityCategory rdf:type rdf:Property ;
    rdfs:label 'Sponsor Causality Category' ;
    rdfs:comment 'The Sponsor Medical Monitor\'s independent causality determination, captured separately from the investigator\'s assessment. When sponsor_causality_override is True, this field holds the sponsor\'s differing conclusion used for regulatory reporting.' ;
    rdfs:domain ind:CausalityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorCausalityOverride rdf:type rdf:Property ;
    rdfs:label 'Sponsor Causality Override' ;
    rdfs:comment 'Indicates whether the Sponsor Medical Monitor\'s causality determination differs from (overrides) the Investigator\'s assessment. When True, both assessments are retained and the sponsor\'s determination governs regulatory reporting obligations per ICH E2A.' ;
    rdfs:domain ind:CausalityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:susarFlag rdf:type rdf:Property ;
    rdfs:label 'Susar Flag' ;
    rdfs:comment 'Indicates whether this adverse event has been classified as a Suspected Unexpected Serious Adverse Reaction (SUSAR) based on the combination of seriousness, causality (at least possible), and unexpectedness criteria. Triggers mandatory expedited regulatory reporting.' ;
    rdfs:domain ind:CausalityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temporalRelationship rdf:type rdf:Property ;
    rdfs:label 'Temporal Relationship' ;
    rdfs:comment 'Assessment of whether the timing between investigational product administration and adverse event onset is consistent with a causal relationship. A key criterion in WHO and ICH causality assessment frameworks.' ;
    rdfs:domain ind:CausalityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:whoDdDrugCode rdf:type rdf:Property ;
    rdfs:label 'Who Dd Drug Code' ;
    rdfs:comment 'WHO Drug Dictionary standardized drug code for the product (investigational or concomitant) being assessed. Enables cross-study signal detection and regulatory pharmacovigilance reporting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeTerm rdf:type rdf:Property ;
    rdfs:label 'Ae Term' ;
    rdfs:comment 'The official CTCAE adverse event term name as published by NCI (e.g., \'Atrial fibrillation\', \'Nausea\', \'Peripheral neuropathy\'). This is the standardized clinical term used to classify and report adverse events across all clinical trials. Corresponds to the AETERM or AEDECOD field in CDISC SDTM AE domain and is the primary human-readable label for this grading record.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicablePopulation rdf:type rdf:Property ;
    rdfs:label 'Applicable Population' ;
    rdfs:comment 'Specifies the patient population for which this CTCAE grade definition is applicable (e.g., \'All\', \'Pediatric\', \'Adult\', \'Oncology\'). Some CTCAE terms and grade criteria differ by population (e.g., pediatric-specific grading criteria). Used to filter applicable grade definitions when assigning severity in studies with specific population constraints.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdiscCodelistCode rdf:type rdf:Property ;
    rdfs:label 'Cdisc Codelist Code' ;
    rdfs:comment 'The CDISC controlled terminology codelist code associated with this CTCAE grade entry (e.g., the AETOXGR codelist code). Enables direct mapping to CDISC SDTM submission datasets and ADaM analysis datasets produced in SAS Drug Development. Required for eCTD regulatory submissions to FDA, EMA, and PMDA.' ;
    rdfs:domain ind:CtcaeGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalCriteria rdf:type rdf:Property ;
    rdfs:label 'Clinical Criteria' ;
    rdfs:comment 'Supplementary clinical criteria, laboratory thresholds, or objective measurement parameters that define the boundary conditions for assigning this specific grade to the AE term (e.g., specific lab value ranges, vital sign thresholds, functional impairment descriptors). Distinct from the grade_description in that it captures the measurable/objective criteria rather than the narrative description. Used by clinical staff for precise grade assignment and by biostatisticians for consistency validation.' ;
    rdfs:domain ind:CtcaeGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctcaeCode rdf:type rdf:Property ;
    rdfs:label 'Ctcae Code' ;
    rdfs:comment 'Official NCI-assigned alphanumeric code uniquely identifying the CTCAE adverse event term within a given version. Used as the primary business identifier for cross-system referencing and CDISC SDTM mapping (AETOXGR domain). Enables unambiguous linkage between AE records and the reference grading criteria.' ;
    rdfs:domain ind:CtcaeGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grade rdf:type rdf:Property ;
    rdfs:label 'Grade' ;
    rdfs:comment 'Numeric severity grade (1 through 5) as defined by CTCAE. Grade 1 = Mild; Grade 2 = Moderate; Grade 3 = Severe; Grade 4 = Life-threatening or disabling; Grade 5 = Death related to AE. This is the core grading dimension of the reference table and is used to populate the AETOXGR field in CDISC SDTM submissions and to trigger SAE/SUSAR reporting workflows in Oracle Argus Safety.' ;
    rdfs:domain ind:CtcaeGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gradeDescription rdf:type rdf:Property ;
    rdfs:label 'Grade Description' ;
    rdfs:comment 'Full verbatim clinical description of the severity grade for the specific AE term as published in the CTCAE by NCI (e.g., for \'Nausea\' Grade 2: \'Moderate nausea; oral intake decreased without significant weight loss, dehydration or malnutrition\'). This is the authoritative clinical criteria text used by investigators and CRAs to assign the correct grade during AE assessment. Stored verbatim to preserve regulatory integrity.' ;
    rdfs:domain ind:CtcaeGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeLabel rdf:type rdf:Property ;
    rdfs:label 'Grade Label' ;
    rdfs:comment 'Standardized textual label corresponding to the numeric CTCAE grade (e.g., \'Mild\' for Grade 1, \'Moderate\' for Grade 2, \'Severe\' for Grade 3, \'Life-Threatening\' for Grade 4, \'Death\' for Grade 5). Provides a human-readable severity descriptor for use in clinical reports, DSMB/DMC safety narratives, and regulatory submissions without requiring a lookup of the numeric grade.' ;
    rdfs:domain ind:CtcaeGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradingNotes rdf:type rdf:Property ;
    rdfs:label 'Grading Notes' ;
    rdfs:comment 'Additional clinical notes, caveats, or guidance provided by NCI for applying this specific grade to the AE term (e.g., \'Also consider Anemia\', \'See also Cardiac disorders: Left ventricular systolic dysfunction\'). Captures the \'Also consider\' and \'Navigational Note\' annotations present in the CTCAE publication that guide investigators in differential grading decisions.' ;
    rdfs:domain ind:CtcaeGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOncologySpecific rdf:type rdf:Property ;
    rdfs:label 'Is Oncology Specific' ;
    rdfs:comment 'Indicates whether this CTCAE adverse event term and grade definition is specific to oncology/cancer treatment contexts. CTCAE was originally developed for oncology trials; some terms are exclusively relevant to chemotherapy, radiation, or immunotherapy adverse effects. Used to filter applicable grading criteria for oncology versus non-oncology study protocols.' ;
    rdfs:domain ind:CtcaeGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSeriousByGrade rdf:type rdf:Property ;
    rdfs:label 'Is Serious By Grade' ;
    rdfs:comment 'Indicates whether this CTCAE grade level is inherently classified as a Serious Adverse Event (SAE) based on regulatory definitions (typically Grade 3 and above may trigger SAE criteria, Grade 4–5 are always serious). Used to automate SAE flagging logic in Oracle Argus Safety and EDC systems (Medidata Rave) when a grade is recorded, supporting expedited reporting timelines under ICH E2A and FDA 21 CFR 312.32.' ;
    rdfs:domain ind:CtcaeGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nciConceptCode rdf:type rdf:Property ;
    rdfs:label 'Nci Concept Code' ;
    rdfs:comment 'The NCI Thesaurus (NCIt) concept identifier (e.g., \'C54767\') for this CTCAE adverse event term. Provides a stable, version-independent identifier from the NCI controlled vocabulary that persists across CTCAE versions. Used for ontology-based data integration, CDISC terminology alignment, and cross-study analytics in SAS Drug Development and AI/ML safety signal detection pipelines.' ;
    rdfs:domain ind:CtcaeGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nciPublicationDate rdf:type rdf:Property ;
    rdfs:label 'Nci Publication Date' ;
    rdfs:comment 'The official publication date of the CTCAE version from which this grade definition originates, as released by the National Cancer Institute (NCI) Cancer Therapy Evaluation Program (CTEP). Provides the authoritative reference date for regulatory submissions and audit trails, distinct from the effective_start_date which may reflect internal adoption timing.' ;
    rdfs:domain ind:CtcaeGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorVersionCode rdf:type rdf:Property ;
    rdfs:label 'Prior Version Code' ;
    rdfs:comment 'The CTCAE term code from the immediately preceding CTCAE version that this record supersedes or corresponds to, enabling version-to-version lineage tracking. Used by data managers and biostatisticians to reconcile AE grading data collected under different CTCAE versions within the same study or across studies in integrated safety analyses.' ;
    rdfs:domain ind:CtcaeGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresExpeditedReporting rdf:type rdf:Property ;
    rdfs:label 'Requires Expedited Reporting' ;
    rdfs:comment 'Indicates whether an AE recorded at this CTCAE grade level triggers mandatory expedited regulatory reporting obligations (e.g., 7-day or 15-day IND safety reports to FDA, EMA, PMDA). Derived from regulatory guidance but stored as a reference attribute to drive automated reporting workflow triggers in Oracle Argus Safety and CTMS. Supports compliance with FDA 21 CFR 312.32, EMA GVP Module VI, and ICH E2A timelines.' ;
    rdfs:domain ind:CtcaeGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectedTreatmentArmId rdf:type rdf:Property ;
    rdfs:label 'Affected Treatment Arm Id' ;
    rdfs:comment 'Foreign key linking to randomization.treatment_arm. Business justification: DSMB stopping rules and arm-suspension recommendations target specific treatment arms. affected_treatment_arms on dsmb_recommendation is a plain text denormalization of treatment_arm. Operational impl' ;
    rdfs:domain ind:DsmbRecommendation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TreatmentArm .

ind:dsmbChairEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Dsmb Chair Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: The DSMB chair who issues stopping recommendations must be traceable for regulatory authority submissions and inspection readiness. dsmb_chair_name is a denormalized text column; the FK supports audit' ;
    rdfs:domain ind:DsmbRecommendation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:resultingStudyBudgetId rdf:type rdf:Property ;
    rdfs:label 'Resulting Study Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.study_budget. Business justification: DSMB recommendations triggering protocol amendments, dose modifications, or study suspension require immediate budget amendments. Linking the recommendation to the resulting study_budget version creat' ;
    rdfs:domain ind:DsmbRecommendation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudyBudget .

ind:argusSafetyCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Argus Safety Case Number' ;
    rdfs:comment 'Case number assigned in Oracle Argus Safety to the safety case or aggregate safety report associated with this DSMB/DMC recommendation. Enables traceability between the recommendation and the underlying pharmacovigilance case management record.' ;
    rdfs:domain ind:DsmbRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitRiskSummary rdf:type rdf:Property ;
    rdfs:label 'Benefit Risk Summary' ;
    rdfs:comment 'Concise summary of the DSMB/DMC benefit-risk assessment that underpins the recommendation, capturing the committee\'s evaluation of the investigational product\'s benefit profile relative to observed safety risks at the time of review.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissentingOpinion rdf:type rdf:Property ;
    rdfs:label 'Dissenting Opinion' ;
    rdfs:comment 'Narrative capturing any dissenting opinion(s) from DSMB/DMC members who did not agree with the majority recommendation. Documented for regulatory transparency and governance purposes when vote_outcome is \'split\' or \'majority\'.' ;
    rdfs:domain ind:DsmbRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpReviewDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Review Date' ;
    rdfs:comment 'Target date for the follow-up DSMB/DMC review meeting required to assess the outcome of actions taken in response to this recommendation. Populated when follow_up_review_required is True.' ;
    rdfs:domain ind:DsmbRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Review Required' ;
    rdfs:comment 'Indicates whether this recommendation requires a follow-up DSMB/DMC review meeting to assess implementation effectiveness or monitor evolving safety data. Drives scheduling of unscheduled interim reviews.' ;
    rdfs:domain ind:DsmbRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:informedConsentUpdateRequired rdf:type rdf:Property ;
    rdfs:label 'Informed Consent Update Required' ;
    rdfs:comment 'Indicates whether this DSMB/DMC recommendation necessitates an update to the Informed Consent Form (ICF) to reflect new safety information. Triggers re-consent workflow in Clinpal eConsent system.' ;
    rdfs:domain ind:DsmbRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recommendationNumber rdf:type rdf:Property ;
    rdfs:label 'Recommendation Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned to this recommendation, typically formatted as a sequential reference within the study (e.g., REC-2024-001). Used for regulatory correspondence, sponsor communications, and TMF filing.' ;
    rdfs:domain ind:DsmbRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationStatus rdf:type rdf:Property ;
    rdfs:label 'Recommendation Status' ;
    rdfs:comment 'Current lifecycle state of the DSMB/DMC recommendation from initial issuance through sponsor acceptance or rejection and final closure. Drives workflow routing in Oracle Argus Safety and Oracle Siebel CTMS. [ENUM-REF-CANDIDATE: draft|issued|under_review|accepted|rejected|superseded|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DsmbRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationType rdf:type rdf:Property ;
    rdfs:label 'Recommendation Type' ;
    rdfs:comment 'Formal classification of the DSMB/DMC recommendation issued following the safety review. Drives sponsor response obligations and regulatory notification requirements. [ENUM-REF-CANDIDATE: continue_unchanged|protocol_amendment_required|dose_modification|study_suspension|early_termination|other — promote to reference product]' ;
    rdfs:domain ind:DsmbRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationVersion rdf:type rdf:Property ;
    rdfs:label 'Recommendation Version' ;
    rdfs:comment 'Version number of this recommendation record, incremented when the recommendation is amended or superseded. Supports version control and audit trail requirements under 21 CFR Part 11 and ALCOA+ principles.' ;
    rdfs:domain ind:DsmbRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryAgenciesNotified rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agencies Notified' ;
    rdfs:comment 'Comma-separated list of health authority agencies notified of this recommendation (e.g., FDA, EMA, MHRA, PMDA, TGA, Health Canada). Supports multi-jurisdictional regulatory compliance tracking.' ;
    rdfs:domain ind:DsmbRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationDeadline rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Deadline' ;
    rdfs:comment 'Regulatory deadline by which the sponsor must notify health authorities of this DSMB/DMC recommendation and any resulting study actions. Typically 7 or 15 calendar days depending on jurisdiction and recommendation type.' ;
    rdfs:domain ind:DsmbRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sponsorResponse rdf:type rdf:Property ;
    rdfs:label 'Sponsor Response' ;
    rdfs:comment 'Formal response of the study sponsor to the DSMB/DMC recommendation, indicating whether the recommendation has been accepted, rejected, or partially accepted. Drives implementation and regulatory notification workflows.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorResponseDate rdf:type rdf:Property ;
    rdfs:label 'Sponsor Response Date' ;
    rdfs:comment 'Date on which the sponsor formally communicated their response (acceptance, rejection, or partial acceptance) to the DSMB/DMC recommendation. Used to calculate response timeliness against regulatory and charter obligations.' ;
    rdfs:domain ind:DsmbRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sponsorResponseRationale rdf:type rdf:Property ;
    rdfs:label 'Sponsor Response Rationale' ;
    rdfs:comment 'Narrative explanation provided by the sponsor for their response to the DSMB/DMC recommendation, particularly required when the recommendation is rejected or only partially accepted. Documented in the TMF.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voteOutcome rdf:type rdf:Property ;
    rdfs:label 'Vote Outcome' ;
    rdfs:comment 'Outcome of the DSMB/DMC committee vote that produced this recommendation, indicating whether the decision was unanimous, by majority, or resulted in a split vote. Relevant for regulatory transparency and committee governance documentation.' ;
    rdfs:domain ind:DsmbRecommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDsmbTmfDocumentId rdf:type rdf:Property ;
    rdfs:label 'Primary Dsmb Tmf Document Id' ;
    rdfs:comment 'Document identifier for the official DSMB/DMC meeting minutes stored in the electronic Trial Master File (eTMF) system (Veeva Vault). Provides traceability to the formal meeting record. Classified confidential as minutes contain unblinded safety deliberations.' ;
    rdfs:domain ind:DsmbReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TmfDocument .

ind:reviewCommitteeId rdf:type rdf:Property ;
    rdfs:label 'Review Committee Id' ;
    rdfs:comment 'Reference to the safety oversight committee (DSMB, DMC, IDMC, or internal SRC) that conducted this review. Links to the committee master record.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReviewCommittee .

ind:argusSafetyCaseRef rdf:type rdf:Property ;
    rdfs:label 'Argus Safety Case Ref' ;
    rdfs:comment 'Reference identifier linking this DSMB/DMC review to related safety cases or aggregate safety reports in Oracle Argus Safety. Enables cross-referencing between safety governance decisions and individual case safety reports.' ;
    rdfs:domain ind:DsmbReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedSessionHeld rdf:type rdf:Property ;
    rdfs:label 'Closed Session Held' ;
    rdfs:comment 'Indicates whether a closed (confidential, unblinded) session was held during the DSMB/DMC meeting, attended only by committee members and the unblinded statistician (True = closed session held; False = no closed session).' ;
    rdfs:domain ind:DsmbReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataPackageVersion rdf:type rdf:Property ;
    rdfs:label 'Data Package Version' ;
    rdfs:comment 'Version identifier of the unblinded safety data package provided to the DSMB/DMC for this review. Ensures traceability between the committee\'s recommendation and the exact data snapshot reviewed.' ;
    rdfs:domain ind:DsmbReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isIndependent rdf:type rdf:Property ;
    rdfs:label 'Is Independent' ;
    rdfs:comment 'Indicates whether the committee is fully independent of the sponsor and investigator team (True = independent; False = internal/non-independent). Independence is a key regulatory requirement for unblinded safety reviews.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openSessionHeld rdf:type rdf:Property ;
    rdfs:label 'Open Session Held' ;
    rdfs:comment 'Indicates whether an open (non-confidential) session was held during the DSMB/DMC meeting, typically attended by the sponsor and investigators (True = open session held; False = closed session only). Standard DSMB meetings include both open and closed sessions.' ;
    rdfs:domain ind:DsmbReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryNotificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Due Date' ;
    rdfs:comment 'Deadline by which the regulatory authority must be notified per applicable regulations (e.g., 7-day or 15-day reporting window). Enables proactive compliance monitoring and escalation.' ;
    rdfs:domain ind:DsmbReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetySignalIdentified rdf:type rdf:Property ;
    rdfs:label 'Safety Signal Identified' ;
    rdfs:comment 'Indicates whether the DSMB/DMC identified a new or emerging safety signal during this review that requires further investigation or monitoring (True = signal identified; False = no new signal). Triggers downstream signal management workflow in Oracle Argus Safety.' ;
    rdfs:domain ind:DsmbReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:studyPhaseReviewed rdf:type rdf:Property ;
    rdfs:label 'Study Phase Reviewed' ;
    rdfs:comment 'Clinical development phase of the study at the time of the DSMB/DMC review. Determines the regulatory framework and risk thresholds applicable to the safety assessment.' ;
    rdfs:domain ind:DsmbReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unblindedStatisticianPresent rdf:type rdf:Property ;
    rdfs:label 'Unblinded Statistician Present' ;
    rdfs:comment 'Indicates whether the independent unblinded statistician was present at the DSMB/DMC meeting to present the unblinded safety data package (True = present; False = not present). Required for valid closed-session deliberations.' ;
    rdfs:domain ind:DsmbReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dsurId rdf:type rdf:Property ;
    rdfs:label 'Dsur Id' ;
    rdfs:comment 'Unique surrogate identifier for the Development Safety Update Report record in the lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dsur .

ind:reportAuthorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Report Author Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: DSUR authorship is a named regulatory role under ICH E2F requiring employee traceability for health authority submissions and inspection readiness. report_author is a denormalized text column; the FK ' ;
    rdfs:domain ind:Dsur ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:argusPeriodicReportReference rdf:type rdf:Property ;
    rdfs:label 'Argus Periodic Report Reference' ;
    rdfs:comment 'The internal report identifier assigned by Oracle Argus Safety periodic reporting module, used to trace this DSUR back to its source system record.' ;
    rdfs:domain ind:Dsur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeSaeCount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Sae Count' ;
    rdfs:comment 'Total number of serious adverse events (SAEs) reported for the investigational product from program inception through the end of the reporting period, as captured in Oracle Argus Safety.' ;
    rdfs:domain ind:Dsur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cumulativeSubjectExposureCount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Subject Exposure Count' ;
    rdfs:comment 'Total number of subjects exposed to the investigational product from the inception of the development program through the end of the reporting period, representing the cumulative safety exposure denominator.' ;
    rdfs:domain ind:Dsur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cumulativeSubjectExposureDays rdf:type rdf:Property ;
    rdfs:label 'Cumulative Subject Exposure Days' ;
    rdfs:comment 'Total patient-days of exposure to the investigational product accumulated across all studies from program inception through the reporting period end date, used as the denominator for incidence rate calculations.' ;
    rdfs:domain ind:Dsur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cumulativeSusarCount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Susar Count' ;
    rdfs:comment 'Total number of SUSARs (Suspected Unexpected Serious Adverse Reactions) reported from program inception through the reporting period end date, a key regulatory safety metric.' ;
    rdfs:domain ind:Dsur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dsmbReviewConducted rdf:type rdf:Property ;
    rdfs:label 'Dsmb Review Conducted' ;
    rdfs:comment 'Indicates whether a Data Safety Monitoring Board (DSMB) or Data Monitoring Committee (DMC) review was conducted during the reporting period, with findings incorporated into this DSUR.' ;
    rdfs:domain ind:Dsur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fatalSaeCount rdf:type rdf:Property ;
    rdfs:label 'Fatal Sae Count' ;
    rdfs:comment 'Number of serious adverse events with a fatal outcome reported during the reporting period, a critical safety metric for benefit-risk assessment and DSMB/DMC review.' ;
    rdfs:domain ind:Dsur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:healthAuthorityAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Health Authority Acknowledgement Date' ;
    rdfs:comment 'The date on which the health authority formally acknowledged receipt of the DSUR submission, used for regulatory compliance tracking and audit trail purposes.' ;
    rdfs:domain ind:Dsur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:healthAuthorityQueryReceived rdf:type rdf:Property ;
    rdfs:label 'Health Authority Query Received' ;
    rdfs:comment 'Indicates whether the health authority issued a query or request for additional information in response to this DSUR submission, triggering a response workflow.' ;
    rdfs:domain ind:Dsur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalReviewer rdf:type rdf:Property ;
    rdfs:label 'Medical Reviewer' ;
    rdfs:comment 'Name or identifier of the qualified medical officer or pharmacovigilance physician who performed the medical review and sign-off of this DSUR prior to submission.' ;
    rdfs:domain ind:Dsur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newSafetySignalIdentified rdf:type rdf:Property ;
    rdfs:label 'New Safety Signal Identified' ;
    rdfs:comment 'Indicates whether a new safety signal for the investigational product was identified during the reporting period, triggering additional signal management activities and potential regulatory notifications.' ;
    rdfs:domain ind:Dsur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ongoingStudyCount rdf:type rdf:Property ;
    rdfs:label 'Ongoing Study Count' ;
    rdfs:comment 'Number of clinical studies with the investigational product that were ongoing during the reporting period, providing context for the scope of the safety data.' ;
    rdfs:domain ind:Dsur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodSaeCount rdf:type rdf:Property ;
    rdfs:label 'Period Sae Count' ;
    rdfs:comment 'Number of serious adverse events (SAEs) reported during the current annual reporting period, used to assess period-over-period safety trends.' ;
    rdfs:domain ind:Dsur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodSubjectExposureCount rdf:type rdf:Property ;
    rdfs:label 'Period Subject Exposure Count' ;
    rdfs:comment 'Number of subjects exposed to the investigational product during the current annual reporting period only, used to assess period-specific safety signal rates.' ;
    rdfs:domain ind:Dsur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodSusarCount rdf:type rdf:Property ;
    rdfs:label 'Period Susar Count' ;
    rdfs:comment 'Number of SUSARs reported during the current annual reporting period, used for expedited reporting compliance monitoring and signal detection.' ;
    rdfs:domain ind:Dsur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referenceSafetyDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Safety Document Type' ;
    rdfs:comment 'Type of reference safety information document used to assess expectedness of adverse reactions in this DSUR (e.g., IB = Investigator\'s Brochure, CCSI = Company Core Safety Information, SmPC = Summary of Product Characteristics, USPI = US Prescribing Information, RSI = Reference Safety Information).' ;
    rdfs:domain ind:Dsur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceSafetyDocumentVersion rdf:type rdf:Property ;
    rdfs:label 'Reference Safety Document Version' ;
    rdfs:comment 'Version number or edition of the reference safety document (e.g., Investigator\'s Brochure edition) used as the basis for expectedness assessment in this DSUR.' ;
    rdfs:domain ind:Dsur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryActionTaken rdf:type rdf:Property ;
    rdfs:label 'Regulatory Action Taken' ;
    rdfs:comment 'Significant regulatory or safety action taken during the reporting period as a result of safety findings (e.g., protocol amendment, Investigator\'s Brochure update, study suspension). [ENUM-REF-CANDIDATE: none|protocol_amendment|ibr_update|study_suspension|study_termination|rmp_update|label_update|dhcp_letter — promote to reference product]' ;
    rdfs:domain ind:Dsur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Externally-known sequential report number assigned to this DSUR (e.g., DSUR-2024-001), used for regulatory tracking and cross-referencing across submissions.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDueDate rdf:type rdf:Property ;
    rdfs:label 'Submission Due Date' ;
    rdfs:comment 'The regulatory deadline by which this DSUR must be submitted to health authorities, typically 60 days after the reporting period end date per ICH E2F.' ;
    rdfs:domain ind:Dsur ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expeditedReportDeadlineId rdf:type rdf:Property ;
    rdfs:label 'Expedited Report Deadline Id' ;
    rdfs:comment 'Unique surrogate identifier for each expedited safety report deadline tracking record in the Silver Layer lakehouse.' ;
    rdfs:domain ind:ExpeditedReportDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Applicable Deadline Date' ;
    rdfs:comment 'The operative deadline date for this specific expedited report submission, reflecting the applicable_deadline_days (7 or 15) from the awareness_date. This is the primary compliance target date for monitoring and alerting.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicableDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Applicable Deadline Days' ;
    rdfs:comment 'The number of calendar days within which the expedited report must be submitted to the applicable regulatory agency (typically 7 or 15 days). Determined by the seriousness, expectedness, and causality of the adverse event per ICH E2A.' ;
    rdfs:domain ind:ExpeditedReportDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:argusWorkflowStatus rdf:type rdf:Property ;
    rdfs:label 'Argus Workflow Status' ;
    rdfs:comment 'The current workflow processing status of the ICSR case within Oracle Argus Safety, reflecting the internal case processing lifecycle from initial data entry through medical review, QC, approval, and submission.' ;
    rdfs:domain ind:ExpeditedReportDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysToSubmission rdf:type rdf:Property ;
    rdfs:label 'Days To Submission' ;
    rdfs:comment 'The number of calendar days elapsed between the awareness_date (clock start) and the actual submission_date. Populated only after submission. Used for compliance KPI reporting and trend analysis against ICH E2A timelines.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deadline15Day rdf:type rdf:Property ;
    rdfs:label 'Deadline 15 Day' ;
    rdfs:comment 'Calculated deadline date for 15-day expedited reporting, applicable to non-fatal/non-life-threatening unexpected SUSARs and other serious unexpected adverse reactions. Computed as awareness_date + 15 calendar days per ICH E2A.' ;
    rdfs:domain ind:ExpeditedReportDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deadline7Day rdf:type rdf:Property ;
    rdfs:label 'Deadline 7 Day' ;
    rdfs:comment 'Calculated deadline date for 7-day expedited reporting, applicable to fatal or life-threatening unexpected SUSARs. Computed as awareness_date + 7 calendar days per ICH E2A and FDA 21 CFR Part 312.32.' ;
    rdfs:domain ind:ExpeditedReportDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deadlineStatus rdf:type rdf:Property ;
    rdfs:label 'Deadline Status' ;
    rdfs:comment 'Current workflow status of the expedited report deadline. Pending = report not yet submitted and deadline not passed; Submitted_on_time = submitted within required days; Submitted_late = submitted after deadline; Overdue = deadline passed without submission; Waived = regulatory waiver granted; Not_applicable = reporting exemption applies.' ;
    rdfs:domain ind:ExpeditedReportDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsmbNotified rdf:type rdf:Property ;
    rdfs:label 'Dsmb Notified' ;
    rdfs:comment 'Indicates whether the Data Safety Monitoring Board (DSMB) or Data Monitoring Committee (DMC) was notified of this expedited safety report. Required for studies with an active DSMB/DMC per the study protocol.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigatorNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Investigator Notification Date' ;
    rdfs:comment 'The date on which the Principal Investigator (PI) was notified of the SUSAR or expedited safety report submission, as required by ICH E2A and GCP guidelines. Supports site-level compliance tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isFatalOrLifeThreatening rdf:type rdf:Property ;
    rdfs:label 'Is Fatal Or Life Threatening' ;
    rdfs:comment 'Indicates whether the adverse event is classified as fatal or life-threatening, which triggers the 7-day expedited reporting requirement rather than the standard 15-day timeline per ICH E2A.' ;
    rdfs:domain ind:ExpeditedReportDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOnTime rdf:type rdf:Property ;
    rdfs:label 'Is On Time' ;
    rdfs:comment 'Indicates whether the expedited safety report was submitted on or before the applicable regulatory deadline. True = submitted within the required timeframe; False = submitted late or not yet submitted past deadline. Core compliance KPI.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnexpected rdf:type rdf:Property ;
    rdfs:label 'Is Unexpected' ;
    rdfs:comment 'Indicates whether the adverse event is unexpected (not consistent with the Investigator Brochure or current labeling), which is a key criterion for SUSAR classification and expedited reporting obligations.' ;
    rdfs:domain ind:ExpeditedReportDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportCategory rdf:type rdf:Property ;
    rdfs:label 'Report Category' ;
    rdfs:comment 'Indicates whether this deadline record pertains to an initial expedited report submission, a follow-up report with updated information, or a final report closing the case.' ;
    rdfs:domain ind:ExpeditedReportDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code identifying the jurisdiction in which the expedited report must be filed. Drives country-specific regulatory timeline requirements.' ;
    rdfs:domain ind:ExpeditedReportDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverReference rdf:type rdf:Property ;
    rdfs:label 'Waiver Reference' ;
    rdfs:comment 'The reference number or description of the regulatory waiver or exemption granted for this expedited report submission. Populated only when waiver_granted is True.' ;
    rdfs:domain ind:ExpeditedReportDeadline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgementNumber rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Number' ;
    rdfs:comment 'The unique reference number or message ID returned by the regulatory agency in the acknowledgement (ACK) message confirming receipt of the ICSR. Used for reconciliation and proof of submission.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadline15dayDate rdf:type rdf:Property ;
    rdfs:label 'Deadline 15day Date' ;
    rdfs:comment 'The calculated calendar date by which a serious unexpected adverse reaction (non-fatal/non-life-threatening SUSAR) must be submitted to the regulatory agency, computed as awareness_date + 15 calendar days per ICH E2A.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deadline7dayDate rdf:type rdf:Property ;
    rdfs:label 'Deadline 7day Date' ;
    rdfs:comment 'The calculated calendar date by which a fatal or life-threatening unexpected SUSAR must be submitted to the regulatory agency, computed as awareness_date + 7 calendar days per ICH E2A.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:delayReason rdf:type rdf:Property ;
    rdfs:label 'Delay Reason' ;
    rdfs:comment 'Free-text explanation documenting the reason why the ICSR was not submitted within the applicable regulatory deadline. Required for late submissions to support CAPA processes and regulatory inspection readiness.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFatal rdf:type rdf:Property ;
    rdfs:label 'Is Fatal' ;
    rdfs:comment 'Indicates whether the adverse event associated with this ICSR resulted in the death of the subject. Fatal cases trigger the 7-day expedited reporting clock per ICH E2A.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLifeThreatening rdf:type rdf:Property ;
    rdfs:label 'Is Life Threatening' ;
    rdfs:comment 'Indicates whether the adverse event associated with this ICSR was life-threatening (i.e., the subject was at immediate risk of death). Life-threatening cases trigger the 7-day expedited reporting clock per ICH E2A.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:senderIdentifier rdf:type rdf:Property ;
    rdfs:label 'Sender Identifier' ;
    rdfs:comment 'The unique identifier of the organization or individual sending the ICSR to the regulatory agency, as defined in ICH E2B(R3) A.3.1. Typically the sponsor or CRO EudraVigilance/FDA sender ID.' ;
    rdfs:domain ind:Icsr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryInvestigatorProductInvestigationalProductId rdf:type rdf:Property ;
    rdfs:label 'Primary Investigator Product Investigational Product Id' ;
    rdfs:comment 'Reference to the investigational product (drug, biologic, or device) for which this Investigator Brochure safety record applies. Links to the master investigational product entity.' ;
    rdfs:domain ind:InvestigatorBrochureSafety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestigationalProduct .

ind:priorVersionId rdf:type rdf:Property ;
    rdfs:label 'Prior Version Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediately preceding version of this IB record. Enables version chain traversal for audit, regulatory inspection, and historical RSI reconstruction.' ;
    rdfs:domain ind:InvestigatorBrochureSafety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Version .

ind:annualReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Annual Review Due Date' ;
    rdfs:comment 'Date by which the next annual review and update of the IB is due, as required by ICH E6(R2). Sponsors must review and update the IB at least annually. Drives compliance calendar in Oracle Siebel CTMS.' ;
    rdfs:domain ind:InvestigatorBrochureSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:argusRsiConfigReference rdf:type rdf:Property ;
    rdfs:label 'Argus Rsi Config Reference' ;
    rdfs:comment 'Identifier of the RSI configuration record in Oracle Argus Safety that corresponds to this IB version. Used to synchronize expectedness determination logic in Argus with the approved IB version. Source system cross-reference key.' ;
    rdfs:domain ind:InvestigatorBrochureSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:editionNumber rdf:type rdf:Property ;
    rdfs:label 'Edition Number' ;
    rdfs:comment 'Sequential integer edition number of the IB (e.g., Edition 1, Edition 2). Distinct from version_number in that edition represents a full rewrite, while version may capture minor amendments within an edition.' ;
    rdfs:domain ind:InvestigatorBrochureSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ibDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Ib Document Number' ;
    rdfs:comment 'Externally-known unique document control number assigned to this Investigator Brochure, as registered in Veeva Vault eTMF or MasterControl. Serves as the business identifier for the IB document across systems.' ;
    rdfs:domain ind:InvestigatorBrochureSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ibStatus rdf:type rdf:Property ;
    rdfs:label 'Ib Status' ;
    rdfs:comment 'Current lifecycle status of this IB version within the document control workflow. \'approved\' indicates the version is active and distributed to investigators. \'superseded\' indicates a newer version has replaced it. Managed in MasterControl or Veeva Vault.' ;
    rdfs:domain ind:InvestigatorBrochureSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ibTitle rdf:type rdf:Property ;
    rdfs:label 'Ib Title' ;
    rdfs:comment 'Full title of the Investigator Brochure document, typically including the investigational product name, compound code, and edition descriptor. Human-readable identity label for the IB.' ;
    rdfs:domain ind:InvestigatorBrochureSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listedAeCount rdf:type rdf:Property ;
    rdfs:label 'Listed Ae Count' ;
    rdfs:comment 'Total number of distinct adverse reactions listed in the RSI section of this IB version. Provides a quantitative measure of the known safety profile breadth at this version. Used in DSMB/DMC safety reviews and DSUR preparation.' ;
    rdfs:domain ind:InvestigatorBrochureSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phaseOfDevelopment rdf:type rdf:Property ;
    rdfs:label 'Phase Of Development' ;
    rdfs:comment 'Phase of clinical development applicable to this IB version (Phase 1 through Phase 4). The RSI content and listed adverse reactions evolve as the product progresses through development phases. Influences SUSAR reporting obligations.' ;
    rdfs:domain ind:InvestigatorBrochureSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productClass rdf:type rdf:Property ;
    rdfs:label 'Product Class' ;
    rdfs:comment 'Classification of the investigational product type. Determines applicable regulatory frameworks (e.g., BLA vs NDA vs PMA) and influences the RSI structure and SUSAR reporting obligations.' ;
    rdfs:domain ind:InvestigatorBrochureSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rsiContentSummary rdf:type rdf:Property ;
    rdfs:label 'Rsi Content Summary' ;
    rdfs:comment 'Narrative summary of the Reference Safety Information section content, describing the known safety profile of the investigational product as documented in this IB version. Provides the basis for expectedness determination for adverse reactions.' ;
    rdfs:domain ind:InvestigatorBrochureSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rsiSectionReference rdf:type rdf:Property ;
    rdfs:label 'Rsi Section Reference' ;
    rdfs:comment 'Section number or heading within the IB that constitutes the Reference Safety Information (RSI), typically the Summary of Safety and Adverse Reactions section (e.g., Section 8.1). Used by Oracle Argus Safety to locate the RSI for expectedness determination.' ;
    rdfs:domain ind:InvestigatorBrochureSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:susarTriggeredAmendment rdf:type rdf:Property ;
    rdfs:label 'Susar Triggered Amendment' ;
    rdfs:comment 'Indicates whether this IB version was created as a direct result of a SUSAR that required the RSI to be updated to reflect new safety information. True = this amendment was SUSAR-driven. Key field for regulatory inspection readiness and Oracle Argus Safety audit trail.' ;
    rdfs:domain ind:InvestigatorBrochureSafety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:argusDictReference rdf:type rdf:Property ;
    rdfs:label 'Argus Dict Reference' ;
    rdfs:comment 'The internal dictionary record identifier assigned by Oracle Argus Safety when this MedDRA term is loaded into the Argus dictionary module. Enables direct cross-reference between the lakehouse silver layer and the Oracle Argus Safety system of record for adverse event coding reconciliation and audit.' ;
    rdfs:domain ind:MeddraTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:introducedVersion rdf:type rdf:Property ;
    rdfs:label 'Introduced Version' ;
    rdfs:comment 'The MedDRA version in which this term was first introduced into the dictionary. Supports historical analysis of term availability across study timelines and ensures correct version-gating when coding adverse events from legacy studies.' ;
    rdfs:domain ind:MeddraTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLltCurrent rdf:type rdf:Property ;
    rdfs:label 'Is Llt Current' ;
    rdfs:comment 'Applicable to LLT-level terms only. Indicates whether the LLT is a \'current\' LLT (true) — meaning it maps to a PT with the same name — or a \'non-current\' LLT (false) that maps to a PT with a different name. Current LLTs are preferred for new coding; non-current LLTs are retained for historical traceability per MSSO policy.' ;
    rdfs:domain ind:MeddraTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadDate rdf:type rdf:Property ;
    rdfs:label 'Load Date' ;
    rdfs:comment 'The date on which this MedDRA term record was loaded into the lakehouse silver layer from the MSSO distribution files. Used to track the effective date of each biannual dictionary update and to support audit trails required under 21 CFR Part 11 and ALCOA+ data integrity principles.' ;
    rdfs:domain ind:MeddraTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:raveDictEntryReference rdf:type rdf:Property ;
    rdfs:label 'Rave Dict Entry Reference' ;
    rdfs:comment 'The dictionary entry identifier assigned by Medidata Rave EDC when this MedDRA term is configured in the Rave coding dictionary for eCRF verbatim-to-MedDRA auto-coding. Supports reconciliation between EDC-coded adverse events and the master MedDRA reference in the lakehouse.' ;
    rdfs:domain ind:MeddraTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementTermCode rdf:type rdf:Property ;
    rdfs:label 'Replacement Term Code' ;
    rdfs:comment 'The 8-digit MedDRA code of the term that replaces this term when it has been retired, split, or merged. Null for active terms and retired terms with no direct replacement. Supports automated re-coding workflows in Oracle Argus Safety during biannual MedDRA version upgrades.' ;
    rdfs:domain ind:MeddraTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retiredVersion rdf:type rdf:Property ;
    rdfs:label 'Retired Version' ;
    rdfs:comment 'The MedDRA version in which this term was retired, if applicable. Null for active terms. Used to enforce coding rules in Oracle Argus Safety and to flag terms that should not be applied to new adverse event records after the specified version.' ;
    rdfs:domain ind:MeddraTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smqMembership rdf:type rdf:Property ;
    rdfs:label 'Smq Membership' ;
    rdfs:comment 'Pipe-delimited list of Standardised MedDRA Query (SMQ) names to which this PT belongs. SMQs are validated, topic-focused groupings of MedDRA terms used for signal detection, aggregate safety analysis, and regulatory queries (e.g., \'Anaphylactic reaction\', \'Drug-induced liver injury\'). Populated for PT-level terms only.' ;
    rdfs:domain ind:MeddraTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smqScope rdf:type rdf:Property ;
    rdfs:label 'Smq Scope' ;
    rdfs:comment 'Indicates whether this term\'s SMQ membership is classified as \'broad\' (higher sensitivity, more inclusive) or \'narrow\' (higher specificity, more restrictive) within the associated SMQ. Used to configure signal detection algorithms in Oracle Argus Safety and to define the scope of safety queries in regulatory submissions.' ;
    rdfs:domain ind:MeddraTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socAbbreviation rdf:type rdf:Property ;
    rdfs:label 'Soc Abbreviation' ;
    rdfs:comment 'The standardized two-to-four letter abbreviation for the System Organ Class (SOC) as defined by MSSO (e.g., \'CARD\' for Cardiac disorders, \'NERV\' for Nervous system disorders). Used in safety tabulation headers, DSMB/DMC slide decks, and abbreviated regulatory reports.' ;
    rdfs:domain ind:MeddraTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceFileName rdf:type rdf:Property ;
    rdfs:label 'Source File Name' ;
    rdfs:comment 'The name of the MSSO-distributed MedDRA ASCII flat file from which this term record was loaded (e.g., \'llt.asc\', \'pt.asc\', \'hlt.asc\', \'hlgt.asc\', \'soc.asc\'). Supports data lineage traceability and ETL audit for the biannual MedDRA dictionary update process in the Databricks lakehouse.' ;
    rdfs:domain ind:MeddraTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termCode rdf:type rdf:Property ;
    rdfs:label 'Term Code' ;
    rdfs:comment 'The official 8-digit numeric MedDRA term code assigned by the Maintenance and Support Services Organization (MSSO) uniquely identifying this term within the MedDRA hierarchy. Used as the primary lookup key in Oracle Argus Safety for adverse event coding and regulatory submissions.' ;
    rdfs:domain ind:MeddraTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termName rdf:type rdf:Property ;
    rdfs:label 'Term Name' ;
    rdfs:comment 'The official MedDRA term label as published by MSSO for this term code. Represents the standardized medical concept name used in adverse event coding, regulatory submissions (IND, NDA, BLA, MAA), and safety signal detection across all five hierarchy levels.' ;
    rdfs:domain ind:MeddraTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termStatus rdf:type rdf:Property ;
    rdfs:label 'Term Status' ;
    rdfs:comment 'Indicates whether the MedDRA term is currently active and available for coding or has been retired in a subsequent MedDRA version release. Retired terms are retained for historical traceability of previously coded adverse events but must not be used for new coding in Oracle Argus Safety.' ;
    rdfs:domain ind:MeddraTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termType rdf:type rdf:Property ;
    rdfs:label 'Term Type' ;
    rdfs:comment 'Classifies the term as \'standard\' (fully endorsed MedDRA term) or \'non-standard\' (a term that has been superseded, split, or merged and retained for backward compatibility). Drives coding validation rules in Oracle Argus Safety and Medidata Rave auto-coding configurations.' ;
    rdfs:domain ind:MeddraTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:whoArtMapping rdf:type rdf:Property ;
    rdfs:label 'Who Art Mapping' ;
    rdfs:comment 'The corresponding WHO Adverse Reaction Terminology (WHO-ART) preferred term code or name for this MedDRA term, where a legacy mapping exists. Supports legacy study migration and cross-dictionary reconciliation for studies coded under WHO-ART prior to MedDRA adoption.' ;
    rdfs:domain ind:MeddraTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCommunicationSafetyCommunicationId rdf:type rdf:Property ;
    rdfs:label 'Parent Communication Safety Communication Id' ;
    rdfs:comment 'Reference to the original (initial) safety communication record when this record is a follow-up communication. Null for initial communications. Enables reconstruction of the full communication chain for a given safety event.' ;
    rdfs:domain ind:SafetyCommunication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyCommunication .

ind:signalEvaluationId rdf:type rdf:Property ;
    rdfs:label 'Signal Evaluation Id' ;
    rdfs:comment 'Reference to the safety signal evaluation record that triggered this communication, where applicable. Null if triggered by a SUSAR or DSMB/DMC recommendation.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SignalEvaluation .

ind:acknowledgementReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Received Date' ;
    rdfs:comment 'Date on which formal acknowledgement of receipt was received from the primary recipient. Null if acknowledgement has not yet been received or is not required. Used for compliance tracking and site monitoring follow-up.' ;
    rdfs:domain ind:SafetyCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:argusCommunicationNumber rdf:type rdf:Property ;
    rdfs:label 'Argus Communication Number' ;
    rdfs:comment 'Externally-known unique reference number assigned by Oracle Argus Safety to this safety communication record. Used for cross-system traceability and regulatory audit trails.' ;
    rdfs:domain ind:SafetyCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsmbDmcNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Dsmb Dmc Notification Date' ;
    rdfs:comment 'Date on which the DSMB/DMC was formally notified of the safety event. Null if dsmb_dmc_notified is False. Used for DSMB/DMC meeting preparation and safety oversight audit trails.' ;
    rdfs:domain ind:SafetyCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dsmbDmcNotified rdf:type rdf:Property ;
    rdfs:label 'Dsmb Dmc Notified' ;
    rdfs:comment 'Indicates whether the Data Safety Monitoring Board (DSMB) or Data Monitoring Committee (DMC) was formally notified of the safety event underlying this communication. Supports DSMB/DMC oversight tracking.' ;
    rdfs:domain ind:SafetyCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpNumber rdf:type rdf:Property ;
    rdfs:label 'Follow Up Number' ;
    rdfs:comment 'Sequential follow-up number for this communication, where 0 or null indicates the initial communication and integers ≥1 indicate subsequent follow-up communications providing updated safety information on the same triggering event.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isExpeditedReport rdf:type rdf:Property ;
    rdfs:label 'Is Expedited Report' ;
    rdfs:comment 'Indicates whether this safety communication constitutes an expedited regulatory report (7-day or 15-day) as defined by ICH E2A and applicable regional regulations. True = expedited report required and submitted; False = routine or non-expedited communication.' ;
    rdfs:domain ind:SafetyCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recipientType rdf:type rdf:Property ;
    rdfs:label 'Recipient Type' ;
    rdfs:comment 'Category of the primary recipient(s) of this safety communication. INVESTIGATOR: Principal Investigator at a clinical site; IRB_IEC: Institutional Review Board or Independent Ethics Committee; HEALTH_AUTHORITY: regulatory agency (FDA, EMA, PMDA, etc.); SPONSOR: pharmaceutical/biotech sponsor organization; DSMB_DMC: Data Safety Monitoring Board or Data Monitoring Committee; HEALTHCARE_PROFESSIONAL: broader HCP audience for DHPCs.' ;
    rdfs:domain ind:SafetyCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'Specific action(s) recommended to the recipient as a result of this safety communication, such as enhanced subject monitoring, protocol amendment implementation, informed consent update, or study suspension. Derived from the safety assessment and sponsor medical review.' ;
    rdfs:domain ind:SafetyCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Deadline Date' ;
    rdfs:comment 'The calculated deadline date by which this safety communication must be submitted to the relevant health authority, based on the reporting clock start date and applicable regulatory timeline (7-day for fatal/life-threatening SUSAR; 15-day for other serious unexpected reactions).' ;
    rdfs:domain ind:SafetyCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingClockStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Clock Start Date' ;
    rdfs:comment 'The date on which the regulatory reporting clock was initiated for this safety communication, typically the sponsor\'s date of first awareness of the triggering safety event. Determines the 7-day or 15-day expedited reporting deadline.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studySuspensionRequired rdf:type rdf:Property ;
    rdfs:label 'Study Suspension Required' ;
    rdfs:comment 'Indicates whether this safety communication is associated with a full or partial suspension of the clinical study or specific study arms. When True, study suspension actions must be tracked in Oracle Siebel CTMS.' ;
    rdfs:domain ind:SafetyCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:triggerEventType rdf:type rdf:Property ;
    rdfs:label 'Trigger Event Type' ;
    rdfs:comment 'The category of safety event or business process that initiated this communication. Distinguishes whether the communication was driven by a SUSAR, a detected safety signal, a DSMB/DMC review outcome, a health authority request, a protocol amendment, or a risk minimization measure.' ;
    rdfs:domain ind:SafetyCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:narrativeId rdf:type rdf:Property ;
    rdfs:label 'Narrative Id' ;
    rdfs:comment 'Unique surrogate identifier for the safety narrative record in the Databricks Silver Layer. Primary key for this data product.' ;
    rdfs:domain ind:Narrative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyNarrativeTmfDocumentId rdf:type rdf:Property ;
    rdfs:label 'Safety Narrative Tmf Document Id' ;
    rdfs:comment 'Foreign key linking to document.tmf_document. Business justification: Safety narratives are formal ICSR components filed as TMF documents. Medical writers and pharmacovigilance teams need to link the narrative record to its TMF-filed version for audit trail, version con' ;
    rdfs:domain ind:Narrative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TmfDocument .

ind:aeOnsetDate rdf:type rdf:Property ;
    rdfs:label 'Ae Onset Date' ;
    rdfs:comment 'Date on which the adverse event first began, as reported by the investigator or subject. Critical for calculating reporting timelines and for CDISC SDTM AE domain mapping.' ;
    rdfs:domain ind:Narrative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aeOutcome rdf:type rdf:Property ;
    rdfs:label 'Ae Outcome' ;
    rdfs:comment 'Coded outcome of the adverse event at the time of narrative authoring or case closure. Aligns with ICH E2B(R3) outcome codes and CDISC SDTM AE.AEOUT controlled terminology.' ;
    rdfs:domain ind:Narrative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Ae Resolution Date' ;
    rdfs:comment 'Date on which the adverse event resolved or stabilized. Null if the event is ongoing at the time of narrative authoring. Used to determine event duration and outcome status.' ;
    rdfs:domain ind:Narrative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authoringDate rdf:type rdf:Property ;
    rdfs:label 'Authoring Date' ;
    rdfs:comment 'Date on which the safety narrative was initially authored or drafted. Supports ALCOA+ audit trail requirements and version history tracking.' ;
    rdfs:domain ind:Narrative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caseSummary rdf:type rdf:Property ;
    rdfs:label 'Case Summary' ;
    rdfs:comment 'High-level executive summary of the safety case, synthesizing the patient description, event, treatment, and outcome into a concise paragraph suitable for inclusion in the ICSR narrative field of E2B(R3) submissions.' ;
    rdfs:domain ind:Narrative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the safety case for which this narrative is written. SAE = Serious Adverse Event; SUSAR = Suspected Unexpected Serious Adverse Reaction; AE = Adverse Event; AESI = Adverse Event of Special Interest.' ;
    rdfs:domain ind:Narrative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:e2bMessageReference rdf:type rdf:Property ;
    rdfs:label 'E2b Message Reference' ;
    rdfs:comment 'Unique message identifier assigned to the ICSR transmission in E2B(R3) XML format as submitted via eCTD to health authorities. Enables traceability between the narrative record and the regulatory submission artifact.' ;
    rdfs:domain ind:Narrative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expeditedReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Expedited Report Due Date' ;
    rdfs:comment 'Regulatory deadline by which the expedited safety report (ICSR) must be submitted to health authorities. Calculated from the date of first awareness per ICH E2A (7-day for fatal/life-threatening; 15-day for other serious unexpected).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expeditedReportSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Expedited Report Submitted Date' ;
    rdfs:comment 'Actual date on which the expedited safety report (ICSR) was submitted to the relevant health authority via eCTD/E2B(R3) format. Used to verify compliance with regulatory reporting timelines.' ;
    rdfs:domain ind:Narrative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meddraPtTerm rdf:type rdf:Property ;
    rdfs:label 'Meddra Pt Term' ;
    rdfs:comment 'MedDRA Preferred Term text (e.g., \'Atrial fibrillation\') for the primary adverse event. Human-readable label used in narrative text and regulatory reports.' ;
    rdfs:domain ind:Narrative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meddraSocTerm rdf:type rdf:Property ;
    rdfs:label 'Meddra Soc Term' ;
    rdfs:comment 'MedDRA System Organ Class term (e.g., \'Cardiac disorders\') corresponding to the SOC code. Used for narrative labeling and regulatory submission display.' ;
    rdfs:domain ind:Narrative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalMonitorCommentary rdf:type rdf:Property ;
    rdfs:label 'Medical Monitor Commentary' ;
    rdfs:comment 'Clinical commentary and causality assessment provided by the medical monitor, including their opinion on the relationship between the investigational product and the adverse event, and any recommendations for protocol amendments or safety actions.' ;
    rdfs:domain ind:Narrative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalMonitorName rdf:type rdf:Property ;
    rdfs:label 'Medical Monitor Name' ;
    rdfs:comment 'Full name of the medical monitor or safety physician who reviewed and approved the safety narrative. Required for regulatory audit trail and ICSR submission accountability.' ;
    rdfs:domain ind:Narrative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:narrativeStatus rdf:type rdf:Property ;
    rdfs:label 'Narrative Status' ;
    rdfs:comment 'Current workflow status of the safety narrative document. Tracks progression from initial authoring through medical monitor review and approval to regulatory submission. \'superseded\' indicates a newer version has replaced this record.' ;
    rdfs:domain ind:Narrative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeDescription rdf:type rdf:Property ;
    rdfs:label 'Outcome Description' ;
    rdfs:comment 'Narrative section describing the resolution or current status of the adverse event, including recovery details, sequelae, or death information. Corresponds to the outcome field in E2B(R3) regulatory submissions.' ;
    rdfs:domain ind:Narrative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectDescription rdf:type rdf:Property ;
    rdfs:label 'Subject Description' ;
    rdfs:comment 'Structured narrative section describing the patient\'s relevant medical history, demographics (age, sex, weight), concomitant medications, and pre-existing conditions relevant to the adverse event. Contains protected health information (PHI).' ;
    rdfs:domain ind:Narrative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByObligationReportingObligationId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Obligation Reporting Obligation Id' ;
    rdfs:comment 'Reference to the newer safety_reporting_obligation record that supersedes this one when regulatory requirements are updated. Enables traceability of obligation version history and ensures Oracle Argus Safety applies the current rule.' ;
    rdfs:domain ind:ReportingObligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReportingObligation .

ind:applicableRegulation rdf:type rdf:Property ;
    rdfs:label 'Applicable Regulation' ;
    rdfs:comment 'The specific regulatory citation governing this reporting obligation (e.g., \'21 CFR 312.32\', \'EU CTR Art. 42\', \'ICH E2A\', \'ICH E2F\', \'ISO 14155 Clause 7.10\'). Used for regulatory correspondence, audit trails, and compliance documentation in Veeva Vault.' ;
    rdfs:domain ind:ReportingObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:argusReportTypeCode rdf:type rdf:Property ;
    rdfs:label 'Argus Report Type Code' ;
    rdfs:comment 'Oracle Argus Safety system report type code (e.g., \'EXP-7\', \'EXP-15\', \'DSUR-ANNUAL\') that maps this obligation to the Argus Safety case classification and output configuration. Used for automated case routing and report generation.' ;
    rdfs:domain ind:ReportingObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:argusWorkflowTemplate rdf:type rdf:Property ;
    rdfs:label 'Argus Workflow Template' ;
    rdfs:comment 'Name or identifier of the Oracle Argus Safety workflow template configured for this reporting obligation. Maps the obligation to the automated case processing, routing, and deadline calculation workflow in Argus Safety.' ;
    rdfs:domain ind:ReportingObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:causalityScope rdf:type rdf:Property ;
    rdfs:label 'Causality Scope' ;
    rdfs:comment 'Defines whether this obligation applies to events assessed as related to the investigational product, unrelated, or all events regardless of causality. Drives Oracle Argus Safety auto-routing logic for expedited reports.' ;
    rdfs:domain ind:ReportingObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clockDayType rdf:type rdf:Property ;
    rdfs:label 'Clock Day Type' ;
    rdfs:comment 'Specifies whether the reporting clock counts calendar days or business days. Most regulatory agencies (FDA, EMA) use calendar days for expedited safety reports per ICH E2A.' ;
    rdfs:domain ind:ReportingObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clockStartEvent rdf:type rdf:Property ;
    rdfs:label 'Clock Start Event' ;
    rdfs:comment 'Defines the business event that starts the regulatory reporting clock (e.g., AWARENESS_DATE — day sponsor becomes aware of the event; RECEIPT_DATE — day report is received from site). Critical for automated deadline calculation in Oracle Argus Safety per ICH E2A Day 0 rules.' ;
    rdfs:domain ind:ReportingObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationAlertDays rdf:type rdf:Property ;
    rdfs:label 'Escalation Alert Days' ;
    rdfs:comment 'Number of days before the regulatory deadline at which an escalation alert is triggered in Oracle Argus Safety to notify the safety team of an approaching submission deadline. Enables proactive compliance management.' ;
    rdfs:domain ind:ReportingObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectednessScope rdf:type rdf:Property ;
    rdfs:label 'Expectedness Scope' ;
    rdfs:comment 'Defines whether this obligation applies to unexpected adverse reactions (not listed in the Reference Safety Information), expected reactions, or all events. Unexpected serious adverse reactions (SUSARs) trigger expedited reporting under ICH E2A.' ;
    rdfs:domain ind:ReportingObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatalityScope rdf:type rdf:Property ;
    rdfs:label 'Fatality Scope' ;
    rdfs:comment 'Specifies whether this obligation applies specifically to fatal events (7-day clock), non-fatal events (15-day clock), or all events regardless of outcome. Fatal SUSARs require 7-day expedited reporting under ICH E2A and 21 CFR 312.32.' ;
    rdfs:domain ind:ReportingObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpClockDays rdf:type rdf:Property ;
    rdfs:label 'Follow Up Clock Days' ;
    rdfs:comment 'Number of calendar days within which a follow-up report must be submitted after new significant information becomes available following the initial expedited report. Typically 15 days per ICH E2A for follow-up SUSARs.' ;
    rdfs:domain ind:ReportingObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followUpReportRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Report Required' ;
    rdfs:comment 'Indicates whether a follow-up report must be submitted after the initial expedited report when additional information becomes available. Follow-up reports are required under ICH E2A when the initial report was incomplete.' ;
    rdfs:domain ind:ReportingObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gracePeriodHours rdf:type rdf:Property ;
    rdfs:label 'Grace Period Hours' ;
    rdfs:comment 'Number of hours of grace period allowed beyond the regulatory deadline before a compliance breach is flagged in Oracle Argus Safety. Accounts for weekends, public holidays, and system downtime. Typically 0 for strict regulatory deadlines.' ;
    rdfs:domain ind:ReportingObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investigatorNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Investigator Notification Required' ;
    rdfs:comment 'Indicates whether all Principal Investigators (PIs) participating in the study must be notified of the safety finding when this obligation is triggered. Drives investigator notification letter generation in Oracle Argus Safety.' ;
    rdfs:domain ind:ReportingObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:obligationCode rdf:type rdf:Property ;
    rdfs:label 'Obligation Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this reporting obligation rule (e.g., SUSAR-FATAL-7D-FDA, SAE-15D-EMA). Used as the business key in Oracle Argus Safety deadline configuration and compliance dashboards.' ;
    rdfs:domain ind:ReportingObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationName rdf:type rdf:Property ;
    rdfs:label 'Obligation Name' ;
    rdfs:comment 'Human-readable name describing the reporting obligation (e.g., \'SUSAR Fatal 7-Day Expedited Report to FDA\', \'Annual Development Safety Update Report to EMA\'). Used in compliance monitoring dashboards and regulatory correspondence.' ;
    rdfs:domain ind:ReportingObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodicReportFrequency rdf:type rdf:Property ;
    rdfs:label 'Periodic Report Frequency' ;
    rdfs:comment 'Frequency at which periodic safety reports (e.g., DSUR, PSUR) must be submitted under this obligation. Applicable only when reporting_category is PERIODIC or ANNUAL. Drives scheduled report generation in Oracle Argus Safety.' ;
    rdfs:domain ind:ReportingObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceSafetyInfoDocument rdf:type rdf:Property ;
    rdfs:label 'Reference Safety Info Document' ;
    rdfs:comment 'Name or identifier of the Reference Safety Information (RSI) document used to assess expectedness for this obligation (e.g., Investigator\'s Brochure version, SmPC, USPI). Expectedness is assessed against the RSI to determine SUSAR status per ICH E2A.' ;
    rdfs:domain ind:ReportingObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBasisDescription rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis Description' ;
    rdfs:comment 'Narrative description of the regulatory basis and rationale for this reporting obligation, including relevant guideline sections, agency guidance documents, and any country-specific deviations from ICH standards. Supports regulatory audit and inspection readiness.' ;
    rdfs:domain ind:ReportingObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCategory rdf:type rdf:Property ;
    rdfs:label 'Reporting Category' ;
    rdfs:comment 'Indicates whether this obligation requires expedited (immediate) reporting or periodic/annual reporting. Expedited applies to SUSARs and fatal SAEs; periodic applies to DSURs and PSURs. Drives workflow prioritization in Oracle Argus Safety.' ;
    rdfs:domain ind:ReportingObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingClockDays rdf:type rdf:Property ;
    rdfs:label 'Reporting Clock Days' ;
    rdfs:comment 'Number of calendar days from the clock start event within which the safety report must be submitted to the regulatory agency (e.g., 7 for fatal SUSARs, 15 for non-fatal SUSARs and SAEs, 30 for IND annual reports). Drives automated deadline calculation in Oracle Argus Safety.' ;
    rdfs:domain ind:ReportingObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seriousnessScope rdf:type rdf:Property ;
    rdfs:label 'Seriousness Scope' ;
    rdfs:comment 'Defines whether this obligation applies to serious adverse events (SAEs), non-serious adverse events, or all events. Serious events meeting ICH E2A criteria trigger expedited reporting obligations.' ;
    rdfs:domain ind:ReportingObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionGateway rdf:type rdf:Property ;
    rdfs:label 'Submission Gateway' ;
    rdfs:comment 'Electronic gateway or portal through which the safety report is transmitted to the regulatory agency (e.g., EUDRAVIGILANCE for EMA, FDA_FAERS for FDA). Drives Oracle Argus Safety transmission routing configuration. [ENUM-REF-CANDIDATE: EUDRAVIGILANCE|FDA_FAERS|MHRA_YELLOW_CARD|PMDA_GATEWAY|TGA_DATABASE|HEALTH_CANADA_MHPD|OTHER — promote to reference product]' ;
    rdfs:domain ind:ReportingObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:argusCommitteeReference rdf:type rdf:Property ;
    rdfs:label 'Argus Committee Reference' ;
    rdfs:comment 'Reference identifier for this committee as configured in Oracle Argus Safety for routing SAE/SUSAR reports and safety data packages to the committee. Enables traceability between safety case management and committee oversight.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:associatedStudyCount rdf:type rdf:Property ;
    rdfs:label 'Associated Study Count' ;
    rdfs:comment 'Number of clinical studies currently under the oversight of this committee. A single DMC/DSMB may oversee multiple studies within a development program. Used for workload assessment and committee capacity planning.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:charterExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Charter Expiry Date' ;
    rdfs:comment 'Date on which the current charter version expires and requires renewal or amendment. Null if the charter is open-ended and tied to study completion. Used for compliance tracking in MasterControl.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closedSessionRequired rdf:type rdf:Property ;
    rdfs:label 'Closed Session Required' ;
    rdfs:comment 'Indicates whether the committee charter mandates a closed/executive session restricted to independent committee members and the unblinded statistician, excluding sponsor representatives. Required for independent DMC/DSMB per FDA guidance.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:committeeName rdf:type rdf:Property ;
    rdfs:label 'Committee Name' ;
    rdfs:comment 'Official full name of the safety review committee as defined in its charter (e.g., \'Study XYZ Data Monitoring Committee\', \'Global Safety Review Committee\'). Used as the primary human-readable identifier across CTMS and safety systems.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committeeStatus rdf:type rdf:Property ;
    rdfs:label 'Committee Status' ;
    rdfs:comment 'Current lifecycle status of the committee. \'active\' = operational and conducting reviews; \'inactive\' = temporarily not meeting; \'dissolved\' = formally disbanded at study close-out; \'suspended\' = operations halted pending investigation; \'pending_charter\' = established but charter not yet approved.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityAgreementRequired rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Agreement Required' ;
    rdfs:comment 'Indicates whether all committee members are required to execute a confidentiality agreement prior to receiving unblinded study data. Mandatory for independent committees with unblinded access per GCP and sponsor SOPs.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ctmsCommitteeReference rdf:type rdf:Property ;
    rdfs:label 'Ctms Committee Reference' ;
    rdfs:comment 'Identifier for this committee record in Oracle Siebel CTMS, used for meeting scheduling, site notification workflows, and cross-system reconciliation between the CTMS and the lakehouse.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishmentDate rdf:type rdf:Property ;
    rdfs:label 'Establishment Date' ;
    rdfs:comment 'Date on which the committee was formally established and constituted by the sponsor. Marks the start of the committee\'s operational lifecycle and is recorded in the Trial Master File (TMF).' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:independentStatisticianAssigned rdf:type rdf:Property ;
    rdfs:label 'Independent Statistician Assigned' ;
    rdfs:comment 'Indicates whether an independent (unblinded) statistician has been formally assigned to support the committee with unblinded data analysis. Required for DSMB/DMC operations per ICH E9(R1) and FDA guidance.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Last Meeting Date' ;
    rdfs:comment 'Date of the most recently completed committee meeting. Used for monitoring meeting cadence compliance against the charter-defined frequency and for DSMB/DMC oversight tracking in Oracle Siebel CTMS.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meetingMinutesRequired rdf:type rdf:Property ;
    rdfs:label 'Meeting Minutes Required' ;
    rdfs:comment 'Indicates whether formal written minutes are required for each committee meeting per the charter. Minutes are a GCP requirement for DMC/DSMB meetings and must be archived in the eTMF.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openSessionRequired rdf:type rdf:Property ;
    rdfs:label 'Open Session Required' ;
    rdfs:comment 'Indicates whether the committee charter mandates an open session (attended by sponsor representatives) in addition to the closed/executive session (independent members only). Standard DMC practice per FDA guidance.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outstandingRecommendationsCount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Recommendations Count' ;
    rdfs:comment 'Number of committee recommendations that have been issued but not yet formally resolved or closed by the sponsor. A non-zero value triggers escalation workflows in Oracle Siebel CTMS and MasterControl CAPA tracking.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTherapeuticArea rdf:type rdf:Property ;
    rdfs:label 'Primary Therapeutic Area' ;
    rdfs:comment 'The primary therapeutic area or disease indication for which the committee provides safety oversight (e.g., \'Oncology\', \'Cardiovascular\', \'Neurology\'). Used for committee expertise matching and portfolio-level safety analytics.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingAuthority rdf:type rdf:Property ;
    rdfs:label 'Reporting Authority' ;
    rdfs:comment 'Name or role of the organizational body or individual to whom the committee formally reports its recommendations (e.g., \'Sponsor Medical Officer\', \'Executive Steering Committee\', \'IRB/IEC\'). Defines the escalation path for safety recommendations.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyDataPackageFrequency rdf:type rdf:Property ;
    rdfs:label 'Safety Data Package Frequency' ;
    rdfs:comment 'Frequency at which the unblinded safety data package is prepared and distributed to committee members prior to meetings. Governs data preparation schedules in SAS Drug Development and Oracle Argus Safety.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorLiaisonName rdf:type rdf:Property ;
    rdfs:label 'Sponsor Liaison Name' ;
    rdfs:comment 'Full name of the sponsor\'s designated liaison or medical monitor who serves as the primary point of contact between the sponsor organization and the committee. This individual typically attends open sessions but is excluded from closed sessions.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalCharterIncluded rdf:type rdf:Property ;
    rdfs:label 'Statistical Charter Included' ;
    rdfs:comment 'Indicates whether the committee charter includes a statistical analysis plan (SAP) or statistical charter defining interim analysis rules, stopping boundaries (e.g., O\'Brien-Fleming, Lan-DeMets), and alpha-spending functions. Critical for DSMB/DMC oversight of adaptive trials.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stoppingRulesDefined rdf:type rdf:Property ;
    rdfs:label 'Stopping Rules Defined' ;
    rdfs:comment 'Indicates whether the charter defines pre-specified stopping rules for efficacy, futility, or safety that the committee is empowered to invoke. Presence of stopping rules is a key regulatory expectation for DSMB/DMC charters.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalMeetingsHeld rdf:type rdf:Property ;
    rdfs:label 'Total Meetings Held' ;
    rdfs:comment 'Cumulative count of formal committee meetings held since the committee\'s establishment. Used for lifecycle tracking, regulatory inspection readiness, and TMF completeness verification.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unblindedAccess rdf:type rdf:Property ;
    rdfs:label 'Unblinded Access' ;
    rdfs:comment 'Indicates whether the committee has access to unblinded (treatment-arm-identified) safety and efficacy data during its reviews. Unblinded access is standard for independent DMC/DSMB; internal SRCs may operate on blinded data. Governs data preparation workflows in SAS Drug Development.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assignedMedicalMonitorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Medical Monitor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Signal management requires a named responsible medical monitor employee for evaluation ownership, regulatory reporting accountability, and DSMB escalation decisions. assigned_medical_monitor is a deno' ;
    rdfs:domain ind:Signal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:argusSignalReference rdf:type rdf:Property ;
    rdfs:label 'Argus Signal Reference' ;
    rdfs:comment 'Native signal identifier assigned by Oracle Argus Safety signal detection and evaluation module. Used for traceability back to the source system of record.' ;
    rdfs:domain ind:Signal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseCount rdf:type rdf:Property ;
    rdfs:label 'Case Count' ;
    rdfs:comment 'Total number of adverse event cases contributing to the safety signal at the time of detection or most recent evaluation. Represents the volume of evidence supporting the signal.' ;
    rdfs:domain ind:Signal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataReviewedSummary rdf:type rdf:Property ;
    rdfs:label 'Data Reviewed Summary' ;
    rdfs:comment 'Summary of the data sources and datasets reviewed during signal evaluation, including case narratives, aggregate safety data, literature, and clinical trial data from Medidata Rave or SAS Drug Development outputs.' ;
    rdfs:domain ind:Signal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionDate rdf:type rdf:Property ;
    rdfs:label 'Detection Date' ;
    rdfs:comment 'Date on which the safety signal was first identified or flagged, either by automated detection algorithms in Oracle Argus Safety or by a medical monitor during clinical review. Critical for regulatory reporting timelines.' ;
    rdfs:domain ind:Signal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Completion Date' ;
    rdfs:comment 'Date on which the formal evaluation of the safety signal was completed and a final disposition was reached. Null if evaluation is still in progress.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationCycleNumber rdf:type rdf:Property ;
    rdfs:label 'Evaluation Cycle Number' ;
    rdfs:comment 'Sequential cycle number for the current evaluation of this safety signal. Supports multiple evaluation cycles as new data emerges (e.g., Cycle 1 = initial evaluation, Cycle 2 = re-evaluation after new cases). Enables tracking of iterative signal assessments.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluationDueDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Due Date' ;
    rdfs:comment 'Target due date for completing the signal evaluation, based on signal priority and applicable regulatory timelines (e.g., 30 days for high-priority signals per EMA GVP Module IX). Used for SLA tracking and escalation.' ;
    rdfs:domain ind:Signal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPlan rdf:type rdf:Property ;
    rdfs:label 'Evaluation Plan' ;
    rdfs:comment 'Narrative description of the planned approach for evaluating the safety signal, including data sources to be reviewed, analyses to be conducted, and timelines. Documented in Oracle Argus Safety evaluation module.' ;
    rdfs:domain ind:Signal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Start Date' ;
    rdfs:comment 'Date on which formal evaluation of the safety signal was initiated. Used to track evaluation timelines against regulatory and internal SOP requirements.' ;
    rdfs:domain ind:Signal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalDisposition rdf:type rdf:Property ;
    rdfs:label 'Final Disposition' ;
    rdfs:comment 'Final outcome of the signal evaluation process. Indicates whether the signal was validated as a new risk, validated as a change in known risk, refuted as not a true signal, requires further monitoring, or requires no action. Populated upon evaluation completion.' ;
    rdfs:domain ind:Signal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDsmbReferred rdf:type rdf:Property ;
    rdfs:label 'Is Dsmb Referred' ;
    rdfs:comment 'Indicates whether this safety signal has been referred to the Data Safety Monitoring Board (DSMB) or Data Monitoring Committee (DMC) for independent review. True = referred; False = not referred.' ;
    rdfs:domain ind:Signal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExpeditedReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Is Expedited Reporting Required' ;
    rdfs:comment 'Indicates whether this safety signal triggers expedited regulatory reporting obligations (e.g., 7-day or 15-day IND safety report to FDA, or SUSAR report to EMA). True = expedited reporting required; False = routine reporting.' ;
    rdfs:domain ind:Signal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSusarRelated rdf:type rdf:Property ;
    rdfs:label 'Is Susar Related' ;
    rdfs:comment 'Indicates whether this safety signal is associated with one or more Suspected Unexpected Serious Adverse Reactions (SUSARs). True = SUSAR-related; False = not SUSAR-related. Relevant for expedited regulatory reporting obligations.' ;
    rdfs:domain ind:Signal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryActionRecommended rdf:type rdf:Property ;
    rdfs:label 'Regulatory Action Recommended' ;
    rdfs:comment 'Regulatory action recommended as a result of signal evaluation. Options include label update (update Investigator Brochure or product label), Direct Healthcare Professional Communication (DHPC), study suspension, protocol amendment, risk minimization measures, no action required, or further monitoring. [ENUM-REF-CANDIDATE: label_update|DHPC|study_suspension|protocol_amendment|risk_minimization|no_action|further_monitoring — promote to reference product]' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryActionStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Action Status' ;
    rdfs:comment 'Current implementation status of the recommended regulatory action. Tracks whether the recommended action (e.g., label update, protocol amendment) has been initiated, completed, or determined not required.' ;
    rdfs:domain ind:Signal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalDescription rdf:type rdf:Property ;
    rdfs:label 'Signal Description' ;
    rdfs:comment 'Detailed narrative describing the nature of the safety signal, including the observed drug-event association, population affected, and clinical context. Supports medical monitor review and regulatory reporting.' ;
    rdfs:domain ind:Signal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalNumber rdf:type rdf:Property ;
    rdfs:label 'Signal Number' ;
    rdfs:comment 'Human-readable, externally-known business identifier for the safety signal (e.g., SIG-2024-00123). Used in regulatory correspondence, DSMB/DMC reports, and cross-functional communications.' ;
    rdfs:domain ind:Signal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalStatus rdf:type rdf:Property ;
    rdfs:label 'Signal Status' ;
    rdfs:comment 'Current lifecycle status of the safety signal in the evaluation workflow. Tracks progression from initial detection through evaluation to final disposition. Values: new (newly detected, not yet evaluated), under_evaluation (active evaluation in progress), validated (confirmed as a real signal), refuted (determined not to be a true signal), ongoing_monitoring (validated but under continued surveillance), closed (evaluation complete, no further action required).' ;
    rdfs:domain ind:Signal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strengthLowerCi rdf:type rdf:Property ;
    rdfs:label 'Strength Lower Ci' ;
    rdfs:comment 'Lower bound of the 95% confidence interval for the signal strength metric value. A lower CI > 1 (for PRR/ROR) or > 0 (for IC) typically indicates a statistically significant signal.' ;
    rdfs:domain ind:Signal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strengthMetricName rdf:type rdf:Property ;
    rdfs:label 'Strength Metric Name' ;
    rdfs:comment 'Name of the quantitative disproportionality metric used to measure signal strength (e.g., PRR - Proportional Reporting Ratio, ROR - Reporting Odds Ratio, BCPNN IC - Information Component, EBGM - Empirical Bayes Geometric Mean). Null if signal was detected by clinical review only.' ;
    rdfs:domain ind:Signal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strengthValue rdf:type rdf:Property ;
    rdfs:label 'Strength Value' ;
    rdfs:comment 'Numeric value of the signal strength metric (e.g., PRR = 3.45, ROR = 4.12, IC = 2.1). Used to quantify the degree of disproportionate reporting and support signal validation decisions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initialReportDate rdf:type rdf:Property ;
    rdfs:label 'Initial Report Date' ;
    rdfs:comment 'The date on which the SAE was first reported to the sponsor or CRO by the investigational site. This is Day 0 for calculating regulatory reporting timelines (e.g., 7-day or 15-day expedited reporting clock).' ;
    rdfs:domain ind:SeriousAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:saeStatus rdf:type rdf:Property ;
    rdfs:label 'Sae Status' ;
    rdfs:comment 'Current lifecycle status of the SAE case in Oracle Argus Safety. \'initial\' = first report received; \'follow_up\' = additional information received; \'closed\' = case fully resolved and closed; \'nullified\' = case determined not to meet SAE criteria and voided.' ;
    rdfs:domain ind:SeriousAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saeTerm rdf:type rdf:Property ;
    rdfs:label 'Sae Term' ;
    rdfs:comment 'The verbatim (as-reported) description of the serious adverse event as recorded by the investigator or site staff in the source document or eCRF. This is the raw, uncoded term prior to MedDRA coding.' ;
    rdfs:domain ind:SeriousAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriousnessCongenitalAnomaly rdf:type rdf:Property ;
    rdfs:label 'Seriousness Congenital Anomaly' ;
    rdfs:comment 'Indicates whether the SAE meets the regulatory seriousness criterion of resulting in a congenital anomaly or birth defect in the offspring of the subject.' ;
    rdfs:domain ind:SeriousAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seriousnessDeath rdf:type rdf:Property ;
    rdfs:label 'Seriousness Death' ;
    rdfs:comment 'Indicates whether the SAE meets the regulatory seriousness criterion of resulting in death of the subject. One of the six ICH E2A seriousness criteria that must be captured individually.' ;
    rdfs:domain ind:SeriousAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seriousnessDisability rdf:type rdf:Property ;
    rdfs:label 'Seriousness Disability' ;
    rdfs:comment 'Indicates whether the SAE meets the regulatory seriousness criterion of resulting in persistent or significant disability or incapacity.' ;
    rdfs:domain ind:SeriousAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seriousnessHospitalization rdf:type rdf:Property ;
    rdfs:label 'Seriousness Hospitalization' ;
    rdfs:comment 'Indicates whether the SAE meets the regulatory seriousness criterion of requiring inpatient hospitalization or prolongation of existing hospitalization.' ;
    rdfs:domain ind:SeriousAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seriousnessLifeThreatening rdf:type rdf:Property ;
    rdfs:label 'Seriousness Life Threatening' ;
    rdfs:comment 'Indicates whether the SAE meets the regulatory seriousness criterion of being immediately life-threatening (i.e., the subject was at immediate risk of death at the time of the event).' ;
    rdfs:domain ind:SeriousAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seriousnessMedicallyImportant rdf:type rdf:Property ;
    rdfs:label 'Seriousness Medically Important' ;
    rdfs:comment 'Indicates whether the SAE meets the regulatory seriousness criterion of being an other medically important condition — events that may not be immediately life-threatening but may jeopardize the subject or require intervention to prevent one of the other serious outcomes.' ;
    rdfs:domain ind:SeriousAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Sponsor Receipt Date' ;
    rdfs:comment 'The date on which the sponsor (or CRO acting on behalf of the sponsor) received the complete minimum information required to process the SAE. This date starts the regulatory reporting clock per ICH E2A.' ;
    rdfs:domain ind:SeriousAdverseEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:argusSignalEvaluationNumber rdf:type rdf:Property ;
    rdfs:label 'Argus Signal Evaluation Number' ;
    rdfs:comment 'Externally-known business identifier for this signal evaluation as assigned by Oracle Argus Safety. Used for cross-system traceability and regulatory correspondence. Serves as the BUSINESS_IDENTIFIER for this TRANSACTION_HEADER.' ;
    rdfs:domain ind:SignalEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitRiskAssessmentSummary rdf:type rdf:Property ;
    rdfs:label 'Benefit Risk Assessment Summary' ;
    rdfs:comment 'Narrative summary of the benefit-risk assessment conducted during this evaluation cycle, documenting the clinical judgment on the balance between therapeutic benefit and identified safety risk.' ;
    rdfs:domain ind:SignalEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseCountReviewed rdf:type rdf:Property ;
    rdfs:label 'Case Count Reviewed' ;
    rdfs:comment 'Total number of adverse event cases reviewed during this signal evaluation cycle. Provides a quantitative measure of the evidence base examined.' ;
    rdfs:domain ind:SignalEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSourcesReviewed rdf:type rdf:Property ;
    rdfs:label 'Data Sources Reviewed' ;
    rdfs:comment 'Description of the data sources reviewed during this evaluation, such as clinical trial databases, spontaneous report databases (FAERS, EudraVigilance), published literature, and DSMB/DMC reports.' ;
    rdfs:domain ind:SignalEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsmbDmcRecommendation rdf:type rdf:Property ;
    rdfs:label 'Dsmb Dmc Recommendation' ;
    rdfs:comment 'Formal recommendation issued by the DSMB or DMC following their independent review of the referred signal evaluation. Populated only when a DSMB/DMC review has been completed.' ;
    rdfs:domain ind:SignalEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsmbDmcReferralDate rdf:type rdf:Property ;
    rdfs:label 'Dsmb Dmc Referral Date' ;
    rdfs:comment 'Date on which the signal evaluation was formally referred to the DSMB or DMC for independent safety review. Populated only when is_dsmb_dmc_referral is True.' ;
    rdfs:domain ind:SignalEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Initiated Date' ;
    rdfs:comment 'The date on which the formal signal evaluation process was initiated. Serves as the principal BUSINESS_EVENT_TIMESTAMP for this transaction, marking the start of the regulatory evaluation clock.' ;
    rdfs:domain ind:SignalEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationOutcome rdf:type rdf:Property ;
    rdfs:label 'Evaluation Outcome' ;
    rdfs:comment 'Final outcome determination of the signal evaluation cycle. Indicates whether the signal was confirmed as a new safety finding, refuted by the evidence, or requires ongoing monitoring.' ;
    rdfs:domain ind:SignalEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationPlanDescription rdf:type rdf:Property ;
    rdfs:label 'Evaluation Plan Description' ;
    rdfs:comment 'Narrative description of the evaluation plan, including the scope of data to be reviewed, analytical approach, and objectives for this evaluation cycle.' ;
    rdfs:domain ind:SignalEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationStatus rdf:type rdf:Property ;
    rdfs:label 'Evaluation Status' ;
    rdfs:comment 'Current lifecycle state of the signal evaluation workflow. Tracks progression from initiation through completion. LIFECYCLE_STATUS for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:SignalEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expeditedReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Expedited Reporting Required' ;
    rdfs:comment 'Indicates whether this signal evaluation triggers an expedited regulatory reporting obligation (e.g., SUSAR 7-day or 15-day report). True = expedited reporting required.' ;
    rdfs:domain ind:SignalEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:healthAuthorityQueryReference rdf:type rdf:Property ;
    rdfs:label 'Health Authority Query Reference' ;
    rdfs:comment 'Reference number assigned by a regulatory authority (FDA, EMA, MHRA, etc.) for any formal query or request for information related to this signal evaluation. Enables traceability of regulatory correspondence.' ;
    rdfs:domain ind:SignalEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDsmbDmcReferral rdf:type rdf:Property ;
    rdfs:label 'Is Dsmb Dmc Referral' ;
    rdfs:comment 'Indicates whether this signal evaluation has been referred to the Data Safety Monitoring Board (DSMB) or Data Monitoring Committee (DMC) for independent review. True = referred; False = not referred.' ;
    rdfs:domain ind:SignalEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryActionJustification rdf:type rdf:Property ;
    rdfs:label 'Regulatory Action Justification' ;
    rdfs:comment 'Narrative justification for the recommended regulatory action, documenting the clinical and scientific rationale supporting the recommendation.' ;
    rdfs:domain ind:SignalEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskMinimizationMeasure rdf:type rdf:Property ;
    rdfs:label 'Risk Minimization Measure' ;
    rdfs:comment 'Risk minimization measure recommended or implemented as a result of this signal evaluation. Supports Risk Management Plan (RMP) updates and regulatory commitments.' ;
    rdfs:domain ind:SignalEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalDetectionMethod rdf:type rdf:Property ;
    rdfs:label 'Signal Detection Method' ;
    rdfs:comment 'Statistical or clinical methodology used to detect the safety signal prior to this evaluation. Examples include disproportionality analysis (PRR, ROR), data mining algorithms, or clinical case series review.' ;
    rdfs:domain ind:SignalEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalSource rdf:type rdf:Property ;
    rdfs:label 'Signal Source' ;
    rdfs:comment 'Origin of the safety signal that triggered this evaluation. Identifies whether the signal arose from spontaneous adverse event reports, clinical trial data, published literature, a regulatory authority communication, or DSMB/DMC review. [ENUM-REF-CANDIDATE: spontaneous_reports|clinical_trial_data|literature|regulatory_authority|dsmb_dmc|eudravigilance|faers|internal_review — promote to reference product]' ;
    rdfs:domain ind:SignalEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blindBreakDate rdf:type rdf:Property ;
    rdfs:label 'Blind Break Date' ;
    rdfs:comment 'Date on which the treatment blind was broken for this subject. Populated only when blind_broken is True. Required for audit trail and regulatory documentation of unblinding events.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blindBroken rdf:type rdf:Property ;
    rdfs:label 'Blind Broken' ;
    rdfs:comment 'Indicates whether the treatment blind was broken for this subject in order to perform the causality assessment for this SUSAR. A blind break is a significant event requiring documentation and regulatory notification.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blindStatus rdf:type rdf:Property ;
    rdfs:label 'Blind Status' ;
    rdfs:comment 'Blinding status of the study at the time of SUSAR reporting. Indicates whether the study was blinded, and if so, whether the blind was broken for this subject to determine treatment assignment for causality assessment.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Externally-known alphanumeric case number assigned by the sponsor or CRO for this SUSAR, used in all regulatory submissions and correspondence. Serves as the BUSINESS_IDENTIFIER for this transaction.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadline15day rdf:type rdf:Property ;
    rdfs:label 'Deadline 15day' ;
    rdfs:comment 'Calculated deadline for 15-day expedited reporting to regulatory authorities for non-fatal/non-life-threatening SUSARs. Derived from the reporting clock start date plus 15 calendar days per ICH E2A and FDA 21 CFR 312.32.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deadline7day rdf:type rdf:Property ;
    rdfs:label 'Deadline 7day' ;
    rdfs:comment 'Calculated deadline for 7-day expedited reporting to regulatory authorities for fatal or life-threatening SUSARs. Derived from the reporting clock start date plus 7 calendar days per ICH E2A and FDA 21 CFR 312.32.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:doseAtOnset rdf:type rdf:Property ;
    rdfs:label 'Dose At Onset' ;
    rdfs:comment 'Dose of the investigational product administered to the subject at the time of the adverse reaction onset, including amount and unit (e.g., \'100 mg\'). Required for causality assessment and regulatory case narratives.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eudravigilanceNumber rdf:type rdf:Property ;
    rdfs:label 'Eudravigilance Number' ;
    rdfs:comment 'Unique case identifier assigned by the EudraVigilance system upon submission of the SUSAR to the EMA. Used for tracking and referencing the case in EU regulatory correspondence and EudraVigilance database.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectednessAssessment rdf:type rdf:Property ;
    rdfs:label 'Expectedness Assessment' ;
    rdfs:comment 'Assessment of whether the serious adverse reaction is unexpected — i.e., not listed or not consistent with the nature, severity, or frequency described in the current Investigator\'s Brochure (IB). A SUSAR must be assessed as unexpected to qualify for expedited reporting.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatalDate rdf:type rdf:Property ;
    rdfs:label 'Fatal Date' ;
    rdfs:comment 'Date of subject death if the outcome of the SUSAR is fatal. Triggers the 7-day expedited reporting clock and is required for death narratives in regulatory submissions.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingStatus rdf:type rdf:Property ;
    rdfs:label 'Reporting Status' ;
    rdfs:comment 'Current lifecycle state of the SUSAR regulatory reporting workflow. Tracks progression from initial draft through submission to regulatory authority acknowledgement and case closure. Serves as the LIFECYCLE_STATUS for this transaction.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionReportType rdf:type rdf:Property ;
    rdfs:label 'Submission Report Type' ;
    rdfs:comment 'Indicates whether this SUSAR submission is an initial report, a follow-up report with additional information, or a final report closing the case. Regulatory authorities require tracking of report versions per ICH E2A.' ;
    rdfs:domain ind:Susar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Enrollment Performance Id' ;
    rdfs:comment 'Unique surrogate identifier for each enrollment performance record at the study-site-reporting period level. Primary key for this data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:EnrollmentPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activeSubjectCount rdf:type rdf:Property ;
    rdfs:label 'Active Subject Count' ;
    rdfs:comment 'The number of subjects currently active (enrolled and not yet completed or discontinued) at this site as of the end of the reporting period. Reflects current site workload and capacity utilization.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualScreenedCount rdf:type rdf:Property ;
    rdfs:label 'Actual Screened Count' ;
    rdfs:comment 'The actual number of subjects who underwent screening procedures at this site during the reporting period, as captured in the EDC (Medidata Rave) and reconciled with CTMS.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completedCount rdf:type rdf:Property ;
    rdfs:label 'Completed Count' ;
    rdfs:comment 'The number of subjects who completed all protocol-required study procedures and visits at this site during the reporting period. Used for PP population analysis and study close-out planning.' ;
    rdfs:domain ind:EnrollmentPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cumulativeDropoutCount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Dropout Count' ;
    rdfs:comment 'The total number of enrolled subjects who have discontinued participation at this site from study activation through the end of the current reporting period. Used for retention analysis and ITT/PP population tracking.' ;
    rdfs:domain ind:EnrollmentPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cumulativeEnrolledCount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Enrolled Count' ;
    rdfs:comment 'The total number of subjects enrolled at this site from study activation through the end of the current reporting period. Primary metric for tracking progress toward the site\'s enrollment target.' ;
    rdfs:domain ind:EnrollmentPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cumulativeScreenedCount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Screened Count' ;
    rdfs:comment 'The total number of subjects screened at this site from study activation through the end of the current reporting period. Enables longitudinal enrollment trend analysis and forecasting.' ;
    rdfs:domain ind:EnrollmentPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dropoutCount rdf:type rdf:Property ;
    rdfs:label 'Dropout Count' ;
    rdfs:comment 'The number of enrolled subjects who discontinued participation (withdrew consent, were lost to follow-up, or were discontinued by investigator) during the reporting period. Impacts ITT and PP population sizes.' ;
    rdfs:domain ind:EnrollmentPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enrollmentRatePerMonth rdf:type rdf:Property ;
    rdfs:label 'Enrollment Rate Per Month' ;
    rdfs:comment 'The average number of subjects enrolled per calendar month at this site during the reporting period. Sourced from CTMS enrollment tracking; used for enrollment forecasting and site performance benchmarking.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentTargetAchievementPct rdf:type rdf:Property ;
    rdfs:label 'Enrollment Target Achievement Pct' ;
    rdfs:comment 'The percentage of the site\'s total enrollment target achieved cumulatively as of the end of the reporting period (cumulative_enrolled_count / site_enrollment_target × 100). Stored as a raw business metric from CTMS for site performance dashboards.' ;
    rdfs:domain ind:EnrollmentPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentVariance rdf:type rdf:Property ;
    rdfs:label 'Enrollment Variance' ;
    rdfs:comment 'The difference between actual enrolled subjects and planned enrolled subjects for the reporting period (actual_enrolled_count - planned_enrolled_count). Negative values indicate under-enrollment; positive values indicate over-enrollment. Stored as a raw business metric from CTMS.' ;
    rdfs:domain ind:EnrollmentPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gcpComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Gcp Compliance Status' ;
    rdfs:comment 'The current GCP compliance status of the site as assessed by the most recent monitoring visit or audit. Drives risk-based monitoring decisions and regulatory escalation. Sourced from Oracle Siebel CTMS monitoring records.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icfSignedCount rdf:type rdf:Property ;
    rdfs:label 'Icf Signed Count' ;
    rdfs:comment 'The number of subjects who signed the Informed Consent Form (ICF) at this site during the reporting period. ICF signature is the first step in the enrollment process and is tracked separately from screening and randomization per GCP requirements.' ;
    rdfs:domain ind:EnrollmentPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:irbIecApprovalExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Approval Expiry Date' ;
    rdfs:comment 'The date on which the current IRB/IEC approval for this study at this site expires. Sites must obtain renewal before this date to continue enrollment. Tracked in Veeva Vault regulatory module.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMonitoringVisitDate rdf:type rdf:Property ;
    rdfs:label 'Last Monitoring Visit Date' ;
    rdfs:comment 'The date of the most recent on-site or remote monitoring visit conducted by the CRA at this site. Used to assess monitoring frequency compliance and identify sites overdue for monitoring.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextMonitoringVisitDate rdf:type rdf:Property ;
    rdfs:label 'Next Monitoring Visit Date' ;
    rdfs:comment 'The date of the next scheduled monitoring visit at this site, as planned in the CTMS. Used for CRA workload planning and ensuring monitoring frequency meets the risk-based monitoring plan.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceStatus rdf:type rdf:Property ;
    rdfs:label 'Performance Status' ;
    rdfs:comment 'Current enrollment performance status of the site for the reporting period, indicating whether the site is meeting, exceeding, or falling short of its planned enrollment targets. Drives CRA escalation and site management actions in the CTMS.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEnrolledCount rdf:type rdf:Property ;
    rdfs:label 'Planned Enrolled Count' ;
    rdfs:comment 'The target number of subjects planned to be enrolled (randomized or consented per protocol definition) at this site during the reporting period. Derived from the site-level enrollment plan agreed with the sponsor.' ;
    rdfs:domain ind:EnrollmentPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedScreenedCount rdf:type rdf:Property ;
    rdfs:label 'Planned Screened Count' ;
    rdfs:comment 'The number of subjects planned to be screened at this site during the reporting period, as defined in the site enrollment plan or feasibility agreement. Baseline for screen failure rate analysis.' ;
    rdfs:domain ind:EnrollmentPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Projected Completion Date' ;
    rdfs:comment 'The forecasted date by which the site is expected to complete enrollment of its assigned target, based on current enrollment rate. Updated each reporting period in the CTMS for timeline management.' ;
    rdfs:domain ind:EnrollmentPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:screenFailureCount rdf:type rdf:Property ;
    rdfs:label 'Screen Failure Count' ;
    rdfs:comment 'The number of subjects who were screened but did not meet eligibility criteria and were therefore not enrolled during the reporting period. A key metric for site feasibility and protocol amendment decisions.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteCapacity rdf:type rdf:Property ;
    rdfs:label 'Site Capacity' ;
    rdfs:comment 'The maximum number of subjects the site can concurrently manage based on staff, facilities, and resources, as assessed during site feasibility. Used to evaluate whether the site is operating within capacity.' ;
    rdfs:domain ind:EnrollmentPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteEnrollmentTarget rdf:type rdf:Property ;
    rdfs:label 'Site Enrollment Target' ;
    rdfs:comment 'The total number of subjects the site is contracted or planned to enroll over the full duration of the study, as agreed in the site initiation agreement or enrollment plan. Denominator for cumulative enrollment progress percentage.' ;
    rdfs:domain ind:EnrollmentPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteNumber rdf:type rdf:Property ;
    rdfs:label 'Site Number' ;
    rdfs:comment 'The sponsor- or CRO-assigned unique site identifier code for the investigational site. Used as the externally-known business identifier for the site in regulatory submissions and CTMS reporting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feasibilityAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Feasibility Assessment Id' ;
    rdfs:comment 'Unique system-generated identifier for the site feasibility assessment record. Primary key for this entity.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FeasibilityAssessment .

ind:competingTrialCount rdf:type rdf:Property ;
    rdfs:label 'Competing Trial Count' ;
    rdfs:comment 'Number of currently active or planned clinical trials at the site that compete for the same patient population or therapeutic area. High competing trial load may reduce enrollment capacity.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dedicatedResearchStaffCount rdf:type rdf:Property ;
    rdfs:label 'Dedicated Research Staff Count' ;
    rdfs:comment 'Number of dedicated clinical research staff (Clinical Research Coordinators (CRCs), research nurses, data entry staff) available at the site to support this study.' ;
    rdfs:domain ind:FeasibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:edcAccessAvailable rdf:type rdf:Property ;
    rdfs:label 'Edc Access Available' ;
    rdfs:comment 'Indicates whether the site has the necessary IT infrastructure, internet connectivity, and hardware to access the study\'s Electronic Data Capture (EDC) system (e.g., Medidata Rave).' ;
    rdfs:domain ind:FeasibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrollmentExperienceScore rdf:type rdf:Property ;
    rdfs:label 'Enrollment Experience Score' ;
    rdfs:comment 'Sub-score component reflecting the site\'s historical enrollment performance, patient population access, and therapeutic area experience. Contributes to the composite feasibility score.' ;
    rdfs:domain ind:FeasibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedEnrollmentCapacity rdf:type rdf:Property ;
    rdfs:label 'Estimated Enrollment Capacity' ;
    rdfs:comment 'The site\'s self-reported estimate of the number of eligible subjects it can enroll for this specific study over the planned enrollment period. Core metric for site selection decisions.' ;
    rdfs:domain ind:FeasibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedScreenFailureRate rdf:type rdf:Property ;
    rdfs:label 'Estimated Screen Failure Rate' ;
    rdfs:comment 'Site\'s estimated percentage of screened subjects expected to fail eligibility criteria for this study. Used to adjust enrollment projections and calculate required screening numbers.' ;
    rdfs:domain ind:FeasibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feasibilityScore rdf:type rdf:Property ;
    rdfs:label 'Feasibility Score' ;
    rdfs:comment 'Composite numeric score (typically 0–100) assigned to the site based on weighted evaluation of all feasibility criteria including enrollment potential, infrastructure, and experience. Used for comparative site ranking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feasibilityScoreTier rdf:type rdf:Property ;
    rdfs:label 'Feasibility Score Tier' ;
    rdfs:comment 'Categorical tier classification derived from the feasibility score (e.g., High ≥ 75, Medium 50–74, Low < 50). Used for rapid site prioritization and sponsor reporting.' ;
    rdfs:domain ind:FeasibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imagingCapabilitiesAvailable rdf:type rdf:Property ;
    rdfs:label 'Imaging Capabilities Available' ;
    rdfs:comment 'Indicates whether the site has the required imaging infrastructure (e.g., MRI, CT, PET) specified in the study protocol for efficacy or safety assessments.' ;
    rdfs:domain ind:FeasibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irbIecStatus rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Status' ;
    rdfs:comment 'Current status of the site\'s Institutional Review Board (IRB) or Independent Ethics Committee (IEC) relationship at the time of feasibility assessment. Active IRB/IEC is a prerequisite for site activation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labCapabilitiesAvailable rdf:type rdf:Property ;
    rdfs:label 'Lab Capabilities Available' ;
    rdfs:comment 'Indicates whether the site has on-site or contracted laboratory capabilities required by the study protocol (e.g., local lab processing, sample storage, cold chain management).' ;
    rdfs:domain ind:FeasibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patientPopulationSize rdf:type rdf:Property ;
    rdfs:label 'Patient Population Size' ;
    rdfs:comment 'Estimated number of patients in the site\'s catchment area who match the study\'s target indication and could potentially be eligible for enrollment.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pharmacyCapabilitiesAvailable rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Capabilities Available' ;
    rdfs:comment 'Indicates whether the site has an investigational drug pharmacy with appropriate storage, dispensing, and accountability capabilities as required by the study protocol.' ;
    rdfs:domain ind:FeasibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorStudyExperienceCount rdf:type rdf:Property ;
    rdfs:label 'Prior Study Experience Count' ;
    rdfs:comment 'Number of prior clinical studies the site has conducted in the same therapeutic area or indication. Reflects site expertise and GCP compliance track record.' ;
    rdfs:domain ind:FeasibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:questionnaireResponseNotes rdf:type rdf:Property ;
    rdfs:label 'Questionnaire Response Notes' ;
    rdfs:comment 'Free-text field capturing additional site comments, clarifications, or qualitative responses provided by the site during the feasibility questionnaire completion.' ;
    rdfs:domain ind:FeasibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:questionnaireVersion rdf:type rdf:Property ;
    rdfs:label 'Questionnaire Version' ;
    rdfs:comment 'Version identifier of the feasibility questionnaire template used for this assessment (e.g., v2.1). Ensures traceability of assessment criteria across protocol amendments.' ;
    rdfs:domain ind:FeasibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Score' ;
    rdfs:comment 'Sub-score component reflecting the site\'s GCP compliance history, inspection findings, audit outcomes, and regulatory standing. Derived from CTMS compliance tracking data.' ;
    rdfs:domain ind:FeasibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:selectionDecision rdf:type rdf:Property ;
    rdfs:label 'Selection Decision' ;
    rdfs:comment 'Final site selection outcome derived from this feasibility assessment. Indicates whether the site was selected, not selected, placed on hold, or awaiting decision.' ;
    rdfs:domain ind:FeasibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCountryCode rdf:type rdf:Property ;
    rdfs:label 'Site Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the country in which the investigational site is located. Used for regional enrollment planning and regulatory jurisdiction determination.' ;
    rdfs:domain ind:FeasibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteInfrastructureScore rdf:type rdf:Property ;
    rdfs:label 'Site Infrastructure Score' ;
    rdfs:comment 'Sub-score component of the overall feasibility score reflecting the site\'s physical and technical infrastructure readiness (EDC, lab, pharmacy, imaging). Scored on a standardized scale.' ;
    rdfs:domain ind:FeasibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteRegion rdf:type rdf:Property ;
    rdfs:label 'Site Region' ;
    rdfs:comment 'Geographic region classification of the investigational site (e.g., North America, Europe, Asia-Pacific). Used for regional enrollment tracking and sponsor reporting.' ;
    rdfs:domain ind:FeasibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorComments rdf:type rdf:Property ;
    rdfs:label 'Sponsor Comments' ;
    rdfs:comment 'Free-text comments entered by the sponsor or CRO reviewer following evaluation of the feasibility questionnaire. Documents rationale for selection decisions or follow-up requirements.' ;
    rdfs:domain ind:FeasibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localLabFacilityId rdf:type rdf:Property ;
    rdfs:label 'Local Lab Facility Id' ;
    rdfs:comment 'Foreign key linking to laboratory.lab_facility. Business justification: Sites with local labs must reference the qualified lab_facility for specimen processing, local safety lab results, and site activation checklists. investigational_site.has_local_laboratory is a boolea' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabFacility .

ind:closeoutDate rdf:type rdf:Property ;
    rdfs:label 'Closeout Date' ;
    rdfs:comment 'Date on which the investigational site was formally closed out, completing all study-related activities, resolving outstanding data queries, and returning or destroying unused investigational product. Triggers archival obligations per GCP.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Dun & Bradstreet Data Universal Numbering System (DUNS) nine-digit identifier for the investigational site organization. Used for sponsor contracting, grant management, and financial due diligence.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eudractSiteNumber rdf:type rdf:Property ;
    rdfs:label 'Eudract Site Number' ;
    rdfs:comment 'European Union Drug Regulating Authorities Clinical Trials (EudraCT) site-level identifier assigned for EU-regulated clinical trials. Required for EMA regulatory submissions and EU CTR 536/2014 compliance reporting.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number for the investigational site, used for transmission of regulatory documents, IRB/IEC correspondence, and sponsor communications where electronic submission is not available.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaFeiNumber rdf:type rdf:Property ;
    rdfs:label 'Fda Fei Number' ;
    rdfs:comment 'U.S. Food and Drug Administration (FDA) Facility Establishment Identifier (FEI) number assigned to the investigational site. Required for FDA-regulated clinical trials and referenced in IND applications and NDA/BLA submissions.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasDedicatedResearchStaff rdf:type rdf:Property ;
    rdfs:label 'Has Dedicated Research Staff' ;
    rdfs:comment 'Indicates whether the investigational site employs dedicated clinical research staff (e.g., Clinical Research Coordinators (CRCs), research nurses) exclusively for clinical trial conduct, as opposed to relying solely on general clinical staff.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasLocalLaboratory rdf:type rdf:Property ;
    rdfs:label 'Has Local Laboratory' ;
    rdfs:comment 'Indicates whether the investigational site has an on-site clinical laboratory certified to process and analyze clinical trial specimens. Relevant for protocol feasibility, sample logistics planning, and central vs. local lab decisions.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasPharmacy rdf:type rdf:Property ;
    rdfs:label 'Has Pharmacy' ;
    rdfs:comment 'Indicates whether the investigational site has an on-site pharmacy capable of receiving, storing, dispensing, and accounting for investigational medicinal products (IMPs) per GCP and regulatory requirements.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irasNumber rdf:type rdf:Property ;
    rdfs:label 'Iras Number' ;
    rdfs:comment 'UK Integrated Research Application System (IRAS) project identifier assigned to the site for studies conducted under MHRA oversight. Required for UK clinical trial regulatory submissions.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent quality assurance (QA) audit conducted at the investigational site by the sponsor, CRO, or regulatory authority. Used to track audit frequency and compliance with quality management plans.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxEnrollmentCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Enrollment Capacity' ;
    rdfs:comment 'Maximum number of subjects the investigational site can enroll and manage concurrently across all active clinical trials. Used for site capacity planning, feasibility assessments, and enrollment forecasting in Oracle Siebel CTMS.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfExamRooms rdf:type rdf:Property ;
    rdfs:label 'Number Of Exam Rooms' ;
    rdfs:comment 'Total number of dedicated examination or procedure rooms available at the investigational site for clinical trial subject visits. Informs site capacity assessments and feasibility scoring.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openCapaCount rdf:type rdf:Property ;
    rdfs:label 'Open Capa Count' ;
    rdfs:comment 'Number of currently open Corrective and Preventive Actions (CAPAs) assigned to the investigational site resulting from monitoring visits, audits, or regulatory inspections. A key GCP compliance KPI tracked in MasterControl.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary telephone number for the investigational site facility. Used for CRA monitoring visit coordination, sponsor communications, and emergency contact during study conduct.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCode rdf:type rdf:Property ;
    rdfs:label 'Site Code' ;
    rdfs:comment 'Sponsor- or CRO-assigned alphanumeric code uniquely identifying the investigational site within the clinical trial management system (CTMS). Used as the operational business key across Medidata Rave, Oracle Siebel CTMS, and Oracle Clinical One for site cross-referencing.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteEmail rdf:type rdf:Property ;
    rdfs:label 'Site Email' ;
    rdfs:comment 'Primary institutional email address for the investigational site. Used for sponsor and CRO communications, regulatory correspondence, and eTMF document distribution.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteName rdf:type rdf:Property ;
    rdfs:label 'Site Name' ;
    rdfs:comment 'Official legal or operating name of the investigational site facility (e.g., hospital, clinic, research center). Used for regulatory submissions, TMF documentation, and sponsor communications.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteTier rdf:type rdf:Property ;
    rdfs:label 'Site Tier' ;
    rdfs:comment 'Sponsor or CRO-assigned tier classification reflecting the site\'s strategic importance, historical performance, enrollment capacity, and GCP compliance track record. Tier 1 represents highest-performing strategic sites; Tier 4 represents new or lower-performing sites.' ;
    rdfs:domain ind:InvestigationalSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalLetterReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Approval Letter Received Date' ;
    rdfs:comment 'The date on which the site or sponsor received the official IRB/IEC approval letter. May differ from the approval_date if there is a postal or administrative delay.' ;
    rdfs:domain ind:IrbIecApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedIcfDate rdf:type rdf:Property ;
    rdfs:label 'Approved Icf Date' ;
    rdfs:comment 'The date of the approved ICF version. Used together with approved_icf_version to confirm the exact ICF document authorized for subject consent at this site.' ;
    rdfs:domain ind:IrbIecApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedIcfVersion rdf:type rdf:Property ;
    rdfs:label 'Approved Icf Version' ;
    rdfs:comment 'The specific version number of the Informed Consent Form (ICF) approved by the IRB/IEC for use at this site. Subjects must be consented using only the IRB/IEC-approved ICF version.' ;
    rdfs:domain ind:IrbIecApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsResolvedDate rdf:type rdf:Property ;
    rdfs:label 'Conditions Resolved Date' ;
    rdfs:comment 'The date on which all conditions attached to a conditional IRB/IEC approval were formally resolved and confirmed by the ethics committee. Null if no conditions were imposed or if conditions remain outstanding.' ;
    rdfs:domain ind:IrbIecApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ctmsApprovalRecordCode rdf:type rdf:Property ;
    rdfs:label 'Ctms Approval Record Code' ;
    rdfs:comment 'The native record identifier for this IRB/IEC approval in the Oracle Siebel CTMS source system. Used for data lineage, reconciliation, and cross-system traceability.' ;
    rdfs:domain ind:IrbIecApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localLanguageIcfApproved rdf:type rdf:Property ;
    rdfs:label 'Local Language Icf Approved' ;
    rdfs:comment 'Indicates whether the IRB/IEC has approved a local-language translation of the ICF for use at this site. Required for sites where the subject population is not primarily English-speaking.' ;
    rdfs:domain ind:IrbIecApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localLanguageIcfVersion rdf:type rdf:Property ;
    rdfs:label 'Local Language Icf Version' ;
    rdfs:comment 'Version identifier of the local-language ICF approved by the IRB/IEC. Null if no local-language ICF was required or approved.' ;
    rdfs:domain ind:IrbIecApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxEnrollmentApproved rdf:type rdf:Property ;
    rdfs:label 'Max Enrollment Approved' ;
    rdfs:comment 'The maximum number of subjects that the IRB/IEC has approved for enrollment at this site under this approval. Enrollment must not exceed this number without a new amendment approval.' ;
    rdfs:domain ind:IrbIecApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pediatricEnrollmentApproved rdf:type rdf:Property ;
    rdfs:label 'Pediatric Enrollment Approved' ;
    rdfs:comment 'Indicates whether the IRB/IEC has specifically approved enrollment of pediatric subjects at this site. Requires additional parental consent and assent documentation per applicable regulations.' ;
    rdfs:domain ind:IrbIecApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vulnerablePopulationApproved rdf:type rdf:Property ;
    rdfs:label 'Vulnerable Population Approved' ;
    rdfs:comment 'Indicates whether the IRB/IEC approval explicitly covers enrollment of vulnerable populations (e.g., minors, pregnant women, prisoners, cognitively impaired individuals). Requires additional safeguards per applicable regulations.' ;
    rdfs:domain ind:IrbIecApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverOfConsentApproved rdf:type rdf:Property ;
    rdfs:label 'Waiver Of Consent Approved' ;
    rdfs:comment 'Indicates whether the IRB/IEC has granted a waiver or alteration of the informed consent requirement for this study-site. Applicable in specific circumstances such as emergency research.' ;
    rdfs:domain ind:IrbIecApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:boardCertification rdf:type rdf:Property ;
    rdfs:label 'Board Certification' ;
    rdfs:comment 'Name of the specialty board certification held by the PI (e.g., American Board of Internal Medicine - Oncology). Validates clinical expertise required by the study protocol.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Board Certification Expiry Date' ;
    rdfs:comment 'Date on which the PI\'s board certification expires. Monitored to ensure ongoing qualification compliance during study conduct.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ctmsInvestigatorCode rdf:type rdf:Property ;
    rdfs:label 'Ctms Investigator Code' ;
    rdfs:comment 'Source system investigator identifier from Oracle Siebel CTMS. Used for cross-system reconciliation and data lineage tracing between the lakehouse silver layer and the operational CTMS.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cvVersionDate rdf:type rdf:Property ;
    rdfs:label 'Cv Version Date' ;
    rdfs:comment 'Date of the most recent version of the PI\'s curriculum vitae (CV) on file. The CV is a required TMF document demonstrating the PI\'s qualifications per ICH E6(R2).' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:debarmentCheckDate rdf:type rdf:Property ;
    rdfs:label 'Debarment Check Date' ;
    rdfs:comment 'Date on which the most recent FDA debarment check was performed for this PI. Periodic re-checks are required per sponsor SOPs.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:debarmentCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Debarment Check Status' ;
    rdfs:comment 'Result of the FDA debarment check confirming the PI is not listed on the FDA Debarment List under 21 CFR Part 312.70. Mandatory pre-study qualification step.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegationLogCurrent rdf:type rdf:Property ;
    rdfs:label 'Delegation Log Current' ;
    rdfs:comment 'Indicates whether the PI\'s delegation of authority log is current and up-to-date in the eTMF. A delegation log documents tasks delegated to sub-investigators and CRCs per ICH E6(R2).' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disqualificationDate rdf:type rdf:Property ;
    rdfs:label 'Disqualification Date' ;
    rdfs:comment 'Date on which the PI was disqualified from conducting clinical trials, either by a regulatory authority or by the sponsor. Nullable for active investigators.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disqualificationReason rdf:type rdf:Property ;
    rdfs:label 'Disqualification Reason' ;
    rdfs:comment 'Narrative description of the reason for PI disqualification, if applicable. Populated only when lifecycle_status is \'disqualified\'. Required for regulatory audit trail.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary professional email address for the PI used for regulatory correspondence, system access provisioning, and CTMS notifications.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eudractInvestigatorNumber rdf:type rdf:Property ;
    rdfs:label 'Eudract Investigator Number' ;
    rdfs:comment 'European Clinical Trials Database (EudraCT / CTIS) identifier assigned to the PI for EU-based clinical trial registrations under EU CTR 536/2014.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaInvestigatorNumber rdf:type rdf:Property ;
    rdfs:label 'Fda Investigator Number' ;
    rdfs:comment 'FDA-assigned investigator identifier, if applicable, used in IND applications and regulatory submissions to uniquely identify the PI in FDA systems.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Financial Disclosure Date' ;
    rdfs:comment 'Date on which the PI\'s financial disclosure form (FDA Form 3454 or 3455) was most recently submitted. Required for NDA/BLA/MAA regulatory submissions.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialDisclosureStatus rdf:type rdf:Property ;
    rdfs:label 'Financial Disclosure Status' ;
    rdfs:comment 'Status of the PI\'s financial disclosure filing (FDA Form 3454/3455) required under 21 CFR Part 54. Discloses financial interests that could affect study objectivity.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:form1572Date rdf:type rdf:Property ;
    rdfs:label 'Form 1572 Date' ;
    rdfs:comment 'Date on which the most recent FDA Form 1572 was signed and submitted for this PI. Used for regulatory compliance tracking and TMF completeness verification.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:form1572Status rdf:type rdf:Property ;
    rdfs:label 'Form 1572 Status' ;
    rdfs:comment 'Current submission status of the FDA Form 1572 (Statement of Investigator) for this PI. The Form 1572 is a regulatory commitment by the PI to conduct the study per GCP and the approved protocol.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gcpTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Gcp Training Date' ;
    rdfs:comment 'Date on which the PI most recently completed ICH Good Clinical Practice (GCP) training. Required for regulatory compliance and site initiation visit (SIV) clearance.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gcpTrainingExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Gcp Training Expiry Date' ;
    rdfs:comment 'Date on which the PI\'s current GCP training certification expires. Triggers re-training workflow in MasterControl to maintain continuous compliance.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gcpTrainingProvider rdf:type rdf:Property ;
    rdfs:label 'Gcp Training Provider' ;
    rdfs:comment 'Name of the organization or platform that delivered the GCP training (e.g., CITI Program, TransCelerate, NIH). Used for audit trail and regulatory inspection readiness.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionHistoryFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection History Flag' ;
    rdfs:comment 'Indicates whether the PI has been subject to a prior FDA, EMA, MHRA, or other regulatory authority inspection. Used in risk-based site selection and monitoring planning.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:institutionCountry rdf:type rdf:Property ;
    rdfs:label 'Institution Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the PI\'s primary institution is located. Determines applicable regulatory framework (FDA, EMA, PMDA, TGA, Health Canada, MHRA).' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalLicenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Medical License Expiry Date' ;
    rdfs:comment 'Date on which the PI\'s medical license expires. Triggers renewal alerts in CTMS to ensure continuous licensure compliance throughout study conduct.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Medical License Number' ;
    rdfs:comment 'State or national medical license number issued to the PI by the relevant medical licensing authority. Required for FDA Form 1572 and site qualification documentation.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalLicenseState rdf:type rdf:Property ;
    rdfs:label 'Medical License State' ;
    rdfs:comment 'Two-letter U.S. state code (or equivalent jurisdiction code) where the PI\'s medical license is issued and active. Used to validate practice authority at the investigational site.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npiNumber rdf:type rdf:Property ;
    rdfs:label 'Npi Number' ;
    rdfs:comment '10-digit National Provider Identifier (NPI) assigned by CMS to the PI. Used for U.S.-based regulatory submissions, billing reconciliation, and provider identity verification.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orcidNumber rdf:type rdf:Property ;
    rdfs:label 'Orcid Number' ;
    rdfs:comment 'Globally unique ORCID identifier for the PI, enabling unambiguous researcher identification across publications, regulatory submissions, and clinical trial registries.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary professional contact phone number for the PI, used for urgent safety communications and site monitoring coordination.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piType rdf:type rdf:Property ;
    rdfs:label 'Pi Type' ;
    rdfs:comment 'Classification of the investigator role within the study hierarchy. Distinguishes the PI with full regulatory accountability from sub-investigators and coordinating investigators. [ENUM-REF-CANDIDATE: principal_investigator|sub_investigator|coordinating_investigator|national_coordinating_investigator — promote to reference product]' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorStudyCount rdf:type rdf:Property ;
    rdfs:label 'Prior Study Count' ;
    rdfs:comment 'Total number of clinical studies the PI has previously conducted as Principal Investigator. Used as a key metric in site feasibility assessments and sponsor qualification reviews.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:professionalTitle rdf:type rdf:Property ;
    rdfs:label 'Professional Title' ;
    rdfs:comment 'Academic or professional degree designation of the PI (e.g., MD, PhD, PharmD). Used to verify minimum qualification requirements per protocol and regulatory submissions. [ENUM-REF-CANDIDATE: MD|DO|PhD|PharmD|MD PhD|MBBS|DVM|NP|PA — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolTrainingComplete rdf:type rdf:Property ;
    rdfs:label 'Protocol Training Complete' ;
    rdfs:comment 'Indicates whether the PI has completed all required protocol-specific training for their currently assigned studies. Managed via MasterControl training management module.' ;
    rdfs:domain ind:PrincipalInvestigator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualificationDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Date' ;
    rdfs:comment 'Date on which the PI was formally qualified and approved by the sponsor or CRO to conduct clinical trials. Marks the start of the PI\'s active lifecycle in the investigator registry.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialty rdf:type rdf:Property ;
    rdfs:label 'Specialty' ;
    rdfs:comment 'Primary medical or scientific specialty of the PI (e.g., Oncology, Cardiology, Neurology, Infectious Disease). Used for protocol feasibility matching and site selection scoring.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionSiteId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Site Id' ;
    rdfs:comment 'Unique surrogate identifier for each site-level regulatory submission record in the Clinical Trial Management System (CTMS). Serves as the primary key for this entity.' ;
    rdfs:domain ind:RegulatorySubmissionSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalReference rdf:type rdf:Property ;
    rdfs:label 'Approval Reference' ;
    rdfs:comment 'The official reference number, protocol number, or tracking identifier issued by the regulatory authority or ethics committee upon approval of the site submission. Used for regulatory correspondence and audit trail.' ;
    rdfs:domain ind:RegulatorySubmissionSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialDisclosureType rdf:type rdf:Property ;
    rdfs:label 'Financial Disclosure Type' ;
    rdfs:comment 'Indicates the type of FDA financial disclosure form submitted for the investigator at this site: FDA Form 3454 (certification of no disclosable financial interest) or FDA Form 3455 (disclosure of financial interest). Required under 21 CFR Part 54 for studies supporting marketing applications.' ;
    rdfs:domain ind:RegulatorySubmissionSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialInterestDisclosed rdf:type rdf:Property ;
    rdfs:label 'Financial Interest Disclosed' ;
    rdfs:comment 'Indicates whether the investigator has disclosed a financial interest or arrangement that could affect the reliability of the clinical data, as required by 21 CFR Part 54. True if a disclosable financial interest exists (FDA Form 3455 filed); False if no disclosable interest (FDA Form 3454 filed).' ;
    rdfs:domain ind:RegulatorySubmissionSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:icfVersion rdf:type rdf:Property ;
    rdfs:label 'Icf Version' ;
    rdfs:comment 'The version of the Informed Consent Form (ICF) that was submitted to and approved by the IRB/IEC as part of this regulatory submission. Tracks which ICF version is authorized for use at the site.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localLanguageIcf rdf:type rdf:Property ;
    rdfs:label 'Local Language Icf' ;
    rdfs:comment 'Indicates whether the ICF submitted for IRB/IEC approval is in the local language of the site country, as required for patient comprehension and regulatory compliance in non-English-speaking countries.' ;
    rdfs:domain ind:RegulatorySubmissionSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryTimelineDays rdf:type rdf:Property ;
    rdfs:label 'Regulatory Timeline Days' ;
    rdfs:comment 'The number of calendar days from submission date to approval date, representing the actual regulatory review cycle time for this submission. Used for site activation performance analytics and benchmarking against regulatory authority standard timelines.' ;
    rdfs:domain ind:RegulatorySubmissionSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewComments rdf:type rdf:Property ;
    rdfs:label 'Review Comments' ;
    rdfs:comment 'Narrative comments or conditions provided by the regulatory authority or ethics committee as part of their review decision. Captures required modifications, conditions of approval, or reasons for deferral or rejection.' ;
    rdfs:domain ind:RegulatorySubmissionSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionPortalReference rdf:type rdf:Property ;
    rdfs:label 'Submission Portal Reference' ;
    rdfs:comment 'The tracking or confirmation number issued by the regulatory authority\'s electronic submission portal (e.g., FDA ESG, EMA CTIS, MHRA IRAS) upon receipt of the submission. Provides external confirmation of receipt.' ;
    rdfs:domain ind:RegulatorySubmissionSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationId rdf:type rdf:Property ;
    rdfs:label 'Activation Id' ;
    rdfs:comment 'Unique surrogate identifier for the site activation workflow record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Activation .

ind:activationStatus rdf:type rdf:Property ;
    rdfs:label 'Activation Status' ;
    rdfs:comment 'Current lifecycle state of the site activation workflow. Tracks overall progress from initiation through full activation or termination. [ENUM-REF-CANDIDATE: pending|in_progress|activated|on_hold|cancelled|closed — promote to reference product if additional states are required]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationType rdf:type rdf:Property ;
    rdfs:label 'Activation Type' ;
    rdfs:comment 'Categorizes the nature of the activation workflow — whether this is a new site being onboarded, a previously closed site being re-activated, a replacement for a terminated site, or an expansion site added mid-study.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualActivationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Activation Date' ;
    rdfs:comment 'The date on which the site was formally activated and cleared to enroll subjects. Corresponds to the completion of all mandatory activation milestones.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cdaExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Cda Execution Date' ;
    rdfs:comment 'The date on which the Confidentiality Disclosure Agreement (CDA) / Non-Disclosure Agreement (NDA) was fully executed between the sponsor/CRO and the investigational site. First milestone in the activation workflow.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cdaStatus rdf:type rdf:Property ;
    rdfs:label 'Cda Status' ;
    rdfs:comment 'Current status of the Confidentiality Disclosure Agreement (CDA) milestone within the site activation workflow.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsActivationRecordCode rdf:type rdf:Property ;
    rdfs:label 'Ctms Activation Record Code' ;
    rdfs:comment 'The externally-known activation record identifier as assigned by Oracle Siebel CTMS. Used for cross-system traceability and source reconciliation.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysElapsed rdf:type rdf:Property ;
    rdfs:label 'Days Elapsed' ;
    rdfs:comment 'Number of calendar days elapsed from the initiation of the activation workflow (CDA execution or site selection confirmation) to the current date or actual activation date. Used as a key performance indicator (KPI) for activation cycle time.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drugShipmentAuthDate rdf:type rdf:Property ;
    rdfs:label 'Drug Shipment Auth Date' ;
    rdfs:comment 'The date on which authorization was granted to ship investigational medicinal product (IMP) to the site. Requires completion of all prerequisite activation milestones including IRB/IEC approval and investigator agreement execution.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drugShipmentAuthStatus rdf:type rdf:Property ;
    rdfs:label 'Drug Shipment Auth Status' ;
    rdfs:comment 'Current status of the investigational medicinal product (IMP) shipment authorization milestone for this site activation.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcAccessProvisionedDate rdf:type rdf:Property ;
    rdfs:label 'Edc Access Provisioned Date' ;
    rdfs:comment 'The date on which site staff were granted access to the Electronic Data Capture (EDC) system (e.g., Medidata Rave) for this study, enabling electronic Case Report Form (eCRF) data entry.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:edcAccessStatus rdf:type rdf:Property ;
    rdfs:label 'Edc Access Status' ;
    rdfs:comment 'Current status of EDC system access provisioning for site staff as part of the site activation workflow.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:essentialDocsVerified rdf:type rdf:Property ;
    rdfs:label 'Essential Docs Verified' ;
    rdfs:comment 'Indicates whether all essential documents required for site activation (as defined in ICH E6(R2) Appendix) have been collected, verified, and filed in the Trial Master File (TMF) or eTMF.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialAgreementExecuted rdf:type rdf:Property ;
    rdfs:label 'Financial Agreement Executed' ;
    rdfs:comment 'Indicates whether the site budget and payment agreement (Clinical Trial Agreement financial schedule) has been fully executed between the sponsor/CRO and the site institution, a prerequisite for site activation.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fpfvDate rdf:type rdf:Property ;
    rdfs:label 'Fpfv Date' ;
    rdfs:comment 'The date on which the first subject at this site completed their first protocol-mandated visit. A key clinical operations milestone marking the start of active enrollment at the site.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gcpTrainingCompleted rdf:type rdf:Property ;
    rdfs:label 'Gcp Training Completed' ;
    rdfs:comment 'Indicates whether the site staff (PI and CRC) have completed mandatory Good Clinical Practice (GCP) training as required prior to site activation and subject enrollment.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigatorAgreementDate rdf:type rdf:Property ;
    rdfs:label 'Investigator Agreement Date' ;
    rdfs:comment 'The date on which the Clinical Trial Agreement (CTA) or Investigator Agreement was fully executed between the sponsor/CRO and the Principal Investigator (PI) or site institution.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigatorAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Investigator Agreement Status' ;
    rdfs:comment 'Current status of the Investigator Agreement / Clinical Trial Agreement (CTA) milestone in the site activation workflow.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbIecSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Submission Date' ;
    rdfs:comment 'The date on which the study protocol and informed consent documents were submitted to the Institutional Review Board (IRB) or Independent Ethics Committee (IEC) for ethical review and approval.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onHoldReason rdf:type rdf:Property ;
    rdfs:label 'On Hold Reason' ;
    rdfs:comment 'Describes the reason the site activation workflow has been placed on hold, if applicable. Populated when activation_status is \'on_hold\'. Examples include sponsor decision, regulatory query, or site resource unavailability.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEnrollmentTarget rdf:type rdf:Property ;
    rdfs:label 'Planned Enrollment Target' ;
    rdfs:comment 'The number of subjects the site is expected to enroll in the study as agreed during site selection and activation planning. Used for capacity planning and performance tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:protocolReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Protocol Receipt Date' ;
    rdfs:comment 'The date on which the investigational site confirmed receipt of the study protocol and related documents from the sponsor or CRO.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:protocolReceiptStatus rdf:type rdf:Property ;
    rdfs:label 'Protocol Receipt Status' ;
    rdfs:comment 'Current status of the protocol receipt milestone in the site activation workflow, indicating whether the site has confirmed receipt of the study protocol.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryPkgApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Pkg Approval Date' ;
    rdfs:comment 'The date on which the health authority granted approval or clearance for the regulatory submission package, permitting the study to proceed at this site.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryPkgStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Pkg Status' ;
    rdfs:comment 'Current status of the regulatory package submission milestone in the site activation workflow.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryPkgSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Pkg Submission Date' ;
    rdfs:comment 'The date on which the regulatory submission package (including essential documents such as investigator brochure, protocol, and site-specific regulatory forms) was submitted to the applicable health authority.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sivCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Siv Completed Date' ;
    rdfs:comment 'The date on which the Site Initiation Visit (SIV) was successfully completed. Completion of the SIV is a prerequisite for site activation and subject enrollment.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sivScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Siv Scheduled Date' ;
    rdfs:comment 'The planned date for the Site Initiation Visit (SIV), during which the Clinical Research Associate (CRA) trains site staff on the protocol, EDC system, and GCP requirements.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sivStatus rdf:type rdf:Property ;
    rdfs:label 'Siv Status' ;
    rdfs:comment 'Current status of the Site Initiation Visit (SIV) milestone within the site activation workflow.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetActivationDate rdf:type rdf:Property ;
    rdfs:label 'Target Activation Date' ;
    rdfs:comment 'The planned date by which the site is expected to be fully activated and ready to enroll the first patient. Used for milestone tracking and timeline management in CTMS.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:negotiationOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Negotiation Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Site agreements require a designated negotiation owner (contracts manager or CRA manager) accountable for the negotiation process. Normalizing the plain-text \'negotiation_owner\' to an employee FK enab' ;
    rdfs:domain ind:SiteAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:closeoutFee rdf:type rdf:Property ;
    rdfs:label 'Closeout Fee' ;
    rdfs:comment 'Fixed fee payable to the investigational site upon study close-out to cover archival, final monitoring visit support, and regulatory document finalization activities. Expressed in the currency defined by currency_code.' ;
    rdfs:domain ind:SiteAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:croEntity rdf:type rdf:Property ;
    rdfs:label 'Cro Entity' ;
    rdfs:comment 'Name of the Contract Research Organization (CRO) acting as the contracting party on behalf of the sponsor, if applicable. Captures the legal entity name when the CRO executes the agreement under delegated authority.' ;
    rdfs:domain ind:SiteAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyAddendum rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Addendum' ;
    rdfs:comment 'Indicates whether a data privacy addendum (DPA) or data processing agreement is included as part of or annexed to this site agreement, addressing GDPR, HIPAA, or other applicable data protection obligations for patient data.' ;
    rdfs:domain ind:SiteAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:indemnificationClause rdf:type rdf:Property ;
    rdfs:label 'Indemnification Clause' ;
    rdfs:comment 'Indicates whether the site agreement includes an indemnification clause protecting the investigational site and PI from third-party claims arising from the sponsor\'s negligence. Standard in CTA templates but may be absent in certain jurisdictions.' ;
    rdfs:domain ind:SiteAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceCoverageRequired rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Required' ;
    rdfs:comment 'Indicates whether the agreement mandates that the sponsor or CRO maintain clinical trial insurance coverage for the duration of the study at this site. Regulatory requirement in many jurisdictions.' ;
    rdfs:domain ind:SiteAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Reference number of the clinical trial insurance policy covering this site agreement. Populated when insurance_coverage_required is True. Used for regulatory inspection documentation.' ;
    rdfs:domain ind:SiteAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perPatientFee rdf:type rdf:Property ;
    rdfs:label 'Per Patient Fee' ;
    rdfs:comment 'Agreed fee payable to the investigational site for each evaluable patient who completes the study per protocol. Core financial term in the site budget agreement. Expressed in the currency defined by currency_code.' ;
    rdfs:domain ind:SiteAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicationRightsClause rdf:type rdf:Property ;
    rdfs:label 'Publication Rights Clause' ;
    rdfs:comment 'Indicates whether the site agreement includes a publication rights clause defining the investigator\'s right to publish study results and the sponsor\'s right to review manuscripts prior to submission. Relevant for academic site agreements.' ;
    rdfs:domain ind:SiteAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siteSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Site Signature Date' ;
    rdfs:comment 'Date on which the authorized representative of the investigational site (e.g., PI or institutional official) signed the agreement. May differ from the sponsor/CRO signature date in multi-party execution workflows.' ;
    rdfs:domain ind:SiteAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sponsorSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Sponsor Signature Date' ;
    rdfs:comment 'Date on which the authorized representative of the sponsor or CRO signed the agreement. The later of site_signature_date and sponsor_signature_date typically defines the execution_date.' ;
    rdfs:domain ind:SiteAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:startupFee rdf:type rdf:Property ;
    rdfs:label 'Startup Fee' ;
    rdfs:comment 'One-time fixed fee payable to the investigational site upon activation to cover site initiation activities such as staff training, IRB/IEC submission preparation, and regulatory document collection. Expressed in the currency defined by currency_code.' ;
    rdfs:domain ind:SiteAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityId rdf:type rdf:Property ;
    rdfs:label 'Capacity Id' ;
    rdfs:comment 'Unique surrogate identifier for the site capacity record. Primary key for the site_capacity data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualPatientPoolSize rdf:type rdf:Property ;
    rdfs:label 'Annual Patient Pool Size' ;
    rdfs:comment 'Estimated number of patients seen annually at the site who could potentially qualify for clinical trial enrollment across therapeutic areas. A key input to enrollment feasibility planning and site selection scoring.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availableExamRooms rdf:type rdf:Property ;
    rdfs:label 'Available Exam Rooms' ;
    rdfs:comment 'Number of examination rooms at the site that are available and dedicated or allocable to clinical trial activities. Directly constrains the number of concurrent subject visits that can be conducted.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityStatus rdf:type rdf:Property ;
    rdfs:label 'Capacity Status' ;
    rdfs:comment 'Current lifecycle status of this site capacity record. \'draft\' indicates an initial assessment in progress; \'active\' indicates the current approved capacity profile; \'under_review\' indicates a reassessment is in progress; \'suspended\' indicates the site is temporarily not accepting new trials; \'archived\' indicates a superseded historical record.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityType rdf:type rdf:Property ;
    rdfs:label 'Capacity Type' ;
    rdfs:comment 'Indicates whether the capacity figures were self-declared by the site (Principal Investigator or Site Coordinator), independently assessed by the CRA/CRO during a feasibility visit, or negotiated and agreed between the sponsor and site.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competingProtocolCount rdf:type rdf:Property ;
    rdfs:label 'Competing Protocol Count' ;
    rdfs:comment 'Number of active or pending clinical trial protocols currently running at the site that compete for the same patient population, staff resources, or infrastructure. A key input to site selection scoring and workload balancing.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crcCount rdf:type rdf:Property ;
    rdfs:label 'Crc Count' ;
    rdfs:comment 'Number of Clinical Research Coordinators (CRCs) currently assigned to or available at the site for trial coordination activities. Used in workload balancing and site selection scoring.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dedicatedResearchFte rdf:type rdf:Property ;
    rdfs:label 'Dedicated Research Fte' ;
    rdfs:comment 'Total full-time equivalent (FTE) headcount of staff dedicated to clinical research activities at the site, including Clinical Research Coordinators (CRCs), research nurses, and sub-investigators. Expressed as a decimal (e.g., 2.5 FTE).' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dropoutRatePct rdf:type rdf:Property ;
    rdfs:label 'Dropout Rate Pct' ;
    rdfs:comment 'Historical percentage of enrolled subjects who withdrew or were discontinued from trials at this site prior to study completion. Used in enrollment planning to account for subject attrition.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ecgCapability rdf:type rdf:Property ;
    rdfs:label 'Ecg Capability' ;
    rdfs:comment 'Indicates whether the site has on-site 12-lead ECG capability for cardiac safety assessments required by many clinical trial protocols.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:econsentCapable rdf:type rdf:Property ;
    rdfs:label 'Econsent Capable' ;
    rdfs:comment 'Indicates whether the site is equipped and approved to administer electronic Informed Consent Forms (eICF) using an eConsent platform such as Clinpal, in compliance with applicable regulatory requirements.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:edcSystemCapable rdf:type rdf:Property ;
    rdfs:label 'Edc System Capable' ;
    rdfs:comment 'Indicates whether the site has the technical infrastructure and trained staff to use an Electronic Data Capture (EDC) system such as Medidata Rave for electronic Case Report Form (eCRF) data entry.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:imagingCapability rdf:type rdf:Property ;
    rdfs:label 'Imaging Capability' ;
    rdfs:comment 'Indicates whether the site has on-site medical imaging capability (e.g., MRI, CT, PET, X-ray, ultrasound) relevant to clinical trial endpoint assessments. Sites without imaging may require referral to external imaging centers.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irbIecApprovalCapacity rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Approval Capacity' ;
    rdfs:comment 'Maximum number of concurrent protocols for which the site\'s IRB/IEC has granted or is willing to grant approval. Regulatory constraint on the site\'s operational capacity.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:irtRtsmCapable rdf:type rdf:Property ;
    rdfs:label 'Irt Rtsm Capable' ;
    rdfs:comment 'Indicates whether the site staff are trained and equipped to use an IRT/RTSM system (such as Medidata RTSM) for subject randomization and investigational product dispensing.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labProcessingCapable rdf:type rdf:Property ;
    rdfs:label 'Lab Processing Capable' ;
    rdfs:comment 'Indicates whether the site has on-site laboratory processing capability for clinical trial samples (e.g., centrifugation, aliquoting, storage). Sites without this capability must rely on central or local reference laboratories.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labSampleProcessingCapacity rdf:type rdf:Property ;
    rdfs:label 'Lab Sample Processing Capacity' ;
    rdfs:comment 'Maximum number of clinical trial samples the on-site laboratory can process per day. Null if the site does not have on-site laboratory processing capability. Used to assess feasibility for high-frequency sampling protocols.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxConcurrentProtocols rdf:type rdf:Property ;
    rdfs:label 'Max Concurrent Protocols' ;
    rdfs:comment 'Maximum number of distinct clinical trial protocols the site can run simultaneously without compromising GCP compliance or subject safety. Used for workload balancing across the site portfolio.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxConcurrentSubjects rdf:type rdf:Property ;
    rdfs:label 'Max Concurrent Subjects' ;
    rdfs:comment 'Maximum number of trial subjects the site can actively manage simultaneously across all concurrent protocols, as declared or assessed. This is the principal capacity metric used in site selection scoring and enrollment planning.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pharmacyColdChainCapable rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Cold Chain Capable' ;
    rdfs:comment 'Indicates whether the site pharmacy has validated cold chain storage capability (e.g., 2–8°C refrigeration or -20°C / -80°C freezer storage) for temperature-sensitive investigational medicinal products.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pharmacyStorageCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Storage Capacity Units' ;
    rdfs:comment 'Number of discrete storage units (e.g., refrigerator slots, freezer compartments, or shelf units) available in the site pharmacy for investigational medicinal product (IMP) storage. Constrains the number of concurrent protocols requiring pharmacy support.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:piFteAllocation rdf:type rdf:Property ;
    rdfs:label 'Pi Fte Allocation' ;
    rdfs:comment 'Proportion of the Principal Investigator\'s time (expressed as FTE) allocated to clinical research activities at this site. A PI with 0.5 FTE allocation is available 50% of their working time for trial oversight.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recruitmentRatePerMonth rdf:type rdf:Property ;
    rdfs:label 'Recruitment Rate Per Month' ;
    rdfs:comment 'Historical average number of subjects recruited per month by this site across prior clinical trials, based on CTMS enrollment data. Used as a predictive input for enrollment planning and site selection scoring.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:screenFailureRatePct rdf:type rdf:Property ;
    rdfs:label 'Screen Failure Rate Pct' ;
    rdfs:comment 'Historical percentage of screened subjects who failed to meet eligibility criteria and were not enrolled, based on prior trial data at this site. A high screen failure rate reduces effective enrollment capacity.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteSelectionScore rdf:type rdf:Property ;
    rdfs:label 'Site Selection Score' ;
    rdfs:comment 'Composite numeric score (typically 0–100) assigned to the site based on capacity, feasibility, and performance metrics for use in site selection ranking. Calculated by the CTMS or feasibility scoring model.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationPct rdf:type rdf:Property ;
    rdfs:label 'Utilization Pct' ;
    rdfs:comment 'Percentage of the site\'s maximum concurrent subject capacity currently in use, calculated as (active_subject_count / max_concurrent_subjects) * 100. Expressed as a decimal percentage (e.g., 75.50 for 75.5%). Used for workload balancing and site selection scoring.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closeoutId rdf:type rdf:Property ;
    rdfs:label 'Closeout Id' ;
    rdfs:comment 'Unique surrogate identifier for the site close-out record. Primary key for the site_closeout data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finalSitePaymentId rdf:type rdf:Property ;
    rdfs:label 'Final Site Payment Id' ;
    rdfs:comment 'Foreign key linking to finance.site_payment. Business justification: Closeout financial reconciliation: site_closeout tracks final_payment_status and final_payment_amount. Linking to the specific site_payment record enables reconciliation of closeout financials, audit ' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SitePayment .

ind:closeoutNumber rdf:type rdf:Property ;
    rdfs:label 'Closeout Number' ;
    rdfs:comment 'Externally-known business identifier for this close-out event, typically generated by the CTMS close-out workflow (e.g., CO-2024-0042). Used for cross-system referencing and regulatory correspondence.' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeoutStatus rdf:type rdf:Property ;
    rdfs:label 'Closeout Status' ;
    rdfs:comment 'Current lifecycle state of the site close-out process as tracked in the CTMS close-out workflow. Drives downstream regulatory notification and payment release actions.' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeoutType rdf:type rdf:Property ;
    rdfs:label 'Closeout Type' ;
    rdfs:comment 'Classification of the reason driving the site close-out. Distinguishes between normal study completion, early termination for safety or operational reasons, and sponsor-initiated decisions. [ENUM-REF-CANDIDATE: planned_completion|early_termination|protocol_amendment|sponsor_decision|regulatory_action|site_request — promote to reference product]' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedDate rdf:type rdf:Property ;
    rdfs:label 'Completed Date' ;
    rdfs:comment 'Date on which all close-out activities were formally completed and the site was officially closed. Marks the end of the site lifecycle for this study.' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drugAccountabilityCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Drug Accountability Completed Date' ;
    rdfs:comment 'Date on which investigational medicinal product (IMP) accountability reconciliation was formally completed and signed off at the site.' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drugAccountabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Drug Accountability Status' ;
    rdfs:comment 'Current status of investigational medicinal product (IMP) accountability reconciliation at the site. Confirms that all dispensed, returned, and destroyed drug quantities are fully accounted for per GCP requirements.' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyTerminationReason rdf:type rdf:Property ;
    rdfs:label 'Early Termination Reason' ;
    rdfs:comment 'Free-text description of the reason for early termination of the site, if applicable. Populated only when closeout_type is \'early_termination\'. Supports regulatory reporting and sponsor decision documentation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:essentialDocArchivalDate rdf:type rdf:Property ;
    rdfs:label 'Essential Doc Archival Date' ;
    rdfs:comment 'Date on which all essential documents were confirmed as archived at the investigational site, satisfying ICH E6(R2) Section 8 requirements.' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:essentialDocArchivalStatus rdf:type rdf:Property ;
    rdfs:label 'Essential Doc Archival Status' ;
    rdfs:comment 'Status of archival of all essential documents required by ICH E6(R2) Section 8 at the investigational site. Confirms that the site\'s Trial Master File (TMF) is complete and archived per regulatory requirements.' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Final Payment Amount' ;
    rdfs:comment 'Monetary value of the final payment disbursed to the investigational site at close-out, denominated in the contract currency. Represents the net amount after reconciliation of all advances and prior payments.' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Final Payment Date' ;
    rdfs:comment 'Date on which the final payment to the investigational site was processed and confirmed, closing all financial obligations under the site budget agreement.' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalPaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Final Payment Status' ;
    rdfs:comment 'Status of the final financial payment to the investigational site upon close-out, covering all outstanding per-subject fees, procedure fees, and close-out visit fees per the site budget agreement.' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impReturnDate rdf:type rdf:Property ;
    rdfs:label 'Imp Return Date' ;
    rdfs:comment 'Date on which unused investigational medicinal product (IMP) was returned to the sponsor/depot or destroyed on-site per the drug destruction protocol.' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impReturnStatus rdf:type rdf:Property ;
    rdfs:label 'Imp Return Status' ;
    rdfs:comment 'Status of the return or on-site destruction of unused investigational medicinal product (IMP) at the site. Distinct from drug accountability reconciliation — this tracks the physical disposition of remaining IMP stock.' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbIecNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Notification Status' ;
    rdfs:comment 'Status of the formal notification to the Institutional Review Board (IRB) or Independent Ethics Committee (IEC) regarding study completion or early termination at this site, as required by GCP and applicable regulations.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lslvDate rdf:type rdf:Property ;
    rdfs:label 'Lslv Date' ;
    rdfs:comment 'Date of the last protocol-required visit for the last subject enrolled at this site. LSLV is a critical clinical milestone that triggers the initiation of the close-out process and database lock activities.' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the final site payment (e.g., USD, EUR, GBP). Ensures consistent financial reporting across multi-currency global trials.' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piAcknowledgementReceived rdf:type rdf:Property ;
    rdfs:label 'Pi Acknowledgement Received' ;
    rdfs:comment 'Indicates whether the Principal Investigator (PI) has formally acknowledged receipt of the close-out letter and confirmed completion of all close-out obligations, as required by ICH E6(R2).' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:protocolDeviationsCount rdf:type rdf:Property ;
    rdfs:label 'Protocol Deviations Count' ;
    rdfs:comment 'Total number of protocol deviations recorded at this site during the study. Summarized at close-out for site performance assessment and inclusion in the Clinical Study Report (CSR).' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryAuthorityNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Notification Status' ;
    rdfs:comment 'Status of notification to applicable regulatory authorities (e.g., FDA, EMA, MHRA) regarding site close-out, as required under applicable IND/CTA regulations.' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdvCompletionPercentage rdf:type rdf:Property ;
    rdfs:label 'Sdv Completion Percentage' ;
    rdfs:comment 'Percentage of critical and non-critical data fields that have been source data verified (SDV) at the site as of the close-out visit. Reflects data quality and monitoring completeness per the monitoring plan.' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteFileTransferDate rdf:type rdf:Property ;
    rdfs:label 'Site File Transfer Date' ;
    rdfs:comment 'Date on which the site\'s investigator file and essential documents were successfully transferred to the sponsor or CRO central archive.' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteFileTransferStatus rdf:type rdf:Property ;
    rdfs:label 'Site File Transfer Status' ;
    rdfs:comment 'Status of the transfer of the site\'s investigator file and essential documents to the sponsor or CRO archive. Applicable when physical or electronic records must be transferred from the site to a central repository.' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteContactId rdf:type rdf:Property ;
    rdfs:label 'Site Contact Id' ;
    rdfs:comment 'Unique surrogate identifier for each site contact record within the Clinical Trial Management System (CTMS). Primary key for the site_contact entity.' ;
    rdfs:domain ind:SiteContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the site contact record within the CTMS staff roster. Drives access provisioning, delegation log validity, and monitoring visit eligibility.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsContactCode rdf:type rdf:Property ;
    rdfs:label 'Ctms Contact Code' ;
    rdfs:comment 'External identifier for this contact as assigned by the source Clinical Trial Management System (Oracle Siebel CTMS). Used for cross-system reconciliation and audit traceability.' ;
    rdfs:domain ind:SiteContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsUserCode rdf:type rdf:Property ;
    rdfs:label 'Ctms User Code' ;
    rdfs:comment 'Username or user identifier assigned to the site contact within the CTMS (Oracle Siebel CTMS). Supports access control, audit trail, and activity tracking for site staff within the trial management platform.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cvDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Cv Document Ref' ;
    rdfs:comment 'Reference to the site contact\'s current curriculum vitae (CV) stored in the eTMF. The CV is a mandatory essential document for PI and Sub-Investigators per ICH E6(R2) and must be on file prior to site initiation.' ;
    rdfs:domain ind:SiteContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegationEndDate rdf:type rdf:Property ;
    rdfs:label 'Delegation End Date' ;
    rdfs:comment 'Date on which the site contact\'s delegation of authority for trial tasks was revoked or expired. Null if delegation is currently active. Used for audit trail and regulatory inspection documentation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:delegationLogRef rdf:type rdf:Property ;
    rdfs:label 'Delegation Log Ref' ;
    rdfs:comment 'Reference identifier linking this site contact to the site delegation of authority log, which documents the specific trial tasks delegated to this individual by the Principal Investigator (PI). Mandatory per GCP and eTMF requirements.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegationStartDate rdf:type rdf:Property ;
    rdfs:label 'Delegation Start Date' ;
    rdfs:comment 'Date from which the site contact is authorized to perform delegated trial tasks as documented in the site delegation of authority log. Defines the effective start of the contact\'s trial responsibilities.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:edcSystemAccess rdf:type rdf:Property ;
    rdfs:label 'Edc System Access' ;
    rdfs:comment 'Indicates whether the site contact has been provisioned with access to the Electronic Data Capture (EDC) system (e.g., Medidata Rave) for electronic Case Report Form (eCRF) data entry or review.' ;
    rdfs:domain ind:SiteContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:edcUserCode rdf:type rdf:Property ;
    rdfs:label 'Edc User Code' ;
    rdfs:comment 'Username or user identifier assigned to the site contact within the EDC system (e.g., Medidata Rave). Required for audit trail attribution of eCRF data entries per 21 CFR Part 11 and ALCOA+ principles.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gcpTrainingStatus rdf:type rdf:Property ;
    rdfs:label 'Gcp Training Status' ;
    rdfs:comment 'Current status of the site contact\'s Good Clinical Practice (GCP) training certification. GCP training is a mandatory regulatory requirement for all site staff involved in clinical trial conduct per ICH E6(R2).' ;
    rdfs:domain ind:SiteContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humanSubjectsTrainingExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Human Subjects Training Expiry Date' ;
    rdfs:comment 'Expiration date of the site contact\'s human subjects research protection training certification. Drives compliance monitoring and renewal alerts.' ;
    rdfs:domain ind:SiteContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:humanSubjectsTrainingStatus rdf:type rdf:Property ;
    rdfs:label 'Human Subjects Training Status' ;
    rdfs:comment 'Status of the site contact\'s human subjects research protection training (e.g., CITI Human Subjects training). Required by OHRP and IRB regulations for all personnel involved in human subjects research.' ;
    rdfs:domain ind:SiteContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbIecApprovalRef rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Approval Ref' ;
    rdfs:comment 'Reference to the IRB/IEC approval document that covers this site contact\'s participation in the trial, particularly relevant for PI and Sub-Investigator roles. Links to the eTMF approval record.' ;
    rdfs:domain ind:SiteContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPi rdf:type rdf:Property ;
    rdfs:label 'Is Pi' ;
    rdfs:comment 'Indicates whether this site contact holds the role of Principal Investigator (PI) for the study at this site. The PI bears overall responsibility for the conduct of the clinical trial at the site per GCP guidelines.' ;
    rdfs:domain ind:SiteContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Preferred language of the site contact for study communications, expressed as an IETF BCP 47 language tag (e.g., en-US, fr-FR, de-DE). Supports localized communication in multinational trials.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'License Expiry Date' ;
    rdfs:comment 'Expiration date of the site contact\'s professional medical or pharmacy license. Triggers renewal alerts to ensure continued regulatory compliance and site qualification validity.' ;
    rdfs:domain ind:SiteContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'Professional medical or pharmacy license number of the site contact. Required for PI and Sub-Investigator qualification verification and regulatory submission documentation.' ;
    rdfs:domain ind:SiteContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseState rdf:type rdf:Property ;
    rdfs:label 'License State' ;
    rdfs:comment 'State or jurisdiction in which the site contact holds their professional medical or pharmacy license. Used for regulatory compliance verification during site qualification.' ;
    rdfs:domain ind:SiteContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'Mobile phone number of the site contact for after-hours urgent communications, including SAE reporting and emergency site escalations.' ;
    rdfs:domain ind:SiteContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleType rdf:type rdf:Property ;
    rdfs:label 'Role Type' ;
    rdfs:comment 'Functional role of the contact at the investigational site. Determines delegation authority, GCP training requirements, and access rights within the CTMS. [ENUM-REF-CANDIDATE: PI|Sub-Investigator|CRC|Pharmacist|Lab Contact|Study Coordinator|Regulatory Contact|Data Entry Operator|Site Manager|Nurse — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCraAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Site Cra Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each CRA-to-study-site assignment record in the Clinical Trial Management System (CTMS). Serves as the primary key for this entity.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SiteCraAssignment .

ind:quaternarySiteApprovedByWorkforceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Site Approved By Workforce Employee Id' ;
    rdfs:comment 'Reference to the workforce record of the manager or clinical operations lead who formally approved this CRA assignment. Supports authorization audit trail and GCP compliance documentation.' ;
    rdfs:domain ind:SiteCraAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiarySiteCroOversightManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Site Cro Oversight Manager Employee Id' ;
    rdfs:comment 'Reference to the workforce record of the CRO line manager or clinical operations manager responsible for overseeing this CRA assignment. Supports management hierarchy, escalation routing, and performance review.' ;
    rdfs:domain ind:SiteCraAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignmentReason rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason' ;
    rdfs:comment 'The business reason for creating or modifying this CRA assignment. Supports operational reporting and root cause analysis for assignment changes. [ENUM-REF-CANDIDATE: new_assignment|replacement|coverage_gap|workload_rebalance|site_activation|escalation|other — promote to reference product]' ;
    rdfs:domain ind:SiteCraAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegationLogEntryConfirmed rdf:type rdf:Property ;
    rdfs:label 'Delegation Log Entry Confirmed' ;
    rdfs:comment 'Indicates whether the CRA\'s monitoring responsibilities have been formally documented on the site\'s delegation of authority log, as required by GCP. True = confirmed on delegation log; False = pending confirmation.' ;
    rdfs:domain ind:SiteCraAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedTravelDaysPerVisit rdf:type rdf:Property ;
    rdfs:label 'Estimated Travel Days Per Visit' ;
    rdfs:comment 'The estimated number of travel days required per monitoring visit for this CRA-site assignment. Used for resource capacity planning, travel cost estimation, and CRA workload calculation.' ;
    rdfs:domain ind:SiteCraAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicTerritory rdf:type rdf:Property ;
    rdfs:label 'Geographic Territory' ;
    rdfs:comment 'The geographic territory or region to which this CRA assignment belongs (e.g., \'Northeast US\', \'Western Europe\', \'APAC\'). Used for territory-based workload planning, travel budgeting, and CRA deployment optimization.' ;
    rdfs:domain ind:SiteCraAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverDate rdf:type rdf:Property ;
    rdfs:label 'Handover Date' ;
    rdfs:comment 'The date on which monitoring responsibility was formally transferred from the predecessor CRA to the current CRA. Relevant for assignment transfers and ensures no monitoring coverage gap.' ;
    rdfs:domain ind:SiteCraAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:handoverVisitCompleted rdf:type rdf:Property ;
    rdfs:label 'Handover Visit Completed' ;
    rdfs:comment 'Indicates whether a formal handover monitoring visit was conducted between the outgoing and incoming CRA at the site. True = handover visit completed; False = not yet completed or not applicable.' ;
    rdfs:domain ind:SiteCraAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:protocolTrainingCompleted rdf:type rdf:Property ;
    rdfs:label 'Protocol Training Completed' ;
    rdfs:comment 'Indicates whether the assigned CRA has completed the required study protocol-specific training prior to initiating monitoring activities at the site. True = training completed; False = pending. Regulatory requirement per GCP.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:protocolTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Protocol Training Date' ;
    rdfs:comment 'The date on which the CRA completed the study protocol-specific training required for this assignment. Supports audit trail and regulatory inspection readiness.' ;
    rdfs:domain ind:SiteCraAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sdvRatePct rdf:type rdf:Property ;
    rdfs:label 'Sdv Rate Pct' ;
    rdfs:comment 'The agreed or actual percentage of critical data fields subject to Source Data Verification (SDV) for this CRA-site assignment, as defined in the monitoring plan. Reflects risk-based monitoring (RBM) strategy. Valid range: 0.00 to 100.00.' ;
    rdfs:domain ind:SiteCraAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:territoryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code representing the primary country of the CRA\'s assigned territory (e.g., USA, GBR, DEU). Supports geographic reporting and regulatory jurisdiction tracking.' ;
    rdfs:domain ind:SiteCraAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelRequired rdf:type rdf:Property ;
    rdfs:label 'Travel Required' ;
    rdfs:comment 'Indicates whether overnight or significant travel is required for the CRA to conduct on-site monitoring visits at this assigned site. True = travel required; False = local or remote only. Used for travel budget planning and CRA logistics.' ;
    rdfs:domain ind:SiteCraAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:visitFrequencyPlanned rdf:type rdf:Property ;
    rdfs:label 'Visit Frequency Planned' ;
    rdfs:comment 'The planned frequency of on-site or remote monitoring visits for this CRA-site assignment as defined in the monitoring plan. Drives visit scheduling and resource forecasting in the CTMS.' ;
    rdfs:domain ind:SiteCraAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiationVisitId rdf:type rdf:Property ;
    rdfs:label 'Initiation Visit Id' ;
    rdfs:comment 'Unique surrogate identifier for the Site Initiation Visit (SIV) record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:InitiationVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualVisitDate rdf:type rdf:Property ;
    rdfs:label 'Actual Visit Date' ;
    rdfs:comment 'The actual calendar date on which the Site Initiation Visit was conducted. May differ from the scheduled date due to rescheduling. This is the principal real-world event date for the SIV.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:attendeeNames rdf:type rdf:Property ;
    rdfs:label 'Attendee Names' ;
    rdfs:comment 'Comma-separated list of names of all personnel who attended the Site Initiation Visit, including site staff (PI, CRC, pharmacist, etc.) and sponsor/CRO representatives (CRA, project manager). Documented in the SIV report for TMF filing.' ;
    rdfs:domain ind:InitiationVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcTrainingCompleted rdf:type rdf:Property ;
    rdfs:label 'Edc Training Completed' ;
    rdfs:comment 'Indicates whether Electronic Data Capture (EDC) system training (e.g., Medidata Rave) was completed during the Site Initiation Visit. Site staff must be trained on eCRF completion prior to first patient enrollment.' ;
    rdfs:domain ind:InitiationVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstPatientEnrollmentAuthorized rdf:type rdf:Property ;
    rdfs:label 'First Patient Enrollment Authorized' ;
    rdfs:comment 'Indicates whether the Site Initiation Visit has resulted in formal authorization for the site to enroll the first patient (First Patient First Visit - FPFV). This flag drives site activation status in the CTMS.' ;
    rdfs:domain ind:InitiationVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstPatientEnrollmentAuthorizedDate rdf:type rdf:Property ;
    rdfs:label 'First Patient Enrollment Authorized Date' ;
    rdfs:comment 'The date on which the site was formally authorized to enroll the first patient following successful completion of the Site Initiation Visit. Key milestone for site activation and study timeline tracking.' ;
    rdfs:domain ind:InitiationVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:icfProcessTrainingCompleted rdf:type rdf:Property ;
    rdfs:label 'Icf Process Training Completed' ;
    rdfs:comment 'Indicates whether training on the Informed Consent Form (ICF) process and procedures was completed during the SIV. Ensures site staff understand the requirements for obtaining valid informed consent from study subjects.' ;
    rdfs:domain ind:InitiationVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipHandlingTrainingCompleted rdf:type rdf:Property ;
    rdfs:label 'Ip Handling Training Completed' ;
    rdfs:comment 'Indicates whether training on Investigational Product (IP) receipt, storage, dispensing, accountability, and return/destruction procedures was completed during the SIV.' ;
    rdfs:domain ind:InitiationVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryAuthorityApprovalObtained rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Approval Obtained' ;
    rdfs:comment 'Indicates whether the required national or regional regulatory authority approval (e.g., IND from FDA, CTA from EMA/MHRA) was confirmed as obtained prior to the Site Initiation Visit. A prerequisite for site activation.' ;
    rdfs:domain ind:InitiationVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rtsmTrainingCompleted rdf:type rdf:Property ;
    rdfs:label 'Rtsm Training Completed' ;
    rdfs:comment 'Indicates whether Randomization and Trial Supply Management (RTSM) / Interactive Response Technology (IRT) system training was completed during the SIV. Required for sites to perform patient randomization and manage investigational product supply.' ;
    rdfs:domain ind:InitiationVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyReportingTrainingCompleted rdf:type rdf:Property ;
    rdfs:label 'Safety Reporting Training Completed' ;
    rdfs:comment 'Indicates whether training on safety and Adverse Event (AE) / Serious Adverse Event (SAE) reporting procedures was completed during the SIV. Mandatory per GCP to ensure timely and accurate safety reporting.' ;
    rdfs:domain ind:InitiationVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledVisitDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Visit Date' ;
    rdfs:comment 'The planned calendar date on which the Site Initiation Visit is scheduled to occur, as recorded in the CTMS. Used for resource planning and site activation timeline tracking.' ;
    rdfs:domain ind:InitiationVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sivNumber rdf:type rdf:Property ;
    rdfs:label 'Siv Number' ;
    rdfs:comment 'Externally-known business identifier for the SIV, typically generated by the CTMS (Oracle Siebel CTMS) and referenced in the Trial Master File (TMF). Used for cross-system traceability and regulatory audit purposes.' ;
    rdfs:domain ind:InitiationVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sivSignoffBy rdf:type rdf:Property ;
    rdfs:label 'Siv Signoff By' ;
    rdfs:comment 'Name or identifier of the sponsor or CRO representative who provided formal sign-off on the Site Initiation Visit, confirming all objectives were met and the site is activated.' ;
    rdfs:domain ind:InitiationVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sivSignoffDate rdf:type rdf:Property ;
    rdfs:label 'Siv Signoff Date' ;
    rdfs:comment 'The date on which the Site Initiation Visit received formal sign-off from the sponsor or CRO representative, confirming site readiness for first patient enrollment.' ;
    rdfs:domain ind:InitiationVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sivSignoffStatus rdf:type rdf:Property ;
    rdfs:label 'Siv Signoff Status' ;
    rdfs:comment 'Indicates the formal sign-off status of the Site Initiation Visit by the sponsor or CRO. Sign-off confirms that all SIV objectives were met and the site is authorized to enroll the first patient. Distinct from visit_status.' ;
    rdfs:domain ind:InitiationVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitEndTime rdf:type rdf:Property ;
    rdfs:label 'Visit End Time' ;
    rdfs:comment 'The precise date and time at which the Site Initiation Visit concluded. Used together with visit_start_time to calculate visit duration and assess adequacy of training time.' ;
    rdfs:domain ind:InitiationVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:visitNotes rdf:type rdf:Property ;
    rdfs:label 'Visit Notes' ;
    rdfs:comment 'Free-text field capturing additional observations, comments, or contextual information recorded by the CRA during or after the Site Initiation Visit. Supplements the structured visit report.' ;
    rdfs:domain ind:InitiationVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitReportCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Visit Report Completion Date' ;
    rdfs:comment 'The date on which the CRA completed and finalized the Site Initiation Visit report. Regulatory guidelines typically require visit reports to be completed within a defined number of days post-visit (e.g., 10 business days). Filed in the eTMF.' ;
    rdfs:domain ind:InitiationVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:visitReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Visit Report Due Date' ;
    rdfs:comment 'The contractually or procedurally defined deadline by which the SIV report must be completed and filed in the eTMF. Used to monitor CRA compliance with SOP timelines.' ;
    rdfs:domain ind:InitiationVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:visitStartTime rdf:type rdf:Property ;
    rdfs:label 'Visit Start Time' ;
    rdfs:comment 'The precise date and time at which the Site Initiation Visit commenced on the day of the visit. Used for duration calculation and audit trail purposes per ALCOA+ principles.' ;
    rdfs:domain ind:InitiationVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:selectionId rdf:type rdf:Property ;
    rdfs:label 'Selection Id' ;
    rdfs:comment 'Unique surrogate identifier for the site selection decision record. Primary key for the site_selection data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Selection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:committeeId rdf:type rdf:Property ;
    rdfs:label 'Committee Id' ;
    rdfs:comment 'Reference to the selection committee or governance body that reviewed and approved or rejected this site selection decision.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SiteSelectionCommittee .

ind:activationTargetDate rdf:type rdf:Property ;
    rdfs:label 'Activation Target Date' ;
    rdfs:comment 'Planned date by which the selected site should complete all activation requirements and be ready to enroll the first subject. Used for study timeline management and milestone tracking.' ;
    rdfs:domain ind:Selection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conditionalRequirements rdf:type rdf:Property ;
    rdfs:label 'Conditional Requirements' ;
    rdfs:comment 'Description of conditions that must be met before a conditionally selected site can proceed to activation (e.g., additional staff training, equipment procurement, IRB approval). Populated when selection_status is \'conditionally_selected\'.' ;
    rdfs:domain ind:Selection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsSiteRecordCode rdf:type rdf:Property ;
    rdfs:label 'Ctms Site Record Code' ;
    rdfs:comment 'The source system record identifier from Oracle Siebel CTMS for this site selection record, enabling traceability and reconciliation between the Silver Layer and the operational CTMS.' ;
    rdfs:domain ind:Selection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstPatientInTargetDate rdf:type rdf:Property ;
    rdfs:label 'First Patient In Target Date' ;
    rdfs:comment 'Target date for enrolling the first subject (First Patient In / FPI) at this site. A key study milestone used for enrollment planning and sponsor KPI reporting.' ;
    rdfs:domain ind:Selection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:piQualificationVerified rdf:type rdf:Property ;
    rdfs:label 'Pi Qualification Verified' ;
    rdfs:comment 'Indicates whether the Principal Investigator\'s (PI) qualifications, CV, and GCP training have been verified and confirmed as adequate for this study at the time of selection, per ICH E6(R2) requirements.' ;
    rdfs:domain ind:Selection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorAuditFinding rdf:type rdf:Property ;
    rdfs:label 'Prior Audit Finding' ;
    rdfs:comment 'Indicates whether the site has any prior significant audit findings or regulatory inspection observations that were considered as part of the selection decision. Supports risk-based site selection.' ;
    rdfs:domain ind:Selection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason a site was not selected. Populated only when selection_status is \'rejected\' or \'withdrawn\'. [ENUM-REF-CANDIDATE: insufficient_patient_population|inadequate_facilities|pi_not_qualified|competing_trials|irb_issues|capacity_constraints|sponsor_decision|other — promote to reference product]' ;
    rdfs:domain ind:Selection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonDetail rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Detail' ;
    rdfs:comment 'Free-text elaboration of the rejection reason, providing additional context beyond the standardized rejection_reason_code. Populated only when the site is rejected or withdrawn.' ;
    rdfs:domain ind:Selection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectionDate rdf:type rdf:Property ;
    rdfs:label 'Selection Date' ;
    rdfs:comment 'The calendar date on which the formal site selection decision was made and approved by the selection committee. This is the principal business event date for this transaction.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:selectionNumber rdf:type rdf:Property ;
    rdfs:label 'Selection Number' ;
    rdfs:comment 'Externally-known business identifier for this site selection decision record, used in CTMS, eTMF, and sponsor communications (e.g., SS-PROT001-00042). Serves as the human-readable reference number.' ;
    rdfs:domain ind:Selection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectionStatus rdf:type rdf:Property ;
    rdfs:label 'Selection Status' ;
    rdfs:comment 'Current lifecycle status of the site selection decision. Drives workflow transitions from feasibility through activation. [ENUM-REF-CANDIDATE: selected|rejected|pending_review|conditionally_selected|withdrawn|on_hold — promote to reference product]' ;
    rdfs:domain ind:Selection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectionType rdf:type rdf:Property ;
    rdfs:label 'Selection Type' ;
    rdfs:comment 'Categorizes the nature of the site selection: whether the site is a newly added site, a replacement for a terminated site, a backup site held in reserve, or an expansion site added to increase enrollment capacity.' ;
    rdfs:domain ind:Selection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorSiteNumber rdf:type rdf:Property ;
    rdfs:label 'Sponsor Site Number' ;
    rdfs:comment 'Sponsor-assigned alphanumeric identifier for the site within the context of this specific study, used in EDC, RTSM, and regulatory submissions. Distinct from the internal site_id.' ;
    rdfs:domain ind:Selection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitConducted rdf:type rdf:Property ;
    rdfs:label 'Visit Conducted' ;
    rdfs:comment 'Indicates whether a formal site selection visit (also known as a pre-study site visit or PSSV) was conducted at this site prior to the selection decision, as recommended by ICH E6(R2).' ;
    rdfs:domain ind:Selection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:centralLabFacilityId rdf:type rdf:Property ;
    rdfs:label 'Central Lab Facility Id' ;
    rdfs:comment 'Foreign key linking to laboratory.lab_facility. Business justification: Each study_site is assigned a central laboratory for specimen analysis. This drives specimen shipment routing, lab kit ordering, result reporting, and eTMF documentation. Role-prefixed \'central_\' beca' ;
    rdfs:domain ind:StudySite ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabFacility .

ind:budgetAgreedAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Agreed Amount' ;
    rdfs:comment 'Total agreed budget amount for this site\'s participation in the study, as specified in the Clinical Trial Agreement. Covers per-patient fees, overhead, and procedure costs. Managed in SAP S/4HANA project accounting.' ;
    rdfs:domain ind:StudySite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacitySubjects rdf:type rdf:Property ;
    rdfs:label 'Capacity Subjects' ;
    rdfs:comment 'Maximum number of subjects the site has declared capacity to enroll and manage concurrently for this study, based on staff resources, facilities, and patient population. Used in feasibility assessment and enrollment planning.' ;
    rdfs:domain ind:StudySite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Contract Execution Date' ;
    rdfs:comment 'Date on which the Clinical Trial Agreement (CTA) or Clinical Site Agreement between the sponsor/CRO and the site institution was fully executed. A mandatory activation milestone before site initiation.' ;
    rdfs:domain ind:StudySite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:edcProvisioningDate rdf:type rdf:Property ;
    rdfs:label 'Edc Provisioning Date' ;
    rdfs:comment 'Date on which the site was provisioned and granted access to the Electronic Data Capture (EDC) system (e.g., Medidata Rave) for this study. Required before site staff can enter subject data into eCRFs.' ;
    rdfs:domain ind:StudySite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrolledCount rdf:type rdf:Property ;
    rdfs:label 'Enrolled Count' ;
    rdfs:comment 'Actual number of subjects who have been enrolled (consented and randomized or assigned to treatment) at this site to date. Updated from EDC/RTSM data feeds. Used for real-time enrollment performance monitoring.' ;
    rdfs:domain ind:StudySite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enrollmentTarget rdf:type rdf:Property ;
    rdfs:label 'Enrollment Target' ;
    rdfs:comment 'Planned number of subjects to be enrolled at this site for this study, as agreed between the sponsor/CRO and the site during feasibility and site selection. Used for site performance tracking and enrollment forecasting.' ;
    rdfs:domain ind:StudySite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lplvDate rdf:type rdf:Property ;
    rdfs:label 'Lplv Date' ;
    rdfs:comment 'Date of the last subject\'s last protocol-specified visit at this site. Marks the end of active subject participation and triggers site close-out activities. Key milestone for study timeline management.' ;
    rdfs:domain ind:StudySite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monitoringVisitCount rdf:type rdf:Property ;
    rdfs:label 'Monitoring Visit Count' ;
    rdfs:comment 'Total number of monitoring visits (on-site and remote) conducted at this site for this study to date. Used for site oversight reporting and resource planning.' ;
    rdfs:domain ind:StudySite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Date' ;
    rdfs:comment 'Date on which the national competent authority (e.g., FDA, EMA, MHRA, PMDA) granted approval or authorization for this site to conduct the study. Required in certain jurisdictions before site activation.' ;
    rdfs:domain ind:StudySite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:selectionRationale rdf:type rdf:Property ;
    rdfs:label 'Selection Rationale' ;
    rdfs:comment 'Narrative justification for selecting this site for the study, including patient population access, PI expertise, infrastructure capability, and prior performance. Captured during the site selection committee review.' ;
    rdfs:domain ind:StudySite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCloseoutDate rdf:type rdf:Property ;
    rdfs:label 'Site Closeout Date' ;
    rdfs:comment 'Date on which the formal site close-out visit was completed and the site was officially closed for this study. Triggers archival of site documents in eTMF and final reconciliation activities.' ;
    rdfs:domain ind:StudySite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteStatus rdf:type rdf:Property ;
    rdfs:label 'Site Status' ;
    rdfs:comment 'Current lifecycle status of the site within this study. Drives operational workflows in CTMS: candidate (under feasibility review), selected (approved for activation), initiated (Site Initiation Visit completed), enrolling (actively recruiting subjects), enrollment_complete (target met or enrollment closed), closed (site formally closed out).' ;
    rdfs:domain ind:StudySite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sivDate rdf:type rdf:Property ;
    rdfs:label 'Siv Date' ;
    rdfs:comment 'Date on which the Site Initiation Visit (SIV) was conducted by the CRA. The SIV confirms site readiness, trains site staff on the protocol and EDC system, and is a key activation milestone before first subject enrollment.' ;
    rdfs:domain ind:StudySite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryAccountEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Account Employee Id' ;
    rdfs:comment 'Reference to the CRO employee (typically a Global Account Director or VP of Business Development) who owns the primary sponsor relationship and is accountable for executing this account plan.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:priorPlanAccountPlanId rdf:type rdf:Property ;
    rdfs:label 'Prior Plan Account Plan Id' ;
    rdfs:comment 'Reference to the preceding account plan for this sponsor, enabling year-over-year continuity tracking and performance comparison against prior period objectives.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountPlan .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'CRO-assigned tier classification for the sponsor account reflecting strategic importance, revenue contribution, and relationship depth. Strategic accounts receive the most intensive account management resources.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeStudyCountTarget rdf:type rdf:Property ;
    rdfs:label 'Active Study Count Target' ;
    rdfs:comment 'Target number of concurrently active studies to be running for this sponsor by end of the account plan period. Key performance indicator for account growth and portfolio depth.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:biostatisticsRevenueTargetUsd rdf:type rdf:Property ;
    rdfs:label 'Biostatistics Revenue Target Usd' ;
    rdfs:comment 'Revenue target in USD for biostatistics and statistical programming service line (SAP development, analysis, CSR support) within this account plan period.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clinicalOpsRevenueTargetUsd rdf:type rdf:Property ;
    rdfs:label 'Clinical Ops Revenue Target Usd' ;
    rdfs:comment 'Revenue target in USD for clinical operations service line (site management, monitoring, CRA services) within this account plan period.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveThreats rdf:type rdf:Property ;
    rdfs:label 'Competitive Threats' ;
    rdfs:comment 'Narrative description of identified competitive threats from other CROs or service providers targeting this sponsor account. Captures intelligence on competitor positioning, pricing pressure, and relationship risks to inform defensive account strategy.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsAccountPlanRef rdf:type rdf:Property ;
    rdfs:label 'Ctms Account Plan Ref' ;
    rdfs:comment 'Native record identifier for this account plan in Oracle Siebel CTMS, the system of record for sponsor account management. Enables traceability back to the source operational system.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataManagementRevenueTargetUsd rdf:type rdf:Property ;
    rdfs:label 'Data Management Revenue Target Usd' ;
    rdfs:comment 'Revenue target in USD for data management service line (EDC, eCRF, CDISC/SDTM/ADaM transformation, DBL) within this account plan period.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governanceMeetingFrequency rdf:type rdf:Property ;
    rdfs:label 'Governance Meeting Frequency' ;
    rdfs:comment 'Planned frequency of formal governance touchpoints (Joint Steering Committee, Executive Business Reviews, Operational Reviews) with the sponsor during this account plan period.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:innovationInitiatives rdf:type rdf:Property ;
    rdfs:label 'Innovation Initiatives' ;
    rdfs:comment 'Description of joint innovation or technology initiatives planned with the sponsor during the account plan period, such as decentralized trial pilots, AI-driven patient recruitment, or integrated CTMS/EDC connectivity.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keySponsorStakeholders rdf:type rdf:Property ;
    rdfs:label 'Key Sponsor Stakeholders' ;
    rdfs:comment 'Narrative or structured summary of key sponsor-side stakeholders to engage during the plan period, including their roles (e.g., VP Clinical Operations, Head of Outsourcing, CMO) and engagement priorities. Supports relationship mapping and contact strategy.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextGovernanceMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Next Governance Meeting Date' ;
    rdfs:comment 'Scheduled date of the next formal governance touchpoint with the sponsor (e.g., Joint Steering Committee or Executive Business Review). Drives proactive account management scheduling.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pipelineOpportunityCount rdf:type rdf:Property ;
    rdfs:label 'Pipeline Opportunity Count' ;
    rdfs:comment 'Number of identified pipeline study opportunities from the sponsor\'s drug development portfolio that the CRO is targeting for award during this account plan period. Drives business development prioritization.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pipelineOpportunityValueUsd rdf:type rdf:Property ;
    rdfs:label 'Pipeline Opportunity Value Usd' ;
    rdfs:comment 'Estimated total contract value in USD of all identified pipeline study opportunities targeted for award during this account plan period. Used for revenue forecasting and resource planning.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan End Date' ;
    rdfs:comment 'Date on which the account plan period formally closes. Nullable for open-ended strategic plans. Triggers plan review and renewal workflow when reached.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Start Date' ;
    rdfs:comment 'Date on which the account plan period formally begins and strategic objectives become active. Aligns with the sponsor engagement cycle or CRO fiscal year.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planYear rdf:type rdf:Property ;
    rdfs:label 'Plan Year' ;
    rdfs:comment 'Primary fiscal or calendar year this account plan covers. For multi-year plans, this represents the starting year. Used for annual performance tracking and year-over-year comparison.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredProviderStatus rdf:type rdf:Property ;
    rdfs:label 'Preferred Provider Status' ;
    rdfs:comment 'Current status of the CRO\'s preferred or approved provider designation with this sponsor. Preferred status typically grants first-look rights on new study opportunities and streamlined contracting.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAffairsRevenueTargetUsd rdf:type rdf:Property ;
    rdfs:label 'Regulatory Affairs Revenue Target Usd' ;
    rdfs:comment 'Revenue target in USD for regulatory affairs service line (IND/NDA/BLA/MAA submissions, eCTD preparation, agency interactions) within this account plan period.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipDevelopmentGoals rdf:type rdf:Property ;
    rdfs:label 'Relationship Development Goals' ;
    rdfs:comment 'Specific goals for deepening or broadening the CRO-sponsor relationship during the plan period, such as expanding into new divisions, achieving executive-level engagement, or establishing a joint innovation council.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipHealthScore rdf:type rdf:Property ;
    rdfs:label 'Relationship Health Score' ;
    rdfs:comment 'Numeric score (1-10) representing the assessed health and strength of the CRO-sponsor relationship at the time of plan creation or last review. Informed by sponsor satisfaction surveys, escalation history, and account manager assessment.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueTargetCurrency rdf:type rdf:Property ;
    rdfs:label 'Revenue Target Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the revenue target amount (e.g., USD, EUR, GBP). Supports multi-currency sponsor relationships.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueTargetUsd rdf:type rdf:Property ;
    rdfs:label 'Revenue Target Usd' ;
    rdfs:comment 'Total CRO revenue target in US dollars for this account plan period across all service lines. Represents the gross contracted and pipeline revenue goal set during account planning.' ;
    rdfs:domain ind:AccountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sponsorSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Sponsor Satisfaction Score' ;
    rdfs:comment 'Most recent sponsor satisfaction survey score (e.g., on a 1.00–5.00 or 0.00–10.00 scale) captured from formal sponsor feedback mechanisms. Baseline metric for relationship development goals in the plan.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strategicObjectives rdf:type rdf:Property ;
    rdfs:label 'Strategic Objectives' ;
    rdfs:comment 'Narrative description of the primary strategic objectives for this account plan period, such as expanding into new therapeutic areas, securing preferred provider status, or deepening data analytics partnerships. Free-text field capturing the overarching relationship strategy.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidRequestId rdf:type rdf:Property ;
    rdfs:label 'Bid Request Id' ;
    rdfs:comment 'Unique surrogate identifier for the bid request record in the CRO\'s business development pipeline. Primary key for this entity.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BidRequest .

ind:parentBidRequestId rdf:type rdf:Property ;
    rdfs:label 'Parent Bid Request Id' ;
    rdfs:comment 'Reference to the original bid request record if this is a resubmission or amendment. Enables lineage tracking across bid iterations for the same study opportunity.' ;
    rdfs:domain ind:BidRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BidRequest .

ind:primaryBidEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Bid Employee Id' ;
    rdfs:comment 'Reference to the CRO\'s internal business development or proposal lead employee responsible for managing this bid request. Drives accountability and commission tracking.' ;
    rdfs:domain ind:BidRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:regulatoryProcedureId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Procedure Id' ;
    rdfs:comment 'Foreign key linking to regulatory.procedure. Business justification: Bid requests for regulatory affairs work are scoped against a specific regulatory procedure (e.g., FDA NDA standard review, EMA centralized procedure). Procedure-specific clock days, fees, and require' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Procedure .

ind:awardDate rdf:type rdf:Property ;
    rdfs:label 'Award Date' ;
    rdfs:comment 'Date on which the sponsor formally awarded the study contract to the CRO. Populated only when bid_status = \'awarded\'. Triggers transition to study start-up activities.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bidDefenseDate rdf:type rdf:Property ;
    rdfs:label 'Bid Defense Date' ;
    rdfs:comment 'Scheduled date for the bid defense meeting or presentation where the CRO presents its proposal to the sponsor\'s evaluation team. A key milestone in the competitive selection process.' ;
    rdfs:domain ind:BidRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bidStatus rdf:type rdf:Property ;
    rdfs:label 'Bid Status' ;
    rdfs:comment 'Current lifecycle state of the bid request within the CRO\'s business development workflow. Drives pipeline reporting and revenue forecasting.' ;
    rdfs:domain ind:BidRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competingCroCount rdf:type rdf:Property ;
    rdfs:label 'Competing Cro Count' ;
    rdfs:comment 'Number of competing Contract Research Organizations (CROs) known to be invited to bid on this RFP. Used for competitive analysis and bid strategy calibration.' ;
    rdfs:domain ind:BidRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitiveContext rdf:type rdf:Property ;
    rdfs:label 'Competitive Context' ;
    rdfs:comment 'Classification of the competitive environment for this bid: sole-source (only CRO invited), competitive (multiple CROs bidding), preferred provider (CRO has preferred status), or incumbent (CRO currently running the study). Influences bid strategy.' ;
    rdfs:domain ind:BidRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryScope rdf:type rdf:Property ;
    rdfs:label 'Country Scope' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes representing the geographic scope of the study as specified in the RFP (e.g., USA, GBR, DEU, JPN). Drives regulatory strategy and site feasibility.' ;
    rdfs:domain ind:BidRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Budget Amount' ;
    rdfs:comment 'CRO\'s internal gross estimated budget for the full scope of services requested in the RFP, expressed in the budget_currency. Used for revenue forecasting and bid pricing strategy.' ;
    rdfs:domain ind:BidRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Months' ;
    rdfs:comment 'Sponsor-estimated total duration of the study in months from first site initiation to database lock (DBL). Used for resource planning and revenue recognition scheduling.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedSiteCount rdf:type rdf:Property ;
    rdfs:label 'Estimated Site Count' ;
    rdfs:comment 'Sponsor-provided estimate of the total number of investigative sites to be activated globally. Drives site management, monitoring, and travel budget estimates.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedSubjectCount rdf:type rdf:Property ;
    rdfs:label 'Estimated Subject Count' ;
    rdfs:comment 'Sponsor-provided estimate of the total number of study subjects (patients) to be enrolled across all sites and countries. Key driver of budget, resource, and timeline estimates.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lossReason rdf:type rdf:Property ;
    rdfs:label 'Loss Reason' ;
    rdfs:comment 'Reason code explaining why the CRO lost this bid to a competitor. Populated only when bid_status = \'lost\'. Used for win/loss analysis and continuous improvement of bid strategy. [ENUM-REF-CANDIDATE: price|capability|relationship|timeline|scope|incumbent|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BidRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noBidDate rdf:type rdf:Property ;
    rdfs:label 'No Bid Date' ;
    rdfs:comment 'Date on which the CRO formally decided not to submit a proposal for this bid request. Populated only when bid_status = \'no_bid\'. Used for pipeline and capacity analysis.' ;
    rdfs:domain ind:BidRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noBidReason rdf:type rdf:Property ;
    rdfs:label 'No Bid Reason' ;
    rdfs:comment 'Reason code explaining why the CRO elected not to submit a proposal for this bid request. Populated only when bid_status = \'no_bid\'. Used for strategic portfolio and capacity analysis. [ENUM-REF-CANDIDATE: capacity|capability_gap|risk|pricing|strategic_fit|sponsor_relationship|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BidRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalDueDate rdf:type rdf:Property ;
    rdfs:label 'Proposal Due Date' ;
    rdfs:comment 'Sponsor-mandated deadline by which the CRO must submit its formal proposal and budget in response to the RFP.' ;
    rdfs:domain ind:BidRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regionScope rdf:type rdf:Property ;
    rdfs:label 'Region Scope' ;
    rdfs:comment 'High-level geographic region classification for the study scope. Used for regional capacity planning and business development reporting.' ;
    rdfs:domain ind:BidRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedServices rdf:type rdf:Property ;
    rdfs:label 'Requested Services' ;
    rdfs:comment 'Free-text or structured description of the specific CRO service modules requested by the sponsor (e.g., clinical monitoring, data management, biostatistics, regulatory affairs, pharmacovigilance). Informs scope-of-work development.' ;
    rdfs:domain ind:BidRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Rfp Document Ref' ;
    rdfs:comment 'Reference identifier or URL to the sponsor\'s RFP document stored in the eTMF or document management system (Veeva Vault). Enables traceability between the bid record and the source RFP document.' ;
    rdfs:domain ind:BidRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpNumber rdf:type rdf:Property ;
    rdfs:label 'Rfp Number' ;
    rdfs:comment 'Externally-assigned reference number provided by the sponsor on the Request for Proposal (RFP) document. Used to cross-reference the CRO\'s bid with the sponsor\'s procurement records.' ;
    rdfs:domain ind:BidRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceModel rdf:type rdf:Property ;
    rdfs:label 'Service Model' ;
    rdfs:comment 'Type of CRO engagement requested by the sponsor: full-service (CRO manages all functions), Functional Service Provider (FSP) model (CRO provides specific functions), hybrid, or module-specific. Drives scope and pricing.' ;
    rdfs:domain ind:BidRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorBudgetCeiling rdf:type rdf:Property ;
    rdfs:label 'Sponsor Budget Ceiling' ;
    rdfs:comment 'Maximum budget amount disclosed by the sponsor in the RFP, if provided. Used to calibrate the CRO\'s proposal and assess bid competitiveness.' ;
    rdfs:domain ind:BidRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studyCode rdf:type rdf:Property ;
    rdfs:label 'Study Code' ;
    rdfs:comment 'Sponsor-assigned alphanumeric code or protocol number for the study referenced in the bid request. Used to link the bid to the sponsor\'s internal study portfolio.' ;
    rdfs:domain ind:BidRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyTitle rdf:type rdf:Property ;
    rdfs:label 'Study Title' ;
    rdfs:comment 'Full descriptive title of the clinical study as provided by the sponsor in the RFP. Describes the investigational product, indication, and study design at a high level.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyType rdf:type rdf:Property ;
    rdfs:label 'Study Type' ;
    rdfs:comment 'Classification of the study design as interventional (subjects receive an investigational treatment) or observational (no intervention assigned). Drives regulatory pathway and operational model.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedBidAmount rdf:type rdf:Property ;
    rdfs:label 'Submitted Bid Amount' ;
    rdfs:comment 'Final total bid amount submitted by the CRO to the sponsor in the formal proposal, expressed in budget_currency. Populated after proposal submission. Key metric for win/loss analysis.' ;
    rdfs:domain ind:BidRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:winProbabilityPct rdf:type rdf:Property ;
    rdfs:label 'Win Probability Pct' ;
    rdfs:comment 'Business development team\'s estimated probability (0.00–100.00%) of winning this bid, based on competitive intelligence, sponsor relationship, and capability fit. Used for weighted pipeline revenue forecasting.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governingDocumentSopId rdf:type rdf:Property ;
    rdfs:label 'Governing Document Sop Id' ;
    rdfs:comment 'Foreign key linking to document.document_sop. Business justification: Sponsor delivery preferences include sponsor_sop_alignment_required and GCP guideline version flags. Linking to the governing SOP formalizes which SOP version applies to sponsor studies. Named process' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocumentSop .

ind:supersededByDeliveryPreferenceId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Delivery Preference Id' ;
    rdfs:comment 'Reference to the newer delivery preference record that replaces this one when preference_status is \'superseded\'. Enables version chain navigation for audit and compliance purposes.' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryPreference .

ind:adamVersion rdf:type rdf:Property ;
    rdfs:label 'Adam Version' ;
    rdfs:comment 'Required version of the CDISC Analysis Data Model (ADaM) standard for analysis-ready datasets (e.g., \'ADaM 1.1\', \'ADaM 1.3\'). Governs structure of analysis datasets supporting statistical analysis plans.' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailRequirement rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Requirement' ;
    rdfs:comment 'Regulatory standard governing electronic audit trail requirements for all sponsor study data and systems. 21 CFR Part 11 applies to FDA submissions; EU Annex 11 applies to EMA submissions.' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biostatisticsSoftware rdf:type rdf:Property ;
    rdfs:label 'Biostatistics Software' ;
    rdfs:comment 'Sponsor\'s required statistical analysis software for biostatistical analysis, CDISC data transformation, and Clinical Study Report (CSR) generation. SAS is the regulatory gold standard; R is increasingly accepted.' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdiscDefineXmlVersion rdf:type rdf:Property ;
    rdfs:label 'Cdisc Define Xml Version' ;
    rdfs:comment 'Required version of the CDISC Define-XML metadata standard for submission data package documentation (e.g., \'Define-XML 2.0\', \'Define-XML 2.1\'). Mandatory for FDA and EMA electronic submissions.' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsPreference rdf:type rdf:Property ;
    rdfs:label 'Ctms Preference' ;
    rdfs:comment 'Sponsor\'s preference for the Clinical Trial Management System (CTMS) to be used for site management, monitoring visit tracking, and study milestone management.' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataTransferFormat rdf:type rdf:Property ;
    rdfs:label 'Data Transfer Format' ;
    rdfs:comment 'Sponsor\'s required format for clinical data transfers between CRO and sponsor systems. SAS XPT is standard for regulatory submissions; ODM-XML is CDISC standard for EDC data exchange.' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataTransferFrequency rdf:type rdf:Property ;
    rdfs:label 'Data Transfer Frequency' ;
    rdfs:comment 'Required cadence for clinical data transfers from CRO to sponsor. Governs data pipeline scheduling and interim analysis readiness. [ENUM-REF-CANDIDATE: weekly|biweekly|monthly|milestone_based|on_demand|continuous — promote to reference product]' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsmbReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Dsmb Reporting Required' ;
    rdfs:comment 'Indicates whether the sponsor requires formal Data Safety Monitoring Board (DSMB) / Data Monitoring Committee (DMC) reporting packages to be prepared by the CRO as part of safety oversight deliverables.' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:econsentRequired rdf:type rdf:Property ;
    rdfs:label 'Econsent Required' ;
    rdfs:comment 'Indicates whether the sponsor mandates the use of electronic Informed Consent Form (ICF) / eConsent technology (e.g., Clinpal) for patient enrollment across their studies. True = eConsent required; False = paper ICF acceptable.' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ectdSubmissionRequired rdf:type rdf:Property ;
    rdfs:label 'Ectd Submission Required' ;
    rdfs:comment 'Indicates whether the sponsor requires CRO deliverables to be formatted and packaged for Electronic Common Technical Document (eCTD) regulatory submission. Governs document formatting and submission readiness standards.' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:edcSystemPreference rdf:type rdf:Property ;
    rdfs:label 'Edc System Preference' ;
    rdfs:comment 'Sponsor\'s mandated or preferred Electronic Data Capture (EDC) platform for clinical data collection across their studies. Governs which EDC system the CRO must deploy for eCRF build and data management.' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etmfSystemPreference rdf:type rdf:Property ;
    rdfs:label 'Etmf System Preference' ;
    rdfs:comment 'Sponsor\'s mandated or preferred Electronic Trial Master File (eTMF) platform for trial documentation management. Governs where TMF documents are stored, indexed, and made inspection-ready.' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interimAnalysisRequired rdf:type rdf:Property ;
    rdfs:label 'Interim Analysis Required' ;
    rdfs:comment 'Indicates whether the sponsor\'s Statistical Analysis Plan (SAP) requires one or more pre-specified interim analyses. Governs biostatistics deliverable scope and unblinding procedures.' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labDataStandard rdf:type rdf:Property ;
    rdfs:label 'Lab Data Standard' ;
    rdfs:comment 'Sponsor\'s required standard for central laboratory data integration and transfer into the EDC/data management system. Governs lab data mapping and CDISC LB domain compliance.' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringStrategy rdf:type rdf:Property ;
    rdfs:label 'Monitoring Strategy' ;
    rdfs:comment 'Sponsor\'s preferred clinical monitoring approach: on_site (traditional 100% SDV), remote (centralized monitoring only), hybrid (combination), or risk_based (RBM — Risk-Based Monitoring per ICH E6(R2) Addendum). Governs CRA deployment and SDV scope.' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:patientDataResidencyRegion rdf:type rdf:Property ;
    rdfs:label 'Patient Data Residency Region' ;
    rdfs:comment 'Geographic region or jurisdiction where patient clinical data must be stored and processed per sponsor data residency requirements (e.g., \'EU\', \'USA\', \'Japan\'). Governs cloud infrastructure and data transfer agreements.' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceCode rdf:type rdf:Property ;
    rdfs:label 'Preference Code' ;
    rdfs:comment 'Externally-known unique business identifier for this sponsor delivery preference configuration, used in cross-system references and sponsor communications (e.g., SP-PREF-PFIZ0001).' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceName rdf:type rdf:Property ;
    rdfs:label 'Preference Name' ;
    rdfs:comment 'Human-readable label for this delivery preference configuration, typically reflecting the sponsor name and applicable scope (e.g., \'Pfizer Global Oncology Delivery Standards 2024\').' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Preference Status' ;
    rdfs:comment 'Current lifecycle state of the delivery preference record. Draft indicates under review; active indicates currently governing CRO delivery; superseded indicates replaced by a newer version; retired indicates no longer applicable.' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceType rdf:type rdf:Property ;
    rdfs:label 'Preference Type' ;
    rdfs:comment 'Classification indicating the scope at which this preference configuration applies: global (all sponsor studies), therapeutic_area (specific TA), study_specific (single study), or program_level (drug development program).' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRegulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Authority' ;
    rdfs:comment 'The primary regulatory authority for which CRO deliverables must be prepared and compliant. Governs applicable data standards, submission formats, and reporting timelines (e.g., FDA for US IND/NDA, EMA for MAA). [ENUM-REF-CANDIDATE: FDA|EMA|PMDA|MHRA|TGA|Health_Canada|multi_regional — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCadence rdf:type rdf:Property ;
    rdfs:label 'Reporting Cadence' ;
    rdfs:comment 'Required frequency for operational and safety reporting deliverables from CRO to sponsor (e.g., enrollment dashboards, safety listings, site performance reports). Governs report generation schedules.' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtsmSystemPreference rdf:type rdf:Property ;
    rdfs:label 'Rtsm System Preference' ;
    rdfs:comment 'Sponsor\'s preferred Randomization and Trial Supply Management (RTSM) / Interactive Response Technology (IRT) system for patient randomization and investigational product supply management.' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetySystemPreference rdf:type rdf:Property ;
    rdfs:label 'Safety System Preference' ;
    rdfs:comment 'Sponsor\'s mandated or preferred pharmacovigilance and adverse event reporting system. Governs the platform used for SAE/SUSAR case processing, regulatory submissions, and signal detection.' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmVersion rdf:type rdf:Property ;
    rdfs:label 'Sdtm Version' ;
    rdfs:comment 'Required version of the CDISC Study Data Tabulation Model (SDTM) standard for submission-ready data packages (e.g., \'SDTM 3.3\', \'SDTM 3.4\'). Governs data structure for FDA/EMA regulatory submissions.' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdvRequirementPercent rdf:type rdf:Property ;
    rdfs:label 'Sdv Requirement Percent' ;
    rdfs:comment 'Minimum percentage of critical data fields requiring Source Data Verification (SDV) per the sponsor\'s monitoring SOP. Ranges from 0 (fully centralized/remote) to 100 (full SDV). Governs CRA monitoring workload and site visit frequency.' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sponsorSopAlignmentRequired rdf:type rdf:Property ;
    rdfs:label 'Sponsor Sop Alignment Required' ;
    rdfs:comment 'Indicates whether the CRO must operate under sponsor Standard Operating Procedures (SOPs) rather than CRO SOPs. True = sponsor SOPs govern; False = CRO SOPs acceptable with sponsor approval.' ;
    rdfs:domain ind:DeliveryPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountPlanPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Account Plan Period End' ;
    rdfs:comment 'End date of the strategic account planning period, marking the horizon for annual or multi-year objectives and revenue targets defined in the account plan.' ;
    rdfs:domain ind:SponsorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountPlanPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Account Plan Period Start' ;
    rdfs:comment 'Start date of the strategic account planning period (typically annual or multi-year) for which objectives, revenue targets, and relationship goals are defined.' ;
    rdfs:domain ind:SponsorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Account Plan Status' ;
    rdfs:comment 'Current workflow status of the strategic account plan associated with this engagement. Controls plan visibility, approval routing, and activation for account management execution.' ;
    rdfs:domain ind:SponsorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeStudyCount rdf:type rdf:Property ;
    rdfs:label 'Active Study Count' ;
    rdfs:comment 'Number of clinical studies currently active under this engagement. Used for capacity planning, account management reporting, and portfolio performance dashboards.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualRevenueTarget rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Target' ;
    rdfs:comment 'CRO-defined annual revenue target for this sponsor engagement, used in strategic account planning and business development performance tracking.' ;
    rdfs:domain ind:SponsorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidentialityAgreementRef rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Agreement Ref' ;
    rdfs:comment 'Reference number or identifier of the Non-Disclosure Agreement (NDA) or Confidentiality Disclosure Agreement (CDA) executed between the CRO and sponsor for this engagement.' ;
    rdfs:domain ind:SponsorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementCode rdf:type rdf:Property ;
    rdfs:label 'Engagement Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the engagement, used in contracts, invoices, and cross-system references (e.g., \'ENG-2024-PFZ-001\').' ;
    rdfs:domain ind:SponsorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementName rdf:type rdf:Property ;
    rdfs:label 'Engagement Name' ;
    rdfs:comment 'Human-readable business name for the CRO-sponsor engagement relationship, typically referencing the sponsor name and scope (e.g., \'Pfizer Oncology Full-Service CRO 2024\').' ;
    rdfs:domain ind:SponsorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementType rdf:type rdf:Property ;
    rdfs:label 'Engagement Type' ;
    rdfs:comment 'Classification of the commercial engagement model between the CRO and sponsor. Full-service CRO covers end-to-end trial management; Functional Service Provider (FSP) covers specific functions; co-development involves shared risk/reward; preferred provider denotes a strategic preferred-vendor arrangement. [ENUM-REF-CANDIDATE: full_service_cro|functional_service_provider|co_development|preferred_provider|standalone — promote to reference product]' ;
    rdfs:domain ind:SponsorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationCountYtd rdf:type rdf:Property ;
    rdfs:label 'Escalation Count Ytd' ;
    rdfs:comment 'Number of formal escalations raised by the sponsor or CRO within the current calendar year for this engagement. Used as a relationship health indicator and input to CAPA tracking.' ;
    rdfs:domain ind:SponsorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:governanceCadence rdf:type rdf:Property ;
    rdfs:label 'Governance Cadence' ;
    rdfs:comment 'Planned frequency of formal governance touchpoints (joint steering committee, operational review meetings) between the CRO and sponsor for this engagement.' ;
    rdfs:domain ind:SponsorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastGovernanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Governance Date' ;
    rdfs:comment 'Date of the most recently completed formal governance touchpoint between the CRO and sponsor, used to track cadence compliance and relationship engagement.' ;
    rdfs:domain ind:SponsorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextGovernanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Governance Date' ;
    rdfs:comment 'Scheduled date of the next formal governance touchpoint (e.g., joint steering committee or operational review) between the CRO and sponsor for this engagement.' ;
    rdfs:domain ind:SponsorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pipelineOpportunityValue rdf:type rdf:Property ;
    rdfs:label 'Pipeline Opportunity Value' ;
    rdfs:comment 'Estimated monetary value of identified pipeline opportunities (new studies, expanded scope) within this sponsor engagement, used in business development forecasting.' ;
    rdfs:domain ind:SponsorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredProviderFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Provider Flag' ;
    rdfs:comment 'Indicates whether this engagement operates under a formal preferred provider or strategic alliance agreement, granting the CRO preferred access to the sponsor\'s study pipeline.' ;
    rdfs:domain ind:SponsorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryGeography rdf:type rdf:Property ;
    rdfs:label 'Primary Geography' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the primary geographic market or regulatory jurisdiction for this engagement (e.g., USA, GBR, DEU).' ;
    rdfs:domain ind:SponsorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRegions rdf:type rdf:Property ;
    rdfs:label 'Regulatory Regions' ;
    rdfs:comment 'Comma-delimited list of regulatory regions covered by this engagement (e.g., US, EU, Japan, Australia), determining applicable regulatory submission requirements and governing body oversight.' ;
    rdfs:domain ind:SponsorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueTargetBiostatistics rdf:type rdf:Property ;
    rdfs:label 'Revenue Target Biostatistics' ;
    rdfs:comment 'Annual revenue target attributed to the Biostatistics and Statistical Programming service line (SAP, ADaM, CSR) within this engagement.' ;
    rdfs:domain ind:SponsorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueTargetClinicalOps rdf:type rdf:Property ;
    rdfs:label 'Revenue Target Clinical Ops' ;
    rdfs:comment 'Annual revenue target attributed to the Clinical Operations service line within this engagement, used for service-line-level business development tracking and P&L reporting.' ;
    rdfs:domain ind:SponsorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueTargetDataManagement rdf:type rdf:Property ;
    rdfs:label 'Revenue Target Data Management' ;
    rdfs:comment 'Annual revenue target attributed to the Data Management service line (EDC, eCRF, CDISC transformation) within this engagement.' ;
    rdfs:domain ind:SponsorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueTargetRegulatory rdf:type rdf:Property ;
    rdfs:label 'Revenue Target Regulatory' ;
    rdfs:comment 'Annual revenue target attributed to the Regulatory Affairs service line (IND, NDA, BLA, MAA submissions) within this engagement.' ;
    rdfs:domain ind:SponsorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLinesInScope rdf:type rdf:Property ;
    rdfs:label 'Service Lines In Scope' ;
    rdfs:comment 'Comma-delimited list of CRO service lines included in this engagement (e.g., Clinical Operations, Biostatistics, Data Management, Regulatory Affairs, Safety). Defines the functional scope of the CRO-sponsor relationship.' ;
    rdfs:domain ind:SponsorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorEngagementStatus rdf:type rdf:Property ;
    rdfs:label 'Sponsor Engagement Status' ;
    rdfs:comment 'Current lifecycle state of the CRO-sponsor commercial engagement. Drives pipeline reporting, account management workflows, and governance cadence. [ENUM-REF-CANDIDATE: prospect|active|on_hold|closed_won|closed_lost|terminated — promote to reference product]' ;
    rdfs:domain ind:SponsorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicAccountTier rdf:type rdf:Property ;
    rdfs:label 'Strategic Account Tier' ;
    rdfs:comment 'CRO-assigned strategic segmentation tier for the sponsor account, reflecting revenue potential, relationship depth, and investment priority. Tier 1 represents the highest-value strategic accounts receiving maximum CRO resource allocation.' ;
    rdfs:domain ind:SponsorEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationId rdf:type rdf:Property ;
    rdfs:label 'Escalation Id' ;
    rdfs:comment 'Unique system-generated identifier for the sponsor escalation record. Primary key for the escalation data product within the sponsor domain.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:croOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Cro Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Escalation resolution management requires a proper FK to the CRO employee who owns the escalation for CAPA initiation, regulatory reportability decisions, and governance review accountability. \'cro_ow' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:dispositionId rdf:type rdf:Property ;
    rdfs:label 'Disposition Id' ;
    rdfs:comment 'Foreign key linking to subject.disposition. Business justification: Subject dispositions such as death or unexpected withdrawal trigger sponsor escalations requiring immediate notification. Linking escalation to the specific disposition record supports safety reportin' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Disposition .

ind:parentEscalationId rdf:type rdf:Property ;
    rdfs:label 'Parent Escalation Id' ;
    rdfs:comment 'Self-referencing identifier linking this escalation to a parent escalation record, used when an escalation is a sub-issue or recurrence of a prior escalation. Supports hierarchical escalation tracking.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Escalation .

ind:acknowledgedDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledged Date' ;
    rdfs:comment 'Date on which the receiving party (sponsor or CRO) formally acknowledged receipt of the escalation. Used for SLA compliance measurement and audit trail.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closedBy rdf:type rdf:Property ;
    rdfs:label 'Closed By' ;
    rdfs:comment 'Name or user identifier of the individual who formally closed the escalation record. Required for audit trail and accountability per ALCOA+ and 21 CFR Part 11.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsEscalationRef rdf:type rdf:Property ;
    rdfs:label 'Ctms Escalation Ref' ;
    rdfs:comment 'Source system reference identifier from Oracle Siebel CTMS for this escalation record. Enables traceability back to the operational system of record for data lineage and reconciliation.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationSource rdf:type rdf:Property ;
    rdfs:label 'Escalation Source' ;
    rdfs:comment 'Identifies the originating party or function that raised the escalation. Distinguishes sponsor-initiated from CRO-initiated or site-initiated escalations for accountability tracking. [ENUM-REF-CANDIDATE: sponsor|cro|site|dsmb|regulator|internal_audit|data_review — promote to reference product]' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationType rdf:type rdf:Property ;
    rdfs:label 'Escalation Type' ;
    rdfs:comment 'Categorical classification of the nature of the escalation. Drives routing, ownership assignment, and resolution workflows. [ENUM-REF-CANDIDATE: quality_issue|timeline_delay|budget_overrun|safety_concern|resource_issue|regulatory_risk|relationship_issue — promote to reference product]' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactUsd rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Usd' ;
    rdfs:comment 'Estimated or actual financial impact of the escalation in US dollars. Relevant for budget overrun escalations, contract amendment triggers, and sponsor financial reporting. Classified confidential as commercially sensitive.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Governance Review Date' ;
    rdfs:comment 'Date on which the escalation was reviewed at a formal governance forum. Populated when governance_review_required is true and the review has occurred.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impactedFunctionalArea rdf:type rdf:Property ;
    rdfs:label 'Impacted Functional Area' ;
    rdfs:comment 'The primary business functional area impacted by this escalation. Used for cross-functional reporting, resource allocation, and trend analysis by department. [ENUM-REF-CANDIDATE: data_management|clinical_operations|regulatory_affairs|safety|biostatistics|supply_chain|finance|site_management|patient_recruitment|quality — promote to reference product]' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRegulatoryReportable rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Reportable' ;
    rdfs:comment 'Indicates whether this escalation requires formal notification to a regulatory authority (FDA, EMA, MHRA, PMDA, etc.) or ethics committee (IRB/IEC). Drives regulatory submission workflows.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:raisedByContactEmail rdf:type rdf:Property ;
    rdfs:label 'Raised By Contact Email' ;
    rdfs:comment 'Email address of the individual who raised the escalation. Used for notification routing and audit trail. Classified as confidential PII per GDPR and HIPAA.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raisedByContactName rdf:type rdf:Property ;
    rdfs:label 'Raised By Contact Name' ;
    rdfs:comment 'Full name of the sponsor contact or CRO staff member who formally raised the escalation. Provides accountability and audit trail per ALCOA+ principles.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raisedByOrgRole rdf:type rdf:Property ;
    rdfs:label 'Raised By Org Role' ;
    rdfs:comment 'Functional role of the individual who raised the escalation within their organization. Supports governance reporting and escalation pattern analysis by role. [ENUM-REF-CANDIDATE: sponsor_medical_monitor|sponsor_project_manager|sponsor_regulatory_lead|cro_project_manager|cro_clinical_lead|principal_investigator|cra|other — promote to reference product]' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionType rdf:type rdf:Property ;
    rdfs:label 'Resolution Type' ;
    rdfs:comment 'Categorical classification of the resolution approach applied to close the escalation. Supports trend analysis and CAPA linkage. [ENUM-REF-CANDIDATE: corrective_action|process_change|resource_reallocation|contract_amendment|protocol_amendment|no_action_required|escalated_to_governance — promote to reference product]' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionId rdf:type rdf:Property ;
    rdfs:label 'Interaction Id' ;
    rdfs:comment 'Unique system-generated identifier for each sponsor-CRO interaction or touchpoint record.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minutesTmfDocumentId rdf:type rdf:Property ;
    rdfs:label 'Minutes Tmf Document Id' ;
    rdfs:comment 'Foreign key linking to document.tmf_document. Business justification: Governance meeting interactions (JSC, PMT) produce minutes that are TMF-filed essential documents per ICH E6. minutes_reference is a denormalized text reference to the TMF document. Named process: TMF' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TmfDocument .

ind:agendaSummary rdf:type rdf:Property ;
    rdfs:label 'Agenda Summary' ;
    rdfs:comment 'Structured summary of agenda items discussed during the interaction. Captures the key topics covered to support meeting minutes and action item traceability.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cadenceCompliant rdf:type rdf:Property ;
    rdfs:label 'Cadence Compliant' ;
    rdfs:comment 'Indicates whether this interaction occurred within the required cadence window as defined by the governance plan or contract. True = compliant; False = cadence breach.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:croParticipantCount rdf:type rdf:Property ;
    rdfs:label 'Cro Participant Count' ;
    rdfs:comment 'Number of CRO-side individuals who attended this interaction. Used for resource allocation analysis and engagement intensity reporting.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:croParticipantNames rdf:type rdf:Property ;
    rdfs:label 'Cro Participant Names' ;
    rdfs:comment 'Comma-separated list of CRO personnel who participated in this interaction. Stored as a denormalized text field; detailed participant records are managed in the interaction_participant association product.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsInteractionCode rdf:type rdf:Property ;
    rdfs:label 'Ctms Interaction Code' ;
    rdfs:comment 'Source system identifier for this interaction record as assigned by Oracle Siebel CTMS. Enables bidirectional traceability between the lakehouse silver layer and the operational CTMS.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionsSummary rdf:type rdf:Property ;
    rdfs:label 'Decisions Summary' ;
    rdfs:comment 'Narrative summary of key decisions made during the interaction. Provides an auditable record of outcomes agreed upon by sponsor and CRO representatives.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Actual elapsed duration of the interaction in minutes as recorded in the meeting system. Stored as a business field from the source system (Oracle Siebel CTMS) rather than derived at query time.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'Precise date and time when the interaction concluded, including timezone offset. Used together with start_timestamp to compute actual meeting duration.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interactionDate rdf:type rdf:Property ;
    rdfs:label 'Interaction Date' ;
    rdfs:comment 'Calendar date on which the interaction took place or is scheduled to take place. Principal real-world event date for this transaction.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interactionStatus rdf:type rdf:Property ;
    rdfs:label 'Interaction Status' ;
    rdfs:comment 'Current lifecycle state of the interaction record: scheduled (confirmed on calendar), completed (held and minutes finalized), cancelled, rescheduled, or pending_minutes (held but minutes not yet approved).' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'Classification of the interaction by its business purpose. Governance meetings include Joint Steering Committee (JSC), Joint Operations Committee (JOC), Executive Business Review (EBR), and Quarterly Business Review (QBR). [ENUM-REF-CANDIDATE: governance_meeting|business_review|bid_defense|regulatory_strategy_call|escalation_call|proposal_presentation|informal_touchpoint — promote to reference product]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingCadence rdf:type rdf:Property ;
    rdfs:label 'Meeting Cadence' ;
    rdfs:comment 'Scheduled recurrence frequency for this type of interaction as defined in the governance framework or contract. Used to assess cadence compliance against contractual obligations. [ENUM-REF-CANDIDATE: ad_hoc|weekly|bi_weekly|monthly|quarterly|semi_annual|annual — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minutesApproved rdf:type rdf:Property ;
    rdfs:label 'Minutes Approved' ;
    rdfs:comment 'Indicates whether the meeting minutes for this interaction have been formally reviewed and approved by both sponsor and CRO representatives. True = approved; False = pending or not applicable.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Next Interaction Date' ;
    rdfs:comment 'Agreed or planned date for the next scheduled interaction of the same type with this sponsor. Supports meeting cadence planning and account management follow-up.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sponsorParticipantCount rdf:type rdf:Property ;
    rdfs:label 'Sponsor Participant Count' ;
    rdfs:comment 'Number of sponsor-side individuals who attended this interaction. Used for engagement intensity analysis and governance tier compliance.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sponsorParticipantNames rdf:type rdf:Property ;
    rdfs:label 'Sponsor Participant Names' ;
    rdfs:comment 'Comma-separated list of sponsor-side personnel who participated in this interaction. Stored as a denormalized text field for meeting minutes and engagement history reporting.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'Precise date and time when the interaction commenced, including timezone offset. Used for duration calculation and meeting cadence compliance tracking.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Brief title or subject line summarizing the purpose of the interaction, analogous to a meeting subject line in calendar systems.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalActionItemCount rdf:type rdf:Property ;
    rdfs:label 'Total Action Item Count' ;
    rdfs:comment 'Total number of action items raised during this interaction, including both open and closed items. Used to assess meeting productivity and governance rigor.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:croExecutiveOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Cro Executive Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Preferred provider agreement governance requires a proper FK to the CRO executive accountable for the master agreement for contract renewal decisions, executive relationship management, and governance' ;
    rdfs:domain ind:MasterAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Descriptive title of the master agreement (e.g., \'Global MSA — Sponsor XYZ 2024\'), used for identification in the Clinical Trial Management System (CTMS) and contract repositories.' ;
    rdfs:domain ind:MasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Flag' ;
    rdfs:comment 'Indicates whether the sponsor retains the right to audit the CRO\'s operations, records, and facilities under this master agreement, as required by GCP and regulatory guidelines.' ;
    rdfs:domain ind:MasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:etmfPlanReference rdf:type rdf:Property ;
    rdfs:label 'Etmf Plan Reference' ;
    rdfs:comment 'Reference identifier for the eTMF plan or agreement that governs document management responsibilities under studies executed within this master agreement framework. Stored in Veeva Vault eTMF.' ;
    rdfs:domain ind:MasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forceMajeureClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Clause Flag' ;
    rdfs:comment 'Indicates whether the master agreement includes a force majeure clause that suspends obligations in the event of extraordinary circumstances beyond the parties\' control.' ;
    rdfs:domain ind:MasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:indemnificationCapUsd rdf:type rdf:Property ;
    rdfs:label 'Indemnification Cap Usd' ;
    rdfs:comment 'Maximum aggregate liability cap in US dollars for indemnification obligations under this master agreement, as negotiated between the sponsor and CRO.' ;
    rdfs:domain ind:MasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initialTermMonths rdf:type rdf:Property ;
    rdfs:label 'Initial Term Months' ;
    rdfs:comment 'Duration in months of the initial binding term of the master agreement from the effective date.' ;
    rdfs:domain ind:MasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoicingFrequency rdf:type rdf:Property ;
    rdfs:label 'Invoicing Frequency' ;
    rdfs:comment 'Agreed frequency at which the CRO issues invoices to the sponsor under this master agreement framework.' ;
    rdfs:domain ind:MasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipOwnershipTerms rdf:type rdf:Property ;
    rdfs:label 'Ip Ownership Terms' ;
    rdfs:comment 'Defines the intellectual property ownership arrangement for data, methodologies, and deliverables generated under studies executed within this master agreement framework.' ;
    rdfs:domain ind:MasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent formal amendment to this master agreement. Used to track currency of agreement terms and trigger re-review workflows.' ;
    rdfs:domain ind:MasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumVolumeCommitmentUsd rdf:type rdf:Property ;
    rdfs:label 'Minimum Volume Commitment Usd' ;
    rdfs:comment 'Minimum annual or total contracted spend commitment in US dollars that the sponsor agrees to award to the CRO under this master agreement. Triggers volume-based pricing discounts.' ;
    rdfs:domain ind:MasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredPricingDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Preferred Pricing Discount Pct' ;
    rdfs:comment 'Percentage discount applied to standard CRO service rates under the preferred pricing terms of this master agreement. Expressed as a percentage (e.g., 12.50 = 12.5%).' ;
    rdfs:domain ind:MasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Quality Agreement Reference' ;
    rdfs:comment 'Reference number or identifier of the associated Quality Agreement (QA) document that defines GCP responsibilities and quality obligations between the sponsor and CRO under this master agreement. Stored in Veeva Vault or MasterControl.' ;
    rdfs:domain ind:MasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Months' ;
    rdfs:comment 'Duration in months of each automatic or negotiated renewal period for the master agreement.' ;
    rdfs:domain ind:MasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Service Scope Description' ;
    rdfs:comment 'Narrative description of the CRO service categories covered under this master agreement (e.g., full-service CRO, FSP data management, biostatistics, regulatory affairs, pharmacovigilance).' ;
    rdfs:domain ind:MasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorExecutiveOwner rdf:type rdf:Property ;
    rdfs:label 'Sponsor Executive Owner' ;
    rdfs:comment 'Name or title of the senior sponsor-side executive accountable for this master agreement relationship (e.g., VP Clinical Operations, Chief Medical Officer).' ;
    rdfs:domain ind:MasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicPartnershipLevel rdf:type rdf:Property ;
    rdfs:label 'Strategic Partnership Level' ;
    rdfs:comment 'Classification of the commercial and strategic relationship tier between the CRO and the sponsor. Determines access to preferred pricing, dedicated resources, and governance escalation paths.' ;
    rdfs:domain ind:MasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationForConvenienceNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination For Convenience Notice Days' ;
    rdfs:comment 'Number of calendar days written notice required by either party to terminate the master agreement for convenience (without cause).' ;
    rdfs:domain ind:MasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeCommitmentTier rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Tier' ;
    rdfs:comment 'Contracted volume commitment tier that determines pricing discounts and service level entitlements. Higher tiers reflect greater committed study volume or spend.' ;
    rdfs:domain ind:MasterAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Org Hierarchy Id' ;
    rdfs:comment 'Unique surrogate identifier for each parent-child corporate hierarchy relationship record within the sponsor organization structure.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childOrgOrganizationId rdf:type rdf:Property ;
    rdfs:label 'Child Org Organization Id' ;
    rdfs:comment 'Identifier of the child sponsor organization in this hierarchy relationship. References the subordinate entity (e.g., subsidiary, affiliate, regional division, or joint-venture partner).' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organization .

ind:primaryOrganizationId rdf:type rdf:Property ;
    rdfs:label 'Primary Organization Id' ;
    rdfs:comment 'Identifier of the parent sponsor organization in this hierarchy relationship. References the superior entity in the corporate structure (e.g., ultimate parent, holding company, or intermediate parent).' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organization .

ind:tertiaryWorkdayOrgOrganizationId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Workday Org Organization Id' ;
    rdfs:comment 'Organization identifier in Workday HCM corresponding to the child entity. Enables workforce planning, headcount roll-up, and talent management data to be aligned with the sponsor corporate hierarchy.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organization .

ind:consolidationScope rdf:type rdf:Property ;
    rdfs:label 'Consolidation Scope' ;
    rdfs:comment 'Indicates how the child organization\'s financials are consolidated into the parent\'s financial statements per IFRS 10 / US GAAP ASC 810. Full = 100% consolidation; Proportional = pro-rata by ownership; Equity method = single-line investment; Excluded = not consolidated (e.g., held-for-sale).' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractingEntityFlag rdf:type rdf:Property ;
    rdfs:label 'Contracting Entity Flag' ;
    rdfs:comment 'Indicates whether the child organization is authorized to independently execute clinical trial contracts and CRO agreements on behalf of the sponsor corporate family. True = can contract independently; False = contracts flow through parent entity. Critical for multi-national sponsor structures.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ctmsOrgCode rdf:type rdf:Property ;
    rdfs:label 'Ctms Org Code' ;
    rdfs:comment 'Organization identifier assigned to the child entity within Oracle Siebel CTMS. Used for cross-referencing sponsor hierarchy records with study portfolio, site management, and monitoring visit data in the CTMS.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Agreement Flag' ;
    rdfs:comment 'Indicates whether a formal data sharing agreement exists between the parent and child organization governing the exchange of clinical trial data, safety data, and regulatory submissions. Relevant for GDPR, HIPAA, and ICH E6(R2) data governance compliance.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprDataControllerRole rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Controller Role' ;
    rdfs:comment 'Defines the GDPR data controller/processor role of the child organization relative to the parent for clinical trial subject data. Controller = determines purposes and means; Joint Controller = shared determination; Processor = processes on behalf of controller. Drives data processing agreement requirements.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyVersion rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Version' ;
    rdfs:comment 'Monotonically incrementing version number for this hierarchy relationship record, supporting optimistic concurrency control and change history tracking. Incremented each time the relationship attributes are updated.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indHolderFlag rdf:type rdf:Property ;
    rdfs:label 'Ind Holder Flag' ;
    rdfs:comment 'Indicates whether the child organization holds or co-holds an Investigational New Drug (IND) application or equivalent regulatory authorization (e.g., CTA in EU) in its own name. Relevant for regulatory accountability and submission ownership tracking.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isControllingEntity rdf:type rdf:Property ;
    rdfs:label 'Is Controlling Entity' ;
    rdfs:comment 'Indicates whether the parent organization exercises control over the child organization as defined by IFRS 10 (power over investee, exposure to variable returns, ability to use power to affect returns). True = controlling; False = non-controlling interest.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryPath rdf:type rdf:Property ;
    rdfs:label 'Is Primary Path' ;
    rdfs:comment 'Indicates whether this relationship represents the primary (canonical) reporting path for the child organization when multiple parent relationships exist (e.g., matrix structures or dual-reporting affiliates). True = primary path used for standard roll-up; False = secondary or alternate path.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'Percentage of equity ownership held by the parent organization in the child organization, expressed as a decimal value between 0.00 and 100.00. Critical for determining consolidation thresholds under IFRS 10 and for sponsor financial roll-up reporting. Classified confidential as it reflects proprietary corporate financial structure.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipelineScope rdf:type rdf:Property ;
    rdfs:label 'Pipeline Scope' ;
    rdfs:comment 'Defines the breadth of the sponsor\'s drug development pipeline that the child organization is responsible for managing or contracting. Supports portfolio analytics and CRO engagement planning across the sponsor corporate family.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'Primary regulatory authority governing the child organization\'s clinical trial activities (e.g., FDA, EMA, PMDA, TGA, MHRA, Health Canada). Determines applicable regulatory submission requirements and GCP compliance frameworks for studies contracted through this entity.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipBasis rdf:type rdf:Property ;
    rdfs:label 'Relationship Basis' ;
    rdfs:comment 'The legal or operational basis underpinning the parent-child relationship. Equity = share ownership; Contractual = agreement-based control without equity; Regulatory = regulatory-mandated grouping; Operational = functional reporting without legal ownership; Statutory = legally mandated structure.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipCode rdf:type rdf:Property ;
    rdfs:label 'Relationship Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this hierarchy relationship, used for cross-system referencing in Oracle Siebel CTMS, SAP S/4HANA, and regulatory submissions. Follows the sponsor organization\'s internal coding convention.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current lifecycle state of the parent-child organizational relationship. Drives whether the relationship is included in active roll-up reporting and sponsor portfolio consolidation.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticAreaAlignment rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Area Alignment' ;
    rdfs:comment 'Primary therapeutic area(s) for which the child organization is responsible within the sponsor corporate family (e.g., Oncology, Cardiovascular, Neuroscience, Immunology). Supports portfolio roll-up reporting and pipeline analysis by therapeutic area across the sponsor hierarchy.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaAccountCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Account Code' ;
    rdfs:comment 'Unique identifier for the child organization\'s account record in Veeva Vault, used for eTMF document ownership, regulatory submission tracking, and quality management linkage. Supports traceability between the corporate hierarchy and document management.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:votingRightsPercentage rdf:type rdf:Property ;
    rdfs:label 'Voting Rights Percentage' ;
    rdfs:comment 'Percentage of voting rights held by the parent organization in the child organization. May differ from ownership percentage in cases of dual-class share structures or contractual voting arrangements. Relevant for regulatory filings and control determination under IFRS 10.' ;
    rdfs:domain ind:OrgHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentOrgOrganizationId rdf:type rdf:Property ;
    rdfs:label 'Parent Org Organization Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent sponsor organization record for organizations that are subsidiaries or divisions of a larger corporate entity. Enables corporate hierarchy traversal for portfolio-level reporting.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organization .

ind:primaryUltimateParentOrgOrganizationId rdf:type rdf:Property ;
    rdfs:label 'Primary Ultimate Parent Org Organization Id' ;
    rdfs:comment 'Identifier of the top-level ultimate parent organization in the corporate hierarchy. Enables consolidated portfolio analytics and enterprise-level sponsor relationship management without recursive hierarchy traversal.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organization .

ind:annualRdBudgetUsdRange rdf:type rdf:Property ;
    rdfs:label 'Annual Rd Budget Usd Range' ;
    rdfs:comment 'Approximate annual R&D investment band for the sponsor organization in USD. Used for sponsor capability assessment, portfolio sizing, and strategic account planning. Stored as a range to protect commercially sensitive data. [ENUM-REF-CANDIDATE: under_10m|10m_50m|50m_250m|250m_1b|1b_5b|over_5b — promote to reference product]' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractFrameworkType rdf:type rdf:Property ;
    rdfs:label 'Contract Framework Type' ;
    rdfs:comment 'Type of overarching contractual framework governing the CRO-sponsor relationship. Determines billing models, governance structures, and scope-of-work templates used in SAP S/4HANA project accounting.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corporateTier rdf:type rdf:Property ;
    rdfs:label 'Corporate Tier' ;
    rdfs:comment 'Business size classification of the sponsor organization used for portfolio segmentation, resource allocation, and strategic account management. Distinguishes Big Pharma from mid-size and emerging biotech sponsors.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:croRelationshipType rdf:type rdf:Property ;
    rdfs:label 'Cro Relationship Type' ;
    rdfs:comment 'Classification of the engagement model between the CRO and this sponsor organization. Drives contract template selection, governance model, and service delivery framework. Full-service sponsors delegate all trial operations; functional service providers retain specific functions.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsAccountCode rdf:type rdf:Property ;
    rdfs:label 'Ctms Account Code' ;
    rdfs:comment 'Oracle Siebel CTMS account record identifier for the sponsor organization. Serves as the cross-reference key for sponsor account data originating from the CTMS system of record.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emaOrgNumber rdf:type rdf:Property ;
    rdfs:label 'Ema Org Number' ;
    rdfs:comment 'EMA-assigned organization identifier used in Marketing Authorization Applications (MAA) and EU Clinical Trials Regulation (EU CTR 536/2014) submissions. Links the sponsor to EudraCT and CTIS regulatory records.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCountRange rdf:type rdf:Property ;
    rdfs:label 'Employee Count Range' ;
    rdfs:comment 'Approximate employee headcount band for the sponsor organization. Used for corporate tier validation, resource planning, and sponsor capability assessment. Stored as a range to avoid precision sensitivity.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaSponsorNumber rdf:type rdf:Property ;
    rdfs:label 'Fda Sponsor Number' ;
    rdfs:comment 'FDA-assigned sponsor identifier used in Investigational New Drug (IND) applications, New Drug Applications (NDA), and Biologics License Applications (BLA). Links the organization to its regulatory submissions in FDA systems.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstStudyStartDate rdf:type rdf:Property ;
    rdfs:label 'First Study Start Date' ;
    rdfs:comment 'Date on which the first clinical study with this sponsor organization was initiated. Establishes the tenure of the CRO-sponsor relationship and is used for loyalty segmentation and strategic account analytics.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:foundingYear rdf:type rdf:Property ;
    rdfs:label 'Founding Year' ;
    rdfs:comment 'Calendar year in which the sponsor organization was legally incorporated or founded. Used for organizational maturity assessment, due diligence, and sponsor profile analytics.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gcpAuditRequired rdf:type rdf:Property ;
    rdfs:label 'Gcp Audit Required' ;
    rdfs:comment 'Indicates whether the sponsor organization requires GCP audits of CRO operations as part of their quality oversight obligations under ICH E6(R2). Triggers audit scheduling in MasterControl.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City where the sponsor organization\'s principal headquarters is located. Used for regulatory jurisdiction determination, site visit planning, and sponsor contact management.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountry rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the country where the sponsor organization\'s principal headquarters is located. Determines primary regulatory jurisdiction and applicable data privacy laws (GDPR, HIPAA).' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'State or province of the sponsor organization\'s principal headquarters. Used for sub-national regulatory jurisdiction determination and tax compliance.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indHolder rdf:type rdf:Property ;
    rdfs:label 'Ind Holder' ;
    rdfs:comment 'Indicates whether the sponsor organization holds one or more active Investigational New Drug (IND) applications with the FDA. Key regulatory classification for study oversight and sponsor obligations under 21 CFR Part 312.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPubliclyTraded rdf:type rdf:Property ;
    rdfs:label 'Is Publicly Traded' ;
    rdfs:comment 'Indicates whether the sponsor organization is publicly traded on a stock exchange. Drives SOX compliance requirements, financial disclosure obligations, and investor relations considerations for study data.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full legal registered name of the sponsor organization as it appears in official corporate filings and regulatory submissions (e.g., IND, NDA, BLA, MAA applications). Used as the authoritative identity label across all regulatory documents.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterAgreementExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Master Agreement Expiry Date' ;
    rdfs:comment 'Expiration date of the master service agreement or preferred provider agreement with the sponsor organization. Triggers contract renewal workflows and financial planning activities in SAP S/4HANA.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orgStatus rdf:type rdf:Property ;
    rdfs:label 'Org Status' ;
    rdfs:comment 'Current lifecycle status of the sponsor organization record. Controls whether new studies can be initiated with this sponsor and whether existing engagements remain operationally active.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgType rdf:type rdf:Property ;
    rdfs:label 'Org Type' ;
    rdfs:comment 'Categorical classification of the sponsor organization by entity type. Drives regulatory pathway selection, contract templates, and reporting obligations. [ENUM-REF-CANDIDATE: pharmaceutical|biotech|academic|government|non_profit|medical_device — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredEdcSystem rdf:type rdf:Property ;
    rdfs:label 'Preferred Edc System' ;
    rdfs:comment 'Sponsor\'s preferred Electronic Data Capture (EDC) platform for clinical data collection. Informs technology stack decisions for study setup in Medidata Rave or Oracle Clinical One and impacts eCRF build timelines.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredEtmfSystem rdf:type rdf:Property ;
    rdfs:label 'Preferred Etmf System' ;
    rdfs:comment 'Sponsor\'s preferred Electronic Trial Master File (eTMF) platform for document management and regulatory archival. Determines integration requirements with Veeva Vault eTMF and document exchange protocols.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStrategyRegion rdf:type rdf:Property ;
    rdfs:label 'Regulatory Strategy Region' ;
    rdfs:comment 'Geographic regulatory strategy scope for the sponsor\'s clinical development program. Determines which regulatory agencies (FDA, EMA, PMDA, TGA, Health Canada) are engaged and which submission pathways apply.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyReportingContactEmail rdf:type rdf:Property ;
    rdfs:label 'Safety Reporting Contact Email' ;
    rdfs:comment 'Designated email address for the sponsor\'s pharmacovigilance or drug safety unit. Used for Serious Adverse Event (SAE), Suspected Unexpected Serious Adverse Reaction (SUSAR), and expedited safety report submissions to Oracle Argus Safety.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockExchange rdf:type rdf:Property ;
    rdfs:label 'Stock Exchange' ;
    rdfs:comment 'Primary stock exchange on which the sponsor organization\'s shares are listed. Relevant for SOX compliance scope and financial reporting obligations.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockTicker rdf:type rdf:Property ;
    rdfs:label 'Stock Ticker' ;
    rdfs:comment 'Exchange-listed stock ticker symbol for publicly traded sponsor organizations. Used for financial monitoring, SOX compliance tracking, and market intelligence.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Number' ;
    rdfs:comment 'Federal Employer Identification Number (EIN) or equivalent national tax identifier for the sponsor organization. Required for SAP S/4HANA financial transactions, contract execution, and regulatory filings.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Operating or brand name of the sponsor organization, which may differ from the legal name. Used in commercial communications, CTMS records, and sponsor-facing correspondence.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Official public website URL of the sponsor organization. Used for due diligence, pipeline research, and sponsor profile enrichment.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:whoUniversalTrialNumberPrefix rdf:type rdf:Property ;
    rdfs:label 'Who Universal Trial Number Prefix' ;
    rdfs:comment 'WHO International Clinical Trials Registry Platform (ICTRP) assigned prefix for the sponsor organization, used to construct Universal Trial Numbers (UTN) for WHO-registered studies.' ;
    rdfs:domain ind:Organization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetCode rdf:type rdf:Property ;
    rdfs:label 'Asset Code' ;
    rdfs:comment 'Sponsor-assigned internal development code or compound number for the investigational asset (e.g., ABC-1234, XYZ-001). Serves as the primary business identifier used across internal systems and regulatory submissions.' ;
    rdfs:domain ind:PipelineAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Free-text narrative description of the investigational asset, summarizing its scientific rationale, differentiation from existing therapies, and strategic importance to the sponsor\'s pipeline. Used in portfolio reviews and business development materials.' ;
    rdfs:domain ind:PipelineAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current lifecycle status of the pipeline asset within the sponsor\'s development portfolio. Drives pipeline reporting, resource planning, and regulatory strategy decisions.' ;
    rdfs:domain ind:PipelineAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcCode rdf:type rdf:Property ;
    rdfs:label 'Atc Code' ;
    rdfs:comment 'WHO Anatomical Therapeutic Chemical (ATC) classification code assigned to the investigational asset, classifying drugs by organ/system acted on and therapeutic, pharmacological, and chemical properties. Used for portfolio analytics and WHO-DD alignment.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandNameCandidate rdf:type rdf:Property ;
    rdfs:label 'Brand Name Candidate' ;
    rdfs:comment 'Proposed proprietary/trade name candidate for the investigational product, subject to regulatory review and approval by FDA, EMA, or other health authorities. May change prior to marketing authorization.' ;
    rdfs:domain ind:PipelineAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicaltrialsGovNumber rdf:type rdf:Property ;
    rdfs:label 'Clinicaltrials Gov Number' ;
    rdfs:comment 'Primary ClinicalTrials.gov registry identifier (NCT number) associated with the lead clinical study for this pipeline asset. Enables public registry linkage and WHO ICTRP compliance for trial transparency.' ;
    rdfs:domain ind:PipelineAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundName rdf:type rdf:Property ;
    rdfs:label 'Compound Name' ;
    rdfs:comment 'The chemical or biological compound name assigned by the sponsor during discovery and early development. May be a systematic IUPAC name, a proprietary internal name, or a code name prior to INN assignment.' ;
    rdfs:domain ind:PipelineAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctaNumber rdf:type rdf:Property ;
    rdfs:label 'Cta Number' ;
    rdfs:comment 'Regulatory authority-assigned Clinical Trial Authorisation (CTA) number for the investigational asset in the European Union or other jurisdictions (e.g., EMA, MHRA, Health Canada). Equivalent to IND for non-U.S. markets.' ;
    rdfs:domain ind:PipelineAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date on which development of the investigational asset was formally discontinued by the sponsor. Null if the asset is still active. Used for portfolio attrition analysis and lessons-learned reporting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discontinuationReason rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Reason' ;
    rdfs:comment 'Primary reason for discontinuation of the investigational asset\'s development program. Used for portfolio attrition analysis, R&D productivity reporting, and lessons-learned processes. [ENUM-REF-CANDIDATE: safety|efficacy|business_decision|regulatory|manufacturing|strategic_partnership|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugClass rdf:type rdf:Property ;
    rdfs:label 'Drug Class' ;
    rdfs:comment 'Pharmacological or therapeutic drug class of the investigational asset (e.g., kinase inhibitor, monoclonal antibody, CAR-T, CRISPR-based therapy, PD-1 inhibitor). Aligns with WHO-DD and MedDRA classification conventions.' ;
    rdfs:domain ind:PipelineAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Ind Submission Date' ;
    rdfs:comment 'Date on which the Investigational New Drug (IND) application or Clinical Trial Authorisation (CTA) was first submitted to the primary regulatory authority. Key regulatory milestone for development timeline reporting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ndaBlaMaaSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Nda Bla Maa Submission Date' ;
    rdfs:comment 'Date on which the marketing authorization application (NDA, BLA, or MAA) was submitted to the primary regulatory authority. Null if the asset has not yet reached the filing stage.' ;
    rdfs:domain ind:PipelineAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskManagementPlanRequired rdf:type rdf:Property ;
    rdfs:label 'Risk Management Plan Required' ;
    rdfs:comment 'Indicates whether a Risk Management Plan (RMP) is required by EMA or other regulatory authorities for this investigational asset as part of the marketing authorization application or post-approval commitments.' ;
    rdfs:domain ind:PipelineAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pipelineAssetPhaseId rdf:type rdf:Property ;
    rdfs:label 'Pipeline Asset Phase Id' ;
    rdfs:comment 'Unique surrogate identifier for each pipeline asset phase record. Primary key for the pipeline_asset_phase data product in the sponsor domain.' ;
    rdfs:domain ind:PipelineAssetPhase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceleratedApprovalPathway rdf:type rdf:Property ;
    rdfs:label 'Accelerated Approval Pathway' ;
    rdfs:comment 'Indicates whether the pipeline asset is being developed under an accelerated approval pathway (FDA Accelerated Approval, EMA Conditional Marketing Authorization, or equivalent) during this phase.' ;
    rdfs:domain ind:PipelineAssetPhase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualEnrollment rdf:type rdf:Property ;
    rdfs:label 'Actual Enrollment' ;
    rdfs:comment 'Actual total number of subjects enrolled across all studies conducted during this development phase. Compared against estimated_enrollment to assess recruitment performance.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualSpendUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Usd' ;
    rdfs:comment 'Total actual expenditure incurred by the sponsor for all clinical development activities within this phase to date, expressed in US Dollars. Used for budget variance analysis and portfolio financial reporting.' ;
    rdfs:domain ind:PipelineAssetPhase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedEnrollment rdf:type rdf:Property ;
    rdfs:label 'Estimated Enrollment' ;
    rdfs:comment 'Planned total number of subjects to be enrolled across all studies conducted during this development phase. Used for resource planning, site selection, and feasibility assessment.' ;
    rdfs:domain ind:PipelineAssetPhase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographyScope rdf:type rdf:Property ;
    rdfs:label 'Geography Scope' ;
    rdfs:comment 'Geographic scope of the clinical development activities conducted during this phase (e.g., \'USA\', \'EU\', \'Global\', \'USA|EU|JPN\'). Drives regulatory strategy, submission planning, and site selection.' ;
    rdfs:domain ind:PipelineAssetPhase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goNoGoDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Go No Go Decision Date' ;
    rdfs:comment 'Calendar date on which the sponsor\'s portfolio governance committee formally issued the go/no-go decision for this phase. Used for development timeline tracking and portfolio reporting.' ;
    rdfs:domain ind:PipelineAssetPhase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phaseBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Phase Budget Usd' ;
    rdfs:comment 'Total approved budget allocated by the sponsor for all clinical development activities within this phase, expressed in US Dollars. Classified as confidential due to commercially sensitive financial content.' ;
    rdfs:domain ind:PipelineAssetPhase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phaseCode rdf:type rdf:Property ;
    rdfs:label 'Phase Code' ;
    rdfs:comment 'Standardized code representing the clinical development phase of the pipeline asset. Covers the full continuum from preclinical research through post-marketing. [ENUM-REF-CANDIDATE: PRECLINICAL|PHASE_I|PHASE_IB|PHASE_II|PHASE_IIA|PHASE_IIB|PHASE_III|PHASE_IV|NDA_BLA_SUBMISSION|APPROVED — promote to reference product]' ;
    rdfs:domain ind:PipelineAssetPhase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseDurationDays rdf:type rdf:Property ;
    rdfs:label 'Phase Duration Days' ;
    rdfs:comment 'Actual number of calendar days elapsed during this development phase, calculated from phase_start_date to phase_end_date. Null if the phase is still active. Used for benchmarking development timelines against industry standards.' ;
    rdfs:domain ind:PipelineAssetPhase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phaseEndDate rdf:type rdf:Property ;
    rdfs:label 'Phase End Date' ;
    rdfs:comment 'Calendar date on which the pipeline asset completed or exited this development phase. Null if the phase is still active. Used to calculate phase duration and development timelines.' ;
    rdfs:domain ind:PipelineAssetPhase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phaseName rdf:type rdf:Property ;
    rdfs:label 'Phase Name' ;
    rdfs:comment 'Human-readable display name for the clinical development phase (e.g., \'Phase I\', \'Phase IIb\', \'NDA/BLA Submission\'). Used in reports, dashboards, and regulatory documents.' ;
    rdfs:domain ind:PipelineAssetPhase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Phase Sequence Number' ;
    rdfs:comment 'Ordinal sequence number representing the chronological order of this phase record within the pipeline asset\'s development history. Enables correct ordering of phase transitions for longitudinal analysis.' ;
    rdfs:domain ind:PipelineAssetPhase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phaseStartDate rdf:type rdf:Property ;
    rdfs:label 'Phase Start Date' ;
    rdfs:comment 'Calendar date on which the pipeline asset formally entered this development phase. For Phase I, this typically aligns with first-in-human (FIH) dosing; for NDA/BLA, with submission filing date.' ;
    rdfs:domain ind:PipelineAssetPhase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phaseStatus rdf:type rdf:Property ;
    rdfs:label 'Phase Status' ;
    rdfs:comment 'Current operational status of the pipeline asset within this development phase. Indicates whether the phase is actively progressing, has been completed, is temporarily suspended, or has been terminated.' ;
    rdfs:domain ind:PipelineAssetPhase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedPhaseEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned Phase End Date' ;
    rdfs:comment 'Originally planned calendar date for the pipeline asset to complete this development phase. Used to measure schedule variance and forecast downstream phase timelines.' ;
    rdfs:domain ind:PipelineAssetPhase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedPhaseStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Phase Start Date' ;
    rdfs:comment 'Originally planned calendar date for the pipeline asset to enter this development phase, as defined in the integrated development plan. Used to measure schedule variance against actual start.' ;
    rdfs:domain ind:PipelineAssetPhase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:previousPhaseCode rdf:type rdf:Property ;
    rdfs:label 'Previous Phase Code' ;
    rdfs:comment 'Phase code of the immediately preceding development phase for this pipeline asset. Enables direct traversal of the phase history chain without requiring a self-join. Null for the first phase record.' ;
    rdfs:domain ind:PipelineAssetPhase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEndpointMet rdf:type rdf:Property ;
    rdfs:label 'Primary Endpoint Met' ;
    rdfs:comment 'Indicates whether the primary efficacy or safety endpoint defined for this development phase was met upon phase completion. True = primary endpoint achieved; False = not achieved; Null = phase not yet completed or endpoint not yet evaluated.' ;
    rdfs:domain ind:PipelineAssetPhase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryMilestoneAchieved rdf:type rdf:Property ;
    rdfs:label 'Regulatory Milestone Achieved' ;
    rdfs:comment 'Description of the key regulatory milestone achieved upon completion or during this phase (e.g., \'IND Clearance\', \'End-of-Phase-II Meeting\', \'NDA Acceptance\', \'Breakthrough Therapy Designation\'). Null if no milestone was achieved.' ;
    rdfs:domain ind:PipelineAssetPhase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMilestoneDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Milestone Date' ;
    rdfs:comment 'Calendar date on which the regulatory milestone associated with this phase was formally achieved or received. Used for regulatory timeline tracking and submission planning.' ;
    rdfs:domain ind:PipelineAssetPhase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReasonCategory rdf:type rdf:Property ;
    rdfs:label 'Termination Reason Category' ;
    rdfs:comment 'Standardized category for the primary reason a phase was terminated. Enables portfolio-level analysis of attrition drivers across the development pipeline. Null if phase was not terminated.' ;
    rdfs:domain ind:PipelineAssetPhase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionReason rdf:type rdf:Property ;
    rdfs:label 'Transition Reason' ;
    rdfs:comment 'Narrative explanation for why the pipeline asset transitioned into or out of this development phase. Captures scientific, regulatory, commercial, or safety rationale for phase progression, hold, or termination.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionType rdf:type rdf:Property ;
    rdfs:label 'Transition Type' ;
    rdfs:comment 'Categorical classification of the type of phase transition event. Distinguishes between forward progression, temporary hold, full termination, restart after hold, or protocol amendment-driven transition.' ;
    rdfs:domain ind:PipelineAssetPhase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Proposal management tracking requires a proper FK to the CRO employee managing the proposal for resource utilization reporting, win/loss analysis by proposal manager, and workload balancing. \'proposal' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bdOwner rdf:type rdf:Property ;
    rdfs:label 'Bd Owner' ;
    rdfs:comment 'Name or employee identifier of the CRO business development lead responsible for managing the proposal process and sponsor relationship for this opportunity.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directCostTotal rdf:type rdf:Property ;
    rdfs:label 'Direct Cost Total' ;
    rdfs:comment 'Sum of all direct CRO service costs within the proposal, excluding pass-through expenses. Represents the CRO\'s own labor and operational costs billed to the sponsor.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusions rdf:type rdf:Property ;
    rdfs:label 'Exclusions' ;
    rdfs:comment 'Narrative description of services, activities, or costs explicitly excluded from the proposal scope. Protects the CRO from scope creep and forms the basis for change order proposals.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCompetitiveBid rdf:type rdf:Property ;
    rdfs:label 'Is Competitive Bid' ;
    rdfs:comment 'Indicates whether this proposal is submitted in a competitive bidding process (True) where multiple CROs are responding to the same bid request, or a sole-source opportunity (False).' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRebid rdf:type rdf:Property ;
    rdfs:label 'Is Rebid' ;
    rdfs:comment 'Indicates whether this proposal is a rebid (True) submitted after a prior version was rejected or returned for revision by the sponsor, or an original submission (False).' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lostReason rdf:type rdf:Property ;
    rdfs:label 'Lost Reason' ;
    rdfs:comment 'Categorized reason why the proposal was not awarded when proposal_status is lost. Used for win/loss analysis and competitive intelligence to improve future proposal quality. [ENUM-REF-CANDIDATE: price|timeline|capabilities|sponsor_preference|study_cancelled|no_decision|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passThroughCostTotal rdf:type rdf:Property ;
    rdfs:label 'Pass Through Cost Total' ;
    rdfs:comment 'Sum of all third-party pass-through costs included in the proposal (e.g., central lab fees, IRB/IEC fees, investigator grants, courier costs). Billed to sponsor at cost without CRO markup.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingModel rdf:type rdf:Property ;
    rdfs:label 'Pricing Model' ;
    rdfs:comment 'Commercial pricing structure applied to this proposal. Unit-based prices per deliverable unit (e.g., per patient, per site visit); milestone-based ties payments to study milestones; fixed_fee is a lump sum; time_and_materials bills actuals; hybrid combines models.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalNumber rdf:type rdf:Property ;
    rdfs:label 'Proposal Number' ;
    rdfs:comment 'Externally visible, human-readable unique identifier for the proposal, used in all sponsor-facing communications and contract negotiations. Format: PRO-YYYY-NNNNNN.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalStatus rdf:type rdf:Property ;
    rdfs:label 'Proposal Status' ;
    rdfs:comment 'Current lifecycle state of the proposal in the CRO business development workflow. Drives downstream contract execution when status transitions to awarded.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalType rdf:type rdf:Property ;
    rdfs:label 'Proposal Type' ;
    rdfs:comment 'Classification of the proposal by service delivery model. Full-service covers end-to-end CRO delivery; FSP (Functional Service Provider) covers specific functional areas; change_order covers scope amendments to an existing contract; budget_amendment covers financial adjustments; feasibility covers pre-study assessment proposals.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedCountryCount rdf:type rdf:Property ;
    rdfs:label 'Proposed Country Count' ;
    rdfs:comment 'Number of countries in which investigational sites are proposed to be activated. Impacts regulatory strategy complexity, translation requirements, and pass-through cost estimates.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proposedCsrDate rdf:type rdf:Property ;
    rdfs:label 'Proposed Csr Date' ;
    rdfs:comment 'Proposed date for delivery of the final Clinical Study Report (CSR) to the sponsor. Represents the end of the CRO\'s primary deliverable obligation and is a key contractual milestone.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposedDblDate rdf:type rdf:Property ;
    rdfs:label 'Proposed Dbl Date' ;
    rdfs:comment 'Proposed date for database lock (DBL), after which no further data changes are permitted and the clean database is handed to biostatistics for final analysis. Critical milestone for regulatory submission planning.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposedFpiDate rdf:type rdf:Property ;
    rdfs:label 'Proposed Fpi Date' ;
    rdfs:comment 'Proposed date for enrollment of the first study subject (First Patient In / First Subject In). Key milestone in the proposed study timeline used for sponsor planning and KPI tracking.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposedLpoDate rdf:type rdf:Property ;
    rdfs:label 'Proposed Lpo Date' ;
    rdfs:comment 'Proposed date for the last study subject completing all protocol-required visits (Last Patient Out / Last Subject Out). Defines the end of the clinical phase in the proposed timeline.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposedProjectDirector rdf:type rdf:Property ;
    rdfs:label 'Proposed Project Director' ;
    rdfs:comment 'Name of the CRO project director proposed to lead the study if awarded. Sponsor may request specific named personnel as a condition of award.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedSiteCount rdf:type rdf:Property ;
    rdfs:label 'Proposed Site Count' ;
    rdfs:comment 'Total number of investigational sites proposed to be activated for the study. Drives monitoring resource planning, site management costs, and feasibility assumptions.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proposedSubjectCount rdf:type rdf:Property ;
    rdfs:label 'Proposed Subject Count' ;
    rdfs:comment 'Total number of study subjects (patients) proposed to be enrolled across all sites. Derived from the protocol synopsis and drives sample size assumptions in the budget model.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskFactors rdf:type rdf:Property ;
    rdfs:label 'Risk Factors' ;
    rdfs:comment 'Narrative summary of identified risks that could impact the proposed budget, timeline, or deliverables (e.g., complex patient population, emerging market sites, novel endpoint technology).' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Study Duration Months' ;
    rdfs:comment 'Total proposed duration of the study in months from study start (first site activation) to CSR delivery. Used for resource loading, timeline risk assessment, and contract term setting.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalProposedBudget rdf:type rdf:Property ;
    rdfs:label 'Total Proposed Budget' ;
    rdfs:comment 'Gross total budget amount proposed by the CRO for the full scope of services, inclusive of all direct costs, pass-through costs, and applicable fees. Expressed in the proposal currency.' ;
    rdfs:domain ind:Proposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorVersionLineProposalLineId rdf:type rdf:Property ;
    rdfs:label 'Prior Version Line Proposal Line Id' ;
    rdfs:comment 'Reference to the previous version of this proposal line item, enabling version chain traceability. Supports audit trail and change history analysis for scope and budget negotiations.' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProposalLine .

ind:assumptions rdf:type rdf:Property ;
    rdfs:label 'Assumptions' ;
    rdfs:comment 'Narrative text capturing the specific protocol and operational assumptions underlying the quantity estimate and pricing for this line item (e.g., assumed number of sites, patient enrollment rate, visit frequency, country mix). Critical for scope change management and out-of-scope billing.' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingScheduleType rdf:type rdf:Property ;
    rdfs:label 'Billing Schedule Type' ;
    rdfs:comment 'The invoicing cadence or trigger type for this line item, defining when the CRO will invoice the sponsor for this service (e.g., monthly pro-rata, quarterly, upon milestone achievement, upfront, upon completion). Drives accounts receivable planning.' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingencyPct rdf:type rdf:Property ;
    rdfs:label 'Contingency Pct' ;
    rdfs:comment 'The contingency reserve percentage added to the base line amount to account for scope uncertainty, protocol amendments, or operational risk. Expressed as a percentage of the total line amount. Classified as confidential.' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costType rdf:type rdf:Property ;
    rdfs:label 'Cost Type' ;
    rdfs:comment 'Indicates whether this line item represents a direct cost (CRO-provided service billed at negotiated rates) or a pass-through cost (third-party expense incurred on behalf of the sponsor and billed at actual cost, e.g., IRB fees, travel, laboratory courier). Critical for budget transparency and sponsor financial reporting.' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPct rdf:type rdf:Property ;
    rdfs:label 'Discount Pct' ;
    rdfs:comment 'The negotiated discount percentage applied to the list price for this line item. Reflects sponsor relationship pricing, volume commitments, or strategic partnership terms. Classified as confidential due to commercially sensitive negotiation data.' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Estimated Quantity' ;
    rdfs:comment 'The projected number of units of measure anticipated for this service line over the study duration. Based on protocol assumptions such as number of sites, patients, visits, or months. Drives the total line amount calculation.' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalCostCenter rdf:type rdf:Property ;
    rdfs:label 'Internal Cost Center' ;
    rdfs:comment 'The CRO\'s internal SAP cost center code to which the revenue and costs for this line item will be allocated upon contract execution. Enables financial reporting and profitability analysis by organizational unit.' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOptional rdf:type rdf:Property ;
    rdfs:label 'Is Optional' ;
    rdfs:comment 'Indicates whether this line item represents an optional service that the sponsor may elect to include or exclude from the final contracted scope. Optional lines are excluded from the base budget total until confirmed by the sponsor.' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentMilestone rdf:type rdf:Property ;
    rdfs:label 'Payment Milestone' ;
    rdfs:comment 'The specific study milestone event that triggers payment for this line item when is_milestone_based is true (e.g., study start-up completion, first patient first visit, last patient last visit, database lock, CSR delivery). Aligns with the study payment schedule.' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceType rdf:type rdf:Property ;
    rdfs:label 'Resource Type' ;
    rdfs:comment 'Categorizes the primary resource type delivering this service line (internal CRO staff, subcontracted CRO, technology platform, facility, or third-party vendor). Informs make-vs-buy decisions and subcontractor management.' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeChangeReference rdf:type rdf:Property ;
    rdfs:label 'Scope Change Reference' ;
    rdfs:comment 'Reference identifier for the change order or scope amendment that introduced or modified this line item. Links the line to the formal change control process when the proposal is revised post-initial submission.' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorComment rdf:type rdf:Property ;
    rdfs:label 'Sponsor Comment' ;
    rdfs:comment 'Free-text comments or feedback provided by the sponsor during the proposal review and negotiation process for this specific line item. Captures negotiation context and rationale for line-level changes.' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractorName rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Name' ;
    rdfs:comment 'Name of the third-party subcontractor or vendor responsible for delivering this line item when resource_type is subcontractor or third_party_vendor. Required for sponsor transparency and regulatory oversight of delegated activities per ICH E6(R2).' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLineAmount rdf:type rdf:Property ;
    rdfs:label 'Total Line Amount' ;
    rdfs:comment 'The total proposed cost for this line item, calculated as unit price multiplied by estimated quantity. Represents the full financial commitment for this scope element. Classified as confidential due to commercially sensitive budget information.' ;
    rdfs:domain ind:ProposalLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:croRegulatoryLeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Cro Regulatory Lead Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory submission accountability requires a proper FK to the CRO regulatory affairs employee leading the strategy for FDA/EMA inspection readiness, health authority meeting preparation, and regula' ;
    rdfs:domain ind:RegulatoryStrategy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:regulatoryStrategyId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Regulatory Strategy Id' ;
    rdfs:comment 'Foreign key linking to regulatory.strategy. Business justification: Sponsor regulatory strategy (sponsor-side view) must align with the CRO operational regulatory strategy. Linking them enables strategy alignment audits, version reconciliation, and joint regulatory pl' ;
    rdfs:domain ind:RegulatoryStrategy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Strategy .

ind:actualIndSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Ind Submission Date' ;
    rdfs:comment 'Actual date on which the IND application was submitted to the FDA. Enables variance analysis against planned submission dates for program performance reporting.' ;
    rdfs:domain ind:RegulatoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualNdaBlaSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Nda Bla Submission Date' ;
    rdfs:comment 'Actual date on which the NDA, BLA, or MAA was submitted to the primary health authority. Used for regulatory milestone tracking and PDUFA/review clock management.' ;
    rdfs:domain ind:RegulatoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:additionalHealthAuthorities rdf:type rdf:Property ;
    rdfs:label 'Additional Health Authorities' ;
    rdfs:comment 'Comma-separated list of secondary health authorities targeted under the global harmonization approach (e.g., \'EMA, PMDA, Health Canada\'). Supports multi-regional submission planning aligned with ICH CTD/eCTD global dossier strategy.' ;
    rdfs:domain ind:RegulatoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advisoryCommitteeRequired rdf:type rdf:Property ;
    rdfs:label 'Advisory Committee Required' ;
    rdfs:comment 'Indicates whether an FDA Advisory Committee meeting is anticipated or required for the review of this NDA/BLA. Drives sponsor and CRO preparation activities for public advisory committee presentations.' ;
    rdfs:domain ind:RegulatoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:designationGrantedDate rdf:type rdf:Property ;
    rdfs:label 'Designation Granted Date' ;
    rdfs:comment 'Date on which the health authority officially granted the requested regulatory designation (e.g., Fast Track, Orphan Drug). Null if designation has not yet been granted.' ;
    rdfs:domain ind:RegulatoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:globalHarmonizationApproach rdf:type rdf:Property ;
    rdfs:label 'Global Harmonization Approach' ;
    rdfs:comment 'Strategy for coordinating multi-regional regulatory submissions under the ICH CTD/eCTD framework. Defines whether a single global dossier, regional adaptations, or parallel/rolling submissions are planned across health authorities.' ;
    rdfs:domain ind:RegulatoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPreSubmissionMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Last Pre Submission Meeting Date' ;
    rdfs:comment 'Date of the most recently completed pre-submission meeting with the health authority. Used to track the history of regulatory interactions and inform the currency of agency alignment on the development program.' ;
    rdfs:domain ind:RegulatoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadRegulatoryContact rdf:type rdf:Property ;
    rdfs:label 'Lead Regulatory Contact' ;
    rdfs:comment 'Name or identifier of the lead regulatory affairs professional (sponsor-side or CRO-side) responsible for executing this regulatory strategy. Serves as the primary point of contact for regulatory agency interactions.' ;
    rdfs:domain ind:RegulatoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextPreSubmissionMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Next Pre Submission Meeting Date' ;
    rdfs:comment 'Planned date for the next scheduled pre-submission meeting with the health authority. Enables CRO regulatory teams to prepare briefing documents and align services with upcoming agency interactions.' ;
    rdfs:domain ind:RegulatoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orphanDrugDesignationNumber rdf:type rdf:Property ;
    rdfs:label 'Orphan Drug Designation Number' ;
    rdfs:comment 'FDA or EMA-assigned orphan drug designation number if the investigational product has received orphan designation for the target indication. Null if no orphan designation has been granted.' ;
    rdfs:domain ind:RegulatoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedNdaBlaSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Nda Bla Submission Date' ;
    rdfs:comment 'Planned date for submitting the NDA or BLA to the FDA (or MAA to EMA). Critical milestone for sponsor program planning, CRO deliverable scheduling, and regulatory timeline commitments.' ;
    rdfs:domain ind:RegulatoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preSubmissionMeetingType rdf:type rdf:Property ;
    rdfs:label 'Pre Submission Meeting Type' ;
    rdfs:comment 'Type of most recent or planned pre-submission meeting with the health authority (e.g., Type A, Type B, Type C for FDA; INTERACT for EMA). Captures the formal meeting category that governs FDA response timelines and agenda scope. [ENUM-REF-CANDIDATE: Type A|Type B|Type C|INTERACT|pre-IND|pre-NDA|pre-BLA|EOP2 — promote to reference product]' ;
    rdfs:domain ind:RegulatoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Regulatory Risk Level' ;
    rdfs:comment 'Overall regulatory risk classification assigned to this strategy based on the risk assessment. Reflects the likelihood and impact of regulatory challenges (e.g., safety signals, CMC issues, clinical data gaps) that could delay or prevent approval.' ;
    rdfs:domain ind:RegulatoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRiskSummary rdf:type rdf:Property ;
    rdfs:label 'Regulatory Risk Summary' ;
    rdfs:comment 'Narrative summary of the key regulatory risks identified for this program, including potential issues with clinical data package, safety profile, CMC, or labeling that could impact the submission or approval timeline.' ;
    rdfs:domain ind:RegulatoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskMitigationStrategy rdf:type rdf:Property ;
    rdfs:label 'Risk Mitigation Strategy' ;
    rdfs:comment 'Description of the planned mitigation actions to address identified regulatory risks, such as additional clinical studies, pre-submission meetings, REMS planning, or labeling negotiations.' ;
    rdfs:domain ind:RegulatoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scientificAdviceRequested rdf:type rdf:Property ;
    rdfs:label 'Scientific Advice Requested' ;
    rdfs:comment 'Indicates whether formal scientific advice has been requested from a health authority (e.g., EMA Scientific Advice, FDA Formal Meeting, PMDA Consultation) as part of the regulatory strategy.' ;
    rdfs:domain ind:RegulatoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:strategyDescription rdf:type rdf:Property ;
    rdfs:label 'Strategy Description' ;
    rdfs:comment 'Comprehensive narrative description of the overall regulatory strategy, including the development rationale, key regulatory milestones, agency alignment approach, and any unique strategic considerations for the program.' ;
    rdfs:domain ind:RegulatoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyName rdf:type rdf:Property ;
    rdfs:label 'Strategy Name' ;
    rdfs:comment 'Human-readable name or title of the regulatory strategy, typically referencing the compound name, indication, and target market (e.g., \'Compound-X NDA Fast Track Strategy – US Oncology\').' ;
    rdfs:domain ind:RegulatoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyVersion rdf:type rdf:Property ;
    rdfs:label 'Strategy Version' ;
    rdfs:comment 'Version identifier of the regulatory strategy document (e.g., v1.0, v2.1), enabling tracking of iterative revisions as the regulatory landscape or sponsor objectives evolve.' ;
    rdfs:domain ind:RegulatoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionPathway rdf:type rdf:Property ;
    rdfs:label 'Submission Pathway' ;
    rdfs:comment 'Regulatory submission pathway selected for the program (e.g., IND, NDA, BLA, MAA, 505(b)(2), biosimilar). Determines the regulatory dossier structure, data requirements, and review timelines applicable to the strategy. [ENUM-REF-CANDIDATE: IND|NDA|BLA|MAA|505(b)(2)|biosimilar|ANDA|CTD — promote to reference product]' ;
    rdfs:domain ind:RegulatoryStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:academicDegree rdf:type rdf:Property ;
    rdfs:label 'Academic Degree' ;
    rdfs:comment 'Highest academic or professional degree held by the sponsor contact (e.g., MD, PhD, PharmD, MBA). Relevant for medical monitor qualification verification and regulatory submission authorship.' ;
    rdfs:domain ind:SponsorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsContactRef rdf:type rdf:Property ;
    rdfs:label 'Ctms Contact Ref' ;
    rdfs:comment 'The native contact record identifier from Oracle Siebel CTMS, the operational system of record for sponsor contact management. Used for system reconciliation and data lineage tracing.' ;
    rdfs:domain ind:SponsorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotContact rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact' ;
    rdfs:comment 'Indicates that this sponsor contact has requested to not be contacted directly, or has been flagged by the CRO as off-limits for direct outreach. Enforces communication suppression in CTMS and marketing workflows.' ;
    rdfs:domain ind:SponsorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprConsentDate rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Date' ;
    rdfs:comment 'Date on which GDPR data processing consent was last obtained or updated for this sponsor contact. Required for audit trail compliance under GDPR Article 7.' ;
    rdfs:domain ind:SponsorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Status' ;
    rdfs:comment 'Records the GDPR data processing consent status for this sponsor contact\'s personal data. Required for contacts based in EU/EEA jurisdictions. \'not_applicable\' for contacts outside GDPR scope.' ;
    rdfs:domain ind:SponsorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFinancialContact rdf:type rdf:Property ;
    rdfs:label 'Is Financial Contact' ;
    rdfs:comment 'Indicates whether this contact is authorized to receive financial communications including invoices, budget amendments, and payment notifications from SAP S/4HANA finance workflows.' ;
    rdfs:domain ind:SponsorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryContact rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Contact' ;
    rdfs:comment 'Indicates whether this contact is designated to receive regulatory submission notifications, IND/NDA/BLA/MAA correspondence, and Health Authority query routing. Used by the regulatory affairs team for submission workflow management.' ;
    rdfs:domain ind:SponsorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyContact rdf:type rdf:Property ;
    rdfs:label 'Is Safety Contact' ;
    rdfs:comment 'Indicates whether this contact is designated to receive Serious Adverse Event (SAE) and Suspected Unexpected Serious Adverse Reaction (SUSAR) notifications. Drives automated safety reporting distribution in Oracle Argus Safety.' ;
    rdfs:domain ind:SponsorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastInteractionDate rdf:type rdf:Property ;
    rdfs:label 'Last Interaction Date' ;
    rdfs:comment 'Date of the most recent documented interaction between the CRO and this sponsor contact (e.g., meeting, email exchange, call). Used for relationship health monitoring and CRA engagement tracking.' ;
    rdfs:domain ind:SponsorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkedinProfileUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Profile Url' ;
    rdfs:comment 'URL to the sponsor contact\'s LinkedIn professional profile. Used by business development and CRA teams for relationship intelligence, background verification, and professional network mapping.' ;
    rdfs:domain ind:SponsorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeLocation rdf:type rdf:Property ;
    rdfs:label 'Office Location' ;
    rdfs:comment 'Physical office location or site name where the sponsor contact is based (e.g., \'Pfizer - New York HQ\', \'Roche - Basel Campus\'). Used for logistics, visit planning, and organizational mapping.' ;
    rdfs:domain ind:SponsorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'The sponsor contact\'s preferred method for receiving communications from the CRO. Drives automated notification routing and meeting scheduling preferences within the CTMS.' ;
    rdfs:domain ind:SponsorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'Primary business email address for the sponsor contact. Used as the principal digital identifier for all CRO-sponsor communications, system notifications, and regulatory correspondence. SSOT for sponsor personnel identity.' ;
    rdfs:domain ind:SponsorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salutation rdf:type rdf:Property ;
    rdfs:label 'Salutation' ;
    rdfs:comment 'Formal salutation or honorific prefix for the sponsor contact (e.g., Dr., Mr., Ms., Prof.). Used in formal written correspondence, regulatory submissions, and meeting invitations.' ;
    rdfs:domain ind:SponsorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryEmail rdf:type rdf:Property ;
    rdfs:label 'Secondary Email' ;
    rdfs:comment 'Alternate email address for the sponsor contact, used when the primary email is unavailable or for routing specific communication types (e.g., personal email for urgent safety notifications).' ;
    rdfs:domain ind:SponsorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veevaContactRef rdf:type rdf:Property ;
    rdfs:label 'Veeva Contact Ref' ;
    rdfs:comment 'The contact record identifier from Veeva Vault, used when the sponsor contact is associated with eTMF document approvals, regulatory submissions, or quality management workflows.' ;
    rdfs:domain ind:SponsorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewMeetingId rdf:type rdf:Property ;
    rdfs:label 'Review Meeting Id' ;
    rdfs:comment 'Unique surrogate identifier for the sponsor-CRO governance review meeting record in the Silver Layer lakehouse.' ;
    rdfs:domain ind:ReviewMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:croChairEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Cro Chair Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Governance meeting records require a proper FK to the CRO employee chairing the meeting for minutes approval, action item ownership, audit trail completeness, and GCP inspection readiness. \'cro_chair\'' ;
    rdfs:domain ind:ReviewMeeting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual End Time' ;
    rdfs:comment 'Precise date and time at which the governance meeting actually concluded. Used to calculate actual meeting duration and assess time management.' ;
    rdfs:domain ind:ReviewMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Time' ;
    rdfs:comment 'Precise date and time at which the governance meeting actually commenced. Compared against scheduled_start_time to measure punctuality and governance discipline.' ;
    rdfs:domain ind:ReviewMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:agendaItemCount rdf:type rdf:Property ;
    rdfs:label 'Agenda Item Count' ;
    rdfs:comment 'Total number of formal agenda items included in the meeting. Provides a high-level measure of meeting scope and complexity.' ;
    rdfs:domain ind:ReviewMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:croAttendeeCount rdf:type rdf:Property ;
    rdfs:label 'Cro Attendee Count' ;
    rdfs:comment 'Total number of CRO-side participants who attended the governance meeting. Used for quorum validation and engagement analytics.' ;
    rdfs:domain ind:ReviewMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationCount rdf:type rdf:Property ;
    rdfs:label 'Escalation Count' ;
    rdfs:comment 'Total number of formal escalations raised during the governance meeting. Null or zero when escalation_raised is False. Used for risk and relationship health analytics.' ;
    rdfs:domain ind:ReviewMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationRaised rdf:type rdf:Property ;
    rdfs:label 'Escalation Raised' ;
    rdfs:comment 'Indicates whether one or more formal escalations were raised during this governance meeting. True = at least one escalation was formally logged; False = no escalations raised. Triggers escalation management workflow.' ;
    rdfs:domain ind:ReviewMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialReviewIncluded rdf:type rdf:Property ;
    rdfs:label 'Financial Review Included' ;
    rdfs:comment 'Indicates whether a formal financial review (budget burn, pass-through reconciliation, change orders) was included as an agenda item in this governance meeting.' ;
    rdfs:domain ind:ReviewMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kpiReviewIncluded rdf:type rdf:Property ;
    rdfs:label 'Kpi Review Included' ;
    rdfs:comment 'Indicates whether a formal KPI dashboard review was included as an agenda item in this governance meeting. True = KPI review conducted; False = KPI review not included.' ;
    rdfs:domain ind:ReviewMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meetingSummary rdf:type rdf:Property ;
    rdfs:label 'Meeting Summary' ;
    rdfs:comment 'High-level narrative summary of the key topics discussed, decisions reached, and outcomes of the governance meeting. Intended for executive stakeholders who require a concise overview without reading full minutes.' ;
    rdfs:domain ind:ReviewMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityReviewIncluded rdf:type rdf:Property ;
    rdfs:label 'Quality Review Included' ;
    rdfs:comment 'Indicates whether a formal quality metrics review (e.g., protocol deviations, CAPA status, audit findings) was included as an agenda item. Relevant for QBR meeting types.' ;
    rdfs:domain ind:ReviewMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'Precise date and time at which the governance meeting was scheduled to conclude. Used to calculate planned meeting duration and manage participant availability.' ;
    rdfs:domain ind:ReviewMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'Precise date and time (with timezone offset) at which the governance meeting was scheduled to begin. Supports calendar management and multi-timezone coordination between sponsor and CRO.' ;
    rdfs:domain ind:ReviewMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sponsorAttendeeCount rdf:type rdf:Property ;
    rdfs:label 'Sponsor Attendee Count' ;
    rdfs:comment 'Total number of sponsor-side participants who attended the governance meeting. Used for quorum validation and engagement analytics.' ;
    rdfs:domain ind:ReviewMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sponsorChair rdf:type rdf:Property ;
    rdfs:label 'Sponsor Chair' ;
    rdfs:comment 'Full name of the sponsor-side individual who chairs or co-chairs the governance meeting. Typically a senior sponsor representative such as a VP Clinical Development or Alliance Manager.' ;
    rdfs:domain ind:ReviewMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdiscComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Cdisc Compliance Required' ;
    rdfs:comment 'Indicates whether the portfolio requires CDISC (Clinical Data Interchange Standards Consortium) compliant data submissions (SDTM/ADaM). Mandatory for FDA and EMA regulatory submissions; drives data management planning.' ;
    rdfs:domain ind:StudyPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataManagementSystem rdf:type rdf:Property ;
    rdfs:label 'Data Management System' ;
    rdfs:comment 'Primary Electronic Data Capture (EDC) or data management system used for clinical data collection across the portfolio\'s studies (e.g., Medidata Rave, Oracle Clinical One). Drives data integration and CDISC compliance planning.' ;
    rdfs:domain ind:StudyPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icfManagementSystem rdf:type rdf:Property ;
    rdfs:label 'Icf Management System' ;
    rdfs:comment 'System used for Informed Consent Form (ICF) management and eConsent across the portfolio\'s studies (e.g., Clinpal for eConsent, paper-based, Veeva Vault). Drives patient engagement and regulatory compliance for consent documentation.' ;
    rdfs:domain ind:StudyPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbIecOversightModel rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Oversight Model' ;
    rdfs:comment 'Institutional Review Board (IRB) or Independent Ethics Committee (IEC) oversight model applied across the portfolio. \'central_irb\' uses a single central IRB; \'local_irb\' requires site-level IRB approvals; \'mixed\' combines both approaches.' ;
    rdfs:domain ind:StudyPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiDataQueryRate rdf:type rdf:Property ;
    rdfs:label 'Kpi Data Query Rate' ;
    rdfs:comment 'Portfolio-level KPI target for the maximum acceptable data query rate (percentage of data points generating queries) across Electronic Data Capture (EDC) systems. Reflects data quality expectations set by the sponsor.' ;
    rdfs:domain ind:StudyPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kpiEnrollmentTarget rdf:type rdf:Property ;
    rdfs:label 'Kpi Enrollment Target' ;
    rdfs:comment 'Portfolio-level Key Performance Indicator (KPI) target for total subject enrollment across all studies in the portfolio. Used for sponsor-level performance reporting and CRO accountability tracking.' ;
    rdfs:domain ind:StudyPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kpiSiteActivationDays rdf:type rdf:Property ;
    rdfs:label 'Kpi Site Activation Days' ;
    rdfs:comment 'Portfolio-level KPI target for the maximum number of days from site selection to site activation. Benchmarks CRO operational efficiency for the sponsor across all studies in the portfolio.' ;
    rdfs:domain ind:StudyPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portfolioBudgetUsd rdf:type rdf:Property ;
    rdfs:label 'Portfolio Budget Usd' ;
    rdfs:comment 'Total contracted budget value for the study portfolio in US Dollars, as agreed in the master service agreement. Serves as the financial ceiling for portfolio-level cost tracking and sponsor billing in SAP S/4HANA.' ;
    rdfs:domain ind:StudyPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portfolioCode rdf:type rdf:Property ;
    rdfs:label 'Portfolio Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the study portfolio, used in sponsor communications, CTMS references, and contract documentation. Unique per sponsor.' ;
    rdfs:domain ind:StudyPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioDescription rdf:type rdf:Property ;
    rdfs:label 'Portfolio Description' ;
    rdfs:comment 'Free-text narrative description of the portfolio\'s scientific rationale, business objectives, and scope. Provides context for CRO teams, governance committees, and sponsor relationship management.' ;
    rdfs:domain ind:StudyPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioEndDate rdf:type rdf:Property ;
    rdfs:label 'Portfolio End Date' ;
    rdfs:comment 'Planned or actual date on which the portfolio relationship concludes. Null for open-ended portfolios. Used for contract lifecycle management and resource wind-down planning.' ;
    rdfs:domain ind:StudyPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:portfolioName rdf:type rdf:Property ;
    rdfs:label 'Portfolio Name' ;
    rdfs:comment 'Human-readable name of the study portfolio as agreed with the sponsor, typically reflecting the therapeutic area or drug program (e.g., \'Oncology Phase II-III Pipeline 2024\'). Treated as confidential sponsor business information.' ;
    rdfs:domain ind:StudyPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioStartDate rdf:type rdf:Property ;
    rdfs:label 'Portfolio Start Date' ;
    rdfs:comment 'Date on which the study portfolio relationship became effective and the CRO began providing services under this portfolio grouping. Aligns with the master service agreement or first study contract activation.' ;
    rdfs:domain ind:StudyPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:portfolioStatus rdf:type rdf:Property ;
    rdfs:label 'Portfolio Status' ;
    rdfs:comment 'Current lifecycle state of the study portfolio. \'active\' indicates studies are ongoing; \'wind_down\' indicates the portfolio is transitioning to close-out; \'completed\' indicates all studies are closed; \'suspended\' indicates operations are paused; \'pending\' indicates the portfolio is not yet initiated.' ;
    rdfs:domain ind:StudyPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtsmRequired rdf:type rdf:Property ;
    rdfs:label 'Rtsm Required' ;
    rdfs:comment 'Indicates whether Randomization and Trial Supply Management (RTSM) / Interactive Response Technology (IRT) is required for studies in this portfolio. Drives Medidata Rave RTSM or equivalent system configuration.' ;
    rdfs:domain ind:StudyPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyReportingStandard rdf:type rdf:Property ;
    rdfs:label 'Safety Reporting Standard' ;
    rdfs:comment 'Applicable safety reporting standard governing Adverse Event (AE) and Serious Adverse Event (SAE) reporting for the portfolio (e.g., ICH E2A for expedited reporting, ICH E2B(R3) for electronic case safety reports, CTCAE v5 for grading). Drives Oracle Argus Safety configuration.' ;
    rdfs:domain ind:StudyPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCountTarget rdf:type rdf:Property ;
    rdfs:label 'Site Count Target' ;
    rdfs:comment 'Planned total number of investigational sites to be activated across all studies in the portfolio. Used for feasibility planning, CRA (Clinical Research Associate) resource allocation, and sponsor reporting.' ;
    rdfs:domain ind:StudyPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:strategicPriorityTier rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority Tier' ;
    rdfs:comment 'Sponsor-assigned strategic priority classification for the portfolio. Tier 1 = highest priority (flagship programs); Tier 2 = standard priority; Tier 3 = exploratory or lower-priority programs. Drives CRO resource allocation and executive attention.' ;
    rdfs:domain ind:StudyPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmfSystem rdf:type rdf:Property ;
    rdfs:label 'Tmf System' ;
    rdfs:comment 'System used for Trial Master File (TMF) or electronic Trial Master File (eTMF) management across the portfolio (e.g., Veeva Vault eTMF). Ensures regulatory inspection readiness and document completeness per ICH E6(R2).' ;
    rdfs:domain ind:StudyPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalStudyCount rdf:type rdf:Property ;
    rdfs:label 'Total Study Count' ;
    rdfs:comment 'Total number of clinical studies contracted under this portfolio, including active, completed, and wind-down studies. Used for portfolio sizing and capacity planning.' ;
    rdfs:domain ind:StudyPortfolio ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adamAdexMappingNotes rdf:type rdf:Property ;
    rdfs:label 'Adam Adex Mapping Notes' ;
    rdfs:comment 'Notes describing how this dosing regimen maps to the CDISC ADaM ADEX (Analysis Dataset for Exposure) domain, including derivation rules for cumulative dose, dose intensity, and relative dose intensity calculations used in biostatistical analysis.' ;
    rdfs:domain ind:DosingRegimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comparatorType rdf:type rdf:Property ;
    rdfs:label 'Comparator Type' ;
    rdfs:comment 'Indicates whether this regimen represents an active investigational product, placebo, vehicle control, sham procedure, or no-treatment arm. Critical for ITT and PP population definitions and regulatory benefit-risk assessment.' ;
    rdfs:domain ind:DosingRegimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doseEscalationStep rdf:type rdf:Property ;
    rdfs:label 'Dose Escalation Step' ;
    rdfs:comment 'Sequential step number within the dose escalation scheme (e.g., 1, 2, 3). Enables ordering of dose cohorts in escalation studies and supports dose-response curve construction in PK/PD modeling.' ;
    rdfs:domain ind:DosingRegimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:doseForm rdf:type rdf:Property ;
    rdfs:label 'Dose Form' ;
    rdfs:comment 'Pharmaceutical form of the investigational product as administered (e.g., \'TABLET\', \'CAPSULE\', \'SOLUTION FOR INJECTION\', \'PATCH\'). Conforms to CDISC SDTM EX.EXDOSFRM controlled terminology. [ENUM-REF-CANDIDATE: TABLET|CAPSULE|SOLUTION FOR INJECTION|PATCH|POWDER|CREAM|SUPPOSITORY|INHALER — promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doseModificationRules rdf:type rdf:Property ;
    rdfs:label 'Dose Modification Rules' ;
    rdfs:comment 'Narrative description of protocol-defined rules for dose modifications, reductions, interruptions, or discontinuations based on toxicity or adverse events (e.g., \'Reduce by 25% for Grade 2 AE; discontinue for Grade 3 SAE\'). Supports safety monitoring and CTCAE-based dose management.' ;
    rdfs:domain ind:DosingRegimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doseReductionLevels rdf:type rdf:Property ;
    rdfs:label 'Dose Reduction Levels' ;
    rdfs:comment 'Number of permitted dose reduction levels defined in the protocol (e.g., 2 levels: Level -1 and Level -2). Used in oncology studies to manage toxicity while maintaining therapeutic benefit. Supports safety dose-response analysis.' ;
    rdfs:domain ind:DosingRegimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:doseUnit rdf:type rdf:Property ;
    rdfs:label 'Dose Unit' ;
    rdfs:comment 'Unit of measurement for the dose level (e.g., \'mg\', \'mg/kg\', \'mg/m2\', \'mcg/kg\'). Conforms to CDISC SDTM EX.EXDOSU controlled terminology. Essential for PK/PD modeling and regulatory submissions. [ENUM-REF-CANDIDATE: mg|mg/kg|mg/m2|mcg|mcg/kg|IU|mL|g — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dosingIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Dosing Interval Days' ;
    rdfs:comment 'Numeric interval between doses expressed in days (e.g., 1.0 for QD, 0.5 for BID, 7.0 for QW). Provides machine-readable precision for automated scheduling in RTSM/IRT systems and PK modeling when frequency alone is insufficient.' ;
    rdfs:domain ind:DosingRegimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dosingRoute rdf:type rdf:Property ;
    rdfs:label 'Dosing Route' ;
    rdfs:comment 'Route by which the investigational product is administered (e.g., \'ORAL\', \'INTRAVENOUS\', \'SUBCUTANEOUS\', \'INTRAMUSCULAR\', \'TOPICAL\', \'INHALATION\'). Conforms to CDISC SDTM EX.EXROUTE controlled terminology. Critical for PK absorption modeling. [ENUM-REF-CANDIDATE: ORAL|INTRAVENOUS|SUBCUTANEOUS|INTRAMUSCULAR|TOPICAL|INHALATION|INTRANASAL|TRANSDERMAL — promote to reference product]' ;
    rdfs:domain ind:DosingRegimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationSchemeDescription rdf:type rdf:Property ;
    rdfs:label 'Escalation Scheme Description' ;
    rdfs:comment 'Narrative description of the dose escalation scheme applied in this regimen (e.g., \'3+3 design\', \'Accelerated Titration\', \'BOIN design\', \'mTPI-2\'). Populated only when is_dose_escalation = True. Supports Phase I safety and PK/PD analysis.' ;
    rdfs:domain ind:DosingRegimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foodEffectInstruction rdf:type rdf:Property ;
    rdfs:label 'Food Effect Instruction' ;
    rdfs:comment 'Protocol-defined instruction regarding food intake relative to dosing (e.g., \'fasted\' = at least 8 hours fasting before dose, \'fed\' = standard high-fat meal before dose). Impacts PK absorption and bioavailability. Conforms to FDA food effect guidance.' ;
    rdfs:domain ind:DosingRegimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infusionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Infusion Duration Minutes' ;
    rdfs:comment 'Duration of intravenous or subcutaneous infusion in minutes, applicable when dosing_route is \'INTRAVENOUS\' or similar. Null for non-infusion routes. Critical for PK modeling of IV drug exposure and site nursing procedure planning.' ;
    rdfs:domain ind:DosingRegimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDoseEscalation rdf:type rdf:Property ;
    rdfs:label 'Is Dose Escalation' ;
    rdfs:comment 'Indicates whether this regimen is part of a dose-escalation scheme (True) or a fixed-dose regimen (False). When True, the escalation_scheme_description and mtd_flag fields become operationally relevant. Common in Phase I oncology studies.' ;
    rdfs:domain ind:DosingRegimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMtd rdf:type rdf:Property ;
    rdfs:label 'Is Mtd' ;
    rdfs:comment 'Indicates whether this dose level has been designated as the Maximum Tolerated Dose (MTD) by the Data Safety Monitoring Board (DSMB) or study team (True = MTD confirmed). Critical for Phase I dose-finding studies and regulatory submissions.' ;
    rdfs:domain ind:DosingRegimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadingDoseDurationDays rdf:type rdf:Property ;
    rdfs:label 'Loading Dose Duration Days' ;
    rdfs:comment 'Number of days the loading dose is administered before transitioning to the maintenance dose. Null if no loading dose is defined. Supports PK/PD modeling of drug accumulation and steady-state calculations.' ;
    rdfs:domain ind:DosingRegimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loadingDoseLevel rdf:type rdf:Property ;
    rdfs:label 'Loading Dose Level' ;
    rdfs:comment 'Initial higher dose administered to rapidly achieve therapeutic drug concentrations before transitioning to the maintenance dose level. Expressed in the same unit as dose_unit. Null if no loading dose is specified in the protocol.' ;
    rdfs:domain ind:DosingRegimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumDoseLevel rdf:type rdf:Property ;
    rdfs:label 'Maximum Dose Level' ;
    rdfs:comment 'Maximum allowable dose level for this regimen as defined in the protocol (e.g., dose cap for safety). Expressed in the same unit as dose_unit. Used in dose modification rules and safety monitoring.' ;
    rdfs:domain ind:DosingRegimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pdAssessmentRequired rdf:type rdf:Property ;
    rdfs:label 'Pd Assessment Required' ;
    rdfs:comment 'Indicates whether pharmacodynamic (PD) biomarker assessments are required for subjects on this dosing regimen (True = PD assessments mandated per protocol). Supports PK/PD modeling and dose-response analysis.' ;
    rdfs:domain ind:DosingRegimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pkSamplingRequired rdf:type rdf:Property ;
    rdfs:label 'Pk Sampling Required' ;
    rdfs:comment 'Indicates whether pharmacokinetic (PK) blood sampling is required for subjects on this dosing regimen (True = PK sampling mandated per protocol). Drives PK visit scheduling, sample collection logistics, and DMPK analysis planning.' ;
    rdfs:domain ind:DosingRegimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:randomizationRatio rdf:type rdf:Property ;
    rdfs:label 'Randomization Ratio' ;
    rdfs:comment 'Allocation ratio for randomization to this arm/regimen expressed as a colon-separated ratio (e.g., \'1:1\', \'2:1\', \'1:1:1\'). Used in RTSM/IRT configuration and statistical analysis plan (SAP) for sample size and power calculations.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regimenCode rdf:type rdf:Property ;
    rdfs:label 'Regimen Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this dosing regimen within the study protocol (e.g., \'REG-001\', \'ARM-A-DOSE-1\'). Used in protocol documents, eCRFs, and CDISC SDTM EX submissions.' ;
    rdfs:domain ind:DosingRegimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regimenName rdf:type rdf:Property ;
    rdfs:label 'Regimen Name' ;
    rdfs:comment 'Human-readable name of the dosing regimen as defined in the study protocol (e.g., \'Low Dose QD\', \'High Dose BID\', \'Placebo TIW\'). Used in protocol documents, SAP, and CSR narratives.' ;
    rdfs:domain ind:DosingRegimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regimenStatus rdf:type rdf:Property ;
    rdfs:label 'Regimen Status' ;
    rdfs:comment 'Current lifecycle status of the dosing regimen within the study. \'draft\' indicates protocol development; \'active\' indicates currently administered; \'suspended\' indicates temporarily halted (e.g., pending safety review); \'discontinued\' indicates permanently stopped; \'completed\' indicates all subjects have completed this regimen.' ;
    rdfs:domain ind:DosingRegimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmExMappingNotes rdf:type rdf:Property ;
    rdfs:label 'Sdtm Ex Mapping Notes' ;
    rdfs:comment 'Notes describing how this dosing regimen maps to the CDISC SDTM EX (Exposure) domain variables, including any derivation logic, controlled terminology mappings, or special handling required for regulatory submission datasets. Supports CDISC compliance and eCTD submission.' ;
    rdfs:domain ind:DosingRegimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startingDoseLevel rdf:type rdf:Property ;
    rdfs:label 'Starting Dose Level' ;
    rdfs:comment 'Initial dose amount at the start of the regimen, particularly relevant for titration or escalation regimens where the dose changes over time. Expressed in the same unit as dose_unit. Supports PK/PD baseline modeling.' ;
    rdfs:domain ind:DosingRegimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentPeriodLabel rdf:type rdf:Property ;
    rdfs:label 'Treatment Period Label' ;
    rdfs:comment 'Label identifying the treatment period within the study to which this regimen applies (e.g., \'Period 1\', \'Run-In\', \'Maintenance\', \'Extension\'). Supports crossover and multi-period study designs. Maps to CDISC SDTM EX.EPOCH.' ;
    rdfs:domain ind:DosingRegimen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousCriterionEligibilityCriterionId rdf:type rdf:Property ;
    rdfs:label 'Previous Criterion Eligibility Criterion Id' ;
    rdfs:comment 'Reference to the prior version of this criterion that was superseded by the current record. Enables full version history chain for audit trail and regulatory traceability of criterion evolution across protocol amendments.' ;
    rdfs:domain ind:EligibilityCriterion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EligibilityCriterion .

ind:crfPageReference rdf:type rdf:Property ;
    rdfs:label 'Crf Page Reference' ;
    rdfs:comment 'The page or section reference in the electronic Case Report Form (eCRF) where this eligibility criterion is assessed and documented. Used for site training, monitoring, and Source Data Verification (SDV) activities.' ;
    rdfs:domain ind:EligibilityCriterion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criterionCategory rdf:type rdf:Property ;
    rdfs:label 'Criterion Category' ;
    rdfs:comment 'Clinical or operational category classifying the nature of the criterion. Supports structured analysis and site training. [ENUM-REF-CANDIDATE: DEMOGRAPHIC|DIAGNOSIS|LAB_VALUE|PRIOR_THERAPY|CONCOMITANT_MEDICATION|REPRODUCTIVE_STATUS|WASHOUT_PERIOD|CONSENT|OTHER — promote to reference product]' ;
    rdfs:domain ind:EligibilityCriterion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criterionNumber rdf:type rdf:Property ;
    rdfs:label 'Criterion Number' ;
    rdfs:comment 'Sequential number assigned to the criterion within its type (inclusion or exclusion) as it appears in the study protocol. Used for ordering and referencing in site screening checklists and EDC eligibility modules.' ;
    rdfs:domain ind:EligibilityCriterion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criterionShortName rdf:type rdf:Property ;
    rdfs:label 'Criterion Short Name' ;
    rdfs:comment 'Abbreviated or condensed label for the criterion used in EDC display, site training materials, and operational screening tools where full text is impractical. Maps to CDISC SDTM IE domain variable IETESTCD.' ;
    rdfs:domain ind:EligibilityCriterion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criterionStatus rdf:type rdf:Property ;
    rdfs:label 'Criterion Status' ;
    rdfs:comment 'Current lifecycle status of the eligibility criterion. DRAFT indicates under review; ACTIVE indicates approved and in use; SUPERSEDED indicates replaced by an amended version; RETIRED indicates removed from the protocol.' ;
    rdfs:domain ind:EligibilityCriterion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criterionText rdf:type rdf:Property ;
    rdfs:label 'Criterion Text' ;
    rdfs:comment 'Full verbatim text of the eligibility criterion as written in the approved study protocol. This is the authoritative, protocol-exact wording used in site screening checklists, EDC eligibility modules, and regulatory submissions. Maps to CDISC SDTM IE domain variable IETEST.' ;
    rdfs:domain ind:EligibilityCriterion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criterionType rdf:type rdf:Property ;
    rdfs:label 'Criterion Type' ;
    rdfs:comment 'Indicates whether the criterion is an inclusion criterion (subject must meet) or an exclusion criterion (subject must not meet) for enrollment eligibility. Maps to CDISC SDTM IE domain variable IECAT.' ;
    rdfs:domain ind:EligibilityCriterion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayOrder rdf:type rdf:Property ;
    rdfs:label 'Display Order' ;
    rdfs:comment 'The display sequence order for this criterion within its type group (inclusion or exclusion) as it should appear in site screening checklists, EDC eligibility modules, and protocol documents. May differ from criterion_number when criteria are reordered by amendment.' ;
    rdfs:domain ind:EligibilityCriterion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:edcFieldOid rdf:type rdf:Property ;
    rdfs:label 'Edc Field Oid' ;
    rdfs:comment 'The Object Identifier (OID) of the corresponding field in the Electronic Data Capture (EDC) system (e.g., Medidata Rave) eligibility module. Enables direct mapping between the protocol criterion and the EDC data collection form for data lineage and validation.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAmendmentDriven rdf:type rdf:Property ;
    rdfs:label 'Is Amendment Driven' ;
    rdfs:comment 'Indicates whether this criterion was introduced or modified as a result of a protocol amendment. True when the criterion originated from or was changed by a formal protocol amendment. Critical for regulatory audit trails and amendment impact analysis.' ;
    rdfs:domain ind:EligibilityCriterion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCriticalCriterion rdf:type rdf:Property ;
    rdfs:label 'Is Critical Criterion' ;
    rdfs:comment 'Indicates whether this criterion is designated as critical, meaning a violation would constitute a major protocol deviation requiring immediate reporting to the sponsor and potentially the IRB/IEC. Critical criteria are typically safety-related or have significant impact on data integrity.' ;
    rdfs:domain ind:EligibilityCriterion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labTestCode rdf:type rdf:Property ;
    rdfs:label 'Lab Test Code' ;
    rdfs:comment 'The standardized laboratory test code (e.g., LOINC code or sponsor-defined code) for the lab parameter referenced in this criterion. Applicable for lab value criteria such as eGFR, hemoglobin, or platelet count thresholds.' ;
    rdfs:domain ind:EligibilityCriterion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numericThresholdComparator rdf:type rdf:Property ;
    rdfs:label 'Numeric Threshold Comparator' ;
    rdfs:comment 'The logical comparator defining the relationship between the subject\'s measured value and the numeric threshold (EQ=equal, NE=not equal, LT=less than, LE=less than or equal, GT=greater than, GE=greater than or equal). Used in conjunction with numeric_threshold_value.' ;
    rdfs:domain ind:EligibilityCriterion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numericThresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Numeric Threshold Unit' ;
    rdfs:comment 'The unit of measure for the numeric threshold value (e.g., years, mL/min/1.73m², kg/m², mg/dL). Follows CDISC controlled terminology for units.' ;
    rdfs:domain ind:EligibilityCriterion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numericThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Numeric Threshold Value' ;
    rdfs:comment 'The quantitative threshold value associated with the criterion where applicable (e.g., age ≥ 18, eGFR ≥ 60, BMI ≤ 35). Used for lab value, vital sign, and demographic criteria that have a numeric boundary.' ;
    rdfs:domain ind:EligibilityCriterion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:protocolVersionFirstApplicable rdf:type rdf:Property ;
    rdfs:label 'Protocol Version First Applicable' ;
    rdfs:comment 'The protocol version number (e.g., v1.0, v2.1) in which this criterion first became applicable. Used to determine which subjects enrolled under which protocol version were subject to this criterion.' ;
    rdfs:domain ind:EligibilityCriterion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolVersionLastApplicable rdf:type rdf:Property ;
    rdfs:label 'Protocol Version Last Applicable' ;
    rdfs:comment 'The protocol version number in which this criterion was last applicable before being superseded or retired. Null if the criterion is still active in the current protocol version.' ;
    rdfs:domain ind:EligibilityCriterion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresSourceDocVerification rdf:type rdf:Property ;
    rdfs:label 'Requires Source Doc Verification' ;
    rdfs:comment 'Indicates whether Source Data Verification (SDV) is required for this criterion during monitoring visits. When True, the Clinical Research Associate (CRA) must verify the criterion assessment against source documents at the site.' ;
    rdfs:domain ind:EligibilityCriterion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:screeningGuidanceNotes rdf:type rdf:Property ;
    rdfs:label 'Screening Guidance Notes' ;
    rdfs:comment 'Operational guidance notes for site staff on how to assess and document this criterion during subject screening. May include clarifications, assessment methods, source document requirements, and common pitfalls. Sourced from the study\'s screening manual or site training materials.' ;
    rdfs:domain ind:EligibilityCriterion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmIeTestcd rdf:type rdf:Property ;
    rdfs:label 'Sdtm Ie Testcd' ;
    rdfs:comment 'CDISC SDTM-compliant short code for the criterion, conforming to the IE domain IETESTCD variable. Maximum 8 uppercase alphanumeric characters. Used for regulatory submission datasets and CDISC compliance validation.' ;
    rdfs:domain ind:EligibilityCriterion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCriterionCode rdf:type rdf:Property ;
    rdfs:label 'Source System Criterion Code' ;
    rdfs:comment 'The native identifier of this criterion record in the originating operational system (e.g., Oracle Clinical One criterion object ID, Medidata Rave field OID). Enables reconciliation between the lakehouse Silver Layer and the source system.' ;
    rdfs:domain ind:EligibilityCriterion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeWindowUnit rdf:type rdf:Property ;
    rdfs:label 'Time Window Unit' ;
    rdfs:comment 'The unit of time for the time window associated with the criterion (e.g., DAYS, WEEKS, MONTHS, YEARS). Used for washout periods, prior therapy windows, and diagnosis recency requirements.' ;
    rdfs:domain ind:EligibilityCriterion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeWindowValue rdf:type rdf:Property ;
    rdfs:label 'Time Window Value' ;
    rdfs:comment 'The numeric duration of the time window associated with the criterion (e.g., prior therapy washout period of 4 weeks, prior diagnosis within 6 months). Used in conjunction with time_window_unit.' ;
    rdfs:domain ind:EligibilityCriterion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverAllowed rdf:type rdf:Property ;
    rdfs:label 'Waiver Allowed' ;
    rdfs:comment 'Indicates whether a protocol deviation waiver or exception can be granted for this criterion on a per-subject basis. When True, a formal waiver request process is required and must be documented in the Trial Master File (TMF).' ;
    rdfs:domain ind:EligibilityCriterion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverAuthority rdf:type rdf:Property ;
    rdfs:label 'Waiver Authority' ;
    rdfs:comment 'The body or role authorized to grant a waiver for this criterion (e.g., Medical Monitor, Sponsor Medical Director, IRB/IEC). Applicable only when waiver_allowed is True.' ;
    rdfs:domain ind:EligibilityCriterion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impTmfDocumentId rdf:type rdf:Property ;
    rdfs:label 'Imp Tmf Document Id' ;
    rdfs:comment 'Foreign key linking to document.tmf_document. Business justification: The Investigational Medicinal Product Dossier (IMPD) / Investigator\'s Brochure is a DIA TMF Zone 4 essential document. IP management teams and regulatory affairs must locate the current IMPD/IB TMF do' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TmfDocument .

ind:activeSubstance rdf:type rdf:Property ;
    rdfs:label 'Active Substance' ;
    rdfs:comment 'Name of the active pharmaceutical ingredient (API) or active substance in the investigational product. May differ from the INN for novel compounds. Used in IMPD/IND CMC sections, pharmacovigilance, and SDTM datasets.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casNumber rdf:type rdf:Property ;
    rdfs:label 'Cas Number' ;
    rdfs:comment 'Chemical Abstracts Service (CAS) Registry Number uniquely identifying the active substance chemical structure. Used in regulatory submissions, safety data sheets, and cross-referencing with pharmacological databases.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlledSubstanceSchedule rdf:type rdf:Property ;
    rdfs:label 'Controlled Substance Schedule' ;
    rdfs:comment 'DEA controlled substance schedule classification for the investigational product (e.g., Schedule II, Schedule IV) or \'not_controlled\' if not a controlled substance. Drives regulatory compliance requirements for storage, dispensing, and accountability at investigational sites.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emaProductNumber rdf:type rdf:Property ;
    rdfs:label 'Ema Product Number' ;
    rdfs:comment 'EMA-assigned product number for the investigational product as registered in the EU Clinical Trials Information System (CTIS) or EudraCT. Required for EU regulatory submissions and EU CTR 536/2014 compliance.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulation rdf:type rdf:Property ;
    rdfs:label 'Formulation' ;
    rdfs:comment 'Qualitative description of the investigational product formulation including excipients, vehicle, and any special formulation characteristics (e.g., \'immediate-release tablet with microcrystalline cellulose\', \'sterile aqueous solution pH 7.4\'). Captured in the IMPD/IND CMC section.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impCode rdf:type rdf:Property ;
    rdfs:label 'Imp Code' ;
    rdfs:comment 'Sponsor-assigned internal drug or device code uniquely identifying the investigational product across all studies (e.g., ABC-1234). Serves as the externally-known business identifier referenced in protocols, supply chain, and regulatory submissions. Maps to the drug code field in Medidata Rave RTSM and Oracle Clinical One.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impdVersion rdf:type rdf:Property ;
    rdfs:label 'Impd Version' ;
    rdfs:comment 'Version number of the current Investigational Medicinal Product Dossier (IMPD) or IND on file with the regulatory authority for this product. Tracked in Veeva Vault for regulatory submission management and amendment history.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationalProductDescription rdf:type rdf:Property ;
    rdfs:label 'Investigational Product Description' ;
    rdfs:comment 'Free-text narrative description of the investigational product including its therapeutic purpose, background, and any additional context not captured in structured fields. Used in protocol background sections and regulatory submissions.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationalProductStatus rdf:type rdf:Property ;
    rdfs:label 'Investigational Product Status' ;
    rdfs:comment 'Current lifecycle status of the investigational product master record (e.g., active for ongoing studies, discontinued if development halted, superseded if replaced by a new formulation). Drives supply chain and regulatory workflow decisions.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isComparator rdf:type rdf:Property ;
    rdfs:label 'Is Comparator' ;
    rdfs:comment 'Indicates whether this product record represents a comparator (active control or placebo) rather than the primary investigational product (True = comparator). Enables differentiation of IMP vs. comparator in supply chain, SDTM, and safety reporting.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPlacebo rdf:type rdf:Property ;
    rdfs:label 'Is Placebo' ;
    rdfs:comment 'Indicates whether this product record represents a placebo (True) rather than an active investigational product or comparator. Used in RTSM randomization configuration, supply chain, and SDTM EX domain coding.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Name of the pharmaceutical manufacturer or contract manufacturing organization (CMO) responsible for producing the investigational product. Referenced in the IMPD/IND CMC section and supply chain records in SAP S/4HANA.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerSite rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Site' ;
    rdfs:comment 'Physical site or facility name and location where the investigational product is manufactured. Required for regulatory submissions (IND/IMPD) and GMP compliance tracking. Distinct from the manufacturer legal entity name.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndcNumber rdf:type rdf:Property ;
    rdfs:label 'Ndc Number' ;
    rdfs:comment 'FDA-assigned National Drug Code (NDC) number for the investigational product, if applicable. Used for US regulatory submissions, pharmacy dispensing records, and drug accountability tracking. May be absent for novel compounds not yet assigned an NDC.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingDescription rdf:type rdf:Property ;
    rdfs:label 'Packaging Description' ;
    rdfs:comment 'Description of the primary and secondary packaging configuration for the investigational product (e.g., \'blister pack of 10 tablets in a carton\', \'single-use vial 10 mL in a kit\'). Referenced in supply chain, pharmacy, and RTSM kit configuration.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Status' ;
    rdfs:comment 'Current regulatory approval status of the investigational product (e.g., approved for a different indication, purely investigational, withdrawn from market). Informs regulatory strategy, labeling requirements, and comparator sourcing decisions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Retest Period Months' ;
    rdfs:comment 'Period in months after which the investigational product must be retested before continued use, applicable to active pharmaceutical ingredients (APIs) and certain formulations. Distinct from shelf life; used in supply chain and QC planning.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shelfLifeMonths rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Months' ;
    rdfs:comment 'Approved shelf life of the investigational product in months from the date of manufacture, as established by stability studies and documented in the IMPD/IND. Drives expiry date calculation, supply planning, and resupply triggers in Medidata Rave RTSM.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sponsorProductCode rdf:type rdf:Property ;
    rdfs:label 'Sponsor Product Code' ;
    rdfs:comment 'Sponsor\'s internal product or compound code used in portfolio management systems, distinct from the IMP code used in clinical operations. Enables cross-referencing between clinical development and commercial product pipelines.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strengthUnit rdf:type rdf:Property ;
    rdfs:label 'Strength Unit' ;
    rdfs:comment 'Unit of measure for the investigational product strength (e.g., mg, mg/mL, IU). Standardized per CDISC controlled terminology to enable cross-study comparisons and SDTM dataset generation. [ENUM-REF-CANDIDATE: mg|mg/mL|mg/kg|mcg|mcg/mL|IU|IU/mL|g|% — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticClass rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Class' ;
    rdfs:comment 'Therapeutic or pharmacological class of the investigational product (e.g., oncology, cardiovascular, CNS, anti-infective). Used for portfolio analytics, regulatory strategy, and study feasibility assessments.' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitOfDispensing rdf:type rdf:Property ;
    rdfs:label 'Unit Of Dispensing' ;
    rdfs:comment 'The unit in which the investigational product is dispensed to subjects at the investigational site (e.g., tablet, vial, kit, syringe). Used in RTSM dispensing records, drug accountability logs, and SDTM EX domain. [ENUM-REF-CANDIDATE: tablet|capsule|vial|kit|syringe|patch|sachet|bottle|ampoule — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InvestigationalProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupSampleVolumeMl rdf:type rdf:Property ;
    rdfs:label 'Backup Sample Volume Ml' ;
    rdfs:comment 'Additional volume of biological sample to be collected as a backup or reserve aliquot, expressed in millilitres (mL). Supports re-analysis and incurred sample reanalysis (ISR) requirements.' ;
    rdfs:domain ind:PkSamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleNumber rdf:type rdf:Property ;
    rdfs:label 'Cycle Number' ;
    rdfs:comment 'Treatment cycle number during which this PK/PD sample is collected, applicable for oncology and multi-cycle dosing studies. Null for single-dose or non-cyclic studies.' ;
    rdfs:domain ind:PkSamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dayInCycle rdf:type rdf:Property ;
    rdfs:label 'Day In Cycle' ;
    rdfs:comment 'Study day within the treatment cycle on which this PK/PD sample is to be collected. Used in conjunction with cycle_number for multi-cycle dosing regimens.' ;
    rdfs:domain ind:PkSamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxStorageDurationHours rdf:type rdf:Property ;
    rdfs:label 'Max Storage Duration Hours' ;
    rdfs:comment 'Maximum allowable duration in hours that the sample may be stored at the specified storage temperature before shipment to the bioanalytical laboratory. Derived from bench-top and freeze-thaw stability data.' ;
    rdfs:domain ind:PkSamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nominalTimepointLabel rdf:type rdf:Property ;
    rdfs:label 'Nominal Timepoint Label' ;
    rdfs:comment 'Descriptive label for the nominal PK sampling timepoint relative to dose administration (e.g., \'Pre-dose\', \'0.5h post-dose\', \'1h post-dose\', \'24h post-dose\'). Maps to CDISC SDTM PC.PCTPT.' ;
    rdfs:domain ind:PkSamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominalTimepointUnit rdf:type rdf:Property ;
    rdfs:label 'Nominal Timepoint Unit' ;
    rdfs:comment 'Unit of measure for the nominal timepoint value (e.g., hours, minutes, days). Maps to CDISC SDTM PC.PCTPTREF unit context.' ;
    rdfs:domain ind:PkSamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominalTimepointValue rdf:type rdf:Property ;
    rdfs:label 'Nominal Timepoint Value' ;
    rdfs:comment 'Numeric value of the nominal sampling timepoint relative to dose administration. Used for PK modeling and CDISC SDTM PC.PCTPTNUM mapping. Expressed in the unit defined by nominal_timepoint_unit.' ;
    rdfs:domain ind:PkSamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfAliquots rdf:type rdf:Property ;
    rdfs:label 'Number Of Aliquots' ;
    rdfs:comment 'Number of aliquots into which the collected sample must be divided for analysis, backup, and archival purposes. Drives sample labelling and supply requirements.' ;
    rdfs:domain ind:PkSamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optionalSample rdf:type rdf:Property ;
    rdfs:label 'Optional Sample' ;
    rdfs:comment 'Indicates whether collection of this sample is optional (e.g., exploratory biomarker, sub-study) or mandatory per the study protocol. Affects protocol deviation assessment.' ;
    rdfs:domain ind:PkSamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preDoseSample rdf:type rdf:Property ;
    rdfs:label 'Pre Dose Sample' ;
    rdfs:comment 'Indicates whether this sampling timepoint is a pre-dose (trough) sample collected before drug administration. Used to assess baseline concentrations and trough levels.' ;
    rdfs:domain ind:PkSamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingInstructions rdf:type rdf:Property ;
    rdfs:label 'Processing Instructions' ;
    rdfs:comment 'Detailed instructions for processing the collected sample at the clinical site (e.g., centrifugation speed, time, temperature, aliquoting steps). Ensures sample integrity per bioanalytical method requirements.' ;
    rdfs:domain ind:PkSamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredSampleVolumeMl rdf:type rdf:Property ;
    rdfs:label 'Required Sample Volume Ml' ;
    rdfs:comment 'Volume of biological sample required for bioanalytical analysis, expressed in millilitres (mL). Used for supply planning, patient burden assessment, and protocol feasibility.' ;
    rdfs:domain ind:PkSamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:samplingCategory rdf:type rdf:Property ;
    rdfs:label 'Sampling Category' ;
    rdfs:comment 'Classification of the sampling purpose: Pharmacokinetic (PK), Pharmacodynamic (PD), combined PK/PD, biomarker, immunogenicity, or safety assessment. Drives CDISC domain assignment (PC for PK, PP for PD).' ;
    rdfs:domain ind:PkSamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleCode rdf:type rdf:Property ;
    rdfs:label 'Schedule Code' ;
    rdfs:comment 'Unique alphanumeric code identifying this PK/PD sampling schedule entry within the study protocol. Used as the externally-known business identifier in CTMS and EDC systems such as Medidata Rave.' ;
    rdfs:domain ind:PkSamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Human-readable name or label for this sampling schedule entry (e.g., \'Pre-dose Day 1\', \'2h Post-dose Cycle 2\'). Used in protocol documents and EDC eCRF annotations.' ;
    rdfs:domain ind:PkSamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmPctptnum rdf:type rdf:Property ;
    rdfs:label 'Sdtm Pctptnum' ;
    rdfs:comment 'Numeric representation of the planned timepoint as defined in CDISC SDTM PC.PCTPTNUM. Used for sorting and PK modeling in SAS Drug Development and ADaM datasets.' ;
    rdfs:domain ind:PkSamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sparseSampling rdf:type rdf:Property ;
    rdfs:label 'Sparse Sampling' ;
    rdfs:comment 'Indicates whether this timepoint is part of a sparse (population PK) sampling design rather than a full intensive PK profile. Drives population PK modeling strategy.' ;
    rdfs:domain ind:PkSamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:steadyStateSample rdf:type rdf:Property ;
    rdfs:label 'Steady State Sample' ;
    rdfs:comment 'Indicates whether this sampling timepoint is intended to characterize drug concentrations at pharmacokinetic steady state. Relevant for multiple-dose PK studies.' ;
    rdfs:domain ind:PkSamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timepointReference rdf:type rdf:Property ;
    rdfs:label 'Timepoint Reference' ;
    rdfs:comment 'The reference event from which the nominal timepoint is measured (e.g., first dose, previous dose, start of infusion, end of infusion). Maps to CDISC SDTM PC.PCTPTREF.' ;
    rdfs:domain ind:PkSamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowLowerBound rdf:type rdf:Property ;
    rdfs:label 'Window Lower Bound' ;
    rdfs:comment 'Allowable lower deviation from the nominal timepoint for sample collection (expressed as a negative or zero offset in the same unit as nominal_timepoint_unit). Defines the acceptable collection window per protocol.' ;
    rdfs:domain ind:PkSamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:windowUnit rdf:type rdf:Property ;
    rdfs:label 'Window Unit' ;
    rdfs:comment 'Unit of measure for the sampling window lower and upper bounds (e.g., minutes, hours, days).' ;
    rdfs:domain ind:PkSamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowUpperBound rdf:type rdf:Property ;
    rdfs:label 'Window Upper Bound' ;
    rdfs:comment 'Allowable upper deviation from the nominal timepoint for sample collection (expressed as a positive offset in the same unit as nominal_timepoint_unit). Defines the acceptable collection window per protocol.' ;
    rdfs:domain ind:PkSamplingSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Method by which participants are assigned to study arms. \'Randomized\' indicates use of RTSM/IRT for random assignment; \'non-randomized\' indicates assignment by investigator or other non-random method. Drives RTSM configuration in Medidata Rave and Oracle Clinical One.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gcpComplianceDeclaration rdf:type rdf:Property ;
    rdfs:label 'Gcp Compliance Declaration' ;
    rdfs:comment 'Indicates whether the protocol includes a formal declaration of compliance with ICH E6(R2) Good Clinical Practice (GCP) guidelines and applicable regulatory requirements. Required for all interventional clinical trials. Tracked in Veeva Vault.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ichComplianceDeclaration rdf:type rdf:Property ;
    rdfs:label 'Ich Compliance Declaration' ;
    rdfs:comment 'Indicates whether the protocol formally declares compliance with applicable ICH guidelines (E6, E8, E9, E10, etc.). Distinct from GCP declaration; covers the broader ICH guideline framework including statistical and design standards.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interventionModel rdf:type rdf:Property ;
    rdfs:label 'Intervention Model' ;
    rdfs:comment 'Describes the strategy for assigning interventions to participants. Determines the statistical analysis plan (SAP) structure, number of arms, and eCRF design in Medidata Rave. Aligns with CDISC SDTM ARM domain.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdaptiveDesign rdf:type rdf:Property ;
    rdfs:label 'Is Adaptive Design' ;
    rdfs:comment 'Indicates whether the study employs an adaptive design allowing pre-specified modifications to the trial or statistical procedures based on interim data analysis. Triggers additional regulatory review requirements and DSMB/DMC oversight obligations.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maskingType rdf:type rdf:Property ;
    rdfs:label 'Masking Type' ;
    rdfs:comment 'Level of blinding applied to the study to minimize bias. Specifies which parties (participant, investigator, outcomes assessor, data analyst) are blinded to treatment assignment. Critical for RTSM/IRT configuration and unblinding procedures.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Months' ;
    rdfs:comment 'Total planned duration of the study in months from first subject first visit (FSFV) to last subject last visit (LSLV) or database lock (DBL), as specified in the protocol. Used for timeline planning, resource forecasting, and milestone tracking in Oracle Siebel CTMS.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryEndpoint rdf:type rdf:Property ;
    rdfs:label 'Primary Endpoint' ;
    rdfs:comment 'The principal outcome measure used to evaluate the primary objective of the study. Defines the variable, measurement method, timepoint, and population. Drives eCRF design in Medidata Rave and the Statistical Analysis Plan (SAP).' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryObjective rdf:type rdf:Property ;
    rdfs:label 'Primary Objective' ;
    rdfs:comment 'Formal statement of the primary scientific objective of the study as defined in the protocol. Describes the main question the study is designed to answer. Directly linked to the primary endpoint and powers the sample size calculation.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPurpose rdf:type rdf:Property ;
    rdfs:label 'Primary Purpose' ;
    rdfs:comment 'The primary reason for conducting the clinical study. Determines regulatory pathway, endpoint requirements, and IRB/IEC review criteria. [ENUM-REF-CANDIDATE: treatment|prevention|diagnostic|supportive_care|screening|health_services_research|basic_science|device_feasibility — promote to reference product]' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolStatus rdf:type rdf:Property ;
    rdfs:label 'Protocol Status' ;
    rdfs:comment 'Current lifecycle state of the protocol version. \'draft\' indicates under development; \'approved\' indicates IRB/IEC and sponsor approval obtained; \'amended\' indicates a formal amendment is in effect; \'superseded\' indicates replaced by a newer version; \'final\' indicates study completed and protocol finalized; \'retired\' indicates withdrawn. Sourced from Veeva Vault quality management workflow.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registryIdentifier rdf:type rdf:Property ;
    rdfs:label 'Registry Identifier' ;
    rdfs:comment 'Public clinical trial registry identifier such as ClinicalTrials.gov NCT number (e.g., NCT12345678) or WHO ICTRP identifier. Required by ICMJE for publication eligibility and by FDA/EMA for transparency. Sourced from Oracle Siebel CTMS.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Status' ;
    rdfs:comment 'Status of the regulatory authority submission for this protocol version or amendment (e.g., IND amendment to FDA, CTA variation to EMA/MHRA). Tracks compliance with regulatory notification and approval requirements. Sourced from Veeva Vault regulatory submissions module.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryObjectives rdf:type rdf:Property ;
    rdfs:label 'Secondary Objectives' ;
    rdfs:comment 'Summary of secondary scientific objectives of the study as defined in the protocol. Describes additional questions the study is designed to address beyond the primary objective. Linked to secondary endpoints in the SAP.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortTitle rdf:type rdf:Property ;
    rdfs:label 'Short Title' ;
    rdfs:comment 'Abbreviated or lay-language title of the clinical study used in operational communications, CTMS displays, patient-facing materials, and internal reporting. Distinct from the full regulatory title.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemIdentifier rdf:type rdf:Property ;
    rdfs:label 'Source System Identifier' ;
    rdfs:comment 'Native record identifier from the originating operational system (Oracle Clinical One study ID or Veeva Vault document ID). Enables bidirectional traceability between the lakehouse silver layer and the system of record for audit and reconciliation purposes.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyPopulationDescription rdf:type rdf:Property ;
    rdfs:label 'Study Population Description' ;
    rdfs:comment 'Narrative description of the target patient population for the study, including disease characteristics, demographic parameters, and key eligibility criteria summary. Used in IRB/IEC submissions, regulatory filings, and patient recruitment materials.' ;
    rdfs:domain ind:Protocol ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adaptiveDesignFlag rdf:type rdf:Property ;
    rdfs:label 'Adaptive Design Flag' ;
    rdfs:comment 'Indicates whether this arm is part of an adaptive trial design where arm allocation, sample size, or continuation may be modified based on interim analysis results per a pre-specified adaptation rule.' ;
    rdfs:domain ind:Arm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:armCode rdf:type rdf:Property ;
    rdfs:label 'Arm Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the arm within the study. Maps directly to the ARMCD variable in the CDISC SDTM ARM domain and is used in randomization and data tabulation.' ;
    rdfs:domain ind:Arm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:armName rdf:type rdf:Property ;
    rdfs:label 'Arm Name' ;
    rdfs:comment 'Full descriptive name of the study arm as defined in the protocol (e.g., \'Drug A 10mg QD\', \'Placebo\'). Maps to the ARM variable in the CDISC SDTM ARM domain.' ;
    rdfs:domain ind:Arm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalOneArmCode rdf:type rdf:Property ;
    rdfs:label 'Clinical One Arm Code' ;
    rdfs:comment 'The native arm identifier assigned by Oracle Clinical One (the source system of record for study design and patient randomization). Used for system-of-record traceability and data lineage from source to lakehouse.' ;
    rdfs:domain ind:Arm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsArmReference rdf:type rdf:Property ;
    rdfs:label 'Ctms Arm Reference' ;
    rdfs:comment 'The arm reference identifier as recorded in Oracle Siebel CTMS for site monitoring, visit tracking, and enrollment management. Supports cross-system reconciliation.' ;
    rdfs:domain ind:Arm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doseDescription rdf:type rdf:Property ;
    rdfs:label 'Dose Description' ;
    rdfs:comment 'Textual description of the dose level and regimen for the investigational product in this arm (e.g., \'10 mg once daily\', \'200 mg BID\'). Supports dose-response analysis and protocol compliance monitoring.' ;
    rdfs:domain ind:Arm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interventionDescription rdf:type rdf:Property ;
    rdfs:label 'Intervention Description' ;
    rdfs:comment 'Detailed narrative description of the intervention assigned to subjects in this arm, including drug name, dose, route of administration, and dosing schedule as specified in the study protocol.' ;
    rdfs:domain ind:Arm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interventionType rdf:type rdf:Property ;
    rdfs:label 'Intervention Type' ;
    rdfs:comment 'Category of the therapeutic intervention assigned to subjects in this arm. Aligns with ClinicalTrials.gov intervention type classifications and supports regulatory submission categorization. [ENUM-REF-CANDIDATE: Drug|Biologic|Device|Procedure|Behavioral|Dietary Supplement|Radiation|Genetic|Combination|Other — promote to reference product]' ;
    rdfs:domain ind:Arm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ittPopulationFlag rdf:type rdf:Property ;
    rdfs:label 'Itt Population Flag' ;
    rdfs:comment 'Indicates whether subjects enrolled in this arm are included in the Intent-to-Treat (ITT) analysis population as defined in the Statistical Analysis Plan (SAP).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxSubjectsCount rdf:type rdf:Property ;
    rdfs:label 'Max Subjects Count' ;
    rdfs:comment 'The maximum allowable number of subjects that may be enrolled in this arm, including any over-enrollment buffer defined in the protocol. Distinct from planned_subjects_count which reflects the statistical target.' ;
    rdfs:domain ind:Arm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minSubjectsCount rdf:type rdf:Property ;
    rdfs:label 'Min Subjects Count' ;
    rdfs:comment 'The minimum number of subjects required in this arm to maintain statistical validity of the study, as defined in the SAP. Used for futility analysis and early stopping rule evaluation.' ;
    rdfs:domain ind:Arm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedSubjectsCount rdf:type rdf:Property ;
    rdfs:label 'Planned Subjects Count' ;
    rdfs:comment 'The planned (target) number of subjects to be enrolled and randomized into this arm as specified in the study protocol and statistical analysis plan (SAP).' ;
    rdfs:domain ind:Arm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ppPopulationFlag rdf:type rdf:Property ;
    rdfs:label 'Pp Population Flag' ;
    rdfs:comment 'Indicates whether subjects enrolled in this arm are included in the Per Protocol (PP) analysis population as defined in the Statistical Analysis Plan (SAP). Subjects with major protocol deviations may be excluded.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:protocolVersionRef rdf:type rdf:Property ;
    rdfs:label 'Protocol Version Ref' ;
    rdfs:comment 'The version identifier of the study protocol or protocol amendment under which this arm was defined or last modified. Ensures traceability of arm design to the governing protocol document.' ;
    rdfs:domain ind:Arm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:randomizationRatioNumeric rdf:type rdf:Property ;
    rdfs:label 'Randomization Ratio Numeric' ;
    rdfs:comment 'Numeric representation of the allocation weight for this arm relative to total allocation (e.g., 0.50 for a 1:1 ratio arm). Supports quantitative analysis and reporting of enrollment balance.' ;
    rdfs:domain ind:Arm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyPopulationFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Population Flag' ;
    rdfs:comment 'Indicates whether subjects enrolled in this arm are included in the safety analysis population (all subjects who received at least one dose of study treatment), as defined in the SAP.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdtmArmDomain rdf:type rdf:Property ;
    rdfs:label 'Sdtm Arm Domain' ;
    rdfs:comment 'CDISC SDTM domain identifier confirming this arm maps to the ARM domain in the SDTM submission dataset. Always \'ARM\' per CDISC standard; included for regulatory submission traceability.' ;
    rdfs:domain ind:Arm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentDurationDays rdf:type rdf:Property ;
    rdfs:label 'Treatment Duration Days' ;
    rdfs:comment 'Planned duration of treatment for subjects in this arm, expressed in days. Used for supply planning, visit schedule design, and protocol compliance monitoring.' ;
    rdfs:domain ind:Arm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ctaRegulatoryBinderId rdf:type rdf:Property ;
    rdfs:label 'Cta Regulatory Binder Id' ;
    rdfs:comment 'Foreign key linking to document.regulatory_binder. Business justification: Each country\'s CTA submission (tracked via cta_submission_date, cta_approval_date on study_country) is filed in a country-specific regulatory binder. Country regulatory leads need direct traceability ' ;
    rdfs:domain ind:Country ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryBinder .

ind:activatedSiteCount rdf:type rdf:Property ;
    rdfs:label 'Activated Site Count' ;
    rdfs:comment 'Actual number of investigative sites that have been activated and authorized to enroll subjects in this country. Compared against planned_site_count for country-level site activation KPI reporting.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'Total approved budget allocated for all study activities in this country, expressed in the country\'s local currency (see currency_code). Sourced from SAP S/4HANA project accounting and used for country-level financial performance tracking.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countryName rdf:type rdf:Property ;
    rdfs:label 'Country Name' ;
    rdfs:comment 'Full English name of the country as defined by ISO 3166-1 (e.g., United States, Germany, Japan). Used for display in regulatory submissions, reports, and dashboards.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctaApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Cta Approval Date' ;
    rdfs:comment 'Date on which the regulatory authority granted approval for the clinical trial to proceed in this country. Milestone used for site activation planning and regulatory timeline KPI reporting.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ctaApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Cta Approval Status' ;
    rdfs:comment 'Current approval status of the CTA or IND application with the national regulatory authority. Drives regulatory hold flags and country activation readiness assessments.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctaSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Cta Submission Date' ;
    rdfs:comment 'Date on which the Clinical Trial Authorization (CTA) or Investigational New Drug (IND) application was submitted to the national regulatory authority for this country. Tracked in Veeva Vault for regulatory timeline management.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dropoutRateAssumption rdf:type rdf:Property ;
    rdfs:label 'Dropout Rate Assumption' ;
    rdfs:comment 'Assumed proportion of enrolled subjects expected to withdraw or be lost to follow-up in this country, expressed as a decimal (e.g., 0.1000 = 10%). Used in sample size and enrollment buffer calculations.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentClosureDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Closure Date' ;
    rdfs:comment 'Date on which enrollment was formally closed in this country, either due to target achievement, regulatory hold, or study termination. Distinct from last_subject_enrolled_date as it reflects the administrative closure decision.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current enrollment lifecycle status for this country within the study. Drives enrollment forecasting, site activation planning, and country-level feasibility reporting in Oracle Siebel CTMS and Medidata Rave.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feasibilityAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Feasibility Assessment Date' ;
    rdfs:comment 'Date on which the country-level feasibility assessment was completed and the feasibility_score was assigned. Used to track the currency of feasibility data for enrollment planning.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstSiteActivationDate rdf:type rdf:Property ;
    rdfs:label 'First Site Activation Date' ;
    rdfs:comment 'Date on which the first investigative site in this country was activated and authorized to enroll subjects. Key milestone for country-level startup timeline KPI reporting in Oracle Siebel CTMS.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstSubjectEnrolledDate rdf:type rdf:Property ;
    rdfs:label 'First Subject Enrolled Date' ;
    rdfs:comment 'Date on which the first subject was enrolled (consented and randomized or screened) at any site within this country. Marks the start of active enrollment for country-level timeline tracking.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:icfVersionRequired rdf:type rdf:Property ;
    rdfs:label 'Icf Version Required' ;
    rdfs:comment 'Version identifier of the Informed Consent Form (ICF) approved by the national IRB/IEC and regulatory authority for use in this country. Ensures sites use the correct country-specific ICF version as tracked in Clinpal and Veeva Vault.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSubjectEnrolledDate rdf:type rdf:Property ;
    rdfs:label 'Last Subject Enrolled Date' ;
    rdfs:comment 'Date on which the last subject was enrolled in this country. Used to calculate country-level enrollment duration and to trigger enrollment completion milestones.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:localLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Local Language Code' ;
    rdfs:comment 'Primary local language code for the country using IETF BCP 47 format (e.g., de-DE, ja-JP, fr-FR). Drives Informed Consent Form (ICF) translation requirements and eCRF localization in Clinpal and Medidata Rave.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localRegulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Local Regulatory Reference Number' ;
    rdfs:comment 'Country-specific regulatory reference or dossier number assigned by the national competent authority upon CTA/IND submission or approval (e.g., EudraCT number for EU, IND number for US, CTN for Australia). Stored in Veeva Vault.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalRegistryNumber rdf:type rdf:Property ;
    rdfs:label 'National Registry Number' ;
    rdfs:comment 'Country-specific clinical trial registry number assigned by the national registry (e.g., ISRCTN, UMIN for Japan, CTRI for India). Distinct from EudraCT and ClinicalTrials.gov identifiers. Required for WHO ICTRP compliance.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedScreenCount rdf:type rdf:Property ;
    rdfs:label 'Planned Screen Count' ;
    rdfs:comment 'Planned number of subjects to be screened in this country, derived from the planned enrollment target and the assumed screen failure rate. Used for site capacity planning and patient recruitment forecasting.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Flag' ;
    rdfs:comment 'Indicates whether a regulatory hold (e.g., FDA Clinical Hold under 21 CFR 312.42, or equivalent national authority hold) is currently in effect for this country, preventing or suspending subject enrollment.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryHoldLiftDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Lift Date' ;
    rdfs:comment 'Date on which the regulatory hold was lifted by the national authority, allowing enrollment to resume. Null if the hold is still in effect.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryHoldReason rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Reason' ;
    rdfs:comment 'Narrative description of the reason for the regulatory hold in this country, as communicated by the national regulatory authority. Populated only when regulatory_hold_flag is True.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryHoldStartDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold Start Date' ;
    rdfs:comment 'Date on which the regulatory hold was imposed by the national authority in this country. Used for regulatory timeline impact analysis and sponsor reporting.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:screenFailureRateAssumption rdf:type rdf:Property ;
    rdfs:label 'Screen Failure Rate Assumption' ;
    rdfs:comment 'Assumed proportion of screened subjects expected to fail screening criteria in this country, expressed as a decimal (e.g., 0.3000 = 30%). Used in enrollment forecasting models to derive planned_screen_count from planned_enrollment_target.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subjectDataTransferAllowed rdf:type rdf:Property ;
    rdfs:label 'Subject Data Transfer Allowed' ;
    rdfs:comment 'Indicates whether subject-level clinical data collected in this country may be transferred cross-border to the sponsor or CRO data systems under applicable data privacy regulations (e.g., GDPR Chapter V adequacy decisions, SCCs). Critical for EDC data flow configuration in Medidata Rave.' ;
    rdfs:domain ind:Country ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adamParameterName rdf:type rdf:Property ;
    rdfs:label 'Adam Parameter Name' ;
    rdfs:comment 'The CDISC ADaM PARAM value — the full descriptive label for the analysis parameter corresponding to this endpoint (e.g., \'Overall Survival Time (Days)\'). Displayed in analysis output tables and listings.' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentTimepoint rdf:type rdf:Property ;
    rdfs:label 'Assessment Timepoint' ;
    rdfs:comment 'The protocol-defined timepoint or window at which the endpoint is assessed (e.g., \'Week 24\', \'End of Treatment\', \'Month 6 ± 7 days\'). Directly maps to the visit schedule and SDTM VISITNUM.' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directionality rdf:type rdf:Property ;
    rdfs:label 'Directionality' ;
    rdfs:comment 'Specifies whether the statistical test for this endpoint is one-sided or two-sided. Determines the alpha allocation and critical value used in hypothesis testing.' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endpointCategory rdf:type rdf:Property ;
    rdfs:label 'Endpoint Category' ;
    rdfs:comment 'Scientific domain category of the endpoint: efficacy (treatment effect), safety (harm characterisation), tolerability, Pharmacokinetics/Pharmacodynamics (PK/PD), quality of life (patient-reported outcomes), or biomarker. [ENUM-REF-CANDIDATE: efficacy|safety|tolerability|PK_PD|quality_of_life|biomarker — promote to reference product]' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimandIntercurrentEventStrategy rdf:type rdf:Property ;
    rdfs:label 'Estimand Intercurrent Event Strategy' ;
    rdfs:comment 'The strategy for handling intercurrent events per ICH E9(R1): treatment_policy (ignore occurrence), hypothetical (counterfactual), composite (incorporate into outcome), while_on_treatment (restrict to on-treatment period), or principal_stratum (condition on intercurrent event status).' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimandPopulation rdf:type rdf:Property ;
    rdfs:label 'Estimand Population' ;
    rdfs:comment 'The target population component of the ICH E9(R1) estimand, specifying the patient population to which the treatment effect applies (e.g., \'all randomised patients with baseline HbA1c ≥ 7.5%\').' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimandPopulationLevelSummary rdf:type rdf:Property ;
    rdfs:label 'Estimand Population Level Summary' ;
    rdfs:comment 'The population-level summary measure component of the ICH E9(R1) estimand (e.g., \'difference in means\', \'hazard ratio\', \'odds ratio\'). Specifies how individual outcomes are aggregated to a treatment effect estimate.' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimandTreatmentCondition rdf:type rdf:Property ;
    rdfs:label 'Estimand Treatment Condition' ;
    rdfs:comment 'The treatment condition component of the ICH E9(R1) estimand framework, describing the treatment regimen of interest (e.g., \'randomised treatment regardless of adherence\', \'treatment as prescribed\').' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimandVariable rdf:type rdf:Property ;
    rdfs:label 'Estimand Variable' ;
    rdfs:comment 'The variable component of the ICH E9(R1) estimand, defining the outcome measure for each patient (e.g., \'change from baseline in HbA1c at Week 24\'). Directly corresponds to the ADaM analysis variable.' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementInstrument rdf:type rdf:Property ;
    rdfs:label 'Measurement Instrument' ;
    rdfs:comment 'The validated instrument, scale, or tool used to measure the endpoint (e.g., RECIST 1.1, HAMD-17, SF-36, CTCAE v5.0, EORTC QLQ-C30). Required for regulatory submission and biostatistical analysis planning.' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiplicityAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Multiplicity Adjustment Flag' ;
    rdfs:comment 'Indicates whether a multiplicity adjustment (e.g., Bonferroni, Holm, Hochberg, gatekeeping procedure) is applied to this endpoint to control the family-wise error rate. Critical for confirmatory trial design and regulatory acceptance.' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:multiplicityProcedure rdf:type rdf:Property ;
    rdfs:label 'Multiplicity Procedure' ;
    rdfs:comment 'The specific statistical procedure used for multiplicity adjustment for this endpoint (e.g., \'Hochberg step-up\', \'Bonferroni\', \'Fixed-sequence testing\', \'Graphical gatekeeping\'). Populated only when multiplicity_adjustment_flag is True.' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objectiveId rdf:type rdf:Property ;
    rdfs:label 'Objective Id' ;
    rdfs:comment 'Reference to the study objective that this endpoint operationalises, enabling objective-to-endpoint traceability required by the Statistical Analysis Plan (SAP).' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:objectiveType rdf:type rdf:Property ;
    rdfs:label 'Objective Type' ;
    rdfs:comment 'Classification of the study objective associated with this endpoint: primary (confirmatory), secondary (supportive), exploratory (hypothesis-generating), or safety (adverse event characterisation).' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemEndpointCode rdf:type rdf:Property ;
    rdfs:label 'Source System Endpoint Code' ;
    rdfs:comment 'The native identifier of this endpoint record in the originating operational system (e.g., Oracle Clinical One endpoint object ID, SAS Drug Development analysis parameter ID). Enables cross-system reconciliation and ETL lineage.' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalHypothesis rdf:type rdf:Property ;
    rdfs:label 'Statistical Hypothesis' ;
    rdfs:comment 'The formal statistical hypothesis framework applied to this endpoint: superiority (treatment better than control), non-inferiority (treatment not worse by a defined margin), equivalence (treatment within a symmetric margin), or descriptive (no formal hypothesis). Drives SAP design.' ;
    rdfs:domain ind:Endpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aeReportingApplicable rdf:type rdf:Property ;
    rdfs:label 'Ae Reporting Applicable' ;
    rdfs:comment 'Indicates whether adverse event (AE) and serious adverse event (SAE) collection and reporting obligations are active during this epoch. Drives safety data collection rules in the EDC and Oracle Argus Safety.' ;
    rdfs:domain ind:Epoch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epochDescription rdf:type rdf:Property ;
    rdfs:label 'Epoch Description' ;
    rdfs:comment 'Detailed narrative description of the epoch\'s purpose, activities, and clinical objectives as specified in the study protocol. Provides context for data reviewers and regulatory submissions.' ;
    rdfs:domain ind:Epoch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epochName rdf:type rdf:Property ;
    rdfs:label 'Epoch Name' ;
    rdfs:comment 'Full descriptive name of the study epoch as defined in the protocol (e.g., \'Screening\', \'Run-in\', \'Treatment Period 1\', \'Washout\', \'Follow-up\', \'Extension\'). Maps to CDISC SDTM TE.EPOCH variable.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epochStatus rdf:type rdf:Property ;
    rdfs:label 'Epoch Status' ;
    rdfs:comment 'Current lifecycle status of the epoch definition within the study protocol. DRAFT indicates under development; ACTIVE indicates approved and in use; AMENDED indicates modified by protocol amendment; SUPERSEDED indicates replaced by a newer version; RETIRED indicates no longer applicable.' ;
    rdfs:domain ind:Epoch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epochType rdf:type rdf:Property ;
    rdfs:label 'Epoch Type' ;
    rdfs:comment 'Controlled vocabulary classification of the epoch\'s functional purpose within the study design. Drives SDTM dataset construction and subject disposition analysis. [ENUM-REF-CANDIDATE: SCREENING|RUN-IN|TREATMENT|WASHOUT|FOLLOW-UP|EXTENSION|BASELINE|OPEN-LABEL|DOUBLE-BLIND|SINGLE-BLIND|PLACEBO|OBSERVATION — promote to reference product]' ;
    rdfs:domain ind:Epoch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionEpoch rdf:type rdf:Property ;
    rdfs:label 'Extension Epoch' ;
    rdfs:comment 'Indicates whether this epoch is an optional or mandatory study extension period beyond the core treatment phase. Extension epochs may have separate regulatory approval requirements.' ;
    rdfs:domain ind:Epoch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpEpoch rdf:type rdf:Property ;
    rdfs:label 'Follow Up Epoch' ;
    rdfs:comment 'Indicates whether this epoch is a post-treatment follow-up period for safety monitoring and long-term outcome assessment. Drives safety reporting timelines and subject disposition coding.' ;
    rdfs:domain ind:Epoch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipAdministered rdf:type rdf:Property ;
    rdfs:label 'Ip Administered' ;
    rdfs:comment 'Indicates whether investigational product (IP) is administered to subjects during this epoch. Drives IP accountability tracking, supply chain planning, and SDTM exposure domain (EX) linkage.' ;
    rdfs:domain ind:Epoch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDeleted rdf:type rdf:Property ;
    rdfs:label 'Is Deleted' ;
    rdfs:comment 'Indicates whether this epoch record has been logically deleted (soft delete). True = record is logically deleted and should be excluded from active queries; False = record is active. Supports data retention compliance without physical deletion.' ;
    rdfs:domain ind:Epoch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ittPopulationEpoch rdf:type rdf:Property ;
    rdfs:label 'Itt Population Epoch' ;
    rdfs:comment 'Indicates whether subject participation in this epoch contributes to Intent-to-Treat (ITT) population eligibility determination. Used in biostatistical analysis and SAP population definitions.' ;
    rdfs:domain ind:Epoch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumDurationDays rdf:type rdf:Property ;
    rdfs:label 'Maximum Duration Days' ;
    rdfs:comment 'Protocol-specified maximum number of days a subject may remain in this epoch before mandatory transition or discontinuation. Enforced by CTMS and EDC visit scheduling logic.' ;
    rdfs:domain ind:Epoch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumDurationDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Duration Days' ;
    rdfs:comment 'Protocol-specified minimum number of days a subject must remain in this epoch to be considered evaluable. Used for per-protocol (PP) population eligibility determination.' ;
    rdfs:domain ind:Epoch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedDurationIso rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Iso' ;
    rdfs:comment 'Protocol-specified planned duration of the epoch expressed in ISO 8601 duration format (e.g., \'P28D\', \'P4W\', \'P6M\'). This is the authoritative CDISC SDTM TE.TEDUR value used for regulatory submissions.' ;
    rdfs:domain ind:Epoch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndDay rdf:type rdf:Property ;
    rdfs:label 'Planned End Day' ;
    rdfs:comment 'Protocol-defined study day on which this epoch is planned to end, relative to the study reference start date. Used for visit schedule construction and subject timeline alignment.' ;
    rdfs:domain ind:Epoch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedStartDay rdf:type rdf:Property ;
    rdfs:label 'Planned Start Day' ;
    rdfs:comment 'Protocol-defined study day on which this epoch is planned to begin, relative to the study reference start date (Day 1). Used for visit schedule construction and subject timeline alignment.' ;
    rdfs:domain ind:Epoch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryEndpointEpoch rdf:type rdf:Property ;
    rdfs:label 'Primary Endpoint Epoch' ;
    rdfs:comment 'Indicates whether the primary efficacy endpoint assessments are collected during this epoch. Used in statistical analysis plan (SAP) to define the primary analysis window.' ;
    rdfs:domain ind:Epoch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:randomizationApplicable rdf:type rdf:Property ;
    rdfs:label 'Randomization Applicable' ;
    rdfs:comment 'Indicates whether subject randomization occurs during this epoch. True = randomization event occurs within this epoch (e.g., Treatment Period 1 start); False = no randomization in this epoch.' ;
    rdfs:domain ind:Epoch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdtmEpochCode rdf:type rdf:Property ;
    rdfs:label 'Sdtm Epoch Code' ;
    rdfs:comment 'CDISC SDTM controlled terminology code for the epoch as submitted in the Trial Elements (TE) domain ETCD variable. Must conform to CDISC CT epoch codelist (C99079). Used for regulatory submission dataset construction.' ;
    rdfs:domain ind:Epoch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmTeDomainFlag rdf:type rdf:Property ;
    rdfs:label 'Sdtm Te Domain Flag' ;
    rdfs:comment 'Indicates whether this epoch record is mapped and included in the CDISC SDTM Trial Elements (TE) domain for regulatory submission. True = included in TE domain; False = excluded (e.g., internal planning epoch not submitted).' ;
    rdfs:domain ind:Epoch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemEpochCode rdf:type rdf:Property ;
    rdfs:label 'Source System Epoch Code' ;
    rdfs:comment 'Native identifier for this epoch as recorded in the originating operational system (e.g., Oracle Clinical One study design module or Medidata Rave EDC). Enables lineage tracing and reconciliation between the lakehouse and source systems.' ;
    rdfs:domain ind:Epoch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemName rdf:type rdf:Property ;
    rdfs:label 'Source System Name' ;
    rdfs:comment 'Name of the operational system of record from which this epoch definition was sourced (e.g., Oracle Clinical One, Medidata Rave). Supports data lineage and audit trail requirements under 21 CFR Part 11.' ;
    rdfs:domain ind:Epoch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentArmSpecific rdf:type rdf:Property ;
    rdfs:label 'Treatment Arm Specific' ;
    rdfs:comment 'Indicates whether this epoch applies to a specific treatment arm only (True) or is common across all arms of the study (False). Relevant for crossover and multi-arm study designs.' ;
    rdfs:domain ind:Epoch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:washoutEpoch rdf:type rdf:Property ;
    rdfs:label 'Washout Epoch' ;
    rdfs:comment 'Indicates whether this epoch is a washout period during which prior treatment effects are expected to dissipate before the next treatment period. Used in crossover study design analysis.' ;
    rdfs:domain ind:Epoch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:windowAfterDays rdf:type rdf:Property ;
    rdfs:label 'Window After Days' ;
    rdfs:comment 'Allowable number of days after the planned epoch start date within which the epoch transition is considered protocol-compliant. Used for protocol deviation assessment.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windowBeforeDays rdf:type rdf:Property ;
    rdfs:label 'Window Before Days' ;
    rdfs:comment 'Allowable number of days before the planned epoch start date within which the epoch transition is considered protocol-compliant. Used for protocol deviation assessment.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:predecessorMilestoneStudyMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Milestone Study Milestone Id' ;
    rdfs:comment 'Self-referencing identifier of the milestone that must be achieved before this milestone can begin. Enables dependency chain modeling for critical path analysis and schedule impact assessment.' ;
    rdfs:domain ind:StudyMilestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudyMilestone .

ind:achievementConfirmedBy rdf:type rdf:Property ;
    rdfs:label 'Achievement Confirmed By' ;
    rdfs:comment 'Name or role of the individual who formally confirmed and recorded the milestone as achieved in the CTMS. Supports ALCOA+ data integrity requirements and audit trail documentation.' ;
    rdfs:domain ind:StudyMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:achievementConfirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Achievement Confirmed Timestamp' ;
    rdfs:comment 'Date and time when the milestone achievement was formally confirmed and recorded in the CTMS. Distinct from actual_date (the business event date) — this is the system confirmation timestamp per ALCOA+ requirements.' ;
    rdfs:domain ind:StudyMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualEnrollmentCount rdf:type rdf:Property ;
    rdfs:label 'Actual Enrollment Count' ;
    rdfs:comment 'For enrollment-type milestones, the actual number of subjects enrolled at the time of milestone achievement. Compared against target_enrollment_count to assess enrollment performance at key study milestones.' ;
    rdfs:domain ind:StudyMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionCriteria rdf:type rdf:Property ;
    rdfs:label 'Completion Criteria' ;
    rdfs:comment 'Formal, measurable criteria that must be satisfied for the milestone to be considered achieved (e.g., \'100% of target sites activated\', \'All CRFs locked and queries resolved\'). Supports objective milestone verification.' ;
    rdfs:domain ind:StudyMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isContractual rdf:type rdf:Property ;
    rdfs:label 'Is Contractual' ;
    rdfs:comment 'Indicates whether this milestone is tied to a contractual obligation with the sponsor (e.g., payment trigger, deliverable deadline). Contractual milestones are tracked for financial and legal compliance purposes.' ;
    rdfs:domain ind:StudyMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryMilestone rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Milestone' ;
    rdfs:comment 'Indicates whether this milestone has a direct regulatory reporting obligation (e.g., IND submission, first patient enrolled notification, DBL, NDA/BLA submission). Regulatory milestones trigger compliance tracking and health authority notifications.' ;
    rdfs:domain ind:StudyMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadLagDays rdf:type rdf:Property ;
    rdfs:label 'Lead Lag Days' ;
    rdfs:comment 'Number of days of lead (negative) or lag (positive) applied to the dependency relationship with the predecessor milestone. Allows scheduling flexibility where a milestone can start before or must wait after its predecessor.' ;
    rdfs:domain ind:StudyMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Timestamp' ;
    rdfs:comment 'Date and time when the milestone achievement notification was dispatched to the relevant stakeholders. Null if notification has not yet been sent. Supports compliance audit trails for regulatory reporting obligations.' ;
    rdfs:domain ind:StudyMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sequence rdf:type rdf:Property ;
    rdfs:label 'Sequence' ;
    rdfs:comment 'Ordinal position of this milestone within the study\'s overall milestone schedule. Defines the logical ordering of milestones for timeline visualization and Gantt chart rendering in CTMS.' ;
    rdfs:domain ind:StudyMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceReason rdf:type rdf:Property ;
    rdfs:label 'Variance Reason' ;
    rdfs:comment 'Free-text or coded explanation for any deviation between the planned and actual/forecast milestone date. Required when variance_days is non-zero. Supports root cause analysis and CAPA tracking per GCP requirements.' ;
    rdfs:domain ind:StudyMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Standardized coded classification of the variance reason to enable aggregate analysis across studies and portfolios. Complements the free-text variance_reason field. [ENUM-REF-CANDIDATE: site_delay|enrollment_shortfall|regulatory_hold|protocol_amendment|sponsor_decision|resource_constraint|covid_impact|other — promote to reference product]' ;
    rdfs:domain ind:StudyMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEndpointId rdf:type rdf:Property ;
    rdfs:label 'Primary Endpoint Id' ;
    rdfs:comment 'Reference to the primary endpoint directly associated with this objective. Establishes the objective-to-endpoint traceability chain required by the SAP and regulatory submissions. Nullable for objectives that map to multiple endpoints.' ;
    rdfs:domain ind:Objective ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Endpoint .

ind:adamDatasetReference rdf:type rdf:Property ;
    rdfs:label 'Adam Dataset Reference' ;
    rdfs:comment 'CDISC ADaM dataset name(s) used for the primary analysis supporting this objective (e.g., ADEFF, ADTTE, ADAE). Provides direct linkage from objective to analysis-ready datasets in SAS Drug Development.' ;
    rdfs:domain ind:Objective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsmbReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Dsmb Reportable Flag' ;
    rdfs:comment 'Indicates whether interim results for this objective are to be reviewed by the Data Safety Monitoring Board (DSMB) or Data Monitoring Committee (DMC) during planned interim analyses. Drives interim analysis planning and unblinding procedures.' ;
    rdfs:domain ind:Objective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irbIecReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Review Required' ;
    rdfs:comment 'Indicates whether a change to this objective requires IRB/IEC review and approval (e.g., substantial protocol amendment). Drives the amendment workflow and site notification process.' ;
    rdfs:domain ind:Objective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAmendedInAmendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Last Amended In Amendment Number' ;
    rdfs:comment 'Protocol amendment number in which this objective was most recently modified. Null if the objective has never been amended. Used to track the amendment history of each objective for regulatory submissions.' ;
    rdfs:domain ind:Objective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiplicityAdjustmentRequired rdf:type rdf:Property ;
    rdfs:label 'Multiplicity Adjustment Required' ;
    rdfs:comment 'Indicates whether statistical multiplicity adjustment (e.g., Bonferroni, Hochberg, hierarchical testing) is required for this objective due to multiple comparisons. Informs the SAP multiplicity control strategy.' ;
    rdfs:domain ind:Objective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:objectiveNumber rdf:type rdf:Property ;
    rdfs:label 'Objective Number' ;
    rdfs:comment 'Structured alphanumeric identifier for the objective within the protocol (e.g., P-1 for Primary Objective 1, S-2 for Secondary Objective 2). Used for cross-referencing in the Statistical Analysis Plan (SAP) and Clinical Study Report (CSR).' ;
    rdfs:domain ind:Objective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objectiveStatus rdf:type rdf:Property ;
    rdfs:label 'Objective Status' ;
    rdfs:comment 'Current lifecycle state of the study objective. Draft objectives are under authoring review; active objectives are in the approved protocol; amended objectives have been modified by a protocol amendment; superseded objectives have been replaced; retired objectives have been removed from the protocol.' ;
    rdfs:domain ind:Objective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objectiveText rdf:type rdf:Property ;
    rdfs:label 'Objective Text' ;
    rdfs:comment 'Full verbatim text of the study objective as stated in the approved protocol. This is the authoritative scientific statement of what the study aims to demonstrate or evaluate, used verbatim in regulatory submissions and the CSR.' ;
    rdfs:domain ind:Objective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:populationDescription rdf:type rdf:Property ;
    rdfs:label 'Population Description' ;
    rdfs:comment 'Description of the analysis population to which this objective applies (e.g., Intent-to-Treat (ITT), Per Protocol (PP), Safety Population). Aligns with the estimand population attribute per ICH E9(R1).' ;
    rdfs:domain ind:Objective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scientificRationale rdf:type rdf:Property ;
    rdfs:label 'Scientific Rationale' ;
    rdfs:comment 'Narrative justification for why this objective is scientifically important and how it contributes to the overall study goals. Supports regulatory review, protocol synopsis, and investigator brochure alignment.' ;
    rdfs:domain ind:Objective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmDomainReference rdf:type rdf:Property ;
    rdfs:label 'Sdtm Domain Reference' ;
    rdfs:comment 'CDISC SDTM domain(s) that contain the data supporting this objective (e.g., ADAE, ADEFF, ADTTE). Enables automated linkage between protocol objectives and SDTM/ADaM datasets in SAS Drug Development.' ;
    rdfs:domain ind:Objective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:summaryMeasure rdf:type rdf:Property ;
    rdfs:label 'Summary Measure' ;
    rdfs:comment 'Statistical summary measure used to quantify the treatment effect for this objective (e.g., difference in means, odds ratio, hazard ratio, response rate difference). Corresponds to the population-level summary attribute of the ICH E9(R1) estimand.' ;
    rdfs:domain ind:Objective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingHierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Testing Hierarchy Level' ;
    rdfs:comment 'Numeric level in the hierarchical testing procedure for this objective. Level 1 is tested first; subsequent levels are tested only if the preceding level achieves statistical significance. Implements the gatekeeping strategy defined in the SAP.' ;
    rdfs:domain ind:Objective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:variableDescription rdf:type rdf:Property ;
    rdfs:label 'Variable Description' ;
    rdfs:comment 'Description of the variable (outcome measure) used to address this objective, as defined in the ICH E9(R1) estimand framework. Specifies what is measured on each subject to evaluate the treatment effect.' ;
    rdfs:domain ind:Objective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentRegulatoryBinderId rdf:type rdf:Property ;
    rdfs:label 'Amendment Regulatory Binder Id' ;
    rdfs:comment 'Foreign key linking to document.regulatory_binder. Business justification: Protocol amendments are submitted as IND amendments or CTA variations filed in regulatory binders. study_protocol_amendment tracks fda_submission_date, ema_submission_date, pmda_submission_date. Linki' ;
    rdfs:domain ind:StudyProtocolAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryBinder .

ind:amendmentTmfDocumentId rdf:type rdf:Property ;
    rdfs:label 'Amendment Tmf Document Id' ;
    rdfs:comment 'Foreign key linking to document.tmf_document. Business justification: Each protocol amendment generates a TMF essential document (DIA TMF Zone 4). Amendment tracking and TMF completeness assessments require linking the amendment record to its filed TMF document. Inspect' ;
    rdfs:domain ind:StudyProtocolAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TmfDocument .

ind:clinicalOneAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Clinical One Amendment Id' ;
    rdfs:comment 'The native amendment identifier from Oracle Clinical One study design system. Used for data lineage and reconciliation between the lakehouse silver layer and the operational source system.' ;
    rdfs:domain ind:StudyProtocolAmendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:changeCategory rdf:type rdf:Property ;
    rdfs:label 'Change Category' ;
    rdfs:comment 'Primary category of change introduced by the amendment. Used for analytics, regulatory reporting, and impact triage. [ENUM-REF-CANDIDATE: eligibility_criteria|dosing_regimen|visit_schedule|safety_monitoring|endpoint|statistical|icf|administrative|other — promote to reference product]' ;
    rdfs:domain ind:StudyProtocolAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsmbDmcRecommendationFlag rdf:type rdf:Property ;
    rdfs:label 'Dsmb Dmc Recommendation Flag' ;
    rdfs:comment 'Indicates whether this amendment was triggered by a formal recommendation from the Data Safety Monitoring Board (DSMB) or Data Monitoring Committee (DMC). Requires documentation of the DSMB/DMC meeting minutes.' ;
    rdfs:domain ind:StudyProtocolAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:edcConfigurationUpdatedFlag rdf:type rdf:Property ;
    rdfs:label 'Edc Configuration Updated Flag' ;
    rdfs:comment 'Indicates whether the Electronic Data Capture (EDC) system (Medidata Rave) has been updated to reflect the protocol changes introduced by this amendment. Critical for data integrity and eCRF alignment.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emaSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Ema Submission Date' ;
    rdfs:comment 'Date the amendment was submitted to the European Medicines Agency (EMA) or relevant national competent authority under EU CTR 536/2014. Null if no EU sites are involved.' ;
    rdfs:domain ind:StudyProtocolAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emaSubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Ema Submission Status' ;
    rdfs:comment 'Current regulatory submission status with the European Medicines Agency (EMA) or relevant EU national competent authority for this amendment.' ;
    rdfs:domain ind:StudyProtocolAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdaSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Fda Submission Date' ;
    rdfs:comment 'Date the amendment was submitted to the U.S. Food and Drug Administration (FDA) as an IND amendment. Null if the study is not conducted under a U.S. IND.' ;
    rdfs:domain ind:StudyProtocolAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fdaSubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Fda Submission Status' ;
    rdfs:comment 'Current regulatory submission status with the U.S. Food and Drug Administration (FDA). \'On_clinical_hold\' indicates FDA has placed a hold pending resolution of safety concerns.' ;
    rdfs:domain ind:StudyProtocolAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icfVersionUpdatedFlag rdf:type rdf:Property ;
    rdfs:label 'Icf Version Updated Flag' ;
    rdfs:comment 'Indicates whether this amendment necessitates a new version of the Informed Consent Form (ICF). When true, a new ICF document version must be created and approved before re-consent activities begin.' ;
    rdfs:domain ind:StudyProtocolAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pmdaSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Pmda Submission Date' ;
    rdfs:comment 'Date the amendment was submitted to Japan\'s Pharmaceuticals and Medical Devices Agency (PMDA). Null if no Japan sites are involved.' ;
    rdfs:domain ind:StudyProtocolAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pmdaSubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Pmda Submission Status' ;
    rdfs:comment 'Current regulatory submission status with Japan\'s Pharmaceuticals and Medical Devices Agency (PMDA) for this amendment.' ;
    rdfs:domain ind:StudyProtocolAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousProtocolVersion rdf:type rdf:Property ;
    rdfs:label 'Previous Protocol Version' ;
    rdfs:comment 'The protocol version number that was in effect immediately before this amendment was applied. Enables version chain traceability for audit and regulatory inspection purposes.' ;
    rdfs:domain ind:StudyProtocolAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyDrivenFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Driven Flag' ;
    rdfs:comment 'Indicates whether this amendment was initiated primarily due to a safety signal, Serious Adverse Event (SAE), SUSAR, or DSMB/DMC recommendation. Safety-driven amendments may require expedited regulatory review.' ;
    rdfs:domain ind:StudyProtocolAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Sap Impact Flag' ;
    rdfs:comment 'Indicates whether this amendment requires an update to the Statistical Analysis Plan (SAP). Changes to primary/secondary endpoints, analysis populations (ITT, PP), or statistical methods trigger SAP revision.' ;
    rdfs:domain ind:StudyProtocolAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:veevaVaultDocumentCode rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Document Code' ;
    rdfs:comment 'The document identifier assigned by Veeva Vault eTMF to the amendment document. Enables direct cross-reference to the source document management system for audit trail and TMF completeness tracking.' ;
    rdfs:domain ind:StudyProtocolAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyCroOrgOrganizationId rdf:type rdf:Property ;
    rdfs:label 'Study Cro Org Organization Id' ;
    rdfs:comment 'Reference identifier for the Contract Research Organization (CRO) assigned to manage or support the clinical study on behalf of the sponsor. Nullable when the sponsor conducts the study internally. Sourced from Oracle Siebel CTMS.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organization .

ind:studyOrganizationId rdf:type rdf:Property ;
    rdfs:label 'Study Organization Id' ;
    rdfs:comment 'Reference identifier for the pharmaceutical or biotech sponsor organization funding and owning the clinical study. Links to the sponsor master entity in the study domain. Sourced from Oracle Siebel CTMS Account/Sponsor object.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organization .

ind:ctmsStudyCode rdf:type rdf:Property ;
    rdfs:label 'Ctms Study Code' ;
    rdfs:comment 'The native study identifier assigned by Oracle Siebel CTMS, the system of record for this entity. Enables direct traceability back to the source system record for audit, reconciliation, and data lineage purposes per ALCOA+ principles.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designType rdf:type rdf:Property ;
    rdfs:label 'Design Type' ;
    rdfs:comment 'The methodological design classification of the clinical study (e.g., Parallel Group, Crossover, Single Arm, Factorial, Adaptive). Informs statistical analysis plan design, randomization schema, and protocol complexity. Sourced from Oracle Clinical One study design configuration. [ENUM-REF-CANDIDATE: Parallel Group|Crossover|Single Arm|Factorial|Adaptive|Basket|Umbrella|Platform — promote to reference product]' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:edcStudyCode rdf:type rdf:Property ;
    rdfs:label 'Edc Study Code' ;
    rdfs:comment 'The study identifier assigned within the Electronic Data Capture (EDC) system (Medidata Rave) used for clinical data collection. Enables cross-system traceability between the CTMS master record and the EDC operational system. Required for data lineage and audit trail purposes per 21 CFR Part 11.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstSiteInitiationDate rdf:type rdf:Property ;
    rdfs:label 'First Site Initiation Date' ;
    rdfs:comment 'The date on which the first investigational site was formally initiated (Site Initiation Visit completed) and authorized to enroll subjects. A key operational milestone tracked in Oracle Siebel CTMS for timeline KPI reporting.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isRandomized rdf:type rdf:Property ;
    rdfs:label 'Is Randomized' ;
    rdfs:comment 'Indicates whether the clinical study employs randomization to assign participants to treatment arms (True) or uses a non-randomized assignment method (False). Determines RTSM/IRT configuration requirements in Medidata Rave and Oracle Clinical One.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedCountryCount rdf:type rdf:Property ;
    rdfs:label 'Planned Country Count' ;
    rdfs:comment 'The planned number of countries in which the clinical study will be conducted. Drives regulatory strategy (multi-national submissions), country-level feasibility, and operational complexity assessment.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRegulatoryRegion rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Region' ;
    rdfs:comment 'The primary regulatory jurisdiction governing the clinical study, determining the lead regulatory authority (e.g., US for FDA, EU for EMA, JP for PMDA). Drives applicable GCP guidelines, submission requirements, and safety reporting timelines.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorStudyNumber rdf:type rdf:Property ;
    rdfs:label 'Sponsor Study Number' ;
    rdfs:comment 'The sponsor-assigned unique alphanumeric identifier for the clinical study (e.g., ABC-1234-001). This is the primary business identifier used across all sponsor systems, regulatory submissions, and inter-organizational communications. Corresponds to the Protocol Number in Oracle Siebel CTMS.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyStatus rdf:type rdf:Property ;
    rdfs:label 'Study Status' ;
    rdfs:comment 'The current operational lifecycle status of the clinical study. Drives workflow gating, resource allocation, regulatory reporting obligations, and system access controls across CTMS, EDC, and eTMF. This is the authoritative status field sourced from Oracle Siebel CTMS. Transitions are tracked in the study status history product.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetEnrollment rdf:type rdf:Property ;
    rdfs:label 'Target Enrollment' ;
    rdfs:comment 'The planned total number of subjects to be enrolled across all study sites as specified in the approved protocol and statistical analysis plan (SAP). Drives site allocation, recruitment planning, and power calculations. Sourced from Oracle Siebel CTMS.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tmfArchivalDate rdf:type rdf:Property ;
    rdfs:label 'Tmf Archival Date' ;
    rdfs:comment 'The date on which the Trial Master File (TMF) was formally archived following study close-out. The TMF must be retained for a minimum of 15 years (or longer per regional requirements) after study completion. Tracked in Veeva Vault eTMF.' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cdiscVisitReference rdf:type rdf:Property ;
    rdfs:label 'Cdisc Visit Reference' ;
    rdfs:comment 'Standardized CDISC controlled terminology code or reference for the visit type, used to align the visit schedule with CDISC SDTM submission datasets and regulatory data packages (e.g., CDISC CT VISIT term).' ;
    rdfs:domain ind:StudyVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDosingVisit rdf:type rdf:Property ;
    rdfs:label 'Is Dosing Visit' ;
    rdfs:comment 'Indicates whether investigational product (IP) administration or dosing occurs at this visit. Used by RTSM/IRT systems for drug supply planning, IP accountability tracking, and site operational scheduling.' ;
    rdfs:domain ind:StudyVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInIttPopulation rdf:type rdf:Property ;
    rdfs:label 'Is In Itt Population' ;
    rdfs:comment 'Indicates whether data collected at this visit contributes to the Intent-to-Treat (ITT) analysis population as defined in the Statistical Analysis Plan (SAP). Used by biostatisticians to configure ADaM datasets and analysis flags.' ;
    rdfs:domain ind:StudyVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInPpPopulation rdf:type rdf:Property ;
    rdfs:label 'Is In Pp Population' ;
    rdfs:comment 'Indicates whether data collected at this visit contributes to the Per Protocol (PP) analysis population as defined in the Statistical Analysis Plan (SAP). Supports biostatistical analysis dataset configuration.' ;
    rdfs:domain ind:StudyVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPkSamplingVisit rdf:type rdf:Property ;
    rdfs:label 'Is Pk Sampling Visit' ;
    rdfs:comment 'Indicates whether Pharmacokinetics (PK) blood or urine sampling is required at this visit. Used by DMPK teams, central labs, and RTSM/IRT systems to plan sample collection kits and logistics.' ;
    rdfs:domain ind:StudyVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryEndpointVisit rdf:type rdf:Property ;
    rdfs:label 'Is Primary Endpoint Visit' ;
    rdfs:comment 'Indicates whether this visit is a primary endpoint assessment visit as defined in the study protocol. Flags visits where the primary efficacy or safety endpoint data is collected, critical for data completeness monitoring and regulatory submission.' ;
    rdfs:domain ind:StudyVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRandomizationVisit rdf:type rdf:Property ;
    rdfs:label 'Is Randomization Visit' ;
    rdfs:comment 'Indicates whether subject randomization occurs at this visit via the RTSM/IRT system (e.g., Oracle Clinical One, Medidata Rave RTSM). Critical for enrollment tracking, DSMB reporting, and regulatory milestone monitoring.' ;
    rdfs:domain ind:StudyVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedStudyDay rdf:type rdf:Property ;
    rdfs:label 'Planned Study Day' ;
    rdfs:comment 'The planned study day on which this visit is scheduled to occur, relative to the study reference start date (Day 1 = first dose or randomization). Negative values indicate pre-treatment visits (e.g., Day -14 for screening). Aligns with CDISC SDTM VISITDY variable.' ;
    rdfs:domain ind:StudyVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedStudyWeek rdf:type rdf:Property ;
    rdfs:label 'Planned Study Week' ;
    rdfs:comment 'The planned study week on which this visit is scheduled, derived from planned_study_day for reporting convenience. Used in study timelines, subject visit planning, and site management dashboards.' ;
    rdfs:domain ind:StudyVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:procedureCategory rdf:type rdf:Property ;
    rdfs:label 'Procedure Category' ;
    rdfs:comment 'High-level category of the clinical procedure or assessment. Drives CDISC SDTM domain mapping, EDC form routing, and operational planning for site staff. [ENUM-REF-CANDIDATE: vital_signs|laboratory|ecg|imaging|dosing|pk_sampling|physical_exam|questionnaire|biomarker|concomitant_medication|adverse_event|other — promote to reference product]' ;
    rdfs:domain ind:Study ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureSequence rdf:type rdf:Property ;
    rdfs:label 'Procedure Sequence' ;
    rdfs:comment 'Ordering sequence of the procedure within a visit, defining the recommended order of assessments (e.g., vital signs before blood draw, ECG before dosing). Used for site operational workflow and EDC form ordering.' ;
    rdfs:domain ind:StudyVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresCentralLab rdf:type rdf:Property ;
    rdfs:label 'Requires Central Lab' ;
    rdfs:comment 'Indicates whether samples collected at this visit-procedure must be processed by the central laboratory (True) rather than a local laboratory. Drives sample kit logistics, central lab requisition, and supply chain planning.' ;
    rdfs:domain ind:StudyVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresLocalLab rdf:type rdf:Property ;
    rdfs:label 'Requires Local Lab' ;
    rdfs:comment 'Indicates whether samples collected at this visit-procedure are to be processed by the site local laboratory. Used for safety lab monitoring where rapid turnaround is required (e.g., pre-dose safety labs).' ;
    rdfs:domain ind:StudyVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Version identifier for this Schedule of Events (SoE), aligned with the protocol amendment version (e.g., v1.0, v2.0, Amendment 1). Tracks iterative changes to the visit schedule over the study lifecycle.' ;
    rdfs:domain ind:StudyVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemVisitCode rdf:type rdf:Property ;
    rdfs:label 'Source System Visit Code' ;
    rdfs:comment 'Native identifier of this visit record in the originating operational system (Medidata Rave or Oracle Clinical One). Used for data lineage, reconciliation, and cross-system traceability per ALCOA+ principles.' ;
    rdfs:domain ind:StudyVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Visit Duration Minutes' ;
    rdfs:comment 'Estimated duration of the visit in minutes as defined in the protocol or site operational plan. Used for site scheduling, resource planning, and subject burden assessment.' ;
    rdfs:domain ind:StudyVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visitShortLabel rdf:type rdf:Property ;
    rdfs:label 'Visit Short Label' ;
    rdfs:comment 'Abbreviated label for the visit used in EDC (Electronic Data Capture) systems, reports, and data listings (e.g., SCR, BL, W04, EOT, FU1). Configured in Medidata Rave and Oracle Clinical One for eCRF navigation.' ;
    rdfs:domain ind:StudyVisitSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adamDataset rdf:type rdf:Property ;
    rdfs:label 'Adam Dataset' ;
    rdfs:comment 'CDISC ADaM dataset name to which this procedure\'s data contributes for statistical analysis (e.g., ADLB, ADVS, ADEG, ADPC). Used by SAS Drug Development for biostatistical analysis and CSR generation.' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctcaeGradingApplicable rdf:type rdf:Property ;
    rdfs:label 'Ctcae Grading Applicable' ;
    rdfs:comment 'Indicates whether CTCAE grading criteria apply to results collected by this procedure (e.g., laboratory abnormalities graded per CTCAE v5.0). Drives safety data review workflows and adverse event reporting linkage.' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Type of clinical equipment or device required to perform this procedure at the site (e.g., \'Holter Monitor\', \'Spirometer\', \'Dual-Energy X-ray Absorptiometry (DXA) Scanner\', \'Electrocardiograph\'). Used for site feasibility assessment and equipment qualification tracking.' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Minutes' ;
    rdfs:comment 'Estimated time in minutes required to complete this procedure at the site. Used for visit duration planning, site burden assessment, and subject scheduling optimization.' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oracleClinicalOneTaskCode rdf:type rdf:Property ;
    rdfs:label 'Oracle Clinical One Task Code' ;
    rdfs:comment 'Identifier of the corresponding task or activity in Oracle Clinical One study design module. Enables cross-system traceability between the lakehouse visit procedure record and the Oracle Clinical One study build configuration.' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureDescription rdf:type rdf:Property ;
    rdfs:label 'Procedure Description' ;
    rdfs:comment 'Detailed narrative description of the clinical procedure, including instructions, conditions, and any protocol-specific requirements (e.g., fasting requirements, timing relative to dosing, specimen handling instructions).' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifiedPersonnelRequired rdf:type rdf:Property ;
    rdfs:label 'Qualified Personnel Required' ;
    rdfs:comment 'Specifies the qualification or role required to perform this procedure (e.g., \'Phlebotomist\', \'Radiologist\', \'Cardiologist\', \'Trained Study Nurse\'). Used for site staff delegation log and training requirement planning.' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raveFormVersion rdf:type rdf:Property ;
    rdfs:label 'Rave Form Version' ;
    rdfs:comment 'Version identifier of the Medidata Rave eCRF form associated with this procedure (e.g., \'1.0\', \'2.1\'). Tracks form versioning to ensure data collected aligns with the correct protocol version and supports audit trail requirements under 21 CFR Part 11.' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresUnscheduledFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Unscheduled Flag' ;
    rdfs:comment 'Indicates whether this procedure definition applies to unscheduled visits (e.g., safety follow-up, early termination). Distinguishes procedures that are only applicable at unscheduled visits from those in the planned Schedule of Events.' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdvRequirement rdf:type rdf:Property ;
    rdfs:label 'Sdv Requirement' ;
    rdfs:comment 'Specifies the Source Data Verification (SDV) requirement level for data collected by this procedure. Drives risk-based monitoring plans and CRA visit scope. 100_percent requires full SDV; risk_based applies statistical sampling; critical_only limits SDV to primary endpoint data.' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timingReference rdf:type rdf:Property ;
    rdfs:label 'Timing Reference' ;
    rdfs:comment 'Specifies the timing reference point for procedure execution relative to a clinical anchor event (e.g., pre_dose, post_dose, fasting). Critical for PK sampling, vital signs, and lab draws where timing relative to dosing affects data interpretation. [ENUM-REF-CANDIDATE: pre_dose|post_dose|any_time|fasting|pre_meal|post_meal|bedtime|morning|evening — promote to reference product]' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timingWindowPostMinutes rdf:type rdf:Property ;
    rdfs:label 'Timing Window Post Minutes' ;
    rdfs:comment 'Allowable time window in minutes after the nominal procedure time point (positive offset). Defines the acceptable late execution window for protocol compliance assessment (e.g., +30 minutes for a post-dose PK sample).' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timingWindowPreMinutes rdf:type rdf:Property ;
    rdfs:label 'Timing Window Pre Minutes' ;
    rdfs:comment 'Allowable time window in minutes before the nominal procedure time point (negative offset). Defines the acceptable early execution window for protocol compliance assessment (e.g., -30 minutes for a pre-dose PK sample).' ;
    rdfs:domain ind:VisitProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:concomitantMedicationId rdf:type rdf:Property ;
    rdfs:label 'Concomitant Medication Id' ;
    rdfs:comment 'Unique surrogate identifier for each concomitant medication record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConcomitantMedication .

ind:aeRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Ae Related Flag' ;
    rdfs:comment 'Indicates whether this concomitant medication was initiated or modified in response to an adverse event (AE). Supports causality assessment and safety narrative construction in Oracle Argus Safety.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cmSeq rdf:type rdf:Property ;
    rdfs:label 'Cm Seq' ;
    rdfs:comment 'Sequential number identifying each concomitant medication record for a given subject within a study, used for SDTM CM domain sequencing (CMSEQ). Enables ordering of multiple medication records per subject.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:concomitantFlag rdf:type rdf:Property ;
    rdfs:label 'Concomitant Flag' ;
    rdfs:comment 'Indicates whether the medication was taken concomitantly (during the study treatment period) as opposed to only in the pre-study period. Supports classification of medications as prior vs. concomitant per SDTM CM domain conventions.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:concomitantMedicationCategory rdf:type rdf:Property ;
    rdfs:label 'Concomitant Medication Category' ;
    rdfs:comment 'Sponsor-defined category grouping for the concomitant medication (e.g., PRIOR, CONCOMITANT, PROHIBITED, RESCUE). Corresponds to SDTM CMCAT. Used for protocol-specific medication classification and reporting.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dose rdf:type rdf:Property ;
    rdfs:label 'Dose' ;
    rdfs:comment 'The numeric dose amount of the concomitant medication administered per dose event. Corresponds to SDTM CMDOSE. Must be interpreted in conjunction with dose_unit.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:doseFrequency rdf:type rdf:Property ;
    rdfs:label 'Dose Frequency' ;
    rdfs:comment 'The frequency at which the concomitant medication is administered (e.g., QD, BID, TID, QID, PRN, weekly). Corresponds to SDTM CMDOSFRQ. Uses CDISC controlled terminology for standardized reporting.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doseRoute rdf:type rdf:Property ;
    rdfs:label 'Dose Route' ;
    rdfs:comment 'The route by which the concomitant medication is administered (e.g., ORAL, INTRAVENOUS, SUBCUTANEOUS, TOPICAL, INHALATION). Corresponds to SDTM CMDOSROUTE. Uses CDISC controlled terminology.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedDrugName rdf:type rdf:Property ;
    rdfs:label 'Modified Drug Name' ;
    rdfs:comment 'Standardized or sponsor-modified version of the verbatim drug name after data cleaning, prior to WHO-DD coding. Corresponds to SDTM CMMODIFY. Used when the verbatim term is modified for coding purposes.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ongoingFlag rdf:type rdf:Property ;
    rdfs:label 'Ongoing Flag' ;
    rdfs:comment 'Indicates whether the concomitant medication was still ongoing at the time of the last assessment or data collection. Corresponds to SDTM CMONGO. True when end_date is not yet known or medication continues beyond the observation window.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorTherapyFlag rdf:type rdf:Property ;
    rdfs:label 'Prior Therapy Flag' ;
    rdfs:comment 'Indicates whether the medication was taken prior to the start of the study (pre-existing medication) as opposed to being initiated during the study. Corresponds to SDTM CMPRESP/CMOCCUR context. Supports prior therapy analysis in efficacy and safety assessments.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prohibitedMedicationFlag rdf:type rdf:Property ;
    rdfs:label 'Prohibited Medication Flag' ;
    rdfs:comment 'Indicates whether this concomitant medication is classified as a prohibited medication per the study protocol. A True value may trigger a protocol deviation review. Critical for protocol compliance monitoring.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Current data management status of the concomitant medication record in the EDC system (Medidata Rave). Indicates whether the record is active, has been deleted, amended after lock, or locked for database lock (DBL).' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rescueMedicationFlag rdf:type rdf:Property ;
    rdfs:label 'Rescue Medication Flag' ;
    rdfs:comment 'Indicates whether this medication was administered as a rescue therapy per the study protocol (e.g., for breakthrough pain, hypoglycemia rescue). Rescue medication use is a key efficacy endpoint in many trials.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:studyDayEnd rdf:type rdf:Property ;
    rdfs:label 'Study Day End' ;
    rdfs:comment 'The study day on which the concomitant medication was stopped, calculated relative to the reference start date. Corresponds to SDTM CMENDY. Null if medication is ongoing. Used for duration and overlap calculations.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:studyDayStart rdf:type rdf:Property ;
    rdfs:label 'Study Day Start' ;
    rdfs:comment 'The study day on which the concomitant medication was started, calculated relative to the reference start date (Day 1 = first dose of investigational product). Corresponds to SDTM CMSTDY. Enables temporal analysis relative to IP exposure.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verbatimDrugName rdf:type rdf:Property ;
    rdfs:label 'Verbatim Drug Name' ;
    rdfs:comment 'The medication name exactly as reported by the subject or investigator on the electronic Case Report Form (eCRF), prior to WHO-DD coding. Corresponds to SDTM CMTRT field. Preserved for source data traceability per ALCOA+ principles.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:whodbAtcCode rdf:type rdf:Property ;
    rdfs:label 'Whodb Atc Code' ;
    rdfs:comment 'The Anatomical Therapeutic Chemical (ATC) classification code assigned by the WHO Drug Dictionary (WHO-DD) for the concomitant medication. Enables therapeutic class-level analysis and drug-drug interaction assessment.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:whodbDrugName rdf:type rdf:Property ;
    rdfs:label 'Whodb Drug Name' ;
    rdfs:comment 'The preferred drug name as coded against the WHO Drug Dictionary (WHO-DD). Corresponds to SDTM CMDECOD. Enables standardized cross-study drug identification and safety signal detection.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:whodbVersion rdf:type rdf:Property ;
    rdfs:label 'Whodb Version' ;
    rdfs:comment 'Version of the WHO Drug Dictionary (WHO-DD) used for coding this concomitant medication record. Required for regulatory submissions to ensure reproducibility of coded data.' ;
    rdfs:domain ind:ConcomitantMedication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demographicId rdf:type rdf:Property ;
    rdfs:label 'Demographic Id' ;
    rdfs:comment 'Unique surrogate identifier for each subject demographic record in the silver layer lakehouse. Primary key for the demographic data product.' ;
    rdfs:domain ind:Demographic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageAtScreening rdf:type rdf:Property ;
    rdfs:label 'Age At Screening' ;
    rdfs:comment 'Subject\'s age in whole years at the time of the screening visit, derived from date of birth and screening date. Used for eligibility verification, stratification, and CDISC SDTM DM domain submission.' ;
    rdfs:domain ind:Demographic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:birthYear rdf:type rdf:Property ;
    rdfs:label 'Birth Year' ;
    rdfs:comment 'Subject\'s year of birth as a four-digit integer. Used when full date of birth is masked for privacy compliance but year-level granularity is required for age-cohort analyses and CDISC partial date handling.' ;
    rdfs:domain ind:Demographic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bmi rdf:type rdf:Property ;
    rdfs:label 'Bmi' ;
    rdfs:comment 'Subject\'s body mass index calculated as weight (kg) divided by height squared (m²) at baseline. Stored as a baseline characteristic per CDISC ADaM ADSL convention; used in eligibility assessment and subgroup analyses.' ;
    rdfs:domain ind:Demographic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataEntryStatus rdf:type rdf:Property ;
    rdfs:label 'Data Entry Status' ;
    rdfs:comment 'Current data entry and verification status of the demographic eCRF form in the EDC system. Tracks completeness and readiness for database lock (DBL) and SDTM submission.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Subject\'s date of birth in ISO 8601 format (yyyy-MM-dd). Used to calculate age at key study milestones and to verify age-based eligibility criteria. May be partially masked (year only) per privacy regulations.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dmSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Dm Sequence Number' ;
    rdfs:comment 'Sequential record number within the DM domain for a given subject, per CDISC SDTM convention. Used to uniquely identify each demographic record when multiple records exist per subject (e.g., re-screening scenarios).' ;
    rdfs:domain ind:Demographic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:edcSubjectKey rdf:type rdf:Property ;
    rdfs:label 'Edc Subject Key' ;
    rdfs:comment 'Source system record key for the subject\'s demographic record in the EDC system (Medidata Rave). Enables traceability from the silver layer back to the source EDC record for SDV and audit purposes.' ;
    rdfs:domain ind:Demographic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epoch rdf:type rdf:Property ;
    rdfs:label 'Epoch' ;
    rdfs:comment 'The study epoch (e.g., SCREENING, TREATMENT, FOLLOW-UP) during which the demographic data was collected, per CDISC SDTM Trial Epochs dataset. Used for temporal context in multi-epoch study designs.' ;
    rdfs:domain ind:Demographic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethnicity rdf:type rdf:Property ;
    rdfs:label 'Ethnicity' ;
    rdfs:comment 'Subject\'s self-reported ethnic origin, coded per FDA and CDISC controlled terminology. Distinguishes Hispanic/Latino origin from non-Hispanic/Latino. Required for FDA demographic subgroup reporting in NDA/BLA submissions.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstExposureDate rdf:type rdf:Property ;
    rdfs:label 'First Exposure Date' ;
    rdfs:comment 'Date of the subject\'s first exposure to the investigational product (IP). Defines the start of the treatment period and is the reference date for study day calculations in CDISC SDTM DM domain.' ;
    rdfs:domain ind:Demographic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:genderIdentity rdf:type rdf:Property ;
    rdfs:label 'Gender Identity' ;
    rdfs:comment 'Subject\'s self-reported gender identity, distinct from biological sex. Collected per evolving FDA guidance on inclusion of gender identity in clinical trials. [ENUM-REF-CANDIDATE: MALE|FEMALE|TRANSGENDER MALE|TRANSGENDER FEMALE|NON-BINARY|PREFER NOT TO ANSWER|OTHER — promote to reference product]' ;
    rdfs:domain ind:Demographic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightCm rdf:type rdf:Property ;
    rdfs:label 'Height Cm' ;
    rdfs:comment 'Subject\'s height in centimeters measured at baseline/screening visit. Used for body surface area (BSA) calculations, dose determination, and baseline characteristic tables in the Clinical Study Report (CSR).' ;
    rdfs:domain ind:Demographic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:informedConsentDate rdf:type rdf:Property ;
    rdfs:label 'Informed Consent Date' ;
    rdfs:comment 'Date on which the subject signed the informed consent form (ICF) prior to any study-related procedures. Anchors the CDISC SDTM DM.RFICDTC reference date and is required for regulatory compliance and ALCOA+ data integrity.' ;
    rdfs:domain ind:Demographic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastExposureDate rdf:type rdf:Property ;
    rdfs:label 'Last Exposure Date' ;
    rdfs:comment 'Date of the subject\'s last exposure to the investigational product (IP). Used to define the end of the treatment period and calculate treatment duration for safety and efficacy analyses.' ;
    rdfs:domain ind:Demographic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:race rdf:type rdf:Property ;
    rdfs:label 'Race' ;
    rdfs:comment 'Subject\'s self-reported racial category, coded per FDA and CDISC controlled terminology (e.g., WHITE, BLACK OR AFRICAN AMERICAN, ASIAN, AMERICAN INDIAN OR ALASKA NATIVE, NATIVE HAWAIIAN OR OTHER PACIFIC ISLANDER, MULTIPLE, UNKNOWN, NOT REPORTED). Required for FDA demographic subgroup analyses. [ENUM-REF-CANDIDATE: WHITE|BLACK OR AFRICAN AMERICAN|ASIAN|AMERICAN INDIAN OR ALASKA NATIVE|NATIVE HAWAIIAN OR OTHER PACIFIC ISLANDER|MULTIPLE|UNKNOWN|NOT REPORTED — promote to reference product]' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raceOtherDescription rdf:type rdf:Property ;
    rdfs:label 'Race Other Description' ;
    rdfs:comment 'Free-text description of race when the subject selects \'OTHER\' or \'MULTIPLE\' as their racial category. Captures verbatim self-reported race for completeness in regulatory submissions.' ;
    rdfs:domain ind:Demographic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceStartDate rdf:type rdf:Property ;
    rdfs:label 'Reference Start Date' ;
    rdfs:comment 'The protocol-defined reference start date for the subject, used as the anchor for study day (STUDYDAY) calculations across all SDTM domains. May differ from first_exposure_date in some study designs (e.g., observational studies).' ;
    rdfs:domain ind:Demographic ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sex rdf:type rdf:Property ;
    rdfs:label 'Sex' ;
    rdfs:comment 'Biological sex of the subject as recorded at screening, coded per CDISC controlled terminology. M=Male, F=Female, U=Unknown, UNDIFFERENTIATED=Intersex or not classifiable. Used in safety analyses, PK/PD modeling, and regulatory submissions.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uniqueSubjectIdentifier rdf:type rdf:Property ;
    rdfs:label 'Unique Subject Identifier' ;
    rdfs:comment 'Globally unique identifier for the subject across the study, constructed per CDISC SDTM convention (typically STUDYID-SITEID-SUBJID). Used as the primary cross-domain linkage key in SDTM submissions.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightKg rdf:type rdf:Property ;
    rdfs:label 'Weight Kg' ;
    rdfs:comment 'Subject\'s body weight in kilograms measured at baseline/screening visit. Used for dose calculations, PK/PD modeling, BMI derivation, and baseline characteristic tables in the CSR.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:randomizationAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Randomization Assignment Id' ;
    rdfs:comment 'Foreign key linking to subject.randomization_assignment. Business justification: Disposition records for randomized subjects should reference the specific randomization assignment that was active at the time of disposition. This enables direct linkage between a subject\'s final stu' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RandomizationAssignment .

ind:recordedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Recorded By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Subject disposition records (withdrawal, completion, death) must be attributed to the staff member who recorded them for SDTM DS domain audit trail, regulatory submission, and GCP inspection. \'initiat' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:aeRelatedDiscontinuation rdf:type rdf:Property ;
    rdfs:label 'Ae Related Discontinuation' ;
    rdfs:comment 'Indicates whether the subject\'s discontinuation was due to an adverse event (AE) or serious adverse event (SAE). When True, links to the safety domain for AE-driven disposition analysis and regulatory safety reporting.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:analysisPopulationItt rdf:type rdf:Property ;
    rdfs:label 'Analysis Population Itt' ;
    rdfs:comment 'Indicates whether the subject is included in the Intent-to-Treat (ITT) analysis population based on disposition and protocol criteria. Drives primary efficacy analysis dataset inclusion. Determined by biostatistics per the Statistical Analysis Plan (SAP).' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:analysisPopulationPp rdf:type rdf:Property ;
    rdfs:label 'Analysis Population Pp' ;
    rdfs:comment 'Indicates whether the subject is included in the Per Protocol (PP) analysis population. Subjects with major protocol deviations affecting efficacy assessment are typically excluded. Determined by biostatistics per the SAP.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:analysisPopulationSafety rdf:type rdf:Property ;
    rdfs:label 'Analysis Population Safety' ;
    rdfs:comment 'Indicates whether the subject is included in the Safety analysis population (subjects who received at least one dose of investigational product). Drives safety tabulations in the CSR and regulatory submissions.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:codedReason rdf:type rdf:Property ;
    rdfs:label 'Coded Reason' ;
    rdfs:comment 'Standardized coded reason for discontinuation or withdrawal after medical coding against MedDRA or sponsor-specific dictionary. Corresponds to SDTM DSDECOD. Used in CSR disposition tables and regulatory submissions.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deathCause rdf:type rdf:Property ;
    rdfs:label 'Death Cause' ;
    rdfs:comment 'Verbatim or coded cause of death for subjects with DEATH disposition. Used in safety narratives, CSR, and regulatory submissions. Coded against MedDRA when applicable.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deathDate rdf:type rdf:Property ;
    rdfs:label 'Death Date' ;
    rdfs:comment 'Date of subject death when the disposition term is DEATH. Required for survival analysis, time-to-event endpoints, and expedited safety reporting. Sourced from Medidata Rave EDC death records and Oracle Argus Safety.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Date' ;
    rdfs:comment 'BUSINESS_EVENT_TIMESTAMP (date precision) — the calendar date on which the formal disposition milestone occurred for the subject (e.g., date of randomization, date of last study visit, date of withdrawal). Corresponds to SDTM DSSTDTC (start date component). Sourced from Medidata Rave EDC.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposition Timestamp' ;
    rdfs:comment 'Full ISO 8601 timestamp of the disposition event when time-of-day precision is available. Supplements disposition_date for events requiring precise timing (e.g., time of death, time of last dose). Corresponds to SDTM DSSTDTC full datetime.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dsSeq rdf:type rdf:Property ;
    rdfs:label 'Ds Seq' ;
    rdfs:comment 'Sequential number identifying the order of disposition records for a given subject within the study, corresponding to the SDTM DSSEQ variable. Supports multiple disposition milestones per subject (e.g., enrolled then discontinued).' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earlyTerminationFlag rdf:type rdf:Property ;
    rdfs:label 'Early Termination Flag' ;
    rdfs:comment 'Indicates whether the subject terminated study participation before completing all protocol-required activities. Distinct from study_completion_flag in that it specifically flags premature exit for operational tracking and site performance metrics.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'Date of the subject\'s last known contact with the study team, including phone calls, remote visits, or any study-related communication. Used for lost-to-follow-up determination and survival analysis censoring.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDoseDate rdf:type rdf:Property ;
    rdfs:label 'Last Dose Date' ;
    rdfs:comment 'Date of the subject\'s last administration of investigational product (IP) prior to or at the disposition milestone. Critical for calculating treatment duration, exposure windows, and safety follow-up periods. Sourced from Medidata Rave EDC dosing records.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meddraPt rdf:type rdf:Property ;
    rdfs:label 'Meddra Pt' ;
    rdfs:comment 'MedDRA Preferred Term (PT) assigned to the coded discontinuation reason. Enables standardized cross-study analysis and regulatory reporting of disposition reasons. Populated by the medical coding process.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneSubcategory rdf:type rdf:Property ;
    rdfs:label 'Milestone Subcategory' ;
    rdfs:comment 'Sponsor-defined subcategory further classifying the disposition milestone within its category (e.g., PROTOCOL DEVIATION, ADVERSE EVENT, SPONSOR DECISION under DISCONTINUATION). Corresponds to SDTM DSSCAT variable.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyFollowupEndDate rdf:type rdf:Property ;
    rdfs:label 'Safety Followup End Date' ;
    rdfs:comment 'Planned or actual end date of the post-discontinuation safety follow-up period. Populated when safety_followup_required is True. Used to track completion of safety obligations for discontinued subjects.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyFollowupRequired rdf:type rdf:Property ;
    rdfs:label 'Safety Followup Required' ;
    rdfs:comment 'Indicates whether the subject requires a post-discontinuation safety follow-up period per protocol requirements. True when the subject discontinued early and protocol mandates continued safety monitoring. Drives safety follow-up visit scheduling.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:screenFailureReason rdf:type rdf:Property ;
    rdfs:label 'Screen Failure Reason' ;
    rdfs:comment 'Reason why a screened subject failed to meet eligibility criteria and was not enrolled. Populated only for SCREEN FAILURE disposition. Used for site feasibility analysis and protocol amendment decisions.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdtmDsRecordReference rdf:type rdf:Property ;
    rdfs:label 'Sdtm Ds Record Reference' ;
    rdfs:comment 'Unique record identifier from the CDISC SDTM DS (Disposition) domain dataset, enabling traceability between the Silver Layer lakehouse record and the regulatory submission dataset. Supports eCTD submission package linkage.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyCompletionFlag rdf:type rdf:Property ;
    rdfs:label 'Study Completion Flag' ;
    rdfs:comment 'Indicates whether the subject completed the study per protocol (True) or did not complete (False). Drives CONSORT flow diagram completion counts and CSR disposition summary tables.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:term rdf:type rdf:Property ;
    rdfs:label 'Term' ;
    rdfs:comment 'Standardized disposition term describing the subject\'s formal study milestone (e.g., COMPLETED, SCREEN FAILURE, DISCONTINUED, WITHDRAWN BY SUBJECT, LOST TO FOLLOW-UP, DEATH). Corresponds to SDTM DSTERM. [ENUM-REF-CANDIDATE: COMPLETED|SCREEN FAILURE|DISCONTINUED|WITHDRAWN BY SUBJECT|LOST TO FOLLOW-UP|DEATH|ENROLLED|RANDOMIZED — promote to reference product]' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verbatimReason rdf:type rdf:Property ;
    rdfs:label 'Verbatim Reason' ;
    rdfs:comment 'Free-text verbatim reason for discontinuation or withdrawal as entered by the investigator or site staff in the eCRF. Captured prior to coding. Supports ALCOA+ attributability and audit trail requirements. Populated only for discontinuation/withdrawal milestones.' ;
    rdfs:domain ind:Disposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Eligibility Assessment Id' ;
    rdfs:comment 'Unique surrogate identifier for each eligibility assessment record in the Silver layer lakehouse. Primary key for this data product.' ;
    rdfs:domain ind:EligibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentResult rdf:type rdf:Property ;
    rdfs:label 'Assessment Result' ;
    rdfs:comment 'Outcome of the eligibility criterion assessment for this subject. MET indicates the criterion was satisfied; NOT MET indicates failure; NOT ASSESSED indicates the criterion was not evaluated. Maps to CDISC SDTM IE.IEORRES.' ;
    rdfs:domain ind:EligibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notMetReason rdf:type rdf:Property ;
    rdfs:label 'Not Met Reason' ;
    rdfs:comment 'Free-text or coded reason explaining why the subject did not meet this eligibility criterion. Populated when assessment_result is NOT MET. Supports clinical review and protocol deviation analysis.' ;
    rdfs:domain ind:EligibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallEligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Eligibility Status' ;
    rdfs:comment 'Overall eligibility determination for the subject based on the complete set of inclusion/exclusion criteria assessments. Drives subject enrollment decision. Lifecycle status for this assessment record. [ENUM-REF-CANDIDATE: ELIGIBLE|INELIGIBLE|PENDING|WAIVER_REQUESTED|WAIVER_APPROVED|WAIVER_DENIED — promote to reference product]' ;
    rdfs:domain ind:EligibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reScreeningFlag rdf:type rdf:Property ;
    rdfs:label 'Re Screening Flag' ;
    rdfs:comment 'Indicates whether this eligibility assessment is part of a re-screening attempt following an initial screen failure. Supports enrollment funnel analytics and re-screening rate KPI reporting.' ;
    rdfs:domain ind:EligibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdtmSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sdtm Sequence Number' ;
    rdfs:comment 'CDISC SDTM sequence number (IESEQ) uniquely identifying this record within the IE domain for a given subject. Required for regulatory submission dataset construction.' ;
    rdfs:domain ind:EligibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceDataReference rdf:type rdf:Property ;
    rdfs:label 'Source Data Reference' ;
    rdfs:comment 'Reference to the source document or data entry (e.g., medical record number, lab report ID, physical examination note) that supports the eligibility criterion assessment. Required for Source Data Verification (SDV) by CRA.' ;
    rdfs:domain ind:EligibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverRequested rdf:type rdf:Property ;
    rdfs:label 'Waiver Requested' ;
    rdfs:comment 'Indicates whether a protocol deviation waiver or exception was requested for this criterion when the subject did not meet it. True when a waiver request has been submitted to the sponsor or IRB/IEC.' ;
    rdfs:domain ind:EligibilityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cohortCode rdf:type rdf:Property ;
    rdfs:label 'Cohort Code' ;
    rdfs:comment 'Code identifying the study cohort or stratum to which the subject belongs, used in stratified randomization designs. Distinct from treatment arm — a cohort may span multiple arms.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date on which the subject was formally enrolled into the clinical study following confirmation of eligibility and completion of informed consent. BUSINESS_EVENT_TIMESTAMP (date precision) for this enrollment transaction. Sourced from Oracle Siebel CTMS.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentType rdf:type rdf:Property ;
    rdfs:label 'Enrollment Type' ;
    rdfs:comment 'Classification of the enrollment event type. \'new\' = first-time enrollment in this study; \'re_enrolled\' = subject re-enrolled after a protocol-allowed break; \'rollover\' = subject rolled over from a preceding study; \'replacement\' = subject enrolled as a replacement per protocol.' ;
    rdfs:domain ind:Enrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstDoseDate rdf:type rdf:Property ;
    rdfs:label 'First Dose Date' ;
    rdfs:comment 'Date on which the subject received the first dose of investigational product (IP). Defines the start of the treatment-emergent period for TEAE analysis. Sourced from Medidata Rave EDC.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:icfSignedDate rdf:type rdf:Property ;
    rdfs:label 'Icf Signed Date' ;
    rdfs:comment 'Date on which the subject (or legally authorized representative) signed the Informed Consent Form (ICF), confirming voluntary agreement to participate. Must precede any study-specific procedures. Sourced from Clinpal eConsent.' ;
    rdfs:domain ind:Enrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ittFlag rdf:type rdf:Property ;
    rdfs:label 'Itt Flag' ;
    rdfs:comment 'Indicates whether the subject is included in the Intent-to-Treat (ITT) analysis population as defined in the Statistical Analysis Plan (SAP). True = subject is in the ITT population. Used by biostatistics for primary efficacy analysis.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppFlag rdf:type rdf:Property ;
    rdfs:label 'Pp Flag' ;
    rdfs:comment 'Indicates whether the subject is included in the Per Protocol (PP) analysis population as defined in the Statistical Analysis Plan (SAP). True = subject meets all protocol compliance criteria for PP inclusion.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:randomizationEligible rdf:type rdf:Property ;
    rdfs:label 'Randomization Eligible' ;
    rdfs:comment 'Indicates whether the subject has been confirmed as eligible for randomization following completion of the run-in or screening period. True = subject meets all randomization criteria per protocol. Sourced from Oracle Clinical One.' ;
    rdfs:domain ind:Enrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:screeningDate rdf:type rdf:Property ;
    rdfs:label 'Screening Date' ;
    rdfs:comment 'Date on which the subject first presented at the site and underwent initial screening procedures to assess eligibility for the study. Represents the first contact milestone in the subject lifecycle.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:screeningNumber rdf:type rdf:Property ;
    rdfs:label 'Screening Number' ;
    rdfs:comment 'Unique identifier assigned to the subject at the time of screening, prior to formal enrollment or randomization. Used to track subjects who may not proceed to enrollment. Sourced from Oracle Clinical One.' ;
    rdfs:domain ind:Subject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitCompliancePct rdf:type rdf:Property ;
    rdfs:label 'Visit Compliance Pct' ;
    rdfs:comment 'Percentage of required protocol visits completed by the subject relative to the total number of scheduled visits. Calculated as (completed visits / scheduled visits) × 100. Used for per-protocol population determination and site performance monitoring.' ;
    rdfs:domain ind:Enrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicalHistoryId rdf:type rdf:Property ;
    rdfs:label 'Medical History Id' ;
    rdfs:comment 'Unique surrogate identifier for each medical history record in the clinical trial system. Primary key for the medical_history data product.' ;
    rdfs:domain ind:MedicalHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:codedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Coded By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: MedDRA coding of medical history conditions must be attributed to the qualified coder for data quality audits, coding consistency reports, and regulatory submission traceability (SDTM MH domain). \'cod' ;
    rdfs:domain ind:MedicalHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:conditionCategory rdf:type rdf:Property ;
    rdfs:label 'Condition Category' ;
    rdfs:comment 'High-level category classifying the type of medical history entry. Corresponds to SDTM MHCAT variable. [ENUM-REF-CANDIDATE: MEDICAL HISTORY|SURGICAL HISTORY|FAMILY HISTORY|PSYCHIATRIC HISTORY|ALLERGY|OBSTETRIC HISTORY — promote to reference product]' ;
    rdfs:domain ind:MedicalHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionStatus rdf:type rdf:Property ;
    rdfs:label 'Condition Status' ;
    rdfs:comment 'Current clinical status of the pre-existing medical condition at the time of data collection. Supports safety profiling and eligibility determination.' ;
    rdfs:domain ind:MedicalHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionSubcategory rdf:type rdf:Property ;
    rdfs:label 'Condition Subcategory' ;
    rdfs:comment 'Optional secondary classification of the medical history condition providing further granularity within the category (e.g., CARDIOVASCULAR within MEDICAL HISTORY). Corresponds to SDTM MHSCAT.' ;
    rdfs:domain ind:MedicalHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionVerbatim rdf:type rdf:Property ;
    rdfs:label 'Condition Verbatim' ;
    rdfs:comment 'The verbatim (as-reported) text of the pre-existing medical condition or medical history event as entered by the investigator or CRC in the eCRF. This is the raw, uncoded term prior to MedDRA coding.' ;
    rdfs:domain ind:MedicalHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Eligibility Relevant Flag' ;
    rdfs:comment 'Indicates whether this medical history condition is relevant to the study\'s inclusion/exclusion eligibility criteria. Used by the medical monitor and data management team to assess protocol compliance.' ;
    rdfs:domain ind:MedicalHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meddraLlt rdf:type rdf:Property ;
    rdfs:label 'Meddra Llt' ;
    rdfs:comment 'The MedDRA Lowest Level Term (LLT) that most closely maps to the verbatim condition text. Provides the most granular level of MedDRA coding hierarchy.' ;
    rdfs:domain ind:MedicalHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mhSeq rdf:type rdf:Property ;
    rdfs:label 'Mh Seq' ;
    rdfs:comment 'Sequential number identifying each medical history record for a given subject within a study. Corresponds to the SDTM MHSEQ variable used in regulatory submissions.' ;
    rdfs:domain ind:MedicalHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preExistingFlag rdf:type rdf:Property ;
    rdfs:label 'Pre Existing Flag' ;
    rdfs:comment 'Indicates whether the condition was present prior to the subject\'s first dose of investigational product. Distinguishes pre-existing conditions from treatment-emergent adverse events (TEAEs) in safety analysis.' ;
    rdfs:domain ind:MedicalHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:populationAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Population Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each population assignment record in the Silver Layer lakehouse. Primary key for this transactional entity.' ;
    rdfs:domain ind:PopulationAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPopulationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Population Employee Id' ;
    rdfs:comment 'Reference to the biostatistician or statistical reviewer who determined and approved this population assignment. Supports ALCOA+ attributability requirements and audit trail for regulatory submissions.' ;
    rdfs:domain ind:PopulationAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByPopulationAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Population Assignment Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the newer population assignment record that supersedes this one (e.g., after a protocol amendment or SAP update). Null if this is the current active assignment. Supports assignment version history.' ;
    rdfs:domain ind:PopulationAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PopulationAssignment .

ind:adamFlagValue rdf:type rdf:Property ;
    rdfs:label 'Adam Flag Value' ;
    rdfs:comment 'The CDISC ADaM-compliant flag value (\'Y\' or \'N\') for the population flag variable, conforming to CDISC controlled terminology. Directly used in ADaM dataset generation for regulatory submissions.' ;
    rdfs:domain ind:PopulationAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adamPopulationFlagVariable rdf:type rdf:Property ;
    rdfs:label 'Adam Population Flag Variable' ;
    rdfs:comment 'The CDISC ADaM variable name corresponding to this population assignment (e.g., \'ITTFL\', \'SAFFL\', \'PPROTFL\', \'PKFL\'). Used to map Silver Layer records to SDTM/ADaM submission datasets for regulatory packages (NDA, BLA, MAA).' ;
    rdfs:domain ind:PopulationAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentDrivenFlag rdf:type rdf:Property ;
    rdfs:label 'Amendment Driven Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this population assignment was created or revised as a direct result of a protocol amendment. Supports impact analysis of protocol changes on analysis populations.' ;
    rdfs:domain ind:PopulationAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:analysisCutoffDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Cutoff Date' ;
    rdfs:comment 'The data cutoff date used to determine subject eligibility for this population assignment. All subject data up to and including this date was considered in the population determination.' ;
    rdfs:domain ind:PopulationAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Timestamp' ;
    rdfs:comment 'Precise date and time (ISO 8601 with timezone offset) when the population assignment record was created or last confirmed in the SAS Drug Development system. Supports 21 CFR Part 11 electronic record audit requirements.' ;
    rdfs:domain ind:PopulationAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consortFlowCategory rdf:type rdf:Property ;
    rdfs:label 'Consort Flow Category' ;
    rdfs:comment 'Category used to classify this subject\'s disposition in the CONSORT flow diagram (e.g., randomized, allocated, lost_to_followup, discontinued, analyzed, excluded). Required for CSR Section 10 and regulatory submission disposition tables.' ;
    rdfs:domain ind:PopulationAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Exclusion Reason Code' ;
    rdfs:comment 'Coded reason for exclusion from the analysis population when exclusion_flag is True (e.g., \'NO_DOSE\', \'MAJOR_PROTOCOL_DEVIATION\', \'CONSENT_WITHDRAWN\', \'ELIGIBILITY_CRITERIA_NOT_MET\'). Sourced from the Statistical Analysis Plan (SAP) exclusion criteria taxonomy. [ENUM-REF-CANDIDATE: NO_DOSE|MAJOR_PROTOCOL_DEVIATION|CONSENT_WITHDRAWN|ELIGIBILITY_CRITERIA_NOT_MET|MISSING_PRIMARY_ENDPOINT|WRONG_DIAGNOSIS — promote to reference product]' ;
    rdfs:domain ind:PopulationAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Exclusion Reason Description' ;
    rdfs:comment 'Verbatim or standardized narrative description of why the subject was excluded from this analysis population. Supports regulatory reviewer queries and CSR narrative sections.' ;
    rdfs:domain ind:PopulationAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Inclusion Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether the subject is included in this analysis population. True = subject meets all criteria and is included; False = subject is excluded. Directly maps to ADaM population flag variables (e.g., ITTFL, SAFFL, PPROTFL).' ;
    rdfs:domain ind:PopulationAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewerRole rdf:type rdf:Property ;
    rdfs:label 'Reviewer Role' ;
    rdfs:comment 'Role of the individual who performed or approved the population assignment (e.g., biostatistician, lead statistician, statistical programmer). Supports audit trail and responsibility tracking per GCP requirements.' ;
    rdfs:domain ind:PopulationAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorAssignmentRandomizationAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Prior Assignment Randomization Assignment Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the previous randomization assignment record that this record supersedes or replaces. Populated only when re_randomization_flag = True or assignment_status = \'replaced\'. Enables lineage tracking across re-randomization events.' ;
    rdfs:domain ind:RandomizationAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RandomizationAssignment .

ind:randomizationPerformedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Randomization Performed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: GCP requires randomization events to be attributed to the qualified staff member who performed them for audit trail, delegation log verification, and regulatory inspection. \'randomization_performed_by' ;
    rdfs:domain ind:RandomizationAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:randomizationConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Randomization Confirmed Flag' ;
    rdfs:comment 'Indicates whether the randomization assignment has been confirmed and accepted in the RTSM system (True) or is in a provisional/pending state (False). A confirmed assignment is the authoritative allocation record.' ;
    rdfs:domain ind:RandomizationAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reRandomizationFlag rdf:type rdf:Property ;
    rdfs:label 'Re Randomization Flag' ;
    rdfs:comment 'Indicates whether this assignment is a re-randomization event (True) rather than the initial randomization (False). Re-randomization may occur in crossover designs, adaptive trials, or following a protocol deviation that necessitates re-assignment.' ;
    rdfs:domain ind:RandomizationAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdtmRandfl rdf:type rdf:Property ;
    rdfs:label 'Sdtm Randfl' ;
    rdfs:comment 'CDISC SDTM-compliant randomization flag (Y/N) indicating whether the subject was randomized, as mapped to the DM.RANDFL variable. Populated during SDTM transformation to support regulatory submission datasets.' ;
    rdfs:domain ind:RandomizationAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stratificationFactor3Code rdf:type rdf:Property ;
    rdfs:label 'Stratification Factor 3 Code' ;
    rdfs:comment 'The code or value of the third stratification factor applied at randomization. Null if the study protocol defines fewer than three stratification factors.' ;
    rdfs:domain ind:RandomizationAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stipendPaymentId rdf:type rdf:Property ;
    rdfs:label 'Stipend Payment Id' ;
    rdfs:comment 'Unique surrogate identifier for each stipend or reimbursement payment record issued to a trial participant. Primary key of this table.' ;
    rdfs:domain ind:StipendPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'Amount formally authorized for disbursement following review and approval, which may differ from the requested amount if partial approval was granted or adjustments were made during the approval workflow.' ;
    rdfs:domain ind:StipendPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearedDate rdf:type rdf:Property ;
    rdfs:label 'Cleared Date' ;
    rdfs:comment 'Date on which the payment was confirmed as received and settled by the subject (e.g., check cashed, ACH settled, card loaded). Used for financial reconciliation and outstanding payment tracking.' ;
    rdfs:domain ind:StipendPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clincardTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Clincard Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier assigned by the Greenphire ClinCard payment platform for this disbursement. Used for reconciliation between the clinical trial management system and the ClinCard payment processor.' ;
    rdfs:domain ind:StipendPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsPaymentKey rdf:type rdf:Property ;
    rdfs:label 'Ctms Payment Key' ;
    rdfs:comment 'Source system record identifier from Oracle Siebel CTMS for this payment record. Enables bidirectional traceability between the lakehouse silver layer and the operational CTMS source system.' ;
    rdfs:domain ind:StipendPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbApprovedAmount rdf:type rdf:Property ;
    rdfs:label 'Irb Approved Amount' ;
    rdfs:comment 'The maximum per-visit or per-activity payment amount as approved by the Institutional Review Board (IRB) or Independent Ethics Committee (IEC) for this study. Used to validate that actual payments do not exceed approved thresholds and to support regulatory compliance.' ;
    rdfs:domain ind:StipendPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:irbPaymentScheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Irb Payment Schedule Version' ;
    rdfs:comment 'Version identifier of the IRB/IEC-approved payment schedule that governs this payment. Ensures traceability to the specific approved schedule in effect at the time of payment, supporting regulatory audit readiness.' ;
    rdfs:domain ind:StipendPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overIrbThresholdFlag rdf:type rdf:Property ;
    rdfs:label 'Over Irb Threshold Flag' ;
    rdfs:comment 'Indicates whether this payment exceeds the IRB/IEC-approved maximum payment amount for the associated visit or activity type. True triggers a compliance review workflow to ensure undue inducement rules are not violated.' ;
    rdfs:domain ind:StipendPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentNotes rdf:type rdf:Property ;
    rdfs:label 'Payment Notes' ;
    rdfs:comment 'Free-text field for additional context, special circumstances, or operational notes related to this payment (e.g., delayed payment justification, partial payment explanation, subject hardship accommodation). Not for audit trail entries.' ;
    rdfs:domain ind:StipendPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementRequestDate rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Request Date' ;
    rdfs:comment 'Date on which the subject or site submitted the reimbursement request or expense claim. Used to track processing turnaround time and ensure timely payment per protocol commitments.' ;
    rdfs:domain ind:StipendPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subjectCountryCode rdf:type rdf:Property ;
    rdfs:label 'Subject Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the subject\'s country of residence at the time of payment. Determines applicable tax reporting requirements, withholding rules, and regulatory jurisdiction for the payment.' ;
    rdfs:domain ind:StipendPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Reportable Flag' ;
    rdfs:comment 'Indicates whether this payment is subject to tax reporting obligations (e.g., IRS Form 1099-MISC for US subjects). True when the cumulative annual payments to the subject meet or exceed the IRS reporting threshold ($600 USD). Critical for US tax compliance.' ;
    rdfs:domain ind:StipendPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxYear rdf:type rdf:Property ;
    rdfs:label 'Tax Year' ;
    rdfs:comment 'Calendar year in which this payment was issued, used for IRS 1099 reporting period assignment and annual tax reporting aggregation for US subjects.' ;
    rdfs:domain ind:StipendPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visitTypeAtPayment rdf:type rdf:Property ;
    rdfs:label 'Visit Type At Payment' ;
    rdfs:comment 'Type of study visit associated with this payment (e.g., screening, baseline, treatment, follow-up, unscheduled). Captured at payment time to support payment schedule compliance analysis independent of visit record changes.' ;
    rdfs:domain ind:StipendPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidDate rdf:type rdf:Property ;
    rdfs:label 'Void Date' ;
    rdfs:comment 'Date on which the payment was voided or cancelled. Populated only when payment_status is \'voided\'. Required for financial reconciliation and audit trail.' ;
    rdfs:domain ind:StipendPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ytdPaymentTotal rdf:type rdf:Property ;
    rdfs:label 'Ytd Payment Total' ;
    rdfs:comment 'Cumulative total of all stipend and reimbursement payments made to this subject within the current calendar year across all studies, as of this payment. Used for IRS 1099 threshold tracking and tax reporting compliance for US subjects.' ;
    rdfs:domain ind:StipendPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subjectContactId rdf:type rdf:Property ;
    rdfs:label 'Subject Contact Id' ;
    rdfs:comment 'Unique surrogate identifier for the subject contact record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:SubjectContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addressVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Address Verified Date' ;
    rdfs:comment 'Date on which the subject\'s home address was last verified by site staff. Supports ALCOA+ data quality requirements and ensures contact information is current for safety follow-up.' ;
    rdfs:domain ind:SubjectContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addressVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Address Verified Flag' ;
    rdfs:comment 'Indicates whether the subject\'s home address has been verified by site staff or through an address validation service. True = address confirmed; False = address unverified or pending confirmation.' ;
    rdfs:domain ind:SubjectContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Flag' ;
    rdfs:comment 'Indicates whether the subject has provided explicit consent to be contacted for study-related communications (visit reminders, follow-up calls). True = consent granted; False = consent not granted or withdrawn. Governed by GDPR and HIPAA privacy requirements.' ;
    rdfs:domain ind:SubjectContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentWithdrawnDate rdf:type rdf:Property ;
    rdfs:label 'Consent Withdrawn Date' ;
    rdfs:comment 'Date on which the subject withdrew consent for contact communications. Null if consent has not been withdrawn. Once populated, all non-safety-critical outreach must cease per GDPR right to withdraw.' ;
    rdfs:domain ind:SubjectContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:doNotContactFlag rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact Flag' ;
    rdfs:comment 'Hard stop flag indicating the subject must not be contacted under any circumstances (excluding mandatory safety communications). True = do not contact; False = contact permitted per consent settings. Overrides all other contact preferences.' ;
    rdfs:domain ind:SubjectContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Email Consent Flag' ;
    rdfs:comment 'Indicates whether the subject has specifically consented to receive communications via email. True = email contact permitted; False = email contact not permitted. Distinct from general contact consent as email may carry additional regulatory requirements.' ;
    rdfs:domain ind:SubjectContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Name' ;
    rdfs:comment 'Full name of the subject\'s designated emergency contact person. Used by site staff to reach a responsible party in the event of a serious adverse event (SAE) or medical emergency.' ;
    rdfs:domain ind:SubjectContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment 'Phone number for the subject\'s emergency contact. Used exclusively for safety-related communications and serious adverse event (SAE) follow-up.' ;
    rdfs:domain ind:SubjectContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactRelationship rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Relationship' ;
    rdfs:comment 'Relationship of the emergency contact person to the subject (e.g., spouse, parent, legal guardian). Provides context for site staff when initiating emergency communications. [ENUM-REF-CANDIDATE: spouse|parent|child|sibling|friend|caregiver|legal_guardian|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SubjectContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContactMethod rdf:type rdf:Property ;
    rdfs:label 'Last Contact Method' ;
    rdfs:comment 'Communication channel used during the most recent successful contact with the subject. Supports analysis of effective outreach strategies and visit compliance improvement.' ;
    rdfs:domain ind:SubjectContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactTime rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Time' ;
    rdfs:comment 'Subject\'s preferred time of day to be contacted. Supports scheduling of outreach calls and reminders to maximize response rates and respect subject preferences.' ;
    rdfs:domain ind:SubjectContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:primaryPhoneType rdf:type rdf:Property ;
    rdfs:label 'Primary Phone Type' ;
    rdfs:comment 'Classification of the primary phone number (e.g., mobile, home, work). Informs the appropriate time and method for outreach.' ;
    rdfs:domain ind:SubjectContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordType rdf:type rdf:Property ;
    rdfs:label 'Record Type' ;
    rdfs:comment 'Classification of the contact record indicating the role of the contact in relation to the subject. \'primary\' is the subject themselves; \'secondary\' is an alternate contact; \'emergency\' is for emergency use only; \'caregiver\' is a designated caregiver; \'legal_representative\' is a legally authorized representative.' ;
    rdfs:domain ind:SubjectContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyContactOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Contact Override Flag' ;
    rdfs:comment 'Indicates whether safety-critical communications (e.g., SAE follow-up, urgent safety notifications) are permitted even when do_not_contact_flag is True. True = safety contact allowed regardless of general consent; False = all contact restricted. Supports regulatory obligation to notify subjects of safety findings.' ;
    rdfs:domain ind:SubjectContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:secondaryPhoneType rdf:type rdf:Property ;
    rdfs:label 'Secondary Phone Type' ;
    rdfs:comment 'Classification of the secondary phone number (e.g., mobile, home, work).' ;
    rdfs:domain ind:SubjectContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Sms Consent Flag' ;
    rdfs:comment 'Indicates whether the subject has specifically consented to receive communications via SMS/text message. True = SMS contact permitted; False = SMS contact not permitted.' ;
    rdfs:domain ind:SubjectContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemContactKey rdf:type rdf:Property ;
    rdfs:label 'Source System Contact Key' ;
    rdfs:comment 'Natural key or unique identifier of this contact record in the originating source system (Clinpal or Oracle Siebel CTMS). Enables bidirectional traceability and reconciliation between the lakehouse Silver Layer and the operational system.' ;
    rdfs:domain ind:SubjectContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDeviationClassificationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Deviation Classification Id' ;
    rdfs:comment 'Foreign key linking to compliance.deviation_classification. Business justification: GCP compliance requires every subject deviation to be classified against a standard taxonomy to determine regulatory reporting obligations, CAPA triggers, and CSR inclusion. The deviation_classificati' ;
    rdfs:domain ind:SubjectDeviation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeviationClassification .

ind:irbIecReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Reportable Flag' ;
    rdfs:comment 'Indicates whether this deviation must be reported to the Institutional Review Board (IRB) or Independent Ethics Committee (IEC) overseeing the study. Separate from regulatory authority reportability. True = must report to IRB/IEC.' ;
    rdfs:domain ind:SubjectDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:piAwareDate rdf:type rdf:Property ;
    rdfs:label 'Pi Aware Date' ;
    rdfs:comment 'The date on which the Principal Investigator (PI) was informed of the deviation. Used to track compliance with site notification requirements.' ;
    rdfs:domain ind:SubjectDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:piAwareFlag rdf:type rdf:Property ;
    rdfs:label 'Pi Aware Flag' ;
    rdfs:comment 'Indicates whether the Principal Investigator (PI) at the site has been made aware of this deviation. True = PI has been informed. Required for GCP compliance as the PI bears ultimate responsibility for conduct of the trial at the site.' ;
    rdfs:domain ind:SubjectDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorNotifiedDate rdf:type rdf:Property ;
    rdfs:label 'Sponsor Notified Date' ;
    rdfs:comment 'The date on which the sponsor was formally notified of the deviation. Used to verify compliance with contractual and regulatory notification timelines.' ;
    rdfs:domain ind:SubjectDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subjectContinuationDecision rdf:type rdf:Property ;
    rdfs:label 'Subject Continuation Decision' ;
    rdfs:comment 'Decision regarding the subject\'s continued participation in the study following the deviation. Informs subject disposition tracking and intent-to-treat (ITT) and per-protocol (PP) population assignments.' ;
    rdfs:domain ind:SubjectDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectRightsImpact rdf:type rdf:Property ;
    rdfs:label 'Subject Rights Impact' ;
    rdfs:comment 'Assessment of whether the deviation affected the rights or well-being of the trial subject, including informed consent procedures, privacy protections, or voluntary participation rights.' ;
    rdfs:domain ind:SubjectDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeCode rdf:type rdf:Property ;
    rdfs:label 'Type Code' ;
    rdfs:comment 'Standardized code identifying the specific type of protocol deviation (e.g., eligibility criteria violation, missed visit, incorrect dosing, prohibited medication use, consent procedure deviation). Sourced from the MasterControl deviation classification taxonomy. [ENUM-REF-CANDIDATE: ELIG_CRIT|MISSED_VISIT|INCORRECT_DOSE|PROHIBITED_MED|CONSENT_PROC|RANDOMIZATION|SAMPLE_TIMING|WASHOUT|CONCOMITANT_MED|ENDPOINT_ASSESS — promote to reference product]' ;
    rdfs:domain ind:SubjectDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeDescription rdf:type rdf:Property ;
    rdfs:label 'Type Description' ;
    rdfs:comment 'Human-readable label corresponding to the deviation_type_code, providing a plain-language description of the deviation type for reporting and review purposes.' ;
    rdfs:domain ind:SubjectDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectStatusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Subject Status History Id' ;
    rdfs:comment 'Unique surrogate identifier for each subject status transition record in the lifecycle history table. Primary key for the subject_status_history data product.' ;
    rdfs:domain ind:SubjectStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySubjectEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Subject Employee Id' ;
    rdfs:comment 'The system user (CRC, CRA, PI, or system account) who initiated or recorded this status transition in the source system. Supports 21 CFR Part 11 electronic signature audit trail and ALCOA+ attributability requirements.' ;
    rdfs:domain ind:SubjectStatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:dispositionCategory rdf:type rdf:Property ;
    rdfs:label 'Disposition Category' ;
    rdfs:comment 'High-level classification of the disposition event type associated with this status transition. Used for regulatory reporting in the CDISC SDTM DS domain and for subject flow summaries in Clinical Study Reports (CSRs). [ENUM-REF-CANDIDATE: screen-failure|early-termination|completion|randomization|enrollment|withdrawal|protocol-deviation — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SubjectStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTerminalStatus rdf:type rdf:Property ;
    rdfs:label 'Is Terminal Status' ;
    rdfs:comment 'Indicates whether the new_status represents a terminal (end-state) disposition for the subject in this study. True = the subject has reached a final state (completed, withdrawn, screen-failed, lost-to-follow-up) with no further expected transitions.' ;
    rdfs:domain ind:SubjectStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorStatus rdf:type rdf:Property ;
    rdfs:label 'Prior Status' ;
    rdfs:comment 'The subject\'s enrollment lifecycle status immediately before this transition event. Together with new_status, defines the state transition vector for longitudinal subject flow analysis. [ENUM-REF-CANDIDATE: pre-screened|screened|screen-failed|enrolled|randomized|on-treatment|completed|withdrawn|lost-to-follow-up|discontinued — promote to reference product]' ;
    rdfs:domain ind:SubjectStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordKey rdf:type rdf:Property ;
    rdfs:label 'Source System Record Key' ;
    rdfs:comment 'The native primary key or unique identifier of this status transition record in the originating source system (Oracle Clinical One or Medidata Rave). Enables traceability back to the system of record for reconciliation and audit purposes.' ;
    rdfs:domain ind:SubjectStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeredBySystem rdf:type rdf:Property ;
    rdfs:label 'Triggered By System' ;
    rdfs:comment 'Identifies whether the status transition was triggered by a human user or an automated system process, and which source system initiated it (Oracle Clinical One, Medidata Rave, IRT/RTSM). Supports data lineage and audit trail requirements.' ;
    rdfs:domain ind:SubjectStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeredByUserRole rdf:type rdf:Property ;
    rdfs:label 'Triggered By User Role' ;
    rdfs:comment 'The clinical role of the user who triggered this status transition (e.g., CRC - Clinical Research Coordinator, CRA - Clinical Research Associate, PI - Principal Investigator). Supports audit trail completeness and role-based accountability per GCP. [ENUM-REF-CANDIDATE: CRC|CRA|PI|sub-investigator|sponsor|system|data-manager — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SubjectStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualVisitEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual Visit End Date' ;
    rdfs:comment 'The actual calendar date on which the visit concluded, applicable for multi-day visits or inpatient stays. Maps to SVENDTC in CDISC SDTM SV domain. Null for single-day visits.' ;
    rdfs:domain ind:SubjectVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysFromPlanned rdf:type rdf:Property ;
    rdfs:label 'Days From Planned' ;
    rdfs:comment 'Signed integer representing the deviation in days between the actual visit date and the planned visit date (actual minus planned). Negative values indicate early visits; positive values indicate late visits. Zero indicates on-schedule. Used for visit compliance analytics and protocol deviation assessment.' ;
    rdfs:domain ind:SubjectVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:informedConsentVerified rdf:type rdf:Property ;
    rdfs:label 'Informed Consent Verified' ;
    rdfs:comment 'Indicates whether a valid, signed Informed Consent Form (ICF) was confirmed on file prior to this visit (True) or not (False). Critical GCP compliance requirement; absence may constitute a major protocol deviation.' ;
    rdfs:domain ind:SubjectVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isScheduled rdf:type rdf:Property ;
    rdfs:label 'Is Scheduled' ;
    rdfs:comment 'Indicates whether this visit was a protocol-scheduled visit (True) or an unscheduled/ad-hoc visit not defined in the protocol schedule of assessments (False). Unscheduled visits may indicate safety events or protocol deviations.' ;
    rdfs:domain ind:SubjectVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:missedReason rdf:type rdf:Property ;
    rdfs:label 'Missed Reason' ;
    rdfs:comment 'Free-text or coded reason explaining why a scheduled visit was missed by the subject (e.g., subject unavailable, adverse event, travel, withdrew consent, site closure). Populated only when visit_status is \'missed\'. Required for protocol deviation assessment and regulatory reporting.' ;
    rdfs:domain ind:SubjectVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:missedReasonCode rdf:type rdf:Property ;
    rdfs:label 'Missed Reason Code' ;
    rdfs:comment 'Standardized coded value for the reason a scheduled visit was missed, aligned with sponsor or protocol-defined coding scheme. Complements missed_reason free text for structured analytics and regulatory submissions.' ;
    rdfs:domain ind:SubjectVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queryCount rdf:type rdf:Property ;
    rdfs:label 'Query Count' ;
    rdfs:comment 'Number of open data discrepancy queries (DCFs) associated with this visit\'s eCRF data in the EDC system. Used for data quality monitoring and site performance tracking. Non-zero values may block database lock.' ;
    rdfs:domain ind:SubjectVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemVisitKey rdf:type rdf:Property ;
    rdfs:label 'Source System Visit Key' ;
    rdfs:comment 'The native primary key or unique identifier for this visit record in the originating source system (e.g., Medidata Rave visit OID, Siebel CTMS visit row ID). Enables traceability and reconciliation between the lakehouse Silver layer and the system of record.' ;
    rdfs:domain ind:SubjectVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitCode rdf:type rdf:Property ;
    rdfs:label 'Visit Code' ;
    rdfs:comment 'Protocol-defined alphanumeric code uniquely identifying the visit within the study schedule (e.g., SCR, BL, V01, V02, ET, EOS). Maps to VISITNUM/VISIT in CDISC SDTM SV domain. Used as the externally-known business identifier for the visit.' ;
    rdfs:domain ind:SubjectVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:week rdf:type rdf:Property ;
    rdfs:label 'Week' ;
    rdfs:comment 'The nominal study week associated with this visit as defined in the protocol schedule of assessments (e.g., Week 1, Week 4, Week 12). Used for time-point labeling in biostatistical analyses and ADaM dataset derivations.' ;
    rdfs:domain ind:SubjectVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windowCloseDate rdf:type rdf:Property ;
    rdfs:label 'Window Close Date' ;
    rdfs:comment 'The latest acceptable date for the visit to occur per the protocol-defined visit window (planned date plus the allowed late deviation in days). Used to determine visit window compliance status.' ;
    rdfs:domain ind:SubjectVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:windowComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Window Compliance Status' ;
    rdfs:comment 'Indicates whether the actual visit date fell within the protocol-defined visit window, occurred early (before window open), occurred late (after window close), was missed entirely, or is not applicable (e.g., unscheduled visits). Critical for protocol deviation identification and monitoring trigger logic.' ;
    rdfs:domain ind:SubjectVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowOpenDate rdf:type rdf:Property ;
    rdfs:label 'Window Open Date' ;
    rdfs:comment 'The earliest acceptable date for the visit to occur per the protocol-defined visit window (planned date minus the allowed early deviation in days). Used to determine visit window compliance status.' ;
    rdfs:domain ind:SubjectVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ageAtEnrollment rdf:type rdf:Property ;
    rdfs:label 'Age At Enrollment' ;
    rdfs:comment 'Subject\'s age in years at the time of enrollment or first dose, calculated from date of birth and enrollment date. Used for eligibility verification, demographic reporting, and subgroup analyses. Stored as a derived-at-source value from Oracle Clinical One.' ;
    rdfs:domain ind:TrialSubject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataLockFlag rdf:type rdf:Property ;
    rdfs:label 'Data Lock Flag' ;
    rdfs:comment 'Indicates whether the subject\'s data has been locked as part of the Database Lock (DBL) process, preventing further modifications to the subject\'s eCRF data. True = subject data locked; False = data still open for entry or query resolution. Critical for CSR preparation and regulatory submission readiness.' ;
    rdfs:domain ind:TrialSubject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Eligible Flag' ;
    rdfs:comment 'Indicates whether the subject met all inclusion and exclusion criteria as assessed during screening. True = all eligibility criteria confirmed met; False = one or more criteria not met. Sourced from Oracle Clinical One eligibility assessment.' ;
    rdfs:domain ind:TrialSubject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seriousAdverseEventFlag rdf:type rdf:Property ;
    rdfs:label 'Serious Adverse Event Flag' ;
    rdfs:comment 'Indicates whether the subject has experienced at least one Serious Adverse Event (SAE) during the study. True = one or more SAEs reported; False = no SAEs. Summary flag for subject-level safety profiling; detailed SAE records are managed in Oracle Argus Safety.' ;
    rdfs:domain ind:TrialSubject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSubjectKey rdf:type rdf:Property ;
    rdfs:label 'Source Subject Key' ;
    rdfs:comment 'The native primary key or identifier for this subject record in the originating operational system (e.g., Medidata Rave subject OID, Oracle Clinical One patient ID). Enables bidirectional traceability between the lakehouse Silver layer and the source system for reconciliation and audit purposes.' ;
    rdfs:domain ind:TrialSubject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Subject Source System' ;
    rdfs:comment 'Identifies the operational system of record from which this subject record was sourced or is mastered (e.g., Medidata Rave EDC, Oracle Clinical One, Oracle Siebel CTMS). Supports data lineage, reconciliation, and ALCOA+ compliance tracing.' ;
    rdfs:domain ind:TrialSubject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:craEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Cra Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: GCP requires the CRA who signs off on IMP accountability reconciliation to be a traceable, qualified employee. This FK supports inspection-ready audit trails and CRA performance reporting. cra_name is' ;
    rdfs:domain ind:AccountabilityReconciliation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualClosingBalanceUnits rdf:type rdf:Property ;
    rdfs:label 'Actual Closing Balance Units' ;
    rdfs:comment 'Physical count of IMP units on hand at the site at the end of the reconciliation period, as verified by the site staff and/or CRA during the monitoring visit. This is the ground-truth inventory count.' ;
    rdfs:domain ind:AccountabilityReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustedUnits rdf:type rdf:Property ;
    rdfs:label 'Adjusted Units' ;
    rdfs:comment 'Net quantity adjustment applied to the reconciliation (positive or negative) to account for documented corrections such as data entry errors, kit relabeling, or sponsor-approved adjustments. Zero if no adjustments were made.' ;
    rdfs:domain ind:AccountabilityReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:craSignoffDate rdf:type rdf:Property ;
    rdfs:label 'Cra Signoff Date' ;
    rdfs:comment 'The date on which the CRA / monitor signed off on this drug accountability reconciliation. Null if cra_signoff_flag is False.' ;
    rdfs:domain ind:AccountabilityReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:craSignoffFlag rdf:type rdf:Property ;
    rdfs:label 'Cra Signoff Flag' ;
    rdfs:comment 'Indicates whether the Clinical Research Associate (CRA) / monitor has reviewed and signed off on this drug accountability reconciliation record. True = signed; False = pending. Required at every monitoring visit per ICH E6(R2).' ;
    rdfs:domain ind:AccountabilityReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destroyedUnits rdf:type rdf:Property ;
    rdfs:label 'Destroyed Units' ;
    rdfs:comment 'Total quantity of IMP units destroyed at the site or returned to depot for destruction during the reconciliation period. Destruction must be documented per sponsor SOP and applicable regulations.' ;
    rdfs:domain ind:AccountabilityReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discrepancyDetail rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Detail' ;
    rdfs:comment 'Free-text narrative describing the nature, root cause, and resolution status of identified discrepancies. Captured by the CRA or site staff. Required when discrepancy_count > 0. Supports regulatory inspection readiness and CAPA documentation.' ;
    rdfs:domain ind:AccountabilityReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyResolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Resolution Status' ;
    rdfs:comment 'Current resolution status of identified discrepancies. \'not_applicable\' = no discrepancy found; \'open\' = discrepancy identified, investigation not started; \'under_investigation\' = root cause analysis in progress; \'resolved\' = discrepancy explained and documented; \'escalated\' = referred to sponsor QA or regulatory authority.' ;
    rdfs:domain ind:AccountabilityReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyUnits rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Units' ;
    rdfs:comment 'Quantity difference between expected_closing_balance_units and actual_closing_balance_units (actual minus expected). A non-zero value triggers discrepancy investigation. Positive = surplus; negative = shortage.' ;
    rdfs:domain ind:AccountabilityReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispensedUnits rdf:type rdf:Property ;
    rdfs:label 'Dispensed Units' ;
    rdfs:comment 'Total quantity of IMP units dispensed to subjects at the site during the reconciliation period. Sourced from dispensing records in Medidata Rave RTSM and eCRF dispensing logs.' ;
    rdfs:domain ind:AccountabilityReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedClosingBalanceUnits rdf:type rdf:Property ;
    rdfs:label 'Expected Closing Balance Units' ;
    rdfs:comment 'Calculated expected closing balance: opening_balance_units + received_units - dispensed_units + returned_units - destroyed_units + adjusted_units. Used as the reference value against which the physical count is compared to identify discrepancies.' ;
    rdfs:domain ind:AccountabilityReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expiredUnitsCount rdf:type rdf:Property ;
    rdfs:label 'Expired Units Count' ;
    rdfs:comment 'Number of IMP units that had expired as of the reconciliation period end date. Expired units must be quarantined and destroyed per sponsor SOP; their presence in usable inventory constitutes a protocol deviation.' ;
    rdfs:domain ind:AccountabilityReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expiryDateEarliest rdf:type rdf:Property ;
    rdfs:label 'Expiry Date Earliest' ;
    rdfs:comment 'The earliest expiry date among all IMP units currently on hand at the site as of the reconciliation period end date. Used to flag impending expiry risk and trigger resupply or destruction actions.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gcpComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Gcp Compliance Flag' ;
    rdfs:comment 'Indicates whether this reconciliation record is fully compliant with GCP §8.3.13 requirements (both investigator and CRA sign-offs obtained, no unresolved discrepancies, all required fields populated). True = compliant; False = non-compliant or pending.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigatorName rdf:type rdf:Property ;
    rdfs:label 'Investigator Name' ;
    rdfs:comment 'Full name of the Principal Investigator (PI) who signed off on this reconciliation. Captured at time of sign-off for audit trail integrity per ALCOA+ principles. Confidential as it identifies a named professional in a regulatory context.' ;
    rdfs:domain ind:AccountabilityReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigatorSignoffDate rdf:type rdf:Property ;
    rdfs:label 'Investigator Signoff Date' ;
    rdfs:comment 'The date on which the Principal Investigator (PI) or delegated sub-investigator signed off on this drug accountability reconciliation. Null if investigator_signoff_flag is False.' ;
    rdfs:domain ind:AccountabilityReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigatorSignoffFlag rdf:type rdf:Property ;
    rdfs:label 'Investigator Signoff Flag' ;
    rdfs:comment 'Indicates whether the Principal Investigator (PI) or delegated sub-investigator has reviewed and signed off on this drug accountability reconciliation record. True = signed; False = pending. Required for GCP compliance and regulatory inspection readiness.' ;
    rdfs:domain ind:AccountabilityReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextReconciliationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Reconciliation Due Date' ;
    rdfs:comment 'The scheduled due date for the next drug accountability reconciliation at this site for this IMP. Derived from the monitoring visit schedule or protocol-defined reconciliation frequency. Used for proactive compliance tracking.' ;
    rdfs:domain ind:AccountabilityReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openingBalanceUnits rdf:type rdf:Property ;
    rdfs:label 'Opening Balance Units' ;
    rdfs:comment 'The quantity of IMP units (e.g., tablets, vials, kits) on hand at the site at the start of the reconciliation period. Carried forward from the closing balance of the prior reconciliation period or from the initial receipt if this is the first period.' ;
    rdfs:domain ind:AccountabilityReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivedUnits rdf:type rdf:Property ;
    rdfs:label 'Received Units' ;
    rdfs:comment 'Total quantity of IMP units received at the site from the depot or sponsor during the reconciliation period. Sourced from shipment receipt records in Medidata Rave RTSM.' ;
    rdfs:domain ind:AccountabilityReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnedUnits rdf:type rdf:Property ;
    rdfs:label 'Returned Units' ;
    rdfs:comment 'Total quantity of IMP units returned from subjects to the site (unused or partially used) during the reconciliation period. Includes returns captured in Medidata Rave RTSM return logs.' ;
    rdfs:domain ind:AccountabilityReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rtsmReconciliationRef rdf:type rdf:Property ;
    rdfs:label 'Rtsm Reconciliation Ref' ;
    rdfs:comment 'The reconciliation reference or transaction identifier assigned by the Randomization and Trial Supply Management (RTSM) system (Medidata Rave) for this accountability event. Enables traceability back to the source system record.' ;
    rdfs:domain ind:AccountabilityReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Source Document Ref' ;
    rdfs:comment 'Reference identifier for the physical or electronic source document (e.g., drug accountability log, dispensing record binder, eTMF artifact ID in Veeva Vault) that supports this reconciliation record. Required for SDV and regulatory inspection.' ;
    rdfs:domain ind:AccountabilityReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ancillarySupplyId rdf:type rdf:Property ;
    rdfs:label 'Ancillary Supply Id' ;
    rdfs:comment 'Unique surrogate identifier for each ancillary supply record in the clinical trial supply chain. Primary key for the ancillary_supply data product.' ;
    rdfs:domain ind:AncillarySupply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Accountability Status' ;
    rdfs:comment 'Current reconciliation status of the ancillary supply accountability record. Indicates whether the received, dispensed, returned, and destroyed quantities have been fully reconciled per GCP requirements.' ;
    rdfs:domain ind:AncillarySupply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ancillarySupplyStatus rdf:type rdf:Property ;
    rdfs:label 'Ancillary Supply Status' ;
    rdfs:comment 'Current lifecycle status of the ancillary supply item at the site or study level. Drives reorder triggers, site communications, and supply chain planning actions.' ;
    rdfs:domain ind:AncillarySupply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code indicating the country where the ancillary supply was manufactured. Required for import/export regulatory compliance and customs documentation.' ;
    rdfs:domain ind:AncillarySupply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsSupplyReference rdf:type rdf:Property ;
    rdfs:label 'Ctms Supply Reference' ;
    rdfs:comment 'Reference identifier for this ancillary supply record in Oracle Siebel CTMS. Supports cross-system traceability between supply chain operations and site management activities.' ;
    rdfs:domain ind:AncillarySupply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Current Stock Quantity' ;
    rdfs:comment 'Current on-hand inventory quantity of the ancillary supply at the assigned site, expressed in the defined unit of measure. Updated upon receipt of shipments and dispensing events.' ;
    rdfs:domain ind:AncillarySupply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destroyedQuantity rdf:type rdf:Property ;
    rdfs:label 'Destroyed Quantity' ;
    rdfs:comment 'Quantity of ancillary supply that has been destroyed at the site or depot due to expiry, damage, or protocol requirements. Supports accountability reconciliation and destruction certificate documentation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispensedQuantity rdf:type rdf:Property ;
    rdfs:label 'Dispensed Quantity' ;
    rdfs:comment 'Cumulative quantity of this ancillary supply dispensed to subjects or consumed in study procedures since last receipt. Used for accountability reconciliation and waste analysis.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isColdChain rdf:type rdf:Property ;
    rdfs:label 'Is Cold Chain' ;
    rdfs:comment 'Indicates whether this ancillary supply requires cold-chain logistics management during storage and shipment. When true, temperature-controlled packaging and monitoring are mandatory.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPatientFacing rdf:type rdf:Property ;
    rdfs:label 'Is Patient Facing' ;
    rdfs:comment 'Indicates whether this ancillary supply is directly used by or administered to study subjects (e.g., patient diaries, injection devices). Patient-facing supplies may require additional labeling and consent documentation.' ;
    rdfs:domain ind:AncillarySupply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProtocolRequired rdf:type rdf:Property ;
    rdfs:label 'Is Protocol Required' ;
    rdfs:comment 'Indicates whether this ancillary supply is explicitly mandated by the study protocol. Protocol-required supplies must be tracked for accountability and regulatory inspection readiness.' ;
    rdfs:domain ind:AncillarySupply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Label Language Code' ;
    rdfs:comment 'ISO 639-1 language code (optionally with ISO 3166-1 country subtag) of the ancillary supply label (e.g., \'en\', \'fr\', \'de-DE\'). Ensures site-appropriate labeling for multi-national trials.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelText rdf:type rdf:Property ;
    rdfs:label 'Label Text' ;
    rdfs:comment 'Full text content of the label applied to the ancillary supply packaging as required by the protocol and applicable regulations. Supports label review, audit, and regulatory inspection readiness.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDispensedDate rdf:type rdf:Property ;
    rdfs:label 'Last Dispensed Date' ;
    rdfs:comment 'Date on which this ancillary supply was most recently dispensed to a study subject or used in a study procedure. Supports usage tracking and expiry risk assessment.' ;
    rdfs:domain ind:AncillarySupply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastShipmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Shipment Date' ;
    rdfs:comment 'Date of the most recent shipment of this ancillary supply to the site. Used to monitor supply chain activity, identify sites with stale stock, and support resupply planning.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'Manufacturer\'s own catalogue or part number for the ancillary supply. Used for procurement ordering, quality investigations, and cross-referencing with supplier documentation.' ;
    rdfs:domain ind:AncillarySupply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxStorageTempC rdf:type rdf:Property ;
    rdfs:label 'Max Storage Temp C' ;
    rdfs:comment 'Maximum allowable storage temperature in degrees Celsius for this ancillary supply. Paired with min_storage_temp_c to define the acceptable temperature range for storage and transport.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Quantity' ;
    rdfs:comment 'Upper inventory limit for this ancillary supply at the site. Prevents overstocking, reduces waste from expiry, and supports cold-chain capacity planning.' ;
    rdfs:domain ind:AncillarySupply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minStorageTempC rdf:type rdf:Property ;
    rdfs:label 'Min Storage Temp C' ;
    rdfs:comment 'Minimum allowable storage temperature in degrees Celsius for this ancillary supply. Used for cold-chain monitoring, excursion detection, and GCP compliance reporting.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packSize rdf:type rdf:Property ;
    rdfs:label 'Pack Size' ;
    rdfs:comment 'Number of individual units contained within one ordering/shipping pack of the ancillary supply. Used to convert between pack-level and unit-level inventory quantities.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:procurementLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Procurement Lead Time Days' ;
    rdfs:comment 'Number of days required from placement of a purchase order to receipt of the ancillary supply at the site or depot. Used for reorder planning and supply continuity risk management.' ;
    rdfs:domain ind:AncillarySupply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reorderQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Quantity' ;
    rdfs:comment 'Standard quantity to be ordered when the reorder threshold is reached. Represents the economic order quantity agreed with the supplier or depot for this ancillary supply.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnedQuantity rdf:type rdf:Property ;
    rdfs:label 'Returned Quantity' ;
    rdfs:comment 'Quantity of ancillary supply returned from the site to the depot or sponsor for destruction or reuse. Required for accountability reconciliation and regulatory compliance.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rtsmSupplyCode rdf:type rdf:Property ;
    rdfs:label 'Rtsm Supply Code' ;
    rdfs:comment 'Identifier assigned to this ancillary supply item within the Medidata Rave RTSM system. Enables cross-system reconciliation between the lakehouse silver layer and the operational RTSM source of record.' ;
    rdfs:domain ind:AncillarySupply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Total shelf life of the ancillary supply in days from the date of manufacture or receipt. Used to calculate expiry dates and plan supply replenishment schedules.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplyCategory rdf:type rdf:Property ;
    rdfs:label 'Supply Category' ;
    rdfs:comment 'Broader classification grouping ancillary supplies by regulatory or operational category (e.g., medical_device, consumable, diagnostic). Determines applicable regulatory labeling and handling requirements distinct from IMP accountability rules.' ;
    rdfs:domain ind:AncillarySupply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyCode rdf:type rdf:Property ;
    rdfs:label 'Supply Code' ;
    rdfs:comment 'Externally-known unique catalogue or part number assigned to this ancillary supply item by the sponsor or procurement system (e.g., SAP S/4HANA material number). Used for cross-system reconciliation and procurement ordering.' ;
    rdfs:domain ind:AncillarySupply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyName rdf:type rdf:Property ;
    rdfs:label 'Supply Name' ;
    rdfs:comment 'Human-readable name of the ancillary supply item (e.g., \'Insulin Syringe 1mL\', \'Sodium Chloride Diluent 0.9%\', \'Patient Diary Booklet\'). Used in site communications, shipment manifests, and accountability reports.' ;
    rdfs:domain ind:AncillarySupply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplyType rdf:type rdf:Property ;
    rdfs:label 'Supply Type' ;
    rdfs:comment 'Categorical classification of the ancillary supply item indicating its functional role in the clinical trial protocol. Drives procurement, labeling, and accountability rules. [ENUM-REF-CANDIDATE: syringe|diluent|infusion_set|patient_diary|lab_kit|swab|bandage|other — promote to reference product]' ;
    rdfs:domain ind:AncillarySupply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifiedPersonEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Qualified Person Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Comparator drugs used in clinical trials require QP certification under EU GMP Annex 13. Linking to employee enables QP qualification verification and GMP compliance reporting for comparator IMP. qual' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedCountries rdf:type rdf:Property ;
    rdfs:label 'Approved Countries' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where the comparator drug holds a valid marketing authorisation or regulatory approval. Used to validate site-level dispensing eligibility and import compliance.' ;
    rdfs:domain ind:ComparatorDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugCode rdf:type rdf:Property ;
    rdfs:label 'Drug Code' ;
    rdfs:comment 'Internally assigned alphanumeric code uniquely identifying this comparator drug or placebo within the clinical supply catalogue. Serves as the IDENTITY_LABEL / BUSINESS_IDENTIFIER for cross-system reference.' ;
    rdfs:domain ind:ComparatorDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugStatus rdf:type rdf:Property ;
    rdfs:label 'Drug Status' ;
    rdfs:comment 'Current lifecycle status of the comparator drug master record. LIFECYCLE_STATUS for MASTER_RESOURCE role. \'quarantined\' indicates the product is on hold pending quality investigation.' ;
    rdfs:domain ind:ComparatorDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formulationDescription rdf:type rdf:Property ;
    rdfs:label 'Formulation Description' ;
    rdfs:comment 'Narrative description of the comparator drug formulation including excipients, vehicle, and any special formulation characteristics relevant to blinding, matching, or stability. Sourced from the product SmPC or Certificate of Analysis.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Gmp Certificate Number' ;
    rdfs:comment 'Reference number of the current Good Manufacturing Practice (GMP) certificate issued by the relevant regulatory authority for the manufacturing site producing the comparator drug. Required for import authorisation and regulatory submissions.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importLicenceRequired rdf:type rdf:Property ;
    rdfs:label 'Import Licence Required' ;
    rdfs:comment 'Indicates whether an import licence or import authorisation is required to ship the comparator drug into the trial countries. True triggers the regulatory affairs team to obtain the necessary import documentation prior to shipment.' ;
    rdfs:domain ind:ComparatorDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBiological rdf:type rdf:Property ;
    rdfs:label 'Is Biological' ;
    rdfs:comment 'Indicates whether the comparator drug is a biological product (e.g., monoclonal antibody, vaccine, blood-derived product). Biological products are subject to additional regulatory requirements including BLA/MAA pathways and cold-chain mandates.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isControlledSubstance rdf:type rdf:Property ;
    rdfs:label 'Is Controlled Substance' ;
    rdfs:comment 'Indicates whether the comparator drug is classified as a controlled substance under applicable national legislation (e.g., DEA Schedule in the US, UK Misuse of Drugs Act). Triggers additional accountability and chain-of-custody requirements.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPlaceboMatched rdf:type rdf:Property ;
    rdfs:label 'Is Placebo Matched' ;
    rdfs:comment 'Indicates whether a matching placebo has been manufactured or sourced to maintain blinding integrity for this comparator drug. True = matching placebo exists; False = no matching placebo required.' ;
    rdfs:domain ind:ComparatorDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturerCountryCode rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the comparator drug is manufactured. Used for import/export compliance and regulatory jurisdiction determination.' ;
    rdfs:domain ind:ComparatorDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndcCode rdf:type rdf:Property ;
    rdfs:label 'Ndc Code' ;
    rdfs:comment 'FDA-assigned National Drug Code (NDC) for the comparator drug product, used for US-based procurement, dispensing records, and regulatory submissions.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overLabellingRequired rdf:type rdf:Property ;
    rdfs:label 'Over Labelling Required' ;
    rdfs:comment 'Indicates whether the commercial comparator drug packaging must be over-labelled with clinical trial-specific information (e.g., protocol number, sponsor name, \'For Clinical Trial Use Only\') to meet GMP Annex 13 and local regulatory requirements.' ;
    rdfs:domain ind:ComparatorDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packagingConfiguration rdf:type rdf:Property ;
    rdfs:label 'Packaging Configuration' ;
    rdfs:comment 'Description of the primary and secondary packaging configuration for the comparator drug (e.g., blister pack of 28 tablets, vial in carton). Used for kit definition alignment and label design.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtsmProductCode rdf:type rdf:Property ;
    rdfs:label 'Rtsm Product Code' ;
    rdfs:comment 'Product identifier assigned to the comparator drug within the RTSM system (Medidata Rave RTSM). Used to link supply planning, kit assignment, and dispensing records in the RTSM to this master record.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingStrategy rdf:type rdf:Property ;
    rdfs:label 'Sourcing Strategy' ;
    rdfs:comment 'Strategy used to procure the comparator drug: commercial_purchase (bought from open market), sponsor_supplied (provided directly by sponsor), comparator_sourcing_service (via specialist CRO sourcing vendor), or donated (provided at no cost by manufacturer).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsPerPack rdf:type rdf:Property ;
    rdfs:label 'Units Per Pack' ;
    rdfs:comment 'Number of individual dosage units (e.g., tablets, capsules, vials) contained in one commercial or clinical pack of the comparator drug. Used for inventory planning and dispensing quantity calculations.' ;
    rdfs:domain ind:ComparatorDrug ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ambientStorageCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Ambient Storage Capacity M3' ;
    rdfs:comment 'Total ambient temperature storage capacity of the depot measured in cubic metres. Ambient storage is typically 15–25°C. Used for supply planning and capacity allocation across studies.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coldChainQualified rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Qualified' ;
    rdfs:comment 'Indicates whether the depot has been formally qualified for cold-chain IMP handling, including validated temperature monitoring, qualified packaging, and trained personnel per WHO and GDP guidelines.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlledSubstanceLicensed rdf:type rdf:Property ;
    rdfs:label 'Controlled Substance Licensed' ;
    rdfs:comment 'Indicates whether the depot is licensed to store and handle controlled substances (narcotics, psychotropics) as defined by DEA Schedule (US), Home Office (UK), or equivalent national authority. Required for studies involving opioids, CNS agents, or other scheduled compounds.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ctmsDepotCode rdf:type rdf:Property ;
    rdfs:label 'Ctms Depot Code' ;
    rdfs:comment 'Depot identifier as recorded in Oracle Siebel CTMS. Enables cross-system reconciliation between the supply chain data product and clinical trial management records.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date on which the depot was or is scheduled to be decommissioned and removed from the active clinical supply network. Null for currently active depots.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depotCode rdf:type rdf:Property ;
    rdfs:label 'Depot Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the depot within the clinical supply network. Used in RTSM (Randomization and Trial Supply Management) and CTMS for depot referencing across studies.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depotName rdf:type rdf:Property ;
    rdfs:label 'Depot Name' ;
    rdfs:comment 'Full legal or operational name of the clinical supply depot as registered with regulatory authorities and used in the Trial Master File (TMF).' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depotStatus rdf:type rdf:Property ;
    rdfs:label 'Depot Status' ;
    rdfs:comment 'Current operational lifecycle status of the depot. Active depots are approved for IMP storage and distribution. Suspended depots are temporarily halted pending investigation or re-qualification. Decommissioned depots are permanently closed.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depotType rdf:type rdf:Property ;
    rdfs:label 'Depot Type' ;
    rdfs:comment 'Classification of the depot within the clinical supply logistics network. Central depots serve as primary distribution hubs; regional depots serve geographic clusters; local depots are near investigational sites; satellite depots are temporary; returns depots handle IMP returns and destruction.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionAuthorized rdf:type rdf:Property ;
    rdfs:label 'Destruction Authorized' ;
    rdfs:comment 'Indicates whether the depot is authorized to perform on-site destruction of expired, returned, or unusable IMPs in compliance with GMP and environmental regulations.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:erpVendorCode rdf:type rdf:Property ;
    rdfs:label 'Erp Vendor Code' ;
    rdfs:comment 'Vendor or supplier identifier for the depot as registered in SAP S/4HANA. Used for purchase order processing, invoice matching, and financial reconciliation of depot service fees.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frozenStorageCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Frozen Storage Capacity M3' ;
    rdfs:comment 'Total frozen storage capacity (typically -20°C or -80°C) of the depot in cubic metres. Required for biologics, gene therapies, and other temperature-sensitive IMPs.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmpCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Gmp Certificate Expiry Date' ;
    rdfs:comment 'Date on which the depot\'s GMP certificate expires. Triggers re-qualification workflows and may suspend depot operations if not renewed prior to expiry.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmpCertified rdf:type rdf:Property ;
    rdfs:label 'Gmp Certified' ;
    rdfs:comment 'Indicates whether the depot holds a current Good Manufacturing Practice (GMP) certification as required for IMP storage and handling under ICH Q7/Q10 and applicable regional regulations.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:importLicenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Import License Expiry Date' ;
    rdfs:comment 'Expiry date of the depot\'s import license for IMP receipt. Expired licenses block inbound international shipments.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:importLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Import License Number' ;
    rdfs:comment 'Regulatory import license number permitting the depot to receive IMP shipments from international origins. Required for cross-border clinical supply operations.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastQualificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Qualification Date' ;
    rdfs:comment 'Date on which the depot last completed a formal qualification or re-qualification exercise (IQ/OQ/PQ). Qualification records are maintained in the eTMF and are subject to regulatory inspection.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'Scheduled date for the next GMP/GDP audit at the depot. Used for audit planning and compliance calendar management.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextQualificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Qualification Due Date' ;
    rdfs:comment 'Scheduled date for the next depot qualification or re-qualification. Drives preventive maintenance and compliance calendar in the CTMS and quality management system.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalStartDate rdf:type rdf:Property ;
    rdfs:label 'Operational Start Date' ;
    rdfs:comment 'Date on which the depot became operationally active for clinical supply activities. Used for lifecycle tracking and regulatory documentation.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refrigeratedStorageCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Refrigerated Storage Capacity M3' ;
    rdfs:comment 'Total refrigerated storage capacity (typically 2–8°C) of the depot in cubic metres. Critical for IMPs requiring cold-chain management.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnsAccepted rdf:type rdf:Property ;
    rdfs:label 'Returns Accepted' ;
    rdfs:comment 'Indicates whether the depot is authorized to receive returned Investigational Medicinal Products (IMPs) from investigational sites. Required for accountability reconciliation and destruction workflows.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rtsmDepotCode rdf:type rdf:Property ;
    rdfs:label 'Rtsm Depot Code' ;
    rdfs:comment 'Depot identifier as configured in the RTSM system (Medidata Rave RTSM). Used to link depot master records to RTSM dispensing, randomization kit assignment, and resupply trigger logic.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMonitoringSystem rdf:type rdf:Property ;
    rdfs:label 'Temperature Monitoring System' ;
    rdfs:comment 'Name or model of the continuous temperature monitoring system installed at the depot (e.g., Sensitech TempTale, Berlinger ELPRO). Ensures 21 CFR Part 11 compliant electronic records of storage conditions.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wholesaleDistributionLicense rdf:type rdf:Property ;
    rdfs:label 'Wholesale Distribution License' ;
    rdfs:comment 'License number authorizing the depot to distribute investigational medicinal products (IMPs) as a wholesale distributor. Required under EU GDP guidelines and equivalent national regulations.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wholesaleLicenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Wholesale License Expiry Date' ;
    rdfs:comment 'Expiry date of the wholesale distribution license. Depot cannot legally distribute IMPs after this date without renewal.' ;
    rdfs:domain ind:Depot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depotInventoryId rdf:type rdf:Property ;
    rdfs:label 'Depot Inventory Id' ;
    rdfs:comment 'Unique surrogate identifier for each depot inventory record. Primary key for the depot_inventory data product in the supply domain Silver layer.' ;
    rdfs:domain ind:DepotInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receiptShipmentId rdf:type rdf:Property ;
    rdfs:label 'Receipt Shipment Id' ;
    rdfs:comment 'Foreign key linking to supply.shipment. Business justification: Depot inventory records are created or updated when a shipment is received at the depot. Adding receipt_shipment_id links the depot inventory record to the inbound shipment that created/updated it. Th' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:accountabilityReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Accountability Reconciliation Status' ;
    rdfs:comment 'Status of the drug accountability reconciliation process for this inventory record. Reconciliation confirms that all dispensed, returned, and destroyed quantities account for the total received, as required by GCP and regulatory authorities.' ;
    rdfs:domain ind:DepotInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Manufacturer-assigned batch or lot number for the IMP stock held in this inventory record. Critical for GMP traceability, recall management, and regulatory accountability.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfAnalysisNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Analysis Number' ;
    rdfs:comment 'Reference number of the Certificate of Analysis (CoA) issued by the manufacturer for this batch. The CoA confirms the batch meets specification and is required for QP release and regulatory inspection readiness.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Destruction Certificate Number' ;
    rdfs:comment 'Reference number of the destruction certificate issued when qty_destroyed units were disposed of. Required for drug accountability reconciliation and regulatory submission documentation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpMaterialDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Erp Material Document Number' ;
    rdfs:comment 'Material document number from SAP S/4HANA corresponding to the goods receipt or inventory movement transaction for this batch. Supports financial reconciliation between supply chain and procurement/finance.' ;
    rdfs:domain ind:DepotInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Inventory Record Number' ;
    rdfs:comment 'Externally visible, human-readable identifier for this depot inventory record as assigned by the RTSM or CTMS system (e.g., INV-2024-00123). Used for cross-system reconciliation and audit trail.' ;
    rdfs:domain ind:DepotInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'Current lifecycle status of this depot inventory record. Drives supply availability calculations, RTSM allocation logic, and GMP disposition decisions. [ENUM-REF-CANDIDATE: Available|Allocated|Quarantined|Expired|Destroyed|Returned|On_Hold — promote to reference product]' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPhysicalCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Count Date' ;
    rdfs:comment 'Date on which the most recent physical inventory count was conducted at the depot for this batch/kit type. Supports GMP compliance scheduling and audit readiness.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minStockThreshold rdf:type rdf:Property ;
    rdfs:label 'Min Stock Threshold' ;
    rdfs:comment 'Minimum quantity of available stock that must be maintained at this depot for this IMP/kit type before a replenishment order is triggered. Supports proactive supply planning and prevents stockouts.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:physicalCountDiscrepancy rdf:type rdf:Property ;
    rdfs:label 'Physical Count Discrepancy' ;
    rdfs:comment 'Difference between qty_last_physical_count and the system-recorded qty_on_hand at the time of the physical count. A non-zero value triggers a discrepancy investigation per GMP requirements.' ;
    rdfs:domain ind:DepotInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qpReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Qp Release Date' ;
    rdfs:comment 'Date on which the Qualified Person formally released this batch for clinical use. Null if release is pending or the batch has been rejected.' ;
    rdfs:domain ind:DepotInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qpReleaseStatus rdf:type rdf:Property ;
    rdfs:label 'Qp Release Status' ;
    rdfs:comment 'Status of the Qualified Person (QP) batch release decision for this inventory. Only QP-released stock may be dispensed to clinical sites per EU GMP Annex 13 requirements.' ;
    rdfs:domain ind:DepotInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qtyAllocated rdf:type rdf:Property ;
    rdfs:label 'Qty Allocated' ;
    rdfs:comment 'Number of kits or units reserved for pending outbound shipments or site replenishment orders that have been confirmed but not yet physically dispatched. Prevents double-allocation in RTSM.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qtyAvailable rdf:type rdf:Property ;
    rdfs:label 'Qty Available' ;
    rdfs:comment 'Number of kits or units available for new allocation or shipment. Calculated as qty_on_hand minus qty_allocated minus qty_quarantined minus qty_expired. Represents the net usable stock for RTSM dispensing decisions.' ;
    rdfs:domain ind:DepotInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qtyDestroyed rdf:type rdf:Property ;
    rdfs:label 'Qty Destroyed' ;
    rdfs:comment 'Cumulative number of kits or units destroyed at this depot for this batch. Supports drug accountability reconciliation and regulatory destruction certificate documentation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qtyExpired rdf:type rdf:Property ;
    rdfs:label 'Qty Expired' ;
    rdfs:comment 'Number of kits or units that have passed their expiry date and are no longer eligible for dispensing. Tracked separately to support destruction reconciliation and regulatory accountability reporting.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qtyLastPhysicalCount rdf:type rdf:Property ;
    rdfs:label 'Qty Last Physical Count' ;
    rdfs:comment 'Actual kit or unit count recorded during the most recent physical inventory count at the depot. Used to reconcile system-recorded quantities against physical stock and identify discrepancies.' ;
    rdfs:domain ind:DepotInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qtyOnHand rdf:type rdf:Property ;
    rdfs:label 'Qty On Hand' ;
    rdfs:comment 'Total number of kits or units of this IMP batch currently physically present at the depot, regardless of allocation status. The gross stock figure before netting allocated, quarantined, or expired quantities.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qtyQuarantined rdf:type rdf:Property ;
    rdfs:label 'Qty Quarantined' ;
    rdfs:comment 'Number of kits or units placed under quarantine status due to quality investigations, temperature excursions, damaged packaging, or pending QP release. Quarantined stock is excluded from available supply.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qtyReturned rdf:type rdf:Property ;
    rdfs:label 'Qty Returned' ;
    rdfs:comment 'Number of kits or units returned from clinical sites to this depot. Returned stock is typically quarantined pending QP review before any disposition decision (reuse, destruction, or reconciliation).' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quarantineReason rdf:type rdf:Property ;
    rdfs:label 'Quarantine Reason' ;
    rdfs:comment 'Reason code explaining why stock was placed in quarantine status. Required for GMP deviation documentation and QP disposition decisions. [ENUM-REF-CANDIDATE: Temperature_Excursion|Damaged_Packaging|QP_Hold|Recall|Stability_Failure|Pending_Release|Investigation — promote to reference product]' ;
    rdfs:domain ind:DepotInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestDate rdf:type rdf:Property ;
    rdfs:label 'Retest Date' ;
    rdfs:comment 'Date by which the IMP batch must be retested to confirm continued potency and stability before further use. Applicable for products with retest periods rather than hard expiry dates.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rtsmInventoryCode rdf:type rdf:Property ;
    rdfs:label 'Rtsm Inventory Code' ;
    rdfs:comment 'Identifier assigned to this inventory record within the RTSM system (Medidata Rave). Enables bidirectional reconciliation between the lakehouse Silver layer and the operational RTSM source system.' ;
    rdfs:domain ind:DepotInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageConditionZone rdf:type rdf:Property ;
    rdfs:label 'Storage Condition Zone' ;
    rdfs:comment 'Temperature-controlled storage zone within the depot where this inventory is held (e.g., Ambient, Refrigerated 2–8°C, Frozen -20°C, Ultra-Low -80°C). Drives cold-chain logistics and compliance with IMP storage requirements.' ;
    rdfs:domain ind:DepotInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Authorized By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: IMP destruction authorization is a regulated GMP/GCP act requiring a named, qualified employee (QP or sponsor representative). This FK supports regulatory inspection readiness and destruction certific' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:returnRecordId rdf:type rdf:Property ;
    rdfs:label 'Return Record Id' ;
    rdfs:comment 'Reference to the inbound return shipment record that delivered the IMP/kits to the destruction facility. Provides traceability from site return to destruction.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReturnRecord .

ind:authorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Authorization Number' ;
    rdfs:comment 'Externally assigned or sponsor-issued authorization number approving the destruction of the IMP/kits. Required for GCP audit trail and regulatory inspection readiness. Serves as the primary business identifier for this destruction event.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateIssueDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issue Date' ;
    rdfs:comment 'Date on which the Certificate of Destruction was formally issued by the destruction facility. May differ from the actual destruction date; both are required for complete GCP documentation.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateOfDestructionRef rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Destruction Ref' ;
    rdfs:comment 'Document reference number or identifier for the official Certificate of Destruction issued by the destruction facility. This document is a mandatory GCP audit trail artifact and must be filed in the Trial Master File (TMF).' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainMaintained rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Maintained' ;
    rdfs:comment 'Indicates whether cold-chain temperature requirements were maintained during transport to the destruction facility (True) or a cold-chain excursion occurred (False). Relevant for temperature-sensitive IMP products.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destructionStatus rdf:type rdf:Property ;
    rdfs:label 'Destruction Status' ;
    rdfs:comment 'Current lifecycle status of the destruction record, tracking progression from authorization request through completion or cancellation.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Facility Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the destruction facility is located. Used for jurisdiction-specific regulatory compliance tracking.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Facility License Number' ;
    rdfs:comment 'Regulatory license or permit number of the destruction facility, confirming it is authorized to handle and destroy pharmaceutical/IMP waste.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impName rdf:type rdf:Property ;
    rdfs:label 'Imp Name' ;
    rdfs:comment 'Name or description of the Investigational Medicinal Product (IMP) being destroyed. Provides human-readable identification of the drug substance for audit and reporting purposes.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBlindedDestruction rdf:type rdf:Property ;
    rdfs:label 'Is Blinded Destruction' ;
    rdfs:comment 'Indicates whether the destruction was performed under blinded conditions (True) to preserve study integrity, or unblinded (False). Relevant for double-blind studies where kit contents must not be revealed during destruction.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kitCountDestroyed rdf:type rdf:Property ;
    rdfs:label 'Kit Count Destroyed' ;
    rdfs:comment 'Number of randomization kits destroyed in this event, as tracked by the RTSM system. Distinct from quantity_destroyed which counts individual IMP units; kit count is the RTSM-level accountability unit.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kitNumberList rdf:type rdf:Property ;
    rdfs:label 'Kit Number List' ;
    rdfs:comment 'Comma-separated or range-notation list of RTSM kit numbers included in this destruction event (e.g., \'KIT-001,KIT-002\' or \'KIT-001 to KIT-050\'). Provides granular kit-level traceability for GCP audit and regulatory inspection.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtsmDestructionConfirmationCode rdf:type rdf:Property ;
    rdfs:label 'Rtsm Destruction Confirmation Code' ;
    rdfs:comment 'Confirmation or transaction identifier generated by the RTSM system (Medidata Rave) when kit destruction is recorded in the randomization and trial supply management system. Enables reconciliation between the destruction record and the RTSM inventory ledger.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorRepresentative rdf:type rdf:Property ;
    rdfs:label 'Sponsor Representative' ;
    rdfs:comment 'Name of the sponsor or CRO representative who oversaw or confirmed the destruction on behalf of the study sponsor. Relevant for multi-party accountability in outsourced destruction activities.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureExcursionNoted rdf:type rdf:Property ;
    rdfs:label 'Temperature Excursion Noted' ;
    rdfs:comment 'Indicates whether a temperature excursion was documented for the IMP prior to or during transport to destruction. Provides additional context for destruction_reason when product integrity was compromised.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weightDestroyedKg rdf:type rdf:Property ;
    rdfs:label 'Weight Destroyed Kg' ;
    rdfs:comment 'Total weight in kilograms of the IMP/pharmaceutical waste destroyed. Required by some environmental and waste management regulations for pharmaceutical destruction reporting.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:witnessTitle rdf:type rdf:Property ;
    rdfs:label 'Witness Title' ;
    rdfs:comment 'Professional title or role of the destruction witness (e.g., QA Manager, Pharmacist, CRA). Confirms the witness has appropriate qualifications per GCP requirements.' ;
    rdfs:domain ind:DestructionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountabilityReconciled rdf:type rdf:Property ;
    rdfs:label 'Accountability Reconciled' ;
    rdfs:comment 'Indicates whether this dispensing record has been included in and reconciled as part of the site-level drug accountability reconciliation (True) or is pending reconciliation (False). Required for study close-out and regulatory inspection readiness.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispensedByName rdf:type rdf:Property ;
    rdfs:label 'Dispensed By Name' ;
    rdfs:comment 'Full name of the site staff member who performed the IMP dispensing, captured at time of dispensing for GCP audit trail. Stored as a denormalized field to preserve the historical record per ALCOA+ enduring data requirements even if staff records change.' ;
    rdfs:domain ind:DispensingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispensedByRole rdf:type rdf:Property ;
    rdfs:label 'Dispensed By Role' ;
    rdfs:comment 'The professional role of the staff member who performed the IMP dispensing (e.g., pharmacist, Clinical Research Coordinator (CRC), Principal Investigator (PI)). Used to verify that dispensing was performed by qualified personnel per GCP and site delegation log requirements.' ;
    rdfs:domain ind:DispensingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispensingMethod rdf:type rdf:Property ;
    rdfs:label 'Dispensing Method' ;
    rdfs:comment 'The method by which the IMP dispensing was executed — whether via automated RTSM assignment, manual override (with justification), emergency supply, or backup procedure. Used for quality oversight and GCP compliance monitoring.' ;
    rdfs:domain ind:DispensingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispensingNotes rdf:type rdf:Property ;
    rdfs:label 'Dispensing Notes' ;
    rdfs:comment 'Free-text notes or comments recorded by site staff at the time of dispensing, capturing any relevant observations, deviations, or special circumstances associated with this IMP dispensing event. Supports GCP audit trail and query resolution.' ;
    rdfs:domain ind:DispensingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispensingStatus rdf:type rdf:Property ;
    rdfs:label 'Dispensing Status' ;
    rdfs:comment 'Current lifecycle status of this dispensing record. Tracks the workflow state from initial dispensing through return, destruction, or reconciliation for GCP drug accountability compliance. [ENUM-REF-CANDIDATE: dispensed|returned|partially_returned|destroyed|lost|reconciled — promote to reference product]' ;
    rdfs:domain ind:DispensingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doseAmount rdf:type rdf:Property ;
    rdfs:label 'Dose Amount' ;
    rdfs:comment 'The numeric dose amount of IMP dispensed to the subject for this dispensing event, expressed in the unit specified by dose_unit. Core quantitative field for pharmacokinetic (PK) analysis and protocol compliance verification.' ;
    rdfs:domain ind:DispensingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rtsmConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Rtsm Confirmation Number' ;
    rdfs:comment 'Unique confirmation number generated by the Medidata Rave RTSM system at the time of dispensing. Serves as the authoritative external business identifier for this dispensing event, used for drug accountability reconciliation and audit trail verification.' ;
    rdfs:domain ind:DispensingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectCompliancePct rdf:type rdf:Property ;
    rdfs:label 'Subject Compliance Pct' ;
    rdfs:comment 'The calculated medication compliance percentage for this dispensing event, derived from quantity dispensed minus quantity returned divided by expected consumption, expressed as a percentage. Critical for per-protocol (PP) population eligibility determination and protocol deviation assessment.' ;
    rdfs:domain ind:DispensingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activeSubstanceName rdf:type rdf:Property ;
    rdfs:label 'Active Substance Name' ;
    rdfs:comment 'International Nonproprietary Name (INN) or chemical name of the active pharmaceutical ingredient (API) contained in the IMP. Used for regulatory submissions, pharmacovigilance coding, and WHO-DD cross-referencing.' ;
    rdfs:domain ind:ImpMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispensingUnit rdf:type rdf:Property ;
    rdfs:label 'Dispensing Unit' ;
    rdfs:comment 'The unit of measure used for dispensing the IMP to subjects at the site level (e.g., kit, vial, tablet, capsule). Aligns with RTSM dispensing records and site accountability logs. [ENUM-REF-CANDIDATE: kit|vial|tablet|capsule|syringe|bottle|patch — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOrphanDesignated rdf:type rdf:Property ;
    rdfs:label 'Is Orphan Designated' ;
    rdfs:comment 'Indicates whether the IMP has received orphan drug designation from FDA (ODD) or EMA (OMP), conferring special regulatory incentives and obligations. Relevant for regulatory strategy, supply planning, and sponsor reporting.' ;
    rdfs:domain ind:ImpMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturerCountry rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the IMP is manufactured. Used for import/export regulatory compliance, customs documentation, and supply chain risk assessment.' ;
    rdfs:domain ind:ImpMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCode rdf:type rdf:Property ;
    rdfs:label 'Product Code' ;
    rdfs:comment 'Sponsor-assigned alphanumeric code uniquely identifying the IMP within the sponsor\'s product catalogue. Used as the externally-known business identifier across RTSM, EDC, and regulatory submissions. Maps to the product code field in Medidata Rave RTSM.' ;
    rdfs:domain ind:ImpMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productStatus rdf:type rdf:Property ;
    rdfs:label 'Product Status' ;
    rdfs:comment 'Current lifecycle status of the IMP master record within the supply domain. Active records are eligible for supply planning and dispensing. Inactive or discontinued records are retained for audit and historical accountability.' ;
    rdfs:domain ind:ImpMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsPerKit rdf:type rdf:Property ;
    rdfs:label 'Units Per Kit' ;
    rdfs:comment 'Number of individual dosage units (tablets, vials, syringes, etc.) contained in one RTSM dispensing kit. Used for supply planning, kit assembly, and accountability reconciliation in Medidata Rave RTSM.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:importPermitId rdf:type rdf:Property ;
    rdfs:label 'Import Permit Id' ;
    rdfs:comment 'Unique surrogate identifier for the import permit record in the clinical supply lakehouse. Primary key for the import_permit data product.' ;
    rdfs:domain ind:ImportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicantName rdf:type rdf:Property ;
    rdfs:label 'Applicant Name' ;
    rdfs:comment 'Name of the legal entity (CRO, sponsor, or local affiliate) that submitted the import permit application to the regulatory authority. May differ from the sponsor when a CRO acts as the applicant.' ;
    rdfs:domain ind:ImportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'Date on which the import permit application was formally submitted to the issuing regulatory authority. Used to track regulatory lead times and application-to-approval cycle times.' ;
    rdfs:domain ind:ImportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exportCountryCode rdf:type rdf:Property ;
    rdfs:label 'Export Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code of the country from which the IMP is being exported. Required for bilateral import/export permit matching and customs documentation.' ;
    rdfs:domain ind:ImportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsTariffCode rdf:type rdf:Property ;
    rdfs:label 'Hs Tariff Code' ;
    rdfs:comment 'World Customs Organization Harmonized System (HS) tariff classification code for the IMP. Required for customs clearance and import duty determination. Typically 6-10 digits depending on the destination country.' ;
    rdfs:domain ind:ImportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impDescription rdf:type rdf:Property ;
    rdfs:label 'Imp Description' ;
    rdfs:comment 'Textual description of the IMP as stated on the import permit, including drug name, dosage form, strength, and any blinding information. Must match the IMP details on the permit document exactly for customs compliance.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importCountryCode rdf:type rdf:Property ;
    rdfs:label 'Import Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code of the destination country into which the IMP is being imported. Determines applicable regulatory requirements and customs procedures.' ;
    rdfs:domain ind:ImportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code of the regulatory authority that issued the permit (e.g., USA, GBR, JPN, AUS, CAN, DEU). Identifies the jurisdiction of the issuing body.' ;
    rdfs:domain ind:ImportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Name' ;
    rdfs:comment 'Name of the national regulatory authority or government body that issued the import permit (e.g., FDA, EMA, PMDA, MHRA, TGA, Health Canada). Used for regulatory correspondence and compliance reporting.' ;
    rdfs:domain ind:ImportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Permit Document Reference' ;
    rdfs:comment 'Reference identifier for the scanned or electronic copy of the import permit document stored in the eTMF (Veeva Vault). Enables direct retrieval of the official permit document for customs and audit purposes.' ;
    rdfs:domain ind:ImportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitNumber rdf:type rdf:Property ;
    rdfs:label 'Permit Number' ;
    rdfs:comment 'Official permit number assigned by the issuing regulatory authority. This is the externally-known identifier used in regulatory correspondence, customs declarations, and shipment documentation.' ;
    rdfs:domain ind:ImportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitStatus rdf:type rdf:Property ;
    rdfs:label 'Permit Status' ;
    rdfs:comment 'Current lifecycle status of the import permit. Drives shipment release decisions and regulatory compliance tracking. Draft = in preparation; Submitted = application filed with authority; Approved = permit granted; Rejected = application denied; Expired = validity period elapsed; Revoked = permit withdrawn by authority.' ;
    rdfs:domain ind:ImportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitType rdf:type rdf:Property ;
    rdfs:label 'Permit Type' ;
    rdfs:comment 'Classification of the import permit by scope of authorization. Single_shipment covers one consignment; multi_shipment covers a defined number of shipments; blanket covers all shipments within a validity period; emergency is expedited authorization; re_export covers onward shipment to another country.' ;
    rdfs:domain ind:ImportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedQuantity rdf:type rdf:Property ;
    rdfs:label 'Permitted Quantity' ;
    rdfs:comment 'Maximum quantity of IMP authorized for import under this permit. Expressed in the unit defined by permitted_quantity_unit. Enables supply planning and prevents over-shipment against permit limits.' ;
    rdfs:domain ind:ImportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permittedQuantityUnit rdf:type rdf:Property ;
    rdfs:label 'Permitted Quantity Unit' ;
    rdfs:comment 'Unit of measure for the permitted_quantity field (e.g., units, vials, tablets, capsules, kg, g, mg, L, mL). Must align with the IMP dosage form and packaging configuration. [ENUM-REF-CANDIDATE: units|vials|tablets|capsules|kg|g|mg|L|mL — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ImportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedShipmentCount rdf:type rdf:Property ;
    rdfs:label 'Permitted Shipment Count' ;
    rdfs:comment 'Maximum number of individual shipments authorized under this permit. Applicable for multi_shipment permit types. Null for single_shipment or blanket permits where shipment count is not restricted.' ;
    rdfs:domain ind:ImportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rejectionDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Date' ;
    rdfs:comment 'Date on which the regulatory authority formally rejected the import permit application. Populated only when permit_status is \'rejected\'. Used to track regulatory response timelines and initiate resubmission.' ;
    rdfs:domain ind:ImportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Lead Time Days' ;
    rdfs:comment 'Number of calendar days before permit expiry that the renewal application must be submitted to the issuing authority. Used to trigger automated renewal reminders and prevent supply disruption.' ;
    rdfs:domain ind:ImportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresColdChain rdf:type rdf:Property ;
    rdfs:label 'Requires Cold Chain' ;
    rdfs:comment 'Indicates whether the IMP requires cold-chain logistics management during import (refrigerated, frozen, or ultra-frozen transport). Drives logistics planning and customs clearance prioritization.' ;
    rdfs:domain ind:ImportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'Date on which the regulatory authority revoked a previously approved import permit. Populated only when permit_status is \'revoked\'. Triggers immediate shipment hold and regulatory notification.' ;
    rdfs:domain ind:ImportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Reason provided by the regulatory authority for revoking a previously approved import permit. Populated when permit_status is \'revoked\'. Triggers regulatory notification and supply chain hold.' ;
    rdfs:domain ind:ImportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizedQuantity rdf:type rdf:Property ;
    rdfs:label 'Utilized Quantity' ;
    rdfs:comment 'Cumulative quantity of IMP actually imported against this permit to date. Used to track permit utilization, remaining authorized quantity, and accountability reconciliation. Expressed in the same unit as permitted_quantity_unit.' ;
    rdfs:domain ind:ImportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizedShipmentCount rdf:type rdf:Property ;
    rdfs:label 'Utilized Shipment Count' ;
    rdfs:comment 'Number of shipments that have been made against this permit to date. Used to track permit utilization and determine remaining shipment capacity for multi_shipment permits.' ;
    rdfs:domain ind:ImportPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispensingQuantity rdf:type rdf:Property ;
    rdfs:label 'Dispensing Quantity' ;
    rdfs:comment 'The standard number of dispensing units to be issued to a subject per dispensing event for this kit definition. Used by RTSM to automate dispensing recommendations at scheduled visits.' ;
    rdfs:domain ind:KitDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:doseStrength rdf:type rdf:Property ;
    rdfs:label 'Dose Strength' ;
    rdfs:comment 'The numeric dose strength of the IMP per unit in this kit definition (e.g., 10.0000 for a 10 mg tablet). Serves as the principal MEASUREMENT_OR_VALUE for this MASTER_RESOURCE. Must be read in conjunction with dose_strength_unit.' ;
    rdfs:domain ind:KitDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:doseStrengthUnit rdf:type rdf:Property ;
    rdfs:label 'Dose Strength Unit' ;
    rdfs:comment 'Unit of measurement for the dose strength value (e.g., mg, mcg, g, mg/mL, IU). Required to fully interpret the dose_strength field. [ENUM-REF-CANDIDATE: mg|mcg|g|mg/mL|IU|mmol|mEq|% — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:KitDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRescueMedication rdf:type rdf:Property ;
    rdfs:label 'Is Rescue Medication' ;
    rdfs:comment 'Indicates whether this kit definition represents a rescue medication (True) rather than the primary study treatment. Rescue medication kits follow different dispensing and accountability rules.' ;
    rdfs:domain ind:KitDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kitDescription rdf:type rdf:Property ;
    rdfs:label 'Kit Description' ;
    rdfs:comment 'Detailed narrative description of the kit definition including its intended use, contents summary, and any special handling instructions relevant to the kit template.' ;
    rdfs:domain ind:KitDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kitName rdf:type rdf:Property ;
    rdfs:label 'Kit Name' ;
    rdfs:comment 'Human-readable descriptive name for the kit definition as configured in the RTSM system (e.g., \'Study XYZ Arm A 10mg Tablet 28-Day Supply\'). Serves as the IDENTITY_LABEL for this MASTER_RESOURCE.' ;
    rdfs:domain ind:KitDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kitNumberRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Kit Number Range End' ;
    rdfs:comment 'The last sequential kit number in the numeric range allocated to physical kits manufactured from this kit definition. Together with kit_number_range_start, defines the total pool of physical kits that can be generated from this definition.' ;
    rdfs:domain ind:KitDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kitNumberRangeStart rdf:type rdf:Property ;
    rdfs:label 'Kit Number Range Start' ;
    rdfs:comment 'The first sequential kit number in the numeric range allocated to physical kits manufactured from this kit definition. Used by RTSM to assign unique kit numbers to physical instances during manufacturing.' ;
    rdfs:domain ind:KitDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manufacturingSiteCode rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Site Code' ;
    rdfs:comment 'The code identifying the manufacturing or packaging site responsible for producing physical kits from this definition. Used for supply chain traceability and GMP compliance.' ;
    rdfs:domain ind:KitDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packSizeUnit rdf:type rdf:Property ;
    rdfs:label 'Pack Size Unit' ;
    rdfs:comment 'The unit descriptor for the pack size count (e.g., tablet, capsule, vial). Clarifies what each unit in the pack_size count represents. [ENUM-REF-CANDIDATE: tablet|capsule|vial|ampoule|syringe|patch|sachet|bottle — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:KitDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:randomizationScheme rdf:type rdf:Property ;
    rdfs:label 'Randomization Scheme' ;
    rdfs:comment 'The randomization methodology applied to kits of this definition type within the RTSM. Determines how kits are allocated to subjects during enrollment and randomization events.' ;
    rdfs:domain ind:KitDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Retest Period Days' ;
    rdfs:comment 'Number of days from manufacture after which kits of this definition must be retested before continued use. Applicable for IMP components with defined retest periods rather than fixed expiry dates.' ;
    rdfs:domain ind:KitDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnRequired rdf:type rdf:Property ;
    rdfs:label 'Return Required' ;
    rdfs:comment 'Indicates whether used or unused kits of this definition must be returned to the depot or sponsor for accountability reconciliation and destruction. Drives returns logistics workflows.' ;
    rdfs:domain ind:KitDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rtsmKitTypeCode rdf:type rdf:Property ;
    rdfs:label 'Rtsm Kit Type Code' ;
    rdfs:comment 'The internal kit type code as configured in the Medidata Rave RTSM system. Used for system-to-system integration and reconciliation between the RTSM and downstream data systems.' ;
    rdfs:domain ind:KitDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainCompliant rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Compliant' ;
    rdfs:comment 'Indicates whether the kit has maintained cold-chain compliance throughout its custody chain based on temperature monitoring data. A value of False triggers a quality investigation before dispensing.' ;
    rdfs:domain ind:KitInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coldChainRequired rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Required' ;
    rdfs:comment 'Indicates whether this kit requires cold-chain storage and transportation (e.g., 2–8°C refrigeration or frozen conditions). Drives logistics planning, temperature monitoring requirements, and qualified packaging selection.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentLocationType rdf:type rdf:Property ;
    rdfs:label 'Current Location Type' ;
    rdfs:comment 'Categorical indicator of where the kit physically resides in the supply chain at the current point in time. Used in conjunction with depot_id or site_id to determine precise location.' ;
    rdfs:domain ind:KitInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depotReceiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Depot Receipt Timestamp' ;
    rdfs:comment 'The date and time at which the kit was received at the supply depot from the manufacturer or another depot. Initiates the depot inventory record and chain-of-custody tracking.' ;
    rdfs:domain ind:KitInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destroyedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Destroyed Timestamp' ;
    rdfs:comment 'The date and time at which the kit was confirmed destroyed per the destruction certificate. Required for drug accountability reconciliation and regulatory close-out documentation.' ;
    rdfs:domain ind:KitInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispensedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispensed Timestamp' ;
    rdfs:comment 'The date and time at which this kit was physically dispensed to the subject by site staff. Captured in RTSM (Medidata Rave) as part of the chain-of-custody audit trail. Conforms to ALCOA+ contemporaneous documentation requirements.' ;
    rdfs:domain ind:KitInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispensingVisit rdf:type rdf:Property ;
    rdfs:label 'Dispensing Visit' ;
    rdfs:comment 'The protocol-defined visit name or number at which this kit was dispensed to the subject (e.g., \'Visit 2 - Week 4\'). Used for protocol compliance verification and eCRF reconciliation.' ;
    rdfs:domain ind:KitInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelVersion rdf:type rdf:Property ;
    rdfs:label 'Label Version' ;
    rdfs:comment 'The version identifier of the IMP label applied to this kit. Used to verify that the correct, IRB/IEC-approved label version was used at the time of dispensing and for regulatory label reconciliation.' ;
    rdfs:domain ind:KitInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Returned Timestamp' ;
    rdfs:comment 'The date and time at which the kit was returned by the subject or site to the depot or destruction facility. Part of the chain-of-custody audit trail for drug accountability.' ;
    rdfs:domain ind:KitInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rtsmKitCode rdf:type rdf:Property ;
    rdfs:label 'Rtsm Kit Code' ;
    rdfs:comment 'The source system identifier for this kit record as assigned by the RTSM module in Medidata Rave. Used for data lineage, reconciliation between the Silver Layer and the operational RTSM system, and audit trail traceability.' ;
    rdfs:domain ind:KitInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteReceiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Site Receipt Timestamp' ;
    rdfs:comment 'The date and time at which the kit was received and confirmed at the investigational site. Marks the transfer of custody from depot/logistics to site. Used for site inventory reconciliation.' ;
    rdfs:domain ind:KitInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:treatmentArm rdf:type rdf:Property ;
    rdfs:label 'Treatment Arm' ;
    rdfs:comment 'The randomization treatment arm or cohort to which this kit is allocated (e.g., \'Active 10mg\', \'Placebo\', \'Dose Level 2\'). Populated by RTSM at randomization. May be blinded and masked for double-blind studies.' ;
    rdfs:domain ind:KitInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableQuantity rdf:type rdf:Property ;
    rdfs:label 'Available Quantity' ;
    rdfs:comment 'Current quantity of units from this batch that are available for allocation to depots or clinical sites, net of already allocated, dispensed, returned, and destroyed quantities. Used for supply planning and shortage risk monitoring.' ;
    rdfs:domain ind:ManufactureBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchSize rdf:type rdf:Property ;
    rdfs:label 'Batch Size' ;
    rdfs:comment 'Total number of units (e.g., tablets, vials, kits) manufactured in this batch. Used for supply planning, yield calculations, and accountability reconciliation against dispensed and returned quantities.' ;
    rdfs:domain ind:ManufactureBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchSizeUnit rdf:type rdf:Property ;
    rdfs:label 'Batch Size Unit' ;
    rdfs:comment 'Unit of measure for the batch size quantity (e.g., units, vials, tablets, kits). Required for unambiguous interpretation of batch_size in supply planning and accountability reports. [ENUM-REF-CANDIDATE: units|vials|tablets|capsules|kits|ampoules|syringes|patches — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ManufactureBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchType rdf:type rdf:Property ;
    rdfs:label 'Batch Type' ;
    rdfs:comment 'Classification of the batch purpose: clinical (intended for subject dosing), validation (process validation), stability (stability study samples), reference (retained reference samples), reserve (emergency reserve). Determines downstream handling and allocation rules.' ;
    rdfs:domain ind:ManufactureBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaReference rdf:type rdf:Property ;
    rdfs:label 'Coa Reference' ;
    rdfs:comment 'Document reference number or identifier for the GMP Certificate of Analysis (CoA) issued by the manufacturing site for this batch. The CoA confirms the batch meets all release specifications. Links to the document management system (Veeva Vault eTMF).' ;
    rdfs:domain ind:ManufactureBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctaReference rdf:type rdf:Property ;
    rdfs:label 'Cta Reference' ;
    rdfs:comment 'Clinical Trial Authorisation (CTA) reference number issued by the relevant national competent authority (e.g., EMA, MHRA) under which this IMP batch is authorised for use in the clinical trial.' ;
    rdfs:domain ind:ManufactureBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionCertificateRef rdf:type rdf:Property ;
    rdfs:label 'Destruction Certificate Ref' ;
    rdfs:comment 'Reference number of the destruction certificate issued upon confirmed destruction of batch units. Required for GMP accountability reconciliation and regulatory audit trail. Links to document management system (Veeva Vault).' ;
    rdfs:domain ind:ManufactureBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingSiteCountry rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Site Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the manufacturing site is located. Used for import/export regulatory compliance and supply chain risk assessment.' ;
    rdfs:domain ind:ManufactureBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturingSiteName rdf:type rdf:Property ;
    rdfs:label 'Manufacturing Site Name' ;
    rdfs:comment 'Name of the GMP-certified facility where this IMP batch was manufactured. Used for regulatory traceability, site audit trails, and supply chain accountability.' ;
    rdfs:domain ind:ManufactureBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineQuantity rdf:type rdf:Property ;
    rdfs:label 'Quarantine Quantity' ;
    rdfs:comment 'Number of units from this batch currently held in quarantine pending QP release or investigation. Tracked separately from available quantity for GMP accountability.' ;
    rdfs:domain ind:ManufactureBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recallDate rdf:type rdf:Property ;
    rdfs:label 'Recall Date' ;
    rdfs:comment 'Date on which the recall of this batch was initiated. Populated only when recall_flag is True. Used for regulatory reporting timelines and site notification tracking.' ;
    rdfs:domain ind:ManufactureBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recallFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Flag' ;
    rdfs:comment 'Indicates whether this batch has been subject to a product recall. True = batch recalled; False = no recall. Triggers urgent site notification, return logistics, and regulatory reporting obligations.' ;
    rdfs:domain ind:ManufactureBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date on which the Qualified Person (QP) or authorized release authority formally released this batch for clinical use. Marks the transition from quarantine to released status and triggers downstream supply chain activities.' ;
    rdfs:domain ind:ManufactureBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseStatus rdf:type rdf:Property ;
    rdfs:label 'Release Status' ;
    rdfs:comment 'Current GMP release status of the batch as determined by the Qualified Person (QP) or authorized release authority. Controls whether the batch may be shipped to depots or dispensed to subjects. Valid values: quarantine (awaiting QP release), released (approved for use), rejected (failed QC), recalled (post-release recall), destroyed (confirmed destruction), under_review (hold pending investigation).' ;
    rdfs:domain ind:ManufactureBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemBatchKey rdf:type rdf:Property ;
    rdfs:label 'Source System Batch Key' ;
    rdfs:comment 'Native batch record identifier from the originating source system (e.g., Medidata Rave RTSM batch record ID, sponsor ERP batch key from SAP S/4HANA). Used for data lineage, reconciliation, and ETL traceability between the lakehouse silver layer and operational systems.' ;
    rdfs:domain ind:ManufactureBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorBatchReference rdf:type rdf:Property ;
    rdfs:label 'Sponsor Batch Reference' ;
    rdfs:comment 'Sponsor-assigned reference number for this batch as provided in the sponsor batch release documentation. May differ from the manufacturing site batch number. Used for sponsor reconciliation and regulatory submissions.' ;
    rdfs:domain ind:ManufactureBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityStudyReference rdf:type rdf:Property ;
    rdfs:label 'Stability Study Reference' ;
    rdfs:comment 'Reference identifier for the ICH stability study protocol under which this batch is enrolled for ongoing stability monitoring. Used to track shelf-life extensions and expiry date updates.' ;
    rdfs:domain ind:ManufactureBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTempMaxC rdf:type rdf:Property ;
    rdfs:label 'Storage Temp Max C' ;
    rdfs:comment 'Maximum acceptable storage temperature in degrees Celsius for this IMP batch, as specified in the product specification. Used for cold-chain monitoring, temperature excursion assessment, and depot/site compliance verification.' ;
    rdfs:domain ind:ManufactureBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageTempMinC rdf:type rdf:Property ;
    rdfs:label 'Storage Temp Min C' ;
    rdfs:comment 'Minimum acceptable storage temperature in degrees Celsius for this IMP batch, as specified in the product specification. Used for cold-chain monitoring, temperature excursion assessment, and depot/site compliance verification.' ;
    rdfs:domain ind:ManufactureBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resupplyOrderId rdf:type rdf:Property ;
    rdfs:label 'Resupply Order Id' ;
    rdfs:comment 'Unique surrogate identifier for the resupply order record in the lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:ResupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceDepotId rdf:type rdf:Property ;
    rdfs:label 'Source Depot Id' ;
    rdfs:comment 'Reference to the depot or distribution center from which the IMP kits will be dispatched to fulfill this resupply order. Supports depot-to-site and depot-to-depot supply chain tracking.' ;
    rdfs:domain ind:ResupplyOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:supplyPlanId rdf:type rdf:Property ;
    rdfs:label 'Supply Plan Id' ;
    rdfs:comment 'Reference to the IMP supply plan or forecast that this resupply order is fulfilling. Links operational orders back to strategic supply planning for variance analysis.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplyPlan .

ind:expectedFulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Expected Fulfillment Date' ;
    rdfs:comment 'Target date by which the resupply order is expected to be delivered to the requesting site or depot, based on standard lead times and courier schedules.' ;
    rdfs:domain ind:ResupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isEmergencyOverride rdf:type rdf:Property ;
    rdfs:label 'Is Emergency Override' ;
    rdfs:comment 'Indicates whether this resupply order was processed as an emergency override, bypassing standard approval workflows due to critical patient supply risk. Triggers mandatory post-hoc documentation.' ;
    rdfs:domain ind:ResupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderComments rdf:type rdf:Property ;
    rdfs:label 'Order Comments' ;
    rdfs:comment 'Free-text field for supply manager notes, special handling instructions, or contextual information related to this resupply order. Supports operational communication between depots and sites.' ;
    rdfs:domain ind:ResupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'The date and time at which the resupply order was formally placed or triggered, either by the RTSM resupply algorithm or by a supply manager. This is the principal business event timestamp for the order.' ;
    rdfs:domain ind:ResupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Human-readable, externally-known business identifier for the resupply order, typically generated by the RTSM (Medidata Rave) or supply management system. Used in communications with depots, couriers, and sponsors.' ;
    rdfs:domain ind:ResupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle state of the resupply order workflow, from initial trigger through fulfillment or cancellation. Drives operational dashboards and escalation logic.' ;
    rdfs:domain ind:ResupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityApproved rdf:type rdf:Property ;
    rdfs:label 'Quantity Approved' ;
    rdfs:comment 'Number of IMP kits or units approved for dispatch after supply manager or depot review. May differ from quantity_requested due to stock availability or protocol constraints.' ;
    rdfs:domain ind:ResupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'Number of IMP kits or units requested in this resupply order, as specified at the time of order creation by the RTSM algorithm or supply manager.' ;
    rdfs:domain ind:ResupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityShipped rdf:type rdf:Property ;
    rdfs:label 'Quantity Shipped' ;
    rdfs:comment 'Actual number of IMP kits or units included in the outbound shipment fulfilling this resupply order. Populated at dispatch and used for accountability reconciliation.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingLocationType rdf:type rdf:Property ;
    rdfs:label 'Requesting Location Type' ;
    rdfs:comment 'Classifies whether the resupply order was initiated by an investigational site, a regional depot, or a central pharmacy. Determines routing and fulfillment logic.' ;
    rdfs:domain ind:ResupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtsmOrderReference rdf:type rdf:Property ;
    rdfs:label 'Rtsm Order Reference' ;
    rdfs:comment 'The native order reference or transaction ID assigned by the RTSM system (Medidata Rave) when the resupply order was generated. Used for cross-system reconciliation and audit.' ;
    rdfs:domain ind:ResupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtsmTriggerRule rdf:type rdf:Property ;
    rdfs:label 'Rtsm Trigger Rule' ;
    rdfs:comment 'Identifier or name of the RTSM resupply algorithm rule that triggered this order (e.g., minimum stock level rule, days-of-supply threshold rule). Null for manually initiated orders.' ;
    rdfs:domain ind:ResupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemOrderCode rdf:type rdf:Property ;
    rdfs:label 'Source System Order Code' ;
    rdfs:comment 'The native primary key or unique identifier of this resupply order in the originating source system (e.g., Medidata Rave RTSM internal order ID). Enables cross-system traceability and reconciliation.' ;
    rdfs:domain ind:ResupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockAtTrigger rdf:type rdf:Property ;
    rdfs:label 'Stock At Trigger' ;
    rdfs:comment 'Actual inventory count at the requesting site or depot at the moment the resupply order was triggered. Used to validate trigger logic and support supply accountability reconciliation.' ;
    rdfs:domain ind:ResupplyOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Received By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: GCP IMP accountability requires the employee who received returned IMP to be traceable for reconciliation and audit purposes. This FK supports return accountability reporting and GCP inspection readin' ;
    rdfs:domain ind:ReturnRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:blindingIntact rdf:type rdf:Property ;
    rdfs:label 'Blinding Intact' ;
    rdfs:comment 'Indicates whether the blinding of the returned IMP kit was maintained at the time of return (True = blinding preserved; False = unblinding occurred or suspected). Critical for double-blind study integrity.' ;
    rdfs:domain ind:ReturnRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destructionAuthorizationRef rdf:type rdf:Property ;
    rdfs:label 'Destruction Authorization Ref' ;
    rdfs:comment 'Reference number or document identifier for the sponsor or depot authorization to destroy the returned IMP. Links to the destruction certificate in the eTMF (Veeva Vault). Required before any IMP destruction can proceed.' ;
    rdfs:domain ind:ReturnRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyExplanation rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Explanation' ;
    rdfs:comment 'Free-text explanation provided by the site or CRA to account for any quantity discrepancy between dispensed and returned IMP. Required for regulatory audit trail when discrepancy_quantity is non-zero.' ;
    rdfs:domain ind:ReturnRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUsed rdf:type rdf:Property ;
    rdfs:label 'Quantity Used' ;
    rdfs:comment 'Number of dispensing units confirmed as consumed by the subject, calculated or reported at the time of return. Supports compliance and adherence analysis.' ;
    rdfs:domain ind:ReturnRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnCondition rdf:type rdf:Property ;
    rdfs:label 'Return Condition' ;
    rdfs:comment 'Physical condition of the IMP or kit at the time of return, as assessed by the site or depot receiving staff. Critical for determining disposition (destruction vs. re-use) and identifying cold-chain or handling failures.' ;
    rdfs:domain ind:ReturnRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnNumber rdf:type rdf:Property ;
    rdfs:label 'Return Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for this return transaction, typically generated by the RTSM (Medidata Rave) or CTMS. Used for cross-system traceability and regulatory audit.' ;
    rdfs:domain ind:ReturnRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReason rdf:type rdf:Property ;
    rdfs:label 'Return Reason' ;
    rdfs:comment 'Narrative or coded reason for the return, such as study completion, subject withdrawal, protocol deviation, product expiry, or damaged packaging. Supports root cause analysis and supply planning.' ;
    rdfs:domain ind:ReturnRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnType rdf:type rdf:Property ;
    rdfs:label 'Return Type' ;
    rdfs:comment 'Classification of the return event indicating the reason and direction of the return: subject returning unused IMP to site, site returning stock to depot, expired stock return, damaged stock return, or return triggered by a protocol deviation.' ;
    rdfs:domain ind:ReturnRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtsmReturnCode rdf:type rdf:Property ;
    rdfs:label 'Rtsm Return Code' ;
    rdfs:comment 'Source system identifier for this return transaction as recorded in the RTSM (Medidata Rave). Enables bidirectional traceability between the lakehouse silver layer and the operational RTSM system.' ;
    rdfs:domain ind:ReturnRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Tracking Number' ;
    rdfs:comment 'Courier or logistics provider tracking number for the return shipment from site to depot. Enables cold-chain monitoring and chain-of-custody verification during transit.' ;
    rdfs:domain ind:ReturnRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name or identifier of the Clinical Research Associate (CRA) or pharmacist who verified the return quantities and condition during a monitoring visit or depot check. Supports Source Data Verification (SDV).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originDepotId rdf:type rdf:Property ;
    rdfs:label 'Origin Depot Id' ;
    rdfs:comment 'Foreign key linking to supply.depot. Business justification: Shipments originate from depots (depot-to-site or depot-to-depot shipments). shipment.origin_node_name is a denormalized string. Adding origin_depot_id creates a proper FK to the originating depot. Nu' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Depot .

ind:actualDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Timestamp' ;
    rdfs:comment 'Precise date and time the IMP shipment was confirmed received at the destination. Supports cold-chain total transit time calculations and ALCOA+ audit trail requirements.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Name of the logistics carrier or courier responsible for transporting the IMP shipment (e.g., World Courier, Marken, DHL). Required for cold-chain accountability and deviation investigation.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainLoggerCode rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Logger Code' ;
    rdfs:comment 'Unique identifier of the temperature data logger device placed in the shipment. Used to retrieve detailed temperature profiles from the logistics provider system for excursion investigation and regulatory documentation.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Date' ;
    rdfs:comment 'Date on which customs clearance was obtained for the international IMP shipment. Used for transit time analysis and regulatory import documentation.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customsClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Required' ;
    rdfs:comment 'Indicates whether the shipment requires customs clearance due to international cross-border transit. Drives import/export documentation requirements and regulatory import permits for IMP.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationNodeName rdf:type rdf:Property ;
    rdfs:label 'Destination Node Name' ;
    rdfs:comment 'Human-readable name of the supply chain destination node (e.g., site name, depot name). Supports logistics documentation and regulatory accountability records.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationNodeType rdf:type rdf:Property ;
    rdfs:label 'Destination Node Type' ;
    rdfs:comment 'Type of supply chain node to which the shipment is directed (e.g., clinical site, central depot, manufacturer). Supports supply chain network mapping and inventory accountability.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchDate rdf:type rdf:Property ;
    rdfs:label 'Dispatch Date' ;
    rdfs:comment 'The date on which the IMP shipment was physically dispatched from the origin node. Represents the principal business event timestamp for outbound shipments. Used for lead-time calculations and regulatory documentation.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispatchTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispatch Timestamp' ;
    rdfs:comment 'Precise date and time the IMP shipment was dispatched from the origin node. Supports cold-chain elapsed time calculations and ALCOA+ data integrity requirements.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'The planned date on which the IMP shipment is expected to arrive at the destination node. Used for site inventory planning, expiry management, and supply chain KPI monitoring.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'International Commercial Terms (Incoterms) code defining the transfer of risk and responsibility between shipper and receiver for the IMP shipment. Governs insurance, customs, and cost allocation. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kitCount rdf:type rdf:Property ;
    rdfs:label 'Kit Count' ;
    rdfs:comment 'Total number of randomization kits included in this shipment as recorded in the RTSM (Medidata Rave). Core quantity field for inventory accountability and reconciliation.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxRecordedTempC rdf:type rdf:Property ;
    rdfs:label 'Max Recorded Temp C' ;
    rdfs:comment 'Maximum temperature in degrees Celsius recorded by the cold-chain data logger during transit. Used to assess whether the IMP was exposed to excessive heat or out-of-range conditions.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minRecordedTempC rdf:type rdf:Property ;
    rdfs:label 'Min Recorded Temp C' ;
    rdfs:comment 'Minimum temperature in degrees Celsius recorded by the cold-chain data logger during transit. Used to assess whether the IMP was exposed to freezing or sub-optimal low temperatures.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originNodeName rdf:type rdf:Property ;
    rdfs:label 'Origin Node Name' ;
    rdfs:comment 'Human-readable name of the supply chain origin node (e.g., depot name, manufacturer facility name, or site name). Supports logistics documentation and regulatory accountability records.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originNodeType rdf:type rdf:Property ;
    rdfs:label 'Origin Node Type' ;
    rdfs:comment 'Type of supply chain node from which the shipment originates (e.g., manufacturer, central depot, clinical site, CRO warehouse). Used for supply chain network mapping and accountability.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineFlag rdf:type rdf:Property ;
    rdfs:label 'Quarantine Flag' ;
    rdfs:comment 'Indicates whether the shipment or its contents have been placed under quarantine pending quality investigation (e.g., following a temperature excursion or damaged packaging). Prevents dispensing of affected kits to subjects.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rtsmShipmentRef rdf:type rdf:Property ;
    rdfs:label 'Rtsm Shipment Ref' ;
    rdfs:comment 'Source system shipment reference identifier from the RTSM module (Medidata Rave). Used for cross-system reconciliation between the lakehouse silver layer and the operational RTSM system.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'Externally-known, human-readable shipment reference number generated by the RTSM (Medidata Rave) or logistics provider. Used for cross-system reconciliation, carrier communication, and regulatory accountability documentation.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waybillNumber rdf:type rdf:Property ;
    rdfs:label 'Waybill Number' ;
    rdfs:comment 'Air waybill (AWB) or bill of lading number issued by the carrier for the shipment. Used for customs documentation, carrier liability, and logistics traceability.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentLineId rdf:type rdf:Property ;
    rdfs:label 'Shipment Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each shipment line record within the IMP supply chain. Primary key for the shipment_line data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receiptConfirmedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Receipt Confirmed By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: GCP requires the named employee who confirms IMP shipment line receipt to be traceable for accountability reconciliation and discrepancy investigation. This FK supports site receipt audit trails and G' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:blinded rdf:type rdf:Property ;
    rdfs:label 'Blinded' ;
    rdfs:comment 'Indicates whether the IMP kit on this shipment line is blinded (True) or unblinded/open-label (False). Supports blinding integrity controls and restricts access to treatment assignment information per ICH E9 and GCP requirements.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyReason rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Reason' ;
    rdfs:comment 'Free-text explanation for any quantity discrepancy between shipped and received amounts on this line. Captured during site receipt confirmation and used for drug accountability investigation and CAPA tracking.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impProductCode rdf:type rdf:Property ;
    rdfs:label 'Imp Product Code' ;
    rdfs:comment 'Sponsor-assigned product code or study drug identifier for the Investigational Medicinal Product (IMP) on this shipment line. Aligns with the study protocol\'s IMP definition and supply catalog.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNotes rdf:type rdf:Property ;
    rdfs:label 'Line Notes' ;
    rdfs:comment 'Free-text notes or comments specific to this shipment line, capturing any special handling instructions, site-specific requirements, or operational remarks not captured in structured fields.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityDiscrepancy rdf:type rdf:Property ;
    rdfs:label 'Quantity Discrepancy' ;
    rdfs:comment 'Difference between quantity_shipped and quantity_received for this shipment line. A non-zero value triggers a discrepancy investigation per drug accountability SOPs. Positive value indicates shortage; negative indicates overage.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarantineStatus rdf:type rdf:Property ;
    rdfs:label 'Quarantine Status' ;
    rdfs:comment 'Current quarantine status of the IMP on this shipment line. Values: NOT_QUARANTINED (available for dispensing), QUARANTINED (held pending quality review), RELEASED (released from quarantine after investigation), DESTROYED (disposed of due to quality failure or expiry).' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemLineRef rdf:type rdf:Property ;
    rdfs:label 'Source System Line Ref' ;
    rdfs:comment 'Original line identifier or reference number from the source operational system (e.g., Medidata Rave RTSM shipment line ID or SAP S/4HANA delivery item number). Enables traceability back to the system of record for audit and reconciliation purposes.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageConditionCode rdf:type rdf:Property ;
    rdfs:label 'Storage Condition Code' ;
    rdfs:comment 'Required storage condition for the IMP on this shipment line as specified in the IMP dossier. Drives cold-chain logistics requirements and site storage compliance monitoring. Values: AMBIENT, REFRIGERATED (2–8°C), FROZEN (≤-20°C), CONTROLLED_ROOM_TEMP (15–25°C), PROTECT_FROM_LIGHT.' ;
    rdfs:domain ind:ShipmentLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentArmCode rdf:type rdf:Property ;
    rdfs:label 'Treatment Arm Code' ;
    rdfs:comment 'Code identifying the treatment arm or cohort to which the kit on this shipment line is allocated (e.g., ARM_A, ARM_B, PLACEBO). Maintained in RTSM and used for supply planning and accountability by arm.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteInventoryId rdf:type rdf:Property ;
    rdfs:label 'Site Inventory Id' ;
    rdfs:comment 'Unique surrogate identifier for each site inventory record representing a stock position of an Investigational Medicinal Product (IMP) or kit type at a specific supply chain node (investigational site or depot).' ;
    rdfs:domain ind:SiteInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Imp Unit Of Measure' ;
    rdfs:comment 'Unit of measure used to count IMP stock at this location (e.g., kit, vial, tablet, capsule, syringe, ampoule). Ensures consistent quantity reporting across different IMP formulations and packaging configurations.' ;
    rdfs:domain ind:SiteInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryNumber rdf:type rdf:Property ;
    rdfs:label 'Inventory Number' ;
    rdfs:comment 'Externally-known, human-readable unique identifier for this inventory position record, typically generated by the RTSM or CTMS system. Used in regulatory accountability documentation and audit trails.' ;
    rdfs:domain ind:SiteInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDispensingDate rdf:type rdf:Property ;
    rdfs:label 'Last Dispensing Date' ;
    rdfs:comment 'Date on which the most recent IMP or kit dispensing event occurred at this location. Used to monitor site dispensing activity and identify inactive sites that may require supply reallocation.' ;
    rdfs:domain ind:SiteInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPhysicalCountQty rdf:type rdf:Property ;
    rdfs:label 'Last Physical Count Qty' ;
    rdfs:comment 'Actual physical count of IMP units or kits recorded during the most recent physical inventory count at this location. Compared against the system quantity to identify discrepancies requiring investigation.' ;
    rdfs:domain ind:SiteInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the supply chain node holding this inventory. Distinguishes between investigational sites (where IMP is dispensed to subjects), depots (regional or central storage), central pharmacies, and satellite depots. Drives resupply logic and accountability reporting.' ;
    rdfs:domain ind:Supply ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumStockQty rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Qty' ;
    rdfs:comment 'Maximum number of IMP units or kits permitted at this location to prevent overstocking, minimize expiry risk, and comply with storage capacity constraints. Used in supply planning and RTSM configuration.' ;
    rdfs:domain ind:SiteInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumStockQty rdf:type rdf:Property ;
    rdfs:label 'Minimum Stock Qty' ;
    rdfs:comment 'Absolute minimum number of IMP units or kits that must be maintained at this location to ensure uninterrupted subject dosing. Falling below this level triggers an urgent resupply escalation.' ;
    rdfs:domain ind:SiteInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qtyAdjusted rdf:type rdf:Property ;
    rdfs:label 'Qty Adjusted' ;
    rdfs:comment 'Net inventory adjustment quantity applied to this position due to physical count discrepancies, data corrections, or reconciliation differences. Positive values indicate upward adjustments; negative values indicate downward adjustments.' ;
    rdfs:domain ind:SiteInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qtyDispensed rdf:type rdf:Property ;
    rdfs:label 'Qty Dispensed' ;
    rdfs:comment 'Cumulative number of IMP units or kits dispensed to study subjects at this location since the study began or since the last accountability reconciliation period. Sourced from dispensing records in the RTSM.' ;
    rdfs:domain ind:SiteInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qtyReceived rdf:type rdf:Property ;
    rdfs:label 'Qty Received' ;
    rdfs:comment 'Cumulative number of IMP units or kits received at this location since the study began or since the last accountability reconciliation period. Sourced from inbound shipment confirmations in the RTSM.' ;
    rdfs:domain ind:SiteInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'Minimum quantity threshold at which a resupply request should be triggered for this IMP or kit type at this location. When qty_on_hand falls at or below this value, the RTSM or supply planner initiates a replenishment shipment.' ;
    rdfs:domain ind:SiteInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reorderQty rdf:type rdf:Property ;
    rdfs:label 'Reorder Qty' ;
    rdfs:comment 'Standard replenishment quantity to be shipped when a resupply is triggered for this location and IMP/kit type. Defined in the supply plan and used by the RTSM to generate resupply orders automatically.' ;
    rdfs:domain ind:SiteInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resupplyRequestDate rdf:type rdf:Property ;
    rdfs:label 'Resupply Request Date' ;
    rdfs:comment 'Date on which the most recent resupply request was initiated for this inventory position. Used to track supply chain responsiveness and expected delivery timelines.' ;
    rdfs:domain ind:SiteInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resupplyTriggered rdf:type rdf:Property ;
    rdfs:label 'Resupply Triggered' ;
    rdfs:comment 'Indicates whether an active resupply request has been triggered for this inventory position. Set to True when qty_on_hand falls at or below the reorder_point and a resupply order has been initiated in the RTSM or supply management system.' ;
    rdfs:domain ind:SiteInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rtsmLocationCode rdf:type rdf:Property ;
    rdfs:label 'Rtsm Location Code' ;
    rdfs:comment 'The location identifier assigned to this site or depot within the RTSM system (Medidata Rave). Used to reconcile inventory records between the lakehouse silver layer and the operational RTSM source system.' ;
    rdfs:domain ind:SiteInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageConditionCompliant rdf:type rdf:Property ;
    rdfs:label 'Storage Condition Compliant' ;
    rdfs:comment 'Indicates whether the current storage conditions at this location are compliant with the required storage condition specification for this IMP or kit type. Set to False when a temperature excursion or storage deviation is recorded, triggering quarantine and quality review.' ;
    rdfs:domain ind:SiteInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureExcursionCount rdf:type rdf:Property ;
    rdfs:label 'Temperature Excursion Count' ;
    rdfs:comment 'Cumulative number of recorded temperature excursion events for this inventory position at this location. Used to assess cold-chain compliance history and inform quarantine or destruction decisions.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountabilityReconciliationRequired rdf:type rdf:Property ;
    rdfs:label 'Accountability Reconciliation Required' ;
    rdfs:comment 'Indicates whether drug accountability reconciliation is required under this supply plan, as mandated by GCP and regulatory requirements. Drives reconciliation workflow in RTSM and site monitoring activities.' ;
    rdfs:domain ind:SupplyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bufferStockWeeks rdf:type rdf:Property ;
    rdfs:label 'Buffer Stock Weeks' ;
    rdfs:comment 'Target buffer stock expressed in weeks of supply to be maintained at depot and/or site level. Ensures continuity of supply during manufacturing lead times and logistics delays.' ;
    rdfs:domain ind:SupplyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destructionPlanIncluded rdf:type rdf:Property ;
    rdfs:label 'Destruction Plan Included' ;
    rdfs:comment 'Indicates whether this supply plan version includes a returns and destruction plan for expired, unused, or damaged IMP. Required for GMP compliance and accountability reconciliation.' ;
    rdfs:domain ind:SupplyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expiryManagementStrategy rdf:type rdf:Property ;
    rdfs:label 'Expiry Management Strategy' ;
    rdfs:comment 'Strategy applied for managing IMP expiry at depot and site level. FIFO (First In First Out), FEFO (First Expired First Out), manual review, or RTSM-managed automated expiry tracking.' ;
    rdfs:domain ind:SupplyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastedEnrollment rdf:type rdf:Property ;
    rdfs:label 'Forecasted Enrollment' ;
    rdfs:comment 'Total number of subjects projected to be enrolled over the planning horizon, derived from enrollment projections and site feasibility assessments. Primary driver of IMP demand forecasting.' ;
    rdfs:domain ind:SupplyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:horizonEndDate rdf:type rdf:Property ;
    rdfs:label 'Horizon End Date' ;
    rdfs:comment 'End date of the planning horizon covered by this supply plan. Typically extends to study completion or database lock (DBL) plus a buffer for returns and destruction.' ;
    rdfs:domain ind:SupplyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:horizonStartDate rdf:type rdf:Property ;
    rdfs:label 'Horizon Start Date' ;
    rdfs:comment 'Start date of the planning horizon covered by this supply plan. Defines the beginning of the forecasted demand and manufacturing schedule window.' ;
    rdfs:domain ind:SupplyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overagePct rdf:type rdf:Property ;
    rdfs:label 'Overage Pct' ;
    rdfs:comment 'Planned overage percentage applied on top of net demand to account for wastage, damaged kits, protocol amendments, and supply chain uncertainties. Agreed with sponsor and documented in the supply agreement.' ;
    rdfs:domain ind:SupplyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planDate rdf:type rdf:Property ;
    rdfs:label 'Plan Date' ;
    rdfs:comment 'The principal business date on which this supply plan was formally prepared or issued. Represents the real-world event date distinct from system audit timestamps.' ;
    rdfs:domain ind:SupplyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedManufacturingBatches rdf:type rdf:Property ;
    rdfs:label 'Planned Manufacturing Batches' ;
    rdfs:comment 'Total number of manufacturing batches planned to fulfill the forecasted IMP demand over the planning horizon, including buffer and overage quantities.' ;
    rdfs:domain ind:SupplyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningCycle rdf:type rdf:Property ;
    rdfs:label 'Planning Cycle' ;
    rdfs:comment 'Frequency or trigger basis for this supply plan update cycle. Typically monthly or per enrollment milestone as defined in the supply agreement with the sponsor.' ;
    rdfs:domain ind:SupplyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resupplyQuantity rdf:type rdf:Property ;
    rdfs:label 'Resupply Quantity' ;
    rdfs:comment 'Standard quantity of kits or units to be shipped per resupply order when the resupply trigger threshold is reached. Defined per site tier and country in the supply plan.' ;
    rdfs:domain ind:SupplyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resupplyTriggerThreshold rdf:type rdf:Property ;
    rdfs:label 'Resupply Trigger Threshold' ;
    rdfs:comment 'Minimum kit or unit quantity at depot or site level that triggers an automatic resupply order via RTSM (Interactive Response Technology). When inventory falls to or below this threshold, a resupply shipment is initiated.' ;
    rdfs:domain ind:SupplyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rtsmPlanCode rdf:type rdf:Property ;
    rdfs:label 'Rtsm Plan Code' ;
    rdfs:comment 'Identifier of the corresponding supply plan configuration record within the Medidata Rave RTSM system. Enables traceability between the lakehouse supply plan record and the operational RTSM configuration.' ;
    rdfs:domain ind:SupplyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteTierScope rdf:type rdf:Property ;
    rdfs:label 'Site Tier Scope' ;
    rdfs:comment 'Site tier classification covered by this supply plan. Allows differentiated supply planning for high-enrolling versus low-enrolling sites, supporting optimized kit allocation and resupply strategies.' ;
    rdfs:domain ind:SupplyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalUnitsPlanned rdf:type rdf:Property ;
    rdfs:label 'Total Units Planned' ;
    rdfs:comment 'Total number of IMP units (e.g., tablets, vials, kits) planned for manufacture and distribution over the planning horizon, inclusive of overage and buffer stock.' ;
    rdfs:domain ind:SupplyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:treatmentArmsCount rdf:type rdf:Property ;
    rdfs:label 'Treatment Arms Count' ;
    rdfs:comment 'Number of treatment arms (including placebo/comparator) in the study protocol that require separate IMP supply planning. Drives kit type differentiation in RTSM randomization configuration.' ;
    rdfs:domain ind:SupplyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispositionAuthorizedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Disposition Authorized By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Temperature excursion disposition decisions (use/quarantine/destroy IMP) must be authorized by a qualified employee (QP or medical monitor). This FK supports GMP compliance reporting and CAPA traceabi' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedBatchNumbers rdf:type rdf:Property ;
    rdfs:label 'Affected Batch Numbers' ;
    rdfs:comment 'Comma-separated list of IMP manufacturing batch/lot numbers affected by this excursion. Required for traceability to the Certificate of Analysis (CoA) and stability data package submitted to the sponsor and regulatory authorities.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedKitCount rdf:type rdf:Property ;
    rdfs:label 'Affected Kit Count' ;
    rdfs:comment 'Total number of IMP kits exposed to the temperature excursion. Used for impact scoping, supply replacement planning, and regulatory reporting.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedKitNumbers rdf:type rdf:Property ;
    rdfs:label 'Affected Kit Numbers' ;
    rdfs:comment 'Comma-separated list of IMP kit numbers (as assigned in the RTSM/IRT system, e.g., Medidata Rave) that were exposed to the temperature excursion. Captured as a denormalized string for audit readiness; detailed kit-level records are maintained in the supply kit inventory.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataLoggerCode rdf:type rdf:Property ;
    rdfs:label 'Data Logger Code' ;
    rdfs:comment 'Unique identifier of the electronic temperature data logger or continuous monitoring device that recorded the excursion. Used for equipment traceability, calibration verification, and audit trail per 21 CFR Part 11 and EU GMP Annex 11.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionSource rdf:type rdf:Property ;
    rdfs:label 'Detection Source' ;
    rdfs:comment 'The mechanism or system that first detected the temperature excursion: data_logger (electronic temperature logger device), continuous_monitor (real-time monitoring system), manual_check (routine manual temperature check), irt_alert (Interactive Response Technology system alert from Medidata Rave RTSM), courier_report (reported by logistics provider), site_report (reported by site staff).' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDecision rdf:type rdf:Property ;
    rdfs:label 'Disposition Decision' ;
    rdfs:comment 'The final disposition decision made by the sponsor or QA team following the impact assessment. Distinct from impact_assessment_outcome in that this represents the formal, authorized decision (which may differ from the initial assessment recommendation). Drives downstream supply replacement and accountability reconciliation actions.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excursionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Excursion End Timestamp' ;
    rdfs:comment 'The date and time (ISO 8601 with timezone) at which the temperature returned within the acceptable range, marking the end of the excursion event. Null if the excursion is still ongoing at time of record creation.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:excursionNarrative rdf:type rdf:Property ;
    rdfs:label 'Excursion Narrative' ;
    rdfs:comment 'Free-text narrative describing the circumstances of the temperature excursion, including any contextual information provided by the site, depot, or courier at the time of detection. Supports GCP audit readiness and regulatory inspection documentation.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excursionNumber rdf:type rdf:Property ;
    rdfs:label 'Excursion Number' ;
    rdfs:comment 'Externally-known, human-readable reference number assigned to this excursion event, used in sponsor communications, QA investigations, and regulatory audit trails. Typically generated by the RTSM or CTMS system (e.g., Medidata Rave or Oracle Siebel CTMS).' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excursionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Excursion Start Timestamp' ;
    rdfs:comment 'The date and time (ISO 8601 with timezone) at which the temperature excursion began — i.e., when the temperature first breached the defined threshold. This is the principal real-world event time for the excursion. Critical for duration calculation and impact assessment.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:excursionStatus rdf:type rdf:Property ;
    rdfs:label 'Excursion Status' ;
    rdfs:comment 'Current lifecycle status of the excursion event record. Drives QA workflow: open (newly detected), under_investigation (impact assessment in progress), pending_disposition (awaiting sponsor/QA decision), closed (disposition finalized), voided (false alarm or data entry error confirmed).' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excursionType rdf:type rdf:Property ;
    rdfs:label 'Excursion Type' ;
    rdfs:comment 'Classification of the excursion by the nature of the breach: high_temperature (exceeded upper limit), low_temperature (fell below lower limit), freeze_thaw (frozen product that should not be), humidity (relative humidity breach), combined (multiple parameter breach simultaneously).' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactAssessmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Impact Assessment Outcome' ;
    rdfs:comment 'The outcome of the scientific/QA impact assessment determining the usability of the affected IMP: use (product confirmed acceptable for continued use), quarantine (product held pending further evaluation), destroy (product deemed unusable and scheduled for destruction), pending (assessment not yet completed), return_to_sponsor (product to be returned to sponsor for evaluation). Critical for GCP compliance and patient safety.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loggerCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Logger Calibration Date' ;
    rdfs:comment 'The most recent calibration date of the temperature data logger at the time of the excursion. Required to validate the reliability of the recorded temperature data for GCP audit readiness and regulatory submissions.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lowerThresholdC rdf:type rdf:Property ;
    rdfs:label 'Lower Threshold C' ;
    rdfs:comment 'The minimum acceptable storage temperature (in degrees Celsius) defined for the affected IMP, as specified in the kit definition or product stability data. Breach of this threshold constitutes a low-temperature excursion.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxTempRecordedC rdf:type rdf:Property ;
    rdfs:label 'Max Temp Recorded C' ;
    rdfs:comment 'The highest temperature value (in degrees Celsius) recorded during the excursion event. Used to assess the severity of a high-temperature excursion against product stability specifications.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanKineticTempC rdf:type rdf:Property ;
    rdfs:label 'Mean Kinetic Temp C' ;
    rdfs:comment 'The Mean Kinetic Temperature (MKT) in degrees Celsius calculated for the excursion period. MKT is the single calculated temperature that, if maintained over the storage period, would produce the same thermal stress as the actual temperature fluctuations. Used per USP <1079> and WHO guidelines for stability impact assessment.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTempRecordedC rdf:type rdf:Property ;
    rdfs:label 'Min Temp Recorded C' ;
    rdfs:comment 'The lowest temperature value (in degrees Celsius) recorded during the excursion event. Used to assess the severity of a low-temperature or freeze-thaw excursion against product stability specifications.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replacementKitsRequired rdf:type rdf:Property ;
    rdfs:label 'Replacement Kits Required' ;
    rdfs:comment 'Indicates whether replacement IMP kits need to be dispatched to the affected site or depot as a result of the disposition decision (e.g., quarantine or destroy outcome). Drives supply replenishment workflow in the RTSM (Medidata Rave).' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedBy rdf:type rdf:Property ;
    rdfs:label 'Reported By' ;
    rdfs:comment 'Name or user identifier of the person (e.g., CRC, CRA, site pharmacist, depot manager) who first reported or logged the temperature excursion into the system. Supports ALCOA+ attributability requirements.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'The date and time when the excursion was formally reported or entered into the system. May differ from excursion_start_timestamp if there was a delay in detection or reporting. Supports ALCOA+ contemporaneity assessment.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rtsmExcursionReference rdf:type rdf:Property ;
    rdfs:label 'Rtsm Excursion Reference' ;
    rdfs:comment 'The excursion or alert reference identifier as recorded in the RTSM system (Medidata Rave IRT/RTSM module). Used for cross-system traceability between the lakehouse silver layer and the operational source system.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stabilityDataReviewed rdf:type rdf:Property ;
    rdfs:label 'Stability Data Reviewed' ;
    rdfs:comment 'Indicates whether the product stability data (from the Investigational Medicinal Product Dossier or stability package) was formally reviewed as part of the impact assessment for this excursion. True = reviewed; False = not yet reviewed. Required for GCP compliance documentation.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:upperThresholdC rdf:type rdf:Property ;
    rdfs:label 'Upper Threshold C' ;
    rdfs:comment 'The maximum acceptable storage temperature (in degrees Celsius) defined for the affected IMP, as specified in the kit definition or product stability data. Breach of this threshold constitutes a high-temperature excursion.' ;
    rdfs:domain ind:TemperatureExcursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationId rdf:type rdf:Property ;
    rdfs:label 'Certification Id' ;
    rdfs:comment 'Unique surrogate identifier for each professional certification record held by a clinical research workforce member. Primary key for the certification data product.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ceCreditsEarned rdf:type rdf:Property ;
    rdfs:label 'Ce Credits Earned' ;
    rdfs:comment 'Total number of continuing education (CE) credits earned by the workforce member in the current renewal cycle toward maintaining or renewing this certification. Compared against ce_credits_required to assess compliance gap.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ceCreditsRequired rdf:type rdf:Property ;
    rdfs:label 'Ce Credits Required' ;
    rdfs:comment 'Total number of continuing education (CE) credits required by the issuing body to maintain or renew the certification within the current renewal cycle. Used to track workforce compliance with professional development obligations.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ceCycleEndDate rdf:type rdf:Property ;
    rdfs:label 'Ce Cycle End Date' ;
    rdfs:comment 'End date of the current continuing education (CE) credit accumulation cycle for this certification. CE credits must be earned by this date to satisfy the renewal requirement.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ceCycleStartDate rdf:type rdf:Property ;
    rdfs:label 'Ce Cycle Start Date' ;
    rdfs:comment 'Start date of the current continuing education (CE) credit accumulation cycle for this certification. CE credits earned before this date do not count toward the current renewal requirement.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'Externally issued unique credential number assigned by the certifying body (e.g., ACRP certificate number, SOCRA CCRP number, RAC registration number). Used for verification with the issuing organization and regulatory audit purposes.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Total monetary cost incurred by the organization for this certification, including examination fees, application fees, and renewal fees paid to the issuing body. Expressed in the currency specified by cost_currency. Used for workforce development budget tracking in SAP S/4HANA.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the cost_amount (e.g., USD, EUR, GBP, JPY). Required for multi-currency financial reporting and budget consolidation in SAP S/4HANA.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialScope rdf:type rdf:Property ;
    rdfs:label 'Credential Scope' ;
    rdfs:comment 'Geographic or organizational scope of the certification\'s recognition and applicability. \'global\' = recognized internationally (e.g., ICH-aligned); \'regional\' = recognized within a regulatory region (e.g., EU, Asia-Pacific); \'national\' = recognized within a single country; \'institutional\' = recognized only within a specific organization.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Reference identifier or URL pointing to the scanned certificate document stored in the eTMF or document management system (Veeva Vault / MasterControl). Enables direct retrieval of the credential document for regulatory inspections and audit purposes.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examDate rdf:type rdf:Property ;
    rdfs:label 'Exam Date' ;
    rdfs:comment 'Date on which the workforce member sat the certification examination. Distinct from issue_date (when the credential was formally awarded). Null if no examination was required for this credential.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examLocation rdf:type rdf:Property ;
    rdfs:label 'Exam Location' ;
    rdfs:comment 'Name or description of the testing center, proctored online platform, or venue where the certification examination was administered (e.g., \'Prometric Testing Center - Chicago\', \'Online - ProctorU\'). Supports audit trail and verification.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examScore rdf:type rdf:Property ;
    rdfs:label 'Exam Score' ;
    rdfs:comment 'Numeric score achieved by the workforce member on the certification examination, as reported by the issuing body. Expressed as a percentage or raw score per the issuing body\'s scale. Null if the certification does not require an examination.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuingBody rdf:type rdf:Property ;
    rdfs:label 'Issuing Body' ;
    rdfs:comment 'Name of the external organization that awarded and administers the certification (e.g., ACRP - Association of Clinical Research Professionals, SOCRA - Society of Clinical Research Associates, RAPS - Regulatory Affairs Professionals Society, SAS Institute, SCDM - Society for Clinical Data Management). Critical for verification and regulatory compliance.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBodyCountry rdf:type rdf:Property ;
    rdfs:label 'Issuing Body Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the certifying body is headquartered or where the certification was issued. Relevant for multi-jurisdictional regulatory compliance (FDA, EMA, PMDA, MHRA, Health Canada).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passingScore rdf:type rdf:Property ;
    rdfs:label 'Passing Score' ;
    rdfs:comment 'Minimum passing score required by the issuing body to achieve the certification. Used to contextualize the exam_score and confirm the workforce member met the threshold. Null if no examination is required.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reimbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Amount' ;
    rdfs:comment 'Actual monetary amount reimbursed to the workforce member for this certification, in the currency specified by cost_currency. May differ from cost_amount if partial reimbursement applies per company policy.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reimbursementEligible rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Eligible' ;
    rdfs:comment 'Indicates whether the organization reimburses the workforce member for the cost of obtaining or renewing this certification under the company\'s professional development or tuition reimbursement policy. True = eligible for reimbursement; False = not eligible.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalReminderDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Reminder Days' ;
    rdfs:comment 'Number of calendar days before the expiry_date at which automated renewal reminder notifications should be triggered for the workforce member and their manager. Configurable per certification type to align with issuing body renewal windows (e.g., 90 days for ACRP CCRC).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialtyArea rdf:type rdf:Property ;
    rdfs:label 'Specialty Area' ;
    rdfs:comment 'Clinical research functional specialty area covered by the certification (e.g., oncology, pharmacovigilance, biostatistics, data management, regulatory affairs, GCP monitoring, pharmacokinetics). Used for resource allocation matching and capability gap analysis.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:craApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Cra Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee record of the authorized approver (e.g., QA Manager, Training Manager) who formally approved the CRA qualification profile for use in study assignments.' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryCraEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Cra Employee Id' ;
    rdfs:comment 'Reference to the employee record in Workday HCM representing the CRA whose qualification profile this record describes.' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:countryCodes rdf:type rdf:Property ;
    rdfs:label 'Country Codes' ;
    rdfs:comment 'Pipe-delimited list of ISO 3166-1 alpha-3 country codes representing countries where the CRA is authorized to conduct site monitoring (e.g., USA|GBR|DEU|JPN). Supports country-level site assignment decisions.' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:craQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Cra Qualification Status' ;
    rdfs:comment 'Current lifecycle status of this CRA\'s qualification for the specific therapeutic area. Drives eligibility filtering during CRA-to-study matching.' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsProficiency rdf:type rdf:Property ;
    rdfs:label 'Ctms Proficiency' ;
    rdfs:comment 'Proficiency level of the CRA in Oracle Siebel CTMS for site monitoring visit tracking, action item management, and study progress reporting.' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsQualificationRef rdf:type rdf:Property ;
    rdfs:label 'Ctms Qualification Ref' ;
    rdfs:comment 'Oracle Siebel CTMS system reference identifier for the CRA qualification record, used for cross-system traceability between the Databricks Silver Layer and the operational CTMS.' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceTrialExperienceConfirmed rdf:type rdf:Property ;
    rdfs:label 'Device Trial Experience Confirmed' ;
    rdfs:comment 'Indicates whether the CRA has documented experience monitoring medical device clinical investigations, subject to ISO 14155 requirements distinct from pharmaceutical GCP.' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:experienceConfirmed rdf:type rdf:Property ;
    rdfs:label 'Experience Confirmed' ;
    rdfs:comment 'Indicates whether the CRA has confirmed, documented monitoring experience in this specific therapeutic area, as distinct from theoretical or training-based qualification. Used as a quality gate in study assignment eligibility.' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicRegions rdf:type rdf:Property ;
    rdfs:label 'Geographic Regions' ;
    rdfs:comment 'Pipe-delimited list of geographic regions where the CRA is qualified and authorized to conduct monitoring activities (e.g., North America|Western Europe|Asia Pacific). Used for regional site assignment planning.' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:independentMonitoringVisits rdf:type rdf:Property ;
    rdfs:label 'Independent Monitoring Visits' ;
    rdfs:comment 'Count of monitoring visits conducted independently (without co-monitoring oversight), distinguishing fully qualified CRAs from those still under supervised training.' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:irtRtsmProficiency rdf:type rdf:Property ;
    rdfs:label 'Irt Rtsm Proficiency' ;
    rdfs:comment 'Proficiency level of the CRA in IRT/RTSM systems (e.g., Medidata RTSM) for patient randomization, drug supply management, and kit dispensation oversight during site monitoring.' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageProficiencies rdf:type rdf:Property ;
    rdfs:label 'Language Proficiencies' ;
    rdfs:comment 'Pipe-delimited list of ISO 639-1 language codes in which the CRA is proficient for site communication and source document review (e.g., en|de|fr|ja). Critical for site assignment in non-English-speaking countries.' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastQualificationReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Qualification Review Date' ;
    rdfs:comment 'Date of the most recent formal review and update of the CRA qualification profile by the line manager or QA function, ensuring the profile reflects current competencies.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medidataRaveProficiency rdf:type rdf:Property ;
    rdfs:label 'Medidata Rave Proficiency' ;
    rdfs:comment 'Self-assessed and/or verified proficiency level of the CRA in Medidata Rave Electronic Data Capture (EDC) system, including eCRF review, query management, and SDV workflows.' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringExperienceYears rdf:type rdf:Property ;
    rdfs:label 'Monitoring Experience Years' ;
    rdfs:comment 'Total years of clinical site monitoring experience accumulated by the CRA, used as a primary qualification criterion for study-phase and complexity-based assignment decisions.' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextQualificationReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Qualification Review Date' ;
    rdfs:comment 'Scheduled date for the next periodic review of the CRA qualification profile. Drives automated reminders in CTMS and Workday HCM to ensure timely re-qualification.' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oncologyExperienceConfirmed rdf:type rdf:Property ;
    rdfs:label 'Oncology Experience Confirmed' ;
    rdfs:comment 'Indicates whether the CRA has confirmed, documented oncology monitoring experience, a specialized qualification required for oncology study assignments given the complexity of CTCAE adverse event grading and tumor assessment protocols. [Moved from cra_qualification: This is a TA-specific experience flag hardcoded for Oncology on the CRA master record. It is a special case of the generic \'experience_confirmed\' association attribute and belongs on the cra_ta_qualification record for the Oncology therapeutic area, not as a standalone boolean on the CRA profile.]' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oracleClinicalOneProficiency rdf:type rdf:Property ;
    rdfs:label 'Oracle Clinical One Proficiency' ;
    rdfs:comment 'Proficiency level of the CRA in Oracle Clinical One platform, covering study design navigation, site management functions, and patient randomization workflows.' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Primary Language Code' ;
    rdfs:comment 'ISO 639-1 two-letter code for the CRA\'s primary working language. Used as the default language for monitoring report generation and site communication.' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationCode rdf:type rdf:Property ;
    rdfs:label 'Qualification Code' ;
    rdfs:comment 'Externally-known business identifier for the qualification profile, used in Oracle Siebel CTMS and Workday HCM for cross-system reference and CRA-to-study matching workflows.' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Effective Date' ;
    rdfs:comment 'Date from which the CRA qualification profile became effective and the CRA was eligible for study assignment based on this profile. Represents the start of the qualification agreement period.' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationNotes rdf:type rdf:Property ;
    rdfs:label 'Qualification Notes' ;
    rdfs:comment 'Free-text field for additional qualification context, exceptions, or special conditions noted by the reviewing manager (e.g., \'Qualified for Phase I only pending Phase II co-monitoring completion\').' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationType rdf:type rdf:Property ;
    rdfs:label 'Qualification Type' ;
    rdfs:comment 'Classification of the CRA qualification profile by operational role type. Determines eligibility for specific monitoring assignment categories (e.g., field vs. remote monitoring, lead CRA oversight responsibilities).' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskBasedMonitoringQualified rdf:type rdf:Property ;
    rdfs:label 'Risk Based Monitoring Qualified' ;
    rdfs:comment 'Indicates whether the CRA is qualified to conduct risk-based monitoring (RBM) activities, including centralized statistical monitoring review and targeted SDV, per ICH E6(R2) Addendum guidance.' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdvExperienceConfirmed rdf:type rdf:Property ;
    rdfs:label 'Sdv Experience Confirmed' ;
    rdfs:comment 'Indicates whether the CRA has confirmed, documented experience performing Source Data Verification (SDV) against source documents at clinical sites, a core GCP monitoring competency.' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorQualificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Sponsor Qualification Expiry Date' ;
    rdfs:comment 'Date on which the most recent sponsor-specific qualification expires and requires renewal. Used to trigger re-qualification workflows and prevent assignment of expired-qualified CRAs to sponsor studies.' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sponsorQualifications rdf:type rdf:Property ;
    rdfs:label 'Sponsor Qualifications' ;
    rdfs:comment 'Pipe-delimited list of sponsor names or sponsor codes for which the CRA holds sponsor-specific qualification status (e.g., sponsor-mandated training completion, sponsor-approved CRA status). Used for sponsor-restricted study assignments.' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyPhasesExperienced rdf:type rdf:Property ;
    rdfs:label 'Study Phases Experienced' ;
    rdfs:comment 'Pipe-delimited list of clinical study phases in which the CRA has monitoring experience (e.g., Phase I|Phase II|Phase III|Phase IV). Used to match CRAs to studies of appropriate complexity. [ENUM-REF-CANDIDATE: Phase I|Phase II|Phase III|Phase IV|Phase I/II|Phase II/III — promote to reference product]' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticAreas rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Areas' ;
    rdfs:comment 'Pipe-delimited list of therapeutic areas in which the CRA has documented monitoring experience (e.g., Oncology|Cardiology|Neurology|Infectious Disease). Used for therapeutic area-based study matching. [ENUM-REF-CANDIDATE: Oncology|Cardiology|Neurology|Infectious Disease|Immunology|Rare Disease|Metabolic|Respiratory — promote to reference product] [Moved from cra_qualification: This pipe-delimited STRING is an anti-pattern storing multiple TA values on the CRA master record. It cannot enforce referential integrity, cannot carry per-TA qualification metadata, and violates 1NF. All TA qualification data belongs on the association product as properly normalized records.]' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalMonitoringVisits rdf:type rdf:Property ;
    rdfs:label 'Total Monitoring Visits' ;
    rdfs:comment 'Cumulative count of clinical site monitoring visits (initiation, interim, close-out) conducted by the CRA across all studies. Key operational metric for experience-based qualification assessment.' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:veevaVaultProficiency rdf:type rdf:Property ;
    rdfs:label 'Veeva Vault Proficiency' ;
    rdfs:comment 'Proficiency level of the CRA in Veeva Vault for electronic Trial Master File (eTMF) management, regulatory document filing, and TMF completeness tracking.' ;
    rdfs:domain ind:CraQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayWorkerCode rdf:type rdf:Property ;
    rdfs:label 'Workday Worker Code' ;
    rdfs:comment 'Workday HCM system worker identifier for the CRA, used for cross-system reconciliation between the qualification profile and HR records.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingRateUsd rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Usd' ;
    rdfs:comment 'The standard hourly or daily billing rate for this workforce member in US dollars, used for sponsor invoicing, study budget calculations, and scope-of-work costing. Confidential financial data managed in SAP S/4HANA.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdiscCertified rdf:type rdf:Property ;
    rdfs:label 'Cdisc Certified' ;
    rdfs:comment 'Indicates whether the workforce member holds a current CDISC certification (e.g., CDISC SDTM, ADaM). Relevant for Data Managers and Biostatisticians assigned to CDISC-compliant submission deliverables.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:departmentName rdf:type rdf:Property ;
    rdfs:label 'Department Name' ;
    rdfs:comment 'Human-readable name of the organizational department to which the workforce member belongs. Complements department_code for reporting and display purposes in CTMS and workforce dashboards.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current lifecycle state of the workforce member\'s employment. Controls access to EDC systems (Medidata Rave), CTMS (Oracle Siebel), eTMF (Veeva Vault), and determines eligibility for new study assignments. Active status is required for delegation log entries per ICH E6(R2).' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etmfUserCode rdf:type rdf:Property ;
    rdfs:label 'Etmf User Code' ;
    rdfs:comment 'The user account identifier for this workforce member in Veeva Vault eTMF. Used to attribute document uploads, approvals, and access events in the trial master file audit trail per ICH E6(R2) and 21 CFR Part 11.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftePercentage rdf:type rdf:Property ;
    rdfs:label 'Fte Percentage' ;
    rdfs:comment 'The proportion of a full-time equivalent that this workforce member represents, expressed as a percentage (e.g., 100.00 for full-time, 50.00 for half-time). Used for capacity planning, resource allocation to studies, and payroll cost calculations in SAP S/4HANA.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gcpRole rdf:type rdf:Property ;
    rdfs:label 'Gcp Role' ;
    rdfs:comment 'The primary GCP-defined functional role of the workforce member within clinical research operations. Determines which study activities the employee may be delegated to perform, which training curricula apply in MasterControl, and which CTMS access profiles are provisioned. [ENUM-REF-CANDIDATE: CRA|CRC|Biostatistician|Data_Manager|Medical_Monitor|Regulatory_Specialist|PI|Project_Manager|Safety_Physician|QA_Auditor — promote to reference product]' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highestEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Highest Education Level' ;
    rdfs:comment 'The highest academic qualification attained by the workforce member, as recorded in Workday HCM. Used for role eligibility checks (e.g., Medical Monitor requires MD/PhD), regulatory submission CVs, and sponsor qualification packages.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'The date on which the workforce member officially commenced employment or engagement with the CRO, as recorded in Workday HCM. Used to calculate tenure, GCP training due dates, and eligibility windows for study assignments.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isKeyPersonnel rdf:type rdf:Property ;
    rdfs:label 'Is Key Personnel' ;
    rdfs:comment 'Indicates whether this workforce member is designated as key personnel on one or more active study contracts or regulatory submissions. Key personnel changes may require sponsor notification and regulatory amendment per ICH E6(R2) and FDA guidance.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Official job title of the workforce member as defined in Workday HCM. Appears on delegation logs, regulatory submissions, and sponsor-facing documentation. Examples: Senior Clinical Research Associate, Principal Biostatistician, Data Manager II.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Nationality Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the workforce member\'s nationality. Used for visa and work authorization tracking, international study assignment eligibility, and regulatory authority jurisdiction compliance.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payGrade rdf:type rdf:Property ;
    rdfs:label 'Pay Grade' ;
    rdfs:comment 'Compensation grade band assigned to the workforce member in Workday HCM, defining the salary range and benefits tier. Confidential HR data used for compensation equity analysis and workforce cost modeling.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredName rdf:type rdf:Property ;
    rdfs:label 'Preferred Name' ;
    rdfs:comment 'The name the workforce member prefers to be addressed by in operational communications and CTMS displays. May differ from legal name; does not replace legal name for regulatory documents.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:professionalLicenseCountry rdf:type rdf:Property ;
    rdfs:label 'Professional License Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction that issued the workforce member\'s professional license. Used to validate regulatory eligibility for study roles in specific geographies.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:professionalLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Professional License Number' ;
    rdfs:comment 'Professional license or registration number for regulated roles (e.g., medical license for Medical Monitors, nursing license for CRCs). Required for regulatory submissions and delegation log validation. Confidential business data.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionAssignment rdf:type rdf:Property ;
    rdfs:label 'Region Assignment' ;
    rdfs:comment 'The geographic region to which the workforce member is primarily assigned for study operations (e.g., North America, Europe, Asia-Pacific). Used for regional capacity planning, CRA territory management, and sponsor reporting.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workAuthorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Work Authorization Status' ;
    rdfs:comment 'Current work authorization status of the workforce member for their primary work country. Determines eligibility for international study assignments and site visits. Managed in Workday HCM.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCountryCode rdf:type rdf:Property ;
    rdfs:label 'Work Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the workforce member\'s primary work location. Determines applicable labor law, data privacy regulations (GDPR, HIPAA), and regulatory authority jurisdiction for GCP compliance.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workLocationCode rdf:type rdf:Property ;
    rdfs:label 'Work Location Code' ;
    rdfs:comment 'Code identifying the primary physical or virtual work location of the workforce member (e.g., office site, home-based, field-based). Used for resource allocation, travel cost planning, and site monitoring coverage mapping.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateDocumentId rdf:type rdf:Property ;
    rdfs:label 'Certificate Document Id' ;
    rdfs:comment 'Reference to the scanned or electronic training certificate stored in Veeva Vault eTMF or MasterControl document management. Enables direct access to the source certificate for audit and inspection purposes.' ;
    rdfs:domain ind:GcpTrainingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TmfDocument .

ind:trainingCourseId rdf:type rdf:Property ;
    rdfs:label 'Training Course Id' ;
    rdfs:comment 'Reference to the training course master record in MasterControl that defines the course curriculum, version, and requirements for this GCP training.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingCourse .

ind:assignedDate rdf:type rdf:Property ;
    rdfs:label 'Assigned Date' ;
    rdfs:comment 'The date on which this GCP training was formally assigned to the workforce member in MasterControl. Used to calculate time-to-completion and overdue status.' ;
    rdfs:domain ind:GcpTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued Date' ;
    rdfs:comment 'The date on which the training certificate was formally issued by the training provider. May differ from completion_date if certificate issuance involves a processing delay. Required for TMF documentation.' ;
    rdfs:domain ind:GcpTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:courseCode rdf:type rdf:Property ;
    rdfs:label 'Course Code' ;
    rdfs:comment 'Alphanumeric code uniquely identifying the training course in MasterControl (e.g., \'TRN-GCP-001\'). Used for structured reporting, filtering, and integration with CTMS and eTMF systems.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseName rdf:type rdf:Property ;
    rdfs:label 'Course Name' ;
    rdfs:comment 'Full name of the GCP training course as defined in MasterControl (e.g., \'ICH E6(R2) GCP Fundamentals\', \'GCP Refresher Training\', \'Protocol-Specific GCP Training — Study XYZ-001\'). Used for reporting and compliance verification.' ;
    rdfs:domain ind:GcpTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurriculumRequired rdf:type rdf:Property ;
    rdfs:label 'Is Curriculum Required' ;
    rdfs:comment 'Indicates whether this training record was generated from a mandatory curriculum assignment (True) or was voluntarily completed outside of a formal curriculum (False). Used to distinguish mandatory compliance training from elective training.' ;
    rdfs:domain ind:GcpTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGcpCurrent rdf:type rdf:Property ;
    rdfs:label 'Is Gcp Current' ;
    rdfs:comment 'Indicates whether this training record represents a currently valid (non-expired) GCP certification (True) or has expired (False). Derived from expiry_date vs. current date but stored as a business flag for efficient compliance queries and delegation log validation.' ;
    rdfs:domain ind:GcpTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mastercontrolRecordCode rdf:type rdf:Property ;
    rdfs:label 'Mastercontrol Record Code' ;
    rdfs:comment 'The externally-known unique identifier assigned by MasterControl training management system to this training completion record. Used for cross-system traceability and audit trail back to the system of record.' ;
    rdfs:domain ind:GcpTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfAttempts rdf:type rdf:Property ;
    rdfs:label 'Number Of Attempts' ;
    rdfs:comment 'Total number of attempts the workforce member made on the GCP training assessment before achieving a pass or exhausting allowed attempts. Used for quality monitoring and identifying personnel who may need additional support.' ;
    rdfs:domain ind:GcpTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'Outcome of the training assessment: \'pass\' (met or exceeded minimum passing score), \'fail\' (did not meet minimum passing score — remedial training required), \'not_applicable\' (no assessment required for this training type, e.g., read-and-acknowledge only).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleAtTraining rdf:type rdf:Property ;
    rdfs:label 'Role At Training' ;
    rdfs:comment 'The workforce role of the employee at the time of training completion (e.g., \'CRA\', \'CRC\', \'PI\', \'Sub-Investigator\', \'Data Manager\', \'Biostatistician\', \'Medical Monitor\', \'Regulatory Affairs Specialist\'). Captured at training time to preserve historical accuracy even if the employee\'s role changes. [ENUM-REF-CANDIDATE: CRA|CRC|PI|sub_investigator|data_manager|biostatistician|medical_monitor|regulatory_specialist|study_coordinator|project_manager — promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmfFilingReference rdf:type rdf:Property ;
    rdfs:label 'Tmf Filing Reference' ;
    rdfs:comment 'The TMF artifact reference number or section code where this training record is filed in the eTMF (e.g., Veeva Vault TMF section \'05.01 — Curriculum Vitae and GCP Training\'). Enables direct traceability between training records and TMF documentation.' ;
    rdfs:domain ind:GcpTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainerQualification rdf:type rdf:Property ;
    rdfs:label 'Trainer Qualification' ;
    rdfs:comment 'Qualifications or credentials of the trainer who delivered the GCP training (e.g., \'Certified GCP Trainer\', \'CCRP\', \'MD\', \'PhD\'). Documents trainer competency as required for regulatory inspection readiness.' ;
    rdfs:domain ind:GcpTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingDurationHours rdf:type rdf:Property ;
    rdfs:label 'Training Duration Hours' ;
    rdfs:comment 'Total duration of the GCP training course in hours (e.g., 2.50 for a 2.5-hour e-learning module). Used for workforce capacity planning, training hour reporting, and regulatory documentation of training effort.' ;
    rdfs:domain ind:GcpTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingProvider rdf:type rdf:Property ;
    rdfs:label 'Training Provider' ;
    rdfs:comment 'Name of the organization or entity that delivered the GCP training (e.g., \'CITI Program\', \'TransCelerate\', \'Internal Training Department\', \'ACRP\', \'SOCRA\', \'External CRO Training Vendor\'). Required for regulatory documentation and audit trail.' ;
    rdfs:domain ind:GcpTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingProviderType rdf:type rdf:Property ;
    rdfs:label 'Training Provider Type' ;
    rdfs:comment 'Classification of the training provider: \'internal\' (delivered by the CRO\'s own training department), \'external\' (third-party training vendor), \'sponsor\' (delivered by the pharmaceutical/biotech sponsor), \'regulatory_body\' (delivered by FDA, EMA, ICH, or equivalent).' ;
    rdfs:domain ind:GcpTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billableRole rdf:type rdf:Property ;
    rdfs:label 'Billable Role' ;
    rdfs:comment 'Indicates whether employees in this job profile are billable to sponsors under study contracts. Drives project accounting in SAP S/4HANA and financial forecasting for study budgets.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingRateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the standard billing rate (e.g., \'USD\', \'EUR\'). Required for multi-currency sponsor billing and financial reporting.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingRateUnit rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Unit' ;
    rdfs:comment 'Time unit basis for the standard billing rate (hourly, daily, or monthly). Ensures consistent financial calculations across study budgets and sponsor invoices.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdiscRoleAlignment rdf:type rdf:Property ;
    rdfs:label 'Cdisc Role Alignment' ;
    rdfs:comment 'Maps the job profile to a recognized CDISC role designation (e.g., \'SDTM Programmer\', \'ADaM Statistician\', \'Data Manager\'). Supports CDISC-compliant study team composition and submission readiness assessments.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyFrameworkVersion rdf:type rdf:Property ;
    rdfs:label 'Competency Framework Version' ;
    rdfs:comment 'Version identifier of the competency framework applied to this job profile (e.g., \'CF-2024-v2.1\'). Enables tracking of competency model evolution and gap analysis over time.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsAccessLevel rdf:type rdf:Property ;
    rdfs:label 'Ctms Access Level' ;
    rdfs:comment 'Standard CTMS access level assigned to employees in this job profile within Oracle Siebel CTMS. Controls visibility of site, subject, and monitoring data.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegationEligible rdf:type rdf:Property ;
    rdfs:label 'Delegation Eligible' ;
    rdfs:comment 'Indicates whether employees in this job profile are eligible to appear on a study delegation log as a delegated task performer. Critical for GCP compliance and site inspection readiness.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:edcAccessLevel rdf:type rdf:Property ;
    rdfs:label 'Edc Access Level' ;
    rdfs:comment 'Standard EDC system access level assigned to employees in this job profile within Medidata Rave. Drives system access provisioning and audit trail compliance per 21 CFR Part 11.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptStatus rdf:type rdf:Property ;
    rdfs:label 'Exempt Status' ;
    rdfs:comment 'Indicates whether the job profile is classified as exempt or non-exempt under the Fair Labor Standards Act (FLSA) or equivalent local labor law. Determines overtime eligibility and payroll processing rules in Workday HCM.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gcpRoleCategory rdf:type rdf:Property ;
    rdfs:label 'Gcp Role Category' ;
    rdfs:comment 'Categorizes the job profile according to its GCP-defined role in clinical trial conduct. Drives GCP training requirements, delegation log eligibility, and regulatory inspection readiness. Values align with ICH E6(R2) role definitions. [ENUM-REF-CANDIDATE: PI|CRA|CRC|Medical Monitor|Data Manager|Biostatistician|Regulatory Specialist|Other — promote to reference product]' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gcpTrainingFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Gcp Training Frequency Months' ;
    rdfs:comment 'Required recertification interval in months for GCP training associated with this job profile (e.g., 24 months). Used to schedule training renewals and flag compliance gaps in MasterControl.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jobCategory rdf:type rdf:Property ;
    rdfs:label 'Job Category' ;
    rdfs:comment 'Classifies the job profile as an individual contributor, people manager, director, or executive. Used for span-of-control analysis and leadership pipeline planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobFamily rdf:type rdf:Property ;
    rdfs:label 'Job Family' ;
    rdfs:comment 'Broad functional grouping to which this job profile belongs within the clinical research organization. Drives workforce planning, competency frameworks, and organizational reporting. [ENUM-REF-CANDIDATE: Clinical Operations|Biostatistics|Data Management|Regulatory Affairs|Medical Affairs|Finance|Workforce|Laboratory|Supply Chain|Compliance — promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobFamilyGroup rdf:type rdf:Property ;
    rdfs:label 'Job Family Group' ;
    rdfs:comment 'Higher-level grouping above job family used for enterprise-wide workforce analytics and organizational hierarchy reporting in Workday HCM (e.g., \'Research & Development\', \'Corporate Functions\').' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobLevel rdf:type rdf:Property ;
    rdfs:label 'Job Level' ;
    rdfs:comment 'Seniority tier of the job profile within its job family. Determines scope of responsibilities, delegation authority, and salary band eligibility. Values: Associate, Senior, Principal, Director, Executive.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyCompetencies rdf:type rdf:Property ;
    rdfs:label 'Key Competencies' ;
    rdfs:comment 'Comma-separated list of core competencies required for this job profile (e.g., \'Protocol Deviation Management, SDV, eCRF Review, Site Relationship Management\'). Used in competency gap analysis and talent development planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementLevel rdf:type rdf:Property ;
    rdfs:label 'Management Level' ;
    rdfs:comment 'Numeric management tier within the organizational hierarchy (e.g., 1 = individual contributor, 2 = team lead, 3 = manager, 4 = director). Supports org chart rendering and reporting chain analysis.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:profileCode rdf:type rdf:Property ;
    rdfs:label 'Profile Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying the job profile across the organization. Used in workforce planning, delegation logs, and resource allocation systems.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileName rdf:type rdf:Property ;
    rdfs:label 'Profile Name' ;
    rdfs:comment 'Human-readable title of the job profile as defined in the Workday HCM job catalog (e.g., \'Senior Clinical Research Associate\', \'Principal Biostatistician\').' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileOwner rdf:type rdf:Property ;
    rdfs:label 'Profile Owner' ;
    rdfs:comment 'Name or identifier of the HR business partner or functional leader responsible for maintaining this job profile definition. Provides accountability for profile accuracy and timely review.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle status of the job profile. \'active\' profiles are available for staffing; \'inactive\' profiles are retired from use; \'draft\' profiles are under review; \'archived\' profiles are retained for historical reference.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionAccess rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Access' ;
    rdfs:comment 'Indicates whether this job profile is authorized to access and contribute to regulatory submission documents in Veeva Vault. Supports 21 CFR Part 11 electronic records access controls.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remoteEligible rdf:type rdf:Property ;
    rdfs:label 'Remote Eligible' ;
    rdfs:comment 'Indicates whether this job profile is approved for remote or hybrid work arrangements. Used in workforce planning and resource allocation decisions.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredCertifications rdf:type rdf:Property ;
    rdfs:label 'Required Certifications' ;
    rdfs:comment 'Comma-separated list of mandatory professional certifications for this job profile (e.g., \'GCP Certificate, ACRP CCRA, CCDM\'). Drives training compliance tracking in MasterControl and Workday HCM.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Required Education Level' ;
    rdfs:comment 'Minimum academic qualification required for this job profile. Used in talent acquisition screening, competency gap analysis, and regulatory inspection readiness for GCP-critical roles.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredYearsExperience rdf:type rdf:Property ;
    rdfs:label 'Required Years Experience' ;
    rdfs:comment 'Minimum number of years of relevant professional experience required for this job profile. Used in recruitment screening and workforce planning.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyReportingRole rdf:type rdf:Property ;
    rdfs:label 'Safety Reporting Role' ;
    rdfs:comment 'Indicates whether this job profile carries responsibilities for adverse event (AE) or serious adverse event (SAE) reporting. Drives access provisioning in Oracle Argus Safety and regulatory notification workflows.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salaryBandCode rdf:type rdf:Property ;
    rdfs:label 'Salary Band Code' ;
    rdfs:comment 'Alphanumeric code identifying the compensation band assigned to this job profile (e.g., \'G5\', \'M3\'). Determines the approved salary range for workforce planning and compensation benchmarking. Classified as confidential business data.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Salary Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the salary range values (e.g., \'USD\', \'EUR\', \'GBP\'). Required for multi-currency workforce planning and financial reporting.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryRangeMax rdf:type rdf:Property ;
    rdfs:label 'Salary Range Max' ;
    rdfs:comment 'Maximum base salary (in local currency) approved for this job profile within its salary band. Used for compensation planning, offer management, and equity analysis. Classified as confidential.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salaryRangeMin rdf:type rdf:Property ;
    rdfs:label 'Salary Range Min' ;
    rdfs:comment 'Minimum base salary (in local currency) approved for this job profile within its salary band. Used for compensation planning, offer management, and equity analysis. Classified as confidential.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sopTrainingCurriculum rdf:type rdf:Property ;
    rdfs:label 'Sop Training Curriculum' ;
    rdfs:comment 'Identifier or name of the SOP training curriculum assigned to this job profile in MasterControl. Defines the set of SOPs that employees must complete upon onboarding and at defined intervals.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardBillingRate rdf:type rdf:Property ;
    rdfs:label 'Standard Billing Rate' ;
    rdfs:comment 'Standard hourly or daily billing rate for this job profile when charged to sponsor study contracts. Used in financial forecasting, budget line creation, and invoice generation in SAP S/4HANA. Classified as confidential.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:travelRequirement rdf:type rdf:Property ;
    rdfs:label 'Travel Requirement' ;
    rdfs:comment 'Expected travel frequency for employees in this job profile. Particularly relevant for CRA and site monitoring roles requiring regular site visits.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workShift rdf:type rdf:Property ;
    rdfs:label 'Work Shift' ;
    rdfs:comment 'Standard work shift pattern associated with this job profile. Relevant for site monitoring roles and laboratory positions requiring non-standard hours.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayJobProfileCode rdf:type rdf:Property ;
    rdfs:label 'Workday Job Profile Code' ;
    rdfs:comment 'The native identifier assigned to this job profile within Workday HCM job catalog. Used for system-of-record traceability and integration reconciliation.' ;
    rdfs:domain ind:JobProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Org Unit Id' ;
    rdfs:comment 'Reference to the immediate parent organizational unit in the hierarchy, enabling hierarchical rollup of headcount, FTE, and training compliance by department. Null for the root organization node.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:unitHeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Unit Head Employee Id' ;
    rdfs:comment 'Reference to the employee who serves as the head or manager of this organizational unit, used for delegation of authority, approval workflows, and organizational reporting.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ctmsOrgRef rdf:type rdf:Property ;
    rdfs:label 'Ctms Org Ref' ;
    rdfs:comment 'Reference identifier for this organizational unit in Oracle Siebel CTMS, used for cross-system reconciliation of resource assignments, site monitoring activities, and study staffing records.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fteBudget rdf:type rdf:Property ;
    rdfs:label 'Fte Budget' ;
    rdfs:comment 'Approved budgeted Full-Time Equivalent (FTE) count for this organizational unit in the current planning period. Supports resource allocation to clinical studies and capacity planning analytics.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gcpTrainingCompliancePct rdf:type rdf:Property ;
    rdfs:label 'Gcp Training Compliance Pct' ;
    rdfs:comment 'Percentage of employees within this organizational unit who have current, valid GCP training certifications. Supports regulatory inspection readiness reporting and compliance dashboards per ICH E6(R2) requirements.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headcountBudget rdf:type rdf:Property ;
    rdfs:label 'Headcount Budget' ;
    rdfs:comment 'Approved budgeted headcount (number of positions) for this organizational unit in the current planning period. Used for workforce capacity planning and variance analysis against actual headcount.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isGcpRegulated rdf:type rdf:Property ;
    rdfs:label 'Is Gcp Regulated' ;
    rdfs:comment 'Indicates whether this organizational unit performs GCP-regulated activities requiring mandatory GCP training, delegation log maintenance, and regulatory inspection readiness per ICH E6(R2) and FDA 21 CFR Part 312.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sopOwner rdf:type rdf:Property ;
    rdfs:label 'Sop Owner' ;
    rdfs:comment 'Name or identifier of the designated Standard Operating Procedure (SOP) owner for this organizational unit, responsible for maintaining and approving SOPs applicable to the unit\'s activities in MasterControl.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticAreaFocus rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Area Focus' ;
    rdfs:comment 'Primary therapeutic area specialization of the organizational unit (e.g., Oncology, Neurology, Cardiovascular, Infectious Disease). Supports study-to-resource matching and capacity planning for sponsor engagements.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCode rdf:type rdf:Property ;
    rdfs:label 'Unit Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the organizational unit, used in system integrations, cost allocation references, and reporting filters (e.g., \'CLIN-OPS-NA\', \'BIOSTATS\', \'REG-AFF\').' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitDescription rdf:type rdf:Property ;
    rdfs:label 'Unit Description' ;
    rdfs:comment 'Free-text description of the organizational unit\'s mandate, responsibilities, and scope within the CRO. Provides context for workforce planning, onboarding, and organizational change management documentation.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitName rdf:type rdf:Property ;
    rdfs:label 'Unit Name' ;
    rdfs:comment 'Official human-readable name of the organizational unit as defined in Workday HCM (e.g., \'Clinical Operations – North America\', \'Biostatistics & Programming\', \'Regulatory Affairs\'). Used in workforce reporting and organizational charts.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitStatus rdf:type rdf:Property ;
    rdfs:label 'Unit Status' ;
    rdfs:comment 'Current lifecycle status of the organizational unit. Inactive or dissolved units are retained for historical reporting and audit trail purposes per GCP and SOX requirements.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitType rdf:type rdf:Property ;
    rdfs:label 'Unit Type' ;
    rdfs:comment 'Classification of the organizational unit within the CRO hierarchy. Determines reporting rollup behavior and cost allocation rules. [ENUM-REF-CANDIDATE: department|division|cost_center|team|function|business_unit — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedRecordPayrollRecordId rdf:type rdf:Property ;
    rdfs:label 'Reversed Record Payroll Record Id' ;
    rdfs:comment 'Reference to the original payroll_record_id that this record reverses or corrects. Null if this is not a reversal record. Maintains the audit chain for payroll corrections per SOX requirements.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollRecord .

ind:allowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Allowance Amount' ;
    rdfs:comment 'Total allowances paid to the employee in this pay period, including travel allowances, per diem, housing allowances, and other non-salary compensation components common in clinical research field roles.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankAccountLast4 rdf:type rdf:Property ;
    rdfs:label 'Bank Account Last4' ;
    rdfs:comment 'Last four digits of the employee\'s bank account number to which direct deposit was made. Stored as a masked reference for audit and reconciliation purposes only; full account number is not retained.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseSalaryAmount rdf:type rdf:Property ;
    rdfs:label 'Base Salary Amount' ;
    rdfs:comment 'The fixed base salary component of gross pay for this pay period, prorated to the pay frequency. Excludes variable pay components such as overtime, bonuses, and allowances.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitsDeduction rdf:type rdf:Property ;
    rdfs:label 'Benefits Deduction' ;
    rdfs:comment 'Total employee-paid benefits deductions withheld from gross pay, including health insurance premiums, dental, vision, and other voluntary benefit elections.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Amount' ;
    rdfs:comment 'Discretionary or performance-based bonus pay included in this payroll record. May include study milestone bonuses, retention bonuses, or annual performance awards.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employeeFullName rdf:type rdf:Property ;
    rdfs:label 'Employee Full Name' ;
    rdfs:comment 'Full legal name of the employee as recorded in Workday HCM at the time of payroll processing. Retained as a point-in-time snapshot for audit and regulatory purposes.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerBenefitsContribution rdf:type rdf:Property ;
    rdfs:label 'Employer Benefits Contribution' ;
    rdfs:comment 'Employer-paid portion of employee benefits costs (health insurance, dental, vision, life insurance) for this pay period. Included in total workforce cost allocation to clinical studies.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerRetirementContribution rdf:type rdf:Property ;
    rdfs:label 'Employer Retirement Contribution' ;
    rdfs:comment 'Employer matching or defined contribution to the employee\'s retirement plan for this pay period (e.g., 401(k) match, pension contribution). Part of total compensation cost for study budget allocation.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerTaxContribution rdf:type rdf:Property ;
    rdfs:label 'Employer Tax Contribution' ;
    rdfs:comment 'Employer-side payroll tax contributions (e.g., employer FICA/Social Security, Medicare, unemployment insurance) associated with this payroll record. Required for total labor cost allocation to clinical studies.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossPay rdf:type rdf:Property ;
    rdfs:label 'Gross Pay' ;
    rdfs:comment 'Total gross compensation earned by the employee for the pay period before any deductions. Equals the sum of all pay components (base salary, overtime, bonus, allowances). Key figure for SOX financial reporting and workforce cost allocation.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursWorked rdf:type rdf:Property ;
    rdfs:label 'Hours Worked' ;
    rdfs:comment 'Total regular hours worked by the employee during the pay period as recorded in Workday HCM time tracking. Used for hourly pay calculations and study resource utilization reporting.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isReversal rdf:type rdf:Property ;
    rdfs:label 'Is Reversal' ;
    rdfs:comment 'Indicates whether this payroll record represents a reversal of a previously processed payroll entry. True if this record corrects or voids a prior disbursement. Critical for SOX audit trail integrity.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netPay rdf:type rdf:Property ;
    rdfs:label 'Net Pay' ;
    rdfs:comment 'The actual amount disbursed to the employee after all deductions (taxes, benefits, retirement contributions) have been subtracted from gross pay. Represents the take-home pay amount.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeAmount rdf:type rdf:Property ;
    rdfs:label 'Overtime Amount' ;
    rdfs:comment 'Total overtime pay earned by the employee during this pay period, calculated per applicable labor law (e.g., FLSA 1.5x rate). Relevant for CRAs and site staff with variable field hours.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours' ;
    rdfs:comment 'Total overtime hours worked by the employee during the pay period beyond the standard threshold (e.g., >40 hours/week under FLSA). Drives overtime_amount calculation.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payFrequency rdf:type rdf:Property ;
    rdfs:label 'Pay Frequency' ;
    rdfs:comment 'The frequency at which the employee is paid within this pay group (e.g., biweekly, monthly). Determines the number of pay periods per year for annualization calculations.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payGroup rdf:type rdf:Property ;
    rdfs:label 'Pay Group' ;
    rdfs:comment 'The Workday HCM pay group to which the employee belongs, determining pay frequency and processing rules (e.g., US-Biweekly, EU-Monthly, APAC-Monthly). [ENUM-REF-CANDIDATE: US-Biweekly|US-Semimonthly|EU-Monthly|APAC-Monthly|CA-Biweekly|UK-Monthly — promote to reference product]' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period End Date' ;
    rdfs:comment 'The last calendar date of the pay period covered by this payroll record. Defines the end of the compensation earning window.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period Start Date' ;
    rdfs:comment 'The first calendar date of the pay period covered by this payroll record. Defines the beginning of the compensation earning window.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payrollRunReference rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Reference' ;
    rdfs:comment 'Unique identifier for the payroll run batch in which this record was processed, as assigned by Workday HCM. Enables traceability of all records processed in a single payroll run cycle.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollRunType rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Type' ;
    rdfs:comment 'Classifies the nature of the payroll run: regular scheduled run, off-cycle correction, supplemental bonus run, or final paycheck upon termination.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementDeduction rdf:type rdf:Property ;
    rdfs:label 'Retirement Deduction' ;
    rdfs:comment 'Employee pre-tax or post-tax retirement contribution deducted from gross pay (e.g., 401(k), pension, RRSP). Supports benefits compliance and workforce total compensation reporting.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studyAllocationCode rdf:type rdf:Property ;
    rdfs:label 'Study Allocation Code' ;
    rdfs:comment 'The clinical study or project code to which this payroll expense is allocated for workforce cost tracking. Enables direct linkage of labor costs to specific clinical trials for sponsor billing and budget management.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'The primary tax jurisdiction code applicable to this payroll record (e.g., US-CA for California, UK for United Kingdom). Determines which tax tables and rates are applied during payroll calculation.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxWithholdingStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Withholding Status' ;
    rdfs:comment 'The employee\'s federal/national tax filing status as declared on their withholding form (e.g., W-4 in the US), which determines the applicable tax withholding rate for this pay period.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTaxDeduction rdf:type rdf:Property ;
    rdfs:label 'Total Tax Deduction' ;
    rdfs:comment 'Aggregate amount withheld from gross pay for all applicable taxes (federal, state/provincial, local income tax, social security, Medicare/national insurance) during this pay period.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionId rdf:type rdf:Property ;
    rdfs:label 'Position Id' ;
    rdfs:comment 'Unique surrogate identifier for the approved headcount position record within the clinical research organization. Primary key for the position master in the Workday HCM Position Management module.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hiringManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Hiring Manager Employee Id' ;
    rdfs:comment 'Reference to the employee record of the manager responsible for recruiting and onboarding the incumbent for this position. Used in Workday HCM recruiting workflows and CTMS resource request approvals.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reportsToPositionId rdf:type rdf:Property ;
    rdfs:label 'Reports To Position Id' ;
    rdfs:comment 'Self-referencing identifier of the parent position in the organizational hierarchy to which this position reports. Enables org chart traversal, span-of-control analytics, and delegation chain validation per GCP requirements.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:budgetedFte rdf:type rdf:Property ;
    rdfs:label 'Budgeted Fte' ;
    rdfs:comment 'Approved full-time equivalent headcount units budgeted for this position (e.g., 1.00 for full-time, 0.50 for half-time). Sourced from the annual headcount plan in Workday HCM and reconciled against SAP S/4HANA project accounting budgets.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clinicalRoleCategory rdf:type rdf:Property ;
    rdfs:label 'Clinical Role Category' ;
    rdfs:comment 'Functional classification of the position within the clinical research organization\'s role taxonomy. Determines GCP training requirements, delegation eligibility, and system access provisioning in Medidata Rave, Veeva Vault, and Oracle Argus Safety. [ENUM-REF-CANDIDATE: CRA|CRC|Biostatistician|Data Manager|Medical Monitor|Regulatory Specialist|Project Manager|Other — promote to reference product]' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filledDate rdf:type rdf:Property ;
    rdfs:label 'Filled Date' ;
    rdfs:comment 'Actual date on which the position was filled by an incumbent employee. Populated when incumbency_status transitions to Filled. Used to calculate time-to-fill KPIs and assess recruiting efficiency.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freezeReason rdf:type rdf:Property ;
    rdfs:label 'Freeze Reason' ;
    rdfs:comment 'Free-text explanation for why a position has been frozen (incumbency_status = Frozen). Common reasons include budget hold, organizational restructuring, study portfolio reduction, or sponsor funding delay. Null when position is not frozen.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountPlanYear rdf:type rdf:Property ;
    rdfs:label 'Headcount Plan Year' ;
    rdfs:comment 'Fiscal year in which this position was approved in the annual headcount plan (e.g., 2024, 2025). Used to align position records with annual budget cycles in SAP S/4HANA and Workday HCM workforce planning.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incumbencyStatus rdf:type rdf:Property ;
    rdfs:label 'Incumbency Status' ;
    rdfs:comment 'Current occupancy state of the position within the approved headcount plan. Filled = active employee assigned; Vacant = approved but unoccupied; Frozen = headcount approved but hiring suspended; Pending-Approval = awaiting budget authorization; Eliminated = position removed from headcount plan. Critical for workforce planning KPI reporting.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDelegationEligible rdf:type rdf:Property ;
    rdfs:label 'Is Delegation Eligible' ;
    rdfs:comment 'Indicates whether the position is eligible to appear on a site delegation log as a delegatee for PI-authorized tasks. Determined by job profile, GCP certification status, and protocol training requirements per ICH E6(R2) and FDA guidance.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPiEligible rdf:type rdf:Property ;
    rdfs:label 'Is Pi Eligible' ;
    rdfs:comment 'Indicates whether the position is designated as eligible to serve as a Principal Investigator (PI) on a clinical study. PI-eligible positions require medical licensure verification and are subject to enhanced regulatory scrutiny by FDA, EMA, and IRB/IEC.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyReportingRole rdf:type rdf:Property ;
    rdfs:label 'Is Safety Reporting Role' ;
    rdfs:comment 'Indicates whether the position carries regulatory responsibility for adverse event (AE) and serious adverse event (SAE) reporting obligations. Positions flagged True require Oracle Argus Safety system access and SAE/SUSAR reporting training per ICH E2A and FDA 21 CFR Part 312.32.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:positionType rdf:type rdf:Property ;
    rdfs:label 'Position Type' ;
    rdfs:comment 'Employment arrangement type for the position. Determines benefits eligibility, contract terms, and workforce planning classification. Permanent and Fixed-Term positions are tracked in Workday HCM headcount; Contractor positions may be managed via SAP S/4HANA procurement. [ENUM-REF-CANDIDATE: Permanent|Fixed-Term|Contractor|Temporary|Intern — promote to reference product if types expand]' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryCurrency rdf:type rdf:Property ;
    rdfs:label 'Salary Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the salary range values associated with this position (e.g., USD, EUR, GBP, JPY). Required for multi-currency workforce cost consolidation in SAP S/4HANA.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetFillDate rdf:type rdf:Property ;
    rdfs:label 'Target Fill Date' ;
    rdfs:comment 'Planned date by which a vacant position should be filled with a qualified incumbent. Used in workforce planning dashboards and study resource gap analysis to flag at-risk studies due to unfilled critical roles (e.g., CRA, Medical Monitor).' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vacatedDate rdf:type rdf:Property ;
    rdfs:label 'Vacated Date' ;
    rdfs:comment 'Date on which the most recent incumbent vacated the position (due to termination, transfer, or promotion), causing the incumbency_status to revert to Vacant. Supports turnover analysis and study continuity risk assessment.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workdayPositionCode rdf:type rdf:Property ;
    rdfs:label 'Workday Position Code' ;
    rdfs:comment 'The native position identifier assigned by Workday HCM (e.g., P-00012345). Used for cross-system reconciliation between the lakehouse silver layer and the Workday source system.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryProtocolEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Protocol Employee Id' ;
    rdfs:comment 'Reference to the workforce member (CRA, CRC, biostatistician, data manager, medical monitor, regulatory specialist, etc.) who completed the protocol training. Sourced from Workday HCM.' ;
    rdfs:domain ind:ProtocolTrainingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:mastercontrolTrainingCode rdf:type rdf:Property ;
    rdfs:label 'Mastercontrol Training Code' ;
    rdfs:comment 'The native training record identifier from MasterControl, the source system of record for training management. Used for cross-system reconciliation and audit trail traceability.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retrainingDueDate rdf:type rdf:Property ;
    rdfs:label 'Retraining Due Date' ;
    rdfs:comment 'The date by which re-training must be completed when re-training is required. Null if re-training is not required. Used for compliance monitoring and escalation workflows.' ;
    rdfs:domain ind:ProtocolTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retrainingRequired rdf:type rdf:Property ;
    rdfs:label 'Retraining Required' ;
    rdfs:comment 'Indicates whether re-training is required for this employee on this protocol, either due to a failed assessment, protocol amendment, or expiry of a prior training record. Drives automated re-training assignment workflows.' ;
    rdfs:domain ind:ProtocolTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureCaptured rdf:type rdf:Property ;
    rdfs:label 'Signature Captured' ;
    rdfs:comment 'Indicates whether a compliant electronic signature (per 21 CFR Part 11) has been captured from the employee acknowledging completion of the protocol training. Required for GCP-compliant training records.' ;
    rdfs:domain ind:ProtocolTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureDate rdf:type rdf:Property ;
    rdfs:label 'Signature Date' ;
    rdfs:comment 'The date on which the employee applied their electronic or wet signature to acknowledge completion of the protocol training. Must align with training_date for ALCOA+ compliance.' ;
    rdfs:domain ind:ProtocolTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingDate rdf:type rdf:Property ;
    rdfs:label 'Training Date' ;
    rdfs:comment 'The date on which the workforce member completed the protocol training session. This is the principal real-world event date used for compliance verification and delegation log validation.' ;
    rdfs:domain ind:ProtocolTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingMaterialVersion rdf:type rdf:Property ;
    rdfs:label 'Training Material Version' ;
    rdfs:comment 'Version identifier of the training material or curriculum used for this training session (e.g., v2.1, Q3-2024). Ensures traceability between training content and the protocol version it covers.' ;
    rdfs:domain ind:ProtocolTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingProviderName rdf:type rdf:Property ;
    rdfs:label 'Training Provider Name' ;
    rdfs:comment 'Name of the external organization or vendor that provided the protocol training, if applicable (e.g., sponsor medical affairs team, CRO training department, third-party eLearning vendor). Null for internally delivered training.' ;
    rdfs:domain ind:ProtocolTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryStudyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Study Employee Id' ;
    rdfs:comment 'Reference to the workforce member being assigned to the study. Links to the employee master record in Workday HCM.' ;
    rdfs:domain ind:StudyAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignedRole rdf:type rdf:Property ;
    rdfs:label 'Assigned Role' ;
    rdfs:comment 'The functional role the workforce member performs on this study. Drives GCP training requirements, delegation log entries, and capacity utilization calculations. [ENUM-REF-CANDIDATE: CRA|CRC|Data Manager|Biostatistician|Medical Monitor|Regulatory Lead|Project Manager — promote to reference product]' ;
    rdfs:domain ind:StudyAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingRate rdf:type rdf:Property ;
    rdfs:label 'Billing Rate' ;
    rdfs:comment 'The hourly or daily billing rate applied to this workforce member for this study assignment, in the contract currency. Used for study budget tracking and sponsor invoicing. Classified confidential as it reflects contractual pricing.' ;
    rdfs:domain ind:StudyAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingRateCurrency rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the billing rate (e.g., USD, EUR, GBP). Required for multi-currency study budget management and sponsor invoicing.' ;
    rdfs:domain ind:StudyAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionReason rdf:type rdf:Property ;
    rdfs:label 'Completion Reason' ;
    rdfs:comment 'Categorized reason for assignment completion or cancellation. Used for workforce attrition analysis and study continuity risk management.' ;
    rdfs:domain ind:StudyAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctmsAssignmentCode rdf:type rdf:Property ;
    rdfs:label 'Ctms Assignment Code' ;
    rdfs:comment 'The native assignment identifier from Oracle Siebel CTMS. Used for cross-system reconciliation between the lakehouse Silver Layer and the operational CTMS source system.' ;
    rdfs:domain ind:StudyAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Timestamp' ;
    rdfs:comment 'The precise timestamp at which the assignment became operationally effective (distinct from start_date which is day-level). Used for intra-day capacity calculations and audit trail precision per 21 CFR Part 11.' ;
    rdfs:domain ind:StudyAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fteAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Fte Allocation Pct' ;
    rdfs:comment 'The percentage of the workforce member\'s full-time equivalent capacity formally allocated to this study. Range 0.00–100.00. Primary input for capacity utilization calculations and resource planning. A value of 50.00 indicates half of the employee\'s working time is committed to this study.' ;
    rdfs:domain ind:StudyAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPiOversightRequired rdf:type rdf:Property ;
    rdfs:label 'Is Pi Oversight Required' ;
    rdfs:comment 'Indicates whether this assignment requires direct oversight by the Principal Investigator per the study delegation log. True = PI oversight required; False = independent execution permitted within delegated authority.' ;
    rdfs:domain ind:StudyAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onHoldDate rdf:type rdf:Property ;
    rdfs:label 'On Hold Date' ;
    rdfs:comment 'The date on which the assignment was placed on hold. Populated only when assignment_status = \'on-hold\'. Used for capacity planning and timeline impact analysis.' ;
    rdfs:domain ind:StudyAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedFteAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Planned Fte Allocation Pct' ;
    rdfs:comment 'The originally planned FTE allocation percentage at the time of assignment creation, before any revisions. Enables variance analysis between planned and actual resource utilization.' ;
    rdfs:domain ind:StudyAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workdayAssignmentCode rdf:type rdf:Property ;
    rdfs:label 'Workday Assignment Code' ;
    rdfs:comment 'The native project assignment identifier from Workday HCM. Used for cross-system reconciliation between the lakehouse Silver Layer and the Workday HCM source system for payroll and project accounting alignment.' ;
    rdfs:domain ind:StudyAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByCurriculumTrainingCurriculumId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Curriculum Training Curriculum Id' ;
    rdfs:comment 'Reference to the training_curriculum_id of the newer curriculum version that replaced this one. Null if this is the current active version. Enables version lineage tracing for regulatory audit purposes.' ;
    rdfs:domain ind:TrainingCurriculum ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingCurriculum .

ind:completionWindowDays rdf:type rdf:Property ;
    rdfs:label 'Completion Window Days' ;
    rdfs:comment 'The number of calendar days from assignment date within which all courses in the curriculum must be completed by the assigned employee. Drives compliance deadline enforcement and escalation workflows (e.g., 30 days for onboarding GCP, 14 days for protocol-specific training).' ;
    rdfs:domain ind:TrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:curriculumDescription rdf:type rdf:Property ;
    rdfs:label 'Curriculum Description' ;
    rdfs:comment 'Detailed narrative description of the curriculum\'s purpose, scope, learning objectives, and target audience. Provides context for training administrators, QA reviewers, and regulatory inspectors.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curriculumName rdf:type rdf:Property ;
    rdfs:label 'Curriculum Name' ;
    rdfs:comment 'Human-readable name of the training curriculum (e.g., \'GCP Onboarding Curriculum for Clinical Research Associates\'). Used in training assignment reports and compliance dashboards.' ;
    rdfs:domain ind:TrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curriculumStatus rdf:type rdf:Property ;
    rdfs:label 'Curriculum Status' ;
    rdfs:comment 'Current lifecycle state of the curriculum in MasterControl. Draft indicates the curriculum is being authored; active means it is currently assigned and enforced; retired means it is no longer in use; superseded means a newer version has replaced it; under_review means it is undergoing periodic review.' ;
    rdfs:domain ind:TrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curriculumType rdf:type rdf:Property ;
    rdfs:label 'Curriculum Type' ;
    rdfs:comment 'Categorical classification of the curriculum by its primary purpose. Onboarding curricula apply to new hires; role_based to specific job profiles; protocol_specific to study-assigned staff; system_specific to EDC/CTMS/eTMF users; regulatory to GCP/ICH/FDA compliance; refresher to periodic re-certification.' ;
    rdfs:domain ind:TrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'The estimated total time in hours required to complete all courses in the curriculum. Used for workforce capacity planning, onboarding scheduling, and resource allocation in Workday HCM.' ;
    rdfs:domain ind:TrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gcpTrainingIncluded rdf:type rdf:Property ;
    rdfs:label 'Gcp Training Included' ;
    rdfs:comment 'Indicates whether this curriculum includes at least one Good Clinical Practice (GCP) training course as required by ICH E6(R2). Critical flag for regulatory inspection readiness and delegation log verification.' ;
    rdfs:domain ind:TrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Flag' ;
    rdfs:comment 'Indicates whether completion of this curriculum is mandatory for the assigned job profile or role. Mandatory curricula trigger compliance alerts and may block system access (e.g., EDC, CTMS) if not completed within the required window.' ;
    rdfs:domain ind:TrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mastercontrolCurriculumCode rdf:type rdf:Property ;
    rdfs:label 'Mastercontrol Curriculum Code' ;
    rdfs:comment 'The native document or curriculum identifier assigned by MasterControl (source system of record). Used for cross-system reconciliation between the Silver Layer lakehouse and MasterControl.' ;
    rdfs:domain ind:TrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passingScorePercent rdf:type rdf:Property ;
    rdfs:label 'Passing Score Percent' ;
    rdfs:comment 'The minimum percentage score required to pass assessments within this curriculum. Typically 80% for GCP-related curricula per industry standard. Null if the curriculum has no scored assessments (e.g., read-and-acknowledge only).' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:protocolTrainingIncluded rdf:type rdf:Property ;
    rdfs:label 'Protocol Training Included' ;
    rdfs:comment 'Indicates whether this curriculum includes protocol-specific training courses. When true, the curriculum is typically linked to a specific study protocol and must be completed before site staff can perform protocol-defined activities.' ;
    rdfs:domain ind:TrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recertificationPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Recertification Period Months' ;
    rdfs:comment 'The interval in months after which employees must re-complete the curriculum to maintain certification (e.g., 24 months for GCP refresher). Null if the curriculum is a one-time completion requirement with no recertification cycle.' ;
    rdfs:domain ind:TrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sopTrainingIncluded rdf:type rdf:Property ;
    rdfs:label 'Sop Training Included' ;
    rdfs:comment 'Indicates whether this curriculum includes Standard Operating Procedure (SOP) training courses. SOP training is a GCP requirement for all clinical research personnel performing regulated activities.' ;
    rdfs:domain ind:TrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorSpecific rdf:type rdf:Property ;
    rdfs:label 'Sponsor Specific' ;
    rdfs:comment 'Indicates whether this curriculum was developed to meet a specific sponsor\'s training requirements. Sponsor-specific curricula may include sponsor SOPs, sponsor EDC system training, or sponsor-mandated GCP guidelines.' ;
    rdfs:domain ind:TrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:systemTrainingIncluded rdf:type rdf:Property ;
    rdfs:label 'System Training Included' ;
    rdfs:comment 'Indicates whether this curriculum includes training on operational systems such as EDC (Medidata Rave), CTMS (Oracle Siebel), eTMF (Veeva Vault), or IRT/RTSM. Required for 21 CFR Part 11 system access authorization.' ;
    rdfs:domain ind:TrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetDepartment rdf:type rdf:Property ;
    rdfs:label 'Target Department' ;
    rdfs:comment 'Organizational department or functional group for which this curriculum is designed (e.g., Clinical Operations, Biostatistics, Data Management, Regulatory Affairs). Enables department-level compliance reporting.' ;
    rdfs:domain ind:TrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCourseCount rdf:type rdf:Property ;
    rdfs:label 'Total Course Count' ;
    rdfs:comment 'The total number of individual training courses included in this curriculum. Provides a quick reference for workload estimation during onboarding planning and capacity management.' ;
    rdfs:domain ind:TrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workdayLearningProgramCode rdf:type rdf:Property ;
    rdfs:label 'Workday Learning Program Code' ;
    rdfs:comment 'The corresponding learning program identifier in Workday HCM Learning module, if the curriculum is also managed or tracked in Workday. Enables bidirectional reconciliation between MasterControl and Workday HCM for completion records.' ;
    rdfs:domain ind:TrainingCurriculum ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRecordId rdf:type rdf:Property ;
    rdfs:label 'Training Record Id' ;
    rdfs:comment 'Primary key for training_record' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingRecord .

ind:primaryTrainingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Training Employee Id' ;
    rdfs:comment 'Identifier of the workforce member assigned to complete this SOP training. References the employee master record in Workday HCM. Represents the PARTY_REFERENCE for this transactional record.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryTrainingAssignedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Training Assigned By Employee Id' ;
    rdfs:comment 'Identifier of the employee (typically a QA manager or training coordinator) who created and assigned this training record in MasterControl. Supports accountability and audit trail for training assignment actions.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessmentRequired rdf:type rdf:Property ;
    rdfs:label 'Assessment Required' ;
    rdfs:comment 'Indicates whether a formal assessment (quiz or competency test) is required to complete this training assignment. Determined by the SOP training requirement configuration in MasterControl. Drives assessment score and pass/fail status population.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobRole rdf:type rdf:Property ;
    rdfs:label 'Job Role' ;
    rdfs:comment 'Job role or title of the employee at the time of training assignment (e.g., Clinical Research Associate, Data Manager, Biostatistician). Captured as a snapshot to support role-based training compliance analysis even if the employee\'s role changes later.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Recurrence Interval Days' ;
    rdfs:comment 'Number of days after completion before the next training assignment is automatically generated for this SOP. Null if recurrence_required is false. Supports periodic retraining scheduling (e.g., 365 for annual retraining).' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recurrenceRequired rdf:type rdf:Property ;
    rdfs:label 'Recurrence Required' ;
    rdfs:comment 'Indicates whether this SOP training must be repeated on a periodic basis (e.g., annually). Drives the generation of future training assignments upon completion. Configured at the SOP training requirement level.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sopEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Sop Effective Date' ;
    rdfs:comment 'Date on which the assigned SOP version became effective. Used to determine whether training was completed before or after the SOP became operative, supporting compliance gap analysis.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiatingAuditId rdf:type rdf:Property ;
    rdfs:label 'Initiating Audit Id' ;
    rdfs:comment 'Reference to the compliance audit or inspection record that triggered this CAPA, if applicable. Links to compliance.audit or compliance.inspection for traceability.' ;
    rdfs:domain ind:WorkforceCapa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:primaryWorkforceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Workforce Employee Id' ;
    rdfs:comment 'Identifier of the workforce member (CRA, CRC, biostatistician, data manager, medical monitor, regulatory specialist, etc.) against whom the CAPA is initiated. References the employee master in Workday HCM.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:priorCapaWorkforceCapaId rdf:type rdf:Property ;
    rdfs:label 'Prior Capa Workforce Capa Id' ;
    rdfs:comment 'Reference to the previous CAPA record for the same employee and non-compliance category, if this CAPA represents a recurrence. Enables recurrence chain analysis and escalation tracking.' ;
    rdfs:domain ind:WorkforceCapa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkforceCapa .

ind:capaNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Number' ;
    rdfs:comment 'Human-readable, externally-known CAPA reference number assigned by MasterControl upon initiation (e.g., CAPA-WF-2024-00123). Used for cross-system referencing, audit trails, and regulatory inspection readiness.' ;
    rdfs:domain ind:WorkforceCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaStatus rdf:type rdf:Property ;
    rdfs:label 'Capa Status' ;
    rdfs:comment 'Current lifecycle state of the CAPA record within MasterControl workflow. Drives escalation logic, dashboard KPIs, and inspection-readiness reporting. [ENUM-REF-CANDIDATE: draft|open|in_progress|pending_review|closed|cancelled|overdue — promote to reference product]' ;
    rdfs:domain ind:WorkforceCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeRole rdf:type rdf:Property ;
    rdfs:label 'Employee Role' ;
    rdfs:comment 'The workforce role of the employee at the time the non-compliance occurred. Captured as a denormalized snapshot to preserve historical accuracy independent of role changes. [ENUM-REF-CANDIDATE: CRA|CRC|data_manager|biostatistician|medical_monitor|regulatory_specialist|project_manager|other — promote to reference product]' ;
    rdfs:domain ind:WorkforceCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mastercontrolCapaRef rdf:type rdf:Property ;
    rdfs:label 'Mastercontrol Capa Ref' ;
    rdfs:comment 'Native record identifier from the MasterControl CAPA module, used for cross-system reconciliation and audit trail linkage back to the system of record.' ;
    rdfs:domain ind:WorkforceCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceCategory rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Category' ;
    rdfs:comment 'High-level category of the non-compliance or performance issue that triggered the CAPA. Used for trend analysis, root cause aggregation, and regulatory reporting. [ENUM-REF-CANDIDATE: gcp_violation|training_non_compliance|protocol_deviation|sop_violation|data_integrity|safety_reporting|delegation_breach|performance_issue — promote to reference product]' ;
    rdfs:domain ind:WorkforceCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceDescription rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Description' ;
    rdfs:comment 'Detailed description of the GCP compliance failure, training non-compliance, or performance issue that prompted the CAPA. Captures the factual account of the event as observed during audit or inspection.' ;
    rdfs:domain ind:WorkforceCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaReviewDate rdf:type rdf:Property ;
    rdfs:label 'Qa Review Date' ;
    rdfs:comment 'Date on which the QA reviewer completed their review of the CAPA record and approved or rejected the closure request.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qaReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Qa Review Outcome' ;
    rdfs:comment 'Outcome of the QA review of the CAPA closure package. Rejected or returned records require additional action before closure can be granted.' ;
    rdfs:domain ind:WorkforceCapa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryWorkforcePiEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Workforce Pi Employee Id' ;
    rdfs:comment 'Reference to the Principal Investigator (PI) who is delegating the trial-related duties. The PI retains overall responsibility per GCP.' ;
    rdfs:domain ind:WorkforceDelegationLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededLogWorkforceDelegationLogId rdf:type rdf:Property ;
    rdfs:label 'Superseded Log Workforce Delegation Log Id' ;
    rdfs:comment 'Reference to the prior delegation log record that this entry supersedes or amends. Enables version chain traceability for regulatory inspection. Null for original entries.' ;
    rdfs:domain ind:WorkforceDelegationLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkforceDelegationLog .

ind:tertiaryWorkforceQaReviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Workforce Qa Reviewer Employee Id' ;
    rdfs:comment 'Reference to the QA staff member who reviewed and approved or rejected this delegation log entry. Null if QA review has not yet been performed or is not required.' ;
    rdfs:domain ind:WorkforceDelegationLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:delegatedTaskCode rdf:type rdf:Property ;
    rdfs:label 'Delegated Task Code' ;
    rdfs:comment 'Standardized code identifying the specific trial-related task or responsibility being delegated (e.g., IC_PROCESS, AE_ASSESSMENT, SDV_CONDUCT, DRUG_DISPENSING, SAMPLE_COLLECTION). Drawn from the site\'s task code reference list. [ENUM-REF-CANDIDATE: IC_PROCESS|AE_ASSESSMENT|SDV_CONDUCT|DRUG_DISPENSING|SAMPLE_COLLECTION|ECRF_ENTRY|ELIGIBILITY_REVIEW|RANDOMIZATION|PROTOCOL_DEVIATION_REVIEW|MEDICAL_HISTORY — promote to reference product]' ;
    rdfs:domain ind:WorkforceDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegatedTaskDescription rdf:type rdf:Property ;
    rdfs:label 'Delegated Task Description' ;
    rdfs:comment 'Free-text description of the specific trial-related duty or responsibility being delegated to the delegatee. Provides the full narrative of the scope of delegation as it appears on the formal delegation log document.' ;
    rdfs:domain ind:WorkforceDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegateeName rdf:type rdf:Property ;
    rdfs:label 'Delegatee Name' ;
    rdfs:comment 'The full name of the delegatee as it appears on the signed delegation log document. Captured as a point-in-time regulatory artifact field required for GCP compliance and inspection readiness.' ;
    rdfs:domain ind:WorkforceDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegateeQualificationConfirmed rdf:type rdf:Property ;
    rdfs:label 'Delegatee Qualification Confirmed' ;
    rdfs:comment 'Indicates whether the PI has confirmed that the delegatee possesses the necessary training, qualifications, and experience to perform the delegated task per ICH E6(R2) Section 4.1.5.' ;
    rdfs:domain ind:WorkforceDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:delegateeRoleTitle rdf:type rdf:Property ;
    rdfs:label 'Delegatee Role Title' ;
    rdfs:comment 'The formal job title or role of the delegatee at the time of delegation (e.g., Sub-Investigator, Clinical Research Coordinator (CRC), Study Nurse, Pharmacist). Captured as a point-in-time record on the delegation log.' ;
    rdfs:domain ind:WorkforceDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegateeSignatureCaptured rdf:type rdf:Property ;
    rdfs:label 'Delegatee Signature Captured' ;
    rdfs:comment 'Indicates whether the delegatee\'s electronic or wet-ink signature has been captured and stored in the system for this delegation log entry. True = signature on file; False = pending.' ;
    rdfs:domain ind:WorkforceDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:delegateeSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Delegatee Signature Date' ;
    rdfs:comment 'The date on which the delegatee signed the delegation log entry, acknowledging acceptance of the delegated responsibility. Required to confirm informed acceptance per GCP.' ;
    rdfs:domain ind:WorkforceDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:delegationScope rdf:type rdf:Property ;
    rdfs:label 'Delegation Scope' ;
    rdfs:comment 'Categorizes the breadth of the delegation: \'full\' covers all aspects of the task, \'partial\' covers defined sub-tasks only, \'temporary\' is time-limited cover (e.g., PI absence), \'emergency\' is an unplanned urgent delegation.' ;
    rdfs:domain ind:WorkforceDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gcpTrainingVerified rdf:type rdf:Property ;
    rdfs:label 'Gcp Training Verified' ;
    rdfs:comment 'Indicates whether the delegatee\'s current Good Clinical Practice (GCP) training certification has been verified and is on file at the time of delegation. Required per ICH E6(R2) and FDA regulations.' ;
    rdfs:domain ind:WorkforceDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irbIecApprovalConfirmed rdf:type rdf:Property ;
    rdfs:label 'Irb Iec Approval Confirmed' ;
    rdfs:comment 'Indicates whether the relevant IRB or IEC approval was in place at the time this delegation was executed. Ensures the delegation is made within an ethically approved study context.' ;
    rdfs:domain ind:WorkforceDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:logStatus rdf:type rdf:Property ;
    rdfs:label 'Log Status' ;
    rdfs:comment 'Current lifecycle status of the delegation log record. \'Active\' indicates the delegation is currently in force; \'superseded\' indicates a newer version exists; \'withdrawn\' indicates the delegation was revoked.' ;
    rdfs:domain ind:WorkforceDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logVersion rdf:type rdf:Property ;
    rdfs:label 'Log Version' ;
    rdfs:comment 'Version identifier of the delegation log document (e.g., v1.0, v2.0). Incremented each time the log is formally amended and re-signed. Required for TMF version control.' ;
    rdfs:domain ind:WorkforceDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolTrainingVerified rdf:type rdf:Property ;
    rdfs:label 'Protocol Training Verified' ;
    rdfs:comment 'Indicates whether the delegatee has completed and documented protocol-specific training for the study prior to performing the delegated task.' ;
    rdfs:domain ind:WorkforceDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qaReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Qa Review Status' ;
    rdfs:comment 'The current Quality Assurance (QA) review status of this delegation log entry. Tracks whether the QA team has reviewed and approved the delegation for TMF completeness and GCP compliance.' ;
    rdfs:domain ind:WorkforceDelegationLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualFte rdf:type rdf:Property ;
    rdfs:label 'Actual Fte' ;
    rdfs:comment 'Actual FTE count allocated and confirmed for the role category and time period. Sourced from Workday HCM actuals. Compared against planned_fte_demand to derive resource gap.' ;
    rdfs:domain ind:WorkforceResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualHeadcount rdf:type rdf:Property ;
    rdfs:label 'Actual Headcount' ;
    rdfs:comment 'Actual number of employees confirmed and allocated for the role category and planning period. Sourced from Workday HCM position management actuals.' ;
    rdfs:domain ind:WorkforceResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualLaborCost rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Cost' ;
    rdfs:comment 'Actual labor cost incurred for the resource plan period, sourced from SAP S/4HANA payroll and project accounting actuals. Compared against planned_labor_cost for variance analysis.' ;
    rdfs:domain ind:WorkforceResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for all monetary values in this resource plan (e.g., USD, EUR, GBP). Ensures consistent financial reporting across multinational studies.' ;
    rdfs:domain ind:WorkforceResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUtilizationTargetPct rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Target Pct' ;
    rdfs:comment 'Target percentage of available FTE capacity to be utilized for billable or productive clinical work during the planning period. Used to set workload balancing thresholds and avoid burnout or under-utilization.' ;
    rdfs:domain ind:WorkforceResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractorFtePlanned rdf:type rdf:Property ;
    rdfs:label 'Contractor Fte Planned' ;
    rdfs:comment 'Planned FTE demand to be fulfilled by contract or temporary staff (CRO contractors, freelance CRAs) rather than permanent employees. Supports make-vs-buy workforce decisions.' ;
    rdfs:domain ind:WorkforceResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'The fiscal quarter within the fiscal year to which this resource plan applies. Used for quarterly capacity reviews and rolling forecast updates.' ;
    rdfs:domain ind:WorkforceResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fteGap rdf:type rdf:Property ;
    rdfs:label 'Fte Gap' ;
    rdfs:comment 'Resource gap expressed as FTE units, calculated as planned_fte_demand minus actual_fte. Positive values indicate a staffing shortfall requiring hiring or contractor engagement; negative values indicate surplus capacity.' ;
    rdfs:domain ind:WorkforceResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gcpCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Gcp Certification Required' ;
    rdfs:comment 'Indicates whether all resources allocated under this plan must hold a valid GCP certification as mandated by ICH E6(R2). Drives training compliance checks in MasterControl.' ;
    rdfs:domain ind:WorkforceResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hiringUrgency rdf:type rdf:Property ;
    rdfs:label 'Hiring Urgency' ;
    rdfs:comment 'Priority classification for filling open positions within this resource plan. Critical indicates study start or regulatory milestone is at risk; high indicates near-term impact; medium and low indicate planned pipeline needs.' ;
    rdfs:domain ind:WorkforceResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalFtePlanned rdf:type rdf:Property ;
    rdfs:label 'Internal Fte Planned' ;
    rdfs:comment 'Planned FTE demand to be fulfilled by permanent internal employees. Complements contractor_fte_planned to give total planned_fte_demand when summed.' ;
    rdfs:domain ind:WorkforceResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastRevisedDate rdf:type rdf:Property ;
    rdfs:label 'Last Revised Date' ;
    rdfs:comment 'Date on which the resource plan was most recently revised. Tracks the recency of planning assumptions and triggers re-approval workflows when material changes are made.' ;
    rdfs:domain ind:WorkforceResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openPositionCount rdf:type rdf:Property ;
    rdfs:label 'Open Position Count' ;
    rdfs:comment 'Number of approved but unfilled positions within this resource plan. Drives active recruiting actions and time-to-fill KPI tracking in Workday HCM talent acquisition.' ;
    rdfs:domain ind:WorkforceResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planNotes rdf:type rdf:Property ;
    rdfs:label 'Plan Notes' ;
    rdfs:comment 'Free-text field for resource manager annotations, planning assumptions, risk flags, or contextual commentary relevant to this resource plan. Not used for structured data.' ;
    rdfs:domain ind:WorkforceResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedFteDemand rdf:type rdf:Property ;
    rdfs:label 'Planned Fte Demand' ;
    rdfs:comment 'Total planned FTE demand for the specified role category and time period. Represents the number of full-time equivalent resources required to execute the planned scope of work. Core metric for capacity planning.' ;
    rdfs:domain ind:WorkforceResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedHeadcount rdf:type rdf:Property ;
    rdfs:label 'Planned Headcount' ;
    rdfs:comment 'Planned number of individual employees (headcount) required for the role category and planning period. Distinct from FTE as it counts persons rather than effort equivalents.' ;
    rdfs:domain ind:WorkforceResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedLaborCost rdf:type rdf:Property ;
    rdfs:label 'Planned Labor Cost' ;
    rdfs:comment 'Total planned labor cost for the resource plan in the specified budget currency, covering all FTE demand for the planning period. Used for study budget alignment and financial forecasting in SAP S/4HANA.' ;
    rdfs:domain ind:WorkforceResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningHorizon rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon' ;
    rdfs:comment 'Time granularity and scope of the resource plan. Study_phase aligns to clinical trial phases (Phase I–IV); quarterly and annual align to fiscal planning cycles; multi_year supports long-horizon program planning.' ;
    rdfs:domain ind:WorkforceResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredLanguage rdf:type rdf:Property ;
    rdfs:label 'Required Language' ;
    rdfs:comment 'Primary language proficiency required for resources allocated under this plan, relevant for multinational studies where site communication and regulatory submissions require specific language skills.' ;
    rdfs:domain ind:WorkforceResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayPlanCode rdf:type rdf:Property ;
    rdfs:label 'Workday Plan Code' ;
    rdfs:comment 'Source system identifier for this resource plan record in Workday HCM workforce planning module. Used for data lineage, reconciliation, and cross-system traceability.' ;
    rdfs:domain ind:WorkforceResourcePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programTeamMemberId rdf:type rdf:Property ;
    rdfs:label 'Program Team Member Id' ;
    rdfs:comment 'Primary key for the program_team_member association' ;
    rdfs:domain ind:ProgramTeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amendmentSiteImplementationId rdf:type rdf:Property ;
    rdfs:label 'Amendment Site Implementation Id' ;
    rdfs:comment 'Primary key for the amendment_site_implementation association' ;
    rdfs:domain ind:AmendmentSiteImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:implementationStatus rdf:type rdf:Property ;
    rdfs:label 'Implementation Status' ;
    rdfs:comment 'Current lifecycle status of the amendment implementation at this specific site. Drives operational follow-up by CRAs and clinical operations managers.' ;
    rdfs:domain ind:AmendmentSiteImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconsentCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Reconsent Completed Flag' ;
    rdfs:comment 'Indicates whether all currently enrolled subjects at this site who are impacted by the amendment have provided updated informed consent. Applicable only when the parent amendment has reconsent_required_flag = true.' ;
    rdfs:domain ind:AmendmentSiteImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sitesImplementedCount rdf:type rdf:Property ;
    rdfs:label 'Sites Implemented Count' ;
    rdfs:comment 'Number of clinical investigative sites that have confirmed full implementation of the amendment, including staff training and updated procedures. Supports monitoring and close-out tracking. [Moved from study_protocol_amendment: This is a derived aggregate roll-up of implementation_status = \'implemented\' records in the amendment_site_implementation association. Same denormalization concern as sites_notified_count — should be computed, not stored on the amendment.]' ;
    rdfs:domain ind:AmendmentSiteImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sitesNotifiedCount rdf:type rdf:Property ;
    rdfs:label 'Sites Notified Count' ;
    rdfs:comment 'Number of clinical investigative sites that have been formally notified of this amendment. Used to track notification completeness against total active site count for the study. [Moved from study_protocol_amendment: This is a derived aggregate roll-up of notification_date records in the amendment_site_implementation association. It does not belong on the amendment itself — it should be computed from the association table. Storing it on study_protocol_amendment creates a denormalization that will drift out of sync.]' ;
    rdfs:domain ind:AmendmentSiteImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ibSiteDistributionId rdf:type rdf:Property ;
    rdfs:label 'Ib Site Distribution Id' ;
    rdfs:comment 'Primary key for the ib_site_distribution association' ;
    rdfs:domain ind:IbSiteDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ibVersionAtDistribution rdf:type rdf:Property ;
    rdfs:label 'Ib Version At Distribution' ;
    rdfs:comment 'The version number of the IB as distributed to this site (e.g., 2.0, 3.1). Denormalized here to provide an audit-safe snapshot of the version label at the time of distribution, independent of any subsequent version record updates.' ;
    rdfs:domain ind:IbSiteDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryEngagementId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Engagement Id' ;
    rdfs:comment 'Primary key for the regulatory_engagement association' ;
    rdfs:domain ind:RegulatoryEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadAgencyFlag rdf:type rdf:Property ;
    rdfs:label 'Lead Agency Flag' ;
    rdfs:comment 'Indicates whether this health authority is the primary or lead regulatory agency for the program\'s global submission strategy. Replaces the denormalized primary_regulatory_agency string field on clinical_program.' ;
    rdfs:domain ind:RegulatoryEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorSiteQualificationId rdf:type rdf:Property ;
    rdfs:label 'Sponsor Site Qualification Id' ;
    rdfs:comment 'Primary key for the sponsor_site_qualification association' ;
    rdfs:domain ind:SponsorSiteQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:historicalStudyCount rdf:type rdf:Property ;
    rdfs:label 'Historical Study Count' ;
    rdfs:comment 'Total number of clinical studies this site has conducted for this sponsor over the lifetime of the relationship. Belongs to the relationship — the same site\'s study count differs per sponsor.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredSiteTier rdf:type rdf:Property ;
    rdfs:label 'Preferred Site Tier' ;
    rdfs:comment 'Sponsor-assigned tier classification for this site within their preferred site network. Distinct from the site\'s global site_tier — a site may be Tier 1 for one sponsor and Tier 3 for another based on therapeutic area fit and historical performance.' ;
    rdfs:domain ind:SponsorSiteQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredTherapeuticArea rdf:type rdf:Property ;
    rdfs:label 'Preferred Therapeutic Area' ;
    rdfs:comment 'The therapeutic area(s) for which this sponsor preferentially engages this site, based on the site\'s specialization and the sponsor\'s pipeline focus. May be a subset of the site\'s full therapeutic_area_specializations.' ;
    rdfs:domain ind:SponsorSiteQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'Date on which the sponsor formally established a working relationship with this investigational site. Used to calculate relationship tenure and for sponsor portfolio reporting.' ;
    rdfs:domain ind:SponsorSiteQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sitePerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Site Performance Rating' ;
    rdfs:comment 'Sponsor\'s aggregate performance rating for this site based on enrollment delivery, data quality, protocol compliance, and regulatory inspection outcomes across all studies conducted under this sponsor. Belongs to the relationship — the same site may have different ratings from different sponsors.' ;
    rdfs:domain ind:SponsorSiteQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Site Qualification Status' ;
    rdfs:comment 'Current qualification status of the investigational site within this sponsor\'s network. Drives whether the site is eligible to be selected for new studies under this sponsor. Belongs to the relationship, not the site (a site may be QUALIFIED for Pfizer but SUSPENDED for Novartis).' ;
    rdfs:domain ind:SponsorSiteQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labQualificationId rdf:type rdf:Property ;
    rdfs:label 'Lab Qualification Id' ;
    rdfs:comment 'Primary key for the lab_qualification association' ;
    rdfs:domain ind:LabQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Reference identifier for the vendor contract or master service agreement governing the laboratory facility\'s engagement for this clinical program. Links to the procurement or legal contract management system.' ;
    rdfs:domain ind:LabQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryLabFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Lab Flag' ;
    rdfs:comment 'Indicates whether this laboratory facility is designated as the primary (central) laboratory for this clinical program. A program may have one primary lab and multiple specialty or backup labs.' ;
    rdfs:domain ind:LabQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeOfServices rdf:type rdf:Property ;
    rdfs:label 'Scope Of Services' ;
    rdfs:comment 'Narrative or structured description of the specific assay panels, specimen types, and analytical services this laboratory facility is approved to perform for this clinical program (e.g., hematology, PK assays, biomarker panels).' ;
    rdfs:domain ind:LabQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelCompositionId rdf:type rdf:Property ;
    rdfs:label 'Panel Composition Id' ;
    rdfs:comment 'Primary key for the panel_composition association' ;
    rdfs:domain ind:PanelComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analyteCount rdf:type rdf:Property ;
    rdfs:label 'Analyte Count' ;
    rdfs:comment 'Total number of individual analytes (tests) included in this panel. Provides a quick reference for panel complexity and is used in turnaround time estimation and cost modelling. [Moved from lab_panel: This INT on lab_panel is a derived/calculated value that counts the number of analytes in the panel. Once panel_composition is the authoritative source of panel membership, analyte_count becomes a computed aggregate (COUNT of panel_composition records for a given lab_panel_id) and should not be stored as a static attribute on lab_panel, where it would require manual maintenance and is prone to drift.]' ;
    rdfs:domain ind:PanelComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analyteList rdf:type rdf:Property ;
    rdfs:label 'Analyte List' ;
    rdfs:comment 'Comma-separated list of analyte names or LBTESTCD codes included in this panel (e.g., \'ALT, AST, ALP, TBILI, DBILI, GGT\'). Provides a human-readable summary of panel content for protocol review and eCRF design. [Moved from lab_panel: This denormalized comma-separated STRING on lab_panel is an anti-pattern that attempts to capture the M:N panel composition relationship in a single column. It cannot support referential integrity, per-analyte metadata, or efficient querying. The panel_composition association table fully replaces this attribute, and analyte_list should be removed from lab_panel.]' ;
    rdfs:domain ind:PanelComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRequiredAnalyte rdf:type rdf:Property ;
    rdfs:label 'Is Required Analyte' ;
    rdfs:comment 'Indicates whether this analyte is mandatory for the panel to be considered complete and reportable. When false, the analyte is optional or conditionally performed. Belongs to the composition relationship as the same analyte may be required in one panel but optional in another.' ;
    rdfs:domain ind:PanelComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumVolumeContributionMl rdf:type rdf:Property ;
    rdfs:label 'Minimum Volume Contribution Ml' ;
    rdfs:comment 'The minimum specimen volume in millilitres required specifically for this analyte\'s performance within this panel. Used to calculate total panel specimen volume requirements. Belongs to the composition relationship as volume requirements may differ per panel context.' ;
    rdfs:domain ind:PanelComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingFlag rdf:type rdf:Property ;
    rdfs:label 'Reporting Flag' ;
    rdfs:comment 'Indicates whether this analyte\'s result is included in the panel\'s standard report output. Some analytes may be performed internally for QC or calculation purposes but not reported to the sponsor or investigator site.' ;
    rdfs:domain ind:PanelComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sowLabPanelRequirementId rdf:type rdf:Property ;
    rdfs:label 'Sow Lab Panel Requirement Id' ;
    rdfs:comment 'Primary key for the sow_lab_panel_requirement association' ;
    rdfs:domain ind:SowLabPanelRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:centralLabRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Central Lab Required Flag' ;
    rdfs:comment 'Indicates whether this SOW mandates that this panel be performed at a central laboratory. Overrides or confirms the lab_type attribute on the panel catalog for the purposes of this specific contractual engagement.' ;
    rdfs:domain ind:SowLabPanelRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractedTurnaroundDays rdf:type rdf:Property ;
    rdfs:label 'Contracted Turnaround Days' ;
    rdfs:comment 'Negotiated turnaround time in days from specimen receipt to result delivery, as agreed in this specific SOW. May differ from the catalog turnaround_time_hours on lab_panel, which represents a general SLA target.' ;
    rdfs:domain ind:SowLabPanelRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:panelRequirementType rdf:type rdf:Property ;
    rdfs:label 'Panel Requirement Type' ;
    rdfs:comment 'Classification of why this lab panel is included in the SOW — e.g., safety monitoring, pharmacokinetics, biomarker assessment. The same panel may serve different purposes in different SOWs.' ;
    rdfs:domain ind:SowLabPanelRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenVolumeContractedMl rdf:type rdf:Property ;
    rdfs:label 'Specimen Volume Contracted Ml' ;
    rdfs:comment 'Contracted specimen volume in millilitres agreed for this panel under this SOW. May differ from the catalog minimum (specimen_volume_ml on lab_panel) due to sponsor-specific protocol requirements or pooling arrangements.' ;
    rdfs:domain ind:SowLabPanelRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visitApplicability rdf:type rdf:Property ;
    rdfs:label 'Visit Applicability' ;
    rdfs:comment 'Specification of which study visit timepoints (e.g., Screening, Day 1, Week 4, End of Treatment) require this panel under this SOW. Encoded as a pipe-separated list of visit codes or a free-text schedule description.' ;
    rdfs:domain ind:SowLabPanelRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piQualificationId rdf:type rdf:Property ;
    rdfs:label 'Pi Qualification Id' ;
    rdfs:comment 'Primary key for the pi_qualification association' ;
    rdfs:domain ind:PiQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedTherapeuticAreas rdf:type rdf:Property ;
    rdfs:label 'Approved Therapeutic Areas' ;
    rdfs:comment 'Comma-delimited list or structured value of therapeutic areas (e.g., Oncology, Cardiology) for which this sponsor has approved this PI to serve as investigator. A sponsor may approve a PI for Oncology but not Neurology; this scope is specific to the sponsor-PI qualification.' ;
    rdfs:domain ind:PiQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:piPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Pi Performance Rating' ;
    rdfs:comment 'Sponsor\'s internal performance rating for this PI based on past study conduct, protocol compliance, data quality, and site management. This rating is sponsor-specific and confidential; a PI may have different ratings from different sponsors.' ;
    rdfs:domain ind:PiQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committeeMembershipId rdf:type rdf:Property ;
    rdfs:label 'Committee Membership Id' ;
    rdfs:comment 'Primary key for the committee_membership association' ;
    rdfs:domain ind:CommitteeMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appointmentStatus rdf:type rdf:Property ;
    rdfs:label 'Appointment Status' ;
    rdfs:comment 'Current lifecycle status of this specific committee membership appointment. Enables tracking of members who are temporarily suspended (e.g., pending COI resolution) without terminating the record.' ;
    rdfs:domain ind:CommitteeMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chairAffiliation rdf:type rdf:Property ;
    rdfs:label 'Chair Affiliation' ;
    rdfs:comment 'Institutional or organizational affiliation of the committee chairperson (e.g., university, hospital, or independent consultancy). Used to verify independence from the sponsor and for conflict-of-interest disclosures. [Moved from safety_review_committee: Chair affiliation is a property of the chair\'s membership appointment (or their employee profile), not a static property of the committee itself. As chairs rotate, this field becomes stale. It should be sourced from the employee record or captured as an association attribute if it differs from the employee\'s standard affiliation.]' ;
    rdfs:domain ind:CommitteeMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:independenceConfirmed rdf:type rdf:Property ;
    rdfs:label 'Independence Confirmed' ;
    rdfs:comment 'Indicates whether this member\'s independence from the sponsor and investigational team has been formally confirmed and documented, as required for DSMB/DMC/IDMC members under FDA and EMA guidance. Must be true for all voting members of independent committees.' ;
    rdfs:domain ind:CommitteeMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memberRole rdf:type rdf:Property ;
    rdfs:label 'Member Role' ;
    rdfs:comment 'The designated functional role of the employee within this committee appointment. Determines responsibilities, access to unblinded data, and quorum contribution. Required for charter compliance and regulatory submissions.' ;
    rdfs:domain ind:CommitteeMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:votingRights rdf:type rdf:Property ;
    rdfs:label 'Voting Rights' ;
    rdfs:comment 'Indicates whether this member holds voting rights for committee decisions and recommendations. Non-voting members (e.g., sponsor liaisons, statistical advisors in observer capacity) are excluded from quorum counts. Derived from member_role but stored explicitly for quorum validation logic.' ;
    rdfs:domain ind:CommitteeMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetAllocationId rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Id' ;
    rdfs:comment 'Primary key for the supply_budget_allocation association' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Lifecycle status of this supply budget allocation record. Tracks whether the allocation is in draft, actively in use, superseded by a newer supply plan version, or closed. Required to manage versioned supply plan amendments.' ;
    rdfs:domain ind:BudgetAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalCaseContributionId rdf:type rdf:Property ;
    rdfs:label 'Signal Case Contribution Id' ;
    rdfs:comment 'Primary key for the signal_case_contribution association' ;
    rdfs:domain ind:SignalCaseContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:caseIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Case Included Flag' ;
    rdfs:comment 'Indicates whether this adverse event case is actively included in the current signal evaluation case pool. Cases may be excluded from a signal\'s active case count due to duplicate detection, data quality issues, or adjudication decisions.' ;
    rdfs:domain ind:SignalCaseContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:caseWeight rdf:type rdf:Property ;
    rdfs:label 'Case Weight' ;
    rdfs:comment 'Statistical weight assigned to this adverse event case in the context of its contribution to the signal\'s disproportionality metric calculation (e.g., PRR, ROR, BCPNN). Reflects the relative influence of this case on the signal strength value.' ;
    rdfs:domain ind:SignalCaseContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contributionDate rdf:type rdf:Property ;
    rdfs:label 'Contribution Date' ;
    rdfs:comment 'Date on which this adverse event case was formally linked to the safety signal as a contributing case, typically recorded during a signal detection or evaluation cycle run in Oracle Argus Safety.' ;
    rdfs:domain ind:SignalCaseContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:includedInCaseCount rdf:type rdf:Property ;
    rdfs:label 'Included In Case Count' ;
    rdfs:comment 'Indicates whether this adverse event case is counted in the safety signal\'s reported case_count denominator. Distinct from case_included_flag — a case may be included in evaluation but excluded from the formal case count due to adjudication or deduplication.' ;
    rdfs:domain ind:SignalCaseContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signalDetectionCycle rdf:type rdf:Property ;
    rdfs:label 'Signal Detection Cycle' ;
    rdfs:comment 'Identifier for the signal detection or evaluation cycle during which this case-signal contribution was established or last reviewed (e.g., \'Q1-2024\', \'Cycle-7\'). Supports tracking of case pool evolution across multiple evaluation cycles.' ;
    rdfs:domain ind:SignalCaseContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsurLineListingId rdf:type rdf:Property ;
    rdfs:label 'Dsur Line Listing Id' ;
    rdfs:comment 'Primary key for the dsur_line_listing association' ;
    rdfs:domain ind:DsurLineListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cumulativeVsPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Cumulative Vs Period Flag' ;
    rdfs:comment 'Indicates whether this SUSAR contributes to the period count, the cumulative count, or both within the DSUR aggregate summaries. Drives reconciliation between period_susar_count and cumulative_susar_count on the parent DSUR.' ;
    rdfs:domain ind:DsurLineListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFollowUpInPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Follow Up In Period' ;
    rdfs:comment 'Indicates whether this SUSAR record represents a follow-up submission (not the initial report) that was submitted during this DSUR reporting period. A SUSAR may appear in multiple DSURs — once as initial and again as follow-up.' ;
    rdfs:domain ind:DsurLineListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNewInPeriod rdf:type rdf:Property ;
    rdfs:label 'Is New In Period' ;
    rdfs:comment 'Indicates whether this SUSAR first became reportable (awareness date falls within the DSUR reporting period). Used to populate the period_susar_count on the parent DSUR.' ;
    rdfs:domain ind:DsurLineListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineListingSection rdf:type rdf:Property ;
    rdfs:label 'Line Listing Section' ;
    rdfs:comment 'The specific regulatory section of the DSUR document in which this SUSAR appears. ICH E2F requires separate line listings for fatal, serious non-fatal, and unexpected reactions. Determines placement in the final DSUR document.' ;
    rdfs:domain ind:DsurLineListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodInclusionType rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Inclusion Type' ;
    rdfs:comment 'Classifies how this SUSAR is included in the DSUR — whether it is a new case first reported during this annual period, a cumulative carry-forward from a prior period, or a case that spans the reporting period boundary. Drives which aggregate count columns in the DSUR are incremented.' ;
    rdfs:domain ind:DsurLineListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedSupplyItemId rdf:type rdf:Property ;
    rdfs:label 'Contracted Supply Item Id' ;
    rdfs:comment 'Primary key for the contracted_supply_item association' ;
    rdfs:domain ind:ContractedSupplyItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedQuantity rdf:type rdf:Property ;
    rdfs:label 'Contracted Quantity' ;
    rdfs:comment 'The total quantity of this IMP agreed to be supplied under this specific contract, expressed in the IMP\'s dispensing unit. Belongs to the relationship because the same IMP may have different contracted quantities across different study contracts.' ;
    rdfs:domain ind:ContractedSupplyItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyRole rdf:type rdf:Property ;
    rdfs:label 'Supply Role' ;
    rdfs:comment 'The functional role this IMP plays within the study as defined in the contract scope: IMP (the investigational product under study), COMPARATOR (active reference drug), PLACEBO, RESCUE_MEDICATION, or AUXILIARY. This role is specific to the IMP-contract pairing and cannot reside on imp_master (which is study-agnostic) or study_contract (which is not IMP-specific).' ;
    rdfs:domain ind:ContractedSupplyItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Imp Authorization Id' ;
    rdfs:comment 'Primary key for the imp_authorization association' ;
    rdfs:domain ind:ImpAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizationStatusAtTime rdf:type rdf:Property ;
    rdfs:label 'Authorization Status At Time' ;
    rdfs:comment 'The authorization status of this specific IMP under this specific CTA at the time of record. Distinct from the overall CTA status, as individual IMPs within a multi-IMP CTA may have different authorization states (e.g., one IMP suspended while others remain authorized).' ;
    rdfs:domain ind:ImpAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:authorizedQuantity rdf:type rdf:Property ;
    rdfs:label 'Authorized Quantity' ;
    rdfs:comment 'The quantity of the IMP authorized for use under this specific CTA, as approved by the national competent authority. Belongs to the IMP-CTA pairing, not to either entity alone, as the same IMP may have different authorized quantities under different CTAs.' ;
    rdfs:domain ind:ImpAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impEudraCtNumber rdf:type rdf:Property ;
    rdfs:label 'Imp Eudra Ct Number' ;
    rdfs:comment 'EudraCT or EudraGMDP reference number for the investigational medicinal product as registered in the EU regulatory system. Used to cross-reference IMP manufacturing and quality data with the CTA. [Moved from clinical_trial_authorization: This EudraCT/EudraGMDP reference for the IMP is a relationship-level identifier that belongs to the IMP-CTA pairing, not to the CTA alone. In a multi-IMP CTA, each IMP has its own EudraCT product number. Moving it to the association correctly models the per-IMP-per-CTA granularity.]' ;
    rdfs:domain ind:ImpAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolEthicsCoverageId rdf:type rdf:Property ;
    rdfs:label 'Protocol Ethics Coverage Id' ;
    rdfs:comment 'Primary key for the protocol_ethics_coverage association' ;
    rdfs:domain ind:ProtocolEthicsCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Ind Serial Number' ;
    rdfs:comment 'The specific IND serial number (amendment sequence number) referenced by this ethics submission. Ethics submissions for protocol amendments reference the corresponding IND amendment serial number, enabling traceability between regulatory filings and ethics review packages.' ;
    rdfs:domain ind:ProtocolEthicsCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipSiteAccountabilityId rdf:type rdf:Property ;
    rdfs:label 'Ip Site Accountability Id' ;
    rdfs:comment 'Primary key for the ip_site_accountability association' ;
    rdfs:domain ind:IpSiteAccountability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountabilityLogReference rdf:type rdf:Property ;
    rdfs:label 'Accountability Log Reference' ;
    rdfs:comment 'Reference identifier linking to the drug accountability log maintained at the site for this IMP. Required by GCP to reconcile quantities received, dispensed, returned, and destroyed.' ;
    rdfs:domain ind:IpSiteAccountability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispensingAuthorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Dispensing Authorization Status' ;
    rdfs:comment 'Current authorization status for the site to dispense this investigational product to trial subjects. Distinct from storage authorization — a site may store but not yet be authorized to dispense.' ;
    rdfs:domain ind:IpSiteAccountability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Storage Authorization Date' ;
    rdfs:comment 'Date on which the investigational site was formally authorized to store this investigational product. Belongs to the IMP-site relationship, not to either master record alone.' ;
    rdfs:domain ind:IpSiteAccountability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storageComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Storage Compliance Status' ;
    rdfs:comment 'Current GCP storage compliance status for this IMP at this specific site. Reflects whether the site is meeting required storage conditions (e.g., temperature range) for this product.' ;
    rdfs:domain ind:IpSiteAccountability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staffRosterId rdf:type rdf:Property ;
    rdfs:label 'Staff Roster Id' ;
    rdfs:comment 'Primary key for the site_staff_roster association' ;
    rdfs:domain ind:StaffRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roleAtSite rdf:type rdf:Property ;
    rdfs:label 'Role At Site' ;
    rdfs:comment 'The GCP-defined functional role the employee performs at this specific investigational site. Distinct from the employee\'s general gcp_role, as a staff member may serve different roles across different site assignments (e.g., CRA at one site, Site Manager at another).' ;
    rdfs:domain ind:StaffRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specializationId rdf:type rdf:Property ;
    rdfs:label 'Specialization Id' ;
    rdfs:comment 'Primary key for the site_specialization association' ;
    rdfs:domain ind:Specialization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activeStudyCountInTa rdf:type rdf:Property ;
    rdfs:label 'Active Study Count In Ta' ;
    rdfs:comment 'Current number of active clinical studies the site is running within this therapeutic area at the time of last assessment. Used by feasibility teams to evaluate site capacity and workload for new study placement in this TA.' ;
    rdfs:domain ind:Specialization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastAssessedDate rdf:type rdf:Property ;
    rdfs:label 'Last Assessed Date' ;
    rdfs:comment 'Date on which the site\'s specialization profile for this therapeutic area was most recently reviewed and updated by clinical operations. Drives reassessment workflows and data freshness governance.' ;
    rdfs:domain ind:Specialization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specializationLevel rdf:type rdf:Property ;
    rdfs:label 'Specialization Level' ;
    rdfs:comment 'Categorical rating of the investigational site\'s depth of expertise and capability within this specific therapeutic area, as assessed by clinical operations. Belongs to the site-TA pairing, not to the site or TA alone.' ;
    rdfs:domain ind:Specialization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticAreaSpecializations rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Area Specializations' ;
    rdfs:comment 'Comma-separated list of therapeutic area specializations for which the investigational site has demonstrated clinical expertise and patient population access (e.g., Oncology, Cardiology, Neurology, Infectious Disease). Used for site-to-study matching during feasibility and site selection. [ENUM-REF-CANDIDATE: oncology|cardiology|neurology|infectious_disease|immunology|endocrinology|rare_disease|dermatology|respiratory|gastroenterology — promote to reference product] [Moved from investigational_site: This comma-separated STRING field on investigational_site is a denormalized, non-normalized representation of the site-TA specialization relationship. It cannot support referential integrity to therapeutic_area, per-specialization attributes, or historical tracking. All specialization data should be migrated to individual site_specialization association records, and this field should be deprecated.]' ;
    rdfs:domain ind:Specialization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programSiteParticipationId rdf:type rdf:Property ;
    rdfs:label 'Program Site Participation Id' ;
    rdfs:comment 'Primary key for the program_site_participation association' ;
    rdfs:domain ind:ProgramSiteParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:historicalEnrollmentCount rdf:type rdf:Property ;
    rdfs:label 'Historical Enrollment Count' ;
    rdfs:comment 'Cumulative number of subjects enrolled by this investigational site across all studies within this clinical program to date. A program-level performance metric that belongs to the site-program relationship, not to the site master (which would aggregate across all programs) nor the program master (which would aggregate across all sites).' ;
    rdfs:domain ind:ProgramSiteParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participationStatus rdf:type rdf:Property ;
    rdfs:label 'Participation Status' ;
    rdfs:comment 'Current lifecycle status of the investigational site\'s participation within this clinical program. Reflects whether the site is actively running studies under the program, pending activation, or has completed or terminated its engagement.' ;
    rdfs:domain ind:ProgramSiteParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSiteFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Site Flag' ;
    rdfs:comment 'Sponsor or CRO designation indicating whether this investigational site is classified as a preferred or strategic site for future studies within this clinical program. Actively managed by portfolio site strategy teams as part of program-level site planning.' ;
    rdfs:domain ind:ProgramSiteParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labServiceContractId rdf:type rdf:Property ;
    rdfs:label 'Lab Service Contract Id' ;
    rdfs:comment 'Primary key for the lab_service_contract association' ;
    rdfs:domain ind:LabServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedRate rdf:type rdf:Property ;
    rdfs:label 'Contracted Rate' ;
    rdfs:comment 'The negotiated unit rate agreed with the lab facility for specimen processing services under this specific study budget. Varies per facility-study combination and cannot reside on either the facility master or the budget master alone.' ;
    rdfs:domain ind:LabServiceContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceScope rdf:type rdf:Property ;
    rdfs:label 'Service Scope' ;
    rdfs:comment 'Narrative or structured description of the assay panels, specimen types, and analytical services covered under this facility-budget contract. Defines what the lab is authorized and budgeted to perform for this study.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelApprovalId rdf:type rdf:Property ;
    rdfs:label 'Label Approval Id' ;
    rdfs:comment 'Primary key for the label_approval association' ;
    rdfs:domain ind:LabelApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Current Approved Flag' ;
    rdfs:comment 'Indicates whether this record represents the currently active and approved labeling document version for this country registration. Only one record per country_registration should have this flag set to true at any point in time.' ;
    rdfs:domain ind:LabelApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelingVersion rdf:type rdf:Property ;
    rdfs:label 'Labeling Version' ;
    rdfs:comment 'Version identifier of the currently approved product labeling (SmPC, Package Insert, or equivalent) in this country. Tracks which labeling version is in force and supports variation management. [Moved from country_registration: country_registration.labeling_version is a denormalized string capturing the currently approved label version for this registration. This relationship data belongs in the label_approval association as a proper FK to labeling_document, with full history. The string field should be removed once the association table is in place.]' ;
    rdfs:domain ind:LabelApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binderDocumentInclusionId rdf:type rdf:Property ;
    rdfs:label 'Binder Document Inclusion Id' ;
    rdfs:comment 'Primary key for the binder_document_inclusion association' ;
    rdfs:domain ind:BinderDocumentInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dossierEthicsReferenceId rdf:type rdf:Property ;
    rdfs:label 'Dossier Ethics Reference Id' ;
    rdfs:comment 'Primary key for the dossier_ethics_reference association' ;
    rdfs:domain ind:DossierEthicsReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalScope rdf:type rdf:Property ;
    rdfs:label 'Approval Scope' ;
    rdfs:comment 'Description of the scope of the ethics approval as it is relevant to this application — e.g., whether it covers the full study population, a specific sub-population, or a particular protocol amendment version cited in the dossier. Belongs to the citation context, not to the ethics approval record itself.' ;
    rdfs:domain ind:DossierEthicsReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citationStatus rdf:type rdf:Property ;
    rdfs:label 'Citation Status' ;
    rdfs:comment 'Lifecycle status of this ethics approval citation within the dossier: active (currently included), superseded (replaced by a newer ethics approval version), or withdrawn (removed from the dossier). Belongs to the citation relationship, not to either entity alone.' ;
    rdfs:domain ind:DossierEthicsReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyReference rdf:type rdf:Property ;
    rdfs:label 'Study Reference' ;
    rdfs:comment 'The study identifier or protocol number as referenced within the application dossier, linking the ethics approval to the specific clinical study evidence it supports in the context of this application. Captured here because the same ethics approval may be referenced under different study identifiers across different applications.' ;
    rdfs:domain ind:DossierEthicsReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionModuleReference rdf:type rdf:Property ;
    rdfs:label 'Submission Module Reference' ;
    rdfs:comment 'The CTD (Common Technical Document) module and section number where this ethics approval document is filed within the application dossier (e.g., Module 5.3.1.1). This is a property of the citation, not of the ethics approval or the application independently.' ;
    rdfs:domain ind:DossierEthicsReference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substantialModificationSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Substantial Modification Submission Id' ;
    rdfs:comment 'Primary key for the substantial_modification_submission association' ;
    rdfs:domain ind:SubstantialModificationSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signalNotificationId rdf:type rdf:Property ;
    rdfs:label 'Signal Notification Id' ;
    rdfs:comment 'Primary key for the signal_notification association' ;
    rdfs:domain ind:SignalNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionReference rdf:type rdf:Property ;
    rdfs:label 'Submission Reference' ;
    rdfs:comment 'Authority-assigned or sponsor-assigned reference number for this specific signal notification submission (e.g., FDA case number, EMA signal tracking ID, PMDA correspondence reference). Unique per authority-signal combination.' ;
    rdfs:domain ind:SignalNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementContactAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Engagement Contact Assignment Id' ;
    rdfs:comment 'Primary key for the engagement_contact_assignment association' ;
    rdfs:domain ind:EngagementContactAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roleInEngagement rdf:type rdf:Property ;
    rdfs:label 'Role In Engagement' ;
    rdfs:comment 'The functional role this sponsor contact holds within this specific engagement. A contact may hold different roles across different engagements (e.g., medical monitor in one, regulatory lead in another). This attribute belongs to the assignment, not to the contact or engagement globally.' ;
    rdfs:domain ind:EngagementContactAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countrySubmissionId rdf:type rdf:Property ;
    rdfs:label 'Country Submission Id' ;
    rdfs:comment 'Primary key for the country_submission association' ;
    rdfs:domain ind:CountrySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countrySpecificSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Country Specific Sequence Number' ;
    rdfs:comment 'The sequence number assigned by the national regulatory authority for this specific country\'s dossier, distinct from the global eCTD sequence number on the submission record. Belongs to the country-submission pairing, not to either entity alone. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:CountrySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countrySubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Country Submission Status' ;
    rdfs:comment 'Current lifecycle status of this submission as it applies to this specific country\'s regulatory authority. A single submission may be approved in one country and still under review in another. Sourced from detection phase relationship data (submission_status per country-submission pair).' ;
    rdfs:domain ind:CountrySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalReviewId rdf:type rdf:Property ;
    rdfs:label 'Signal Review Id' ;
    rdfs:comment 'Primary key for the site_signal_review association' ;
    rdfs:domain ind:SignalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionTakenDate rdf:type rdf:Property ;
    rdfs:label 'Action Taken Date' ;
    rdfs:comment 'Date on which the site-specific action required was implemented or confirmed at this investigational site. Belongs to the site-signal intersection, not to either entity alone.' ;
    rdfs:domain ind:SignalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteRiskAssessment rdf:type rdf:Property ;
    rdfs:label 'Site Risk Assessment' ;
    rdfs:comment 'Narrative risk assessment specific to this site\'s patient population, investigator practices, and local case profile for this signal. Distinct from the study-level benefit_risk_summary on safety_signal. Belongs to the site-signal intersection.' ;
    rdfs:domain ind:SignalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteSpecificCaseCount rdf:type rdf:Property ;
    rdfs:label 'Site Specific Case Count' ;
    rdfs:comment 'Number of adverse event cases at this specific investigational site that contribute to the safety signal. Distinct from the aggregate case_count on safety_signal, which spans all sites and data sources. Belongs to the site-signal intersection.' ;
    rdfs:domain ind:SignalReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visitBillingReconciliationId rdf:type rdf:Property ;
    rdfs:label 'Visit Billing Reconciliation Id' ;
    rdfs:comment 'Primary key for the visit_billing_reconciliation association' ;
    rdfs:domain ind:VisitBillingReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityBilled rdf:type rdf:Property ;
    rdfs:label 'Quantity Billed' ;
    rdfs:comment 'The number of visit units attributed to this subject_visit on this invoice_line. Belongs to the reconciliation relationship as it represents the billing quantity allocated to this specific visit-line pairing, which may differ from the invoice_line.quantity aggregate.' ;
    rdfs:domain ind:VisitBillingReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sdvReviewId rdf:type rdf:Property ;
    rdfs:label 'Sdv Review Id' ;
    rdfs:comment 'Primary key for the sdv_review association' ;
    rdfs:domain ind:SdvReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:binderContentInclusionId rdf:type rdf:Property ;
    rdfs:label 'Binder Content Inclusion Id' ;
    rdfs:comment 'Primary key for the binder_content_inclusion association' ;
    rdfs:domain ind:BinderContentInclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:susarSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Susar Submission Id' ;
    rdfs:comment 'Primary key for the susar_submission association' ;
    rdfs:domain ind:SusarSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline' ;
    rdfs:comment 'Calculated regulatory deadline for submitting this SUSAR to this specific health authority, derived from the reporting clock start date and the authority\'s mandated reporting timeline (7-day or 15-day). Distinct from the aggregate deadline fields on the SUSAR record.' ;
    rdfs:domain ind:SusarSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:witnessEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Witness Employee Id' ;
    rdfs:comment 'Foreign key reference to the staff member (e.g., site coordinator, investigator) who witnessed the consent signing. Required for GCP compliance when the subject is illiterate or consent is obtained verbally. Belongs to the signing event.' ;
    rdfs:domain ind:SubjectConsent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:icfDate rdf:type rdf:Property ;
    rdfs:label 'Icf Date' ;
    rdfs:comment 'Date on which the subject signed the most recent version of the Informed Consent Form (ICF). Must precede any study-related screening procedures. Used for GCP compliance verification and regulatory inspection readiness. [Moved from trial_subject: icf_date on trial_subject captures only the most recent consent date and cannot represent the full re-consent history. This date belongs to each individual consent signing event and should live on the subject_consent association, where one record per signing event captures the date accurately.]' ;
    rdfs:domain ind:SubjectConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:icfSigned rdf:type rdf:Property ;
    rdfs:label 'Icf Signed' ;
    rdfs:comment 'Indicates whether the subject has signed a valid Informed Consent Form (ICF) prior to any study-related procedures. Mandatory regulatory requirement. True = ICF signed and on file; False = ICF not yet signed or consent withdrawn. Sourced from Clinpal eConsent or site paper ICF records. [Moved from trial_subject: This BOOLEAN on trial_subject is a derived/summary flag indicating whether any valid ICF has been signed. It can be computed from the subject_consent association (any record with consent_status = signed). Storing it on trial_subject creates a maintenance burden and potential inconsistency. It may be retained as a computed/derived attribute but should not be the source of truth.]' ;
    rdfs:domain ind:SubjectConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconsentFlag rdf:type rdf:Property ;
    rdfs:label 'Reconsent Flag' ;
    rdfs:comment 'Indicates whether this consent event was a re-consent (true) due to a protocol amendment or new safety information, or an initial consent (false) at enrollment. Belongs to the signing event, not to the subject or the ICF version.' ;
    rdfs:domain ind:SubjectConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assessmentDatasetEvidenceId rdf:type rdf:Property ;
    rdfs:label 'Assessment Dataset Evidence Id' ;
    rdfs:comment 'Primary key for the assessment_dataset_evidence association' ;
    rdfs:domain ind:AssessmentDatasetEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:datasetRole rdf:type rdf:Property ;
    rdfs:label 'Dataset Role' ;
    rdfs:comment 'The evidentiary role this SDTM dataset played in the benefit-risk assessment. Classifies whether the dataset contributed safety evidence (e.g., AE, DS), efficacy evidence (e.g., RS, ADRS), exposure quantification (e.g., EX), or served as supportive or sensitivity analysis data.' ;
    rdfs:domain ind:AssessmentDatasetEvidence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugLabInteractionId rdf:type rdf:Property ;
    rdfs:label 'Drug Lab Interaction Id' ;
    rdfs:comment 'Primary key for the drug_lab_interaction association' ;
    rdfs:domain ind:DrugLabInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assessor Employee Id' ;
    rdfs:comment 'Reference to the employee (clinician, medical monitor, or data manager) who performed the drug-lab interaction assessment and documented the linkage. Belongs to the relationship as it identifies who made the specific clinical judgment connecting this lab result to this medication record.' ;
    rdfs:domain ind:DrugLabInteraction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:obligationFulfillmentId rdf:type rdf:Property ;
    rdfs:label 'Obligation Fulfillment Id' ;
    rdfs:comment 'Primary key for the obligation_fulfillment association' ;
    rdfs:domain ind:ObligationFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fulfillmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Percentage' ;
    rdfs:comment 'Numeric percentage (0–100) indicating the degree to which this deliverable satisfies the associated obligation. Supports partial fulfillment scenarios where an obligation requires multiple deliverables collectively, each contributing a portion of the total fulfillment.' ;
    rdfs:domain ind:ObligationFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depotSlaCoverageId rdf:type rdf:Property ;
    rdfs:label 'Depot Sla Coverage Id' ;
    rdfs:comment 'Primary key for the depot_sla_coverage association' ;
    rdfs:domain ind:DepotSlaCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaScope rdf:type rdf:Property ;
    rdfs:label 'Sla Scope' ;
    rdfs:comment 'Describes which activities, shipment types, or operational processes at this depot are covered by this SLA assignment (e.g., \'outbound IMP dispatch only\', \'all temperature-controlled storage operations\'). Scope may differ per depot even for the same SLA.' ;
    rdfs:domain ind:DepotSlaCoverage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementScopeId rdf:type rdf:Property ;
    rdfs:label 'Engagement Scope Id' ;
    rdfs:comment 'Primary key for the engagement_scope association' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementScopeStatus rdf:type rdf:Property ;
    rdfs:label 'Engagement Scope Status' ;
    rdfs:comment 'Current lifecycle status of this health authority\'s scope within the engagement (e.g., planned, active, suspended, closed). Sourced from detection phase relationship data as engagement_status.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionVolumeTarget rdf:type rdf:Property ;
    rdfs:label 'Submission Volume Target' ;
    rdfs:comment 'The planned number or volume of regulatory submissions to this health authority under this engagement for the planning period. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:EngagementScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impIndicationTrackId rdf:type rdf:Property ;
    rdfs:label 'Imp Indication Track Id' ;
    rdfs:comment 'Primary key for the imp_indication_track association' ;
    rdfs:domain ind:ImpIndicationTrack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trackStartDate rdf:type rdf:Property ;
    rdfs:label 'Track Start Date' ;
    rdfs:comment 'Date on which development of this IMP for this indication was formally initiated (e.g., first IND filing date or first study activation date for this pairing).' ;
    rdfs:domain ind:ImpIndicationTrack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trackStatus rdf:type rdf:Property ;
    rdfs:label 'Track Status' ;
    rdfs:comment 'Lifecycle status of this specific IMP-indication development track. Allows the business to mark individual tracks as discontinued without affecting the IMP master or indication records.' ;
    rdfs:domain ind:ImpIndicationTrack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impSopApplicabilityId rdf:type rdf:Property ;
    rdfs:label 'Imp Sop Applicability Id' ;
    rdfs:comment 'Primary key for the imp_sop_applicability association' ;
    rdfs:domain ind:ImpSopApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicabilityEndDate rdf:type rdf:Property ;
    rdfs:label 'Applicability End Date' ;
    rdfs:comment 'The date on which this SOP version ceased to be applicable to the IMP — e.g., upon SOP retirement, supersession, or IMP discontinuation. Null if the applicability is currently active. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:ImpSopApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicabilityStartDate rdf:type rdf:Property ;
    rdfs:label 'Applicability Start Date' ;
    rdfs:comment 'The date on which this SOP version became formally applicable to the IMP. Typically aligned with the SOP effective_date or the IMP\'s first use in a study governed by this SOP. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:ImpSopApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sopRoleForImp rdf:type rdf:Property ;
    rdfs:label 'Sop Role For Imp' ;
    rdfs:comment 'The specific operational capacity in which this SOP governs the IMP — e.g., storage, dispensing, destruction, cold-chain handling. A single IMP may have multiple applicability records with different roles. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:ImpSopApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productDesignationId rdf:type rdf:Property ;
    rdfs:label 'Product Designation Id' ;
    rdfs:comment 'Primary key for the product_designation association' ;
    rdfs:domain ind:ProductDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indicationScope rdf:type rdf:Property ;
    rdfs:label 'Indication Scope' ;
    rdfs:comment 'The specific disease, condition, or patient population for which this designation applies to this investigational product. Belongs to the association because the same product may hold different designations for different indications, and the same designation type may cover different indication scopes across products. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:ProductDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depotAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Depot Assignment Id' ;
    rdfs:comment 'Primary key for the site_depot_assignment association' ;
    rdfs:domain ind:DepotAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDepotFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Depot Flag' ;
    rdfs:comment 'Indicates whether this depot is the primary (true) or a backup/secondary (false) supply source for the investigational site under this assignment. A site may have one primary depot and one or more backup depots active simultaneously.' ;
    rdfs:domain ind:DepotAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplyRouteType rdf:type rdf:Property ;
    rdfs:label 'Supply Route Type' ;
    rdfs:comment 'Classifies the logistics routing model used for IMP delivery from the depot to the investigational site under this assignment (e.g., DIRECT_TO_SITE, HUB_AND_SPOKE, CROSS_DOCK, COURIER_DIRECT). Drives shipment planning and carrier selection.' ;
    rdfs:domain ind:DepotAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationId rdf:type rdf:Property ;
    rdfs:label 'Authorization Id' ;
    rdfs:comment 'Primary key for the site_authorization association' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enrollmentAuthorizedCount rdf:type rdf:Property ;
    rdfs:label 'Enrollment Authorized Count' ;
    rdfs:comment 'The maximum number of subjects the competent authority has authorized this specific site to enroll under this CTA. This per-site cap is set at authorization time and may differ from the site\'s operational max_enrollment_capacity.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteSpecificConditions rdf:type rdf:Property ;
    rdfs:label 'Site Specific Conditions' ;
    rdfs:comment 'Narrative description of any conditions, restrictions, or obligations attached by the national competent authority that apply exclusively to this investigational site under this CTA. Distinct from the overall CTA conditions_description which applies to all sites.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusAtSite rdf:type rdf:Property ;
    rdfs:label 'Status At Site' ;
    rdfs:comment 'The current authorization status of the CTA as it applies specifically to this investigational site. A site may be suspended under a CTA while other sites under the same CTA remain active, so this status is independent of the overall CTA authorization_status.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prerequisitePlanId rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Plan Id' ;
    rdfs:comment 'Identifier of another training plan that must be completed before this plan can be assigned, establishing training sequencing dependencies.' ;
    rdfs:domain ind:TrainingPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingPlan .

ind:studyProtocolId rdf:type rdf:Property ;
    rdfs:label 'Study Protocol Id' ;
    rdfs:comment 'Identifier of the clinical study protocol to which this training plan is specifically linked, if study-specific.' ;
    rdfs:domain ind:TrainingPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Protocol .

ind:assessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assessment Method' ;
    rdfs:comment 'Method used to evaluate trainee competency upon completion, such as written quiz, practical demonstration, direct observation, attestation, portfolio review, or interview.' ;
    rdfs:domain ind:TrainingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Completion Deadline Days' ;
    rdfs:comment 'Number of calendar days from assignment date within which the trainee must complete the training plan to remain compliant.' ;
    rdfs:domain ind:TrainingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentManagementReference rdf:type rdf:Property ;
    rdfs:label 'Document Management Reference' ;
    rdfs:comment 'Unique identifier within MasterControl or the document management system where the training plan document is stored and version-controlled.' ;
    rdfs:domain ind:TrainingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfModules rdf:type rdf:Property ;
    rdfs:label 'Number Of Modules' ;
    rdfs:comment 'Total count of individual training modules or courses included within this training plan.' ;
    rdfs:domain ind:TrainingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planOwnerName rdf:type rdf:Property ;
    rdfs:label 'Plan Owner Name' ;
    rdfs:comment 'Full name of the individual responsible for maintaining, reviewing, and approving the training plan content.' ;
    rdfs:domain ind:TrainingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recertificationIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Recertification Interval Months' ;
    rdfs:comment 'Number of months after which personnel must recertify or retake the training to maintain qualification and GCP compliance.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retirementReason rdf:type rdf:Property ;
    rdfs:label 'Retirement Reason' ;
    rdfs:comment 'Business justification for retiring the training plan, such as superseded by new version, regulatory change, or process elimination.' ;
    rdfs:domain ind:TrainingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:status rdf:type rdf:Property ;
    rdfs:label 'Status' ;
    rdfs:comment 'Current lifecycle state of the training plan indicating whether it is in draft, actively assigned, suspended, retired, under review, or archived.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Description of the intended audience for this training plan, such as clinical research associates, data managers, principal investigators, or site coordinators.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTrainingHours rdf:type rdf:Property ;
    rdfs:label 'Total Training Hours' ;
    rdfs:comment 'Estimated total number of hours required to complete all modules and assessments within the training plan.' ;
    rdfs:domain ind:TrainingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingModality rdf:type rdf:Property ;
    rdfs:label 'Training Modality' ;
    rdfs:comment 'Delivery method for the training content, such as instructor-led classroom, e-learning, blended approach, self-study, on-the-job, or webinar.' ;
    rdfs:domain ind:TrainingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteId rdf:type rdf:Property ;
    rdfs:label 'Site Id' ;
    rdfs:comment 'Identifier of the investigational site where the data entry session originated.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudySite .

ind:subjectId rdf:type rdf:Property ;
    rdfs:label 'Subject Id' ;
    rdfs:comment 'Identifier of the clinical trial subject/patient whose data is being entered during this session.' ;
    rdfs:domain ind:DataEntrySession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrialSubject .

ind:auditTrailReason rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reason' ;
    rdfs:comment 'Reason provided by the user for data modifications made during this session, required for ALCOA+ compliance and regulatory audit trails.' ;
    rdfs:domain ind:DataEntrySession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codingRequired rdf:type rdf:Property ;
    rdfs:label 'Coding Required' ;
    rdfs:comment 'Indicates whether data entered in this session requires medical coding (MedDRA or WHO-DD) for adverse events, medications, or medical history.' ;
    rdfs:domain ind:DataEntrySession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataPageName rdf:type rdf:Property ;
    rdfs:label 'Data Page Name' ;
    rdfs:comment 'Name of the specific eCRF data page or form section being completed during this session (e.g., Demographics, Vital Signs, Adverse Events).' ;
    rdfs:domain ind:DataEntrySession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:domainCode rdf:type rdf:Property ;
    rdfs:label 'Domain Code' ;
    rdfs:comment 'Two-character CDISC SDTM domain code (e.g., DM, AE, VS, LB) indicating the clinical data domain being entered.' ;
    rdfs:domain ind:DataEntrySession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Total elapsed time of the data entry session measured in seconds, used for productivity analysis and anomaly detection.' ;
    rdfs:domain ind:DataEntrySession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entryMethod rdf:type rdf:Property ;
    rdfs:label 'Entry Method' ;
    rdfs:comment 'Method by which data was entered into the EDC system during this session.' ;
    rdfs:domain ind:DataEntrySession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldsEnteredCount rdf:type rdf:Property ;
    rdfs:label 'Fields Entered Count' ;
    rdfs:comment 'Total number of eCRF fields that were populated or modified during this data entry session.' ;
    rdfs:domain ind:DataEntrySession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fieldsWithErrorsCount rdf:type rdf:Property ;
    rdfs:label 'Fields With Errors Count' ;
    rdfs:comment 'Number of fields that triggered edit check or validation rule failures during this data entry session.' ;
    rdfs:domain ind:DataEntrySession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDoubleDataEntry rdf:type rdf:Property ;
    rdfs:label 'Is Double Data Entry' ;
    rdfs:comment 'Indicates whether this session is part of a double data entry (DDE) process where data is entered twice independently for verification purposes.' ;
    rdfs:domain ind:DataEntrySession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSourceDataVerified rdf:type rdf:Property ;
    rdfs:label 'Is Source Data Verified' ;
    rdfs:comment 'Indicates whether source data verification was performed during or as part of this data entry session, confirming data matches source documents.' ;
    rdfs:domain ind:DataEntrySession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTrainingMode rdf:type rdf:Property ;
    rdfs:label 'Is Training Mode' ;
    rdfs:comment 'Indicates whether this session was conducted in training/sandbox mode rather than production, ensuring training data is excluded from analysis.' ;
    rdfs:domain ind:DataEntrySession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:queriesGeneratedCount rdf:type rdf:Property ;
    rdfs:label 'Queries Generated Count' ;
    rdfs:comment 'Number of data queries (discrepancies) automatically generated by edit checks during this session, requiring resolution.' ;
    rdfs:domain ind:DataEntrySession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:saveCount rdf:type rdf:Property ;
    rdfs:label 'Save Count' ;
    rdfs:comment 'Number of times the user saved data during this session, indicating session complexity and user behavior patterns.' ;
    rdfs:domain ind:DataEntrySession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionNumber rdf:type rdf:Property ;
    rdfs:label 'Session Number' ;
    rdfs:comment 'Externally-visible business identifier for the data entry session, used for audit trail references and query management communications.' ;
    rdfs:domain ind:DataEntrySession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timezoneOffset rdf:type rdf:Property ;
    rdfs:label 'Timezone Offset' ;
    rdfs:comment 'UTC timezone offset of the user\'s location during the data entry session, critical for accurate timestamp reconciliation in global trials.' ;
    rdfs:domain ind:DataEntrySession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Timestamp when the delegation of authority record was first created in the document management system.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:delegatedTasksSummary rdf:type rdf:Property ;
    rdfs:label 'Delegated Tasks Summary' ;
    rdfs:comment 'Summary description of the trial-related duties and tasks that have been delegated, such as informed consent, dispensing IP, CRF completion, and SAE reporting.' ;
    rdfs:domain ind:DelegationOfAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicSignatureApplied rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Applied' ;
    rdfs:comment 'Indicates whether a 21 CFR Part 11 compliant electronic signature has been applied to this delegation of authority document.' ;
    rdfs:domain ind:DelegationOfAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:findingCount rdf:type rdf:Property ;
    rdfs:label 'Finding Count' ;
    rdfs:comment 'Number of audit or quality findings identified against this delegation of authority document during inspections or internal reviews.' ;
    rdfs:domain ind:DelegationOfAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Timestamp when the delegation of authority record was last modified, supporting audit trail requirements.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:numberOfDelegates rdf:type rdf:Property ;
    rdfs:label 'Number Of Delegates' ;
    rdfs:comment 'Total count of individuals listed on the delegation of authority log who have been delegated specific trial-related responsibilities.' ;
    rdfs:domain ind:DelegationOfAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Check Status' ;
    rdfs:comment 'Status of the quality control review performed on the delegation of authority document to ensure completeness and accuracy.' ;
    rdfs:domain ind:DelegationOfAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopReference rdf:type rdf:Property ;
    rdfs:label 'Sop Reference' ;
    rdfs:comment 'Reference to the governing SOP that defines the process for creating, maintaining, and archiving delegation of authority logs.' ;
    rdfs:domain ind:DelegationOfAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded By Document Number' ;
    rdfs:comment 'Document number of the newer version that supersedes this delegation of authority, enabling version chain traceability.' ;
    rdfs:domain ind:DelegationOfAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingConfirmationRequired rdf:type rdf:Property ;
    rdfs:label 'Training Confirmation Required' ;
    rdfs:comment 'Indicates whether delegates listed on this document must provide evidence of training completion before performing delegated tasks.' ;
    rdfs:domain ind:DelegationOfAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address line of the vendor\'s registered business location used for correspondence and payment remittance.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address line for suite, floor, building, or additional location details of the vendor.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'Vendor\'s bank account number used for electronic fund transfers and payment remittance. Encrypted at rest per PCI-DSS requirements.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Routing Number' ;
    rdfs:comment 'Bank routing or SWIFT/BIC code used to identify the vendor\'s financial institution for payment processing.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:category rdf:type rdf:Property ;
    rdfs:label 'Category' ;
    rdfs:comment 'Tiered classification of the vendor based on strategic importance, qualification status, and procurement preference level.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Contract Effective Date' ;
    rdfs:comment 'Date on which the current master service agreement or framework contract with the vendor became effective.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiration Date' ;
    rdfs:comment 'Date on which the current master service agreement or framework contract with the vendor expires and requires renewal.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'The trade name or doing-business-as name under which the vendor operates, if different from the legal name.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversityClassification rdf:type rdf:Property ;
    rdfs:label 'Diversity Classification' ;
    rdfs:comment 'Diversity certification classification of the vendor for supplier diversity reporting and compliance with corporate social responsibility programs.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiration Date' ;
    rdfs:comment 'Expiration date of the vendor\'s certificate of insurance, ensuring adequate liability coverage for clinical trial services.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:is1099Reportable rdf:type rdf:Property ;
    rdfs:label 'Is 1099 Reportable' ;
    rdfs:comment 'Indicates whether payments to this vendor are subject to IRS 1099 reporting requirements for US tax compliance.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMinorityOwned rdf:type rdf:Property ;
    rdfs:label 'Is Minority Owned' ;
    rdfs:comment 'Indicates whether the vendor is certified as a minority-owned business enterprise for diversity tracking and reporting purposes.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:name rdf:type rdf:Property ;
    rdfs:label 'Name' ;
    rdfs:comment 'The official registered legal name of the vendor organization used in contracts, invoices, and regulatory filings.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'Date of the next scheduled quality audit or vendor oversight review as required by GCP vendor management procedures.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date on which the vendor was initially onboarded and approved in the vendor master system for clinical trial engagements.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchasingOrganization rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization' ;
    rdfs:comment 'The organizational unit responsible for procurement activities and contract negotiations with this vendor.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'The vendor\'s government-issued tax identification number used for tax reporting, 1099 filings, and regulatory compliance.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:type rdf:type rdf:Property ;
    rdfs:label 'Type' ;
    rdfs:comment 'Classification of the vendor by the nature of services or goods provided to clinical trial operations. Includes Contract Research Organizations (CROs), central laboratories, investigator sites, material suppliers, consultants, and technology providers.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'Unique alphanumeric business code assigned to the vendor for identification in financial systems and purchase orders.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentManifestId rdf:type rdf:Property ;
    rdfs:label 'Shipment Manifest Id' ;
    rdfs:comment 'Primary key for shipment_manifest' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chainOfCustodyIntact rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Intact' ;
    rdfs:comment 'Indicates whether the chain of custody was maintained without interruption throughout the shipment lifecycle.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionOnReceipt rdf:type rdf:Property ;
    rdfs:label 'Condition On Receipt' ;
    rdfs:comment 'Assessment of the shipment condition upon arrival at the destination, documenting any visible damage or compromise.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerCount rdf:type rdf:Property ;
    rdfs:label 'Container Count' ;
    rdfs:comment 'Total number of shipping containers (boxes, cryoshippers, coolers) in this manifest.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationAddress rdf:type rdf:Property ;
    rdfs:label 'Destination Address' ;
    rdfs:comment 'Full street address of the shipment destination location.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the shipment destination.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationFacilityName rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Name' ;
    rdfs:comment 'Name of the receiving facility (central lab, biorepository, or analytical lab).' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousGoodsClass rdf:type rdf:Property ;
    rdfs:label 'Hazardous Goods Class' ;
    rdfs:comment 'UN hazardous goods classification for the shipment contents (e.g., UN3373 Category B biological substance).' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isInternational rdf:type rdf:Property ;
    rdfs:label 'Is International' ;
    rdfs:comment 'Indicates whether the shipment crosses international borders, triggering additional regulatory and customs requirements.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTemperatureExcursion rdf:type rdf:Property ;
    rdfs:label 'Is Temperature Excursion' ;
    rdfs:comment 'Indicates whether a temperature excursion (deviation outside acceptable range) was detected during transit.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manifestNumber rdf:type rdf:Property ;
    rdfs:label 'Manifest Number' ;
    rdfs:comment 'Externally-visible business identifier for the shipment manifest, used for tracking and regulatory documentation of specimen shipments.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestType rdf:type rdf:Property ;
    rdfs:label 'Manifest Type' ;
    rdfs:comment 'Classification of the shipment manifest indicating the nature of contents being shipped (specimens, reagents, supplies, returns, or items for destruction).' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originAddress rdf:type rdf:Property ;
    rdfs:label 'Origin Address' ;
    rdfs:comment 'Full street address of the shipment origin location.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originCountryCode rdf:type rdf:Property ;
    rdfs:label 'Origin Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the shipment origin.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originFacilityName rdf:type rdf:Property ;
    rdfs:label 'Origin Facility Name' ;
    rdfs:comment 'Name of the facility from which the shipment originates (clinical site, lab, or depot).' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverName rdf:type rdf:Property ;
    rdfs:label 'Receiver Name' ;
    rdfs:comment 'Full name of the individual who received and acknowledged the shipment at the destination.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperName rdf:type rdf:Property ;
    rdfs:label 'Shipper Name' ;
    rdfs:comment 'Full name of the individual who prepared and dispatched the shipment, required for chain of custody.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingPriority rdf:type rdf:Property ;
    rdfs:label 'Shipping Priority' ;
    rdfs:comment 'Priority level assigned to the shipment based on specimen stability, study timelines, or regulatory deadlines.' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitWindow rdf:type rdf:Property ;
    rdfs:label 'Visit Window' ;
    rdfs:comment 'Study visit or timepoint window associated with the specimens in this manifest (e.g., Week 4, Screening).' ;
    rdfs:domain ind:ShipmentManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentItemId rdf:type rdf:Property ;
    rdfs:label 'Parent Item Id' ;
    rdfs:comment 'Self-referencing identifier pointing to a parent checklist item, enabling hierarchical checklist structures with sub-items.' ;
    rdfs:domain ind:ChecklistItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChecklistItem .

ind:capaTrigger rdf:type rdf:Property ;
    rdfs:label 'Capa Trigger' ;
    rdfs:comment 'Flag indicating whether non-compliance on this item automatically initiates a Corrective and Preventive Action (CAPA) workflow.' ;
    rdfs:domain ind:ChecklistItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:code rdf:type rdf:Property ;
    rdfs:label 'Code' ;
    rdfs:comment 'Unique business code assigned to the checklist item for identification in monitoring workflows and CTMS systems.' ;
    rdfs:domain ind:ChecklistItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:description rdf:type rdf:Property ;
    rdfs:label 'Description' ;
    rdfs:comment 'Detailed description of the checklist item explaining the monitoring task, verification requirement, or assessment criteria.' ;
    rdfs:domain ind:ClinicalTrials ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationClassification rdf:type rdf:Property ;
    rdfs:label 'Deviation Classification' ;
    rdfs:comment 'Classification of the type of deviation that would be recorded if this checklist item is found non-compliant during monitoring.' ;
    rdfs:domain ind:ChecklistItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedResponse rdf:type rdf:Property ;
    rdfs:label 'Expected Response' ;
    rdfs:comment 'The expected or compliant response value for this checklist item, used to auto-flag deviations when actual responses differ.' ;
    rdfs:domain ind:ChecklistItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guidanceText rdf:type rdf:Property ;
    rdfs:label 'Guidance Text' ;
    rdfs:comment 'Instructional guidance or help text provided to CRAs explaining how to properly assess or complete this checklist item during monitoring.' ;
    rdfs:domain ind:ChecklistItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalToQuality rdf:type rdf:Property ;
    rdfs:label 'Is Critical To Quality' ;
    rdfs:comment 'Flag indicating whether this checklist item is designated as Critical to Quality (CtQ) per the study risk assessment, requiring heightened monitoring attention.' ;
    rdfs:domain ind:ChecklistItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemType rdf:type rdf:Property ;
    rdfs:label 'Item Type' ;
    rdfs:comment 'Classification of the type of monitoring action required: verification (source data check), assessment (judgment-based), confirmation (yes/no), collection (document retrieval), or observation (visual inspection).' ;
    rdfs:domain ind:ChecklistItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringMethod rdf:type rdf:Property ;
    rdfs:label 'Monitoring Method' ;
    rdfs:comment 'The monitoring method for which this checklist item is applicable, supporting risk-based monitoring (RBM) strategies that combine on-site, remote, and centralized approaches.' ;
    rdfs:domain ind:ChecklistItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionApplicability rdf:type rdf:Property ;
    rdfs:label 'Region Applicability' ;
    rdfs:comment 'Geographic region or country codes where this checklist item is applicable, supporting multi-regional trial monitoring with jurisdiction-specific requirements.' ;
    rdfs:domain ind:ChecklistItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresDocumentation rdf:type rdf:Property ;
    rdfs:label 'Requires Documentation' ;
    rdfs:comment 'Flag indicating whether completion of this checklist item requires supporting documentation or evidence to be attached to the monitoring visit report.' ;
    rdfs:domain ind:ChecklistItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseType rdf:type rdf:Property ;
    rdfs:label 'Response Type' ;
    rdfs:comment 'Defines the expected response format when a CRA completes this checklist item during a monitoring visit.' ;
    rdfs:domain ind:ChecklistItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retiredDate rdf:type rdf:Property ;
    rdfs:label 'Retired Date' ;
    rdfs:comment 'Date when this checklist item was retired from active use, maintaining historical reference while preventing inclusion in new monitoring checklists.' ;
    rdfs:domain ind:ChecklistItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:visitTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Visit Type Applicability' ;
    rdfs:comment 'Indicates which type of monitoring visit this checklist item applies to: site initiation visit (SIV), interim monitoring visit (IMV), close-out visit (COV), or all visit types.' ;
    rdfs:domain ind:ChecklistItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightScore rdf:type rdf:Property ;
    rdfs:label 'Weight Score' ;
    rdfs:comment 'Numeric weighting factor assigned to this checklist item for calculating overall site compliance scores in risk-based monitoring analytics.' ;
    rdfs:domain ind:ChecklistItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteSelectionCommitteeId rdf:type rdf:Property ;
    rdfs:label 'Site Selection Committee Id' ;
    rdfs:comment 'Primary key for site_selection_committee' ;
    rdfs:domain ind:SiteSelectionCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:chairpersonEmail rdf:type rdf:Property ;
    rdfs:label 'Chairperson Email' ;
    rdfs:comment 'Primary email address of the committee chairperson for official communications regarding site selection activities.' ;
    rdfs:domain ind:SiteSelectionCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chairpersonName rdf:type rdf:Property ;
    rdfs:label 'Chairperson Name' ;
    rdfs:comment 'Full name of the individual serving as chairperson of the site selection committee, responsible for leading deliberations and final recommendations.' ;
    rdfs:domain ind:SiteSelectionCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:charterEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Charter Effective Date' ;
    rdfs:comment 'Date when the current committee charter became effective, establishing the committees authority and operating procedures.' ;
    rdfs:domain ind:SiteSelectionCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:diversityRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Diversity Requirement Flag' ;
    rdfs:comment 'Indicates whether the committee enforces patient population diversity requirements in site selection to ensure representative enrollment.' ;
    rdfs:domain ind:SiteSelectionCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationAuthority rdf:type rdf:Property ;
    rdfs:label 'Escalation Authority' ;
    rdfs:comment 'Name or role of the governance body or individual to whom the committee escalates contested or high-risk site selection decisions.' ;
    rdfs:domain ind:SiteSelectionCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feasibilityScoringModel rdf:type rdf:Property ;
    rdfs:label 'Feasibility Scoring Model' ;
    rdfs:comment 'Name or identifier of the quantitative scoring model applied during site feasibility assessments (e.g., weighted scorecard, risk-based model).' ;
    rdfs:domain ind:SiteSelectionCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irbApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Irb Approval Required' ;
    rdfs:comment 'Indicates whether the committee requires evidence of IRB/IEC approval or conditional approval before a site can be selected.' ;
    rdfs:domain ind:SiteSelectionCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxSitesPerReview rdf:type rdf:Property ;
    rdfs:label 'Max Sites Per Review' ;
    rdfs:comment 'Maximum number of candidate sites the committee can evaluate in a single review cycle, reflecting operational capacity constraints.' ;
    rdfs:domain ind:SiteSelectionCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberCount rdf:type rdf:Property ;
    rdfs:label 'Member Count' ;
    rdfs:comment 'Total number of current voting and non-voting members serving on the site selection committee.' ;
    rdfs:domain ind:SiteSelectionCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumEnrollmentTarget rdf:type rdf:Property ;
    rdfs:label 'Minimum Enrollment Target' ;
    rdfs:comment 'Minimum patient enrollment capacity threshold that a site must demonstrate during feasibility to be considered by the committee.' ;
    rdfs:domain ind:SiteSelectionCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextScheduledMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Meeting Date' ;
    rdfs:comment 'Date of the next planned committee meeting for site selection review activities.' ;
    rdfs:domain ind:SiteSelectionCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:piQualificationCriteria rdf:type rdf:Property ;
    rdfs:label 'Pi Qualification Criteria' ;
    rdfs:comment 'Summary description of the minimum qualifications, experience, and credentials required of a Principal Investigator for site approval by this committee.' ;
    rdfs:domain ind:SiteSelectionCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quorumThreshold rdf:type rdf:Property ;
    rdfs:label 'Quorum Threshold' ;
    rdfs:comment 'Minimum number of voting members required to be present for the committee to make binding site selection decisions.' ;
    rdfs:domain ind:SiteSelectionCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskAssessmentFramework rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Framework' ;
    rdfs:comment 'Name or identifier of the risk-based quality management framework used by the committee to evaluate site-level risks during selection.' ;
    rdfs:domain ind:SiteSelectionCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectionCriteriaVersion rdf:type rdf:Property ;
    rdfs:label 'Selection Criteria Version' ;
    rdfs:comment 'Version identifier of the standardized site selection criteria framework currently used by the committee for evaluating investigational sites.' ;
    rdfs:domain ind:SiteSelectionCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSitesApproved rdf:type rdf:Property ;
    rdfs:label 'Total Sites Approved' ;
    rdfs:comment 'Cumulative count of investigational sites that have been approved for selection by this committee since its formation.' ;
    rdfs:domain ind:SiteSelectionCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSitesReviewed rdf:type rdf:Property ;
    rdfs:label 'Total Sites Reviewed' ;
    rdfs:comment 'Cumulative count of investigational sites that have been formally reviewed by this committee since its formation.' ;
    rdfs:domain ind:SiteSelectionCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:votingMethod rdf:type rdf:Property ;
    rdfs:label 'Voting Method' ;
    rdfs:comment 'Decision-making methodology used by the committee to approve or reject site candidates during selection deliberations.' ;
    rdfs:domain ind:SiteSelectionCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Assessment Required Flag' ;
    rdfs:comment 'Indicates whether a formal assessment or examination is required for course completion, as opposed to attendance-only completion.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availableLanguages rdf:type rdf:Property ;
    rdfs:label 'Available Languages' ;
    rdfs:comment 'Comma-separated list of ISO 639-1 language codes for all available translations of this training course.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyLevel rdf:type rdf:Property ;
    rdfs:label 'Competency Level' ;
    rdfs:comment 'The proficiency level that the course is designed to develop, used for career development pathways and role qualification matrices.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentOwnerDepartment rdf:type rdf:Property ;
    rdfs:label 'Content Owner Department' ;
    rdfs:comment 'The internal department or functional group responsible for maintaining and updating the course content (e.g., Quality Assurance, Clinical Operations, Regulatory Affairs).' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerParticipant rdf:type rdf:Property ;
