# RDFS Schema for Business: Staffing Hr

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/staffing_hr#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Staffing Hr ---
ind:StaffingHr rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Staffing Hr' ;
    rdfs:comment 'Staffing and Human Resources is a workforce solutions industry providing temporary and permanent talent placement, recruitment process outsourcing, workforce management, and HR consulting services across all industries and skill levels.' .

# --- Domain Classes ---
ind:Candidate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:StaffingHr ;
    rdfs:label 'Candidate' ;
    rdfs:comment 'SSOT for all talent supply-side identity and qualification data. Owns candidate profiles, resumes, skills inventories, certifications, work history, availability, preferences, sourcing channel attribution, and candidate engagement records. Supports ATS workflows in Bullhorn and drives talent pool management, redeployment, and bench tracking across all placement types (W-2, 1099, EOR). Tracks candidate status from initial sourcing through placement and beyond.' .

ind:Client rdf:type rdfs:Class ;
    rdfs:subClassOf ind:StaffingHr ;
    rdfs:label 'Client' ;
    rdfs:comment 'SSOT for all client (employer) identity and commercial relationship data. Owns client company profiles, contacts, account hierarchies, locations, MSA agreements, rate cards, VMS integrations, SLA configurations, NPS scores, and CRM engagement history sourced from Bullhorn and Salesforce. Serves as the authoritative source for WHO the business serves on the demand side, supporting both direct clients and VMS/MSP program relationships.' .

ind:Recruitment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:StaffingHr ;
    rdfs:label 'Recruitment' ;
    rdfs:comment 'Owns the end-to-end talent acquisition and sourcing lifecycle. Covers sourcing strategies, job posting, sourcing campaigns, candidate submittals, right-to-represent (RTR) tracking, client interviews, interview scheduling, offer management, hiring decisions, and QoS (Quality of Submission) metrics. Tracks recruitment KPIs such as time-to-fill (TTF), time-to-start (TTS), submittal-to-hire ratios, and fall-off rates. Integrates with Bullhorn ATS and supports RPO and MSP delivery models.' .

ind:Joborder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:StaffingHr ;
    rdfs:label 'Joborder' ;
    rdfs:comment 'SSOT for all client requisitions (reqs) and job order demand data. Owns job order headers, position requirements, skill specifications, headcount targets, duration, bill rates, pay rates, markup percentages, SLA commitments, TTF and TTS targets, and fulfillment status lifecycle. Tracks the complete job order lifecycle from intake through closure including extensions, modifications, and cancellations. Central operational hub connecting client demand to candidate supply.' .

ind:Placement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:StaffingHr ;
    rdfs:label 'Placement' ;
    rdfs:comment 'Owns the full placement and assignment lifecycle for both temporary and permanent hires. Manages temporary assignments, contract-to-hire, temp-to-perm, and direct hire placement records. Tracks assignment start/end dates, extensions, backfill tracking, conversions, conversion fees, job details, work location, supervisor, fall-off rate monitoring, redeployment events, and assignment status. SSOT for active worker assignment status connecting candidates to job orders.' .

ind:Timesheet rdf:type rdfs:Class ;
    rdfs:subClassOf ind:StaffingHr ;
    rdfs:label 'Timesheet' ;
    rdfs:comment 'Owns all worker time and attendance data for contingent workers. Covers daily timesheet submission, hours worked, approval workflows, overtime (OT), double-time (DT), breaks, absences, PTO usage, per diem tracking, schedule management, and labor hour records sourced from Kronos Workforce Ready. Captures billable hours for client invoicing and payable hours for worker compensation. Feeds payroll processing and client billing with authoritative hours data.' .

ind:Payroll rdf:type rdfs:Class ;
    rdfs:subClassOf ind:StaffingHr ;
    rdfs:label 'Payroll' ;
    rdfs:comment 'Owns all worker pay and tax processing data. Covers gross pay calculation, pay rates, gross-to-net calculations, tax withholdings (FICA, FUTA, SUTA), burden rates, deductions, net pay, workers compensation insurance premiums, W-2 and 1099 tax form processing, payroll tax filing, PTO accruals, and benefits administration processed through TempWorks Payroll. Handles multi-state payroll compliance and supports EOR and co-employment payroll models.' .

ind:Billing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:StaffingHr ;
    rdfs:label 'Billing' ;
    rdfs:comment 'SSOT for all revenue and financial transaction data. Owns client invoice generation, bill rates, spread calculations (bill rate minus pay rate), markup calculations, gross margin tracking, payment terms, accounts receivable, payment processing, collections, credit memos, and dispute management sourced from Salesforce Revenue Cloud and Oracle NetSuite ERP. Supports various billing models including hourly time-and-materials, per-diem, project-based, SOW-based, and direct placement fee billing.' .

ind:Compliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:StaffingHr ;
    rdfs:label 'Compliance' ;
    rdfs:comment 'Owns regulatory and legal compliance data across the entire workforce lifecycle. Covers I-9 verification, E-Verify, EEOC compliance and reporting, OFCCP reporting, FLSA worker classification determinations (W-2 vs 1099), co-employment and joint employment risk management, non-compete and NDA enforcement tracking, OSHA safety compliance, audit trails required by DOL, OSHA, and IRS regulatory frameworks. Ensures all placements meet federal, state, and client-specific compliance requirements.' .

ind:Credentialing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:StaffingHr ;
    rdfs:label 'Credentialing' ;
    rdfs:comment 'Owns all candidate credential, certification, license, screening verification, and qualification data. Covers BGC (Background Check) results from Sterling, drug screen outcomes, professional license verification, skills assessments, training records, skill validations, credential expiration tracking, renewal requirements, and compliance with industry-specific certification mandates. Supports credentialing requirements for healthcare, IT, skilled trades, finance, government, and other specialized staffing verticals.' .

ind:Vendor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:StaffingHr ;
    rdfs:label 'Vendor' ;
    rdfs:comment 'SSOT for all third-party staffing supplier, subcontractor, and service provider data within MSP and VMS-managed programs. Owns vendor profiles, tier classifications, rate cards, rate agreements, Beeline VMS program enrollment, SOW vendor agreements, IC (Independent Contractor) supplier records, vendor performance scorecards, vendor contracts, and vendor compliance tracking. Supports multi-vendor contingent workforce programs and managed service provider operations.' .

ind:Contract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:StaffingHr ;
    rdfs:label 'Contract' ;
    rdfs:comment 'Owns all commercial agreement and contract lifecycle data. Covers Master Service Agreements (MSA) terms, Statements of Work (SOW) execution, rate schedule amendments, non-disclosure agreements (NDA), non-compete clauses, service level agreements (SLA), contract amendments, renewal and expiration tracking, and e-signature workflows via DocuSign CLM. SSOT for the legal and commercial terms governing all client and vendor contractual commitments.' .

# --- Data Product Classes (Tables) ---
ind:ApprovedHoursSummary rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Timesheet ;
    rdfs:label 'Approved Hours Summary' ;
    rdfs:comment 'Unified aggregated summary of approved hours for a worker-assignment-client combination within a pay period, broken down by pay type (regular, OT, DT, per diem, holiday). Serves as the single authoritative handoff record for both client invoice generation (billing domain) and payroll processing (payroll domain). Captures total regular hours, OT hours, DT hours, per diem units, bill rate applied, pay rate applied, total billable amount, total payable amount, burden rate components, approval confirmation flag, and payroll transmission status. Replaces separate billable and payable hour summaries to ensure a single reconciled SSOT. Distinct from raw time_entry records — this is the approved, billing-and-payroll-ready output of the timesheet approval process.' .

ind:Adjustment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Timesheet ;
    rdfs:label 'Adjustment' ;
    rdfs:comment 'Records post-submission corrections and amendments to approved timesheets, capturing the original timesheet reference, adjustment type (hours correction, rate correction, pay type reclassification, retroactive change), original values, adjusted values, adjustment reason, requestor, approver, and effective pay period. Maintains a complete audit trail of all timesheet modifications for compliance, dispute resolution, and payroll/billing reconciliation.' .

ind:LaborCategory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Timesheet ;
    rdfs:label 'Labor Category' ;
    rdfs:comment 'Reference entity defining labor categories and work classifications used to categorize time entries for cost allocation, billing rate determination, and workforce analytics. Captures category code, category name, skill level, FLSA classification (exempt/non-exempt), prevailing wage indicator, prevailing wage rate (for Davis-Bacon Act compliance on government staffing contracts), union code applicability, SCA (Service Contract Act) labor category mapping, and default bill/pay rate tier. Used by clients and staffing operations to segment labor costs by function, skill, or contract type. Links to ot_rule for determining applicable overtime calculation rules.' .

ind:PayRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payroll ;
    rdfs:label 'Pay Run' ;
    rdfs:comment 'Master record for each payroll processing cycle executed through TempWorks Payroll. Captures the payroll run header including pay period start and end dates, pay date, pay frequency, run type (regular, off-cycle, adjustment, void-and-reissue), run status (open, processing, approved, posted, voided), total gross pay, total net pay, total tax withholdings, total deductions, total employer burden, worker count, processing timestamps, and approver. Serves as the authoritative anchor for all payroll transactions within a given cycle and the primary reconciliation point for payroll operations.' .

ind:PayStub rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payroll ;
    rdfs:label 'Pay Stub' ;
    rdfs:comment 'Transactional record representing the individual worker pay statement generated for each pay run, including full pay disbursement details. Captures worker identifier, pay run reference, gross pay, regular hours, overtime hours, double-time hours, per diem amounts, gross-to-net calculation details, total deductions, total tax withholdings, net pay, and stub status. Disbursement attributes: pay delivery method (direct deposit, check, pay card), check number or ACH trace number, bank routing number, account number (masked), account type (checking, savings), deposit allocation type (full net, fixed amount, percentage split), allocation amounts for split-deposit configurations, deposit priority for multiple accounts, prenote status, account verification status, and pay card routing for unbanked workers. SSOT for individual worker earnings per pay period, associated payment disbursement instructions, and banking configuration — consolidates all direct deposit and ACH details formerly tracked separately.' .

ind:PayRate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payroll ;
    rdfs:label 'Pay Rate' ;
    rdfs:comment 'Master record defining the pay rate structure for a worker on a specific assignment or job order. Captures regular pay rate, overtime (OT) rate multiplier, double-time (DT) rate multiplier, per diem rate, shift differential rate, effective start and end dates, rate type (hourly, salary, piece-rate, daily), pay frequency (weekly, bi-weekly, semi-monthly), currency, rate source (negotiated, VMS-driven, standard), and approval status. Supports multi-rate scenarios for workers on multiple assignments.' .

ind:EarningsLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payroll ;
    rdfs:label 'Earnings Line' ;
    rdfs:comment 'Transactional line-item record capturing each individual earnings component within a worker pay stub. Covers regular pay, OT pay, DT pay, holiday pay, PTO payout, bonus, commission, per diem, expense reimbursement, shift differential, and other earning types. Stores hours or units, rate applied, earning code, earning description, taxability flag, and computed gross amount. Enables granular gross pay decomposition for reporting and compliance.' .

ind:TaxLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payroll ;
    rdfs:label 'Tax Line' ;
    rdfs:comment 'Transactional record capturing all payroll tax obligations — both employee withholdings and employer-side taxes — per worker per pay stub within a pay run. Employee side: federal income tax, state income tax, local/city tax, FICA Social Security and Medicare employee shares, additional Medicare surtax, and supplemental withholdings. Employer side: FICA Social Security and Medicare employer match, FUTA, SUTA by state, and local employer taxes. Stores tax side discriminator (employee/employer), tax authority jurisdiction, tax type code, taxable wage base, tax rate applied, withholding method (percentage, flat, table-based), computed amount, YTD taxable wages, YTD amount, and multi-state jurisdiction details. SSOT for ALL payroll tax line items — both employee withholdings and employer taxes are unified in this single product with a tax_side discriminator. Critical for gross-to-net calculation, burden rate validation, multi-state payroll tax filing, and quarterly/annual tax reconciliation.' .

ind:DeductionLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payroll ;
    rdfs:label 'Deduction Line' ;
    rdfs:comment 'Transactional line-item record for each voluntary or involuntary deduction applied to a worker pay stub, serving as the SSOT for all payroll deductions including benefit enrollment-driven withholdings. For benefit-type deductions: stores benefit plan name, plan type (medical, dental, vision, 401k, FSA, HSA, life, supplemental), coverage tier (employee only, employee+spouse, family), employee premium contribution, employer contribution, benefit carrier, enrollment effective and termination dates, and enrollment status. For garnishment-type deductions: references the governing garnishment order. For all deductions: stores deduction code, deduction type (pre-tax, post-tax, benefit, garnishment), deduction amount, deduction frequency, YTD deduction total, court order reference for garnishments, and deduction status (active, suspended, terminated). Consolidates benefit enrollment tracking with deduction processing — enrollment attributes drive premium withholding calculations each pay period.' .

ind:BurdenRate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payroll ;
    rdfs:label 'Burden Rate' ;
    rdfs:comment 'Master record defining the employer burden rate structure applied to worker pay for cost modeling, spread calculation, and client billing markup in staffing operations. Captures burden components including FICA employer share percentage, FUTA rate, SUTA rate by state, workers compensation (WC) rate by NCCI class code (with state-specific overrides, class description, hazard category, and base rate per $100 of payroll), general liability rate, benefits load percentage, overhead percentage, and total burden percentage. Stores effective dates, state jurisdiction, WC policy reference, client or assignment applicability, and rate source (manual, system-calculated, carrier-provided). Used to compute total employer cost per worker hour, validate bill rate margins, and support spread analysis for staffing profitability reporting.' .

ind:WcPolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payroll ;
    rdfs:label 'Wc Policy' ;
    rdfs:comment 'Master and transactional record for workers compensation insurance policies and premium calculations administered through TempWorks Payroll — unified SSOT for both WC policy administration and premium accrual. Policy attributes: policy number, insurance carrier, policy effective and expiration dates, state jurisdiction, experience modification factor (EMR), policy type (guaranteed cost, loss-sensitive), premium basis (payroll-based), audit frequency, and policy status. Premium transaction attributes: WC class code, NCCI class description, state jurisdiction, payroll amount subject to WC, WC rate applied per $100 of payroll, computed premium amount, experience modification factor applied, YTD premium total, premium period, and pay run reference. Supports multi-state WC compliance for temporary and contract workers, carrier reporting, premium audit reconciliation, accurate burden rate application, and cost allocation to client assignments.' .

ind:TaxFiling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payroll ;
    rdfs:label 'Tax Filing' ;
    rdfs:comment 'Transactional record tracking payroll tax deposit and filing obligations submitted to federal, state, and local tax authorities. Captures filing type (941, 940, SUTA, state income tax), tax authority, filing period, total taxable wages, total tax liability, deposit amount, deposit date, filing due date, filing status (pending, deposited, filed, amended), confirmation number, and penalty/interest amounts if applicable. Supports multi-state tax compliance and IRS/DOL audit readiness.' .

ind:TaxForm rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payroll ;
    rdfs:label 'Tax Form' ;
    rdfs:comment 'Master record representing annual tax forms generated for both W-2 employees/temporary workers and 1099 independent contractors. For W-2 forms: captures Box 1 wages, Box 2 federal income tax withheld, Boxes 3-6 Social Security and Medicare wages and withholdings, state and local wages and withholdings, pre-tax benefit amounts (Box 12 codes), and W-2 filing status. For 1099 forms: captures 1099-NEC nonemployee compensation (Box 1), 1099-MISC miscellaneous income, backup withholding, and state income. Stores tax year, worker/contractor identifier, employer/payer EIN, form type discriminator (W-2, W-2c, 1099-NEC, 1099-MISC), filing status (draft, filed, corrected), e-file confirmation, and correction history. SSOT for ALL annual tax form reporting — unified W-2 and 1099 populations common in staffing operations where both employee and IC worker types coexist. Supports IRS e-filing, state filing, worker distribution, and year-end reconciliation.' .

ind:TaxWithholdingElection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payroll ;
    rdfs:label 'Tax Withholding Election' ;
    rdfs:comment 'Master record capturing a workers federal and state tax withholding elections as submitted via W-4 (federal) and equivalent state withholding forms. Stores filing status (single, married, head of household), number of allowances or Step 3 dependent credits (post-2020 W-4), additional withholding amount, exempt from withholding flag, state withholding form type, state-specific elections, effective date, and election source (paper form, electronic self-service). Drives tax withholding calculation in each pay run.' .

ind:Invoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Invoice' ;
    rdfs:comment 'Core billing document issued to a client for staffing services rendered during a billing period. Captures invoice number, date, due date, billing period, total amount, tax amount, net amount, payment terms, status (draft, sent, paid, partially paid, disputed, void), billing model (time-and-materials, per-diem, project-based, SOW-based, direct placement fee), currency, PO number, and client billing account reference. SSOT for all client-facing billing documents across all staffing engagement types. Supports void-and-rebill workflows for retroactive billing corrections.' .

ind:InvoiceLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Invoice Line' ;
    rdfs:comment 'Line-item detail within a client invoice representing a single billable unit of work. Each line ties to a specific worker assignment, timesheet period, or deliverable. Captures line number, service description, billing type (regular, OT, DT, per diem, expense, placement fee), quantity, bill rate, extended amount, pay period dates, worker and job order references, cost center, GL account, tax code, and markup/spread values.' .

ind:BillRate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Bill Rate' ;
    rdfs:comment 'Master record of negotiated bill rates for client engagements. Stores the agreed-upon rate for a specific job category, skill level, client, and contract. Includes rate amount, rate type (standard, OT, DT, per diem, blended), effective dates, currency, rate card reference, markup percentage, spread amount (bill minus pay rate), gross margin percentage, burden inclusion flag, and approval status. Authoritative rate source for invoice generation and profitability calculations.' .

ind:BillingRateSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Billing Rate Schedule' ;
    rdfs:comment 'Reference entity defining structured rate schedules and rate card templates used across client engagements. Captures rate schedule name, schedule type (standard, premium, MSP-managed, VMS-driven, SOW), applicable job categories, skill tiers, geographic market, effective date range, markup percentage tiers, OT multiplier, DT multiplier, per diem allowance, holiday rate multiplier, and associated MSA or contract reference. Used as the template from which individual bill rates are instantiated for specific worker assignments.' .

ind:Payment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Payment' ;
    rdfs:comment 'Transactional record of client payments received against outstanding invoices. Captures payment date, payment amount, payment method (ACH, wire, check, credit card), payment reference number, bank account details (masked), remittance advice reference, applied invoice references, unapplied amount, currency, exchange rate, payment status (pending, cleared, returned, voided), and source transaction identifier. SSOT for all client payment receipts in the billing domain.' .

ind:PaymentApplication rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Payment Application' ;
    rdfs:comment 'Association record linking client payments to specific invoices or invoice lines, capturing the allocation of a payment across one or more outstanding invoices. Stores applied amount, discount taken, write-off amount, application date, application type (full, partial, prepayment, credit memo offset), and reconciliation status. Enables accurate accounts receivable aging and cash application tracking.' .

ind:CreditMemo rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Credit Memo' ;
    rdfs:comment 'Transactional record of credit memos issued to clients to offset or reduce outstanding invoice balances. Captures credit memo number, issue date, credit amount, reason code (billing error, retroactive rate correction, timesheet rebilling, service credit, fall-off adjustment, conversion fee reversal), originating invoice reference, approval status, applied status, expiration date, and issuing user. Supports dispute resolution, retroactive rate adjustments, timesheet correction rebilling, and accounts receivable balance corrections. Used in conjunction with invoice void-and-rebill workflows for full retroactive billing adjustments.' .

ind:Dispute rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Dispute' ;
    rdfs:comment 'Operational record tracking client billing disputes raised against invoices or invoice lines. Captures dispute number, dispute open date, dispute type (rate discrepancy, hours mismatch, unauthorized charge, duplicate invoice, worker eligibility), disputed amount, client contact, assigned resolution owner, dispute status (open, under review, resolved, escalated, closed), resolution date, resolution type (credit issued, invoice adjusted, dispute rejected), and root cause category. Drives the dispute-to-resolution workflow and feeds collections hold logic.' .

ind:CollectionActivity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Collection Activity' ;
    rdfs:comment 'Operational record of collections actions taken against past-due client billing accounts. Captures activity date, type (phone call, email, demand letter, escalation, legal referral, payment plan setup, write-off recommendation), collector, client contact, outcome (promise to pay, dispute raised, payment received, no response, escalated, payment plan agreed), follow-up date, notes, and associated invoice references. Drives the collections workflow, DSO reduction efforts, and aging bucket management.' .

ind:BillingAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Billing Account' ;
    rdfs:comment 'Master record representing a clients financial billing entity — the account to which invoices are issued and against which payments and credits are tracked. Distinct from the CRM client profile (owned by client domain). Captures billing account number, billing address, AR contact, payment terms (net days, early payment discount percentage, discount window), credit limit, credit status, preferred payment method, tax ID, tax exemption status, invoice delivery method, currency, billing cycle (weekly, bi-weekly, monthly), and external customer account identifier. SSOT for client billing identity and payment terms within the billing domain.' .

ind:PlacementFee rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Placement Fee' ;
    rdfs:comment 'Transactional record for direct placement and permanent hire fee billing. Captures fee type (direct placement, temp-to-perm conversion, RPO fee, retained search), fee amount, fee percentage of first-year salary, guarantee period (fall-off window in days), fall-off date, replacement eligibility, invoiced amount, invoice reference, payment status, and associated job order and candidate references. SSOT for permanent placement revenue, distinct from time-and-materials billing. Supports fall-off tracking and guarantee period management critical to direct hire operations.' .

ind:ExpenseCharge rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Expense Charge' ;
    rdfs:comment 'Transactional record of billable expenses incurred by workers or staffing operations and passed through to client invoices. Captures expense type (per diem, travel, lodging, mileage, equipment, training), date, amount, currency, receipt reference, approval status, billable flag, markup percentage, client PO reference, cost center, GL account, and associated assignment and invoice line references. Supports pass-through expense billing in project-based and SOW engagements.' .

ind:I9Verification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'I9 Verification' ;
    rdfs:comment 'Master record for I-9 Employment Eligibility Verification for each worker. Tracks Section 1 (employee attestation), Section 2 (employer document review), Section 3 (reverification/rehire), document types presented, document numbers, expiration dates, E-Verify case number linkage, completion status, and re-verification due dates. SSOT for I-9 compliance per INA requirements. Sourced from onboarding workflows and Sterling BGC system.' .

ind:EverifyCase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Everify Case' ;
    rdfs:comment 'Transactional record for each E-Verify case submitted to DHS/SSA for worker employment eligibility confirmation. Captures case number, submission timestamp, initial case result (Employment Authorized, Tentative Nonconfirmation - TNC, Final Nonconfirmation), TNC resolution status, referral dates, closure reason, and federal case closure code. Links to i9_verification. Sourced from Sterling BGC and E-Verify federal portal integration.' .

ind:WorkerClassification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Worker Classification' ;
    rdfs:comment 'Master record capturing FLSA worker classification determinations for each worker engagement — W-2 employee vs. 1099 independent contractor (IC). Stores classification type, determination basis (behavioral control, financial control, relationship type per IRS common law test), classification date, reviewing attorney or compliance officer, client-requested classification, override flags, co-employment risk rating, and IRS audit exposure notes. SSOT for IC vs. W-2 classification decisions.' .

ind:EeocFiling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Eeoc Filing' ;
    rdfs:comment 'Transactional record for EEOC (Equal Employment Opportunity Commission) regulatory filings and reports submitted on behalf of the staffing firm or client. Covers EEO-1 Component 1 report submissions, filing period, establishment count, total headcount by race/ethnicity/gender/job category, submission confirmation number, filing status, and amendment history. Supports EEOC and OFCCP audit readiness.' .

ind:OshaIncident rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Osha Incident' ;
    rdfs:comment 'Transactional record for OSHA recordable workplace safety incidents involving contingent workers on client sites. Captures incident date, client site location, injury/illness type, body part affected, OSHA recordability determination (recordable vs. first-aid only), days away from work, restricted duty days, OSHA 300 log entry number, workers compensation claim linkage, root cause, and corrective action taken. Supports OSHA 300/300A annual summary reporting.' .

ind:RegulatoryViolation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Violation' ;
    rdfs:comment 'Transactional record for identified regulatory violations, compliance breaches, and enforcement actions across all regulatory frameworks (DOL, EEOC, OSHA, IRS, FCRA, GDPR, CCPA, state labor boards). Captures violation type, regulatory body, applicable regulation/statute, discovery date, discovery method (internal audit, external complaint, agency notice, whistleblower report, client notification, self-assessment), severity level (minor/moderate/major/critical), affected worker or client count, root cause category, remediation plan, remediation owner, remediation due date, resolution status, financial penalty amount, legal counsel involvement flag, and board notification flag. SSOT for compliance incident tracking. Supports compliance dashboard KPIs, regulatory risk trending, and board-level compliance reporting.' .

ind:Audit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Audit' ;
    rdfs:comment 'Master record for internal and external compliance audits conducted across the staffing firms operations, with embedded audit finding detail records. Covers audit type (I-9 audit, payroll tax audit, FLSA audit, FCRA audit, SOC 2 audit, client compliance audit, DOL audit), audit scope, auditor (internal team or external firm), audit period, and final audit disposition. Each audit contains one-to-many finding records capturing: finding category (documentation gap, process failure, regulatory breach, control weakness), regulatory citation, affected population size, risk rating (low/medium/high/critical), recommended corrective action, responsible owner, due date, remediation evidence, and closure status. SSOT for all compliance audit activity and finding lifecycle management from identification through closure. Distinct from ofccp_compliance which covers OFCCP-specific federal contractor reviews and Affirmative Action Plans.' .

ind:WageHourDetermination rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Wage Hour Determination' ;
    rdfs:comment 'Master record for wage and hour compliance determinations made for worker engagements, covering FLSA overtime eligibility, state-specific minimum wage applicability, prevailing wage determinations (Davis-Bacon, Service Contract Act), exempt vs. non-exempt classification, and pay equity assessments. Captures determination date, applicable law/regulation, pay rate validated, overtime threshold, and compliance officer sign-off. Supports DOL audit readiness and FLSA litigation defense.' .

ind:Requirement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Requirement' ;
    rdfs:comment 'Reference master for federal regulations and client-specific contractual compliance requirements that govern staffing operations. Each record defines a requirement type (federal regulation, client contractual mandate, industry standard), applicable jurisdiction scope, effective date, expiration date, governing body, requirement description, and mandatory documentation checklist. Serves as the compliance rule catalog driving requirement-to-worker and requirement-to-placement enforcement checks. Distinct from state_compliance_rule which owns state-specific and local jurisdiction requirements that vary by geography.' .

ind:PlacementComplianceCheck rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Placement Compliance Check' ;
    rdfs:comment 'Transactional record capturing the compliance gate-check results for each worker placement prior to assignment start or extension. Validates that all applicable federal, state, and client-specific compliance requirements are satisfied: I-9 complete, E-Verify authorized, BGC cleared, drug screen passed, required credentials verified, safety training complete, worker classification determined, co-employment risk assessed, wage and hour determination completed, and client-specific requirements met. Each check item has a pass/fail/waived/pending status, check date, reviewer, and waiver authorization (if applicable). Acts as the compliance clearance record before a placement goes active. Supports real-time compliance dashboards and prevents non-compliant placements from generating billable hours.' .

ind:StateComplianceRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'State Compliance Rule' ;
    rdfs:comment 'Reference master for state-specific and local jurisdiction compliance requirements that vary by geography and impact multi-state staffing operations. Captures state/locality, effective date, expiration date, requirement type (ban-the-box, pay transparency, salary history ban, state E-Verify mandate, state-specific drug testing restrictions, portable background check laws, paid sick leave mandate, predictive scheduling, wage theft prevention notice, state mini-WARN Act, independent contractor classification test variations such as ABC test vs. common law test), applicability criteria (employer size threshold, industry sector, worker type), penalty for non-compliance, enforcement agency, and source citation with URL. Drives jurisdiction-aware compliance enforcement for multi-state staffing operations. Distinct from compliance_requirement which owns federal regulations and client-specific contractual mandates.' .

ind:Credential rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Credentialing ;
    rdfs:label 'Credential' ;
    rdfs:comment 'Master record for every credential, certification, license, qualification, immunization, or safety certification type recognized by Staffing Hr across all staffing verticals (healthcare, IT, skilled trades, finance, government). Defines the credential taxonomy including credential name, issuing authority, governing body, credential category (license, certification, clearance, assessment, immunization, safety_certification), applicable industry vertical, required renewal cycle, expiration rules, and whether the credential is mandatory for placement eligibility. Covers professional licenses (RN, CPA, PE, CDL), safety certifications (OSHA 10/30/510), immunizations (Hep B, MMR, TB, COVID-19), security clearances, and skills assessments. This is the SSOT for credential definitions — distinct from a candidates actual held credential instance.' .

ind:CredentialInstance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Credentialing ;
    rdfs:label 'Credential Instance' ;
    rdfs:comment 'Transactional record capturing a specific credential held by a candidate — the instance of a credential type owned by a worker. Tracks credential number, issuing authority, issue date, expiration date, current verification status (pending, verified, expired, revoked), verification method, verification date, source system (Sterling BGC, manual upload, third-party registry), and extended attributes for specialized credential types (e.g., lot number and titer results for immunizations, card number for OSHA certifications, clearance level/granting agency/investigation type/polygraph details for security clearances). Also owns the full renewal lifecycle for the credential instance: renewal application date, submission date, renewal authority, renewal fee, renewal status (initiated, submitted, approved, denied, pending_documentation), new expiration date upon approval, and CEU requirements fulfilled. This is the operational SSOT for does this candidate currently hold this credential? and what is the renewal status? — drives placement eligibility checks, expiry alerting, and renewal workflows.' .

ind:BgcOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Credentialing ;
    rdfs:label 'Bgc Order' ;
    rdfs:comment 'Transactional record representing a background check (BGC) order placed with Sterling Background Check or another screening vendor for a specific candidate. Captures order date, package type (criminal, employment verification, education verification, drug screen, credit check, MVR), order status (ordered, in-progress, completed, disputed, cancelled), turnaround SLA, adjudication status, and the triggering job order or placement. Sourced from Sterling Background Check system.' .

ind:BgcResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Credentialing ;
    rdfs:label 'Bgc Result' ;
    rdfs:comment 'Consolidated SSOT for all screening and verification outcome data returned from Sterling or another screening vendor. Each record represents a single component result within a background check order or standalone screening event. Captures the check component type (criminal_search, employment_verification, education_verification, reference_check, sex_offender_registry, global_watchlist, drug_screen, credit_check, MVR), result status (clear, consider, adverse, pending, negative, positive, dilute, adulterated, substituted), finding details, county/jurisdiction searched, adjudication decision, adverse action flag, FCRA compliance flags, result received timestamp, and component-specific extended attributes. Drug screen attributes: panel type (5/10/12-panel), specimen type (urine, hair, oral fluid), collection site, collection date, lab processing date, MRO review status and decision, DOT vs. non-DOT flag, substances detected. Education verification attributes: institution name, degree type, field of study, graduation date, verification source (NSC, direct institution, third-party), verification outcome. Employment verification attributes: employer name, employment dates, job title, verification method (direct, The Work Number/Equifax), discrepancies found. Reference check attributes: reference contact name, relationship to candidate, structured ratings (work quality, reliability, communication, rehire eligibility), verbatim comments, overall recommendation. One bgc_order produces multiple bgc_result records. This is the single authoritative source for all screening outcomes — no separate sub-type products exist.' .

ind:DrugScreen rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Credentialing ;
    rdfs:label 'Drug Screen' ;
    rdfs:comment 'Transactional record for a drug screening event ordered for a candidate. Tracks panel type (5-panel, 10-panel, 12-panel), specimen type (urine, hair, oral fluid, breath), collection site, collection date, lab processing date, result status (negative, positive, dilute, adulterated, substituted, cancelled, pending), substances detected, MRO (Medical Review Officer) review status, MRO decision, and DOT vs. non-DOT compliance flag. Sourced from Sterling Background Check drug screen module.' .

ind:LicenseVerification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Credentialing ;
    rdfs:label 'License Verification' ;
    rdfs:comment 'Transactional record capturing the verification of a professional license against an official state or national registry (e.g., nursing license via state board, CPA via NASBA, PE via NCEES, CDL via DMV). Tracks license number, issuing state/jurisdiction, license type, verification source (primary source, third-party registry, manual), verification date, verification outcome (verified, not found, expired, suspended, revoked), license status at time of verification, and next scheduled re-verification date. Critical for healthcare, finance, and government staffing verticals.' .

ind:SkillsAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Credentialing ;
    rdfs:label 'Skills Assessment' ;
    rdfs:comment 'Transactional record for a formal skills assessment administered to a candidate to validate proficiency in a specific skill, technology, or trade. Captures assessment type (written test, practical evaluation, simulation, coding challenge, trade skills test), assessment provider (internal, third-party like Criteria Corp or Wonderlic), skill or competency assessed, assessment date, raw score, percentile rank, pass/fail threshold, result status, and validity period. Supports QoS (Quality of Submission) tracking and candidate ranking.' .

ind:TrainingRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Credentialing ;
    rdfs:label 'Training Record' ;
    rdfs:comment 'Transactional record tracking completion of a required or elective training course by a candidate or placed worker. Captures training course name, training provider (internal LMS via SAP SuccessFactors, external vendor), training category (OSHA safety, HIPAA compliance, harassment prevention, skills development, onboarding orientation), delivery method (in-person, e-learning, virtual), completion date, expiration date, pass/fail status, CEU credits earned, and whether the training is mandatory for a specific placement or client. Sourced from SAP SuccessFactors LMS.' .

ind:CredentialRequirement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Credentialing ;
    rdfs:label 'Credential Requirement' ;
    rdfs:comment 'Association entity defining which credentials, licenses, certifications, drug screens, and BGC packages are required for a specific job order or placement type. Captures the job order or placement type reference, required credential type, whether the requirement is mandatory or preferred, the required verification level (primary source vs. self-reported), acceptable expiration window, client-specific override rules, and effective date of the requirement. Enables automated credentialing gap analysis when a candidate is submitted for a role. Named to avoid collision with the placement domains core entities.' .

ind:CredentialPackage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Credentialing ;
    rdfs:label 'Credential Package' ;
    rdfs:comment 'Master record defining a named bundle of credentialing requirements (BGC checks, drug screens, license verifications, training completions, assessments) that must be satisfied for a specific client, industry vertical, or job category. Examples: Healthcare Travel Nurse Package, Federal Government IT Clearance Package, Light Industrial Warehouse Package. Captures package name, applicable vertical, client or program scope, list of required credential types, required BGC components, drug screen panel, effective and expiry dates, and package version for change tracking. Enables standardized credentialing workflows across similar placements and drives the candidate_readiness evaluation.' .

ind:WorkAuthorization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Credentialing ;
    rdfs:label 'Work Authorization' ;
    rdfs:comment 'Master record capturing a candidates work authorization status and documentation in the United States or other jurisdictions. Tracks authorization type (US Citizen, Permanent Resident, H-1B, OPT, TN, EAD, L-1, O-1, etc.), sponsorship required flag, visa number, visa category, authorized start date, authorized end date, country of authorization, sponsoring employer (if applicable), and USCIS case number. Distinct from I-9 verification (which is the compliance process) — this is the authoritative record of the workers legal right to work. Critical for placement eligibility, co-employment risk management, and ensuring compliance with immigration law in staffing engagements.' .

ind:CredentialDocument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Credentialing ;
    rdfs:label 'Credential Document' ;
    rdfs:comment 'Master record for physical or digital documents submitted by a candidate to support credentialing verification — diplomas, transcripts, license copies, certification cards, immunization records, professional references, and government-issued IDs. Captures document type, document title, issuing institution or authority, issue date, expiration date, document storage reference (DocuSign CLM or document vault URI), verification status, and the credential or verification record it supports. Provides the document audit trail required for FCRA, HIPAA, and client audit purposes.' .

ind:PackageRequirement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Credentialing ;
    rdfs:label 'Package Requirement' ;
    rdfs:comment 'This association product represents the requirement relationship between credential_package and credential. It captures the specific rules and constraints that govern how each credential must be satisfied within the context of a specific credentialing package. Each record links one credential_package to one credential with attributes that define whether the credential is mandatory, verification requirements, expiry windows, renewal policies, and waiver rules for that specific package-credential combination.. Existence Justification: In staffing and recruitment operations, credential packages are reusable bundles that combine multiple credentials with package-specific rules. A single package (e.g., Healthcare Travel Nurse Package) requires multiple credentials (RN license, BLS, immunizations, background check), and a single credential (e.g., RN license) is required by multiple packages across different clients and verticals. Compliance teams actively configure and manage these package-credential relationships, setting mandatory/optional flags, verification levels, expiry windows, and waiver policies for each combination.' .

ind:CredentialType rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Credentialing ;
    rdfs:label 'Credential Type' ;
    rdfs:comment 'Master reference table for credential_type. Referenced by credential_type_id.' .

ind:Supplier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vendor ;
    rdfs:label 'Supplier' ;
    rdfs:comment 'Master record for all third-party staffing suppliers, subcontractors, independent contractor (IC) suppliers, and service providers participating in MSP/VMS-managed contingent workforce programs. Captures vendor identity, legal entity details, business type (staffing agency, IC supplier, SOW provider, subcontractor), tax classification (W-2, 1099, Corp-to-Corp), EIN, DUNS number, NAICS code, diversity certifications (MBE, WBE, SDVOB), primary contact, headquarters address, operational regions, onboarding status, and Beeline VMS enrollment status. For IC supplier subtypes, additionally captures IRS worker classification determination, IC compliance program enrollment status, IC compliance vendor (e.g., MBO Partners, Shiftpixy), indemnification agreement status, right-to-audit clause, insurance minimums, IC risk score, and business structure (sole prop, LLC, S-Corp, C-Corp). SSOT for ALL vendor identity across all programs — all vendor types including staffing agencies, IC suppliers, SOW providers, and subcontractors are unified in this single master record. The ic_supplier subtype is distinguished by business_type and carries additional IC-specific compliance attributes within this same entity to avoid data divergence across staffing agency and IC supplier workflows.' .

ind:TierClassification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vendor ;
    rdfs:label 'Tier Classification' ;
    rdfs:comment 'Reference and history table defining vendor tier levels and tracking tier reclassification events within MSP/VMS programs. Tier definitions capture tier code, tier name (e.g., Tier 1 Preferred, Tier 2 Approved, Tier 3 Conditional, Tier 4 Probationary), tier description, program eligibility rules, submission priority order, maximum fill-rate allocation percentage, SLA requirements per tier, and review cycle frequency. Tier review history captures review date, vendor ID, previous tier, proposed tier, review trigger (scheduled, performance-based, compliance failure, client request), scorecard period referenced, review committee members, decision outcome (upgraded, downgraded, maintained, suspended), effective date of tier change, rationale notes, and approval status. Drives vendor routing logic in Beeline VMS and provides full audit trail for tier movement decisions.' .

ind:VmsEnrollment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vendor ;
    rdfs:label 'Vms Enrollment' ;
    rdfs:comment 'Tracks each vendors enrollment, participation record, and onboarding task completion within the Beeline VMS contingent workforce program. Captures enrollment date, program name, client program ID, enrollment status (active, suspended, terminated, pending), approved job categories, approved work locations, VMS portal credentials status, electronic onboarding completion flag, MSP sponsor, enrollment agreement reference, and vendor onboarding workflow tasks (document submission, insurance verification, system access provisioning, training completion, contract execution, compliance attestation) with task status, due dates, completion dates, assigned reviewers, and blocking flags. One record per vendor per VMS program. Supports multi-client MSP program management and tracks the full supplier-organization-level onboarding lifecycle from initial enrollment through full program activation. Distinct from worker onboarding (owned by the onboarding domain) — this is supplier-organization-level enrollment and onboarding.' .

ind:VendorRateCard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vendor ;
    rdfs:label 'Vendor Rate Card' ;
    rdfs:comment 'Defines the standard bill rate and pay rate schedule negotiated with a vendor for specific job categories, skill levels, and labor classifications within a VMS program or MSP engagement. Captures vendor ID, job category, labor category (e.g., IT, light industrial, clerical, professional), skill level (e.g., junior, mid, senior, lead), standard bill rate, standard pay rate, OT bill rate, OT pay rate, DT bill rate, DT pay rate, per diem rate, currency, effective date, expiration date, geographic market, and rate card version. Serves as the rate template from which binding rate_agreement records are executed. Supports rate benchmarking, spread analysis, and market rate comparison across the vendor supply chain.' .

ind:RateAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vendor ;
    rdfs:label 'Rate Agreement' ;
    rdfs:comment 'Captures the formally executed rate agreement between the MSP/staffing firm and a vendor supplier for a specific client program or engagement period. Tracks agreement reference number, vendor ID, client program, negotiated markup percentage, spread floor, rate lock period, rate escalation clauses, approved rate exceptions, signatory names, execution date, effective start date, expiration date, and DocuSign CLM document reference. Distinct from the rate card template — this is the binding executed agreement.' .

ind:SowAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vendor ;
    rdfs:label 'Sow Agreement' ;
    rdfs:comment 'Manages Statement of Work (SOW) agreements executed with vendors for project-based or deliverable-based engagements within the vendor program. Captures SOW number, vendor ID, client ID, project title, scope of work description, deliverables list, fixed price or T&M structure, total contract value, milestone schedule, start date, end date, amendment history, SOW status (draft, executed, active, closed, terminated), DocuSign CLM reference, and co-employment risk classification. Supports SOW vendor program management distinct from staff augmentation. Note: This product owns the vendor-side SOW relationship and program enrollment aspects; the contract domain owns the commercial contract lifecycle and legal terms of the SOW.' .

ind:PerformanceScorecard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vendor ;
    rdfs:label 'Performance Scorecard' ;
    rdfs:comment 'Periodic vendor performance scorecard capturing quantitative and qualitative KPIs for each supplier within an MSP/VMS program. Tracks evaluation period, overall score, TTF (Time to Fill) score, QoS (Quality of Submission) score, submittal-to-interview ratio, interview-to-offer ratio, offer-to-start ratio, fall-off rate, assignment completion rate, compliance rate, NPS score, client satisfaction rating, redeployment rate, and scorecard status (draft, published, disputed, finalized). Drives tier reclassification and program allocation decisions.' .

ind:VendorContact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vendor ;
    rdfs:label 'Vendor Contact' ;
    rdfs:comment 'Master record for individual contacts associated with a vendor/supplier organization. Captures contact full name, job title, role type (account manager, recruiter, compliance officer, billing contact, executive sponsor), email, phone, mobile, preferred communication method, contact status (active, inactive), primary contact flag, and the vendor organization they represent. Supports relationship management and communication routing for MSP program operations.' .

ind:ProgramAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vendor ;
    rdfs:label 'Program Allocation' ;
    rdfs:comment 'Defines the requisition fill-rate allocation and submission quota assigned to each vendor within a specific client VMS program and job category. Captures program ID, vendor ID, job category, tier classification reference, allocation percentage, maximum concurrent submissions allowed, priority rank within tier, allocation effective date, expiration date, and allocation status (active, suspended, exhausted). Governs how job orders are distributed across the vendor supply chain in Beeline VMS to ensure preferred suppliers receive first-look access per MSP program rules. Updated periodically based on scorecard results and tier reclassification decisions.' .

ind:VendorCompliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vendor ;
    rdfs:label 'Vendor Compliance' ;
    rdfs:comment 'Tracks vendor-level compliance status, regulatory obligation fulfillment, and insurance certificate records for each supplier in the MSP/VMS program. Captures compliance category (insurance, E-Verify, EEOC, OFCCP, OSHA, FCRA, I-9 audit, workers comp, FUTA/SUTA registration, non-compete policy, data security SOC 2), compliance item description, required document, document expiration date, compliance status (compliant, non-compliant, pending review, waived), last audit date, next review date, remediation notes, and compliance officer assigned. For insurance-category records, additionally captures certificate number, insurance type (general liability, professional liability/E&O, workers compensation, cyber liability, umbrella), carrier name, policy number, coverage limit, certificate holder (MSP/client), additional insured status, auto-renewal flag, and COI document reference. Triggers compliance alerts when documents or certificates approach expiration. Distinct from the credentialing domain which tracks worker-level credentials.' .

ind:PreferredSupplierList rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vendor ;
    rdfs:label 'Preferred Supplier List' ;
    rdfs:comment 'Manages the Preferred Supplier List (PSL) — the curated, approved roster of vendors authorized to supply contingent workers or SOW services for a specific client program or job category. Captures client program ID, vendor ID, job category, PSL status (preferred, approved, conditional, excluded), inclusion date, exclusion date, PSL version, approval authority, and client-specific notes. Governs which vendors are visible and eligible to receive requisitions in the VMS for each client engagement.' .

ind:DiversityCertification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Vendor ;
    rdfs:label 'Diversity Certification' ;
    rdfs:comment 'Tracks vendor diversity certifications required for OFCCP compliance, client diversity spend reporting, and supplier diversity program participation. Captures certification type (MBE, WBE, SDVOB, HUBZone, 8(a), LGBTBE, VOSB), certifying body (NMSDC, WBENC, SBA, USVBA), certification number, issue date, expiration date, certification status (active, expired, pending renewal, revoked), and supporting document reference. Enables diversity spend analytics and OFCCP supplier diversity reporting.' .

ind:Msa rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Msa' ;
    rdfs:comment 'Master Service Agreement — the primary commercial contract governing the overall client-staffing firm relationship. Stores MSA header data including effective dates, governing law, jurisdiction, auto-renewal terms, termination notice periods, liability caps, indemnification clauses, insurance requirements (GL, WC, E&O minimums), and MSA status lifecycle (draft, under_review, executed, expired, terminated). Links to client account hierarchy. SSOT for all client MSA terms managed via DocuSign CLM. Parent contract for SOWs, rate schedules, SLAs, and amendments.' .

ind:Sow rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Sow' ;
    rdfs:comment 'Statement of Work — a child contract under an MSA that defines a specific engagement scope, deliverables, milestones, project timelines, fixed-fee or time-and-materials pricing, and acceptance criteria. Tracks SOW status (draft, submitted, approved, active, closed), SOW type (project-based, staff augmentation, RPO, MSP), and links to the governing MSA. Managed via DocuSign CLM.' .

ind:Nda rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Nda' ;
    rdfs:comment 'Non-Disclosure Agreement — standalone or ancillary confidentiality agreement executed with clients, candidates, or vendors. Captures NDA type (mutual, one-way), parties involved, confidentiality scope, duration, carve-outs, and execution status. Tracks expiration and renewal obligations. Managed via DocuSign CLM.' .

ind:Sla rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Sla' ;
    rdfs:comment 'Service Level Agreement record defining measurable performance commitments within an MSA or SOW, along with periodic measurement results tracking actual performance against those targets. Stores SLA metric name (TTF, TTS, QoS, fill rate, NPS, submittal-to-interview ratio, first-day no-show rate), target threshold, measurement frequency (weekly, monthly, quarterly), penalty/credit terms, and governing contract reference. Captures measurement results per period: actual metric value, variance from target, breach flag, penalty/credit amount triggered, measurement period dates, and measurement source system. SSOT for all contractual SLA obligations, compliance tracking, and performance measurement. Enables SLA compliance reporting, penalty/credit calculation, client QBR (Quarterly Business Review) preparation, and trend analysis across measurement periods.' .

ind:ContractRateSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Contract Rate Schedule' ;
    rdfs:comment 'Contractual rate schedule defining agreed bill rates, pay rates, markup percentages, spread, burden rates, OT/DT multipliers, and per diem allowances for specific job categories, skill levels, or labor classifications under an MSA or SOW. Tracks effective date ranges, rate card version, and approval status. SSOT for all contractually agreed pricing terms.' .

ind:Amendment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Amendment' ;
    rdfs:comment 'Contract Amendment — a formal, versioned modification to an existing MSA, SOW, rate schedule, or vendor agreement. Captures amendment sequence number, amendment type (rate change, scope change, term extension, party addition/removal, insurance requirement change), detailed description of changes with before/after values, effective date, expiration of prior terms, approval chain with legal and finance sign-off, and execution status via DocuSign CLM. Maintains a complete amendment audit trail for any parent contract document, enabling full contract version history reconstruction. Critical for staffing firms managing hundreds of active client and vendor contracts with frequent rate and scope changes.' .

ind:Renewal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Renewal' ;
    rdfs:comment 'Contract renewal, expiry, and critical date lifecycle record tracking upcoming renewal events, expiration milestones, and proactive date management for MSAs, SOWs, and vendor agreements. Stores renewal type (auto-renewal, manual renewal, evergreen, one-time), renewal trigger date, notice deadline, opt-out deadline, renewal term length, renewed rate schedule reference, negotiation status, and outcome (renewed, renegotiated, lapsed, terminated). Tracks all critical contract dates requiring proactive action — including auto-renewal opt-out deadlines, insurance certificate renewal dates, rate schedule review dates, and compliance filing deadlines — with alert type, trigger date, lead-time days, assigned owner, acknowledgment status, and resolution action taken. Enables proactive renewal pipeline management, prevents costly contract lapses or unwanted auto-renewals, and drives critical date alerting across the entire contract portfolio.' .

ind:Template rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Template' ;
    rdfs:comment 'Contract template and clause library master record defining the standard structure, default clauses, configurable parameters, and complete reusable clause inventory for each contract type (MSA, SOW, NDA, non-compete, amendment, IC agreement, vendor agreement). Stores template name, version, applicable contract type, default jurisdiction, required clause set, optional clause menu, and approval status. Includes the full clause library: standard and custom clause text for all clause types (indemnification, limitation of liability, IP ownership, co-employment, EEOC, OFCCP, FLSA, workers comp, governing law, data privacy, non-solicitation), clause version, jurisdiction applicability, mandatory vs. optional flag, regulatory source reference, and clause approval status. Used by DocuSign CLM to generate new contract drafts consistently while enabling clause-level compliance tracking, template governance, and regulatory clause audit. SSOT for all contract generation configuration and reusable clause management.' .

ind:VendorAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Vendor Agreement' ;
    rdfs:comment 'Vendor/subcontractor agreement governing the commercial relationship with third-party staffing suppliers, subvendors, independent contractor firms, and service providers within MSP/VMS-managed programs. Captures agreement type (subvendor staffing agreement, IC firm agreement, EOR/Employer of Record agreement, PEO agreement, RPO subcontract), tier classification (Tier 1/2/3), markup caps and fee schedules, payment terms (net-30/45/60), insurance requirements (GL, WC, E&O minimums), diversity certification status (MBE, WBE, SDVOB), and compliance obligations (E-Verify, background check standards, drug screening requirements). Distinct from client-facing MSAs — this is the supply-side commercial contract governing the staffing supply chain. Note: vendor identity and profile data is owned by the vendor domain; this product owns the commercial agreement terms only.' .

ind:IcAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Ic Agreement' ;
    rdfs:comment 'Independent Contractor (1099/IC) agreement record governing the engagement of independent contractors. Captures IC classification basis (IRS worker classification rules, ABC test, economic realities test), contract type (project-based, retainer), scope of services, payment terms, IP assignment, non-solicitation terms, and IRS Form 1099 reporting flag. Critical for co-employment risk management and IRS compliance.' .

ind:Document rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Document' ;
    rdfs:comment 'Physical or digital contract document record representing a specific executed or draft document file associated with any contract type (MSA, SOW, NDA, amendment, IC agreement). Stores document name, file format, version number, storage location (DocuSign CLM vault reference), document status (draft, pending signature, fully executed, superseded), and retention policy classification per FCRA, GDPR, and CCPA requirements.' .

ind:OnboardingEngagement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recruitment ;
    rdfs:label 'Onboarding Engagement' ;
    rdfs:comment 'Master record for a single worker onboarding engagement tied to a placement or assignment. Tracks onboarding status, start date, target ready-for-assignment date, onboarding type (temp, perm, contract-to-hire, redeployment), assigned coordinator, and completion milestones. SSOT for onboarding status across the staffing lifecycle. One record per worker per placement. Central hub entity — all onboarding activities (tasks, documents, screenings, I-9, orientation, training, equipment, communications) link back to this record.' .

ind:OffboardingRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Timesheet ;
    rdfs:label 'Offboarding Record' ;
    rdfs:comment 'Master record for a workers assignment-end and separation workflow. Captures offboarding type (assignment end, voluntary resignation, client termination, conversion to perm, redeployment), coordinator assignment, equipment return tracking references, final timesheet reconciliation status, rehire eligibility determination, exit interview status, COBRA notification flag, and last day worked. One record per assignment end event. Links to redeployment_candidate when the worker is flagged for bench management.' .

ind:TaskChecklist rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payroll ;
    rdfs:label 'Task Checklist' ;
    rdfs:comment 'Reusable template defining a named collection of required onboarding or offboarding tasks for a specific scenario (e.g., temp healthcare onboarding, IT contractor onboarding, light industrial assignment end). Includes applicable placement type, division, client-specific flag, version number, effective date, and active status. Task_assignment records are instantiated from these templates for each worker engagement. Driven by requirement_rule configuration.' .

ind:TaskAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recruitment ;
    rdfs:label 'Task Assignment' ;
    rdfs:comment 'Individual onboarding or offboarding task assigned to a specific worker within their onboarding_record or offboarding_record. Tracks task category (document collection, orientation, training, equipment, compliance, credentialing), responsible party (worker, recruiter, coordinator, client), due date, completion status, and blocking dependencies. Instantiated from task_checklist templates.' .

ind:TaxFormSubmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Joborder ;
    rdfs:label 'Tax Form Submission' ;
    rdfs:comment 'Records worker tax form submissions collected during onboarding. Covers W-4 (federal withholding), state withholding equivalents, W-9 (independent contractor), and 1099 setup forms. Tracks form type, tax year, filing status, allowances or exemptions claimed, additional withholding amount, submission date, effective date, and whether the form supersedes a prior submission. Feeds payroll tax configuration in TempWorks Payroll.' .

ind:DirectDepositSetup rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Timesheet ;
    rdfs:label 'Direct Deposit Setup' ;
    rdfs:comment 'Captures worker direct deposit banking instructions collected during onboarding. Tracks bank name, routing number (masked), account number (masked/tokenized), account type (checking, savings), allocation type (full amount, fixed amount, percentage), allocation value, priority sequence (for split deposits), effective date, and verification status (prenote sent, prenote cleared, active, rejected). Supports split-deposit configurations with multiple records per worker. Feeds TempWorks Payroll for pay distribution.' .

ind:DocumentCollection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payroll ;
    rdfs:label 'Document Collection' ;
    rdfs:comment 'Tracks each document collected, signed, or acknowledged during the onboarding or offboarding process. Covers document type (MSA acknowledgment, NDA, non-compete, handbook acknowledgment, safety policy, drug screen consent, BGC authorization, FCRA disclosure, offer letter, assignment confirmation, W-4, state withholding, W-9, 1099 setup), document source system (DocuSign CLM, SAP SuccessFactors, TempWorks, manual upload), DocuSign envelope ID, signed date, expiration date, storage location reference, document status, and tax-form-specific fields (tax year, filing status, allowances or exemptions claimed, additional withholding amount, effective date, supersedes prior flag, form submission date). Consolidates all onboarding document types including tax form submissions into a single collection entity differentiated by document_type. Feeds payroll tax configuration in TempWorks Payroll for tax form document types (W-4, state withholding, W-9, 1099).' .

ind:OrientationSession rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Candidate ;
    rdfs:label 'Orientation Session' ;
    rdfs:comment 'Scheduled or completed orientation session for one or more workers. Tracks orientation type (in-person, virtual, client-site, self-paced), session date, location or virtual link, facilitator, duration, topics covered, and per-worker attendance status. May be staffing-agency-led or client-led. Linked to onboarding_record for milestone completion tracking.' .

ind:StatusEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recruitment ;
    rdfs:label 'Status Event' ;
    rdfs:comment 'Immutable event log capturing every status transition, communication, and milestone event in the onboarding or offboarding lifecycle for a worker. Records event type (status_change, outbound_email, outbound_sms, inbound_response, portal_notification, task_reminder, document_request, welcome_message, orientation_invite, bgc_status_update, offer_letter_delivery, phone_call), prior status, new status, transition timestamp, triggering actor (system, recruiter, coordinator, worker), trigger source (task completion, document signing, BGC clearance, LMS completion, manual override), communication channel (email, SMS, portal, phone), delivery status, worker response flag, linked task or document reference, and notes. Consolidates all onboarding timeline events including outbound/inbound communications into a single unified event stream. Provides the single onboarding timeline for audit trail, SLA measurement (TTF, TTS), coordinator engagement tracking, and communication history.' .

ind:Profile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Candidate ;
    rdfs:label 'Profile' ;
    rdfs:comment 'SSOT master record for every talent supply-side individual tracked in the ATS. Stores core identity: legal name, preferred name, date of birth, gender, pronouns, contact details (email, phone, address), SSN (masked), LinkedIn URL, portfolio URL, candidate type (W-2, 1099, EOR), current employment status, ATS record ID, source system, data classification level, GDPR/CCPA consent flags, do-not-contact flag, and audit timestamps. Captures sourcing attribution: source channel type (job board, referral, social media, direct outreach, RPO campaign, VMS portal, career site, walk-in), source channel name, campaign ID, sourcing recruiter, sourcing date, cost-per-source, UTM parameters, and attribution model (first-touch, last-touch, multi-touch). Anchor entity for the entire candidate domain — all child entities resolve to this record via profile_id FK.' .

ind:Resume rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Candidate ;
    rdfs:label 'Resume' ;
    rdfs:comment 'Stores parsed and raw resume content for each candidate version. Tracks resume version number, file format (PDF, DOCX), raw text blob, parsed structured content (skills extracted, titles extracted, education extracted), parsing engine used (e.g., Sovren, Textkernel), parse confidence score, upload source (portal, recruiter upload, email parse), upload timestamp, active version flag, and storage URI. Supports ATS resume search and talent pool matching workflows in Bullhorn.' .

ind:WorkHistory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Candidate ;
    rdfs:label 'Work History' ;
    rdfs:comment 'Structured employment history records for each candidate, capturing prior employer name, job title held, employment type (FTE, contract, temp, self-employed), start date, end date, is_current flag, industry sector, responsibilities summary, reason for leaving, verified flag, verification source, and gap indicator. Sourced from resume parsing and candidate-submitted data in Bullhorn. Used for tenure analysis, skill inference, and placement suitability scoring.' .

ind:Skill rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Candidate ;
    rdfs:label 'Skill' ;
    rdfs:comment 'Canonical skill inventory record for a candidate, representing a single skill or competency attributed to the individual. Captures skill name (normalized to a controlled taxonomy where available), skill category (technical, soft skill, domain expertise, language, tool/platform), proficiency level (beginner, intermediate, advanced, expert), years of experience with the skill, last used date, skill source (self-reported, resume parsed, assessment verified, recruiter tagged), endorsement count, and is_primary flag indicating the candidates top marketable skills. Supports talent pool search, job order matching via skill-to-requirement mapping, and QoS (Quality of Submission) scoring workflows in Bullhorn. Skills may be linked to specific work_history entries or assessment results for provenance.' .

ind:Availability rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Candidate ;
    rdfs:label 'Availability' ;
    rdfs:comment 'Tracks a candidates current and future availability for placement along with stated job search and placement preferences. Availability attributes: status (available, on assignment, bench, unavailable), available start date, preferred shift, preferred hours per week (min/max), preferred work arrangement (on-site, remote, hybrid), geographic availability (city, state, radius), willing to relocate flag, willing to travel flag, travel percentage max. Preference attributes: preferred job titles, preferred industries, preferred employment type (temp, contract-to-hire, direct placement, FTE), desired pay rate (min/max), desired bill rate awareness flag, preferred locations, preferred company size, preferred work culture attributes, open to temp-to-perm flag, open to per diem flag, preference last updated date. Critical for bench tracking, redeployment, dispatch workflows, and proactive sourcing outreach.' .

ind:StatusHistory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Candidate ;
    rdfs:label 'Status History' ;
    rdfs:comment 'Immutable audit log of all candidate lifecycle status transitions within the ATS workflow. Captures prior status, new status, transition reason code, transition trigger (system, recruiter, candidate, client), recruiter ID who made the change, associated job order ID (if applicable), transition timestamp, and notes. Status values include: new lead, in-progress, submitted, interviewed, placed, on assignment, bench, redeployed, inactive, do-not-place, fall-off. For do-not-place (DNP) transitions, additionally captures DNP scope (client-specific, program-specific, global), DNP reason code, DNP initiator, DNP expiration date, and review-required flag. Supports fall-off rate tracking, pipeline velocity, compliance audit trails, and DNP enforcement workflows.' .

ind:Interaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Candidate ;
    rdfs:label 'Interaction' ;
    rdfs:comment 'Records all recruiter-to-candidate and system-to-candidate interaction events throughout the candidate lifecycle. Captures interaction type (call, email, SMS, in-person meeting, video interview, portal message), interaction direction (inbound, outbound), interaction channel, interaction subject/summary, recruiter ID, interaction timestamp, response received flag, response timestamp, sentiment tag (positive, neutral, negative), and linked job order ID if applicable. Supports NPS tracking, candidate experience measurement, recruiter activity KPI reporting, and SLA compliance monitoring in Bullhorn CRM. This is the transactional activity log for candidate communications — distinct from status_history which tracks lifecycle state changes.' .

ind:Assessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Candidate ;
    rdfs:label 'Assessment' ;
    rdfs:comment 'Stores results of formal candidate assessments and screening evaluations administered during the recruitment process. Captures assessment type (skills test, behavioral assessment, cognitive test, technical screen, video interview score, drug screen result, reference check score), assessment provider (HireVue, Codility, Wonderlic, etc.), assessment date, raw score, normalized score, pass/fail result, assessor ID (if human), assessment version, expiration date, and linked job order ID if assessment was req-specific. Supports QoS and candidate ranking workflows.' .

ind:Education rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Candidate ;
    rdfs:label 'Education' ;
    rdfs:comment 'Structured education history for each candidate, capturing institution name, institution type (university, community college, trade school, bootcamp, online platform), degree type (high school diploma, associate, bachelor, master, doctorate, certificate, bootcamp certificate), field of study, major, minor, graduation date, GPA (if provided), is_highest_degree flag, verified flag, and verification source. Sourced from resume parsing and candidate-submitted data. Used for qualification matching on job orders requiring specific educational credentials.' .

ind:PayRateAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Candidate ;
    rdfs:label 'Pay Rate Agreement' ;
    rdfs:comment 'Records the negotiated or agreed pay rate terms between the staffing firm and the candidate for a specific engagement context. Captures pay rate type (hourly, daily, weekly, salary), base pay rate, OT (overtime) rate, DT (double time) rate, per diem rate, currency, effective date, expiration date, pay rate basis (W-2, 1099, EOR), burden rate applied, negotiated by recruiter ID, and approval status. Distinct from the billing-side bill rate — this is the candidate-facing pay agreement. Supports payroll processing handoff to TempWorks.' .

ind:RightToRepresent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Candidate ;
    rdfs:label 'Right To Represent' ;
    rdfs:comment 'Tracks RTR (Right to Represent) grants issued by candidates authorizing the staffing firm to submit their profile to a specific client or job order. Captures candidate ID, job order ID, client ID, RTR grant method (verbal, email, portal consent, signed form), RTR grant timestamp, RTR expiration date, RTR scope (single req, client-wide, program-wide), revocation flag, revocation timestamp, and revocation reason. Critical for compliance with co-employment rules and preventing unauthorized submittals. Supports OFCCP and EEOC audit readiness.' .

ind:TalentPoolMembership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Candidate ;
    rdfs:label 'Talent Pool Membership' ;
    rdfs:comment 'Association entity tracking which curated talent pools or talent communities a candidate belongs to, including redeployment pool assignments when a candidate is being actively redeployed from an ending assignment' .

ind:TalentPool rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Candidate ;
    rdfs:label 'Talent Pool' ;
    rdfs:comment 'Master reference table for talent_pool. Referenced by talent_pool_id.' .

ind:ClientAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Client Account' ;
    rdfs:comment 'Master record for every client (employer) organization that Staffing Hr serves. SSOT for client company identity, classification, and billing configuration. Sourced from Bullhorn ATS/CRM and Salesforce Revenue Cloud. Captures legal entity name, DBA name, DUNS number, FEIN, industry classification (NAICS/SIC), company size tier, client type (direct, VMS/MSP, RPO), account status (prospect, active, inactive, on-hold, terminated), primary business address, website, and CRM account owner. Also owns billing preferences: invoice delivery method, invoice frequency, invoice grouping rules (by location, department, cost center, or consolidated), PO number requirements, payment method (ACH, check, wire), billing contact, and preferred payment portal. Demand-side anchor entity for all job orders, placements, billing, and commercial relationships.' .

ind:ClientContact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Client Contact' ;
    rdfs:comment 'Individual person record at a client organization who interacts with Staffing Hr in a business capacity. Sourced from Bullhorn CRM and Salesforce. Captures full name, job title, department, direct phone, mobile, business email, contact type (hiring manager, procurement, AP, executive sponsor, VMS coordinator), preferred communication channel, LinkedIn URL, contact status, and opt-in/opt-out flags. Supports CRM engagement tracking and relationship management workflows.' .

ind:AccountHierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Account Hierarchy' ;
    rdfs:comment 'Parent-child organizational relationship between client accounts, enabling enterprise account structures such as global parent, regional subsidiary, and local site. Captures parent account reference, child account reference, hierarchy level, relationship type (corporate parent, division, subsidiary, franchise), effective date, and end date. Critical for consolidated billing, enterprise SLA management, MSP/VMS program roll-ups, and territory planning across account families.' .

ind:Location rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Location' ;
    rdfs:comment 'Physical or virtual work site associated with a client account. Represents the specific facility, office, plant, or remote work designation where workers are deployed. Captures site name, address (street, city, state, zip, country), location type (headquarters, branch, warehouse, remote, on-site), OSHA establishment ID, workers comp jurisdiction state, site contact, parking/badge instructions, and active status. Used for assignment dispatch, workers comp classification, and compliance jurisdiction mapping.' .

ind:ClientRateCard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Client Rate Card' ;
    rdfs:comment 'Negotiated bill rate and markup schedule agreed upon with a client under an MSA or VMS program agreement. Captures job category, job title, skill level, bill rate (regular, OT, DT), pay rate guidance, markup percentage, spread (bill minus pay), burden rate inclusion flag, per diem rate, currency, effective date, expiration date, rate card version, and approval status. Sourced from Beeline VMS and Salesforce Revenue Cloud. Serves as the client-domain pricing reference for job order creation, candidate submittal pricing, and invoice generation. Note: contract-level rate schedule terms, rate escalation clauses, and contractual rate governance are owned by the contract domain; this product owns the operational rate table used in day-to-day staffing transactions.' .

ind:VmsProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Vms Program' ;
    rdfs:comment 'Vendor Management System program record representing a client-managed contingent workforce program administered through a VMS technology platform. Captures program name, VMS platform (Beeline, Fieldglass, Coupa, IQNavigator), MSP partner name (if applicable), program type (MSP-managed, self-managed, hybrid), program scope (all categories, IT only, light industrial, professional, etc.), supplier tier structure, requisition routing rules, markup cap, program start date, program end date, and program status. Sourced from Beeline VMS integration. Critical for staffing firms participating in managed programs where requisition flow, rate caps, and supplier tiering are controlled by the client or their MSP.' .

ind:Engagement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Engagement' ;
    rdfs:comment 'CRM engagement activity record capturing all touchpoints and interactions between Staffing Hr staff and client contacts. Sourced from Bullhorn CRM and Salesforce. Captures engagement type (call, email, meeting, site visit, QBR, proposal presentation, NPS survey), engagement date and time, duration, subject, outcome, next action, assigned recruiter or account manager, and engagement channel. Supports relationship health monitoring, account management cadence tracking, and pipeline development.' .

ind:AccountSegment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Account Segment' ;
    rdfs:comment 'Commercial segmentation and classification record for a client account, defining strategic tier, revenue potential, and service model. Captures segment tier (strategic, key, growth, transactional), vertical industry focus, geographic market, annual revenue band, headcount band, estimated annual staffing spend, wallet share estimate, primary service line (temp staffing, direct hire, RPO, MSP), account manager assignment, and segment review date. Used for territory planning, resource allocation, and go-to-market prioritization.' .

ind:ProgramSupplier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Program Supplier' ;
    rdfs:comment 'Association record linking a staffing supplier (vendor) to a specific VMS program, capturing the suppliers participation terms and performance within a client-managed contingent workforce program. Captures supplier tier (preferred, approved, backup), category authorization (which job categories the supplier can fill), markup cap for this supplier within the program, submission limit per requisition, performance score, program enrollment date, certification/compliance status within the program, and supplier status (active, suspended, removed). Sourced from Beeline VMS. Note: supplier/vendor identity and master data are owned by the vendor domain; this product owns only the program-specific participation terms, tier assignments, and performance metrics within the clients program context.' .

ind:SlaMeasurement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Sla Measurement' ;
    rdfs:comment 'Periodic performance measurement record capturing actual results against a defined SLA configuration for a specific reporting window. Captures measurement period (start/end date), SLA config reference, measured value, target value, variance, compliance flag (met/missed), requisition count in scope, fill count, TTF (Time to Fill) actual average, TTS (Time to Start) actual average, QoS (Quality of Submission) actual rate, fill rate actual, and measurement source system. Generated from operational data in the recruitment and placement domains. Enables SLA compliance reporting, client QBR (Quarterly Business Review) preparation, penalty/bonus calculation triggers, and account health scoring.' .

ind:CreditProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Credit Profile' ;
    rdfs:comment 'Client credit and financial risk assessment record used to evaluate and monitor a clients creditworthiness and ability to pay invoices on agreed terms. Captures credit score (D&B PAYDEX, internal composite score), credit limit, approved payment terms (net days), credit hold flag, credit hold reason, last credit review date, next scheduled review date, DSO (Days Sales Outstanding) actual, aging bucket summary (current, 30, 60, 90+ days), bank reference, trade references, credit decision (approved, conditional, declined), decision date, approving authority, and risk tier (low, medium, high, watch). Sourced from D&B Direct, internal AR aging reports, and credit committee decisions. Critical for staffing firms managing significant accounts receivable exposure — supports go/no-go decisions on new business, headcount expansion approvals, and credit hold enforcement during invoice generation.' .

ind:ManagedProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Managed Program' ;
    rdfs:comment 'Master record for a managed workforce program — RPO, MSP, or hybrid — operated on behalf of a client, capturing program scope, governance model, and SLA framework' .

ind:RateCardLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Rate Card Line' ;
    rdfs:comment 'This association product represents the pricing line items within a client rate card, linking negotiated rates to specific job categories. Each record captures the bill rates, pay guidance, markup, and effective dates that apply when a specific job category is priced under a specific client rate card. This is the operational pricing matrix used daily in job order creation, candidate submittal pricing, and invoice generation.. Existence Justification: In staffing operations, a single rate card negotiated with a client contains pricing for multiple job categories (e.g., Software Engineer, Project Manager, Business Analyst), and each job category appears across multiple client rate cards with different negotiated rates. The rate card is a pricing matrix, not a single-category document. Recruiters and account managers actively manage these rate card lines when creating job orders, pricing candidate submittals, and generating invoices.' .

ind:SourcingCampaign rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recruitment ;
    rdfs:label 'Sourcing Campaign' ;
    rdfs:comment 'Master record for talent sourcing campaigns initiated to fill job orders. Captures campaign name, type (job board, social media, referral, RPO, MSP), target skill sets, geographic scope, budget, start/end dates, channel mix, campaign owner, associated requisition targets, and campaign status. Supports sourcing strategy planning and channel effectiveness analysis.' .

ind:JobPosting rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recruitment ;
    rdfs:label 'Job Posting' ;
    rdfs:comment 'Represents a published job advertisement derived from a job order requisition. Tracks posting title, description, required skills, location, employment type (temp, contract-to-hire, direct placement), pay range, bill rate range, posting channel (job board, career site, VMS, social), posting date, expiration date, posting status (active, paused, closed, filled), and ATS reference from Bullhorn. Supports multi-channel job distribution and posting lifecycle management.' .

ind:Submittal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recruitment ;
    rdfs:label 'Submittal' ;
    rdfs:comment 'Core transactional record representing a candidate submittal (submission) to a client for a specific job order. Captures submittal date, submitting recruiter, candidate profile reference, job order reference, client contact submitted to, submittal status (submitted, viewed, shortlisted, rejected, interview requested), right-to-represent (RTR) flag, RTR date, QoS (Quality of Submission) rating, pay rate proposed, bill rate proposed, and Bullhorn ATS submittal ID. Central entity for tracking recruiter activity and submittal-to-hire conversion ratios.' .

ind:RtrAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recruitment ;
    rdfs:label 'Rtr Agreement' ;
    rdfs:comment 'Tracks Right-to-Represent (RTR) agreements between a staffing firm and a candidate for a specific client or job order. Records RTR grant date, expiration date, RTR status (pending, granted, expired, revoked), candidate acknowledgment method (email, portal, verbal), exclusivity flag, and any RTR conflicts with competing agencies. Ensures legal protection of candidate representation rights and prevents co-representation disputes.' .

ind:Interview rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recruitment ;
    rdfs:label 'Interview' ;
    rdfs:comment 'Represents a client interview event for a submitted candidate, covering the full interview lifecycle from scheduling through feedback collection and hiring recommendation. Captures interview date/time, type (phone screen, video, onsite, panel), format, client interviewer names, candidate confirmation status, coordinator, location or video link, reschedule/cancellation tracking, overall rating, individual competency ratings, hire recommendation (yes/no/maybe), detailed feedback notes, feedback submission date, decision outcome (advance, reject, hold), and rejection reason code. Central to interview coordination workflows, scheduling efficiency metrics, QoS scoring, and submittal-to-hire ratio analytics. Single source of truth for all interview scheduling and feedback data.' .

ind:InterviewFeedback rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recruitment ;
    rdfs:label 'Interview Feedback' ;
    rdfs:comment 'Captures client feedback and evaluation results following a candidate interview. Records overall rating, individual competency ratings, hire recommendation (yes/no/maybe), feedback notes, feedback submission date, interviewer name, decision outcome (advance, reject, hold), and rejection reason code. Feeds into QoS scoring and submittal-to-hire ratio analytics.' .

ind:HiringDecision rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recruitment ;
    rdfs:label 'Hiring Decision' ;
    rdfs:comment 'Records the final hiring decision made by the client for a candidate submittal. Captures decision date, decision type (hired, rejected, on-hold, backfill), decision maker (client contact), rejection reason category, rejection reason detail, time-to-fill (TTF) calculated value in days, time-to-start (TTS) calculated value in days, and whether the hire resulted from a temp-to-perm conversion. Links the recruitment lifecycle to placement initiation.' .

ind:ReqPipeline rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recruitment ;
    rdfs:label 'Req Pipeline' ;
    rdfs:comment 'Real-time snapshot of candidate progression through recruitment stages for a specific job order or requisition. Tracks pipeline stage (sourced, screened, submitted, interviewing, offered, hired, rejected, withdrawn), stage entry/exit timestamps, stage duration in business days, candidate counts per stage, and pipeline health indicators including stage conversion rates, aging alerts, and bottleneck flags. Primary tool for recruiter workload management, hiring manager visibility dashboards, VMS scorecard reporting, and time-to-fill forecasting in RPO and MSP delivery models. Refreshed on each stage transition event to maintain current-state accuracy.' .

ind:CandidateScreening rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recruitment ;
    rdfs:label 'Candidate Screening' ;
    rdfs:comment 'Records the results of candidate screening activities performed during the recruitment process. Captures screening type (phone screen, skills assessment, behavioral interview, technical test), screening date, screener name, screening outcome (pass, fail, conditional), scoring details, notes, disqualification reason, and whether the candidate was advanced to submittal. Distinct from credentialing (BGC, drug screen) which is owned by the credentialing domain.' .

ind:RecruiterAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recruitment ;
    rdfs:label 'Recruiter Assignment' ;
    rdfs:comment 'Defines recruiter ownership and accountability for filling a specific job order or requisition. Tracks assigned recruiter, assignment date, type (primary, backup, split-desk, RPO team, MSP coordinator), status (active, reassigned, closed), reassignment reason, target submittal count, and performance against target. Supports workload balancing across desks, recruiter performance tracking, split-fee arrangements, and RPO/MSP delivery team management.' .

ind:Referral rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recruitment ;
    rdfs:label 'Referral' ;
    rdfs:comment 'Tracks candidate referrals from employees, placed workers, or external sources, capturing referrer identity, referred candidate, referral date, and referral bonus eligibility' .

ind:OrderHeader rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Joborder ;
    rdfs:label 'Order Header' ;
    rdfs:comment 'Core master entity representing a client requisition (req) — the authoritative job order header record and central hub of the joborder domain. Captures the full lifecycle of a client demand request from intake through closure. Stores requisition number, job title, position type (temp, contract-to-hire, direct placement, SOW), employment classification (W-2, 1099, C2C), headcount target (total positions authorized, positions filled, positions remaining), backfill indicator, priority level, order status (open, filled, cancelled, on-hold, closed), intake date, target start date, assignment end date, and originating source (VMS, CRM, direct). Central hub connecting client demand to candidate supply in the ATS/CRM. All other joborder products reference this entity via req_id.' .

ind:PositionRequirement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Joborder ;
    rdfs:label 'Position Requirement' ;
    rdfs:comment 'Defines the detailed position specifications attached to a requisition. Captures job description, required education level, years of experience, work location type (on-site, remote, hybrid), shift type, travel requirements, physical demands, security clearance level, drug screen requirement, background check requirement, and any client-specific screening criteria. Represents the structured demand profile that drives candidate matching and submittal qualification.' .

ind:SkillRequirement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Joborder ;
    rdfs:label 'Skill Requirement' ;
    rdfs:comment 'Captures the individual skill, competency, and technology requirements associated with a requisition. Stores skill name, skill category (technical, soft, industry-specific), proficiency level required (beginner, intermediate, expert), whether the skill is mandatory or preferred, years of experience required for the skill, and certification requirement flag. Enables structured skill-based candidate matching and QoS (Quality of Submission) scoring within the ATS.' .

ind:RateOverride rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Joborder ;
    rdfs:label 'Rate Override' ;
    rdfs:comment 'Stores the approved bill rate, pay rate, markup percentage, spread (bill rate minus pay rate), burden rate, and gross margin targets for a requisition. Captures OT (overtime) bill rate, DT (double time) bill rate, per diem allowance, and any client-negotiated rate caps or floors. Tracks rate effective dates, rate approval status, and the rate source (MSA rate schedule, VMS rate card, negotiated). Serves as the financial backbone of the job order connecting to billing and payroll domains.' .

ind:SlaCommitment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Joborder ;
    rdfs:label 'Sla Commitment' ;
    rdfs:comment 'Defines the SLA (Service Level Agreement) commitments and submittal governance rules attached to a requisition or client program. Captures TTF (Time to Fill) target in business days, TTS (Time to Start) target, submittal SLA (hours to first submittal), minimum submittals required per req, maximum submittals per vendor (VMS programs), submittal window open/close dates, exclusive submittal period flag, RTR (Right to Represent) enforcement flag, duplicate submittal prevention rules, interview-to-offer ratio target, fill rate target, and penalty terms for SLA breach. Tracks SLA tier (standard, premium, VMS-managed), SLA status (on-track, at-risk, breached), and measurement methodology. Enables operational SLA monitoring, QoS (Quality of Submission) governance, VMS program compliance, and client reporting.' .

ind:OrderStatusHistory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Joborder ;
    rdfs:label 'Order Status History' ;
    rdfs:comment 'Authoritative lifecycle event log for a job order, capturing every status transition and fulfillment milestone from intake through closure. Records event type (status change, milestone reached), previous status, new status, milestone type (req received, sourcing started, first submittal, interview scheduled, offer extended, placement confirmed, worker started, assignment ended), transition timestamp, target date, actual completion date, variance in business days, reason code, triggering user or system, responsible recruiter, and associated notes. Single source of truth for TTF (Time to Fill) and TTS (Time to Start) measurement, SLA breach analysis, recruiter performance benchmarking, and operational reporting. Subsumes all milestone tracking — no separate milestone entity exists.' .

ind:FulfillmentTeam rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Joborder ;
    rdfs:label 'Fulfillment Team' ;
    rdfs:comment 'Association entity linking a requisition to the internal recruiter(s), account manager(s), and sourcing team responsible for fulfillment. Captures assigned recruiter, assignment role (lead recruiter, sourcing specialist, account manager, coordinator), assignment start date, assignment end date, assignment status (active, reassigned, closed), and workload weight for split-credit scenarios. Enables recruiter workload management, performance attribution, and commission split tracking.' .

ind:VmsOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Joborder ;
    rdfs:label 'Vms Order' ;
    rdfs:comment 'Captures VMS (Vendor Management System)-specific metadata for requisitions managed through platforms such as Beeline, Fieldglass, or Wand. Stores VMS requisition ID, VMS program name, MSP (Managed Service Provider) name, vendor tier eligibility, submission window timestamps, max submittal count per vendor, VMS rate caps, markup caps, RTR (Right to Represent) requirement flag, VMS order status, and cross-reference mapping to internal ATS req ID. Essential for MSP/VMS program compliance, automated req import reconciliation, and dual-system synchronization between the VMS platform and internal ATS.' .

ind:OrderLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Joborder ;
    rdfs:label 'Order Location' ;
    rdfs:comment 'Defines the work location details for a requisition, supporting multi-site deployments where a single req may have workers at multiple client facilities. Captures site name, street address, city, state, zip code, country, location type (client site, remote, hybrid, field), work site safety classification (OSHA category), and location-specific requirements (parking, badge access, union jurisdiction, prevailing wage applicability, per diem eligibility). References client domain for master site data via FK; stores req-specific overrides and work-condition details that affect candidate matching, compliance determination, payroll tax jurisdiction (SUTA state, local tax), and workers compensation classification.' .

ind:OrderExtension rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Joborder ;
    rdfs:label 'Order Extension' ;
    rdfs:comment 'Tracks assignment extension events for temporary and contract requisitions — one of the most common operational transactions in staffing. Captures extension request date, extension approved date, extension start date, new end date, extension duration in weeks, extended bill rate, extended pay rate, rate change indicator, extension reason (client request, project continuation, backfill pending, budget renewal), extension approval status, approving authority, and whether the extension triggers a temp-to-perm conversion clock reset or benefits eligibility change. Enables extension lifecycle management, revenue forecasting for ongoing assignments, and client billing adjustments for rate changes on extension.' .

ind:JobCategory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Joborder ;
    rdfs:label 'Job Category' ;
    rdfs:comment 'Reference entity defining standardized job categories, job families, and occupational classifications (SOC codes, O*NET) used to classify requisitions and match candidates' .

ind:HeadcountPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Joborder ;
    rdfs:label 'Headcount Plan' ;
    rdfs:comment 'Strategic headcount planning master record capturing FTE targets, headcount budgets, and workforce mix ratios for client programs and job categories' .

ind:Assignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Placement ;
    rdfs:label 'Assignment' ;
    rdfs:comment 'Core master record for every temporary, contract, contract-to-hire, and temp-to-perm worker assignment. Serves as the SSOT for active worker assignment status, connecting a candidate to a job order at a specific client work location. Tracks assignment type (temp, CTH, temp-to-perm), start date, scheduled end date, actual end date, assignment status (active, ended, extended, converted, cancelled), supervisor name, work location, bill rate, pay rate, spread, markup percentage, FLSA classification, workers comp code, cost center, PO number, and redeployment eligibility flag. Primary operational entity of the placement domain and the backbone of the Bullhorn ATS placement record.' .

ind:DirectHire rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Placement ;
    rdfs:label 'Direct Hire' ;
    rdfs:comment 'Master record for permanent placement and direct hire engagements where a candidate is placed full-time with a client. Distinct from temporary assignment lifecycle — tracks offer date, accepted date, start date, base salary, conversion fee amount, fee percentage, fee payment terms, guarantee period (fall-off window), fall-off date if applicable, replacement obligation flag, and placement status (offered, accepted, started, fell-off, replaced). Owned by the placement domain as the SSOT for permanent placement outcomes. Sourced from Bullhorn permanent placement module.' .

ind:AssignmentExtension rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Placement ;
    rdfs:label 'Assignment Extension' ;
    rdfs:comment 'Transactional record capturing each extension event on a temporary or contract assignment. Tracks the prior end date, new end date, extension reason, extension request date, approver, revised bill rate (if renegotiated), revised pay rate, extension sequence number, and extension status (pending, approved, rejected, executed). Enables fall-off rate monitoring and redeployment planning by providing a complete extension history per assignment. Sourced from Bullhorn assignment extension workflow.' .

ind:Conversion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Placement ;
    rdfs:label 'Conversion' ;
    rdfs:comment 'Transactional record capturing the temp-to-perm or contract-to-hire conversion event when a temporary worker transitions to a permanent employee of the client. Tracks conversion date, conversion type (temp-to-perm, CTH), original assignment reference, conversion fee amount, fee waiver flag, fee waiver reason, conversion notice date, client confirmation date, and conversion status (pending, confirmed, invoiced, fell-off). Critical for billing the conversion fee and monitoring conversion rate KPIs. Sourced from Bullhorn placement conversion workflow.' .

ind:AssignmentStatusHistory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Placement ;
    rdfs:label 'Assignment Status History' ;
    rdfs:comment 'Audit trail of all status transitions for a worker assignment throughout its lifecycle (e.g., offered → confirmed → active → extended → ended, or active → cancelled). Captures prior status, new status, transition timestamp, changed-by user, change reason code, and any associated notes. Enables SLA compliance tracking (TTF, TTS), fall-off rate analysis, and regulatory audit requirements. Supports Bullhorn status change event log.' .

ind:Redeployment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Placement ;
    rdfs:label 'Redeployment' ;
    rdfs:comment 'Tracks redeployment events and pipeline management for workers coming off active assignments (bench management). Records the ending assignment reference, redeployment target date, redeployment status (bench, in-process, redeployed, separated), candidate availability date, preferred work type, preferred location, redeployment coordinator, days on bench, and outcome (redeployed to new assignment, converted, separated). Enables proactive bench management and reduces time-to-redeploy KPI. Sourced from Bullhorn redeployment workflow.' .

ind:Rate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Placement ;
    rdfs:label 'Rate' ;
    rdfs:comment 'Master record for all negotiated rate components associated with a specific assignment or direct hire placement. Each rate record represents a single rate type — standard bill/pay rate, overtime (OT), double-time (DT), holiday, per diem (travel, lodging, meals, incidentals), or burden rate. Tracks effective date, expiration date, rate type, bill rate amount, pay rate amount, spread amount, markup percentage, gross margin percentage, burden rate, workers comp rate, IRS GSA rate reference (for per diem), taxable flag, reimbursement method, per diem daily allowance, per diem budget cap, rate approval status, and rate card source. Serves as the SSOT for all placement-level rate and per diem data feeding payroll and billing domains. Per diem rate types include travel, lodging, meals, and incidentals with IRS GSA compliance tracking. Sourced from Bullhorn rate card, Beeline VMS rate management, and TempWorks Payroll per diem configuration.' .

ind:WorkLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Placement ;
    rdfs:label 'Work Location' ;
    rdfs:comment 'Master record for physical or virtual work locations where placed workers perform their assignments, including dispatch and scheduling locations. Tracks location name, address, client site details, remote/hybrid designation, and capacity planning attributes.' .

ind:Supervisor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Placement ;
    rdfs:label 'Supervisor' ;
    rdfs:comment 'Master record for the client-side supervisor or hiring manager who directly oversees placed workers at a work location. Tracks supervisor full name, title, email, phone, client company reference, work location reference, supervisor type (direct manager, site supervisor, project lead), timesheet approval authority flag, onboarding contact flag, and active status. This is the operational assignment supervision relationship — distinct from the client contact master in the client domain. Used for timesheet routing, performance escalation, day-one onboarding coordination, and assignment check-in scheduling. Sourced from Bullhorn contact and assignment supervisor fields.' .

ind:FallOff rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Placement ;
    rdfs:label 'Fall Off' ;
    rdfs:comment 'Transactional record capturing fall-off events where a placed candidate leaves or is removed from an assignment or direct hire within the guarantee period. Tracks fall-off date, fall-off reason code (candidate quit, client termination, no-show, performance, personal), days-to-fall-off, guarantee period days, replacement obligation flag, replacement deadline, replacement status, revenue impact amount, and recruiter accountability reference. Critical for fall-off rate KPI monitoring and client SLA compliance. Sourced from Bullhorn placement fall-off workflow.' .

ind:SowEngagement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Placement ;
    rdfs:label 'Sow Engagement' ;
    rdfs:comment 'Master record for Statement of Work (SOW) based placements where workers are engaged under a defined deliverable-based contract rather than a time-and-materials assignment. Tracks SOW reference number, SOW title, engagement start date, engagement end date, total SOW value, milestone-based billing flag, deliverable descriptions, SOW status (draft, active, completed, terminated), IC classification flag, co-employment risk assessment, and vendor reference for MSP-managed SOW programs. Distinct from the contract domains SOW template — this product tracks the operational placement-level engagement instance, not the commercial agreement terms. Sourced from DocuSign CLM and Beeline VMS SOW module.' .

ind:Offer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Placement ;
    rdfs:label 'Offer' ;
    rdfs:comment 'Transactional record capturing the formal job offer extended to a candidate for a temporary assignment, contract-to-hire, or permanent placement. Tracks offer date, offer type (temp, CTH, perm, SOW), offered bill rate, offered pay rate, offered salary, sign-on bonus, offer expiration date, offer status (pending, accepted, declined, rescinded, expired, counter-offered), decline reason code, counter-offer details, negotiation round count, and offer-to-acceptance cycle time. Serves as the bridge between the recruitment submittal process and the active assignment or direct hire record. Critical for offer acceptance rate KPI, time-to-fill analytics, and compensation benchmarking. Sourced from Bullhorn offer management workflow.' .

ind:AssignmentCompliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Placement ;
    rdfs:label 'Assignment Compliance' ;
    rdfs:comment 'This association product represents the compliance fulfillment relationship between a worker assignment and a regulatory or client-specific compliance requirement. It captures the operational tracking of which requirements must be satisfied for each assignment, the completion status, verification methods, and re-verification schedules. Each record links one assignment to one compliance requirement with attributes that exist only in the context of this specific assignment-requirement pairing, enabling the business to enforce compliance gates, track waivers, and manage re-verification workflows.. Existence Justification: In staffing operations, each worker assignment must satisfy multiple compliance requirements (I-9 employment eligibility, background checks, drug screens, client-specific credentials, industry certifications, training mandates). Simultaneously, each compliance requirement applies to many assignments across different workers, clients, and time periods. The business actively manages the fulfillment status of each assignment-requirement pairing, tracking completion dates, verification methods, waivers, expiration dates, and re-verification schedules as operational data that belongs to neither the assignment nor the requirement alone.' .

ind:Timesheet rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Timesheet ;
    rdfs:label 'Timesheet' ;
    rdfs:comment 'Core master record for a workers timesheet submission covering a defined pay period. Represents the authoritative timesheet header sourced from Kronos Workforce Ready, capturing the worker, assignment, client, pay period dates, submission status, total regular hours, OT hours, DT hours, per diem, approval state, and audit timestamps. This is the SSOT for all billable and payable hours for a given worker-assignment-period combination. Subject to FLSA §516 recordkeeping requirements (minimum 3-year retention of hours worked, wages paid, and conditions of employment). Supports state-specific meal/rest break compliance tracking for California, Washington, Oregon, and other jurisdictions with mandatory break laws.' .

ind:TimeEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Timesheet ;
    rdfs:label 'Time Entry' ;
    rdfs:comment 'Granular daily or shift-level time record representing a single worked period for a contingent worker. This is the unified SSOT for all shift-level and daily worked-time data — there is no separate shift product. Captures the specific date, planned and actual start/end times, break duration, meal break compliance flag, rest break compliance flag, net hours worked, pay type (regular, OT, DT), shift differential code, shift type (day/evening/night/weekend), labor category, cost center, schedule variance (planned vs actual hours delta), and entry source (Kronos clock, mobile, manual). Child record of the timesheet header. Incorporates shift-level schedule comparison, shift differential tracking, and dispatch-relevant shift metadata. Feeds both payroll and billing calculations. Links raw punch events to the timesheet summary. Subject to FLSA §516 and state-specific recordkeeping requirements including California Labor Code §226 (itemized wage statement backing data).' .

ind:ApprovalWorkflow rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Timesheet ;
    rdfs:label 'Approval Workflow' ;
    rdfs:comment 'Tracks the multi-step approval workflow lifecycle for a timesheet submission. Captures each approval stage (worker submission, supervisor review, client approval, back-office audit), the approver identity, approval action (approved, rejected, escalated, auto-approved), action timestamp, rejection reason, and SLA compliance flag. Enables full audit trail of who approved what and when, supporting dispute resolution and compliance requirements.' .

ind:AbsenceRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Timesheet ;
    rdfs:label 'Absence Record' ;
    rdfs:comment 'Records worker absences, PTO usage, sick leave, FMLA leave, holiday observances, jury duty, bereavement, and unexcused absences within a pay period. Captures absence type, absence date range, hours absent, PTO balance consumed, leave reason code, approval status, paid/unpaid indicator, client notification flag, and replacement worker request trigger. Sourced from Kronos Workforce Ready leave management module. Feeds payroll deductions, workforce availability reporting, and client SLA compliance tracking. For contingent workers, unexcused absences may trigger assignment termination workflows. Subject to FMLA recordkeeping requirements (3-year retention) and state-specific paid sick leave laws (e.g., California Healthy Workplaces, Healthy Families Act).' .

ind:Schedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Timesheet ;
    rdfs:label 'Schedule' ;
    rdfs:comment 'Defines the planned work schedule for a contingent worker on a specific assignment, including scheduled shift start/end times, days of week, shift type (day/evening/night/weekend), expected weekly hours, and effective date range. Sourced from Kronos Workforce Ready scheduling module. Serves as the baseline against which actual time entries are compared for variance analysis and OT calculation.' .

ind:Shift rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Timesheet ;
    rdfs:label 'Shift' ;
    rdfs:comment 'Represents a specific scheduled or worked shift instance for a worker, capturing the shift date, planned start/end, actual start/end, shift duration, break time, net hours, shift differential code, and variance from schedule. Distinct from time_entry in that it represents the shift-level aggregation and schedule comparison, while time_entry captures individual punches. Supports scheduling dispatch and labor analytics.' .

ind:OtRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Timesheet ;
    rdfs:label 'Ot Rule' ;
    rdfs:comment 'Reference entity defining overtime and double-time calculation rules applicable to specific clients, states, job categories, or worker classifications. Captures the weekly OT threshold (e.g., 40 hrs/week federal FLSA §207), daily OT threshold (e.g., 8 hrs/day California Labor Code §510), DT threshold (e.g., 12 hrs/day California), seventh-consecutive-day rules, applicable FLSA exemption status, state-specific OT law references, effective date range, and rule priority for conflict resolution. Supports blended OT rate calculation for workers on multiple assignments. Includes prevailing wage OT rules for Davis-Bacon Act compliance on government staffing contracts. Ensures compliant OT/DT classification across all time entries in multi-state staffing operations.' .

ind:PayPeriod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Timesheet ;
    rdfs:label 'Pay Period' ;
    rdfs:comment 'Reference entity defining pay period cycles used across the staffing operation. Captures pay period type (weekly, bi-weekly, semi-monthly, monthly), period start date, period end date, payroll processing cutoff date, check date, fiscal week number, holiday adjustment flag, and active status. Serves as the authoritative calendar for timesheet grouping, payroll runs, and billing cycle alignment. Critical for multi-state operations where different clients may operate on different pay cycles.' .

# --- Attribute Properties ---
ind:approvedHoursSummaryId rdf:type rdf:Property ;
    rdfs:label 'Approved Hours Summary Id' ;
    rdfs:comment 'Primary key for approved_hours_summary' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApprovedHoursSummary .

ind:assignmentId rdf:type rdf:Property ;
    rdfs:label 'Assignment Id' ;
    rdfs:comment 'Reference to the active placement or assignment under which the worker performed the hours captured in this summary. Ties the hours to a specific job order and client engagement.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assignment .

ind:clientAccountId rdf:type rdf:Property ;
    rdfs:label 'Client Account Id' ;
    rdfs:comment 'Reference to the client (end-customer) for whom the worker performed services during this pay period. Used to route billable amounts to the correct client invoice.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientAccount .

ind:contractRateScheduleId rdf:type rdf:Property ;
    rdfs:label 'Contract Rate Schedule Id' ;
    rdfs:comment 'Foreign key linking to contract.contract_rate_schedule. Business justification: Approved hours summaries aggregate billing using rate schedules; invoicing systems pull contracted rates for billing calculations and client invoice generation. Real business process: invoice generati' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractRateSchedule .

ind:directDepositSetupId rdf:type rdf:Property ;
    rdfs:label 'Direct Deposit Setup Id' ;
    rdfs:comment 'Foreign key linking to timesheet.direct_deposit_setup. Business justification: The approved_hours_summary drives worker payment, and the direct_deposit_setup contains the banking instructions for that payment. Linking approved_hours_summary to direct_deposit_setup establishes wh' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DirectDepositSetup .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice. Business justification: Approved hours summaries are the authoritative billable-hours records that drive invoice generation. AR teams reconcile invoices against approved_hours_summary records. A staffing billing analyst expe' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:orderHeaderId rdf:type rdf:Property ;
    rdfs:label 'Order Header Id' ;
    rdfs:comment 'Reference to the job order or requisition (Req) that originated the workers assignment. Enables traceability from approved hours back to the originating staffing request.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderHeader .

ind:payPeriodId rdf:type rdf:Property ;
    rdfs:label 'Pay Period Id' ;
    rdfs:comment 'Reference to the pay period calendar record that defines the start and end dates of the period covered by this approved hours summary.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayPeriod .

ind:profileId rdf:type rdf:Property ;
    rdfs:label 'Profile Id' ;
    rdfs:comment 'Reference to the contingent worker whose approved hours are summarized in this record. Links to the worker master record in the Candidate/Worker domain.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:sowEngagementId rdf:type rdf:Property ;
    rdfs:label 'Sow Engagement Id' ;
    rdfs:comment 'Foreign key linking to placement.sow_engagement. Business justification: Approved hours summaries for SOW workers drive milestone billing and SOW budget consumption reporting. Finance teams require approved_hours_summary→SOW engagement linkage to generate SOW invoices and ' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SowEngagement .

ind:supplierId rdf:type rdf:Property ;
    rdfs:label 'Supplier Id' ;
    rdfs:comment 'Foreign key linking to vendor.supplier. Business justification: Approved hours summaries drive vendor billing and diversity spend reporting. Attributing each summary to the supplying vendor is required for MSP program spend analytics, vendor scorecards, and client' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:timesheetId rdf:type rdf:Property ;
    rdfs:label 'Timesheet Id' ;
    rdfs:comment 'Reference to the source timesheet record from which this approved hours summary was derived. Provides traceability back to the raw time entry data in Kronos Workforce Ready.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timesheet .

ind:wageHourDeterminationId rdf:type rdf:Property ;
    rdfs:label 'Wage Hour Determination Id' ;
    rdfs:comment 'Foreign key linking to compliance.wage_hour_determination. Business justification: Approved hours summaries are the primary payroll and billing output — they must be validated against the governing wage/hour determination (SCA, Davis-Bacon, state prevailing wage) to confirm pay rate' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WageHourDetermination .

ind:amendmentReason rdf:type rdf:Property ;
    rdfs:label 'Amendment Reason' ;
    rdfs:comment 'Free-text description of the reason for any post-approval amendment to this hours summary. Required when is_amended is True. Supports audit trail and dispute resolution.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Current lifecycle state of the approved hours summary record within the timesheet approval workflow. approved indicates hours are cleared for billing and payroll; disputed indicates a client or worker challenge is open; amended indicates a post-approval correction was applied.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'The exact date and time when the timesheet hours were formally approved by the authorized approver. Represents the principal business event timestamp that triggers downstream billing and payroll processing.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billRate rdf:type rdf:Property ;
    rdfs:label 'Bill Rate' ;
    rdfs:comment 'The hourly rate charged to the client for the workers regular hours during this pay period, as defined in the client MSA or VMS rate card. Expressed in USD per hour. Used to calculate total billable amount.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingTransmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Transmission Status' ;
    rdfs:comment 'Indicates the current state of this approved hours summarys transmission to the client billing system (Salesforce Revenue Cloud). invoiced means a client invoice has been generated from this record.' ;
    rdfs:domain ind:ApprovedHoursSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:burdenRatePct rdf:type rdf:Property ;
    rdfs:label 'Burden Rate Pct' ;
    rdfs:comment 'The total employer burden rate applied to this workers payable wages for the pay period, expressed as a decimal percentage. Encompasses FICA, FUTA, SUTA, Workers Compensation (Workers Comp), and benefits costs. Used to calculate fully-loaded labor cost.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'The date and time when this approved hours summary record was first created in the Silver Layer. Supports audit trail and data lineage requirements.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for all monetary amounts in this record (e.g., USD, CAD, GBP). Supports multi-currency operations for international staffing engagements.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dtBillRate rdf:type rdf:Property ;
    rdfs:label 'Dt Bill Rate' ;
    rdfs:comment 'The hourly rate charged to the client for double-time (DT) hours during this pay period. Typically 2x the regular bill rate per the client MSA or applicable state labor law.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dtHours rdf:type rdf:Property ;
    rdfs:label 'Dt Hours' ;
    rdfs:comment 'Total approved double-time (DT) hours worked during the pay period, applicable in jurisdictions or client agreements requiring 2x pay for hours beyond a daily or weekly threshold (e.g., California daily OT rules).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flsaExemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Flsa Exemption Status' ;
    rdfs:comment 'Indicates whether the worker is classified as exempt or non-exempt under the Fair Labor Standards Act (FLSA) for this assignment. Non-exempt workers are entitled to overtime pay at 1.5x for hours exceeding 40 per week.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossMarginAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Amount' ;
    rdfs:comment 'The gross margin (Spread) for this pay period, calculated as total_billable_amount minus total_payable_amount minus burden costs. Represents the staffing agencys gross profit contribution from this worker-assignment combination before SG&A.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holidayHours rdf:type rdf:Property ;
    rdfs:label 'Holiday Hours' ;
    rdfs:comment 'Total approved hours worked on designated company or client holidays during the pay period. Holiday hours may carry a premium bill rate and pay rate per the client MSA or worker agreement.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAmended rdf:type rdf:Property ;
    rdfs:label 'Is Amended' ;
    rdfs:comment 'Indicates whether this approved hours summary record has been amended after initial approval (e.g., due to a timesheet correction, missed punch adjustment, or retroactive rate change). True triggers a reconciliation process in payroll and billing.' ;
    rdfs:domain ind:ApprovedHoursSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isApproved rdf:type rdf:Property ;
    rdfs:label 'Is Approved' ;
    rdfs:comment 'Boolean flag confirming that all hours in this summary have been formally approved by an authorized approver. True indicates the record is cleared for payroll and billing handoff. False indicates approval is still pending or was revoked.' ;
    rdfs:domain ind:ApprovedHoursSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otBillRate rdf:type rdf:Property ;
    rdfs:label 'Ot Bill Rate' ;
    rdfs:comment 'The hourly rate charged to the client for overtime (OT) hours during this pay period. Typically 1.5x the regular bill rate, but may be negotiated differently in the client MSA.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otHours rdf:type rdf:Property ;
    rdfs:label 'Ot Hours' ;
    rdfs:comment 'Total approved overtime (OT) hours worked during the pay period, typically hours exceeding 40 per week for non-exempt workers under FLSA. Billed and paid at the OT multiplier rate (commonly 1.5x).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period End Date' ;
    rdfs:comment 'The last calendar date of the pay period covered by this approved hours summary. Defines the inclusive end boundary for all hours aggregated in this record.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period Start Date' ;
    rdfs:comment 'The first calendar date of the pay period covered by this approved hours summary. Defines the inclusive start boundary for all hours aggregated in this record.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payRate rdf:type rdf:Property ;
    rdfs:label 'Pay Rate' ;
    rdfs:comment 'The hourly rate paid to the worker for regular hours during this pay period, as defined in the workers placement agreement. Expressed in USD per hour. Used to calculate total payable amount and gross margin (Spread).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payrollTransmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Payroll Transmission Status' ;
    rdfs:comment 'Indicates the current state of this approved hours summarys transmission to the payroll processing system (TempWorks Payroll). confirmed means payroll has acknowledged receipt and the record is locked for the pay run.' ;
    rdfs:domain ind:ApprovedHoursSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perDiemRate rdf:type rdf:Property ;
    rdfs:label 'Per Diem Rate' ;
    rdfs:comment 'The daily per diem allowance rate paid to the worker per approved per diem unit. Must not exceed IRS-published per diem limits to maintain tax-free treatment. Expressed in USD per day.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perDiemUnits rdf:type rdf:Property ;
    rdfs:label 'Per Diem Units' ;
    rdfs:comment 'Number of per diem units (typically days) approved for the worker during the pay period. Per diem is a daily allowance paid to workers for meals, lodging, or incidentals when working away from their tax home. Not subject to payroll taxes when within IRS limits.' ;
    rdfs:domain ind:ApprovedHoursSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ptoHours rdf:type rdf:Property ;
    rdfs:label 'Pto Hours' ;
    rdfs:comment 'Total approved paid time off (PTO) hours for the worker during the pay period. PTO hours are payable to the worker but are typically not billable to the client unless specified in the MSA.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regularHours rdf:type rdf:Property ;
    rdfs:label 'Regular Hours' ;
    rdfs:comment 'Total approved regular (straight-time) hours worked by the worker during the pay period, excluding overtime and double-time. Used as the base quantity for both client billing and worker payroll at the standard bill rate and pay rate respectively.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Identifies the operational system of record from which this approved hours summary was sourced or triggered. Kronos Workforce Ready is the primary source; Beeline VMS may be the source for MSP-managed programs; Manual indicates a staffing coordinator override entry.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:summaryNumber rdf:type rdf:Property ;
    rdfs:label 'Summary Number' ;
    rdfs:comment 'Externally-visible business identifier for this approved hours summary record, formatted as AHS-{YYYY}-{WW}-{SEQUENCE}. Used in billing and payroll correspondence to reference a specific approved period.' ;
    rdfs:domain ind:ApprovedHoursSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBillableAmount rdf:type rdf:Property ;
    rdfs:label 'Total Billable Amount' ;
    rdfs:comment 'Total gross amount to be invoiced to the client for this pay period, calculated as the sum of (regular_hours × bill_rate) + (ot_hours × ot_bill_rate) + (dt_hours × dt_bill_rate) + (holiday_hours × applicable holiday bill rate). Feeds Salesforce Revenue Cloud invoice generation.' ;
    rdfs:domain ind:ApprovedHoursSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalHours rdf:type rdf:Property ;
    rdfs:label 'Total Hours' ;
    rdfs:comment 'Sum of all approved hour types (regular + OT + DT + holiday) for the worker during the pay period. Represents the total time-based quantity used for workforce analytics and FTE calculations. Excludes PTO hours.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPayableAmount rdf:type rdf:Property ;
    rdfs:label 'Total Payable Amount' ;
    rdfs:comment 'Total gross wages payable to the worker for this pay period, calculated as the sum of (regular_hours × pay_rate) + (ot_hours × ot_pay_rate) + (dt_hours × dt_pay_rate) + (holiday_hours × holiday pay rate) + (per_diem_units × per_diem_rate). Feeds TempWorks Payroll processing.' ;
    rdfs:domain ind:ApprovedHoursSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'The date and time when this approved hours summary record was last modified. Tracks amendments such as retroactive adjustments or correction reprocessing.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:vmsRequisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Vms Requisition Number' ;
    rdfs:comment 'The requisition or purchase order number assigned by the clients Vendor Management System (VMS), such as Beeline, for this workers engagement. Required on client invoices for MSP-managed programs.' ;
    rdfs:domain ind:ApprovedHoursSummary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workLocationType rdf:type rdf:Property ;
    rdfs:label 'Work Location Type' ;
    rdfs:comment 'Indicates whether the worker performed services on-site at the client location, fully remote, or in a hybrid arrangement during this pay period. Affects per diem eligibility and certain state tax obligations.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerType rdf:type rdf:Property ;
    rdfs:label 'Worker Type' ;
    rdfs:comment 'Classification of the workers tax and employment relationship for this assignment. W-2 indicates a staffing agency employee; 1099 indicates an independent contractor (IC); C2C indicates a corp-to-corp engagement. Drives payroll tax treatment and burden rate application.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workersCompCode rdf:type rdf:Property ;
    rdfs:label 'Workers Comp Code' ;
    rdfs:comment 'The National Council on Compensation Insurance (NCCI) workers compensation class code assigned to the worker for this assignment. Determines the workers comp insurance premium rate applied within the burden rate calculation.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Id' ;
    rdfs:comment 'Unique system-generated identifier for each timesheet adjustment record. Serves as the primary key for the timesheet_adjustment entity. TRANSACTION_HEADER role — canonical minimum categories enforced.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustedPayStubId rdf:type rdf:Property ;
    rdfs:label 'Adjusted Pay Stub Id' ;
    rdfs:comment 'Foreign key linking to payroll.pay_stub. Business justification: Timesheet adjustments often trigger pay stub corrections or reissues. Tracking which specific pay stub was affected (vs. just the pay_run) is essential for audit trails, worker communication about cor' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayStub .

ind:amendmentId rdf:type rdf:Property ;
    rdfs:label 'Amendment Id' ;
    rdfs:comment 'Foreign key linking to contract.amendment. Business justification: Retroactive billing and payroll adjustments are frequently triggered by contract amendments (rate changes, scope modifications). Linking adjustments to the causative amendment is required for financia' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:creditMemoId rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Id' ;
    rdfs:comment 'Foreign key linking to billing.credit_memo. Business justification: Timesheet adjustments that reduce billable hours/amounts result in credit memos. Linking adjustment to credit_memo enables the adjustment-to-credit-memo audit trail that staffing AR teams use for bill' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditMemo .

ind:disputeId rdf:type rdf:Property ;
    rdfs:label 'Dispute Id' ;
    rdfs:comment 'Foreign key linking to billing.billing_dispute. Business justification: Timesheet adjustments are frequently triggered by billing disputes. Linking adjustment directly to the causative billing_dispute enables dispute-driven adjustment tracking — a named staffing billing o' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dispute .

ind:earningsLineId rdf:type rdf:Property ;
    rdfs:label 'Earnings Line Id' ;
    rdfs:comment 'Foreign key linking to payroll.earnings_line. Business justification: Payroll adjustments correct specific earnings lines. Linking adjustment.earnings_line_id → payroll.earnings_line enables auditors to trace which earnings line was corrected by a retroactive adjustment' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EarningsLine .

ind:payRunId rdf:type rdf:Property ;
    rdfs:label 'Pay Run Id' ;
    rdfs:comment 'Reference to the payroll run in which this adjustment was processed. Enables reconciliation between timesheet adjustments and payroll output records. Null until the adjustment is applied to payroll.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayRun .

ind:rateOverrideId rdf:type rdf:Property ;
    rdfs:label 'Rate Override Id' ;
    rdfs:comment 'Foreign key linking to joborder.rate_override. Business justification: Retroactive billing and payroll adjustments are frequently triggered by approved rate overrides. Staffing billing teams must link each retroactive adjustment to the specific rate_override that authori' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateOverride .

ind:regulatoryViolationId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Violation Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_violation. Business justification: Timesheet adjustments may be triggered by wage-hour violations discovered in DOL/state audits (unpaid OT, misclassified hours). Real business process: remediation tracking linking adjustments to viola' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryViolation .

ind:adjustmentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Number' ;
    rdfs:comment 'Externally-visible, human-readable business identifier for the adjustment (e.g., ADJ-2024-000123). Used in dispute resolution, payroll reconciliation, and client billing communications. Maps to the BUSINESS_IDENTIFIER canonical category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current workflow lifecycle state of the adjustment record. Tracks progression from initial draft through approval and application to payroll and billing. Maps to the LIFECYCLE_STATUS canonical category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Categorical classification of the nature of the adjustment. Drives downstream payroll and billing processing logic. [ENUM-REF-CANDIDATE: hours_correction|rate_correction|pay_type_reclassification|retroactive_change|break_correction|absence_correction — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectsBilling rdf:type rdf:Property ;
    rdfs:label 'Affects Billing' ;
    rdfs:comment 'Indicates whether this timesheet adjustment impacts client billable hours or bill rates, triggering a credit memo or supplemental invoice. False for adjustments that only affect worker pay (e.g., internal pay type reclassifications with no billing impact).' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectsPayroll rdf:type rdf:Property ;
    rdfs:label 'Affects Payroll' ;
    rdfs:comment 'Indicates whether this timesheet adjustment impacts worker payable hours or pay rates, requiring a payroll correction or supplemental pay run. False for adjustments that only affect billing (e.g., bill rate corrections with no pay rate change).' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliedToBillingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Applied To Billing Timestamp' ;
    rdfs:comment 'The date and time when the approved adjustment was applied to client billing in Salesforce Revenue Cloud. Null until billing is updated. Confirms the client invoice or credit memo has been generated for the adjustment.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appliedToPayrollTimestamp rdf:type rdf:Property ;
    rdfs:label 'Applied To Payroll Timestamp' ;
    rdfs:comment 'The date and time when the approved adjustment was applied to the payroll run in TempWorks Payroll. Null until the adjustment is processed. Confirms the adjustment has been actioned in the payroll system of record.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'Indicates the approval tier required for this adjustment based on the adjustment type, dollar impact, or client contract requirements. Single-level approvals are handled internally; dual or client-required approvals involve additional stakeholders.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'The date and time when the timesheet adjustment was approved by the designated approver. Null if not yet approved. Used for approval cycle time analytics and SLA compliance reporting.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billAmountAdjusted rdf:type rdf:Property ;
    rdfs:label 'Bill Amount Adjusted' ;
    rdfs:comment 'The corrected gross client billing amount (in USD) after the adjustment. Drives credit memo issuance or supplemental invoice generation in Salesforce Revenue Cloud. Part of MONETARY_TRIPLET canonical category.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billAmountOriginal rdf:type rdf:Property ;
    rdfs:label 'Bill Amount Original' ;
    rdfs:comment 'The gross client billing amount (in USD) calculated from the original timesheet hours and bill rate before adjustment. Baseline for client invoice reconciliation and credit memo calculation.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billRateAdjusted rdf:type rdf:Property ;
    rdfs:label 'Bill Rate Adjusted' ;
    rdfs:comment 'The corrected client bill rate (per hour) in USD after the adjustment. Used when a rate correction changes the amount invoiced to the client. Drives credit memo or supplemental invoice generation.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billRateOriginal rdf:type rdf:Property ;
    rdfs:label 'Bill Rate Original' ;
    rdfs:comment 'The client bill rate (per hour) recorded on the original timesheet, in USD. Preserved for billing reconciliation when rate corrections affect client invoices. Represents the rate charged to the client before adjustment.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientApproved rdf:type rdf:Property ;
    rdfs:label 'Client Approved' ;
    rdfs:comment 'Indicates whether the client has formally approved the timesheet adjustment, required when the adjustment affects billable hours or bill rates under the clients Master Service Agreement (MSA). True when client sign-off is obtained.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hoursAdjusted rdf:type rdf:Property ;
    rdfs:label 'Hours Adjusted' ;
    rdfs:comment 'The corrected number of hours after the adjustment is applied. Replaces the original hours value for payroll processing and client billing. The difference between hours_adjusted and hours_original represents the net hours change.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursOriginal rdf:type rdf:Property ;
    rdfs:label 'Hours Original' ;
    rdfs:comment 'The number of hours recorded on the original approved timesheet for the work date and pay type being corrected. Preserved as the pre-adjustment baseline for audit, dispute resolution, and reconciliation.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRetroactive rdf:type rdf:Property ;
    rdfs:label 'Is Retroactive' ;
    rdfs:comment 'Indicates whether this adjustment applies to a prior pay period that has already been processed in payroll and/or billing. Retroactive adjustments require special handling in payroll tax recalculation (FICA, FUTA, SUTA) and may trigger amended invoices.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payAmountAdjusted rdf:type rdf:Property ;
    rdfs:label 'Pay Amount Adjusted' ;
    rdfs:comment 'The corrected gross worker pay amount (in USD) after the adjustment is applied. Represents the authoritative payable amount for the adjusted period. The difference from pay_amount_original drives payroll debit or credit entries. Maps to MONETARY_TRIPLET canonical category.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payAmountOriginal rdf:type rdf:Property ;
    rdfs:label 'Pay Amount Original' ;
    rdfs:comment 'The gross worker pay amount (in USD) calculated from the original timesheet hours and pay rate before adjustment. Serves as the financial baseline for payroll reconciliation and adjustment impact analysis.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payRateAdjusted rdf:type rdf:Property ;
    rdfs:label 'Pay Rate Adjusted' ;
    rdfs:comment 'The corrected worker pay rate (per hour) in USD after the adjustment. Used for rate correction and retroactive change adjustment types. Drives recalculation of worker gross pay for the affected period.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payRateOriginal rdf:type rdf:Property ;
    rdfs:label 'Pay Rate Original' ;
    rdfs:comment 'The worker pay rate (per hour) recorded on the original timesheet, in USD. Preserved for rate correction adjustments and retroactive pay rate changes. Sensitive compensation data.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payTypeAdjusted rdf:type rdf:Property ;
    rdfs:label 'Pay Type Adjusted' ;
    rdfs:comment 'The corrected pay type code after adjustment. Used when a pay type reclassification adjustment is applied (e.g., regular hours reclassified as overtime (OT) or double-time (DT)). Drives recalculation of worker pay and client bill amounts. [ENUM-REF-CANDIDATE: regular|overtime|double_time|per_diem|pto|holiday|on_call — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payTypeOriginal rdf:type rdf:Property ;
    rdfs:label 'Pay Type Original' ;
    rdfs:comment 'The pay type code recorded on the original timesheet before adjustment (e.g., regular, overtime (OT), double-time (DT), per diem, paid time off (PTO), holiday, on-call). Preserved for full audit trail and reclassification tracking. [ENUM-REF-CANDIDATE: regular|overtime|double_time|per_diem|pto|holiday|on_call — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized reason code categorizing why the timesheet adjustment was initiated. Supports root-cause analysis, compliance reporting, and process improvement. [ENUM-REF-CANDIDATE: data_entry_error|system_error|missed_punch|rate_change|ot_reclassification|client_dispute|worker_dispute|manager_correction — promote to reference product]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonNotes rdf:type rdf:Property ;
    rdfs:label 'Reason Notes' ;
    rdfs:comment 'Free-text narrative explanation provided by the requestor describing the specific circumstances requiring the timesheet adjustment. Supplements the reason code with contextual detail for audit and dispute resolution.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorRole rdf:type rdf:Property ;
    rdfs:label 'Requestor Role' ;
    rdfs:comment 'The business role of the individual who submitted the adjustment request. Provides context for approval routing and compliance audit without requiring a join to the user table.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'The date and time when the timesheet adjustment request was formally submitted into the workflow system. Maps to the BUSINESS_EVENT_TIMESTAMP canonical category for TRANSACTION_HEADER role. Used for SLA tracking and audit trail.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workDate rdf:type rdf:Property ;
    rdfs:label 'Work Date' ;
    rdfs:comment 'The specific calendar date on which the hours being adjusted were originally worked. Enables day-level audit trail and supports overtime calculation corrections at the daily level.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:laborCategoryId rdf:type rdf:Property ;
    rdfs:label 'Labor Category Id' ;
    rdfs:comment 'Unique surrogate identifier for the labor category record. Primary key for the labor_category reference entity. [_canonical_skip_reason: Entity role is REFERENCE_LOOKUP — a reference/code table defining labor classifications; per-role minimums are exempt, but MASTER_RESOURCE categories are applied given the entity carries substantive business attributes beyond a simple enumeration.]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LaborCategory .

ind:burdenRateId rdf:type rdf:Property ;
    rdfs:label 'Burden Rate Id' ;
    rdfs:comment 'Foreign key linking to payroll.burden_rate. Business justification: Labor categories define job classifications; burden_rate defines employer cost loads (FICA, SUTA, WC) by worker classification. Linking labor_category.burden_rate_id → payroll.burden_rate enables payr' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BurdenRate .

ind:credentialRequirementId rdf:type rdf:Property ;
    rdfs:label 'Credential Requirement Id' ;
    rdfs:comment 'Foreign key linking to credentialing.credential_requirement. Business justification: Staffing operations require mapping labor categories to credential requirements for compliance gating at assignment start. A \'Registered Nurse\' labor category must reference the credential requirement' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CredentialRequirement .

ind:jobCategoryId rdf:type rdf:Property ;
    rdfs:label 'Job Category Id' ;
    rdfs:comment 'Foreign key linking to joborder.job_category. Business justification: Staffing firms must reconcile timesheet labor categories against job order job categories for bill rate validation, markup calculation, and workforce cost reporting. job_category carries typical_marku' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobCategory .

ind:otRuleId rdf:type rdf:Property ;
    rdfs:label 'Ot Rule Id' ;
    rdfs:comment 'Reference to the overtime rule set applicable to this labor category. Determines how overtime hours are calculated (e.g., daily OT after 8 hours, weekly OT after 40 hours, California daily/weekly OT rules). Links to the ot_rule reference entity as specified in the product description.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OtRule .

ind:skillId rdf:type rdf:Property ;
    rdfs:label 'Skill Id' ;
    rdfs:comment 'Foreign key linking to candidate.skill. Business justification: Labor categories are defined by primary skill type and proficiency level — a staffing firm\'s rate card maps directly from verified skill to labor category tier. Linking labor_category to the canonical' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Skill .

ind:vendorRateCardId rdf:type rdf:Property ;
    rdfs:label 'Vendor Rate Card Id' ;
    rdfs:comment 'Foreign key linking to vendor.vendor_rate_card. Business justification: Labor categories must map to vendor-specific rate cards for rate validation, margin analysis, and vendor bill rate verification. When evaluating vendor submissions or processing timesheets, staffing f' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorRateCard .

ind:vmsProgramId rdf:type rdf:Property ;
    rdfs:label 'Vms Program Id' ;
    rdfs:comment 'Foreign key linking to client.vms_program. Business justification: VMS programs define client-specific labor categories with rate caps and category codes. The vms_category_code on labor_category is a denormalized reference to vms_program. Staffing VMS operations requ' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VmsProgram .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or identifier of the business user or manager who approved this labor category definition and its associated rates. Required for governance and audit compliance in rate card management.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date on which this labor category record was formally approved by the designated approver. Used for governance, audit trail, and effective dating validation.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billableIndicator rdf:type rdf:Property ;
    rdfs:label 'Billable Indicator' ;
    rdfs:comment 'Flag indicating whether time entries coded to this labor category are billable to the client. When true, hours are included in client invoicing. When false, hours are internal or non-billable (e.g., orientation, training, bench time).' ;
    rdfs:domain ind:LaborCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the labor category. Used in timesheets, billing systems, and VMS integrations to reference the category. Sourced from Kronos Workforce Ready and synchronized to Beeline VMS and Salesforce Revenue Cloud.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryDescription rdf:type rdf:Property ;
    rdfs:label 'Category Description' ;
    rdfs:comment 'Detailed narrative description of the labor category, including scope of work, typical duties, and applicable skill requirements. Used for client-facing documentation, MSA exhibits, and SOW labor category definitions.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Human-readable name of the labor category (e.g., Software Engineer – Senior, Light Industrial – Forklift Operator, Administrative – Data Entry). Displayed in timesheets, client invoices, and workforce analytics dashboards.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryType rdf:type rdf:Property ;
    rdfs:label 'Category Type' ;
    rdfs:comment 'Broad classification grouping the labor category into a workforce segment (e.g., professional, light industrial, clerical, technical, healthcare, executive, skilled trades). Drives workforce analytics segmentation and client billing tier assignment. [ENUM-REF-CANDIDATE: professional|light_industrial|clerical|technical|healthcare|executive|skilled_trades — promote to reference product if additional values are needed]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultBillRate rdf:type rdf:Property ;
    rdfs:label 'Default Bill Rate' ;
    rdfs:comment 'Default hourly bill rate (in USD) charged to the client for workers assigned to this labor category. Serves as the baseline rate before client-specific or contract-specific overrides are applied. Used by Salesforce Revenue Cloud for invoice generation.' ;
    rdfs:domain ind:LaborCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultDtBillRate rdf:type rdf:Property ;
    rdfs:label 'Default Dt Bill Rate' ;
    rdfs:comment 'Default hourly double-time (DT) bill rate charged to the client for double-time hours worked by workers in this labor category. Applicable in states or contracts requiring double-time pay (e.g., California labor law).' ;
    rdfs:domain ind:LaborCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultDtPayRate rdf:type rdf:Property ;
    rdfs:label 'Default Dt Pay Rate' ;
    rdfs:comment 'Default hourly double-time (DT) pay rate paid to workers in this labor category for double-time hours. Applicable under state-specific labor laws or union agreements requiring double-time compensation.' ;
    rdfs:domain ind:LaborCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultOtBillRate rdf:type rdf:Property ;
    rdfs:label 'Default Ot Bill Rate' ;
    rdfs:comment 'Default hourly overtime (OT) bill rate charged to the client for overtime hours worked by workers in this labor category. Typically 1.5x the standard bill rate unless a client-specific rate card overrides it.' ;
    rdfs:domain ind:LaborCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultOtPayRate rdf:type rdf:Property ;
    rdfs:label 'Default Ot Pay Rate' ;
    rdfs:comment 'Default hourly overtime (OT) pay rate paid to workers in this labor category for overtime hours. Must comply with FLSA overtime requirements (minimum 1.5x regular rate for non-exempt workers).' ;
    rdfs:domain ind:LaborCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultPayRate rdf:type rdf:Property ;
    rdfs:label 'Default Pay Rate' ;
    rdfs:comment 'Default hourly pay rate (in USD) paid to workers assigned to this labor category. Serves as the baseline rate before worker-specific or assignment-specific overrides are applied. Used by TempWorks Payroll for compensation calculation.' ;
    rdfs:domain ind:LaborCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eeoJobCategory rdf:type rdf:Property ;
    rdfs:label 'Eeo Job Category' ;
    rdfs:comment 'EEOC EEO-1 job category assigned to this labor category for equal employment opportunity reporting. Required for federal contractors and employers with 100+ employees. [ENUM-REF-CANDIDATE: executives_senior_officials|first_mid_officials|professionals|technicians|sales_workers|administrative_support|craft_workers|operatives|laborers_helpers|service_workers — promote to reference product]' ;
    rdfs:domain ind:LaborCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The date from which this labor category definition and its associated rates become effective. Supports rate versioning and historical rate lookups for timesheet processing and billing reconciliation.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'The date on which this labor category definition and its associated rates expire. Null for open-ended categories. After this date, the category is no longer available for new timesheet entries unless renewed or superseded.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:flsaClassification rdf:type rdf:Property ;
    rdfs:label 'Flsa Classification' ;
    rdfs:comment 'Indicates whether workers in this labor category are classified as exempt or non-exempt under the Fair Labor Standards Act (FLSA). Non-exempt workers are entitled to overtime pay; exempt workers are not. Critical for overtime rule application and payroll compliance.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icEligible rdf:type rdf:Property ;
    rdfs:label 'Ic Eligible' ;
    rdfs:comment 'Flag indicating whether workers in this labor category may be engaged as independent contractors (1099) rather than W-2 employees. Drives worker classification compliance checks per IRS worker classification rules and DOL economic reality test.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobFunctionCode rdf:type rdf:Property ;
    rdfs:label 'Job Function Code' ;
    rdfs:comment 'Standardized job function code classifying the primary work function of this labor category (e.g., IT, Finance, Operations, Engineering, Healthcare). Aligns with O*NET or SOC occupational classification codes for workforce analytics and regulatory reporting.' ;
    rdfs:domain ind:LaborCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kronosLaborCategoryRef rdf:type rdf:Property ;
    rdfs:label 'Kronos Labor Category Ref' ;
    rdfs:comment 'The native labor category identifier in Kronos Workforce Ready, the system of record for time and attendance. Used for system integration and data lineage tracing between the lakehouse silver layer and the Kronos source system.' ;
    rdfs:domain ind:LaborCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborCategoryStatus rdf:type rdf:Property ;
    rdfs:label 'Labor Category Status' ;
    rdfs:comment 'Current lifecycle status of the labor category record. active indicates the category is available for use in timesheet entries and billing; inactive indicates it has been retired; pending indicates it is awaiting approval; deprecated indicates it has been superseded by a newer category.' ;
    rdfs:domain ind:LaborCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markupPct rdf:type rdf:Property ;
    rdfs:label 'Markup Pct' ;
    rdfs:comment 'Default markup percentage applied over the pay rate to derive the bill rate for this labor category. Represents the spread as a percentage of pay rate. Used in pricing models and profitability analysis. Markup = (Bill Rate - Pay Rate) / Pay Rate × 100.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxBillRate rdf:type rdf:Property ;
    rdfs:label 'Max Bill Rate' ;
    rdfs:comment 'Maximum allowable hourly bill rate for this labor category. Used as a ceiling in VMS rate card negotiations and client contract management. Bill rates above this ceiling require management approval.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minPayRate rdf:type rdf:Property ;
    rdfs:label 'Min Pay Rate' ;
    rdfs:comment 'Minimum allowable hourly pay rate for workers assigned to this labor category. Enforces compliance with applicable federal, state, or local minimum wage laws and prevailing wage requirements. Pay rates below this floor are rejected during payroll processing.' ;
    rdfs:domain ind:LaborCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perDiemEligible rdf:type rdf:Property ;
    rdfs:label 'Per Diem Eligible' ;
    rdfs:comment 'Flag indicating whether workers assigned to this labor category are eligible for per diem allowances (daily expense reimbursements for travel, lodging, or meals). Affects payroll processing and client billing for travel-based assignments.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prevailingWageIndicator rdf:type rdf:Property ;
    rdfs:label 'Prevailing Wage Indicator' ;
    rdfs:comment 'Flag indicating whether this labor category is subject to prevailing wage requirements under the Davis-Bacon Act or Service Contract Act (SCA) for government or federally funded contracts. When true, the prevailing_wage_rate field applies.' ;
    rdfs:domain ind:LaborCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prevailingWageRate rdf:type rdf:Property ;
    rdfs:label 'Prevailing Wage Rate' ;
    rdfs:comment 'The federally or state-mandated prevailing wage rate (in USD per hour) applicable to this labor category for government or public works contracts. Determined by DOL wage determinations under the Davis-Bacon Act or SCA. Null when prevailing_wage_indicator is false.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateTierCode rdf:type rdf:Property ;
    rdfs:label 'Rate Tier Code' ;
    rdfs:comment 'Code identifying the default bill/pay rate tier associated with this labor category. Rate tiers define pricing bands used across client contracts and VMS programs. Links to rate tier configuration in Beeline VMS and Salesforce Revenue Cloud.' ;
    rdfs:domain ind:LaborCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaLaborCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Sca Labor Category Code' ;
    rdfs:comment 'The official Service Contract Act (SCA) labor category code or title as defined in the applicable DOL wage determination. Used to map internal labor categories to SCA-compliant job classifications for federal service contracts. Required for compliance reporting on government staffing contracts.' ;
    rdfs:domain ind:LaborCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillLevel rdf:type rdf:Property ;
    rdfs:label 'Skill Level' ;
    rdfs:comment 'Proficiency or seniority tier associated with the labor category (e.g., entry, junior, mid, senior, lead, principal, executive). Used to differentiate bill/pay rate tiers and to support workforce planning analytics. [ENUM-REF-CANDIDATE: entry|junior|mid|senior|lead|principal|executive — promote to reference product if additional values are needed]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socCode rdf:type rdf:Property ;
    rdfs:label 'Soc Code' ;
    rdfs:comment 'U.S. Bureau of Labor Statistics Standard Occupational Classification (SOC) code mapped to this labor category. Used for EEOC reporting, DOL compliance, workforce analytics, and labor market benchmarking. Format: XX-XXXX (e.g., 15-1252 for Software Developers).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tempToPermEligible rdf:type rdf:Property ;
    rdfs:label 'Temp To Perm Eligible' ;
    rdfs:comment 'Flag indicating whether placements in this labor category are eligible for temp-to-perm conversion (contract-to-hire). When true, a conversion fee may apply upon permanent placement. Used in Bullhorn ATS/CRM for placement tracking and conversion fee calculation.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionApplicable rdf:type rdf:Property ;
    rdfs:label 'Union Applicable' ;
    rdfs:comment 'Flag indicating whether this labor category is subject to a collective bargaining agreement (CBA) or union work rules. When true, the union_code field identifies the applicable union. Affects pay rates, overtime rules, and benefit requirements.' ;
    rdfs:domain ind:LaborCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionCode rdf:type rdf:Property ;
    rdfs:label 'Union Code' ;
    rdfs:comment 'Code identifying the labor union or collective bargaining agreement (CBA) applicable to this labor category. Null when union_applicable is false. Used to apply union-specific pay rules, benefit contributions, and work rules in payroll processing.' ;
    rdfs:domain ind:LaborCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchCode rdf:type rdf:Property ;
    rdfs:label 'Branch Code' ;
    rdfs:comment 'Staffing branch or cost center code associated with this payroll run. Used for branch-level payroll cost allocation, P&L reporting, and operational analytics in Power BI.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkDate rdf:type rdf:Property ;
    rdfs:label 'Check Date' ;
    rdfs:comment 'Date printed on physical payroll checks or used as the effective date for direct deposit transactions. May differ from pay_date when banking processing windows shift the settlement date.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'Identifier for the legal employing entity or EOR entity under which this payroll run is processed. Supports multi-entity payroll operations and co-employment models where Staffing Hr acts as the employer of record.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementMethod rdf:type rdf:Property ;
    rdfs:label 'Disbursement Method' ;
    rdfs:comment 'Primary method used to disburse net pay to workers in this run. Direct deposit (ACH) is standard; check and pay card are alternatives for workers without bank accounts; wire for special high-value payments.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostDate rdf:type rdf:Property ;
    rdfs:label 'Gl Post Date' ;
    rdfs:comment 'Date on which this payroll runs journal entries were posted to the Oracle NetSuite ERP General Ledger. Marks the accounting period in which payroll costs are recognized.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:icWorkerCount rdf:type rdf:Property ;
    rdfs:label 'Ic Worker Count' ;
    rdfs:comment 'Number of 1099 independent contractors (ICs) included in this payroll run. Used for IRS 1099-NEC filing thresholds and worker classification compliance monitoring.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isMultiState rdf:type rdf:Property ;
    rdfs:label 'Is Multi State' ;
    rdfs:comment 'Indicates whether this payroll run spans workers in more than one US state, triggering multi-state tax withholding, SUTA apportionment, and additional compliance review requirements.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payDate rdf:type rdf:Property ;
    rdfs:label 'Pay Date' ;
    rdfs:comment 'Scheduled date on which worker net pay is disbursed via direct deposit, check, or pay card. Determines the tax deposit due date per IRS deposit schedule rules.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payFrequency rdf:type rdf:Property ;
    rdfs:label 'Pay Frequency' ;
    rdfs:comment 'Frequency at which workers are paid within this run. Drives pay period date calculations and tax withholding schedules per IRS Publication 15 annualization tables.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollStateCodes rdf:type rdf:Property ;
    rdfs:label 'Payroll State Codes' ;
    rdfs:comment 'Comma-delimited list of two-letter US state codes (e.g., CA,TX,NY) representing all states in which workers were paid in this run. Drives multi-state tax filing obligations and SUTA rate application.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted Timestamp' ;
    rdfs:comment 'Date and time when this payroll run was finalized and posted to the General Ledger in Oracle NetSuite ERP, making it immutable for the accounting period.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processed Timestamp' ;
    rdfs:comment 'Date and time when TempWorks Payroll completed the payroll calculation and tax computation processing for this run. Used for payroll operations SLA monitoring and processing time analytics.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the pay run, used in reconciliation, audit trails, and payroll operations communications. Format: PR-YYYY-MM-NNNN.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:comment 'Current lifecycle state of the payroll run within TempWorks Payroll workflow. Progresses from open (data entry) through processing, approved, and posted (finalized to GL). Voided indicates the run was reversed.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Classification of the payroll run indicating its operational purpose. Regular runs cover standard pay periods; off-cycle handles out-of-band payments; adjustment corrects prior-period errors; void-and-reissue replaces a voided run; supplemental covers bonuses or special payments.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxQuarter rdf:type rdf:Property ;
    rdfs:label 'Tax Quarter' ;
    rdfs:comment 'Calendar quarter (1–4) to which this payroll run belongs, used for IRS Form 941 quarterly payroll tax filing and FUTA/SUTA quarterly reporting.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxYear rdf:type rdf:Property ;
    rdfs:label 'Tax Year' ;
    rdfs:comment 'Calendar year to which this payroll runs earnings and withholdings are attributed for IRS W-2 and 1099 tax reporting purposes. Critical for year-end tax form generation.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDeductions rdf:type rdf:Property ;
    rdfs:label 'Total Deductions' ;
    rdfs:comment 'Sum of all voluntary and involuntary employee deductions (benefits, garnishments, 401k, health insurance premiums, etc.) withheld from worker gross pay in this run. Reconciles gross-to-net pay calculations.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDtPay rdf:type rdf:Property ;
    rdfs:label 'Total Dt Pay' ;
    rdfs:comment 'Sum of double time (DT) earnings for all workers in this run, applicable in states such as California where DT is mandated for hours exceeding 12 in a workday or 8 on the seventh consecutive day.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalEmployerBurden rdf:type rdf:Property ;
    rdfs:label 'Total Employer Burden' ;
    rdfs:comment 'Sum of all employer-side payroll costs beyond gross wages in this run, including employer FICA, FUTA, SUTA, workers comp premiums, and employer-paid benefits. Used to calculate the burden rate and total cost of workforce deployment.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFicaEmployee rdf:type rdf:Property ;
    rdfs:label 'Total Fica Employee' ;
    rdfs:comment 'Sum of employee-side Federal Insurance Contributions Act (FICA) withholdings (Social Security 6.2% + Medicare 1.45%) across all workers in this run. Reported on IRS Form 941.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFicaEmployer rdf:type rdf:Property ;
    rdfs:label 'Total Fica Employer' ;
    rdfs:comment 'Sum of employer-side Federal Insurance Contributions Act (FICA) matching contributions (Social Security 6.2% + Medicare 1.45%) for all W-2 workers in this run. Included in total employer burden calculation.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFutaTax rdf:type rdf:Property ;
    rdfs:label 'Total Futa Tax' ;
    rdfs:comment 'Sum of Federal Unemployment Tax Act (FUTA) employer tax accrued in this payroll run, calculated at 6.0% on the first $7,000 of each employees wages (net of SUTA credit). Filed annually on IRS Form 940.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGrossPay rdf:type rdf:Property ;
    rdfs:label 'Total Gross Pay' ;
    rdfs:comment 'Sum of all gross earnings for all workers in this payroll run before any deductions or tax withholdings. Includes regular pay, overtime (OT), double time (DT), per diem, and other earnings components.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetPay rdf:type rdf:Property ;
    rdfs:label 'Total Net Pay' ;
    rdfs:comment 'Sum of net pay disbursed to all workers in this run after all tax withholdings and deductions. Represents the total cash outflow for worker compensation and is the primary reconciliation figure against bank ACH/check totals.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOtPay rdf:type rdf:Property ;
    rdfs:label 'Total Ot Pay' ;
    rdfs:comment 'Sum of overtime (OT) premium earnings for all workers in this run, calculated at 1.5x the regular rate for hours exceeding 40 per workweek per FLSA. Supports OT cost monitoring and client billing reconciliation.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPerDiemPay rdf:type rdf:Property ;
    rdfs:label 'Total Per Diem Pay' ;
    rdfs:comment 'Sum of per diem allowances paid to workers in this run for travel, lodging, and meal reimbursements. Per diem amounts within IRS GSA rates are non-taxable; amounts above are taxable wages.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPtoPay rdf:type rdf:Property ;
    rdfs:label 'Total Pto Pay' ;
    rdfs:comment 'Sum of paid time off (PTO) earnings disbursed in this payroll run, including vacation, sick, and holiday pay. Supports PTO accrual reconciliation and state-mandated paid leave compliance.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRegularPay rdf:type rdf:Property ;
    rdfs:label 'Total Regular Pay' ;
    rdfs:comment 'Sum of straight-time (regular rate) earnings for all workers in this run, excluding overtime, double time, and premium pay components. Used for pay rate analytics and FLSA regular rate of pay calculations.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSutaTax rdf:type rdf:Property ;
    rdfs:label 'Total Suta Tax' ;
    rdfs:comment 'Sum of State Unemployment Tax Act (SUTA) employer tax accrued across all applicable states in this payroll run. Rates and wage bases vary by state; critical for multi-state payroll compliance.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxWithholding rdf:type rdf:Property ;
    rdfs:label 'Total Tax Withholding' ;
    rdfs:comment 'Sum of all employee-side tax withholdings across all workers in this run, including federal income tax, state income tax, local taxes, and employee FICA (Social Security and Medicare). Used for IRS Form 941 and state tax deposit reconciliation.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWorkersCompPremium rdf:type rdf:Property ;
    rdfs:label 'Total Workers Comp Premium' ;
    rdfs:comment 'Sum of workers compensation insurance premiums accrued for all workers in this payroll run, calculated based on payroll amounts and applicable workers comp class codes and rates. Supports insurance carrier reporting and burden rate analysis.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidReason rdf:type rdf:Property ;
    rdfs:label 'Void Reason' ;
    rdfs:comment 'Business justification or reason code for voiding this payroll run. Required when run_status = voided to support audit compliance and payroll error tracking.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Voided Timestamp' ;
    rdfs:comment 'Date and time when this payroll run was voided, if applicable. Populated only for runs with run_status = voided. Supports payroll reversal audit trail and GL correction tracking.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:w2WorkerCount rdf:type rdf:Property ;
    rdfs:label 'W2 Worker Count' ;
    rdfs:comment 'Number of W-2 (Wage and Tax Statement) employees included in this payroll run. Distinguishes co-employed temporary workers from independent contractors for tax and compliance reporting.' ;
    rdfs:domain ind:PayRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workerCount rdf:type rdf:Property ;
    rdfs:label 'Worker Count' ;
    rdfs:comment 'Total number of workers (W-2 employees and 1099 independent contractors) included in this payroll run. Used for headcount reporting, payroll audit reconciliation, and workforce analytics.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payStubId rdf:type rdf:Property ;
    rdfs:label 'Pay Stub Id' ;
    rdfs:comment 'Unique system-generated identifier for each individual pay stub record. Primary key for the pay_stub data product. TRANSACTION_HEADER role — serves as the anchor for all gross-to-net pay disbursement details for a single worker in a single pay run.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayStub .

ind:contractMsaId rdf:type rdf:Property ;
    rdfs:label 'Contract Msa Id' ;
    rdfs:comment 'Foreign key linking to contract.msa. Business justification: Pay stubs must reference governing MSA for audit trail, co-employment determination, and compliance verification. Required for client audits, dispute resolution, and demonstrating adherence to contrac' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Msa .

ind:credentialInstanceId rdf:type rdf:Property ;
    rdfs:label 'Credential Instance Id' ;
    rdfs:comment 'Foreign key linking to credentialing.credential_instance. Business justification: Payroll processing validates credential status before issuing payment; compliance holds block pay_stub generation when mandatory credentials expire. Staffing firms routinely hold paychecks until BGC/l' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CredentialInstance .

ind:credentialPackageId rdf:type rdf:Property ;
    rdfs:label 'Credential Package Id' ;
    rdfs:comment 'Foreign key linking to credentialing.credential_package. Business justification: Pay stubs must be validated against the credential package governing the assignment — staffing payroll audits run \'Pay Stubs by Credential Package\' to verify workers paid at premium rates hold the req' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CredentialPackage .

ind:directHireId rdf:type rdf:Property ;
    rdfs:label 'Direct Hire Id' ;
    rdfs:comment 'Foreign key linking to placement.direct_hire. Business justification: Direct hire employees receive pay stubs when staffing firm handles payroll during transition or under PEO arrangements. Links pay records to permanent placement for payroll continuity and compliance.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DirectHire .

ind:everifyCaseId rdf:type rdf:Property ;
    rdfs:label 'Everify Case Id' ;
    rdfs:comment 'Foreign key linking to compliance.everify_case. Business justification: E-Verify case status must be resolved before continuing payroll for new hires at federal contractor clients. TNC (Tentative Non-Confirmation) cases require payroll suspension until resolution - federa' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EverifyCase .

ind:i9VerificationId rdf:type rdf:Property ;
    rdfs:label 'I9 Verification Id' ;
    rdfs:comment 'Foreign key linking to compliance.i9_verification. Business justification: Every pay stub requires valid I-9 work authorization verification before payment issuance. Staffing firms cannot pay workers without documented work eligibility - core compliance gate for payroll proc' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:I9Verification .

ind:icAgreementId rdf:type rdf:Property ;
    rdfs:label 'Ic Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.ic_agreement. Business justification: IC contractor payment processing requires referencing the IC agreement to validate payment_structure, payment_terms_net_days, and form_1099_reporting_flag when generating pay stubs. Staffing payroll t' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IcAgreement .

ind:onboardingEngagementId rdf:type rdf:Property ;
    rdfs:label 'Onboarding Engagement Id' ;
    rdfs:comment 'Foreign key linking to recruitment.onboarding_engagement. Business justification: Payroll validation requires verifying worker completed onboarding before issuing first paycheck. Links pay stub to the onboarding engagement that authorized payment. Critical for compliance audits and' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OnboardingEngagement .

ind:payRateId rdf:type rdf:Property ;
    rdfs:label 'Pay Rate Id' ;
    rdfs:comment 'Foreign key linking to payroll.pay_rate. Business justification: A pay stub is generated based on a specific pay rate master record. Adding pay_rate_id to pay_stub creates a traceable link from the transactional pay statement back to the authoritative rate definiti' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayRate .

ind:placementComplianceCheckId rdf:type rdf:Property ;
    rdfs:label 'Placement Compliance Check Id' ;
    rdfs:comment 'Foreign key linking to compliance.placement_compliance_check. Business justification: Staffing payroll gates pay stub issuance on compliance clearance (I-9, BGC, drug screen). Payroll auditors reference the placement_compliance_check record to confirm a worker was legally authorized to' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlacementComplianceCheck .

ind:wcPolicyId rdf:type rdf:Property ;
    rdfs:label 'Wc Policy Id' ;
    rdfs:comment 'Foreign key linking to payroll.wc_policy. Business justification: A pay stub captures workers_comp_premium (the actual WC premium charged on this pay cycle) and workers_comp_code (the NCCI class code). Adding wc_policy_id links the pay stub to the governing WC polic' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WcPolicy .

ind:workAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Work Authorization Id' ;
    rdfs:comment 'Foreign key linking to credentialing.work_authorization. Business justification: Work authorization validity at each pay date is a direct payroll compliance requirement — staffing firms must confirm active work authorization before disbursing pay. \'Payroll Compliance: Work Authori' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkAuthorization .

ind:workLocationId rdf:type rdf:Property ;
    rdfs:label 'Work Location Id' ;
    rdfs:comment 'Foreign key linking to placement.work_location. Business justification: Per diem eligibility and multi-state tax withholding on pay stubs depend on the specific work location. pay_stub carries work_state_code as a denormalized field; a direct FK to work_location enables p' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffingHr .

ind:workerClassificationId rdf:type rdf:Property ;
    rdfs:label 'Worker Classification Id' ;
    rdfs:comment 'Foreign key linking to compliance.worker_classification. Business justification: Pay stub processing depends on correct worker classification (W-2 vs 1099) to determine tax withholding obligations, FICA applicability, and reporting requirements. Classification drives payroll tax t' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkerClassification .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Type of bank account designated for direct deposit disbursement. checking or savings as required by NACHA ACH transaction codes (PPD). Determines the ACH SEC code used in the payment file. Null for check and pay card disbursements.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:achTraceNumber rdf:type rdf:Property ;
    rdfs:label 'Ach Trace Number' ;
    rdfs:comment 'Unique 15-digit NACHA ACH trace number assigned to the direct deposit transaction for this pay stub. Null for check and pay card disbursements. Used for ACH payment tracing, return item resolution, and bank reconciliation.' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'Sequential check number printed on the physical paycheck when pay_delivery_method is check. Null for direct deposit and pay card disbursements. Used for check reconciliation, stop-payment requests, and positive pay bank file matching.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Deposit Allocation Amount' ;
    rdfs:comment 'Dollar amount or percentage value of net pay allocated to this account in a split-deposit arrangement. Populated when deposit_allocation_type is fixed_amount or percentage. Null when deposit_allocation_type is full_net.' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositAllocationType rdf:type rdf:Property ;
    rdfs:label 'Deposit Allocation Type' ;
    rdfs:comment 'Specifies how net pay is allocated to this bank account in a split-deposit configuration. full_net = entire net pay to one account; fixed_amount = a specific dollar amount; percentage = a defined percentage of net pay. Supports multi-account direct deposit configurations.' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositPriority rdf:type rdf:Property ;
    rdfs:label 'Deposit Priority' ;
    rdfs:comment 'Numeric sequence (1 = highest priority) determining the order in which net pay is allocated across multiple bank accounts in a split-deposit configuration. Ensures correct disbursement sequencing when a worker has designated multiple accounts.' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dtEarnings rdf:type rdf:Property ;
    rdfs:label 'Dt Earnings' ;
    rdfs:comment 'Dollar amount of earnings for double-time hours (dt_hours × pay_rate × 2.0). Applicable in states with double-time mandates. Stored as a discrete earnings component for gross pay audit and state compliance reporting.' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:federalIncomeTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'Federal Income Tax Withheld' ;
    rdfs:comment 'Dollar amount of federal income tax withheld from the workers wages for this pay period based on W-4 elections and IRS withholding tables. Required for W-2 reporting (Box 2) and federal tax deposit obligations.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:futaTaxableWages rdf:type rdf:Property ;
    rdfs:label 'Futa Taxable Wages' ;
    rdfs:comment 'Portion of the workers gross wages subject to Federal Unemployment Tax Act (FUTA) employer tax for this pay period, up to the $7,000 annual wage base. Required for IRS Form 940 filing and employer burden rate reporting.' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossPay rdf:type rdf:Property ;
    rdfs:label 'Gross Pay' ;
    rdfs:comment 'Total pre-deduction, pre-tax earnings for the pay period. Sum of regular_earnings, ot_earnings, dt_earnings, per_diem_amount, and any other pay components. Represents the gross-base amount in the MONETARY_TRIPLET for this transaction. Used as the basis for all tax withholding calculations.' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicareTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'Medicare Tax Withheld' ;
    rdfs:comment 'Employee share of Medicare (HI) tax withheld under FICA at the applicable rate (1.45%, plus 0.9% Additional Medicare Tax for high earners). Required for W-2 reporting (Box 6) and FICA deposit compliance.' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPay rdf:type rdf:Property ;
    rdfs:label 'Net Pay' ;
    rdfs:comment 'Final take-home amount disbursed to the worker after all deductions and tax withholdings (gross_pay − total_deductions − total_tax_withheld). Represents the net total in the MONETARY_TRIPLET. The amount actually paid via direct deposit, check, or pay card.' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otEarnings rdf:type rdf:Property ;
    rdfs:label 'Ot Earnings' ;
    rdfs:comment 'Dollar amount of earnings for overtime hours (ot_hours × pay_rate × 1.5). Stored separately from regular earnings to support FLSA compliance reporting, overtime cost analytics, and client billing reconciliation.' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Pay Delivery Method' ;
    rdfs:comment 'Method by which net pay is disbursed to the worker. direct_deposit = ACH electronic transfer to bank account; check = physical paper check; pay_card = prepaid debit card for unbanked workers. Determines downstream disbursement routing logic.' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payRateType rdf:type rdf:Property ;
    rdfs:label 'Pay Rate Type' ;
    rdfs:comment 'Classification of the pay rate basis for this stub. hourly = standard time-based; salary = fixed periodic amount; per_diem = daily allowance-based; piece_rate = unit-of-output based. Determines gross pay calculation method and FLSA overtime applicability.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perDiemAmount rdf:type rdf:Property ;
    rdfs:label 'Per Diem Amount' ;
    rdfs:comment 'Non-taxable per diem allowance paid to the worker for travel, meals, or lodging during the pay period. Sourced from approved per diem claims. Tracked separately from taxable wages for IRS accountable plan compliance and gross pay composition.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prenoteStatus rdf:type rdf:Property ;
    rdfs:label 'Prenote Status' ;
    rdfs:comment 'Status of the NACHA prenote (zero-dollar test transaction) process for this bank account. pending = prenote initiated; sent = prenote transmitted to bank; verified = bank confirmed account valid; failed = account validation failed. Governs whether live ACH disbursement is permitted.' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ptoAccrualBalance rdf:type rdf:Property ;
    rdfs:label 'Pto Accrual Balance' ;
    rdfs:comment 'Workers remaining PTO accrual balance as of this pay stubs pay period end date, expressed in hours. Snapshot value captured at time of pay run for worker statement display and leave liability reporting.' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ptoHoursUsed rdf:type rdf:Property ;
    rdfs:label 'Pto Hours Used' ;
    rdfs:comment 'Number of PTO hours applied to this pay stub for the pay period. Represents paid leave hours that contribute to gross pay but are not worked hours. Required for PTO accrual balance management and FLSA leave tracking.' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regularEarnings rdf:type rdf:Property ;
    rdfs:label 'Regular Earnings' ;
    rdfs:comment 'Dollar amount of earnings for regular straight-time hours (regular_hours × pay_rate). Core component of gross pay. Stored as a raw earnings component to support gross-to-net audit trail and payroll reconciliation.' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialSecurityTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'Social Security Tax Withheld' ;
    rdfs:comment 'Employee share of Social Security (OASDI) tax withheld under FICA at the applicable rate (6.2% up to the annual wage base). Required for W-2 reporting (Box 4) and FICA tax deposit compliance.' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateIncomeTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'State Income Tax Withheld' ;
    rdfs:comment 'Dollar amount of state income tax withheld for the primary work state during this pay period. Supports multi-state payroll compliance and state W-2 / equivalent reporting. May be zero for states with no income tax.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stubNumber rdf:type rdf:Property ;
    rdfs:label 'Stub Number' ;
    rdfs:comment 'Externally visible, human-readable identifier for this pay stub as printed on the workers pay statement (e.g., PS-2024-00045231). Used for worker inquiries, audit trails, and payroll reconciliation. Satisfies BUSINESS_IDENTIFIER requirement for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stubStatus rdf:type rdf:Property ;
    rdfs:label 'Stub Status' ;
    rdfs:comment 'Current lifecycle state of the pay stub within the payroll processing workflow. draft = in calculation; calculated = gross-to-net complete pending approval; approved = authorized for disbursement; issued = payment released to worker; voided = cancelled before disbursement; reversed = post-issuance correction applied. Satisfies LIFECYCLE_STATUS requirement.' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sutaTaxableWages rdf:type rdf:Property ;
    rdfs:label 'Suta Taxable Wages' ;
    rdfs:comment 'Portion of the workers gross wages subject to State Unemployment Tax Act (SUTA) employer tax for this pay period, up to the applicable state wage base. Required for state unemployment tax filing and workforce cost burden rate calculation.' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxFilingStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Filing Status' ;
    rdfs:comment 'Workers federal income tax filing status as declared on IRS Form W-4, used to determine the correct withholding amount for this pay stub. [ENUM-REF-CANDIDATE: single|married_filing_jointly|married_filing_separately|head_of_household|exempt|qualifying_surviving_spouse — promote to reference product]' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'Total Tax Withheld' ;
    rdfs:comment 'Aggregate dollar amount of all federal, state, and local taxes withheld from the workers gross pay for this pay period. Includes FICA (Social Security and Medicare), federal income tax, and applicable state/local income taxes. Key component of gross-to-net calculation.' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:w2Eligible rdf:type rdf:Property ;
    rdfs:label 'W2 Eligible' ;
    rdfs:comment 'Indicates whether this pay stub is associated with a W-2 employee (True) versus a 1099 independent contractor (False). Drives tax withholding applicability, FICA obligations, and year-end tax form generation routing in TempWorks Payroll.' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workersCompPremium rdf:type rdf:Property ;
    rdfs:label 'Workers Comp Premium' ;
    rdfs:comment 'Employer-paid workers compensation insurance premium allocated to this pay stub for the pay period, calculated as (workers_comp_rate × payroll_basis). Represents a key component of the employer burden rate and total labor cost.' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ytdGrossPay rdf:type rdf:Property ;
    rdfs:label 'Ytd Gross Pay' ;
    rdfs:comment 'Cumulative gross pay earned by the worker from the start of the calendar year through this pay stubs pay period end date. Displayed on the workers pay statement and used for W-2 wage box population, FICA wage base tracking, and annual compensation reporting.' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ytdNetPay rdf:type rdf:Property ;
    rdfs:label 'Ytd Net Pay' ;
    rdfs:comment 'Cumulative net pay disbursed to the worker from the start of the calendar year through this pay stubs pay period end date. Displayed on the workers pay statement for annual earnings visibility and financial planning.' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ytdTaxWithheld rdf:type rdf:Property ;
    rdfs:label 'Ytd Tax Withheld' ;
    rdfs:comment 'Cumulative total of all taxes withheld from the workers pay from the start of the calendar year through this pay stubs pay period end date. Displayed on the pay statement and used for W-2 Box 2/4/6 population and tax deposit reconciliation.' ;
    rdfs:domain ind:PayStub ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hiringDecisionId rdf:type rdf:Property ;
    rdfs:label 'Hiring Decision Id' ;
    rdfs:comment 'Foreign key linking to recruitment.hiring_decision. Business justification: Pay rate records implement the bill/pay rates authorized by the hiring decision. Payroll auditors and rate dispute resolution processes require direct traceability from the active pay_rate record to t' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HiringDecision .

ind:locationId rdf:type rdf:Property ;
    rdfs:label 'Location Id' ;
    rdfs:comment 'Foreign key linking to client.location. Business justification: Pay rates frequently vary by work location due to metro differentials, cost-of-living adjustments, and site-specific client agreements. Essential for accurate rate management and pricing by location i' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:managedProgramId rdf:type rdf:Property ;
    rdfs:label 'Managed Program Id' ;
    rdfs:comment 'Foreign key linking to client.managed_program. Business justification: MSP managed programs govern markup caps and rate schedules (markup_cap_pct, target_ttf_days). Pay rate approval in MSP engagements requires tracing rates to the managed program for billing compliance ' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManagedProgram .

ind:positionRequirementId rdf:type rdf:Property ;
    rdfs:label 'Position Requirement Id' ;
    rdfs:comment 'Foreign key linking to joborder.position_requirement. Business justification: Staffing firms set pay rates directly against position-level requirements (pay_rate_min/max defined per position). Multi-position orders require position-level rate traceability for pay compliance aud' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PositionRequirement .

ind:rateAgreementId rdf:type rdf:Property ;
    rdfs:label 'Rate Agreement Id' ;
    rdfs:comment 'Foreign key linking to vendor.rate_agreement. Business justification: rate_agreement defines negotiated markup, pay rate bounds, and spread floors/ceilings with a supplier. pay_rate must reference the governing rate_agreement to enforce rate compliance, flag exceptions,' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateAgreement .

ind:sowId rdf:type rdf:Property ;
    rdfs:label 'Sow Id' ;
    rdfs:comment 'Foreign key linking to contract.sow. Business justification: SOWs define engagement-specific terms including pay rate structures and worker classifications. Staffing firms must link pay rates to SOWs for scope compliance, change order management, and SOW-level ' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sow .

ind:stateComplianceRuleId rdf:type rdf:Property ;
    rdfs:label 'State Compliance Rule Id' ;
    rdfs:comment 'Foreign key linking to compliance.state_compliance_rule. Business justification: Pay rates must meet state-specific minimum wage, prevailing wage, and overtime rules. Staffing firms link rate records to the governing state compliance rule to validate rates against jurisdictional m' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StateComplianceRule .

ind:vmsRateId rdf:type rdf:Property ;
    rdfs:label 'Vms Rate Id' ;
    rdfs:comment 'External rate identifier assigned by the Vendor Management System (VMS), such as Beeline, when the rate is VMS-driven. Used for reconciliation between TempWorks Payroll and Beeline VMS rate management. Populated only when rate_source = vms_driven.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rate .

ind:conversionFeeWaiverDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Fee Waiver Date' ;
    rdfs:comment 'Date after which the clients conversion fee obligation is waived if the worker is converted to a permanent employee. Typically tied to a minimum number of hours worked or weeks on assignment per the MSA terms. Null if no conversion fee waiver applies.' ;
    rdfs:domain ind:PayRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dtRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Dt Rate Multiplier' ;
    rdfs:comment 'Multiplier applied to the regular pay rate to calculate the double-time (DT) pay rate. Typically 2.0x, applicable in states such as California for hours over 12 in a day or on the 7th consecutive day. Applied by TempWorks Payroll for DT hours.' ;
    rdfs:domain ind:PayRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'The date after which this pay rate is no longer active. Nullable for open-ended rates. When populated, payroll processing after this date must use a successor rate record. Supports rate versioning and assignment extensions.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'The date from which this pay rate becomes active and applicable to payroll processing. Defines the beginning of the rates binding period. Payroll transactions on or after this date use this rate.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ficaExempt rdf:type rdf:Property ;
    rdfs:label 'Fica Exempt' ;
    rdfs:comment 'Indicates whether the worker is exempt from FICA (Social Security and Medicare) withholding for this assignment. True for certain visa holders (e.g., F-1, J-1 students) or specific worker classifications. Drives TempWorks Payroll tax withholding logic.' ;
    rdfs:domain ind:PayRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flsaExempt rdf:type rdf:Property ;
    rdfs:label 'Flsa Exempt' ;
    rdfs:comment 'Indicates whether the worker is classified as exempt from FLSA overtime requirements (True = exempt salaried; False = non-exempt hourly). Determines whether OT and DT multipliers apply. Critical for wage and hour compliance and DOL audit defense.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBlendedRate rdf:type rdf:Property ;
    rdfs:label 'Is Blended Rate' ;
    rdfs:comment 'Indicates whether this pay rate is a blended rate covering multiple job duties or skill levels within a single assignment. True = blended rate applies; False = single-role rate. Common in SOW engagements and multi-skill temporary placements.' ;
    rdfs:domain ind:PayRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxStraightTimeHours rdf:type rdf:Property ;
    rdfs:label 'Max Straight Time Hours' ;
    rdfs:comment 'Maximum number of hours per week or pay period at the regular pay rate before overtime (OT) rates apply. Typically 40 hours per week under FLSA, but may be lower per client contract or state law (e.g., California daily OT threshold). Drives OT calculation trigger in TempWorks Payroll.' ;
    rdfs:domain ind:PayRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minGuaranteedHours rdf:type rdf:Property ;
    rdfs:label 'Min Guaranteed Hours' ;
    rdfs:comment 'Minimum number of hours per pay period the worker is guaranteed to be paid, regardless of actual hours worked. Common in certain staffing contracts and SOW engagements. Impacts gross pay floor calculation in TempWorks Payroll.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Ot Rate Multiplier' ;
    rdfs:comment 'Multiplier applied to the regular pay rate to calculate the overtime (OT) pay rate. Standard FLSA minimum is 1.5x for hours over 40 per week. May be higher per client contract or state law. Applied by TempWorks Payroll for OT hours on timesheets.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payGrade rdf:type rdf:Property ;
    rdfs:label 'Pay Grade' ;
    rdfs:comment 'Internal compensation band or grade classification assigned to this pay rate (e.g., G1, G2, Band A). Used for workforce analytics, compensation equity analysis, and EEOC/OFCCP reporting on pay equity across worker populations.' ;
    rdfs:domain ind:PayRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ptoAccrualEligible rdf:type rdf:Property ;
    rdfs:label 'Pto Accrual Eligible' ;
    rdfs:comment 'Indicates whether the worker accrues Paid Time Off (PTO) under this pay rate configuration. Eligibility may depend on assignment duration, worker classification, or client program rules. Drives PTO accrual processing in TempWorks Payroll.' ;
    rdfs:domain ind:PayRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ptoAccrualRate rdf:type rdf:Property ;
    rdfs:label 'Pto Accrual Rate' ;
    rdfs:comment 'Rate at which PTO hours accrue per hour worked or per pay period, expressed in hours. For example, 0.0385 hours of PTO per hour worked equates to approximately 1 week of PTO per year. Populated only when pto_accrual_eligible = True.' ;
    rdfs:domain ind:PayRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCode rdf:type rdf:Property ;
    rdfs:label 'Rate Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this pay rate configuration within TempWorks Payroll and Beeline VMS. Used for rate card lookups and VMS-driven rate matching.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateNegotiationNotes rdf:type rdf:Property ;
    rdfs:label 'Rate Negotiation Notes' ;
    rdfs:comment 'Free-text notes documenting the rationale, context, or special conditions behind the negotiated pay rate. May include references to candidate counter-offers, market data justifications, or client-specific rate exceptions. Supports recruiter and account manager context for future rate reviews.' ;
    rdfs:domain ind:PayRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateSource rdf:type rdf:Property ;
    rdfs:label 'Rate Source' ;
    rdfs:comment 'Origin of the pay rate determination. Negotiated = individually agreed with worker; vms_driven = rate set by Vendor Management System (VMS) such as Beeline; standard = internal standard rate table; client_rate_card = derived from client-specific rate card agreement.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Classification of how the worker is compensated. Hourly = per hour worked; salary = fixed periodic amount; piece_rate = per unit produced; daily = per day worked. Drives gross pay calculation logic in TempWorks Payroll.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regularPayRate rdf:type rdf:Property ;
    rdfs:label 'Regular Pay Rate' ;
    rdfs:comment 'The base pay rate for the worker expressed in the applicable rate_type unit (e.g., dollars per hour for hourly workers, dollars per day for daily workers). This is the principal quantitative compensation fact. Used as the basis for gross pay calculation in TempWorks Payroll.' ;
    rdfs:domain ind:PayRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftDifferentialRate rdf:type rdf:Property ;
    rdfs:label 'Shift Differential Rate' ;
    rdfs:comment 'Additional pay rate amount added to the regular pay rate for workers assigned to non-standard shifts (e.g., evening, overnight, weekend). Expressed as a flat dollar amount per hour or as a percentage add-on depending on the shift_differential_type field.' ;
    rdfs:domain ind:PayRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftDifferentialType rdf:type rdf:Property ;
    rdfs:label 'Shift Differential Type' ;
    rdfs:comment 'Indicates whether the shift_differential_rate is a flat dollar amount added per hour or a percentage of the regular pay rate. Determines how TempWorks Payroll calculates the effective shift pay.' ;
    rdfs:domain ind:PayRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateCode rdf:type rdf:Property ;
    rdfs:label 'State Code' ;
    rdfs:comment 'Two-letter US state code where the worker performs services under this pay rate. Determines applicable SUTA rate, state income tax withholding rules, state-specific overtime laws, and workers comp jurisdiction. Critical for multi-state payroll compliance.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sutaStateCode rdf:type rdf:Property ;
    rdfs:label 'Suta State Code' ;
    rdfs:comment 'Two-letter state code designating the state to which SUTA (State Unemployment Tax Act) taxes are remitted for this worker. May differ from work state_code in multi-state scenarios or when the workers base state differs from the work location state.' ;
    rdfs:domain ind:PayRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:absenceRecordId rdf:type rdf:Property ;
    rdfs:label 'Absence Record Id' ;
    rdfs:comment 'Foreign key linking to timesheet.absence_record. Business justification: PTO and FMLA earnings lines must trace back to the approved absence record. Linking earnings_line.absence_record_id → timesheet.absence_record enables FMLA/PTO payroll audit trails and ensures paid le' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AbsenceRecord .

ind:originalLineEarningsLineId rdf:type rdf:Property ;
    rdfs:label 'Original Line Earnings Line Id' ;
    rdfs:comment 'Reference to the original earnings_line_id that this adjustment or correction line is reversing or modifying. Populated only when is_adjustment is True. Enables full audit trail of payroll corrections and supports prior-period adjustment reporting. Null for original (non-adjustment) earnings lines.' ;
    rdfs:domain ind:EarningsLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EarningsLine .

ind:timeEntryId rdf:type rdf:Property ;
    rdfs:label 'Time Entry Id' ;
    rdfs:comment 'Foreign key linking to timesheet.time_entry. Business justification: Each earnings line is derived from one or more time entries. Linking earnings_line.time_entry_id → timesheet.time_entry enables payroll auditors to trace each earnings line to the specific punch recor' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TimeEntry .

ind:trainingRecordId rdf:type rdf:Property ;
    rdfs:label 'Training Record Id' ;
    rdfs:comment 'Foreign key linking to credentialing.training_record. Business justification: Training pay earnings lines (orientation pay, mandatory training stipends) are directly triggered by completed training records. \'Training Pay Audit: Earnings Lines by Training Record\' is a real staff' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingRecord .

ind:earningCode rdf:type rdf:Property ;
    rdfs:label 'Earning Code' ;
    rdfs:comment 'Standardized alphanumeric code identifying the type of earning component (e.g., REG for regular pay, OT for overtime, DT for double time, HOL for holiday, PTO for paid time off, BONUS, COMM for commission, PERDIEM, EXPREIM for expense reimbursement, SHFTDIFF for shift differential). Satisfies RESOURCE_REFERENCE minimum category as the classification key for the earning type resource. Drives tax treatment, GL account mapping, and compliance reporting.' ;
    rdfs:domain ind:EarningsLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earningDescription rdf:type rdf:Property ;
    rdfs:label 'Earning Description' ;
    rdfs:comment 'Human-readable description of the earning component as it appears on the workers pay stub. Examples: Regular Hours, Overtime Pay, Holiday Pay - Labor Day, PTO Payout, Weekly Per Diem - Chicago Assignment. Provides transparency to the worker and supports payroll audit trails.' ;
    rdfs:domain ind:EarningsLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earningType rdf:type rdf:Property ;
    rdfs:label 'Earning Type' ;
    rdfs:comment 'Categorical classification of the earning component. Drives gross pay decomposition, tax withholding logic, and compliance reporting. Regular = straight-time wages; OT (Overtime) = FLSA-mandated 1.5x pay; DT (Double Time) = 2x pay per CBA or client agreement; PTO (Paid Time Off) = accrued leave payout; Per Diem = non-taxable daily allowance; Expense Reimbursement = accountable plan reimbursement. [ENUM-REF-CANDIDATE: regular|overtime|double_time|holiday|pto|bonus|commission|per_diem|expense_reimbursement|shift_differential|other — promote to reference product]' ;
    rdfs:domain ind:EarningsLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Computed gross dollar amount for this earnings line, calculated as hours_quantity multiplied by pay_rate, or as a flat amount for non-hourly earnings. Represents the workers pre-tax, pre-deduction compensation for this specific earning component. Satisfies LINE_VALUE_OR_RESULT minimum category for TRANSACTION_LINE role. Feeds into gross pay totals on the pay stub.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursQuantity rdf:type rdf:Property ;
    rdfs:label 'Hours Quantity' ;
    rdfs:comment 'Number of hours or units associated with this earnings line. For hour-based earnings (regular, OT, DT, holiday, PTO), this is the number of hours worked or paid. For unit-based earnings (piece rate, per diem days), this represents the unit count. Null for flat-amount earnings such as bonuses or expense reimbursements. Satisfies LINE_QUANTITY minimum category for TRANSACTION_LINE role.' ;
    rdfs:domain ind:EarningsLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAdjustment rdf:type rdf:Property ;
    rdfs:label 'Is Adjustment' ;
    rdfs:comment 'Indicates whether this earnings line is a payroll adjustment or correction entry rather than an original earnings line. True for retroactive pay corrections, prior-period adjustments, and manual override entries. Adjustment lines may carry negative gross_amount values to reverse prior earnings. Used for payroll audit and SOX compliance.' ;
    rdfs:domain ind:EarningsLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFicaSubject rdf:type rdf:Property ;
    rdfs:label 'Is Fica Subject' ;
    rdfs:comment 'Indicates whether this earning component is subject to FICA (Federal Insurance Contributions Act) taxes, comprising Social Security (6.2%) and Medicare (1.45%) withholding. False for per diem reimbursements, expense reimbursements under accountable plans, and certain non-cash fringe benefits. Critical for accurate payroll tax calculation and IRS Form 941 filing.' ;
    rdfs:domain ind:EarningsLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOvertime rdf:type rdf:Property ;
    rdfs:label 'Is Overtime' ;
    rdfs:comment 'Indicates whether this earnings line represents overtime pay as defined under FLSA (Fair Labor Standards Act) — hours worked beyond 40 in a workweek compensated at a minimum of 1.5x the regular rate. Used for FLSA compliance reporting, overtime cost analytics, and client billing reconciliation where OT bill rates differ from straight-time rates.' ;
    rdfs:domain ind:EarningsLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxable rdf:type rdf:Property ;
    rdfs:label 'Is Taxable' ;
    rdfs:comment 'Indicates whether this earning component is subject to federal and state income tax withholding. True for wages, OT, DT, holiday pay, bonuses, and commissions. False for qualifying per diem allowances within IRS GSA limits, accountable plan expense reimbursements, and certain fringe benefits. Drives FICA, FUTA, SUTA, and income tax withholding calculations.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Labor Category Code' ;
    rdfs:comment 'Classification code identifying the labor category or job classification for this earnings line (e.g., LIGHT_IND for light industrial, IT_PROF for IT professional, CLERICAL, HEALTHCARE). Used for workforce cost analytics, bill rate reconciliation, and compliance with prevailing wage determinations under DOL regulations. Aligns with timesheet.labor_category.' ;
    rdfs:domain ind:EarningsLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineSequence rdf:type rdf:Property ;
    rdfs:label 'Line Sequence' ;
    rdfs:comment 'Sequential line number ordering this earnings component within the parent pay stub. Satisfies LINE_SEQUENCE minimum category for TRANSACTION_LINE role. Used for display ordering on pay stubs and for deterministic processing order during gross pay calculation.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current processing status of this earnings line within the payroll workflow. Pending = awaiting payroll approval; Approved = authorized for payment; Processed = included in a completed payroll run; Voided = cancelled/reversed; Adjusted = corrected via an adjustment entry. Satisfies LIFECYCLE_STATUS minimum category for TRANSACTION_LINE role.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otMultiplier rdf:type rdf:Property ;
    rdfs:label 'Ot Multiplier' ;
    rdfs:comment 'The pay rate multiplier applied to the base pay rate for premium pay earnings. Standard values: 1.0000 for regular pay, 1.5000 for OT (overtime), 2.0000 for DT (double time). May reflect CBA (collective bargaining agreement) or client-specific premium rates. Used to validate gross_amount calculation and support FLSA compliance audits.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perDiemRateDaily rdf:type rdf:Property ;
    rdfs:label 'Per Diem Rate Daily' ;
    rdfs:comment 'The daily per diem rate applied for this earnings line when earning_type is per_diem. Compared against GSA (General Services Administration) published rates to determine taxability — amounts within GSA limits are non-taxable; excess amounts are taxable wages. Null for non-per-diem earning types.' ;
    rdfs:domain ind:EarningsLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perDiemType rdf:type rdf:Property ;
    rdfs:label 'Per Diem Type' ;
    rdfs:comment 'Classification of per diem allowance type when earning_type is per_diem. Lodging = accommodation allowance; Meals and Incidentals (M&IE) = daily meal and incidental expense allowance; Combined = single daily rate covering both; None = not a per diem line. GSA per diem rates determine taxability thresholds. Null or none for non-per-diem earning types.' ;
    rdfs:domain ind:EarningsLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prevailingWageFlag rdf:type rdf:Property ;
    rdfs:label 'Prevailing Wage Flag' ;
    rdfs:comment 'Indicates whether this earnings line is subject to prevailing wage requirements under the Davis-Bacon Act, Service Contract Act, or state prevailing wage laws. True for government contract assignments requiring certified payroll reporting. Triggers additional compliance reporting obligations to DOL and OFCCP.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Code identifying the work shift associated with this earnings line (e.g., DAY, EVE for evening, NIGHT, WKND for weekend). Used to apply shift differential pay rates and to reconcile earnings with Kronos Workforce Ready scheduling data. Relevant for shift_differential earning types.' ;
    rdfs:domain ind:EarningsLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRef rdf:type rdf:Property ;
    rdfs:label 'Source System Ref' ;
    rdfs:comment 'The native record identifier from the originating payroll system (TempWorks Payroll) for this earnings line. Enables traceability and reconciliation between the lakehouse silver layer and the operational system of record. Used for audit trails, data lineage, and dispute resolution.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workStateCode rdf:type rdf:Property ;
    rdfs:label 'Work State Code' ;
    rdfs:comment 'Two-letter US state code where the work was performed for this earnings line. Drives state income tax withholding, SUTA (State Unemployment Tax Act) employer contributions, state-specific overtime rules, and workers compensation premium allocation. Critical for multi-state payroll compliance in staffing operations where workers may be deployed across multiple states.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxLineId rdf:type rdf:Property ;
    rdfs:label 'Tax Line Id' ;
    rdfs:comment 'Primary key for tax_line' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalTaxLineId rdf:type rdf:Property ;
    rdfs:label 'Original Tax Line Id' ;
    rdfs:comment 'Reference to the original tax line record that this adjustment line corrects or reverses. Null for original (non-adjustment) lines. Enables audit trail linking between original and corrected tax line records.' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxLine .

ind:taxFilingId rdf:type rdf:Property ;
    rdfs:label 'Tax Filing Id' ;
    rdfs:comment 'Foreign key linking to payroll.tax_filing. Business justification: Tax line records (individual tax obligations per pay stub) feed into aggregate tax filings (941, state quarterly filings). Adding FK tax_filing_id → tax_filing.payroll_tax_filing_id links each tax_lin' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxFiling .

ind:taxWithholdingElectionId rdf:type rdf:Property ;
    rdfs:label 'Tax Withholding Election Id' ;
    rdfs:comment 'Foreign key linking to payroll.tax_withholding_election. Business justification: Tax withholding execution (tax_line) should reference the workers tax withholding election (W-4 form data) that drove the calculation. tax_line currently has denormalized attributes filing_status, al' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxWithholdingElection .

ind:addMedicareSurtaxFlag rdf:type rdf:Property ;
    rdfs:label 'Add Medicare Surtax Flag' ;
    rdfs:comment 'Indicates whether this tax line represents the Additional Medicare Tax (0.9% surtax) applicable to high-earning employees whose wages exceed the IRS threshold ($200,000 for single filers). Employer does not match this surtax.' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Flag' ;
    rdfs:comment 'Indicates whether this tax line is an adjustment or correction to a previously processed tax line (e.g., retroactive rate change, prior-period correction, amended return adjustment). When True, adjustment_reason should be populated.' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Free-text description of the reason for a tax line adjustment when adjustment_flag is True (e.g., Retroactive SUTA rate change Q1 2024, W-4 correction applied, Prior period underpayment correction).' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:computedAmount rdf:type rdf:Property ;
    rdfs:label 'Computed Amount' ;
    rdfs:comment 'The calculated tax dollar amount for this line in the current pay period (taxable_wage_base × tax_rate, or flat amount for flat-rate taxes). Core value used in gross-to-net calculation and payroll tax remittance. TRANSACTION_LINE LINE_VALUE_OR_RESULT category.' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositSchedule rdf:type rdf:Property ;
    rdfs:label 'Deposit Schedule' ;
    rdfs:comment 'The employers IRS-assigned federal tax deposit schedule for this tax type (monthly, semi-weekly, or next-day for large deposits). Determines the tax_deposit_liability_date. State deposit schedules may differ.' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:futaCreditRate rdf:type rdf:Property ;
    rdfs:label 'Futa Credit Rate' ;
    rdfs:comment 'The FUTA state tax credit rate (up to 5.4%) applied to reduce the gross FUTA rate of 6.0% when the employer has paid SUTA taxes in a credit-reduction state. Applies only to FUTA tax type lines.' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remittanceStatus rdf:type rdf:Property ;
    rdfs:label 'Remittance Status' ;
    rdfs:comment 'Current status of the tax remittance for this line to the applicable tax authority. Tracks whether the tax has been deposited on time, is pending, was remitted late (triggering penalty exposure), has been adjusted, or voided. TRANSACTION_LINE LIFECYCLE_STATUS category.' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'The native record identifier from TempWorks Payroll (the system of record) for this tax line. Enables traceability and reconciliation between the lakehouse Silver layer and the operational payroll system.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sutaExperienceRate rdf:type rdf:Property ;
    rdfs:label 'Suta Experience Rate' ;
    rdfs:comment 'The employers SUTA experience-rated tax rate for the applicable state, as assigned by the state unemployment agency based on the companys claims history. Applies only to SUTA tax type lines. Drives burden rate calculations.' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sutaState rdf:type rdf:Property ;
    rdfs:label 'Suta State' ;
    rdfs:comment 'Two-letter state code identifying the state to which SUTA taxes are remitted for this worker. May differ from the workers work state in multi-state assignments. Applies only to SUTA tax type lines.' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Level' ;
    rdfs:comment 'Level of government authority imposing this tax obligation. Supports multi-state payroll compliance and jurisdiction-level tax filing and reporting.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDepositLiabilityDate rdf:type rdf:Property ;
    rdfs:label 'Tax Deposit Liability Date' ;
    rdfs:comment 'The date by which the employer must remit this tax to the applicable tax authority (IRS, state, or local). Determined by the employers deposit schedule (monthly or semi-weekly for federal; varies by state). Critical for avoiding late deposit penalties.' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'Indicates whether the worker is exempt from this specific tax type (e.g., FICA exemption for certain visa holders, FUTA exemption for specific worker categories). When True, computed_amount is zero and the exemption basis should be documented.' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxExemptReason rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Reason' ;
    rdfs:comment 'Reason or basis for the tax exemption when tax_exempt_flag is True (e.g., F-1 Visa FICA Exemption, W-4 Exempt Election, Agricultural Worker FUTA Exemption). Required for compliance audit trail.' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionFips rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Fips' ;
    rdfs:comment 'Five-digit FIPS code uniquely identifying the county or county-equivalent jurisdiction for this tax line. Enables precise multi-state and local tax jurisdiction mapping and filing.' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionLocality rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Locality' ;
    rdfs:comment 'Name of the local taxing jurisdiction (city, county, municipality, school district) for local/city tax lines. Null for federal and state-level taxes. Supports local tax filing compliance.' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionState rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction State' ;
    rdfs:comment 'Two-letter U.S. state code (USPS abbreviation) for the state in which this tax obligation applies. Null for federal-only taxes. Critical for multi-state payroll tax filing and SUTA rate management.' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'The effective tax rate (as a decimal fraction, e.g., 0.062000 for 6.2%) applied to the taxable wage base to compute the tax amount for this line. For flat-dollar taxes, this may be zero with the flat amount captured in computed_amount.' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxSide rdf:type rdf:Property ;
    rdfs:label 'Tax Side' ;
    rdfs:comment 'Discriminator indicating whether this tax line represents an employee-side withholding (deducted from worker gross pay) or an employer-side tax obligation (borne by the staffing company). Critical for gross-to-net calculation and burden rate validation. TRANSACTION_LINE LINE_VALUE_OR_RESULT category (discriminator).' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxTypeCode rdf:type rdf:Property ;
    rdfs:label 'Tax Type Code' ;
    rdfs:comment 'Standardized code identifying the specific type of tax obligation on this line (e.g., FIT, SIT, FICA_SS_EE, FICA_MED_EE, FICA_SS_ER, FICA_MED_ER, FUTA, SUTA, LOCAL, ADD_MED, SUPP). Used for tax filing, reporting, and reconciliation. [ENUM-REF-CANDIDATE: FIT|SIT|LOCAL|FICA_SS_EE|FICA_MED_EE|FICA_SS_ER|FICA_MED_ER|FUTA|SUTA|ADD_MED|SUPP — promote to reference product]' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxTypeName rdf:type rdf:Property ;
    rdfs:label 'Tax Type Name' ;
    rdfs:comment 'Human-readable name of the tax type (e.g., Federal Income Tax, California State Income Tax, FICA Social Security Employee, Federal Unemployment Tax). Displayed on pay stubs and tax reports.' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableWageBase rdf:type rdf:Property ;
    rdfs:label 'Taxable Wage Base' ;
    rdfs:comment 'The portion of the workers gross wages subject to this specific tax in the current pay period, after applying any applicable wage base caps (e.g., Social Security wage base, FUTA/SUTA wage base limits). TRANSACTION_LINE LINE_QUANTITY category.' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wageBaseAnnualLimit rdf:type rdf:Property ;
    rdfs:label 'Wage Base Annual Limit' ;
    rdfs:comment 'The annual taxable wage base ceiling for this tax type (e.g., $168,600 for Social Security in 2024; $7,000 for FUTA). Once the workers YTD wages exceed this limit, no further tax is assessed for this tax type in the calendar year.' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wageBaseCapReached rdf:type rdf:Property ;
    rdfs:label 'Wage Base Cap Reached' ;
    rdfs:comment 'Indicates whether the worker has reached the annual taxable wage base ceiling for this tax type in the current calendar year. When True, no further tax is assessed for this tax type until the next calendar year reset.' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:withholdingMethod rdf:type rdf:Property ;
    rdfs:label 'Withholding Method' ;
    rdfs:comment 'Method used to calculate the tax withholding for this line: percentage of taxable wages, flat dollar amount, IRS tax table lookup, supplemental flat rate, or exempt (no withholding). Drives the calculation logic applied in TempWorks Payroll.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerTaxFormType rdf:type rdf:Property ;
    rdfs:label 'Worker Tax Form Type' ;
    rdfs:comment 'Indicates whether the worker is classified as a W-2 employee (subject to withholding) or a 1099 independent contractor (IC) for this tax line. Drives which tax obligations apply and which annual tax form is issued. Aligns with IRS worker classification rules.' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ytdTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Ytd Tax Amount' ;
    rdfs:comment 'Cumulative tax amount withheld or assessed for this worker under this tax type from the start of the calendar year through and including this pay period. Critical for quarterly (941/940) and annual (W-2/1099) tax reconciliation and filing.' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ytdTaxableWages rdf:type rdf:Property ;
    rdfs:label 'Ytd Taxable Wages' ;
    rdfs:comment 'Cumulative taxable wages for this worker under this tax type from the start of the calendar year through and including this pay period. Used to enforce annual wage base limits and for W-2/1099 annual reconciliation.' ;
    rdfs:domain ind:TaxLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductionLineId rdf:type rdf:Property ;
    rdfs:label 'Deduction Line Id' ;
    rdfs:comment 'Unique system-generated identifier for each deduction line item on a worker pay stub. Primary key for the deduction_line product. Entity role: TRANSACTION_LINE — represents one deduction item within a payroll check/pay stub header.' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Limit Amount' ;
    rdfs:comment 'Maximum dollar amount that may be withheld for this deduction type in a calendar year, as set by IRS regulations or plan rules (e.g., IRS 401k elective deferral limit, FSA annual contribution cap, HSA annual contribution limit). Used to automatically stop withholding once the limit is reached. Null for deductions with no annual cap.' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arrearsAmount rdf:type rdf:Property ;
    rdfs:label 'Arrears Amount' ;
    rdfs:comment 'Dollar amount of deduction that was missed in a prior pay period and is being carried forward for collection in a subsequent period. Common for garnishments when disposable earnings were insufficient to cover the full order amount, or for benefit premiums missed during a leave of absence. Zero if no arrears exist.' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitCarrierName rdf:type rdf:Property ;
    rdfs:label 'Benefit Carrier Name' ;
    rdfs:comment 'Name of the insurance carrier or financial institution administering the benefit plan associated with this deduction (e.g., Aetna, MetLife, Fidelity Investments, WageWorks). Used for carrier remittance reconciliation and benefits vendor management. Null for non-benefit deductions.' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitEnrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Benefit Enrollment Status' ;
    rdfs:comment 'Current enrollment status of the worker in the benefit plan driving this deduction. Determines whether premium withholding should be active. COBRA status indicates the worker is continuing coverage under COBRA after employment separation. Null for non-benefit deductions.' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitPlanName rdf:type rdf:Property ;
    rdfs:label 'Benefit Plan Name' ;
    rdfs:comment 'Name of the employer-sponsored benefit plan associated with this deduction (e.g., Aetna PPO Gold, Delta Dental Premier, VSP Vision Basic, Fidelity 401k Plan). Populated only for benefit-type deductions. Sourced from the benefit enrollment record and used for benefits administration reporting and carrier remittance.' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitPlanType rdf:type rdf:Property ;
    rdfs:label 'Benefit Plan Type' ;
    rdfs:comment 'Classification of the benefit plan type driving this deduction. Used to categorize benefit deductions for ACA reporting, W-2 Box 12 coding, and benefits analytics. Null for non-benefit deductions. [ENUM-REF-CANDIDATE: medical|dental|vision|401k|roth_401k|fsa|hsa|life|supplemental — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courtOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Court Order Number' ;
    rdfs:comment 'Official court case number or agency order reference for garnishment-type deductions (child support, tax levy, creditor garnishment). Required for legal compliance and remittance to the issuing court or agency. Null for non-garnishment deductions.' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageTier rdf:type rdf:Property ;
    rdfs:label 'Coverage Tier' ;
    rdfs:comment 'The coverage tier elected by the worker for this benefit plan, which determines the premium amount withheld. Applicable to medical, dental, and vision benefit deductions. Values: employee_only (single coverage), employee_spouse (worker plus spouse/domestic partner), employee_children (worker plus dependents), family (worker plus all dependents). Null for non-benefit deductions.' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionAmount rdf:type rdf:Property ;
    rdfs:label 'Deduction Amount' ;
    rdfs:comment 'Dollar amount withheld from the workers gross pay for this deduction line in the current pay period. For benefit deductions, represents the employee premium contribution. For garnishments, represents the court-ordered withholding amount. TRANSACTION_LINE role: LINE_VALUE_OR_RESULT — the principal monetary fact for this line.' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductionCategory rdf:type rdf:Property ;
    rdfs:label 'Deduction Category' ;
    rdfs:comment 'Granular business category of the deduction used for benefits administration reporting, compliance, and analytics. Distinguishes benefit plan types (medical, dental, vision, 401k, FSA, HSA, life, supplemental) from garnishment subtypes (child_support, tax_levy, creditor_garnishment, student_loan) and other voluntary deductions. [ENUM-REF-CANDIDATE: medical|dental|vision|401k|roth_401k|fsa|hsa|life|supplemental|child_support|tax_levy|creditor_garnishment|student_loan|uniform|other — promote to reference product]' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionCode rdf:type rdf:Property ;
    rdfs:label 'Deduction Code' ;
    rdfs:comment 'Standardized alphanumeric code identifying the specific deduction type as configured in the payroll system (e.g., MED01, DENT01, 401K, GARNCS, UNIFEE). Maps to the deduction setup table in TempWorks Payroll and drives calculation rules, GL account mapping, and tax treatment.' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionFrequency rdf:type rdf:Property ;
    rdfs:label 'Deduction Frequency' ;
    rdfs:comment 'How often this deduction is applied to the workers paycheck. Drives whether the deduction is taken every pay period or on a specific schedule (e.g., some benefit premiums are taken only on first and third paycheck of the month for semimonthly payroll). [ENUM-REF-CANDIDATE: per_pay_period|weekly|biweekly|semimonthly|monthly|quarterly|annual|one_time — promote to reference product]' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionName rdf:type rdf:Property ;
    rdfs:label 'Deduction Name' ;
    rdfs:comment 'Human-readable name of the deduction as it appears on the workers pay stub (e.g., Medical Insurance - Employee, Child Support Garnishment, 401(k) Contribution). Sourced from the deduction code setup in TempWorks Payroll.' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionStatus rdf:type rdf:Property ;
    rdfs:label 'Deduction Status' ;
    rdfs:comment 'Current lifecycle status of this deduction line: active (currently being withheld), suspended (temporarily halted, e.g., worker on leave), terminated (permanently stopped, e.g., benefit cancelled or garnishment satisfied), pending (set up but not yet effective), waived (worker or employer elected to waive for this period). TRANSACTION_LINE role: maps to LIFECYCLE_STATUS of the deduction arrangement.' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionType rdf:type rdf:Property ;
    rdfs:label 'Deduction Type' ;
    rdfs:comment 'Classification of the deduction by tax treatment and origin: pre_tax (reduces taxable gross, e.g., 401k, FSA, HSA, Section 125 benefits), post_tax (applied after tax calculation, e.g., Roth 401k, after-tax life insurance), benefit (employer-sponsored benefit premium withholding), garnishment (court-ordered or agency-mandated wage withholding), voluntary (worker-elected non-benefit deduction). Drives gross-to-net calculation sequencing.' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Amount' ;
    rdfs:comment 'Dollar amount contributed by the employer toward this benefit deduction in the current pay period (e.g., employer share of medical premium, employer 401k match). Applicable only to benefit-type deductions. Zero or null for garnishments and purely employee-funded deductions. Used in total compensation reporting and burden rate calculations.' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Effective Date' ;
    rdfs:comment 'Date on which the workers benefit enrollment became effective, triggering the start of premium withholding for this deduction. May differ from the deduction effective_date if there is a retroactive enrollment adjustment. Null for non-benefit deductions.' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Termination Date' ;
    rdfs:comment 'Date on which the workers benefit enrollment ended, triggering cessation of premium withholding. Populated when a worker loses eligibility, voluntarily cancels coverage, or separates from employment. Null if enrollment is ongoing. Null for non-benefit deductions.' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:garnishmentIssuingAgency rdf:type rdf:Property ;
    rdfs:label 'Garnishment Issuing Agency' ;
    rdfs:comment 'Name of the court, government agency, or child support enforcement agency that issued the garnishment order (e.g., Cook County Circuit Court, IRS, Illinois DCSS). Used for remittance routing and compliance documentation. Null for non-garnishment deductions.' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:garnishmentRemittanceDate rdf:type rdf:Property ;
    rdfs:label 'Garnishment Remittance Date' ;
    rdfs:comment 'Date by which the withheld garnishment amount must be remitted to the issuing court or agency. Derived from the court order terms and state-specific remittance deadlines. Null for non-garnishment deductions.' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isArrearsRecovery rdf:type rdf:Property ;
    rdfs:label 'Is Arrears Recovery' ;
    rdfs:comment 'Indicates whether this deduction line represents a recovery of a previously missed (arrears) deduction amount rather than a standard current-period deduction. True when the deduction_amount includes or consists entirely of arrears recovery. Used to distinguish regular deductions from catch-up withholdings in payroll analytics.' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFicaExempt rdf:type rdf:Property ;
    rdfs:label 'Is Fica Exempt' ;
    rdfs:comment 'Indicates whether this deduction amount is exempt from FICA (Social Security and Medicare) taxes. True for qualified Section 125 benefit deductions and HSA employer contributions. False for most other deductions. Drives FICA taxable wage base calculation in payroll processing.' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPretax rdf:type rdf:Property ;
    rdfs:label 'Is Pretax' ;
    rdfs:comment 'Indicates whether this deduction reduces the workers taxable gross wages before FICA, federal income tax, and applicable state income tax are calculated. True for Section 125 cafeteria plan deductions (medical, dental, vision, FSA), traditional 401k contributions, and HSA contributions. False for post-tax deductions such as Roth 401k and after-tax life insurance. Critical for accurate gross-to-net payroll calculation.' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Date on which this deduction arrangement was or is scheduled to be permanently stopped. For benefit deductions, aligns with benefit enrollment termination or coverage end date. For garnishments, the date the order is satisfied or released. Null if the deduction is ongoing with no defined end.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:w2BoxCode rdf:type rdf:Property ;
    rdfs:label 'W2 Box Code' ;
    rdfs:comment 'IRS W-2 form box code under which this deduction amount must be reported at year-end (e.g., D for 401k elective deferrals, W for HSA employer contributions, DD for employer-sponsored health coverage cost). Drives W-2 generation in TempWorks Payroll. Null for deductions not reportable on W-2.' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ytdDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Ytd Deduction Amount' ;
    rdfs:comment 'Cumulative total of this deduction withheld from the workers pay from the start of the calendar year through and including the current pay period. Used for W-2 reporting, IRS annual contribution limit enforcement (e.g., 401k IRS limit, FSA/HSA annual caps), and year-end tax reconciliation.' ;
    rdfs:domain ind:DeductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryOtBurdenRateId rdf:type rdf:Property ;
    rdfs:label 'Primary Ot Burden Rate Id' ;
    rdfs:comment 'Reference to the burden rate record applicable to overtime (OT) hours for this worker classification and state. Overtime pay triggers different FICA and WC cost calculations. Null if the same burden rate applies to both regular and OT hours.' ;
    rdfs:domain ind:BurdenRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BurdenRate .

ind:tertiarySupersededByBurdenRateId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Superseded By Burden Rate Id' ;
    rdfs:comment 'Reference to the burden rate record that replaced this record when status is superseded. Enables forward navigation in the rate version chain for audit and historical analysis.' ;
    rdfs:domain ind:BurdenRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BurdenRate .

ind:vendorAgreementId rdf:type rdf:Property ;
    rdfs:label 'Vendor Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.vendor_agreement. Business justification: Vendor agreement\'s markup_cap_percentage directly constrains burden rate calculations for supplier-provided workers. Staffing finance teams validate burden rates against vendor agreement markup caps d' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorAgreement .

ind:applicabilityScope rdf:type rdf:Property ;
    rdfs:label 'Applicability Scope' ;
    rdfs:comment 'Defines the scope at which this burden rate is applied: enterprise_wide (default for all placements), client_specific (negotiated rate for a specific client account), assignment_specific (applied to a single placement or assignment), or branch_specific (applicable to a specific branch or division).' ;
    rdfs:domain ind:BurdenRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitsLoadPercent rdf:type rdf:Property ;
    rdfs:label 'Benefits Load Percent' ;
    rdfs:comment 'Employer-paid benefits cost expressed as a percentage of gross wages included in the burden rate. Covers health insurance, dental, vision, 401(k) match, and other statutory or voluntary benefits provided to workers. Varies by worker classification and benefit plan enrollment.' ;
    rdfs:domain ind:BurdenRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:burdenRateStatus rdf:type rdf:Property ;
    rdfs:label 'Burden Rate Status' ;
    rdfs:comment 'Current lifecycle status of the burden rate record. active indicates the rate is in use for payroll cost calculations; superseded indicates a newer version has replaced this record; draft indicates pending approval before activation.' ;
    rdfs:domain ind:BurdenRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Type of staffing engagement to which this burden rate applies. Temporary and contract placements typically carry higher WC and benefits burden; direct hire placements may carry only a placement fee structure. Temp-to-perm engagements may have conversion fee implications.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ficaEmployerRate rdf:type rdf:Property ;
    rdfs:label 'Fica Employer Rate' ;
    rdfs:comment 'Employers share of FICA tax expressed as a percentage of gross wages (e.g., 7.6500 for 7.65%). Comprises Social Security (6.2%) and Medicare (1.45%) employer contributions. Applied to gross pay up to applicable wage bases per IRS regulations.' ;
    rdfs:domain ind:BurdenRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:futaRate rdf:type rdf:Property ;
    rdfs:label 'Futa Rate' ;
    rdfs:comment 'Federal Unemployment Tax Act employer tax rate expressed as a percentage of gross wages (e.g., 0.6000 for 0.60% net after state credit). Applied to the first $7,000 of each employees wages per calendar year per IRS regulations.' ;
    rdfs:domain ind:BurdenRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:generalLiabilityRate rdf:type rdf:Property ;
    rdfs:label 'General Liability Rate' ;
    rdfs:comment 'General liability insurance cost expressed as a percentage of gross payroll included in the employer burden structure. Covers third-party bodily injury and property damage claims arising from staffing operations.' ;
    rdfs:domain ind:BurdenRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isEorModel rdf:type rdf:Property ;
    rdfs:label 'Is Eor Model' ;
    rdfs:comment 'Indicates whether this burden rate applies to an Employer of Record (EOR) engagement model where the staffing firm acts as the legal employer of record for co-employment or client-directed workforce arrangements. EOR models carry distinct burden and compliance obligations.' ;
    rdfs:domain ind:BurdenRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPeoModel rdf:type rdf:Property ;
    rdfs:label 'Is Peo Model' ;
    rdfs:comment 'Indicates whether this burden rate applies to a Professional Employer Organization (PEO) co-employment model where the PEO assumes employer tax and benefits obligations. PEO burden structures differ from standard staffing burden rates.' ;
    rdfs:domain ind:BurdenRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markupPercent rdf:type rdf:Property ;
    rdfs:label 'Markup Percent' ;
    rdfs:comment 'Target markup percentage applied over the pay rate to derive the bill rate, incorporating the total burden and desired gross margin. Used in spread analysis and client billing validation. Expressed as a percentage of pay rate (e.g., 45.00 = 45% markup).' ;
    rdfs:domain ind:BurdenRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for payroll analysts or finance staff to document special conditions, exceptions, carrier negotiation details, or regulatory basis for this burden rate configuration. Supports audit documentation and knowledge transfer.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overheadPercent rdf:type rdf:Property ;
    rdfs:label 'Overhead Percent' ;
    rdfs:comment 'Internal overhead allocation expressed as a percentage of gross wages included in the burden rate. Covers branch operating costs, recruiter commissions, back-office administration, and other indirect costs attributable to workforce deployment.' ;
    rdfs:domain ind:BurdenRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payRateMax rdf:type rdf:Property ;
    rdfs:label 'Pay Rate Max' ;
    rdfs:comment 'Maximum hourly pay rate threshold (in USD) at which this burden rate structure is applicable. Defines the upper bound of the pay rate band for this burden rate. Null indicates no upper limit.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payRateMin rdf:type rdf:Property ;
    rdfs:label 'Pay Rate Min' ;
    rdfs:comment 'Minimum hourly pay rate threshold (in USD) at which this burden rate structure is applicable. Used to define pay rate banding for tiered burden rate structures where different pay levels carry different overhead or benefits loads.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateName rdf:type rdf:Property ;
    rdfs:label 'Rate Name' ;
    rdfs:comment 'Human-readable descriptive name for the burden rate structure (e.g., California Light Industrial WC Class 5403 2024). Used in reporting, dashboards, and analyst-facing tools.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sutaRate rdf:type rdf:Property ;
    rdfs:label 'Suta Rate' ;
    rdfs:comment 'State Unemployment Tax Act employer contribution rate expressed as a percentage of gross wages for the applicable state jurisdiction. Varies by state experience rating, industry classification, and annual state-assigned rate notices. Applied to state-specific taxable wage bases.' ;
    rdfs:domain ind:BurdenRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sutaWageBase rdf:type rdf:Property ;
    rdfs:label 'Suta Wage Base' ;
    rdfs:comment 'Maximum annual gross wages per employee subject to SUTA tax in the applicable state jurisdiction (e.g., $7,000 in some states, $56,500 in others). Required for accurate SUTA cost modeling and burden rate calculation.' ;
    rdfs:domain ind:BurdenRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetGrossMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Target Gross Margin Percent' ;
    rdfs:comment 'Target gross margin percentage for placements using this burden rate structure, representing the desired spread (bill rate minus total employer cost) as a percentage of bill rate. Used in profitability reporting and bill rate validation.' ;
    rdfs:domain ind:BurdenRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBurdenPercent rdf:type rdf:Property ;
    rdfs:label 'Total Burden Percent' ;
    rdfs:comment 'Aggregate employer burden rate expressed as a percentage of gross wages, representing the sum of all burden components (FICA employer share, FUTA, SUTA, WC, general liability, benefits load, and overhead). Used to compute total employer cost per worker hour and validate bill rate margins. Note: this is a stored configuration value, not a real-time computed aggregate.' ;
    rdfs:domain ind:BurdenRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Sequential version number for this burden rate record, incremented each time the rate structure is updated. Supports rate versioning and historical rate lookups for payroll audits and retroactive adjustments.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wcBaseRatePer100 rdf:type rdf:Property ;
    rdfs:label 'Wc Base Rate Per 100' ;
    rdfs:comment 'Workers Compensation insurance premium base rate expressed as dollars per $100 of gross payroll for the applicable NCCI class code and state jurisdiction (e.g., 2.3500 = $2.35 per $100). This is the primary WC cost driver in the burden rate structure.' ;
    rdfs:domain ind:BurdenRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wcClassDescription rdf:type rdf:Property ;
    rdfs:label 'Wc Class Description' ;
    rdfs:comment 'Human-readable description of the NCCI Workers Compensation class code (e.g., Carpentry — Construction, Clerical Office Employees). Used in reporting, audits, and WC policy documentation.' ;
    rdfs:domain ind:BurdenRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wcExperienceModFactor rdf:type rdf:Property ;
    rdfs:label 'Wc Experience Mod Factor' ;
    rdfs:comment 'Experience modification factor (e-mod) applied to the WC base rate to adjust premiums based on the employers actual loss history relative to industry average. Values below 1.0 indicate better-than-average loss history; above 1.0 indicates worse. Sourced from WC carrier or NCCI.' ;
    rdfs:domain ind:BurdenRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wcHazardCategory rdf:type rdf:Property ;
    rdfs:label 'Wc Hazard Category' ;
    rdfs:comment 'Risk hazard category assigned to the WC NCCI class code indicating the relative injury risk level of the job duties. Used for internal risk segmentation, pricing decisions, and WC carrier negotiations.' ;
    rdfs:domain ind:BurdenRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wcNcciClassCode rdf:type rdf:Property ;
    rdfs:label 'Wc Ncci Class Code' ;
    rdfs:comment 'Four-digit NCCI Workers Compensation classification code identifying the job duty category for WC premium calculation (e.g., 5403 for Carpentry, 8810 for Clerical Office). Drives WC base rate per $100 of payroll and is the primary driver of WC cost in staffing operations.' ;
    rdfs:domain ind:BurdenRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Audit Adjustment Amount' ;
    rdfs:comment 'The dollar amount of premium adjustment resulting from the most recent carrier audit, representing the difference between estimated premiums paid and actual earned premium based on audited payroll. Positive values indicate additional premium owed; negative values indicate a return premium credit.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditFrequency rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency' ;
    rdfs:comment 'The frequency at which the insurance carrier conducts a premium audit to reconcile estimated premiums against actual payroll. Staffing firms with high payroll volume often negotiate more frequent audits to reduce year-end true-up exposure.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseRatePer100 rdf:type rdf:Property ;
    rdfs:label 'Base Rate Per 100' ;
    rdfs:comment 'The manual (base) WC premium rate expressed as a dollar amount per $100 of covered payroll for the associated class code and state jurisdiction, before application of the experience modification factor (EMR). Sourced from the applicable state rating bureau or NCCI.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:burdenRateWcComponent rdf:type rdf:Property ;
    rdfs:label 'Burden Rate Wc Component' ;
    rdfs:comment 'The WC premium cost expressed as a decimal rate applied to gross payroll, representing the WC component of the total employer burden rate. Used in bill rate calculations, spread analysis, and gross margin reporting. Derived from the modified rate and historical payroll mix for this class code.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierNaicCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Naic Code' ;
    rdfs:comment 'The five-digit NAIC company code assigned to the insurance carrier by the National Association of Insurance Commissioners. Used for regulatory identification and carrier verification in multi-state WC compliance.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'The legal name of the insurance carrier or underwriter providing the workers compensation coverage under this policy. Used for carrier reporting, premium remittance, and audit correspondence.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientCostAllocationCode rdf:type rdf:Property ;
    rdfs:label 'Client Cost Allocation Code' ;
    rdfs:comment 'The internal cost allocation code used to attribute WC premium costs to specific client accounts or job orders. Enables client-level WC cost reporting, profitability analysis, and accurate bill rate construction inclusive of WC burden.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coEmploymentFlag rdf:type rdf:Property ;
    rdfs:label 'Co Employment Flag' ;
    rdfs:comment 'Indicates whether this WC policy record involves a co-employment arrangement where both the staffing firm and the client share employer responsibilities. Affects WC coverage determination and premium allocation between parties.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:computedPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Computed Premium Amount' ;
    rdfs:comment 'The calculated WC premium dollar amount for the premium period, computed as (payroll_subject_to_wc / 100) multiplied by the modified_rate_per_100. Represents the accrued WC cost for the period and is used in burden rate application and client cost allocation.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductibleAmountPerClaim rdf:type rdf:Property ;
    rdfs:label 'Deductible Amount Per Claim' ;
    rdfs:comment 'The per-claim deductible amount the employer is responsible for funding before the carrier pays WC benefits, applicable to large deductible programs. Zero for guaranteed cost policies. Impacts cash flow planning and loss reserve requirements.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Deposit Premium Amount' ;
    rdfs:comment 'The initial deposit premium paid to the carrier at policy inception, typically a percentage of the estimated annual premium. Represents the upfront cash outlay and is reconciled against actual earned premium at audit.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerLiabilityLimitDiseasePolicy rdf:type rdf:Property ;
    rdfs:label 'Employer Liability Limit Disease Policy' ;
    rdfs:comment 'The aggregate policy limit of employers liability coverage for bodily injury by disease. Distinct from the per-accident limit and the per-employee disease limit. Used for risk management reporting and MSA compliance verification.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerLiabilityLimitEachAccident rdf:type rdf:Property ;
    rdfs:label 'Employer Liability Limit Each Accident' ;
    rdfs:comment 'The per-occurrence limit of employers liability coverage (Part B of the WC policy) for bodily injury by accident. Standard limits are $100,000, $500,000, or $1,000,000. Used for risk management and client contract compliance.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eorFlag rdf:type rdf:Property ;
    rdfs:label 'Eor Flag' ;
    rdfs:comment 'Indicates whether this WC policy record applies to workers placed under an Employer of Record (EOR) arrangement, where the staffing firm acts as the legal employer for WC purposes. Drives co-employment risk management and premium allocation logic.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedAnnualPremium rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Premium' ;
    rdfs:comment 'The estimated total annual WC premium for this policy as projected at policy inception, based on estimated payroll and applicable rates. Used for budgeting, cash flow planning, and comparison against actual accrued premiums during the audit cycle.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:experienceModFactor rdf:type rdf:Property ;
    rdfs:label 'Experience Mod Factor' ;
    rdfs:comment 'The experience modification rate (EMR) assigned by NCCI or the applicable state rating bureau, reflecting the employers actual loss history relative to expected losses for the class. A factor below 1.0 indicates better-than-average loss experience; above 1.0 indicates worse. Applied to the base rate to compute the modified premium rate.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'The date of the most recently completed premium audit conducted by the insurance carrier. Used to track audit cycle compliance, identify overdue audits, and reconcile estimated versus actual premium balances.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lossSensitiveProgramType rdf:type rdf:Property ;
    rdfs:label 'Loss Sensitive Program Type' ;
    rdfs:comment 'For loss-sensitive policies, identifies the specific program structure. Retrospective rated programs adjust final premium based on actual losses; large deductible programs require the employer to fund losses up to a deductible threshold. Null or none for guaranteed cost policies.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Premium Amount' ;
    rdfs:comment 'The minimum premium amount guaranteed to the carrier regardless of actual payroll volume, as stipulated in the policy terms. Relevant for low-volume periods and ensures the carrier recovers minimum administrative costs.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedRatePer100 rdf:type rdf:Property ;
    rdfs:label 'Modified Rate Per 100' ;
    rdfs:comment 'The effective WC premium rate per $100 of payroll after applying the experience modification factor (EMR) to the base rate. This is the rate used in actual premium calculations for payroll runs. Computed as base_rate_per_100 multiplied by experience_mod_factor.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'The scheduled date for the next premium audit by the insurance carrier. Used for audit preparation planning, payroll record retention compliance, and proactive reconciliation of estimated versus actual premiums.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payrollSubjectToWc rdf:type rdf:Property ;
    rdfs:label 'Payroll Subject To Wc' ;
    rdfs:comment 'The gross payroll dollar amount for the premium period that is subject to workers compensation premium calculation for this class code and state jurisdiction. Excludes non-covered remuneration per NCCI rules (e.g., tips, certain overtime premiums). Used as the basis for premium computation.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:policyNotes rdf:type rdf:Property ;
    rdfs:label 'Policy Notes' ;
    rdfs:comment 'Free-text field for operational notes, underwriting conditions, endorsements, or special program terms associated with this WC policy record. Used by payroll and risk management teams to document carrier-specific requirements or exceptions.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyNumber rdf:type rdf:Property ;
    rdfs:label 'Policy Number' ;
    rdfs:comment 'The externally-assigned policy number issued by the insurance carrier that uniquely identifies this workers compensation insurance policy. Used for carrier reporting, premium audit reconciliation, and regulatory filings.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle state of the workers compensation policy. Active policies are in force and covering workers; expired policies have passed their expiration date; cancelled policies were terminated before expiration; pending policies are bound but not yet effective.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Classification of the WC insurance policy structure. Guaranteed cost policies have fixed premiums; loss-sensitive policies (e.g., retrospective rated, large deductible) have premiums that vary based on actual loss experience. Drives premium calculation methodology and financial risk exposure.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyYear rdf:type rdf:Property ;
    rdfs:label 'Policy Year' ;
    rdfs:comment 'The four-digit calendar or fiscal year of the workers compensation policy period. Used to group premium transactions for annual audit reconciliation, loss run reporting, and year-over-year cost trend analysis.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:premiumBasis rdf:type rdf:Property ;
    rdfs:label 'Premium Basis' ;
    rdfs:comment 'The basis on which WC premiums are calculated. In staffing, the standard basis is payroll (gross remuneration subject to WC), but some specialty programs may use flat or per-capita bases. Determines how payroll_subject_to_wc is computed.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Premium Period End Date' ;
    rdfs:comment 'The end date of the payroll period for which this WC premium transaction was calculated. Together with premium_period_start_date, defines the coverage window for the premium accrual.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:premiumPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Premium Period Start Date' ;
    rdfs:comment 'The start date of the payroll period for which this WC premium transaction was calculated. Defines the coverage window for the premium accrual and aligns with the pay run cycle.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleCreditDebitPct rdf:type rdf:Property ;
    rdfs:label 'Schedule Credit Debit Pct' ;
    rdfs:comment 'The schedule rating credit (negative value) or debit (positive value) percentage applied to the manual premium, reflecting underwriter judgment on risk characteristics not captured by the experience modification factor. Expressed as a decimal (e.g., -0.10 for a 10% credit).' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateJurisdiction rdf:type rdf:Property ;
    rdfs:label 'State Jurisdiction' ;
    rdfs:comment 'The two-letter US state code representing the state jurisdiction under which this workers compensation policy is filed and governed. Critical for multi-state WC compliance, SUTA alignment, and state-specific rate application for temporary and contract workers.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workersCompCodeSource rdf:type rdf:Property ;
    rdfs:label 'Workers Comp Code Source' ;
    rdfs:comment 'Identifies the rating bureau or authority that issued the WC class code and rates for this policy record. Most states use NCCI; California uses WCIRB; a few states have independent bureaus. Critical for multi-state compliance and rate validation. [ENUM-REF-CANDIDATE: NCCI|WCIRB|NYBCOMP|DELAWARE|INDIANA|MICHIGAN|MINNESOTA|OTHER — promote to reference product]' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ytdPremiumTotal rdf:type rdf:Property ;
    rdfs:label 'Ytd Premium Total' ;
    rdfs:comment 'The cumulative workers compensation premium accrued from the start of the policy year through the current premium period for this class code and state jurisdiction. Used for premium audit reconciliation, carrier reporting, and financial forecasting of WC costs.' ;
    rdfs:domain ind:WcPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditId rdf:type rdf:Property ;
    rdfs:label 'Audit Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_audit. Business justification: Tax filings are subject to compliance audits by IRS, state tax authorities, and DOL. Audit scope includes payroll tax returns, deposit schedules, and withholding accuracy - audit trail links filings t' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:originalFilingTaxFilingId rdf:type rdf:Property ;
    rdfs:label 'Original Filing Tax Filing Id' ;
    rdfs:comment 'Reference to the original payroll_tax_filing_id that this amended filing corrects. Null for original (non-amended) filings. Enables amendment chain tracking for IRS audit readiness.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxFiling .

ind:amendedFilingFlag rdf:type rdf:Property ;
    rdfs:label 'Amended Filing Flag' ;
    rdfs:comment 'Indicates whether this record represents an amended or corrected tax filing (True) versus an original filing (False). Amended filings (e.g., Form 941-X) correct errors in previously submitted returns and are tracked separately for audit purposes.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:balanceDueAmount rdf:type rdf:Property ;
    rdfs:label 'Balance Due Amount' ;
    rdfs:comment 'Remaining tax balance owed to the tax authority after applying all deposits and credits (tax_liability_amount minus deposit_amount minus prior_deposit_amount). A positive value indicates underpayment; zero or negative indicates overpayment or credit.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'Confirmation or acknowledgment number returned by the tax authority (e.g., EFTPS trace number, state portal confirmation) upon successful receipt of the tax deposit or filed return. Used for audit trail and dispute resolution.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositAmount rdf:type rdf:Property ;
    rdfs:label 'Deposit Amount' ;
    rdfs:comment 'Actual dollar amount deposited to the tax authority for this filing period. May differ from tax_liability_amount due to prior deposits, adjustments, or credits. Net amount remitted. Part of the MONETARY_TRIPLET for this TRANSACTION_HEADER.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositDate rdf:type rdf:Property ;
    rdfs:label 'Deposit Date' ;
    rdfs:comment 'Actual date on which the tax deposit was transmitted to the tax authority via EFTPS or state equivalent. Used to determine timeliness and calculate any late deposit penalties. Serves as the BUSINESS_EVENT_TIMESTAMP (date precision) for this TRANSACTION_HEADER.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depositMethod rdf:type rdf:Property ;
    rdfs:label 'Deposit Method' ;
    rdfs:comment 'Method used to transmit the tax deposit to the tax authority. EFTPS = IRS Electronic Federal Tax Payment System (mandatory for most employers); ACH = Automated Clearing House bank transfer for state deposits; check = paper check (rare); state_portal = state-specific online payment portal.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Statutory deadline by which this tax deposit or return must be submitted to the tax authority to avoid penalties. Determined by IRS deposit schedule rules (semi-weekly or monthly) or statutory filing deadlines for annual/quarterly returns.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ein rdf:type rdf:Property ;
    rdfs:label 'Ein' ;
    rdfs:comment 'IRS-assigned Employer Identification Number (EIN) of the legal entity filing this return. Required on all federal and state payroll tax filings. In EOR (Employer of Record) and co-employment models, this may reflect the EOR entitys EIN rather than the clients EIN.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eorArrangementFlag rdf:type rdf:Property ;
    rdfs:label 'Eor Arrangement Flag' ;
    rdfs:comment 'Indicates whether this tax filing is processed under an Employer of Record (EOR) or co-employment arrangement (True), where the staffing firm acts as the legal employer for tax purposes on behalf of a client. Affects EIN used and liability allocation.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ficaEmployeeTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Fica Employee Tax Amount' ;
    rdfs:comment 'Employee share of FICA taxes (Social Security 6.2% + Medicare 1.45%) withheld from worker paychecks and remitted as part of this filing. Applicable for W-2 employees; not applicable for 1099 independent contractors.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ficaEmployerTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Fica Employer Tax Amount' ;
    rdfs:comment 'Employer matching share of FICA taxes (Social Security 6.2% + Medicare 1.45%) owed by the staffing firm or EOR entity as the employer of record. Equal to the employee FICA amount under standard rules.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Filed Timestamp' ;
    rdfs:comment 'Exact date and time when the tax return was electronically submitted to the tax authority. Provides precise audit trail for compliance and IRS/DOL audit readiness. Null if return has not yet been filed.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:filingNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to this tax filing or deposit transaction, used for reconciliation with the tax authority and TempWorks Payroll records. Serves as the BUSINESS_IDENTIFIER for this TRANSACTION_HEADER.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingPeriodType rdf:type rdf:Property ;
    rdfs:label 'Filing Period Type' ;
    rdfs:comment 'Frequency classification of the tax filing period. Determines deposit schedule (e.g., semi-weekly vs. monthly depositor rules under IRS Publication 15) and aligns with the form type (e.g., quarterly for 941, annual for 940).' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current workflow state of the payroll tax filing or deposit obligation. pending = liability identified but not yet deposited; deposited = funds transferred to tax authority; filed = return submitted; amended = corrected filing submitted; voided = filing cancelled; rejected = filing rejected by authority. Serves as the LIFECYCLE_STATUS for this TRANSACTION_HEADER.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingType rdf:type rdf:Property ;
    rdfs:label 'Filing Type' ;
    rdfs:comment 'The IRS or state tax form type associated with this filing obligation. Common values include: 941 (Employers Quarterly Federal Tax Return), 940 (Federal Unemployment Tax Act annual return), 944 (annual federal tax return for small employers), W-2 (Wage and Tax Statement), 1099-NEC (Non-Employee Compensation), state SUTA return, state income tax withholding return. [ENUM-REF-CANDIDATE: 941|940|944|W-2|1099-NEC|SUTA|state_income_tax|local_income_tax — promote to reference product]' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:futaTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Futa Tax Amount' ;
    rdfs:comment 'Federal Unemployment Tax Act (FUTA) tax liability for this filing period. Calculated at 6.0% on the first $7,000 of each employees wages, net of SUTA credit (typically reducing effective rate to 0.6%). Reported on IRS Form 940.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestAmount rdf:type rdf:Property ;
    rdfs:label 'Interest Amount' ;
    rdfs:comment 'Dollar amount of interest charged by the tax authority on late or underpaid tax deposits. Accrues from the deposit due date to the actual payment date. Zero if no interest assessed.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'Full legal name of the employer entity as registered with the IRS and state tax authorities for this filing. Supports multi-entity payroll structures including EOR, PEO, and co-employment arrangements.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overpaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Overpayment Amount' ;
    rdfs:comment 'Amount overpaid to the tax authority for this filing period. May be applied as a credit to the next period or requested as a refund. Null or zero if no overpayment exists.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payrollPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Payroll Period End Date' ;
    rdfs:comment 'Last date of the payroll period covered by this tax filing. Defines the end of the wage and tax liability window for this return.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payrollPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Payroll Period Start Date' ;
    rdfs:comment 'First date of the payroll period covered by this tax filing. Combined with payroll_period_end_date, defines the wage and tax liability window for this return.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Dollar amount of IRS or state-assessed penalties for late deposit, late filing, or underpayment of payroll taxes. Zero if no penalties assessed. Critical for compliance monitoring and SLA tracking.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorDepositAmount rdf:type rdf:Property ;
    rdfs:label 'Prior Deposit Amount' ;
    rdfs:comment 'Total tax deposits made in prior periods within the same filing period that are applied against the current tax liability. Used for reconciliation between cumulative deposits and the final return balance due.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sutaTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Suta Tax Amount' ;
    rdfs:comment 'State Unemployment Tax Act (SUTA) tax liability for this filing period. Rate and wage base vary by state and employer experience rating. Critical for multi-state staffing operations where workers are assigned across multiple states.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Name' ;
    rdfs:comment 'Name of the federal, state, or local tax authority to which this filing or deposit is submitted (e.g., IRS, California EDD, New York State DTF, City of Philadelphia Revenue Department). Used for multi-jurisdiction payroll compliance tracking.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxLiabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Liability Amount' ;
    rdfs:comment 'Total tax liability computed for this filing period based on taxable wages and applicable tax rates. Represents the gross amount owed to the tax authority before any prior deposits or credits are applied. Part of the MONETARY_TRIPLET for this TRANSACTION_HEADER.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxableWages rdf:type rdf:Property ;
    rdfs:label 'Total Taxable Wages' ;
    rdfs:comment 'Aggregate gross taxable wages subject to the specific tax type covered by this filing for the filing period. Basis for computing the total tax liability. Excludes non-taxable fringe benefits and pre-tax deductions where applicable.' ;
    rdfs:domain ind:TaxFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workerClassification rdf:type rdf:Property ;
    rdfs:label 'Worker Classification' ;
    rdfs:comment 'Classification of workers covered by this filing: W-2 for employees subject to withholding and employer taxes, 1099 for independent contractors (IC) subject only to self-employment tax reporting, or both for filings covering mixed worker populations. Critical for IRS worker classification compliance.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxFormId rdf:type rdf:Property ;
    rdfs:label 'Tax Form Id' ;
    rdfs:comment 'Unique surrogate primary key for each annual tax form record (W-2, W-2c, 1099-NEC, 1099-MISC) generated in TempWorks Payroll. Globally unique across all form types and tax years.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalFormTaxFormId rdf:type rdf:Property ;
    rdfs:label 'Original Form Tax Form Id' ;
    rdfs:comment 'Reference to the original tax_form record that this corrected form (W-2c or amended 1099) supersedes. Null for original (non-corrected) forms. Enables correction history chain tracking for audit and IRS reconciliation.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxForm .

ind:distributionDate rdf:type rdf:Property ;
    rdfs:label 'Distribution Date' ;
    rdfs:comment 'Date the workers copy of the tax form was distributed (mailed, electronically delivered, or handed in person). Must be on or before January 31 of the year following the tax year per IRS requirements.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionMethod rdf:type rdf:Property ;
    rdfs:label 'Distribution Method' ;
    rdfs:comment 'Method used to distribute the workers copy of the tax form. Mail: physical paper mailed to worker address. Electronic: delivered via secure online portal (requires worker consent). In-person: handed directly to worker.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:efileAcceptedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Efile Accepted Timestamp' ;
    rdfs:comment 'Date and time when the IRS FIRE system or SSA ACCUWAGE system accepted the e-file submission for this tax form. Null if not yet filed or if paper-filed. Critical for IRS filing deadline compliance.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:efileSubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Efile Submission Reference' ;
    rdfs:comment 'IRS or SSA-assigned submission identifier returned upon successful e-file transmission. For W-2s: SSA ACCUWAGE submission ID. For 1099s: IRS FIRE system submission ID. Used to track filing status and retrieve acknowledgements.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerEin rdf:type rdf:Property ;
    rdfs:label 'Employer Ein' ;
    rdfs:comment 'Federal Employer Identification Number (EIN) of the staffing company or EOR entity issuing the tax form. Appears in Box c of W-2 and Payer TIN field of 1099 forms. Required for IRS e-filing and state tax agency submissions.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formType rdf:type rdf:Property ;
    rdfs:label 'Form Type' ;
    rdfs:comment 'Discriminator identifying the IRS tax form type. W-2 for W-2 employees and temporary workers; W-2c for corrected W-2s; 1099-NEC for independent contractor (IC) nonemployee compensation; 1099-MISC for miscellaneous income. Drives form-specific field population and filing rules.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCorrected rdf:type rdf:Property ;
    rdfs:label 'Is Corrected' ;
    rdfs:comment 'True if this record represents a corrected tax form (W-2c or amended 1099). The corrected checkbox is checked on the physical form. Links to the original form via original_form_id for correction history tracking.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Date and time when this tax form record was most recently modified (e.g., correction applied, filing status updated, distribution recorded). Supports audit trail and change tracking.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:localIncomeTaxWithheldBox19 rdf:type rdf:Property ;
    rdfs:label 'Local Income Tax Withheld Box19' ;
    rdfs:comment 'W-2 Box 19: Total local income tax withheld from the workers wages. Reported to the applicable local tax authority. Null if no local tax applies.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localWagesBox18 rdf:type rdf:Property ;
    rdfs:label 'Local Wages Box18' ;
    rdfs:comment 'W-2 Box 18: Total wages subject to local income tax withholding (e.g., city or county taxes). Applicable in jurisdictions such as New York City, Philadelphia, or Ohio municipalities. Null if no local tax applies.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:miscOtherIncomeBox3 rdf:type rdf:Property ;
    rdfs:label 'Misc Other Income Box3' ;
    rdfs:comment '1099-MISC Box 3: Other income payments not reportable in other boxes, such as prizes, awards, or taxable per diem amounts exceeding IRS limits. Null for W-2 and 1099-NEC form types.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:miscRentsBox1 rdf:type rdf:Property ;
    rdfs:label 'Misc Rents Box1' ;
    rdfs:comment '1099-MISC Box 1: Rent payments of $600 or more paid to a landlord or property owner. Applicable when staffing company pays office or facility rent to a non-corporate payee. Null for W-2 and 1099-NEC form types.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:necCompensationBox1 rdf:type rdf:Property ;
    rdfs:label 'Nec Compensation Box1' ;
    rdfs:comment '1099-NEC Box 1: Total nonemployee compensation paid to an independent contractor (IC) during the tax year. Includes fees, commissions, prizes, and awards for services rendered. Null for W-2 form types. Threshold: $600 or more triggers filing requirement.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:necFederalTaxWithheldBox4 rdf:type rdf:Property ;
    rdfs:label 'Nec Federal Tax Withheld Box4' ;
    rdfs:comment '1099-NEC Box 4: Federal income tax withheld under backup withholding rules (24% rate) when the contractor failed to provide a valid TIN or IRS notified backup withholding is required. Null for W-2 form types.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paperFiled rdf:type rdf:Property ;
    rdfs:label 'Paper Filed' ;
    rdfs:comment 'True if this tax form was submitted to the IRS/SSA via paper rather than electronic filing. Staffing companies filing 10 or more forms are required to e-file per IRS regulations. Tracks compliance with mandatory e-file thresholds.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payerTin rdf:type rdf:Property ;
    rdfs:label 'Payer Tin' ;
    rdfs:comment 'Payers Taxpayer Identification Number (TIN) as reported on 1099 forms. Typically the same as the employer EIN but may differ for EOR or co-employment arrangements where a third-party PEO is the payer of record.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientTinType rdf:type rdf:Property ;
    rdfs:label 'Recipient Tin Type' ;
    rdfs:comment 'Type of TIN used for the recipient/worker on this tax form. SSN for W-2 employees and individual contractors; EIN for contractors operating as a business entity; ITIN for foreign workers without an SSN. Drives IRS validation rules.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateEmployerNumber rdf:type rdf:Property ;
    rdfs:label 'State Employer Number' ;
    rdfs:comment 'State-assigned employer identification number used for state income tax withholding reporting (W-2 Box 15). Required for state e-filing submissions. Format varies by state.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateFilingStatus rdf:type rdf:Property ;
    rdfs:label 'State Filing Status' ;
    rdfs:comment 'Current status of the state tax agency filing for this form. Not_required: state has no income tax or filing not required. Pending: prepared but not yet submitted. Filed: submitted to state agency. Accepted: state agency confirmed receipt. Supports multi-state payroll compliance tracking.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateIncomeTaxWithheldBox17 rdf:type rdf:Property ;
    rdfs:label 'State Income Tax Withheld Box17' ;
    rdfs:comment 'W-2 Box 17: Total state income tax withheld from the workers wages. Reported to the applicable state tax agency. Null for 1099 form types or states with no income tax.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateWagesBox16 rdf:type rdf:Property ;
    rdfs:label 'State Wages Box16' ;
    rdfs:comment 'W-2 Box 16: Total wages subject to state income tax withholding. May differ from Box 1 federal wages due to state-specific pre-tax exclusions. Supports multi-state payroll compliance. Null for 1099 form types.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:w2Box12CodeAAmount rdf:type rdf:Property ;
    rdfs:label 'W2 Box12 Code A Amount' ;
    rdfs:comment 'W-2 Box 12 Code A: Uncollected Social Security tax on tips. One of up to four Box 12 entries capturing pre-tax benefit and special compensation amounts. Null if not applicable.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:w2Box12Codes rdf:type rdf:Property ;
    rdfs:label 'W2 Box12 Codes' ;
    rdfs:comment 'Pipe-delimited list of IRS Box 12 codes reported on this W-2 (e.g., D|DD|W). Code D = 401(k) elective deferrals; Code DD = employer-sponsored health coverage cost; Code W = HSA employer contributions; Code C = taxable cost of group-term life insurance. Supports multi-code scenarios common in staffing. Null for 1099 form types. [ENUM-REF-CANDIDATE: A|B|C|D|DD|E|F|G|H|J|K|L|M|N|P|Q|R|S|T|V|W|Y|Z|AA|BB|DD|EE|FF|GG|HH — promote to reference product]' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:w2Box12TotalAmount rdf:type rdf:Property ;
    rdfs:label 'W2 Box12 Total Amount' ;
    rdfs:comment 'Aggregate dollar amount across all Box 12 codes reported on this W-2. Used for year-end reconciliation of pre-tax benefit deductions (401k, HSA, health coverage). Null for 1099 form types.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:w2FederalTaxWithheldBox2 rdf:type rdf:Property ;
    rdfs:label 'W2 Federal Tax Withheld Box2' ;
    rdfs:comment 'W-2 Box 2: Total federal income tax withheld from the workers wages during the tax year. Reported to IRS and used by worker for federal tax return filing. Null for 1099 form types.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:w2MedicareTaxWithheldBox6 rdf:type rdf:Property ;
    rdfs:label 'W2 Medicare Tax Withheld Box6' ;
    rdfs:comment 'W-2 Box 6: Employees share of Medicare (FICA) tax withheld. Equals 1.45% of Box 5 wages, plus 0.9% Additional Medicare Tax for high earners. Null for 1099 form types.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:w2MedicareWagesBox5 rdf:type rdf:Property ;
    rdfs:label 'W2 Medicare Wages Box5' ;
    rdfs:comment 'W-2 Box 5: Total wages and tips subject to Medicare (FICA) tax. No wage base cap applies. Includes wages above the Social Security wage base. Null for 1099 form types.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:w2OtherCompensationBox14 rdf:type rdf:Property ;
    rdfs:label 'W2 Other Compensation Box14' ;
    rdfs:comment 'W-2 Box 14: Employer-reported informational amounts such as state disability insurance (SDI) withheld, union dues, educational assistance, or other items not captured in other boxes. Null for 1099 form types.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:w2RetirementPlanBox13 rdf:type rdf:Property ;
    rdfs:label 'W2 Retirement Plan Box13' ;
    rdfs:comment 'W-2 Box 13 checkbox: True if the worker was an active participant in an employer-sponsored retirement plan (401k, SIMPLE IRA, etc.) during the tax year. Affects IRA deductibility on the workers personal return. Null for 1099 form types.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:w2SsTaxWithheldBox4 rdf:type rdf:Property ;
    rdfs:label 'W2 Ss Tax Withheld Box4' ;
    rdfs:comment 'W-2 Box 4: Employees share of Social Security (FICA) tax withheld. Equals 6.2% of Box 3 wages up to the wage base. Null for 1099 form types.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:w2SsWagesBox3 rdf:type rdf:Property ;
    rdfs:label 'W2 Ss Wages Box3' ;
    rdfs:comment 'W-2 Box 3: Total wages subject to Social Security (FICA) tax, capped at the annual Social Security wage base limit. Null for 1099 form types.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:w2StatutoryEmployeeBox13 rdf:type rdf:Property ;
    rdfs:label 'W2 Statutory Employee Box13' ;
    rdfs:comment 'W-2 Box 13 checkbox: True if the worker is classified as a statutory employee (e.g., certain drivers, traveling salespeople). Affects self-employment tax treatment. Null for 1099 form types.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:w2ThirdPartySickPayBox13 rdf:type rdf:Property ;
    rdfs:label 'W2 Third Party Sick Pay Box13' ;
    rdfs:comment 'W-2 Box 13 checkbox: True if the worker received third-party sick pay (e.g., from an insurance carrier) that is included in wages. Common in staffing for workers on short-term disability. Null for 1099 form types.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:w2WagesBox1 rdf:type rdf:Property ;
    rdfs:label 'W2 Wages Box1' ;
    rdfs:comment 'W-2 Box 1: Total taxable wages, tips, and other compensation subject to federal income tax withholding. Excludes pre-tax benefit deductions (401k, health insurance). Null for 1099 form types.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workerAddressCity rdf:type rdf:Property ;
    rdfs:label 'Worker Address City' ;
    rdfs:comment 'City of the workers mailing address as printed on the tax form. Used for form distribution and state tax filing jurisdiction determination.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Worker Address Line1' ;
    rdfs:comment 'First line of the workers mailing address as printed on the tax form for distribution. Required for paper form mailing and IRS/SSA filing. Appears in Box f of W-2 and Recipient Address of 1099.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerAddressState rdf:type rdf:Property ;
    rdfs:label 'Worker Address State' ;
    rdfs:comment 'Two-letter US state code of the workers mailing address. Drives state tax filing jurisdiction and multi-state payroll compliance rules.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerAddressZip rdf:type rdf:Property ;
    rdfs:label 'Worker Address Zip' ;
    rdfs:comment 'ZIP or ZIP+4 postal code of the workers mailing address as printed on the tax form.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerCopyDistributed rdf:type rdf:Property ;
    rdfs:label 'Worker Copy Distributed' ;
    rdfs:comment 'True if the workers copy of the tax form (Copy B for W-2, Copy B for 1099) has been distributed to the worker by the IRS deadline (January 31). Tracks compliance with worker distribution requirements.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workerLegalName rdf:type rdf:Property ;
    rdfs:label 'Worker Legal Name' ;
    rdfs:comment 'Full legal name of the worker or independent contractor as it appears on the tax form (W-2 Box e or 1099 Recipient Name). Must match SSA records for W-2 employees to avoid name/SSN mismatch errors.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerSsn rdf:type rdf:Property ;
    rdfs:label 'Worker Ssn' ;
    rdfs:comment 'Workers Social Security Number (SSN) as reported on the tax form. Appears in Box a of W-2 and Recipient TIN field of 1099 forms. Masked in most operational views; full value required only for IRS e-filing and SSA submission. Governed by FCRA and IRS regulations.' ;
    rdfs:domain ind:TaxForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workersCompState rdf:type rdf:Property ;
    rdfs:label 'Workers Comp State' ;
    rdfs:comment 'Two-letter state code for the state under which workers compensation (Workers Comp) insurance was carried for this worker during the tax year. Relevant for W-2 employees on temporary assignments. Used in year-end workers comp audit reconciliation.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByElectionTaxWithholdingElectionId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Election Tax Withholding Election Id' ;
    rdfs:comment 'Reference to the newer tax_withholding_election record that replaced this one. Populated when election_status = superseded. Enables forward-chaining of the election history for audit trails.' ;
    rdfs:domain ind:TaxWithholdingElection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxWithholdingElection .

ind:allowancesClaimed rdf:type rdf:Property ;
    rdfs:label 'Allowances Claimed' ;
    rdfs:comment 'Number of withholding allowances claimed by the worker on pre-2020 W-4 forms. Each allowance reduces the amount of federal income tax withheld. Applicable only for W-4 forms prior to the 2020 redesign. Null for 2020+ W-4 forms which use the step-based approach.' ;
    rdfs:domain ind:Payroll ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deductionsAmount rdf:type rdf:Property ;
    rdfs:label 'Deductions Amount' ;
    rdfs:comment 'Dollar amount of itemized or other deductions entered in Step 4b of the 2020+ W-4. Reduces withholding by accounting for deductions that exceed the standard deduction. Null for pre-2020 W-4 forms.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dependentCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Dependent Credit Amount' ;
    rdfs:comment 'Dollar amount of qualifying dependent credits entered in Step 3 of the 2020+ redesigned W-4. Reduces the amount of income subject to withholding. Includes child tax credit ($2,000 per qualifying child under 17) and other dependent credits ($500 per other dependent). Null for pre-2020 W-4 forms.' ;
    rdfs:domain ind:TaxWithholdingElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Document Reference Code' ;
    rdfs:comment 'Reference identifier for the physical or electronic withholding form document stored in the document management system (e.g., DocuSign CLM or SAP SuccessFactors document repository). Enables retrieval of the original signed form for audit and compliance verification.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electionNotes rdf:type rdf:Property ;
    rdfs:label 'Election Notes' ;
    rdfs:comment 'Free-text notes entered by payroll staff regarding this withholding election. May include reasons for IRS lock-in overrides, documentation of verbal instructions, or notes on unusual withholding configurations.' ;
    rdfs:domain ind:TaxWithholdingElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electionNumber rdf:type rdf:Property ;
    rdfs:label 'Election Number' ;
    rdfs:comment 'Externally-visible business identifier for this withholding election record, used for audit trails, payroll processing references, and worker communications (e.g., TWE-2024-00123).' ;
    rdfs:domain ind:TaxWithholdingElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electionSource rdf:type rdf:Property ;
    rdfs:label 'Election Source' ;
    rdfs:comment 'The channel or method through which the withholding election was submitted. Paper form = physical W-4 or state form submitted; Electronic self-service = worker submitted via online portal (e.g., SAP SuccessFactors ESS); Employer default = system default applied when no form received; IRS lock-in = IRS-mandated withholding rate overriding worker election; Verbal instruction = documented verbal request.' ;
    rdfs:domain ind:TaxWithholdingElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electionStatus rdf:type rdf:Property ;
    rdfs:label 'Election Status' ;
    rdfs:comment 'Current lifecycle state of this withholding election. Active = currently driving withholding calculations; Superseded = replaced by a newer election; Pending = submitted but not yet effective; Cancelled = voided before taking effect; Expired = past the expiration date.' ;
    rdfs:domain ind:TaxWithholdingElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electionVersion rdf:type rdf:Property ;
    rdfs:label 'Election Version' ;
    rdfs:comment 'Sequential version number for withholding elections for the same worker and jurisdiction. Increments each time the worker submits a new withholding form. Enables tracking of election history and supersession chain for audit and compliance purposes.' ;
    rdfs:domain ind:TaxWithholdingElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enteredBy rdf:type rdf:Property ;
    rdfs:label 'Entered By' ;
    rdfs:comment 'Username or employee ID of the payroll staff member or system process that entered this withholding election into TempWorks Payroll. Supports audit trail requirements for payroll compliance and SOC 2 Type II controls.' ;
    rdfs:domain ind:TaxWithholdingElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flatWithholdingRatePct rdf:type rdf:Property ;
    rdfs:label 'Flat Withholding Rate Pct' ;
    rdfs:comment 'Fixed percentage rate applied to gross wages for income tax withholding when the withholding method is percentage or flat_amount. Expressed as a decimal (e.g., 0.2200 = 22%). Used for supplemental wage withholding at the IRS flat supplemental rate or for state flat-rate withholding.' ;
    rdfs:domain ind:TaxWithholdingElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:irsLockInAllowances rdf:type rdf:Property ;
    rdfs:label 'Irs Lock In Allowances' ;
    rdfs:comment 'The maximum number of withholding allowances permitted by the IRS lock-in letter, overriding the workers own W-4 election. Employer must not allow the worker to claim more allowances than this value.' ;
    rdfs:domain ind:TaxWithholdingElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:irsLockInFilingStatus rdf:type rdf:Property ;
    rdfs:label 'Irs Lock In Filing Status' ;
    rdfs:comment 'The filing status mandated by the IRS lock-in letter, overriding the workers own W-4 election. Populated only when an IRS lock-in letter is in effect. Employer must use this status for withholding calculations.' ;
    rdfs:domain ind:TaxWithholdingElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irsLockInLetterDate rdf:type rdf:Property ;
    rdfs:label 'Irs Lock In Letter Date' ;
    rdfs:comment 'Date of the IRS lock-in letter received by the employer mandating a specific withholding rate for this worker. When present, the employer must withhold at the IRS-specified rate regardless of the workers W-4 elections. Null if no lock-in letter applies.' ;
    rdfs:domain ind:TaxWithholdingElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isExemptFromWithholding rdf:type rdf:Property ;
    rdfs:label 'Is Exempt From Withholding' ;
    rdfs:comment 'Indicates whether the worker has claimed exemption from federal or state income tax withholding. True = worker claims exempt status and no income tax will be withheld. Exempt status expires February 15 each year and must be renewed. Employer must retain the exempt W-4 and notify IRS if required.' ;
    rdfs:domain ind:TaxWithholdingElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStateExemptFromWithholding rdf:type rdf:Property ;
    rdfs:label 'Is State Exempt From Withholding' ;
    rdfs:comment 'Indicates whether the worker has claimed exemption from state income tax withholding on the state withholding form. Exempt criteria and renewal requirements vary by state.' ;
    rdfs:domain ind:TaxWithholdingElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionType rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Type' ;
    rdfs:comment 'Indicates whether this election applies to federal, state, or local tax withholding. Federal elections are governed by IRS W-4; state elections by equivalent state withholding forms; local elections by municipality-specific forms.' ;
    rdfs:domain ind:TaxWithholdingElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localityName rdf:type rdf:Property ;
    rdfs:label 'Locality Name' ;
    rdfs:comment 'Name of the local taxing jurisdiction (city, county, or municipality) for local income tax withholding elections. Applicable in states with local income taxes such as Ohio, Pennsylvania, Kentucky, and New York City.' ;
    rdfs:domain ind:TaxWithholdingElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multipleJobsFlag rdf:type rdf:Property ;
    rdfs:label 'Multiple Jobs Flag' ;
    rdfs:comment 'Indicates whether the worker checked the Step 2 multiple jobs checkbox on the 2020+ W-4, signaling they hold multiple concurrent jobs or their spouse also works. When true, withholding is calculated using the higher withholding rate tables to prevent under-withholding.' ;
    rdfs:domain ind:TaxWithholdingElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonresidentAlienFlag rdf:type rdf:Property ;
    rdfs:label 'Nonresident Alien Flag' ;
    rdfs:comment 'Indicates whether the worker is a nonresident alien (NRA) for U.S. tax purposes. NRA workers are subject to special withholding rules under IRS Publication 15 and must follow specific W-4 instructions (cannot claim exempt, must add an additional amount to wages for withholding calculation). Relevant for staffing firms placing international workers.' ;
    rdfs:domain ind:TaxWithholdingElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date the withholding election form was received by the employer or payroll department. Used to determine the required effective date per IRS rules (must take effect no later than the first payroll period ending on or after the 30th day after receipt).' ;
    rdfs:domain ind:TaxWithholdingElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stateAdditionalWithholdingAmount rdf:type rdf:Property ;
    rdfs:label 'State Additional Withholding Amount' ;
    rdfs:comment 'Additional flat dollar amount the worker requests to be withheld for state income tax beyond the calculated state withholding. Applied per pay period in addition to the standard state withholding calculation.' ;
    rdfs:domain ind:TaxWithholdingElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateAllowancesClaimed rdf:type rdf:Property ;
    rdfs:label 'State Allowances Claimed' ;
    rdfs:comment 'Number of withholding allowances claimed on the state withholding form. Many states still use an allowance-based system independent of the federal W-4 redesign (e.g., California DE-4, New York IT-2104). Null for states with no income tax or states that have adopted the federal W-4.' ;
    rdfs:domain ind:TaxWithholdingElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplementalWageMethod rdf:type rdf:Property ;
    rdfs:label 'Supplemental Wage Method' ;
    rdfs:comment 'Method used to withhold income tax on supplemental wages (bonuses, commissions, overtime, per diem above IRS threshold). Flat rate = mandatory 22% federal flat rate for supplemental wages under $1M; Aggregate = combined with regular wages using withholding tables; Optional flat = employer elects flat rate when not mandatory.' ;
    rdfs:domain ind:TaxWithholdingElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatyCountryCode rdf:type rdf:Property ;
    rdfs:label 'Treaty Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country with which the worker claims a U.S. tax treaty benefit, potentially reducing or eliminating withholding on certain income types. Applicable for nonresident alien workers claiming treaty exemptions via Form 8233 or W-8BEN.' ;
    rdfs:domain ind:TaxWithholdingElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:w4FormVersionYear rdf:type rdf:Property ;
    rdfs:label 'W4 Form Version Year' ;
    rdfs:comment 'The tax year version of the W-4 or equivalent withholding form submitted by the worker. Critical because the 2020 redesigned W-4 eliminated allowances and introduced a new step-based structure. Pre-2020 forms use allowances; 2020+ forms use Step 3 dependent credits and Step 4 adjustments.' ;
    rdfs:domain ind:TaxWithholdingElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingAccountId rdf:type rdf:Property ;
    rdfs:label 'Billing Account Id' ;
    rdfs:comment 'Foreign key linking to billing.billing_account. Business justification: An invoice is issued to a client\'s billing account — the financial entity that owns the AR relationship. billing_account is the SSOT for payment terms, credit limits, invoice delivery preferences, and' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingAccount .

ind:billingContactClientContactId rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Client Contact Id' ;
    rdfs:comment 'Foreign key linking to client.client_contact. Business justification: Invoices in staffing are addressed and delivered to a specific client billing/AP contact. Knowing which contact received each invoice is essential for dispute initiation, delivery confirmation, and co' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientContact .

ind:originalInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Original Invoice Id' ;
    rdfs:comment 'Reference to the original invoice that this invoice replaces in a void-and-rebill scenario. Populated on the replacement invoice to maintain the audit chain linking corrected invoices back to their originals. Null for original invoices not created as part of a rebill.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:sourcingCampaignId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Campaign Id' ;
    rdfs:comment 'Foreign key linking to recruitment.sourcing_campaign. Business justification: In RPO/MSP models, sourcing campaign costs are billed back to clients. Invoice references campaign for cost recovery, ROI analysis, and campaign budget reconciliation. Real business need in managed pr' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourcingCampaign .

ind:sowAgreementId rdf:type rdf:Property ;
    rdfs:label 'Sow Agreement Id' ;
    rdfs:comment 'Foreign key linking to vendor.sow_agreement. Business justification: Invoices for SOW engagements must be reconciled against the vendor SOW agreement to validate billing against not-to-exceed amounts and milestone deliverables. Vendor SOW billing reconciliation is a na' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SowAgreement .

ind:vmsEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Vms Enrollment Id' ;
    rdfs:comment 'Foreign key linking to vendor.vms_enrollment. Business justification: VMS-managed program invoices must be reconciled against the supplier\'s VMS enrollment to validate billing eligibility and program compliance. VMS invoice reconciliation is a named operational process;' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VmsEnrollment .

ind:amountPaid rdf:type rdf:Property ;
    rdfs:label 'Amount Paid' ;
    rdfs:comment 'Total amount received from the client against this invoice to date. May be less than net_amount for partially paid invoices. Used to calculate the outstanding balance and drive collections workflows.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingModel rdf:type rdf:Property ;
    rdfs:label 'Billing Model' ;
    rdfs:comment 'Classification of the billing methodology used for this invoice. Determines how line items are calculated and how revenue is recognized. time_and_materials = hourly bill rate x hours worked; per_diem = daily flat rate; project_based = milestone or deliverable-based; sow_based = Statement of Work (SOW) fixed-fee; direct_placement_fee = one-time permanent placement fee.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Billing Period End' ;
    rdfs:comment 'The last date of the service period covered by this invoice. Together with billing_period_start, defines the billing window for which staffing services are being charged.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start' ;
    rdfs:comment 'The first date of the service period covered by this invoice. For time-and-materials invoices, this is the start of the timesheet week or pay period. Used for revenue recognition period alignment and client billing reconciliation.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Number' ;
    rdfs:comment 'Reference number of the credit memo issued against this invoice, if applicable. Populated when a credit adjustment is applied to resolve a dispute, correct a billing error, or process a void-and-rebill. Links to the corresponding credit memo record in Oracle NetSuite ERP.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'The channel through which this invoice was or will be delivered to the client. Determines the transmission workflow in Salesforce Revenue Cloud. VMS portal delivery is required for clients using Beeline or similar VMS platforms.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Total discount or credit applied to the invoice, such as volume discounts, contractual rate adjustments, or promotional credits negotiated in the Master Service Agreement (MSA). Reduces the net amount payable.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Description of the reason provided by the client for disputing this invoice. Populated when status is disputed. Common reasons include rate discrepancies, unauthorized hours, missing PO number, or timesheet approval issues. Used for dispute resolution tracking and root cause analysis.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date the invoice was formally issued to the client. Represents the principal business event timestamp for the invoice. Used as the basis for payment due date calculation and revenue recognition period assignment.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Externally-visible, human-readable invoice identifier issued to the client. Unique across all billing periods and client accounts. Used on client-facing documents and referenced in payment remittances. Sourced from Salesforce Revenue Cloud invoice numbering sequence.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle state of the invoice. Drives accounts receivable workflows, collections actions, and revenue recognition. draft = not yet issued; sent = delivered to client; paid = fully settled; partially_paid = partial payment received; disputed = client has raised a dispute; void = cancelled, typically triggering a rebill.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isVoid rdf:type rdf:Property ;
    rdfs:label 'Is Void' ;
    rdfs:comment 'Indicates whether this invoice has been voided. True when the invoice has been cancelled and is no longer collectible. Voided invoices are retained for audit trail purposes and typically trigger a replacement invoice in void-and-rebill workflows.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markupPercentage rdf:type rdf:Property ;
    rdfs:label 'Markup Percentage' ;
    rdfs:comment 'The percentage markup applied over the pay rate to arrive at the bill rate, expressed as a decimal (e.g., 0.45 = 45%). Calculated as (bill_rate - pay_rate) / pay_rate. A standard staffing industry profitability metric used in client pricing negotiations and margin analysis.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Final amount due from the client after applying taxes and discounts. Calculated as gross_amount + tax_amount - discount_amount. This is the amount the client is expected to remit. Core component of the monetary triplet.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Remaining unpaid amount on the invoice, calculated as net_amount minus amount_paid. Drives accounts receivable aging reports and collections prioritization. Zero when invoice is fully paid.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeHoursBilled rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours Billed' ;
    rdfs:comment 'Number of overtime (OT) hours included in the total hours billed on this invoice. Overtime hours are billed at a premium rate per FLSA regulations (typically 1.5x the regular bill rate). Tracked separately for compliance reporting and client billing transparency.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidTimestamp rdf:type rdf:Property ;
    rdfs:label 'Paid Timestamp' ;
    rdfs:comment 'Date and time full payment was received and confirmed for this invoice. Populated when status transitions to paid. Used for Days Sales Outstanding (DSO) calculation, cash flow reporting, and accounts receivable closure.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Contractual payment terms agreed with the client, defining the number of days from invoice date within which payment is due. Sourced from the clients Master Service Agreement (MSA). Drives due_date calculation and accounts receivable aging classification.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Client-issued Purchase Order (PO) number that authorizes the staffing services billed on this invoice. Required by many enterprise clients and Vendor Management System (VMS) programs for invoice approval and payment processing. Must match the PO number in the clients procurement system.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'The date on which revenue from this invoice is recognized in the general ledger per GAAP ASC 606 revenue recognition standards. May differ from invoice_date for milestone-based or deferred revenue scenarios. Critical for accurate financial period reporting.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sent Timestamp' ;
    rdfs:comment 'Date and time the invoice was transmitted to the client via email, VMS portal, or EDI. Marks the transition from draft to sent status. Used for SLA measurement of billing cycle time and for dispute resolution (proof of delivery).' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sowNumber rdf:type rdf:Property ;
    rdfs:label 'Sow Number' ;
    rdfs:comment 'Reference to the Statement of Work (SOW) document governing project-based or SOW-based billing engagements. Populated only when billing_model is sow_based or project_based. Links to the specific SOW deliverables being invoiced.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spreadAmount rdf:type rdf:Property ;
    rdfs:label 'Spread Amount' ;
    rdfs:comment 'The difference between the bill rate and the pay rate (bill_rate minus pay_rate), representing the gross margin per unit before burden costs. A key profitability metric in staffing known as the Spread. Stored at the invoice level for aggregate reporting; detailed spread is tracked at the line item level.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Total tax charges applied to the invoice, including applicable state and local taxes on staffing services. Varies by jurisdiction and service type. Some staffing services may be tax-exempt depending on client tax status and state regulations.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalHoursBilled rdf:type rdf:Property ;
    rdfs:label 'Total Hours Billed' ;
    rdfs:comment 'Total number of hours billed to the client on this invoice across all workers and assignments in the billing period. Applicable for time-and-materials billing models. Sourced from approved timesheets in Kronos Workforce Ready. Used for billing reconciliation and workforce utilization reporting.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each invoice line item record in the billing system. Primary key for the invoice_line data product. Role: TRANSACTION_LINE.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:assessmentId rdf:type rdf:Property ;
    rdfs:label 'Assessment Id' ;
    rdfs:comment 'Foreign key linking to candidate.assessment. Business justification: Assessment costs (background checks, drug screens, skills tests) are frequently billed as separate line items to clients in staffing. Direct link enables assessment-specific billing, cost recovery tra' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assessment .

ind:bgcOrderId rdf:type rdf:Property ;
    rdfs:label 'Bgc Order Id' ;
    rdfs:comment 'Foreign key linking to credentialing.bgc_order. Business justification: BGC screening fees are billed as discrete invoice line items. invoice_line links to credential_instance but not directly to bgc_order, preventing direct line-item-to-screening-order reconciliation. St' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BgcOrder .

ind:billRateId rdf:type rdf:Property ;
    rdfs:label 'Bill Rate Id' ;
    rdfs:comment 'Foreign key linking to billing.bill_rate. Business justification: Each invoice line is billed at a specific bill rate. The invoice_line currently has bill_rate and pay_rate as scalar values, but these should reference the authoritative bill_rate master record. The b' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillRate .

ind:clientLocationId rdf:type rdf:Property ;
    rdfs:label 'Client Location Id' ;
    rdfs:comment 'Reference to the specific client work site or location where the worker performed services billed on this line. Used for multi-site billing, tax jurisdiction determination, and workforce analytics.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:drugScreenId rdf:type rdf:Property ;
    rdfs:label 'Drug Screen Id' ;
    rdfs:comment 'Foreign key linking to credentialing.drug_screen. Business justification: Drug screening fees are billed as discrete invoice line items in safety-sensitive staffing. invoice_line currently lacks a direct drug_screen FK, preventing line-item-to-screen-order reconciliation. B' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrugScreen .

ind:licenseVerificationId rdf:type rdf:Property ;
    rdfs:label 'License Verification Id' ;
    rdfs:comment 'Foreign key linking to credentialing.license_verification. Business justification: License verification fees are billed as line items on client invoices in healthcare and professional staffing. The invoice_line needs a direct reference to the license_verification record for verifica' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicenseVerification .

ind:billingType rdf:type rdf:Property ;
    rdfs:label 'Billing Type' ;
    rdfs:comment 'Classification of the billable service type on this line item. Regular = standard hours; OT (Overtime) = hours exceeding FLSA thresholds billed at OT rate; DT (Double Time) = hours billed at double rate; Per Diem = daily allowance billing; Expense = reimbursable expense; Placement Fee = direct hire or temp-to-perm conversion fee.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:burdenRateAmount rdf:type rdf:Property ;
    rdfs:label 'Burden Rate Amount' ;
    rdfs:comment 'The employer burden cost allocated to this line item, representing the employer-side payroll taxes and benefits costs (FICA, FUTA, SUTA, Workers Comp, benefits) associated with the worker hours billed. Sourced from TempWorks Payroll burden rate configuration.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditMemoReference rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Reference' ;
    rdfs:comment 'The credit memo document number issued against this invoice line item when a billing dispute is resolved or an adjustment is required. Populated when line_status is credited. Enables accounts receivable reconciliation in Oracle NetSuite ERP.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedAmount rdf:type rdf:Property ;
    rdfs:label 'Extended Amount' ;
    rdfs:comment 'The total billable amount for this line item, calculated as quantity multiplied by bill rate. Represents the gross revenue for this line before any adjustments, credits, or taxes. Satisfies LINE_VALUE_OR_RESULT minimum category for TRANSACTION_LINE role.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBillable rdf:type rdf:Property ;
    rdfs:label 'Is Billable' ;
    rdfs:comment 'Indicates whether this line item is billable to the client (True) or is a non-billable internal cost line (False). Non-billable lines may represent internal adjustments, write-offs, or courtesy credits that are tracked but not invoiced.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line item number within the parent invoice, used for ordering and referencing individual line items on the invoice document. Satisfies LINE_SEQUENCE minimum category for TRANSACTION_LINE role.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'The billable quantity for this line item. Represents hours worked for time-and-materials billing, number of days for per-diem billing, or a count of 1 for placement fee billing. Satisfies LINE_QUANTITY minimum category for TRANSACTION_LINE role.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'Unit of measure for the quantity field. Hours for time-and-materials, days for per-diem, units for deliverable-based SOW billing, flat for fixed-fee placement fees.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDescription rdf:type rdf:Property ;
    rdfs:label 'Service Description' ;
    rdfs:comment 'Human-readable description of the billable service or work performed on this line item, as it appears on the client invoice. Examples: Temporary Staffing Services - IT, Direct Placement Fee - Software Engineer, Per Diem - Travel Assignment.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'The tax jurisdiction or tax treatment code applied to this invoice line item in Oracle NetSuite ERP. Determines applicable sales tax, use tax, or VAT rates based on the clients billing location and service type.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmsReqNumber rdf:type rdf:Property ;
    rdfs:label 'Vms Req Number' ;
    rdfs:comment 'The requisition or purchase order number assigned by the clients Vendor Management System (VMS), such as Beeline, for this billing line. Required for VMS-managed programs to match invoices to approved requisitions and enable straight-through processing.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingRateScheduleId rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Schedule Id' ;
    rdfs:comment 'Foreign key linking to billing.rate_schedule. Business justification: Bill rates are often derived from or reference rate schedules (rate cards). A bill_rate record represents a specific negotiated rate, which may be based on a rate_schedule template. This FK allows tra' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingRateSchedule .

ind:contractSowId rdf:type rdf:Property ;
    rdfs:label 'Contract Sow Id' ;
    rdfs:comment 'Foreign key linking to contract.sow. Business justification: SOW-specific rates for project-based work with fixed pricing or milestone billing. Required for SOW rate validation, project margin analysis, and ensuring rates match SOW pricing model.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sow .

ind:previousRateBillRateId rdf:type rdf:Property ;
    rdfs:label 'Previous Rate Bill Rate Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the prior version of this bill rate record. Enables rate lineage tracking and audit trail for rate changes over the engagement lifecycle.' ;
    rdfs:domain ind:BillRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillRate .

ind:tierClassificationId rdf:type rdf:Property ;
    rdfs:label 'Tier Classification Id' ;
    rdfs:comment 'Foreign key linking to vendor.tier_classification. Business justification: In MSP managed programs, supplier tier classification determines bill rate eligibility and markup tier. Tier 1 suppliers receive preferred rates vs Tier 2. Rate setup and tier-based pricing reports re' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TierClassification .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The agreed-upon rate charged to the client per unit (hour, day, or project) for the specified job category and skill level. This is the authoritative rate used for invoice generation. Expressed in the currency defined by currency_code.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:burdenIncluded rdf:type rdf:Property ;
    rdfs:label 'Burden Included' ;
    rdfs:comment 'Indicates whether employer burden costs (FICA, FUTA, SUTA, Workers Compensation, benefits) are factored into the bill rate amount. When True, the bill rate is all-inclusive; when False, burden is billed separately or absorbed by the staffing firm.' ;
    rdfs:domain ind:BillRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:burdenRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Burden Rate Percentage' ;
    rdfs:comment 'The employer burden rate percentage applied to the pay rate, covering FICA, FUTA, SUTA, Workers Compensation, and benefits costs. Used to calculate true gross margin when burden_included is True.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dtBillRateAmount rdf:type rdf:Property ;
    rdfs:label 'Dt Bill Rate Amount' ;
    rdfs:comment 'The negotiated bill rate for double-time hours (holiday, weekend, or contractually defined premium hours). Applied when timesheet entries are classified as DT per the client MSA terms.' ;
    rdfs:domain ind:BillRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossMarginPercentage rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Percentage' ;
    rdfs:comment 'Gross margin expressed as a percentage of the bill rate: ((Bill Rate - Pay Rate - Burden) / Bill Rate) * 100. Represents the profitability of the engagement after direct labor costs. Key KPI for financial reporting and Power BI dashboards.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxBillRateAmount rdf:type rdf:Property ;
    rdfs:label 'Max Bill Rate Amount' ;
    rdfs:comment 'The ceiling rate above which this bill rate cannot be set, as defined by the client rate card or VMS program constraints. Used in rate cap enforcement for MSP/VMS-managed programs.' ;
    rdfs:domain ind:BillRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minBillRateAmount rdf:type rdf:Property ;
    rdfs:label 'Min Bill Rate Amount' ;
    rdfs:comment 'The floor rate below which this bill rate cannot be negotiated, as defined by the rate card or internal pricing policy. Enforces minimum margin thresholds during rate negotiations and VMS submissions.' ;
    rdfs:domain ind:BillRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otBillRateAmount rdf:type rdf:Property ;
    rdfs:label 'Ot Bill Rate Amount' ;
    rdfs:comment 'The negotiated bill rate for overtime hours (hours exceeding the FLSA standard 40-hour workweek threshold). Stored separately from the standard rate to support accurate invoice generation for OT hours on timesheets.' ;
    rdfs:domain ind:BillRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payRateAmount rdf:type rdf:Property ;
    rdfs:label 'Pay Rate Amount' ;
    rdfs:comment 'The corresponding pay rate for the worker associated with this bill rate. Stored alongside the bill rate to enable real-time spread and gross margin calculations without joining to the payroll domain.' ;
    rdfs:domain ind:BillRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateVersion rdf:type rdf:Property ;
    rdfs:label 'Rate Version' ;
    rdfs:comment 'Sequential version number for this bill rate record, incremented each time the rate is renegotiated or updated. Supports rate history tracking and ensures the correct version is applied to invoices within the effective date range.' ;
    rdfs:domain ind:BillRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'The native record identifier from the originating system of record (Salesforce Revenue Cloud or Oracle NetSuite ERP). Enables cross-system reconciliation and data lineage tracing in the Databricks Silver Layer.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientRateCardId rdf:type rdf:Property ;
    rdfs:label 'Client Rate Card Id' ;
    rdfs:comment 'Foreign key linking to client.client_rate_card. Business justification: billing_rate_schedule operationalizes the rates from client_rate_card for actual billing. bill_rate already has this FK but billing_rate_schedule (the template/schedule level) does not. Rate audits an' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientRateCard .

ind:requirementId rdf:type rdf:Property ;
    rdfs:label 'Requirement Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_requirement. Business justification: Rate schedules must incorporate compliance requirements (prevailing wage rules, state-specific wage laws, federal contractor requirements). Pricing strategy and rate card design depend on applicable c' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Requirement .

ind:supersededByScheduleBillingRateScheduleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Schedule Billing Rate Schedule Id' ;
    rdfs:comment 'Reference to the rate schedule that replaces this one when status is Superseded. Nullable for active schedules. Used to maintain rate schedule lineage and version history.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingRateSchedule .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'The date on which this rate schedule was approved by authorized personnel (finance, sales leadership, or client). Used for compliance and audit purposes.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baseBillRate rdf:type rdf:Property ;
    rdfs:label 'Base Bill Rate' ;
    rdfs:comment 'The standard hourly bill rate charged to the client for regular hours worked under this rate schedule. Expressed in the contract currency. Foundation for markup and margin calculations.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:basePayRate rdf:type rdf:Property ;
    rdfs:label 'Base Pay Rate' ;
    rdfs:comment 'The standard hourly pay rate paid to the worker for regular hours worked under this rate schedule. Used to calculate spread and gross margin. Expressed in the contract currency.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'The frequency at which invoices are generated for placements under this rate schedule. Aligns with client payment terms and payroll cycles.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingRateScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the rate schedule. Active schedules are in use, Inactive are retired, Draft are under development, Pending Approval await authorization, Expired have passed their end date, and Superseded have been replaced by newer versions.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionFeePercentage rdf:type rdf:Property ;
    rdfs:label 'Conversion Fee Percentage' ;
    rdfs:comment 'The percentage of annual salary charged as a conversion fee if the client hires a temporary worker as a permanent employee (temp-to-perm conversion). Nullable for direct hire or non-convertible placements.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:directPlacementFeePercentage rdf:type rdf:Property ;
    rdfs:label 'Direct Placement Fee Percentage' ;
    rdfs:comment 'The percentage of first-year salary charged for direct hire placements under this rate schedule. Typically ranges from 15% to 25% depending on role complexity and market conditions.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dtMultiplier rdf:type rdf:Property ;
    rdfs:label 'Dt Multiplier' ;
    rdfs:comment 'The multiplier applied to the base bill rate for double-time hours (typically 2.0). Used for hours worked on holidays, weekends, or beyond daily overtime thresholds per state law or contract terms.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicMarket rdf:type rdf:Property ;
    rdfs:label 'Geographic Market' ;
    rdfs:comment 'The geographic region, metro area, or market zone to which this rate schedule applies. Used for cost-of-living adjustments and regional rate differentiation.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holidayRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Holiday Rate Multiplier' ;
    rdfs:comment 'The multiplier applied to the base bill rate for hours worked on designated holidays. Varies by client contract and may differ from standard overtime or double-time rates.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Maximum Hours Per Week' ;
    rdfs:comment 'The maximum number of hours per week allowed under this rate schedule before requiring special approval or triggering overtime. Used for compliance with client budgets and labor law thresholds.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Minimum Hours Per Week' ;
    rdfs:comment 'The minimum number of hours per week guaranteed or required under this rate schedule. Used for part-time, full-time, and contract-to-hire classifications.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'The date and time when this rate schedule record was last updated. Used for change tracking and audit compliance.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'The number of days from invoice date within which payment is due from the client. Standard terms include Net 30, Net 45, or Net 60. Used for accounts receivable aging and cash flow forecasting.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:perDiemAllowance rdf:type rdf:Property ;
    rdfs:label 'Per Diem Allowance' ;
    rdfs:comment 'The daily allowance amount provided for meals, lodging, and incidental expenses for travel assignments. Nullable for non-travel roles. Expressed in the contract currency.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleCode rdf:type rdf:Property ;
    rdfs:label 'Schedule Code' ;
    rdfs:comment 'Short alphanumeric code used as a unique business identifier for the rate schedule in billing systems and client contracts.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Business-friendly name of the rate schedule used for identification and reference in client engagements and internal reporting.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Classification of the rate schedule indicating the billing model and engagement structure. Standard for general placements, Premium for specialized skills, MSP-Managed for Managed Service Provider programs, VMS-Driven for Vendor Management System engagements, SOW-Based for Statement of Work contracts, and Project-Based for fixed-scope deliverables.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillTier rdf:type rdf:Property ;
    rdfs:label 'Skill Tier' ;
    rdfs:comment 'The proficiency or seniority level for which this rate schedule is designed. Entry for junior roles, Intermediate for mid-level, Advanced for senior, Expert for specialized, and Executive for leadership positions.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaFillTimeDays rdf:type rdf:Property ;
    rdfs:label 'Sla Fill Time Days' ;
    rdfs:comment 'The maximum number of days committed to fill a requisition under this rate schedule as defined in the client SLA. Used for Time to Fill (TTF) performance tracking.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaSubmittalCount rdf:type rdf:Property ;
    rdfs:label 'Sla Submittal Count' ;
    rdfs:comment 'The minimum number of qualified candidate submittals guaranteed per requisition under this rate schedule. Used for Quality of Submission (QoS) performance measurement.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Unique identifier for the payment transaction. Primary key for the payment entity.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payment .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'The portion of the payment amount that has been applied to outstanding invoices. May be less than payment_amount if payment is partially unapplied.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankAccountLastFour rdf:type rdf:Property ;
    rdfs:label 'Bank Account Last Four' ;
    rdfs:comment 'Last four digits of the bank account number used for the payment. Masked for security and PCI compliance.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashAccountCode rdf:type rdf:Property ;
    rdfs:label 'Cash Account Code' ;
    rdfs:comment 'The general ledger cash account code to which this payment is deposited. Used for financial reporting and reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The interface or channel through which the payment was submitted (e.g., online portal, mobile app, mail, in-person). [ENUM-REF-CANDIDATE: Online Portal|Mobile App|Mail|In-Person|Phone|Bank Transfer|Lockbox — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearedDate rdf:type rdf:Property ;
    rdfs:label 'Cleared Date' ;
    rdfs:comment 'The date on which the payment cleared the banking system and funds became available. Null if payment has not yet cleared.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discountTaken rdf:type rdf:Property ;
    rdfs:label 'Discount Taken' ;
    rdfs:comment 'The amount of early payment discount taken by the client if payment was made within discount terms. Reduces the amount due.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The exchange rate applied to convert the payment amount to the base currency if the payment was made in a foreign currency. Null if payment is in base currency.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isOverpayment rdf:type rdf:Property ;
    rdfs:label 'Is Overpayment' ;
    rdfs:comment 'Flag indicating whether this payment exceeds the amount due, resulting in a credit balance on the client account.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPartialPayment rdf:type rdf:Property ;
    rdfs:label 'Is Partial Payment' ;
    rdfs:comment 'Flag indicating whether this payment represents a partial payment against an invoice (true) or full payment (false).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockboxBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Lockbox Batch Number' ;
    rdfs:comment 'The batch identifier from the lockbox service if payment was received through a lockbox arrangement. Used for reconciliation of bulk payment processing.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'The name or identifier of the user or system that last modified the payment record. Used for audit trail purposes.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The date on which the payment was received or processed. Principal business event timestamp for the payment transaction.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The financial instrument or mechanism used to make the payment (e.g., ACH, wire transfer, check, credit card).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Number' ;
    rdfs:comment 'Externally visible unique payment reference number used for tracking and reconciliation. Business identifier for the payment transaction.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current lifecycle status of the payment transaction indicating its processing state and validity.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processor rdf:type rdf:Property ;
    rdfs:label 'Processor' ;
    rdfs:comment 'The name of the payment processor or gateway that handled the transaction (e.g., Stripe, PayPal, Authorize.Net, bank name for ACH/wire).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciledBy rdf:type rdf:Property ;
    rdfs:label 'Reconciled By' ;
    rdfs:comment 'The name or identifier of the user who performed the payment reconciliation. Used for audit trail purposes.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciledDate rdf:type rdf:Property ;
    rdfs:label 'Reconciled Date' ;
    rdfs:comment 'The date on which the payment was reconciled with bank statements and invoice applications. Null if not yet reconciled.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Status indicating whether the payment has been reconciled with bank statements and invoice applications.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceReference rdf:type rdf:Property ;
    rdfs:label 'Remittance Reference' ;
    rdfs:comment 'Reference number or identifier from the remittance advice document provided by the client indicating which invoices the payment covers.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The date on which the payment was reversed or returned. Null if payment has not been reversed.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'The reason for payment reversal or return if the payment was voided or returned (e.g., insufficient funds, stop payment, account closed).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'Nine-digit ABA routing number identifying the financial institution for ACH or wire transfers. Stored for reconciliation purposes.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terms rdf:type rdf:Property ;
    rdfs:label 'Terms' ;
    rdfs:comment 'The payment terms applicable to this payment (e.g., Net 30, 2/10 Net 30). Indicates the agreed-upon payment schedule and discount eligibility.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionReference rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference' ;
    rdfs:comment 'External transaction identifier from the payment processor or banking system. Used for reconciliation and dispute resolution.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unappliedAmount rdf:type rdf:Property ;
    rdfs:label 'Unapplied Amount' ;
    rdfs:comment 'The portion of the payment amount that has not yet been applied to any invoice. Represents credit on account or overpayment.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'The name or identifier of the user or system that created the payment record. Used for audit trail purposes.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentApplicationId rdf:type rdf:Property ;
    rdfs:label 'Payment Application Id' ;
    rdfs:comment 'Unique identifier for the payment application record. Primary key.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversedByApplicationPaymentApplicationId rdf:type rdf:Property ;
    rdfs:label 'Reversed By Application Payment Application Id' ;
    rdfs:comment 'Reference to the payment application record that reversed this application. Null if this application has not been reversed. Creates audit trail for reversal transactions.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentApplication .

ind:reversesApplicationId rdf:type rdf:Property ;
    rdfs:label 'Reverses Application Id' ;
    rdfs:comment 'Reference to the original payment application record that this record reverses. Null if this is not a reversal transaction. Creates audit trail linking reversals to original applications.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentApplication .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Additional adjustment amount applied to the invoice, such as currency exchange adjustments, rounding differences, or other reconciliation adjustments not classified as discount or write-off.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingBucket rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket' ;
    rdfs:comment 'The accounts receivable aging category of the invoice at the time of payment application. Used for AR aging analysis and collection effectiveness reporting.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'The business date on which the payment was applied to the invoice. This is the accounting effective date for accounts receivable (AR) reduction and may differ from the payment receipt date.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Human-readable business identifier for the payment application record. Externally visible reference number used in financial reporting and reconciliation.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current lifecycle status of the payment application. Pending = awaiting approval, Applied = successfully applied to AR, Reversed = application has been reversed, Disputed = under dispute investigation, Reconciled = confirmed and closed, Voided = cancelled before application.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationType rdf:type rdf:Property ;
    rdfs:label 'Application Type' ;
    rdfs:comment 'Classification of how the payment is being applied. Full = entire invoice paid, Partial = portion of invoice paid, Prepayment = payment applied before invoice due date, Credit Memo Offset = credit memo applied against invoice, Overpayment = payment exceeds invoice amount, Underpayment = payment less than invoice amount.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysToPayment rdf:type rdf:Property ;
    rdfs:label 'Days To Payment' ;
    rdfs:comment 'Number of days between invoice date and payment application date. Used for Days Sales Outstanding (DSO) calculation and payment performance analysis.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Flag indicating whether this payment application is associated with a disputed invoice or payment. Used to track disputed receivables and resolution processes.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Gl Batch Number' ;
    rdfs:comment 'Reference to the general ledger batch in which this payment application was posted. Used for audit trail and GL reconciliation.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'The accounting period date when this payment application was posted to the general ledger. Used for financial period close and reporting.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isDeleted rdf:type rdf:Property ;
    rdfs:label 'Is Deleted' ;
    rdfs:comment 'Soft delete flag indicating whether this payment application record has been logically deleted. Used for audit trail preservation while excluding from active reporting.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEarlyPayment rdf:type rdf:Property ;
    rdfs:label 'Is Early Payment' ;
    rdfs:comment 'Flag indicating whether the payment was received before the invoice due date. Used to track early payment discount eligibility and client payment behavior.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLatePayment rdf:type rdf:Property ;
    rdfs:label 'Is Late Payment' ;
    rdfs:comment 'Flag indicating whether the payment was received after the invoice due date. Used to track collection effectiveness and client payment behavior.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netAppliedAmount rdf:type rdf:Property ;
    rdfs:label 'Net Applied Amount' ;
    rdfs:comment 'The net amount applied to accounts receivable after all discounts, write-offs, and adjustments. Calculated as applied_amount minus discount_amount minus writeoff_amount plus/minus adjustment_amount.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'External reference number from the payment transaction, such as check number, wire confirmation number, ACH trace number, or credit card authorization code. Used for payment reconciliation and audit.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeoffAmount rdf:type rdf:Property ;
    rdfs:label 'Writeoff Amount' ;
    rdfs:comment 'The amount written off as uncollectible or forgiven on this invoice application. Represents bad debt or goodwill adjustment that reduces accounts receivable without cash receipt.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientContactId rdf:type rdf:Property ;
    rdfs:label 'Client Contact Id' ;
    rdfs:comment 'Foreign key linking to client.client_contact. Business justification: credit_memo has client_notification_date and client_notified fields indicating a specific contact was notified. In staffing billing, credit memos are issued to and acknowledged by a specific client AP' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientContact .

ind:conversionId rdf:type rdf:Property ;
    rdfs:label 'Conversion Id' ;
    rdfs:comment 'Foreign key linking to placement.conversion. Business justification: Conversion fall-offs (converted employee leaves before minimum tenure) trigger conversion fee credit memos per MSA terms. Credit memos track fee reversals or prorated adjustments. Essential for conver' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Conversion .

ind:fallOffId rdf:type rdf:Property ;
    rdfs:label 'Fall Off Id' ;
    rdfs:comment 'Foreign key linking to placement.fall_off. Business justification: Credit memos are issued to clients when placements fall off within the guarantee period. The credit_memo must reference the specific fall_off event to support guarantee period validation, fee credit c' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FallOff .

ind:primaryCreditInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Primary Credit Invoice Id' ;
    rdfs:comment 'Reference to the originating invoice that this credit memo offsets or reduces. Links the credit memo to the specific billing transaction being corrected, reversed, or adjusted. Core to void-and-rebill workflows and accounts receivable reconciliation.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:appliedDate rdf:type rdf:Property ;
    rdfs:label 'Applied Date' ;
    rdfs:comment 'Date on which the credit memo was fully applied against outstanding invoice balances. Populated when applied_status transitions to fully_applied. Used for accounts receivable close-out and cash flow reporting.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appliedStatus rdf:type rdf:Property ;
    rdfs:label 'Applied Status' ;
    rdfs:comment 'Indicates the application state of the credit memo against outstanding invoices. unapplied: no amount applied yet; partially_applied: some amount applied, remainder open; fully_applied: entire credit amount has been applied; expired: credit memo passed expiration date without full application.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'End date of the billing period to which the credit memo applies. Paired with billing_period_start_date to define the scope of the adjustment. Critical for timesheet rebilling and retroactive rate correction workflows.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'Start date of the billing period to which the credit memo applies. Used when the credit relates to a specific timesheet week, pay period, or project billing cycle. Enables period-specific accounts receivable adjustments and retroactive rate correction scoping.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Client Notification Date' ;
    rdfs:comment 'Date on which the client was formally notified of the credit memo. Populated when client_notified is True. Used for SLA measurement of credit memo communication turnaround and client relationship management.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientNotified rdf:type rdf:Property ;
    rdfs:label 'Client Notified' ;
    rdfs:comment 'Indicates whether the client has been formally notified of the credit memo issuance (True) or not yet notified (False). Supports client communication tracking and SLA compliance for credit memo notification turnaround.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctedBillRate rdf:type rdf:Property ;
    rdfs:label 'Corrected Bill Rate' ;
    rdfs:comment 'The revised bill rate that should have been applied, used in retroactive rate correction credit memos. The difference between original_bill_rate and corrected_bill_rate, multiplied by the applicable hours, drives the credit_amount calculation. Supports rate card compliance validation.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'Internal cost center or profit center code associated with the credit memo for management accounting and P&L attribution. Enables gross margin and spread analysis by business unit or division within Oracle NetSuite ERP.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'Gross monetary value of the credit memo in the billing currency. Represents the total amount to be credited against the clients outstanding accounts receivable balance. Always expressed as a positive value; the credit direction is implied by the document type.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditedHours rdf:type rdf:Property ;
    rdfs:label 'Credited Hours' ;
    rdfs:comment 'Number of hours being credited in this memo, applicable for time-and-materials billing model credits (timesheet rebilling, rate corrections). Multiplied by the rate differential to derive credit_amount. Nullable for non-hourly billing models.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'General Ledger account code to which the credit memo is posted in Oracle NetSuite ERP. Determines the financial statement impact of the credit (e.g., revenue reversal, accounts receivable reduction, allowance for doubtful accounts). Required for period-close and financial reporting.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isVoidAndRebill rdf:type rdf:Property ;
    rdfs:label 'Is Void And Rebill' ;
    rdfs:comment 'Flag indicating whether this credit memo is part of a formal void-and-rebill workflow (True) or a standalone partial credit (False). When True, the credit memo fully offsets the originating invoice and a rebill_invoice_id should be populated with the replacement invoice.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'The calendar date on which the credit memo was formally issued to the client. Used as the principal business event date for accounts receivable aging, revenue recognition adjustments, and period-close reporting. Conforms to yyyy-MM-dd format.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalBillRate rdf:type rdf:Property ;
    rdfs:label 'Original Bill Rate' ;
    rdfs:comment 'The bill rate (hourly or per-diem) that was originally invoiced and is being corrected by this credit memo. Applicable for rate_correction and timesheet_rebilling reason codes. Expressed in the billing currency per unit (hour or day). Supports spread and markup recalculation.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text narrative providing detailed explanation of why the credit memo was issued. Supplements the reason_code with specific context such as the nature of the billing error, the corrected bill rate, or the timesheet period being rebilled. Required for audit and dispute documentation.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Adjustment Amount' ;
    rdfs:comment 'Tax amount being reversed or adjusted as part of this credit memo, where applicable. Represents the tax component of the original invoice that is being credited back to the client. Required for accurate tax liability reporting and IRS compliance. Nullable when no tax was applied to the original invoice.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidDate rdf:type rdf:Property ;
    rdfs:label 'Void Date' ;
    rdfs:comment 'Date on which the credit memo was voided. Populated only when approval_status is voided. Used in void-and-rebill workflows and accounts receivable audit trails.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentExtensionId rdf:type rdf:Property ;
    rdfs:label 'Assignment Extension Id' ;
    rdfs:comment 'Foreign key linking to placement.assignment_extension. Business justification: Billing disputes frequently arise from rate changes on assignment extensions (prior vs. revised bill rate). Staffing billing teams need this link to pull extension rate change details when resolving c' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssignmentExtension .

ind:slaId rdf:type rdf:Property ;
    rdfs:label 'Sla Id' ;
    rdfs:comment 'Foreign key linking to contract.sla. Business justification: billing_dispute already has sla_breach_flag, indicating SLA breaches trigger disputes. Linking to the specific SLA record enables penalty_amount calculation, SLA breach reporting, and dispute resoluti' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sla .

ind:agreedBillRate rdf:type rdf:Property ;
    rdfs:label 'Agreed Bill Rate' ;
    rdfs:comment 'The contractually agreed bill rate per the client rate card, MSA, or VMS program at the time of the disputed invoice. Used to calculate the rate variance driving the dispute and to validate the correct rate for invoice adjustment.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Credit Amount' ;
    rdfs:comment 'The dollar amount approved for credit or adjustment as the outcome of dispute resolution. May be equal to, less than, or zero relative to the disputed_amount depending on resolution type. Feeds credit memo generation in Oracle NetSuite ERP.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedHours rdf:type rdf:Property ;
    rdfs:label 'Approved Hours' ;
    rdfs:comment 'The number of hours the client acknowledges as correctly approved and billable, as determined during dispute investigation. Used to calculate the hours variance and determine the correct invoice adjustment amount.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billRateDisputed rdf:type rdf:Property ;
    rdfs:label 'Bill Rate Disputed' ;
    rdfs:comment 'The bill rate (hourly or per-diem) that the client is contesting as incorrect on the disputed invoice. Captured specifically for rate_discrepancy dispute types to enable direct comparison against the agreed rate on the client rate card or MSA.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionsHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Collections Hold Flag' ;
    rdfs:comment 'Indicates whether the disputed invoice or invoice line has been placed on collections hold pending dispute resolution. True prevents collections activity on the disputed amount; False allows normal collections processing to proceed.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeDescription rdf:type rdf:Property ;
    rdfs:label 'Dispute Description' ;
    rdfs:comment 'Free-text narrative describing the nature of the billing dispute as submitted by the client or captured by the billing operations team. Provides context beyond the structured dispute_type classification for investigation and resolution purposes.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for the dispute, used in client communications, collections correspondence, and dispute tracking. Sourced from Salesforce Revenue Cloud case numbering.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current workflow state of the dispute through its resolution lifecycle. Drives collections hold logic — invoices with open or under_review disputes are typically placed on collections hold pending resolution.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeType rdf:type rdf:Property ;
    rdfs:label 'Dispute Type' ;
    rdfs:comment 'Classification of the nature of the billing dispute. Rate discrepancy indicates bill rate vs. agreed rate mismatch; hours mismatch indicates timesheet vs. billed hours variance; unauthorized charge indicates a charge not covered by the MSA or SOW; duplicate invoice indicates the same charge was billed twice; worker eligibility indicates the worker did not meet client-specified credential or compliance requirements. [ENUM-REF-CANDIDATE: rate_discrepancy|hours_mismatch|unauthorized_charge|duplicate_invoice|worker_eligibility|other — promote to reference product]' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'The gross dollar amount the client is contesting on the invoice or invoice line. Represents the full value under dispute before any partial credit or adjustment is determined. Used in accounts receivable aging and collections hold logic.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputedHours rdf:type rdf:Property ;
    rdfs:label 'Disputed Hours' ;
    rdfs:comment 'The number of hours the client is contesting as incorrectly billed. Captured specifically for hours_mismatch dispute types to enable reconciliation against approved timesheet records in Kronos Workforce Ready.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'The date on which the dispute was escalated to a higher resolution tier. Null when escalation_flag is False. Used to measure escalation response time and SLA compliance at the escalated tier.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether the dispute has been formally escalated to senior management or a specialized resolution team due to complexity, high value, or SLA breach. True when escalated; False when being handled at standard tier.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoicePeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Invoice Period End' ;
    rdfs:comment 'End date of the billing period covered by the disputed invoice. Used alongside invoice_period_start to define the exact work period under dispute for timesheet reconciliation and billing audit purposes.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoicePeriodStart rdf:type rdf:Property ;
    rdfs:label 'Invoice Period Start' ;
    rdfs:comment 'Start date of the billing period covered by the disputed invoice. Provides temporal context for the dispute, enabling correlation with timesheet records, placement assignments, and pay period data.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'The calendar date on which the client formally raised the billing dispute. Used as the start point for SLA measurement, aging calculations, and dispute-to-resolution cycle time reporting.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Business priority level assigned to the dispute, typically based on disputed amount, client tier, or SLA requirements. Drives resolution queue ordering and escalation thresholds within the billing operations workflow.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Precise date and time when the dispute was first captured in the system of record. Serves as the RECORD_AUDIT_CREATED anchor for SLA tracking and audit trail purposes.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'The calendar date on which the dispute was formally resolved and closed. Used to calculate dispute cycle time (open_date to resolution_date) and to measure SLA compliance for dispute resolution.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Free-text notes documenting the investigation findings, resolution rationale, and any client communication outcomes. Captured by the resolution owner upon closing the dispute. Supports audit trail and process improvement analysis.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionType rdf:type rdf:Property ;
    rdfs:label 'Resolution Type' ;
    rdfs:comment 'The outcome category of the dispute resolution. Credit issued means a credit memo was generated; invoice adjusted means the original invoice was corrected; dispute rejected means the client claim was denied; partial credit means a portion of the disputed amount was credited; write_off means the amount was written off to bad debt.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'Categorization of the underlying cause of the billing dispute after investigation. Used for process improvement analytics, identifying systemic billing errors, and reducing future dispute rates. Billing error indicates internal invoicing mistake; timesheet error indicates incorrect hours submitted; rate setup error indicates incorrect bill rate configured in the system; worker compliance indicates the worker did not meet eligibility requirements; system error indicates a technical processing failure; client error indicates the dispute was raised in error by the client.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether the dispute resolution exceeded the sla_target_days threshold. True when the dispute remained unresolved beyond the SLA target; False when resolved within the target. Drives SLA compliance reporting and client relationship management alerts.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetDays rdf:type rdf:Property ;
    rdfs:label 'Sla Target Days' ;
    rdfs:comment 'The contractually or operationally defined target number of calendar days within which the dispute must be resolved, per the client SLA or internal KPI standard. Used to calculate SLA compliance and flag at-risk disputes.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionActivityId rdf:type rdf:Property ;
    rdfs:label 'Collection Activity Id' ;
    rdfs:comment 'Unique identifier for the collection activity record. Primary key.' ;
    rdfs:domain ind:CollectionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activityDate rdf:type rdf:Property ;
    rdfs:label 'Activity Date' ;
    rdfs:comment 'The date on which the collection activity was performed. Used for tracking collections timeline and aging analysis.' ;
    rdfs:domain ind:CollectionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'The type of collection action taken. Categorizes the nature of the collection effort for workflow management and effectiveness analysis.' ;
    rdfs:domain ind:CollectionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionActivityStatus rdf:type rdf:Property ;
    rdfs:label 'Collection Activity Status' ;
    rdfs:comment 'The current status of the collection activity record. Tracks whether the activity is complete or requires further action.' ;
    rdfs:domain ind:CollectionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Contact Email Address' ;
    rdfs:comment 'The email address used to reach the client contact during this activity, if applicable. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:CollectionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactMethod rdf:type rdf:Property ;
    rdfs:label 'Contact Method' ;
    rdfs:comment 'The communication channel used for the collection activity. Distinct from activity_type; tracks the medium of contact for effectiveness analysis.' ;
    rdfs:domain ind:CollectionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Contact Phone Number' ;
    rdfs:comment 'The phone number used to reach the client contact during this activity, if applicable. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:CollectionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Issued Flag' ;
    rdfs:comment 'Indicates whether a credit memo was issued as a result of this collection activity, typically due to a validated dispute. Impacts revenue recognition and accounts receivable.' ;
    rdfs:domain ind:CollectionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'The duration of the collection activity in minutes, particularly for phone calls or in-person meetings. Used for resource allocation and efficiency analysis.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'The escalation tier to which the collection activity has been elevated. Tracks progression through collections workflow from initial contact through legal action or write-off recommendation.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Date' ;
    rdfs:comment 'The scheduled date for the next collection action or follow-up. Drives collections workflow and ensures timely pursuit of outstanding receivables.' ;
    rdfs:domain ind:CollectionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalActionFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Action Flag' ;
    rdfs:comment 'Indicates whether this activity involved or resulted in legal action or referral to legal counsel. Critical for compliance and risk management tracking.' ;
    rdfs:domain ind:CollectionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'The result of the collection activity. Drives next-action workflow and measures collection effectiveness. Critical for Days Sales Outstanding (DSO) reduction tracking.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReceivedAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Received Amount' ;
    rdfs:comment 'The dollar amount of payment received as a direct result of this collection activity, if applicable. Links collection effort to revenue realization.' ;
    rdfs:domain ind:CollectionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'The date payment was received as a result of this collection activity, if applicable. Used for measuring time-to-payment and collection effectiveness.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promiseToPayAmount rdf:type rdf:Property ;
    rdfs:label 'Promise To Pay Amount' ;
    rdfs:comment 'The dollar amount the client committed to pay, if a promise to pay was obtained. May be partial or full invoice amount.' ;
    rdfs:domain ind:CollectionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promiseToPayDate rdf:type rdf:Property ;
    rdfs:label 'Promise To Pay Date' ;
    rdfs:comment 'The date the client committed to making payment, if a promise to pay was obtained. Used for follow-up scheduling and commitment tracking.' ;
    rdfs:domain ind:CollectionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffReason rdf:type rdf:Property ;
    rdfs:label 'Write Off Reason' ;
    rdfs:comment 'The business justification for recommending write-off, if applicable. Supports bad debt analysis and collections process improvement.' ;
    rdfs:domain ind:CollectionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffRecommendedFlag rdf:type rdf:Property ;
    rdfs:label 'Write Off Recommended Flag' ;
    rdfs:comment 'Indicates whether the collector recommended writing off the outstanding balance as uncollectible. Triggers approval workflow and financial reporting.' ;
    rdfs:domain ind:CollectionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:arClientContactId rdf:type rdf:Property ;
    rdfs:label 'Ar Client Contact Id' ;
    rdfs:comment 'Foreign key linking to client.client_contact. Business justification: billing_account stores ar_contact_name/email/phone as denormalized text — these represent the client\'s AP/billing contact. Staffing AR teams must contact this person for invoice delivery, payment foll' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientContact .

ind:msaId rdf:type rdf:Property ;
    rdfs:label 'Msa Id' ;
    rdfs:comment 'Foreign key linking to contract.msa. Business justification: Billing accounts are established under executed MSAs — payment terms, credit limits, and billing cycles in billing_account are governed by the MSA. billing_account.msa_reference_number is a denormaliz' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Msa .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'Legal or trade name of the client entity to which invoices are issued. Reflects the billing entity name as it appears on invoices and AR records. May differ from the CRM client profile name if the billing entity is a subsidiary or parent.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally-known, human-readable billing account number assigned to the clients financial billing entity. Used on invoices, statements, and AR correspondence. Sourced from Salesforce Revenue Cloud or Oracle NetSuite ERP customer record.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle state of the billing account. Controls whether new invoices can be generated and whether payments are being accepted. on_hold indicates a credit or collections hold. suspended indicates a temporary freeze pending resolution.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'Primary street address line of the billing entity. Used on invoice headers, statements, and AR correspondence. Must match the legal billing address on the Master Service Agreement (MSA).' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'Secondary address line for the billing entity (suite, floor, department, PO Box). Supplementary to billing_address_line1 for complete invoice address formatting.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City of the billing entitys legal billing address. Used on invoice headers and for state/local tax jurisdiction determination.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code of the billing entitys legal billing address (e.g., USA, CAN, GBR). Determines currency, tax regime, and regulatory compliance requirements including GDPR for international clients.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCycle rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle' ;
    rdfs:comment 'Frequency at which invoices are generated and issued to this billing account. Aligns with the timesheet submission and payroll cycle cadence. Weekly is most common for temporary staffing; monthly for SOW and project-based engagements.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'ZIP or postal code of the billing entitys legal billing address. Used for tax jurisdiction lookup and invoice address formatting.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingState rdf:type rdf:Property ;
    rdfs:label 'Billing State' ;
    rdfs:comment 'Two-letter US state or territory code of the billing entitys legal billing address. Drives state tax applicability, SUTA jurisdiction, and invoice compliance requirements.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidatedInvoicing rdf:type rdf:Property ;
    rdfs:label 'Consolidated Invoicing' ;
    rdfs:comment 'Indicates whether multiple job orders or work locations should be consolidated into a single invoice per billing cycle, rather than generating separate invoices per placement or location. Common for enterprise MSP clients.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum outstanding AR balance (in account currency) that Staffing Hr will extend to this billing account before requiring payment or placing the account on hold. Enforced during invoice generation and placement approval workflows.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Status' ;
    rdfs:comment 'Current credit standing of the billing account as assessed by the AR/credit team. Determines whether new placements and invoices can be extended to this client. probationary indicates reduced credit terms are in effect.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyPaymentDiscountDays rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Days' ;
    rdfs:comment 'Number of days from invoice date within which the client must pay to qualify for the early payment discount percentage. For example, 10 in a 2/10 Net 30 arrangement. Null if no early payment discount applies.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earlyPaymentDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Pct' ;
    rdfs:comment 'Percentage discount offered to the client if payment is received within the early payment discount window (e.g., 0.0200 = 2% discount). Supports 2/10 Net 30 and similar early payment incentive structures common in staffing billing.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalCustomerCode rdf:type rdf:Property ;
    rdfs:label 'External Customer Code' ;
    rdfs:comment 'The clients own internal account or vendor number assigned to Staffing Hr within the clients ERP or VMS system (e.g., Beeline VMS supplier ID, client SAP vendor number). Used for cross-system reconciliation and remittance matching.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Invoice Delivery Method' ;
    rdfs:comment 'Preferred method by which invoices are delivered to the clients AR department. vms_portal indicates delivery through the clients Vendor Management System (VMS) such as Beeline. edi indicates Electronic Data Interchange transmission.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceFormat rdf:type rdf:Property ;
    rdfs:label 'Invoice Format' ;
    rdfs:comment 'Format template used when generating invoices for this billing account. detailed includes line-level timesheet and worker detail. summary provides consolidated totals only. custom indicates a client-specific format defined in the MSA.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lateFeePct rdf:type rdf:Property ;
    rdfs:label 'Late Fee Pct' ;
    rdfs:comment 'Monthly percentage fee applied to overdue invoice balances beyond the payment terms net days. For example, 0.0150 = 1.5% per month. Defined in the Master Service Agreement (MSA). Null if no late fee applies.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netsuiteCustomerCode rdf:type rdf:Property ;
    rdfs:label 'Netsuite Customer Code' ;
    rdfs:comment 'Oracle NetSuite ERP internal customer record identifier for this billing account. Used for GL posting, AR sub-ledger reconciliation, and revenue recognition alignment between the billing domain and the ERP general ledger.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsNetDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Net Days' ;
    rdfs:comment 'Number of calendar days from invoice date within which the client is contractually obligated to remit payment (e.g., Net 30, Net 45, Net 60). Drives AR aging buckets, dunning schedules, and cash flow forecasting.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredPaymentMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Payment Method' ;
    rdfs:comment 'Clients preferred method for remitting payment against invoices. ach (Automated Clearing House) is most common for enterprise staffing clients. vms_payment indicates payment processed through the clients VMS platform.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderRequired rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Required' ;
    rdfs:comment 'Indicates whether a valid Purchase Order (PO) number must be present on all invoices issued to this billing account. When True, invoices without a PO number will be rejected by the clients AP department.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesforceAccountCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Account Code' ;
    rdfs:comment 'Salesforce Revenue Cloud account record identifier linked to this billing account. Enables traceability between the billing domain SSOT and the upstream CRM/revenue system for invoice generation and client financial management.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExempt rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt' ;
    rdfs:comment 'Indicates whether the billing account holds a valid tax exemption certificate, meaning sales tax or applicable taxes should not be applied to invoices. When True, tax_exempt_certificate_number must be populated.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxExemptCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Certificate Number' ;
    rdfs:comment 'Certificate number of the clients tax exemption documentation. Required when tax_exempt is True. Used to substantiate tax-exempt invoice treatment during audits and state tax authority reviews.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Federal Employer Identification Number (EIN) or Tax Identification Number (TIN) of the billing entity. Required for IRS 1099 reporting, tax exemption validation, and invoice compliance. Format: XX-XXXXXXX (EIN format).' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmsBillingEnabled rdf:type rdf:Property ;
    rdfs:label 'Vms Billing Enabled' ;
    rdfs:comment 'Indicates whether this billing account is managed through a clients Vendor Management System (VMS) such as Beeline, requiring invoice submission and payment processing through the VMS portal rather than direct billing.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placementFeeId rdf:type rdf:Property ;
    rdfs:label 'Placement Fee Id' ;
    rdfs:comment 'Unique surrogate identifier for the placement fee record. Primary key for the billing.placement_fee data product. TRANSACTION_HEADER role — represents a discrete direct placement or permanent hire fee billing event with its own lifecycle.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlacementFee .

ind:offerId rdf:type rdf:Property ;
    rdfs:label 'Offer Id' ;
    rdfs:comment 'Foreign key linking to placement.offer. Business justification: Placement fees originate from accepted offers; fee audits trace back to the original offer terms (salary, fee percentage, start date). Staffing billing teams require this link to validate fee calculat' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offer .

ind:primaryReplacementPlacementAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Replacement Placement Assignment Id' ;
    rdfs:comment 'Reference to the replacement placement record created when a fall-off occurs and the client exercises their guarantee replacement right. Links the original fee record to the replacement placement for tracking and reporting.' ;
    rdfs:domain ind:PlacementFee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assignment .

ind:recruiterAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Recruiter Assignment Id' ;
    rdfs:comment 'Foreign key linking to recruitment.recruiter_assignment. Business justification: Placement fees must reference recruiter assignments to calculate split fees, determine commission eligibility, and track recruiter performance. Essential for commission payout and split fee allocation' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecruiterAssignment .

ind:rightToRepresentId rdf:type rdf:Property ;
    rdfs:label 'Right To Represent Id' ;
    rdfs:comment 'Foreign key linking to candidate.right_to_represent. Business justification: Placement fee legitimacy audit requires confirming an active right-to-represent agreement existed at time of placement. Staffing compliance and finance teams must verify RTR before approving or disput' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RightToRepresent .

ind:submittalId rdf:type rdf:Property ;
    rdfs:label 'Submittal Id' ;
    rdfs:comment 'Foreign key linking to recruitment.submittal. Business justification: Direct-hire and temp-to-perm placement fee calculation, fall-off tracking, and guarantee period management require tracing the fee to the originating submittal. Staffing billing analysts routinely aud' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submittal .

ind:candidateAnnualSalary rdf:type rdf:Property ;
    rdfs:label 'Candidate Annual Salary' ;
    rdfs:comment 'The candidates agreed first-year annual base salary for the placed position, used as the basis for percentage-based fee calculations. Expressed in the billing currency. Sourced from the placement record in Bullhorn ATS/CRM.' ;
    rdfs:domain ind:PlacementFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditMemoAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Amount' ;
    rdfs:comment 'The monetary value of the credit memo issued to the client, representing the fee amount credited back due to a fall-off within the guarantee period or a billing dispute resolution. Expressed as a positive value; applied as a reduction to the clients AR balance.' ;
    rdfs:domain ind:PlacementFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fallOffDate rdf:type rdf:Property ;
    rdfs:label 'Fall Off Date' ;
    rdfs:comment 'The date on which the placed candidate left or was terminated from the clients position within the guarantee period, triggering a fall-off event. Null if no fall-off occurred. A fall-off within the guarantee period may require fee reversal, credit memo issuance, or replacement candidate sourcing.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fallOffReason rdf:type rdf:Property ;
    rdfs:label 'Fall Off Reason' ;
    rdfs:comment 'The reason code explaining why the placed candidate left the position within the guarantee period. Used for fall-off rate analytics, recruiter performance tracking, and quality-of-submission (QoS) reporting. Null if no fall-off occurred.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Adjustment Amount' ;
    rdfs:comment 'Any negotiated discount, credit memo, or adjustment applied to the gross fee amount. Negative values represent discounts or credits. Supports scenarios such as volume discounts, client concessions, or partial credit for guarantee period replacements.' ;
    rdfs:domain ind:PlacementFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'The gross calculated placement fee amount billed to the client before any adjustments, credits, or discounts. For percentage-based fees, this equals candidate_annual_salary multiplied by fee_percentage. For flat fees, this is the agreed fixed amount. Primary revenue figure for direct placement billing.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeBasis rdf:type rdf:Property ;
    rdfs:label 'Fee Basis' ;
    rdfs:comment 'Indicates whether the placement fee is calculated as a percentage of the candidates first-year annual salary, a flat fixed fee amount, or a hybrid of both. Drives fee calculation logic in Salesforce Revenue Cloud.' ;
    rdfs:domain ind:PlacementFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeDate rdf:type rdf:Property ;
    rdfs:label 'Fee Date' ;
    rdfs:comment 'The principal real-world business event date on which the placement fee was earned, typically aligned to the candidates confirmed start date or the date the direct placement was finalized and accepted by the client. Used as the revenue recognition date.' ;
    rdfs:domain ind:PlacementFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeNumber rdf:type rdf:Property ;
    rdfs:label 'Fee Number' ;
    rdfs:comment 'Externally-known business identifier for the placement fee transaction, used in client communications, invoices, and reconciliation. Format: PF-{YYYY}-{NNNNNN}. Sourced from Salesforce Revenue Cloud opportunity/order object.' ;
    rdfs:domain ind:PlacementFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feePercentage rdf:type rdf:Property ;
    rdfs:label 'Fee Percentage' ;
    rdfs:comment 'The agreed-upon percentage of the candidates first-year annual salary used to calculate the placement fee when fee_basis is percentage_of_salary or hybrid. Typically ranges from 15% to 30% for direct placement. Stored as a decimal (e.g., 20.00 = 20%). Sourced from the client rate card or MSA.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeType rdf:type rdf:Property ;
    rdfs:label 'Fee Type' ;
    rdfs:comment 'Classification of the placement fee by the nature of the engagement model. Direct Placement: one-time fee for permanent hire. Temp-to-Perm: conversion fee when a temporary worker converts to permanent. RPO Fee: fee under a Recruitment Process Outsourcing (RPO) engagement. Retained Search: upfront retainer-based executive search fee. Contingency Search: fee paid only upon successful placement.' ;
    rdfs:domain ind:PlacementFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteeEndDate rdf:type rdf:Property ;
    rdfs:label 'Guarantee End Date' ;
    rdfs:comment 'The calculated date on which the guarantee period expires, derived from the candidates start date plus guarantee_period_days. After this date, the placement fee is fully earned with no replacement obligation. Used for fall-off risk monitoring and revenue recognition.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guaranteePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Guarantee Period Days' ;
    rdfs:comment 'The number of days from the candidates start date during which the staffing firm guarantees the placement. If the candidate leaves or is terminated within this window (fall-off), the client is entitled to a replacement or fee credit. Industry standard ranges from 30 to 90 days. Critical to direct hire operations and fall-off risk management.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoicedAmount rdf:type rdf:Property ;
    rdfs:label 'Invoiced Amount' ;
    rdfs:comment 'The net amount actually invoiced to the client after applying any adjustments (fee_amount + fee_adjustment_amount). This is the amount reflected on the client invoice and tracked in accounts receivable. Supports revenue recognition and AR aging reporting.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFallOff rdf:type rdf:Property ;
    rdfs:label 'Is Fall Off' ;
    rdfs:comment 'Boolean flag indicating whether this placement experienced a fall-off event within the guarantee period. True when fall_off_date is populated and falls within the guarantee window. Drives fall-off rate KPI calculations and revenue reversal workflows.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:comment 'The total amount received from the client against this placement fee invoice. May be less than invoiced_amount if partially paid or disputed. Used for AR reconciliation and cash application in Oracle NetSuite ERP.' ;
    rdfs:domain ind:PlacementFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'The contractual date by which the client must remit payment for the placement fee invoice, calculated from invoice_date based on the agreed payment terms (e.g., Net 30, Net 45). Drives collections and overdue status transitions.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:replacementEligible rdf:type rdf:Property ;
    rdfs:label 'Replacement Eligible' ;
    rdfs:comment 'Indicates whether the client is eligible to receive a replacement candidate at no additional fee charge following a fall-off event within the guarantee period. Determined by the terms of the clients MSA and the nature of the fall-off.' ;
    rdfs:domain ind:PlacementFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemFeeCode rdf:type rdf:Property ;
    rdfs:label 'Source System Fee Code' ;
    rdfs:comment 'The native identifier of this placement fee record in the originating source system (Bullhorn, Salesforce Revenue Cloud, or NetSuite). Enables bidirectional traceability between the lakehouse silver layer and operational systems for reconciliation and support.' ;
    rdfs:domain ind:PlacementFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:splitFeeIndicator rdf:type rdf:Property ;
    rdfs:label 'Split Fee Indicator' ;
    rdfs:comment 'Indicates whether this placement fee is shared between multiple recruiters or offices (split placement). When true, the fee revenue and commission are divided according to the split arrangement. Common in executive search and cross-office placements.' ;
    rdfs:domain ind:PlacementFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:splitFeePercentage rdf:type rdf:Property ;
    rdfs:label 'Split Fee Percentage' ;
    rdfs:comment 'The percentage of the total placement fee allocated to this recruiter or office in a split placement arrangement. Applicable only when split_fee_indicator is true. Used for commission calculation and revenue attribution.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenseChargeId rdf:type rdf:Property ;
    rdfs:label 'Expense Charge Id' ;
    rdfs:comment 'Unique system-generated identifier for each billable expense charge record in the billing domain. Primary key for the expense_charge data product. Entity role: TRANSACTION_HEADER — represents a discrete billable expense event with its own lifecycle.' ;
    rdfs:domain ind:ExpenseCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orientationSessionId rdf:type rdf:Property ;
    rdfs:label 'Orientation Session Id' ;
    rdfs:comment 'Foreign key linking to candidate.orientation_session. Business justification: Orientation session costs (materials, venue, facilitator fees tracked via cost_per_attendee) are billed as expense charges to clients. Staffing ops teams need to reconcile expense charges against spec' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrientationSession .

ind:billableAmount rdf:type rdf:Property ;
    rdfs:label 'Billable Amount' ;
    rdfs:comment 'The total amount charged to the client for this expense, equal to expense_amount plus markup_amount. This is the net total included on the client invoice. Part of the MONETARY_TRIPLET net total component.' ;
    rdfs:domain ind:ExpenseCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargeStatus rdf:type rdf:Property ;
    rdfs:label 'Charge Status' ;
    rdfs:comment 'Current workflow state of the expense charge record. Drives approval routing, invoice inclusion eligibility, and collections processing. Satisfies LIFECYCLE_STATUS category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:ExpenseCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientPoNumber rdf:type rdf:Property ;
    rdfs:label 'Client Po Number' ;
    rdfs:comment 'The client-issued Purchase Order number authorizing this expense charge. Required for invoice processing by many enterprise clients and VMS-managed programs. Used for client-side accounts payable matching.' ;
    rdfs:domain ind:ExpenseCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenseAmount rdf:type rdf:Property ;
    rdfs:label 'Expense Amount' ;
    rdfs:comment 'The gross base amount of the expense as incurred, before any markup or adjustment. Represents the raw cost passed through from the worker or vendor. Part of the MONETARY_TRIPLET for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenseDate rdf:type rdf:Property ;
    rdfs:label 'Expense Date' ;
    rdfs:comment 'The calendar date on which the expense was incurred by the worker or staffing operation. Used for period matching, per diem eligibility, and invoice period alignment. Satisfies BUSINESS_EVENT_TIMESTAMP category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:ExpenseCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expenseDescription rdf:type rdf:Property ;
    rdfs:label 'Expense Description' ;
    rdfs:comment 'Free-text description of the expense charge providing additional context about the nature, purpose, or business justification of the expense. Appears on client invoices and expense reports for transparency.' ;
    rdfs:domain ind:ExpenseCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenseNumber rdf:type rdf:Property ;
    rdfs:label 'Expense Number' ;
    rdfs:comment 'Externally-visible, human-readable identifier for the expense charge record, used in client communications, invoice line references, and dispute management. Sourced from Salesforce Revenue Cloud or Oracle NetSuite ERP. Satisfies BUSINESS_IDENTIFIER category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:ExpenseCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenseType rdf:type rdf:Property ;
    rdfs:label 'Expense Type' ;
    rdfs:comment 'Classification of the expense category incurred by the worker or staffing operation. Drives billing rules, markup applicability, and GL account mapping. Standard types include Per Diem (daily allowance), travel, lodging, mileage reimbursement, equipment, and training costs. Satisfies CLASSIFICATION_OR_TYPE category for TRANSACTION_HEADER role. [ENUM-REF-CANDIDATE: per_diem|travel|lodging|mileage|equipment|training|meals|parking|communication|relocation — promote to reference product]' ;
    rdfs:domain ind:ExpenseCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReimbursable rdf:type rdf:Property ;
    rdfs:label 'Is Reimbursable' ;
    rdfs:comment 'Indicates whether the worker is entitled to reimbursement for this expense from the staffing firm, independent of whether it is billed to the client. Drives payroll reimbursement processing in TempWorks Payroll.' ;
    rdfs:domain ind:ExpenseCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markupAmount rdf:type rdf:Property ;
    rdfs:label 'Markup Amount' ;
    rdfs:comment 'The calculated dollar value of the markup applied to the base expense amount (expense_amount × markup_percentage / 100). Stored as a discrete field for audit and invoice line transparency. Part of the MONETARY_TRIPLET adjustment component.' ;
    rdfs:domain ind:ExpenseCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mileageRate rdf:type rdf:Property ;
    rdfs:label 'Mileage Rate' ;
    rdfs:comment 'The per-mile or per-kilometer reimbursement rate applied to mileage expense charges. May reflect the IRS standard mileage rate or a client-negotiated rate. Used to validate that expense_amount equals mileage_units × mileage_rate.' ;
    rdfs:domain ind:ExpenseCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mileageUnits rdf:type rdf:Property ;
    rdfs:label 'Mileage Units' ;
    rdfs:comment 'Number of miles or kilometers driven for mileage-type expense charges. Used to calculate reimbursement at the applicable IRS standard mileage rate or client-negotiated rate. Applicable only when expense_type is mileage.' ;
    rdfs:domain ind:ExpenseCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'The date shown on the supporting receipt or expense documentation. May differ from expense_date in cases of delayed submission. Used for IRS substantiation compliance and audit purposes.' ;
    rdfs:domain ind:ExpenseCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receiptReference rdf:type rdf:Property ;
    rdfs:label 'Receipt Reference' ;
    rdfs:comment 'Document reference number or identifier for the supporting receipt or proof of expense. Used for audit trail, FCRA-compliant recordkeeping, and expense dispute resolution. May reference a document stored in DocuSign CLM or an external document management system.' ;
    rdfs:domain ind:ExpenseCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Name of the external vendor or supplier from whom the expense was incurred (e.g., hotel chain, airline, equipment supplier). Used for vendor spend analysis, preferred vendor compliance, and accounts payable matching in Oracle NetSuite ERP.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerName rdf:type rdf:Property ;
    rdfs:label 'Worker Name' ;
    rdfs:comment 'Full name of the worker (temporary employee, contractor, or W-2 employee) who incurred the expense. Retained on the expense record for audit trail and dispute resolution purposes. Classified as restricted PII per GDPR, CCPA, and FCRA.' ;
    rdfs:domain ind:ExpenseCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listACredentialInstanceId rdf:type rdf:Property ;
    rdfs:label 'List A Credential Instance Id' ;
    rdfs:comment 'Foreign key linking to credentialing.credential_instance. Business justification: I-9 Section 2 List A document verification links to the actual credential instance record (passport, EAD, etc.). Business process: I-9 compliance audit trail requires reference to verified credential ' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CredentialInstance .

ind:alienRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Alien Registration Number' ;
    rdfs:comment 'USCIS Alien Registration Number (A-Number) provided by the employee in Section 1 when applicable. Required for lawful permanent residents and certain aliens authorized to work. Highly sensitive government-issued identifier.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Authorized Representative Name' ;
    rdfs:comment 'Full name of the employers authorized representative who physically examined the employees documents and completed Section 2 of the I-9 form. Required for audit trail and employer liability documentation.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedRepresentativeTitle rdf:type rdf:Property ;
    rdfs:label 'Authorized Representative Title' ;
    rdfs:comment 'Job title of the employers authorized representative who completed Section 2. Documents the authority level of the individual who performed the document inspection.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Unique externally-known case reference number assigned to this I-9 verification record, often sourced from the onboarding workflow or Sterling BGC system. Used for audit trail and cross-system reconciliation.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citizenshipStatus rdf:type rdf:Property ;
    rdfs:label 'Citizenship Status' ;
    rdfs:comment 'Employees attested citizenship or immigration status as declared in Section 1 of the I-9 form. Determines document list requirements for Section 2 verification. Sensitive PII per USCIS and FCRA.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentIssuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Document Issuing Authority' ;
    rdfs:comment 'Name of the government agency or authority that issued the primary document used for verification (e.g., U.S. Department of State for passports, state DMV for drivers licenses, SSA for Social Security cards).' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerBusinessName rdf:type rdf:Property ;
    rdfs:label 'Employer Business Name' ;
    rdfs:comment 'Legal business name of the employer (staffing firm or client company) recorded in Section 2 of the I-9. In co-employment or joint employment scenarios, this identifies which entity is the employer of record for I-9 purposes.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerOfRecordType rdf:type rdf:Property ;
    rdfs:label 'Employer Of Record Type' ;
    rdfs:comment 'Identifies which entity type is acting as the Employer of Record (EOR) for I-9 compliance purposes. Critical in staffing and co-employment arrangements to determine I-9 responsibility. Values: staffing_firm (staffing agency is EOR), client_company (client is EOR), peo (Professional Employer Organization), eor (dedicated Employer of Record service).' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:everifyCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Everify Case Number' ;
    rdfs:comment 'Unique case number assigned by the DHS/SSA E-Verify system when the employer submits the I-9 information for electronic employment eligibility verification. Links this I-9 record to the corresponding E-Verify transaction.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:everifyFinalResultDate rdf:type rdf:Property ;
    rdfs:label 'Everify Final Result Date' ;
    rdfs:comment 'Date on which the E-Verify case reached a final determination (Employment Authorized or Final Nonconfirmation). Used for compliance reporting and audit trail.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:everifyStatus rdf:type rdf:Property ;
    rdfs:label 'Everify Status' ;
    rdfs:comment 'Current status of the E-Verify case associated with this I-9 verification. Tracks the electronic verification result from DHS/SSA. A Tentative Nonconfirmation (TNC) requires employee notification and contest opportunity.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:everifySubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Everify Submission Date' ;
    rdfs:comment 'Date on which the employer submitted the I-9 information to the E-Verify system. Must occur no later than 3 business days after the hire date per E-Verify program requirements.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:foreignPassportCountry rdf:type rdf:Property ;
    rdfs:label 'Foreign Passport Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country that issued the foreign passport referenced in Section 1. Required when a foreign passport number is provided.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foreignPassportNumber rdf:type rdf:Property ;
    rdfs:label 'Foreign Passport Number' ;
    rdfs:comment 'Foreign passport number provided by the employee in Section 1 when applicable, along with the country of issuance. Used for aliens authorized to work who provide a foreign passport with Form I-94.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'The date the worker was hired or the assignment commenced. Section 1 of the I-9 must be completed no later than the first day of employment; Section 2 must be completed within 3 business days of this date.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:i94AdmissionNumber rdf:type rdf:Property ;
    rdfs:label 'I94 Admission Number' ;
    rdfs:comment 'CBP Form I-94 Arrival/Departure Record number provided by the employee in Section 1 when applicable. Used for aliens authorized to work who do not have an A-Number or foreign passport with visa.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listADocumentNumber rdf:type rdf:Property ;
    rdfs:label 'List A Document Number' ;
    rdfs:comment 'Document number from the List A identity and employment authorization document presented in Section 2. Recorded by the employer/authorized representative during physical document inspection.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listADocumentType rdf:type rdf:Property ;
    rdfs:label 'List A Document Type' ;
    rdfs:comment 'Type of List A document (establishes both identity and employment authorization) presented by the employee in Section 2. Examples include U.S. Passport, Permanent Resident Card (I-551), Employment Authorization Document (I-766). Mutually exclusive with List B/C combination. [ENUM-REF-CANDIDATE: us_passport|us_passport_card|permanent_resident_card|alien_registration_receipt_card|employment_auth_document|foreign_passport_i94|foreign_passport_i551|passport_i94_i20|passport_i94_ds2019 — promote to reference product]' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listAExpirationDate rdf:type rdf:Property ;
    rdfs:label 'List A Expiration Date' ;
    rdfs:comment 'Expiration date of the List A document as recorded in Section 2. Used to determine reverification requirements. Null if the document has no expiration date.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:listBDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'List B Document Number' ;
    rdfs:comment 'Document number from the List B identity document presented in Section 2. Recorded by the employer/authorized representative during physical document inspection.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listBDocumentType rdf:type rdf:Property ;
    rdfs:label 'List B Document Type' ;
    rdfs:comment 'Type of List B document (establishes identity only) presented by the employee in Section 2 when no List A document is provided. Examples include drivers license, state ID card, school ID with photo. Must be used in combination with a List C document. [ENUM-REF-CANDIDATE: drivers_license|state_id|school_id_photo|voter_registration|us_military_card|military_dependent_id|us_coast_guard_id|native_american_tribal_doc|canadian_drivers_license — promote to reference product]' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listBExpirationDate rdf:type rdf:Property ;
    rdfs:label 'List B Expiration Date' ;
    rdfs:comment 'Expiration date of the List B document as recorded in Section 2. Null if the document has no expiration date.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:listCDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'List C Document Number' ;
    rdfs:comment 'Document number from the List C employment authorization document presented in Section 2. Recorded by the employer/authorized representative during physical document inspection.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listCDocumentType rdf:type rdf:Property ;
    rdfs:label 'List C Document Type' ;
    rdfs:comment 'Type of List C document (establishes employment authorization only) presented by the employee in Section 2 when no List A document is provided. Examples include Social Security card, birth certificate, employment authorization issued by DHS. Must be used in combination with a List B document. [ENUM-REF-CANDIDATE: social_security_card|us_birth_certificate|us_citizen_id_card|native_american_tribal_doc|us_id_card_for_use_in_us|dhs_employment_auth — promote to reference product]' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listCExpirationDate rdf:type rdf:Property ;
    rdfs:label 'List C Expiration Date' ;
    rdfs:comment 'Expiration date of the List C document as recorded in Section 2. Null if the document has no expiration date.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Onboarding Source System' ;
    rdfs:comment 'Identifies the operational system from which this I-9 record was sourced or initiated. Supports data lineage and reconciliation between SAP SuccessFactors onboarding workflows and Sterling BGC verification system.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparerUsed rdf:type rdf:Property ;
    rdfs:label 'Preparer Used' ;
    rdfs:comment 'Indicates whether a preparer or translator assisted the employee in completing Section 1 of the I-9 form. When True, the preparer/translator certification fields must also be completed.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remoteVerification rdf:type rdf:Property ;
    rdfs:label 'Remote Verification' ;
    rdfs:comment 'Indicates whether the I-9 document examination was conducted remotely using the DHS-authorized alternative procedure (video link, fax, or email) rather than in-person physical inspection. Remote verification requires additional documentation and is subject to specific DHS authorization.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reverificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Reverification Due Date' ;
    rdfs:comment 'Date by which Section 3 reverification must be completed to maintain continuous employment authorization compliance. Typically set to the work authorization expiration date or document expiration date, whichever is earlier.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reverificationRequired rdf:type rdf:Property ;
    rdfs:label 'Reverification Required' ;
    rdfs:comment 'Indicates whether this I-9 record requires reverification of employment authorization documents before the work authorization expiration date. Drives compliance workflow alerts and Section 3 completion.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:section1CompletedDate rdf:type rdf:Property ;
    rdfs:label 'Section1 Completed Date' ;
    rdfs:comment 'Date on which the employee completed and signed Section 1 (Employee Information and Attestation) of the I-9 form. Must be completed no later than the first day of employment per INA requirements.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:section2CompletedDate rdf:type rdf:Property ;
    rdfs:label 'Section2 Completed Date' ;
    rdfs:comment 'Date on which the employer or authorized representative completed Section 2 (Employer or Authorized Representative Review and Verification) of the I-9 form. Must be completed within 3 business days of the hire date.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:section3CompletedDate rdf:type rdf:Property ;
    rdfs:label 'Section3 Completed Date' ;
    rdfs:comment 'Date on which Section 3 (Reverification and Rehires) was completed. Populated when a worker is rehired within 3 years of the original I-9 date or when work authorization documents require reverification.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'The native record identifier from the originating source system (SAP SuccessFactors, Sterling BGC, or Bullhorn) for this I-9 record. Enables cross-system reconciliation and data lineage tracing in the Silver layer.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tncContested rdf:type rdf:Property ;
    rdfs:label 'Tnc Contested' ;
    rdfs:comment 'Indicates whether the employee chose to contest the Tentative Nonconfirmation (TNC). If True, the employee has 8 federal government working days to contact SSA or DHS to resolve the discrepancy.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tncIssued rdf:type rdf:Property ;
    rdfs:label 'Tnc Issued' ;
    rdfs:comment 'Indicates whether a Tentative Nonconfirmation (TNC) was issued by E-Verify for this case. When True, the employer must notify the employee and provide the Further Action Notice. Triggers a mandatory contest window.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tncNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Tnc Notification Date' ;
    rdfs:comment 'Date on which the employer notified the employee of the Tentative Nonconfirmation (TNC) result. Employer must notify the employee promptly and cannot take adverse action during the contest period.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Current lifecycle status of the I-9 verification record. Tracks progression from initial employee attestation through employer document review to final closure or reverification. [ENUM-REF-CANDIDATE: pending|section1_complete|section2_complete|reverification_required|closed|cancelled — promote to reference product if additional statuses are needed]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workAuthExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Work Auth Expiration Date' ;
    rdfs:comment 'Date on which the employees work authorization expires as attested in Section 1. Drives reverification scheduling. Null for U.S. citizens, nationals, and lawful permanent residents with no expiration.' ;
    rdfs:domain ind:I9Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verifiedCredentialInstanceId rdf:type rdf:Property ;
    rdfs:label 'Verified Credential Instance Id' ;
    rdfs:comment 'Foreign key linking to credentialing.credential_instance. Business justification: E-Verify cases validate specific work authorization documents tracked as credential instances. Business process: E-Verify document validation and photo match reference the actual credential instance b' ;
    rdfs:domain ind:EverifyCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CredentialInstance .

ind:caseClosureDate rdf:type rdf:Property ;
    rdfs:label 'Case Closure Date' ;
    rdfs:comment 'The date on which the E-Verify case was officially closed in the federal portal. Marks the end of the case lifecycle. Used for compliance reporting, audit trails, and calculating case processing duration.' ;
    rdfs:domain ind:EverifyCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caseClosureReason rdf:type rdf:Property ;
    rdfs:label 'Case Closure Reason' ;
    rdfs:comment 'The business reason for closing the E-Verify case. Captures whether closure was due to authorization, final nonconfirmation, early termination, case error, or other administrative reasons. Required for federal audit trails and DOL regulatory reporting.' ;
    rdfs:domain ind:EverifyCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current lifecycle status of the E-Verify case as returned by the DHS/SSA federal portal. Drives compliance workflow actions including TNC resolution, referral, and closure processes. [ENUM-REF-CANDIDATE: Employment Authorized|Tentative Nonconfirmation|Final Nonconfirmation|Case in Continuance|Closed|DHS Verification in Process — promote to reference product]' ;
    rdfs:domain ind:EverifyCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseVerificationType rdf:type rdf:Property ;
    rdfs:label 'Case Verification Type' ;
    rdfs:comment 'Classifies the type of E-Verify verification being performed. New Hire cases are standard; Rehire cases apply when a worker is rehired after a break in service; Federal Contractor cases apply under FAR E-Verify clause requirements for federal contract placements.' ;
    rdfs:domain ind:EverifyCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text field for compliance officers to document case-specific notes, exceptions, escalations, or remediation actions taken during the E-Verify process. Used for internal audit documentation and legal hold purposes. Sourced from Sterling BGC and manual compliance team entries.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dhsCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Dhs Case Number' ;
    rdfs:comment 'The official case number assigned by the DHS/SSA E-Verify federal portal upon case creation. This is the externally-known identifier used to track and reference the case with federal authorities. Sourced from Sterling BGC and E-Verify federal portal integration.' ;
    rdfs:domain ind:EverifyCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTitleListUsed rdf:type rdf:Property ;
    rdfs:label 'Document Title List Used' ;
    rdfs:comment 'Indicates whether the worker presented a List A document (establishes both identity and employment authorization) or a combination of List B (identity) and List C (employment authorization) documents during I-9 verification. Relevant to E-Verify case processing rules.' ;
    rdfs:domain ind:EverifyCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeFirstDayOfWork rdf:type rdf:Property ;
    rdfs:label 'Employee First Day Of Work' ;
    rdfs:comment 'The date the employee began work for pay at Staffing Hr or the client site. E-Verify cases must be submitted within 3 business days of this date per federal program rules. Used to validate timely submission compliance.' ;
    rdfs:domain ind:EverifyCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employerCaseCreator rdf:type rdf:Property ;
    rdfs:label 'Employer Case Creator' ;
    rdfs:comment 'The name or identifier of the Staffing Hr staff member (recruiter, onboarding specialist, or compliance officer) who created and submitted the E-Verify case. Required for internal audit trails and accountability tracking per SOC 2 Type II controls.' ;
    rdfs:domain ind:EverifyCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentAuthorizationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Employment Authorization Expiry Date' ;
    rdfs:comment 'The expiration date of the workers employment authorization document as recorded in the E-Verify case. Triggers re-verification requirements for workers with temporary employment authorization. Critical for ongoing compliance monitoring and assignment management.' ;
    rdfs:domain ind:EverifyCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:federalClosureCode rdf:type rdf:Property ;
    rdfs:label 'Federal Closure Code' ;
    rdfs:comment 'The standardized federal closure code assigned by the DHS E-Verify portal upon case closure. Used for regulatory reporting, federal audit reconciliation, and compliance tracking with DHS and DOL requirements.' ;
    rdfs:domain ind:EverifyCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:federalContractorFlag rdf:type rdf:Property ;
    rdfs:label 'Federal Contractor Flag' ;
    rdfs:comment 'Indicates whether this E-Verify case was submitted under the Federal Acquisition Regulation (FAR) E-Verify clause requirement for federal contractor placements. True = federal contractor case; False = standard commercial placement. Drives OFCCP compliance reporting.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:finalCaseResult rdf:type rdf:Property ;
    rdfs:label 'Final Case Result' ;
    rdfs:comment 'The conclusive result of the E-Verify case after all resolution steps (TNC contest, referral, continuance) have been completed. Used for final compliance determination and regulatory reporting to DOL and EEOC.' ;
    rdfs:domain ind:EverifyCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:furtherActionNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Further Action Notice Date' ;
    rdfs:comment 'The date on which the Further Action Notice (FAN) was provided to the worker. Must be documented as part of the TNC resolution process. Null when no FAN was issued. Used for compliance audit trails and DOL regulatory reporting.' ;
    rdfs:domain ind:EverifyCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:furtherActionNoticeIssued rdf:type rdf:Property ;
    rdfs:label 'Further Action Notice Issued' ;
    rdfs:comment 'Indicates whether a Further Action Notice (FAN) was issued to the worker as part of the TNC process. True = FAN was issued and provided to the worker; False = no FAN issued. Required documentation step for TNC compliance per DHS E-Verify program rules.' ;
    rdfs:domain ind:EverifyCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initialCaseResult rdf:type rdf:Property ;
    rdfs:label 'Initial Case Result' ;
    rdfs:comment 'The first result returned by the E-Verify system upon initial case submission. Distinct from the final case status — captures the original determination before any TNC resolution or continuance. Key field for compliance audit trails required by DOL and IRS.' ;
    rdfs:domain ind:EverifyCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lateSubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Late Submission Flag' ;
    rdfs:comment 'Indicates whether the E-Verify case was submitted after the federally mandated 3-business-day window from the employees first day of work. True = late submission; False = timely submission. Used for compliance monitoring, SLA reporting, and DOL audit risk management.' ;
    rdfs:domain ind:EverifyCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photoMatchResult rdf:type rdf:Property ;
    rdfs:label 'Photo Match Result' ;
    rdfs:comment 'The result of the E-Verify photo matching step, where the photo on the workers identity document is compared against DHS records. Applicable when the worker presents a document with a photo that E-Verify can match. Used for fraud detection and compliance documentation.' ;
    rdfs:domain ind:EverifyCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reVerificationRequired rdf:type rdf:Property ;
    rdfs:label 'Re Verification Required' ;
    rdfs:comment 'Indicates whether the workers employment authorization requires re-verification before the expiry date. True = re-verification is required; False = no re-verification needed (e.g., U.S. citizen). Drives compliance workflow alerts for assignment managers.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralAgency rdf:type rdf:Property ;
    rdfs:label 'Referral Agency' ;
    rdfs:comment 'The federal agency (Social Security Administration or Department of Homeland Security) to which the worker was referred to resolve a Tentative Nonconfirmation (TNC). Determines the resolution process and timeline. Null or None when no referral was required.' ;
    rdfs:domain ind:EverifyCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralDate rdf:type rdf:Property ;
    rdfs:label 'Referral Date' ;
    rdfs:comment 'The date on which the worker was referred to the SSA or DHS to resolve a Tentative Nonconfirmation (TNC). Must occur within the federally mandated timeframe after TNC issuance. Null when no TNC referral was required. Tracked for DOL and DHS audit compliance.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referralDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Referral Deadline Date' ;
    rdfs:comment 'The federally mandated deadline by which the worker must be referred to SSA or DHS to contest a Tentative Nonconfirmation (TNC). Calculated from the TNC issuance date per DHS E-Verify program rules. Used for SLA monitoring and compliance alerting.' ;
    rdfs:domain ind:EverifyCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Deadline Date' ;
    rdfs:comment 'The federally mandated deadline by which the TNC must be resolved by the referring agency (SSA or DHS). Staffing Hr must not terminate employment before this date solely due to TNC status. Tracked for EEOC anti-discrimination compliance and DOL audit.' ;
    rdfs:domain ind:EverifyCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sterlingCaseReference rdf:type rdf:Property ;
    rdfs:label 'Sterling Case Reference' ;
    rdfs:comment 'The case reference number assigned by Sterling Background Check system for this E-Verify submission. Used for reconciliation between Sterling BGC integration records and the DHS E-Verify federal portal. Enables cross-system audit trail.' ;
    rdfs:domain ind:EverifyCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'The exact date and time when the E-Verify case was submitted to the DHS/SSA federal portal. This is the principal business event timestamp for the case. Must occur within 3 business days of the employees first day of work per federal E-Verify program rules.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tncIssuanceDate rdf:type rdf:Property ;
    rdfs:label 'Tnc Issuance Date' ;
    rdfs:comment 'The date on which the Tentative Nonconfirmation (TNC) was issued by the E-Verify system. Triggers the mandatory referral and resolution timeline. Null when no TNC was issued. Critical for calculating referral and resolution deadlines.' ;
    rdfs:domain ind:EverifyCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tncResolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Tnc Resolution Status' ;
    rdfs:comment 'Tracks the workers response and resolution outcome for a Tentative Nonconfirmation (TNC). Indicates whether the worker contested the TNC, did not contest, and the resulting resolution. Null when no TNC was issued. Required for OFCCP and DOL compliance audit trails.' ;
    rdfs:domain ind:EverifyCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tncType rdf:type rdf:Property ;
    rdfs:label 'Tnc Type' ;
    rdfs:comment 'Identifies whether the Tentative Nonconfirmation (TNC) was issued by the Social Security Administration (SSA), the Department of Homeland Security (DHS), or both. Null or None when no TNC was issued. Drives the appropriate referral agency and resolution workflow.' ;
    rdfs:domain ind:EverifyCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerContestedTnc rdf:type rdf:Property ;
    rdfs:label 'Worker Contested Tnc' ;
    rdfs:comment 'Indicates whether the worker chose to contest the Tentative Nonconfirmation (TNC) with the issuing agency (SSA or DHS). True = worker contested; False = worker did not contest. Null when no TNC was issued. Critical for FLSA and EEOC anti-discrimination compliance.' ;
    rdfs:domain ind:EverifyCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:abcTestApplicable rdf:type rdf:Property ;
    rdfs:label 'Abc Test Applicable' ;
    rdfs:comment 'Indicates whether the state-level ABC Test (stricter than IRS Common Law Test) applies to this classification determination based on the work jurisdiction. True = ABC Test governs; False = IRS Common Law or DOL Economic Realities Test applies.' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:abcTestResult rdf:type rdf:Property ;
    rdfs:label 'Abc Test Result' ;
    rdfs:comment 'Outcome of the ABC Test evaluation where applicable. Pass = worker qualifies as independent contractor under all three prongs; Fail = worker must be classified as W-2 employee; Not Applicable = ABC Test does not govern this jurisdiction.' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:behavioralControlScore rdf:type rdf:Property ;
    rdfs:label 'Behavioral Control Score' ;
    rdfs:comment 'Numeric score (0–100) reflecting the degree of behavioral control the staffing firm or client exercises over the worker, per the IRS Common Law Test. Higher scores indicate greater control and stronger W-2 classification support.' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:classificationNumber rdf:type rdf:Property ;
    rdfs:label 'Classification Number' ;
    rdfs:comment 'Externally-known unique business identifier for this classification determination record, used in audit correspondence, legal filings, and IRS inquiries. Format: WC-YYYY-NNNNNN.' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationStatus rdf:type rdf:Property ;
    rdfs:label 'Classification Status' ;
    rdfs:comment 'Current lifecycle status of this classification determination. Pending = under review; Active = in force; Superseded = replaced by a newer determination; Appealed = under formal challenge; Revoked = withdrawn due to error or legal order.' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationType rdf:type rdf:Property ;
    rdfs:label 'Classification Type' ;
    rdfs:comment 'The determined classification type for the worker engagement. W2 = W-2 employee (temporary or permanent); 1099_IC = Independent Contractor (1099-MISC); 1099_NEC = Non-Employee Compensation contractor; C2C = Corp-to-Corp engagement; EOR = Employer of Record arrangement. This is the SSOT for IC vs. W-2 decisions.' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientRequestedClassification rdf:type rdf:Property ;
    rdfs:label 'Client Requested Classification' ;
    rdfs:comment 'The worker classification type explicitly requested by the client in the job order, MSA, or SOW. May differ from the compliance-determined classification. Used to track client preference vs. legal determination and flag misalignment.' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:determinationBasis rdf:type rdf:Property ;
    rdfs:label 'Determination Basis' ;
    rdfs:comment 'The legal or regulatory test framework used to arrive at the classification determination. Behavioral Control = IRS test on instruction/training; Financial Control = IRS test on investment/profit/loss; Relationship Type = IRS test on written contracts/benefits/permanency; ABC Test = state-level test (e.g., California AB5); Economic Realities = DOL FLSA test; Multi-Factor = combination of tests applied.' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:determinationDate rdf:type rdf:Property ;
    rdfs:label 'Determination Date' ;
    rdfs:comment 'The date on which the formal worker classification determination was made and recorded. This is the principal business event date for this record.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'The date from which this classification determination is binding and in effect for the worker engagement. May differ from determination_date if retroactive or prospective.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'The date on which this classification determination expires or is superseded. Null for open-ended classifications. Populated when a new determination replaces this one or the engagement ends.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialControlScore rdf:type rdf:Property ;
    rdfs:label 'Financial Control Score' ;
    rdfs:comment 'Numeric score (0–100) reflecting the degree of financial control the staffing firm or client exercises over the worker, per the IRS Common Law Test. Considers investment in tools, opportunity for profit/loss, and services available to the general market.' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:icAgreementDate rdf:type rdf:Property ;
    rdfs:label 'Ic Agreement Date' ;
    rdfs:comment 'Date on which the Independent Contractor Agreement was executed. Used to verify agreement predates the engagement start and is current for the classification period.' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:icAgreementOnFile rdf:type rdf:Property ;
    rdfs:label 'Ic Agreement On File' ;
    rdfs:comment 'Indicates whether a signed Independent Contractor Agreement is on file for this worker engagement. Required for 1099/IC classifications. Absence of a signed agreement increases misclassification risk.' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irsAuditExposureNotes rdf:type rdf:Property ;
    rdfs:label 'Irs Audit Exposure Notes' ;
    rdfs:comment 'Free-text field capturing compliance officer or attorney notes regarding IRS audit exposure risk for this classification. Documents specific factors that could attract IRS scrutiny, misclassification penalties, or back-tax liability under IRC Section 3509.' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:misclassificationRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Misclassification Risk Level' ;
    rdfs:comment 'Overall assessed risk level that the current classification determination could be challenged or reversed by the IRS, DOL, or state labor authority. Drives compliance monitoring frequency and legal review escalation.' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaOnFile rdf:type rdf:Property ;
    rdfs:label 'Nda On File' ;
    rdfs:comment 'Indicates whether a signed Non-Disclosure Agreement (NDA) is on file for this worker engagement. Tracked as part of the compliance documentation package for the classification record.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonCompeteOnFile rdf:type rdf:Property ;
    rdfs:label 'Non Compete On File' ;
    rdfs:comment 'Indicates whether a signed Non-Compete Agreement is on file for this worker. Relevant to classification because non-compete clauses are more consistent with employee relationships and may affect IC classification defensibility.' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Indicates whether the final classification determination overrides the system-recommended or compliance-officer-recommended classification. True = an override was applied; False = determination follows standard process. Triggers mandatory documentation and senior review.' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Free-text explanation documenting the business or legal justification for overriding the standard classification recommendation. Required when override_flag is True. Retained for audit trail and IRS inquiry response.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousClassificationType rdf:type rdf:Property ;
    rdfs:label 'Previous Classification Type' ;
    rdfs:comment 'The prior classification type for this worker on this engagement, captured when a reclassification event occurs. Enables audit trail of classification changes and supports IRS back-period liability analysis.' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reclassificationDate rdf:type rdf:Property ;
    rdfs:label 'Reclassification Date' ;
    rdfs:comment 'Date on which a workers classification was changed from a prior type to the current classification_type. Null if this is the original classification with no prior change.' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reclassificationTrigger rdf:type rdf:Property ;
    rdfs:label 'Reclassification Trigger' ;
    rdfs:comment 'The event or authority that triggered a reclassification of the worker. Captures whether the change was driven by an IRS audit, DOL investigation, state labor audit, client request, proactive internal compliance review, legal counsel advice, or court order. [ENUM-REF-CANDIDATE: irs_audit|dol_audit|state_audit|client_request|internal_review|legal_counsel|court_order — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipTypeScore rdf:type rdf:Property ;
    rdfs:label 'Relationship Type Score' ;
    rdfs:comment 'Numeric score (0–100) reflecting the nature of the relationship between the worker and the engaging party, per the IRS Common Law Test. Considers written contracts, employee benefits, permanency of relationship, and integral business activity.' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewingOfficerName rdf:type rdf:Property ;
    rdfs:label 'Reviewing Officer Name' ;
    rdfs:comment 'Full name of the compliance officer, HR attorney, or legal counsel who reviewed and approved this classification determination. Required for audit trail and regulatory defense.' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewingOfficerTitle rdf:type rdf:Property ;
    rdfs:label 'Reviewing Officer Title' ;
    rdfs:comment 'Job title or role of the individual who reviewed and approved the classification determination (e.g., Chief Compliance Officer, Employment Attorney, HR Director).' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ss8DeterminationResult rdf:type rdf:Property ;
    rdfs:label 'Ss8 Determination Result' ;
    rdfs:comment 'The IRSs official determination result from Form SS-8 review. Employee = IRS determined worker is an employee; Independent Contractor = IRS confirmed IC status; Pending = IRS review in progress; Withdrawn = SS-8 filing was withdrawn.' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ss8Filed rdf:type rdf:Property ;
    rdfs:label 'Ss8 Filed' ;
    rdfs:comment 'Indicates whether IRS Form SS-8 (Determination of Worker Status for Purposes of Federal Employment Taxes and Income Tax Withholding) has been filed for this worker engagement. True = SS-8 filed with IRS; False = not filed.' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ss8FiledDate rdf:type rdf:Property ;
    rdfs:label 'Ss8 Filed Date' ;
    rdfs:comment 'Date on which IRS Form SS-8 was filed with the IRS for this worker engagement. Null if ss8_filed is False.' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:voluntaryClassificationSettlement rdf:type rdf:Property ;
    rdfs:label 'Voluntary Classification Settlement' ;
    rdfs:comment 'Indicates whether the staffing firm has enrolled this worker classification under the IRS Voluntary Classification Settlement Program (VCSP), which allows prospective reclassification of workers as employees with reduced tax liability.' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workersCompExempt rdf:type rdf:Property ;
    rdfs:label 'Workers Comp Exempt' ;
    rdfs:comment 'Indicates whether the worker is exempt from Workers Compensation coverage based on their classification (e.g., 1099 IC workers are typically exempt). Drives payroll and insurance configuration in TempWorks Payroll.' ;
    rdfs:domain ind:WorkerClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eeocFilingId rdf:type rdf:Property ;
    rdfs:label 'Eeoc Filing Id' ;
    rdfs:comment 'Unique surrogate identifier for each EEOC regulatory filing record in the Staffing Hr compliance system. Primary key for this transactional entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amendedFilingEeocFilingId rdf:type rdf:Property ;
    rdfs:label 'Amended Filing Eeoc Filing Id' ;
    rdfs:comment 'Reference to the original EEOC filing record that this amendment supersedes. Populated only when is_amendment is True, enabling amendment history tracking.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EeocFiling .

ind:acceptedDate rdf:type rdf:Property ;
    rdfs:label 'Accepted Date' ;
    rdfs:comment 'Date on which the EEOC officially accepted and validated this filing submission. Populated when filing_status transitions to accepted. Key date for audit readiness and compliance records.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certifyingOfficialTitle rdf:type rdf:Property ;
    rdfs:label 'Certifying Official Title' ;
    rdfs:comment 'Job title of the company official who certified the EEOC filing. Typically a senior HR, legal, or executive officer with authority to attest to workforce data accuracy.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countAmericanIndianAlaskaNative rdf:type rdf:Property ;
    rdfs:label 'Count American Indian Alaska Native' ;
    rdfs:comment 'Total number of employees self-identified as American Indian or Alaska Native (not Hispanic or Latino) across all job categories in this filing. One of the seven EEOC-mandated race/ethnicity categories.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countAsian rdf:type rdf:Property ;
    rdfs:label 'Count Asian' ;
    rdfs:comment 'Total number of employees self-identified as Asian (not Hispanic or Latino) across all job categories in this filing. One of the seven EEOC-mandated race/ethnicity categories.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countBlackAfricanAmerican rdf:type rdf:Property ;
    rdfs:label 'Count Black African American' ;
    rdfs:comment 'Total number of employees self-identified as Black or African American (not Hispanic or Latino) across all job categories in this filing. One of the seven EEOC-mandated race/ethnicity categories.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countHispanicLatino rdf:type rdf:Property ;
    rdfs:label 'Count Hispanic Latino' ;
    rdfs:comment 'Total number of employees self-identified as Hispanic or Latino across all job categories in this filing. One of the seven EEOC-mandated race/ethnicity categories.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countNativeHawaiianPacificIslander rdf:type rdf:Property ;
    rdfs:label 'Count Native Hawaiian Pacific Islander' ;
    rdfs:comment 'Total number of employees self-identified as Native Hawaiian or Other Pacific Islander (not Hispanic or Latino) across all job categories in this filing. One of the seven EEOC-mandated race/ethnicity categories.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countTwoOrMoreRaces rdf:type rdf:Property ;
    rdfs:label 'Count Two Or More Races' ;
    rdfs:comment 'Total number of employees self-identified as Two or More Races (not Hispanic or Latino) across all job categories in this filing. One of the seven EEOC-mandated race/ethnicity categories.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countWhiteNonHispanic rdf:type rdf:Property ;
    rdfs:label 'Count White Non Hispanic' ;
    rdfs:comment 'Total number of employees self-identified as White (not Hispanic or Latino) across all job categories in this filing. One of the seven EEOC-mandated race/ethnicity categories.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Operational system of record from which the workforce headcount and demographic data was extracted to populate this EEOC filing. Supports data lineage and audit trail requirements.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishmentCount rdf:type rdf:Property ;
    rdfs:label 'Establishment Count' ;
    rdfs:comment 'Total number of physical establishments (locations) included in this EEOC filing. Multi-establishment employers must report headcount data for each location.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:filingDeadline rdf:type rdf:Property ;
    rdfs:label 'Filing Deadline' ;
    rdfs:comment 'Regulatory deadline date by which this EEOC filing must be submitted to remain in compliance. Set annually by the EEOC.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingNotes rdf:type rdf:Property ;
    rdfs:label 'Filing Notes' ;
    rdfs:comment 'Free-text notes or comments entered by the compliance team regarding this EEOC filing. May include explanations for data anomalies, amendment rationale, or internal review observations.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingYear rdf:type rdf:Property ;
    rdfs:label 'Filing Year' ;
    rdfs:comment 'Calendar year for which this EEOC report is being filed (e.g., 2023). Determines the applicable reporting period and regulatory deadline.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isAmendment rdf:type rdf:Property ;
    rdfs:label 'Is Amendment' ;
    rdfs:comment 'Indicates whether this filing is an amendment to a previously submitted EEOC report. Amendments correct errors or update data in an accepted original filing.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFederalContractor rdf:type rdf:Property ;
    rdfs:label 'Is Federal Contractor' ;
    rdfs:comment 'Indicates whether the filing entity is a federal contractor or subcontractor subject to OFCCP regulations and Executive Order 11246, which imposes additional EEO obligations beyond standard EEOC requirements.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFirstTimeFiler rdf:type rdf:Property ;
    rdfs:label 'Is First Time Filer' ;
    rdfs:comment 'Indicates whether this is the first EEOC EEO-1 filing submitted by this employer. First-time filers may have different onboarding requirements and EEOC outreach procedures.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ofccpAuditFlag rdf:type rdf:Property ;
    rdfs:label 'Ofccp Audit Flag' ;
    rdfs:comment 'Indicates whether this EEOC filing has been flagged for or is subject to an OFCCP compliance audit or review. Enables proactive audit readiness tracking for federal contractor obligations.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Description of the reason provided by the EEOC for rejecting this filing submission. Populated only when filing_status is rejected. Used to guide corrective action and resubmission.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportComponent rdf:type rdf:Property ;
    rdfs:label 'Report Component' ;
    rdfs:comment 'Specifies the EEO-1 component being filed. Component 1 covers race/ethnicity and gender by job category; Component 2 (historically) covered pay data by race/ethnicity and gender. Relevant for EEO-1 filers.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Classification of the EEOC report form being filed. EEO-1 is the primary form for private employers and federal contractors; other types apply to unions, state/local governments, and educational institutions. Serves as the CLASSIFICATION_OR_TYPE for this transaction.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End' ;
    rdfs:comment 'End date of the workforce data reporting period covered by this EEOC filing. Defines the close of the window from which the workforce snapshot is drawn.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start' ;
    rdfs:comment 'Start date of the workforce data reporting period covered by this EEOC filing. Defines the beginning of the window from which the workforce snapshot is drawn.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:snapshotDate rdf:type rdf:Property ;
    rdfs:label 'Snapshot Date' ;
    rdfs:comment 'The specific pay period date used as the workforce count snapshot for the EEO-1 filing, typically a pay period in October through December of the filing year. Required by EEOC instructions.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'Method used to submit the EEOC filing to the EEOC. Options include the EEOC online portal, bulk data upload, API integration, or legacy paper submission.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFemaleCount rdf:type rdf:Property ;
    rdfs:label 'Total Female Count' ;
    rdfs:comment 'Total number of female employees across all job categories and establishments included in this EEOC filing. Required gender dimension for EEO-1 reporting.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalHeadcount rdf:type rdf:Property ;
    rdfs:label 'Total Headcount' ;
    rdfs:comment 'Total number of employees across all establishments included in this EEOC filing during the snapshot pay period. Represents the aggregate workforce count reported to the EEOC.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalMaleCount rdf:type rdf:Property ;
    rdfs:label 'Total Male Count' ;
    rdfs:comment 'Total number of male employees across all job categories and establishments included in this EEOC filing. Required gender dimension for EEO-1 reporting.' ;
    rdfs:domain ind:EeocFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oshaIncidentId rdf:type rdf:Property ;
    rdfs:label 'Osha Incident Id' ;
    rdfs:comment 'Unique system-generated identifier for each OSHA recordable workplace safety incident record. Primary key for this entity. TRANSACTION_HEADER role — represents a discrete workplace safety event with its own lifecycle.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offboardingRecordId rdf:type rdf:Property ;
    rdfs:label 'Offboarding Record Id' ;
    rdfs:comment 'Foreign key linking to timesheet.offboarding_record. Business justification: When workplace injuries occur near separation date, linking incident to offboarding record captures workers comp claim continuity, return-to-work vs separation decisions, and rehire eligibility impact' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OffboardingRecord .

ind:safetyCredentialInstanceId rdf:type rdf:Property ;
    rdfs:label 'Safety Credential Instance Id' ;
    rdfs:comment 'Foreign key linking to credentialing.credential_instance. Business justification: OSHA incident investigations review whether worker held required safety credentials (OSHA 10/30, forklift cert, etc.) at time of incident. Business process: Root cause analysis validates credential st' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CredentialInstance .

ind:bodyPartAffected rdf:type rdf:Property ;
    rdfs:label 'Body Part Affected' ;
    rdfs:comment 'The specific body part injured or affected by the illness (e.g., lower back, right hand, left knee, eye, head). Required for OSHA Form 301 and used for ergonomic risk analysis and workers comp claim management. [ENUM-REF-CANDIDATE: head|neck|back|shoulder|arm|hand|finger|leg|knee|foot|eye|multiple — promote to reference product]' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Narrative description of the corrective and preventive actions taken or planned in response to the incident (e.g., retraining, equipment repair, process change, PPE provision, worksite modification). Required for OSHA compliance program documentation and client safety reporting.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completed Date' ;
    rdfs:comment 'The actual date on which all corrective and preventive actions were fully implemented and verified. Used to close the incident record and confirm compliance with the corrective action plan.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'The target completion date by which all corrective and preventive actions identified in the incident investigation must be implemented. Used for compliance tracking and client safety SLA management.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysAwayFromWork rdf:type rdf:Property ;
    rdfs:label 'Days Away From Work' ;
    rdfs:comment 'The number of calendar days the worker was unable to work due to the injury or illness, as counted per OSHA recordkeeping rules (capped at 180 days for OSHA 300 log purposes). Required for OSHA 300 log Column K and DART rate calculation.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysRestrictedDuty rdf:type rdf:Property ;
    rdfs:label 'Days Restricted Duty' ;
    rdfs:comment 'The number of calendar days the worker was placed on restricted work activity or job transfer due to the injury or illness, as counted per OSHA recordkeeping rules (capped at 180 days). Required for OSHA 300 log Column L and DART rate calculation.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'The type of event or exposure that directly produced the injury or illness, per BLS Occupational Injury and Illness Classification Manual (OIICS) event categories. Used for trend analysis, root cause classification, and OSHA 300A summary reporting. [ENUM-REF-CANDIDATE: fall|struck_by|caught_in|overexertion|exposure|transportation|violence|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'The calendar date on which the workplace injury or illness event occurred. This is the principal real-world event date used for OSHA 300 log entry, workers comp filing deadlines, and annual 300A summary reporting. Serves as the BUSINESS_EVENT_TIMESTAMP (date precision) for this transaction.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentDescription rdf:type rdf:Property ;
    rdfs:label 'Incident Description' ;
    rdfs:comment 'Narrative description of how the injury or illness occurred, including the sequence of events, equipment involved, and environmental conditions. Required for OSHA Form 301 and used for root cause analysis and corrective action planning.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the incident (e.g., INC-2024-000123). Used in OSHA 300 log entries, workers comp filings, client communications, and regulatory correspondence. Serves as the BUSINESS_IDENTIFIER for this transaction.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Status' ;
    rdfs:comment 'Current lifecycle state of the OSHA incident record. open indicates active investigation; under_review indicates pending recordability determination; closed indicates fully resolved with corrective actions documented; appealed indicates contested recordability; voided indicates duplicate or erroneous entry.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentTime rdf:type rdf:Property ;
    rdfs:label 'Incident Time' ;
    rdfs:comment 'The time of day (HH:MM, 24-hour format) at which the workplace incident occurred. Used for shift-pattern analysis, root cause investigation, and OSHA 300 log documentation.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:injuryIllnessType rdf:type rdf:Property ;
    rdfs:label 'Injury Illness Type' ;
    rdfs:comment 'OSHA-defined classification of the nature of the workplace injury or illness. Maps directly to the OSHA Form 300 column headers: injury, skin disorder, respiratory condition, poisoning, hearing loss, or all other illness. Required for OSHA 300 log and 300A annual summary.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryNature rdf:type rdf:Property ;
    rdfs:label 'Injury Nature' ;
    rdfs:comment 'Detailed description of the specific nature of the injury or illness (e.g., laceration, fracture, sprain, burn, contusion, amputation, concussion). Provides granularity beyond the OSHA Form 300 type classification for root cause analysis and trend reporting. [ENUM-REF-CANDIDATE: laceration|fracture|sprain|strain|burn|contusion|amputation|concussion|puncture|abrasion|dislocation|crush_injury — promote to reference product]' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completed Date' ;
    rdfs:comment 'The date on which the formal incident investigation was completed and the investigation report was finalized. Used to track investigation timeliness and ensure compliance with internal safety program SLAs.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isFatality rdf:type rdf:Property ;
    rdfs:label 'Is Fatality' ;
    rdfs:comment 'Indicates whether the incident resulted in the death of the worker. True = fatality. Triggers mandatory OSHA reporting within 8 hours of employer knowledge under 29 CFR Part 1904.39 and activates escalation protocols.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHospitalized rdf:type rdf:Property ;
    rdfs:label 'Is Hospitalized' ;
    rdfs:comment 'Indicates whether the worker was admitted to a hospital (inpatient) as a result of the incident. True = inpatient hospitalization. Triggers mandatory OSHA reporting within 24 hours under 29 CFR Part 1904.39.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOshaRecordable rdf:type rdf:Property ;
    rdfs:label 'Is Osha Recordable' ;
    rdfs:comment 'Indicates whether the incident meets OSHA recordability criteria under 29 CFR Part 1904.7 (i.e., results in days away from work, restricted duty, medical treatment beyond first aid, loss of consciousness, or diagnosis of a significant injury/illness). True = recordable; False = first-aid only. Drives OSHA 300 log entry requirement.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrivacyCase rdf:type rdf:Property ;
    rdfs:label 'Is Privacy Case' ;
    rdfs:comment 'Indicates whether this incident qualifies as a privacy case under OSHA recordkeeping rules (e.g., sexual assault, mental illness, HIV/AIDS, needlestick, tuberculosis). True = privacy case. When true, the workers name must be withheld from the OSHA 300 log and replaced with privacy case.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itaSubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Ita Submission Reference' ;
    rdfs:comment 'The confirmation identifier returned by OSHAs Injury Tracking Application (ITA) upon electronic submission of the OSHA 300A annual summary data. Required for establishments with 250+ employees or in high-hazard industries under the OSHA Electronic Recordkeeping Rule.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:naicsCode rdf:type rdf:Property ;
    rdfs:label 'Naics Code' ;
    rdfs:comment 'The six-digit NAICS code for the client establishment where the incident occurred. Required for OSHA 300A annual summary and OSHA electronic submission (ITA/OSHA Data Collection) to classify the industry for benchmarking incidence rates.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osha300LogEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Osha 300 Log Entry Number' ;
    rdfs:comment 'The sequential entry number assigned to this incident on the OSHA Form 300 (Log of Work-Related Injuries and Illnesses) for the applicable calendar year. Required for OSHA 300A annual summary reconciliation and regulatory audit. Null if incident is not recordable.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osha300LogYear rdf:type rdf:Property ;
    rdfs:label 'Osha 300 Log Year' ;
    rdfs:comment 'The calendar year of the OSHA Form 300 log in which this incident is recorded. Used to partition OSHA 300A annual summary reporting and multi-year trend analysis.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oshaReportSubmitted rdf:type rdf:Property ;
    rdfs:label 'Osha Report Submitted' ;
    rdfs:comment 'Indicates whether the required OSHA severe injury report (fatality, amputation, loss of eye, or inpatient hospitalization) has been submitted to OSHA within the mandated timeframe (8 hours for fatalities, 24 hours for other severe injuries).' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oshaReportSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Osha Report Submitted Timestamp' ;
    rdfs:comment 'The exact date and time at which the OSHA severe injury report was submitted to OSHA (via phone or online). Used to verify compliance with the 8-hour (fatality) and 24-hour (severe injury) reporting deadlines under 29 CFR Part 1904.39.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:outcomeType rdf:type rdf:Property ;
    rdfs:label 'Outcome Type' ;
    rdfs:comment 'The most severe outcome classification of the incident per OSHA recordkeeping hierarchy: fatality, days away from work, restricted duty or job transfer, medical treatment beyond first aid, or first aid only. Maps to OSHA Form 300 columns G through J. Drives recordability and severity classification.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordabilityDeterminationDate rdf:type rdf:Property ;
    rdfs:label 'Recordability Determination Date' ;
    rdfs:comment 'The date on which the safety officer or compliance team made the final determination of whether the incident is OSHA recordable. Required for audit trail and to ensure timely OSHA 300 log entry within the 7-calendar-day requirement.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportedDate rdf:type rdf:Property ;
    rdfs:label 'Reported Date' ;
    rdfs:comment 'The date on which the incident was formally reported to the staffing agency or client safety officer. Used to measure reporting lag compliance against OSHA 24-hour and 8-hour reporting requirements for severe injuries.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnToWorkDate rdf:type rdf:Property ;
    rdfs:label 'Return To Work Date' ;
    rdfs:comment 'The date on which the injured worker returned to full or modified duty following the incident. Used to calculate actual days away from work, manage assignment continuity, and track workers comp claim closure.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Narrative or structured description of the underlying root cause(s) identified through incident investigation (e.g., inadequate training, equipment failure, unsafe work practice, environmental hazard, lack of PPE). Required for corrective action planning and OSHA compliance program documentation.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerJobTitle rdf:type rdf:Property ;
    rdfs:label 'Worker Job Title' ;
    rdfs:comment 'The job title or occupation of the contingent worker at the time of the incident. Required for OSHA Form 301 and used for occupation-level risk analysis and EEOC/OFCCP workforce safety reporting.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerTenureDays rdf:type rdf:Property ;
    rdfs:label 'Worker Tenure Days' ;
    rdfs:comment 'The number of days the worker had been on the current assignment at the client site at the time of the incident. Used for new-worker safety risk analysis, as OSHA data consistently shows elevated injury rates in the first 90 days of an assignment.' ;
    rdfs:domain ind:OshaIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorViolationRegulatoryViolationId rdf:type rdf:Property ;
    rdfs:label 'Prior Violation Regulatory Violation Id' ;
    rdfs:comment 'Reference to the earlier regulatory_violation record that this violation is a recurrence of. Enables lineage tracking of repeat violations and supports OSHA repeat citation defense documentation. Nullable when repeat_violation_flag is false.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryViolation .

ind:affectedClientCount rdf:type rdf:Property ;
    rdfs:label 'Affected Client Count' ;
    rdfs:comment 'Number of client accounts impacted by this regulatory violation. Relevant for systemic violations spanning multiple client engagements (e.g., widespread I-9 non-compliance, multi-site OSHA violations). Supports enterprise-wide compliance risk assessment.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedWorkerCount rdf:type rdf:Property ;
    rdfs:label 'Affected Worker Count' ;
    rdfs:comment 'Number of workers (temporary associates, contractors, or permanent employees) impacted by this regulatory violation. Used for severity assessment, penalty calculation, and EEOC/DOL class-action risk evaluation. Supports board-level compliance reporting.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agencyCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Agency Case Number' ;
    rdfs:comment 'External case or docket number assigned by the regulatory agency (e.g., EEOC charge number, OSHA inspection number, DOL case reference, IRS audit ID). Required for tracking formal enforcement actions and agency correspondence. Nullable for internally-discovered violations not yet reported to an agency.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Agency Notification Date' ;
    rdfs:comment 'Date on which the regulatory agency was formally notified of the violation or initiated contact with the organization. Triggers mandatory response timelines under OSHA, EEOC, and GDPR breach notification requirements. Nullable for violations not yet reported to an agency.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicableStatute rdf:type rdf:Property ;
    rdfs:label 'Applicable Statute' ;
    rdfs:comment 'The specific federal, state, or local statute, regulation, or code section that was violated (e.g., 29 CFR Part 1904, FLSA Section 13(a)(1), Title VII of the Civil Rights Act, INA Section 274A, FCRA Section 604). Supports precise legal tracking and regulatory reporting.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Board Notification Date' ;
    rdfs:comment 'Date on which the board of directors or executive leadership was formally notified of this regulatory violation. Nullable when board_notification_required is false or notification has not yet occurred. Supports governance audit trails.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:boardNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Board Notification Required' ;
    rdfs:comment 'Indicates whether this violation meets the threshold requiring notification to the board of directors or executive leadership. Typically triggered by critical severity, significant financial penalty, or class-action exposure. Supports board-level compliance reporting cadence.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coEmploymentRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Co Employment Risk Flag' ;
    rdfs:comment 'Indicates whether this violation involves or creates co-employment or joint employment risk between the staffing firm and the client. Triggers enhanced legal review and client notification protocols. Critical for MSP/VMS program compliance and liability management.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataPrivacyBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Breach Flag' ;
    rdfs:comment 'Indicates whether this violation constitutes or involves a personal data breach requiring notification under GDPR Article 33, CCPA, or FCRA. Triggers the 72-hour GDPR breach notification clock and state-specific breach notification timelines.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discoveryDate rdf:type rdf:Property ;
    rdfs:label 'Discovery Date' ;
    rdfs:comment 'The calendar date on which the regulatory violation was first identified or discovered. Serves as the principal business event date for the violation record. Critical for calculating regulatory response deadlines, statute of limitations tracking, and trending analysis.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discoveryMethod rdf:type rdf:Property ;
    rdfs:label 'Discovery Method' ;
    rdfs:comment 'The mechanism by which the regulatory violation was identified: internal audit, external complaint, agency notice, whistleblower report, client notification, or self-assessment. Critical for root cause analysis and improving proactive compliance controls.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eeocChargeBasis rdf:type rdf:Property ;
    rdfs:label 'Eeoc Charge Basis' ;
    rdfs:comment 'The protected class or basis for an EEOC discrimination charge associated with this violation (e.g., race, color, sex, national origin, religion, age, disability, genetic information). Nullable for non-EEOC violations. [ENUM-REF-CANDIDATE: race|color|sex|national_origin|religion|age|disability|genetic_information|retaliation|other — promote to reference product]' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Penalty Amount' ;
    rdfs:comment 'Monetary value of fines, penalties, or settlements assessed or anticipated as a result of this regulatory violation, expressed in USD. Includes OSHA citations, DOL back-pay orders, EEOC settlements, and IRS tax penalties. Supports financial risk reporting and board-level compliance dashboards.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:i9EverifyFlag rdf:type rdf:Property ;
    rdfs:label 'I9 Everify Flag' ;
    rdfs:comment 'Indicates whether this violation specifically involves I-9 Employment Eligibility Verification or E-Verify non-compliance under the Immigration and Nationality Act. Triggers mandatory ICE/DHS reporting protocols and I-9 audit remediation workflows.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionCountry rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the jurisdiction in which the violation occurred (e.g., USA, GBR, CAN). Supports international compliance tracking under GDPR and other cross-border regulatory frameworks for staffing firms with global operations.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionState rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction State' ;
    rdfs:comment 'Two-letter U.S. state code (or equivalent jurisdiction identifier) where the violation occurred or where the applicable law is enforced. Supports state labor board reporting, state-specific wage and hour compliance, and CCPA/state privacy law tracking.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalCounselInvolved rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Involved' ;
    rdfs:comment 'Indicates whether internal or external legal counsel has been engaged in connection with this regulatory violation. Triggers attorney-client privilege protections and routes the record to the legal hold workflow. Required for board-level compliance reporting.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oshaCitationType rdf:type rdf:Property ;
    rdfs:label 'Osha Citation Type' ;
    rdfs:comment 'OSHA-specific citation classification for safety violations: willful, serious, other-than-serious, repeat, or de minimis. Determines penalty calculation under OSHA 29 CFR Part 1903. Nullable for non-OSHA violations.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the financial penalty amount (e.g., USD for U.S. Dollar, EUR for Euro). Supports international operations under GDPR and multi-jurisdiction compliance tracking.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'The governing regulatory authority or agency associated with this violation (e.g., DOL, EEOC, OSHA, OFCCP, IRS, FCRA, GDPR, CCPA, state labor board). Drives routing to appropriate legal counsel and determines mandatory response timelines. [ENUM-REF-CANDIDATE: DOL|EEOC|OSHA|OFCCP|IRS|FCRA|GDPR|CCPA|state_labor_board|other — promote to reference product]' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Completed Date' ;
    rdfs:comment 'Actual date on which the remediation plan was fully executed and the violation was resolved. Used to calculate remediation cycle time KPIs and to confirm closure eligibility. Nullable until remediation is complete.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationDueDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Due Date' ;
    rdfs:comment 'Target date by which the remediation plan must be fully executed and the violation resolved. Drives SLA tracking on the compliance dashboard and triggers escalation alerts when approaching or past due.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationPlan rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan' ;
    rdfs:comment 'Detailed description of the corrective action plan developed to address and resolve the regulatory violation. Includes specific steps, process changes, training requirements, and system corrections required. Supports DOL, OSHA, and EEOC corrective action documentation requirements.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Violation Flag' ;
    rdfs:comment 'Indicates whether this violation is a recurrence of a previously identified and remediated violation of the same type. Repeat violations carry significantly higher OSHA and DOL penalty multipliers and indicate systemic compliance control failures.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Current lifecycle state of the regulatory violation record, tracking progress from initial identification through remediation and closure. Drives compliance dashboard KPIs and board-level reporting. [ENUM-REF-CANDIDATE: open|in_remediation|pending_review|resolved|closed|escalated — promote to reference product]' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Response Deadline Date' ;
    rdfs:comment 'Mandatory deadline by which the organization must respond to the regulatory agency or complete required filings. Derived from agency notification date plus statutory response windows (e.g., OSHA 15-day informal conference, EEOC 180-day charge response). Critical for SLA compliance tracking.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Standardized severity classification of the regulatory violation: minor (low risk, administrative), moderate (process failure, correctable), major (significant regulatory exposure), critical (immediate legal/financial risk, board notification required). Drives escalation workflows and KPI dashboards.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationDescription rdf:type rdf:Property ;
    rdfs:label 'Violation Description' ;
    rdfs:comment 'Detailed narrative description of the regulatory violation, including the specific non-compliant act or omission, the circumstances under which it occurred, and the regulatory requirement that was breached. Supports legal counsel review and regulatory agency correspondence.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationNumber rdf:type rdf:Property ;
    rdfs:label 'Violation Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the violation record (e.g., RV-2024-000123). Used in correspondence with regulatory agencies, legal counsel, and board-level reporting. Sourced from the compliance management workflow.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationType rdf:type rdf:Property ;
    rdfs:label 'Violation Type' ;
    rdfs:comment 'Categorical classification of the regulatory violation by type (e.g., I-9 non-compliance, FLSA misclassification, EEOC discrimination, OSHA safety breach, FCRA background check violation, GDPR data breach, CCPA privacy violation, wage and hour violation, co-employment breach). [ENUM-REF-CANDIDATE: i9_noncompliance|flsa_misclassification|eeoc_discrimination|osha_safety|fcra_violation|gdpr_breach|ccpa_violation|wage_hour|co_employment|other — promote to reference product]' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerClassificationType rdf:type rdf:Property ;
    rdfs:label 'Worker Classification Type' ;
    rdfs:comment 'The IRS/FLSA worker classification applicable to the affected worker at the time of the violation: W-2 (employee), 1099 (independent contractor), EOR (Employer of Record), PEO (Professional Employer Organization), FTE (Full-Time Equivalent), or contract-to-hire. Central to FLSA misclassification violation tracking and IRS audit defense.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Penalty Amount' ;
    rdfs:comment 'Actual monetary penalty, fine, or back-wage settlement amount assessed as a result of the audit, expressed in USD. Populated upon audit closure when a regulatory determination or settlement has been reached. Distinct from estimated_financial_exposure.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedPopulationSize rdf:type rdf:Property ;
    rdfs:label 'Affected Population Size' ;
    rdfs:comment 'Total number of workers, placements, timesheets, or records within the audit scope that were subject to review. Used to assess the breadth of compliance exposure and calculate error rates (e.g., I-9 deficiency rate per 100 workers).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the audit (e.g., AUD-2024-000123). Used for cross-referencing with regulatory agencies, external auditors, and internal tracking systems. Sourced from the compliance management module.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Narrative description of the audit scope, including the business processes, organizational units, client accounts, placement types, or regulatory requirements under review. Defines the boundaries of the audit engagement.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditSource rdf:type rdf:Property ;
    rdfs:label 'Audit Source' ;
    rdfs:comment 'Indicates whether the audit was initiated internally (by the compliance team), externally (by a regulatory agency or external auditor), at client request, or self-initiated as part of a proactive compliance program.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle state of the compliance audit. Tracks progression from planning through closure. Valid values: planned (scheduled but not started), in_progress (fieldwork underway), findings_issued (draft or final report delivered), remediation (corrective actions in progress), closed (all findings resolved and audit concluded), cancelled (audit voided before completion).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the compliance audit by regulatory or operational domain. Indicates the primary subject matter of the audit. [ENUM-REF-CANDIDATE: i9_audit|payroll_tax_audit|flsa_audit|fcra_audit|soc2_audit|client_compliance_audit|dol_audit|osha_audit|eeoc_audit|ofccp_audit|workers_comp_audit|state_wage_audit — promote to reference product]' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'The date on which the audit was formally closed, meaning all findings have been remediated and accepted by the auditing party. Null if the audit is still open.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionPlanDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Due Date' ;
    rdfs:comment 'The deadline by which the formal Corrective Action Plan (CAP) must be submitted to the auditing party or regulatory agency. Drives remediation scheduling and escalation workflows.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Status' ;
    rdfs:comment 'Current status of the Corrective Action Plan (CAP) associated with this audit. Tracks whether a CAP is required, has been submitted, accepted by the auditing party, rejected, or is overdue.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Number of findings rated as critical severity within this audit. Critical findings typically require immediate escalation and expedited remediation. Tracked separately for executive and regulatory reporting.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedFinancialExposure rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Exposure' ;
    rdfs:comment 'Estimated monetary exposure or liability associated with the audit findings, expressed in USD. Includes potential penalties, back wages, fines, or remediation costs. Used for financial risk management and executive reporting. Not a calculated aggregate — represents the compliance teams point-in-time risk estimate.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalAuditorFirm rdf:type rdf:Property ;
    rdfs:label 'External Auditor Firm' ;
    rdfs:comment 'Name of the external auditing firm, regulatory agency, or third-party organization conducting the audit. Null for purely internal audits. Examples: KPMG, Deloitte, DOL Wage and Hour Division, EEOC field office.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldworkEndDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork End Date' ;
    rdfs:comment 'The date on which active audit fieldwork was completed. Marks the transition from evidence gathering to findings analysis and report drafting.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldworkStartDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork Start Date' ;
    rdfs:comment 'The date on which active audit fieldwork (evidence collection, interviews, document review) commenced. Represents the principal real-world business event timestamp for the audit engagement start. Used for SLA and TTF (Time to Fill) compliance tracking.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Description of the geographic coverage of the audit, such as specific states, regions, or enterprise-wide. Relevant for state wage and hour audits (SUTA, state FLSA equivalents), CCPA (California), and multi-state compliance reviews.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatingAgency rdf:type rdf:Property ;
    rdfs:label 'Initiating Agency' ;
    rdfs:comment 'Name of the regulatory agency, external auditing firm, or client organization that initiated or requested the audit. Examples: U.S. Department of Labor, EEOC, OSHA, IRS, client legal counsel, or an external CPA firm conducting a SOC 2 review.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAuditorName rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Name' ;
    rdfs:comment 'Full name of the primary auditor responsible for conducting the audit. May be an internal compliance officer or an external auditor from a regulatory agency or third-party firm. Used for accountability and communication tracking.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalCounselEngaged rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Engaged' ;
    rdfs:comment 'Indicates whether external or internal legal counsel has been engaged in connection with this audit. True when legal representation is involved, which may affect document privilege and response strategy.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:methodology rdf:type rdf:Property ;
    rdfs:label 'Methodology' ;
    rdfs:comment 'The approach used to conduct the audit. Statistical sample audits review a representative subset; full population audits review all records; targeted sample focuses on high-risk records; desk review is document-only; on-site involves physical inspection; hybrid combines methods.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Open Findings Count' ;
    rdfs:comment 'Number of audit findings that remain open (not yet remediated or closed) at the time of record update. Supports real-time compliance dashboard monitoring and escalation tracking.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallDisposition rdf:type rdf:Property ;
    rdfs:label 'Overall Disposition' ;
    rdfs:comment 'Final outcome or disposition of the audit. Indicates whether the organization passed, passed with findings requiring remediation, failed, or whether the audit was inconclusive or withdrawn. Key metric for executive compliance dashboards and regulatory reporting.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRiskRating rdf:type rdf:Property ;
    rdfs:label 'Overall Risk Rating' ;
    rdfs:comment 'Aggregate risk rating assigned to the audit based on the severity and volume of findings. Rolled up from individual finding risk ratings. Drives escalation protocols and executive reporting. Values: low, medium, high, critical.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The ending date of the time period under audit review. Defines the latest date of business activity or records subject to examination. Together with audit_period_start_date, establishes the audit window.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The beginning date of the time period under audit review. Defines the earliest date of business activity or records subject to examination. Distinct from the audit execution start date.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:placementTypeScope rdf:type rdf:Property ;
    rdfs:label 'Placement Type Scope' ;
    rdfs:comment 'The type of worker placement covered by this audit. Indicates whether the audit applies to temporary workers, permanent placements, contract-to-hire (temp-to-perm), direct hire, SOW (Statement of Work) engagements, or all placement types. Relevant for FLSA worker classification and co-employment risk audits.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorAuditReference rdf:type rdf:Property ;
    rdfs:label 'Prior Audit Reference' ;
    rdfs:comment 'Audit number of the most recent prior audit of the same type, used to establish continuity and track repeat findings. Enables year-over-year compliance trend analysis without creating a hard FK dependency at this stage.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privilegeHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Privilege Hold Flag' ;
    rdfs:comment 'Indicates whether attorney-client privilege or work product doctrine has been asserted over audit materials. When True, certain audit documents are restricted from disclosure. Relevant for regulatory audits where legal exposure exists.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryCitation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Citation' ;
    rdfs:comment 'The primary federal or state regulatory citation, statute, or rule that is the subject of the audit. Examples: 29 CFR Part 516 (FLSA recordkeeping), 8 CFR 274a (I-9), 29 CFR 1904 (OSHA recordkeeping), IRC Section 3509 (worker misclassification). Supports regulatory mapping and citation-level trend analysis.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNoticeReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notice Reference' ;
    rdfs:comment 'Official case number, docket number, or notice reference assigned by the regulatory agency initiating the audit. Examples: DOL case number, EEOC charge number, IRS examination reference. Used for official correspondence and regulatory tracking.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatFindingFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Finding Flag' ;
    rdfs:comment 'Indicates whether this audit contains one or more findings that were also identified in a prior audit cycle (repeat findings). Repeat findings signal systemic control failures and typically result in elevated regulatory scrutiny and penalties.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Report Issued Date' ;
    rdfs:comment 'The date on which the formal audit report (draft or final) was issued to stakeholders. Triggers the remediation clock for findings with regulatory deadlines.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Number of records, transactions, or workers included in the audit sample. Applicable when audit_methodology is statistical_sample or targeted_sample. Used to calculate deficiency rates and statistical confidence levels.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Secondary classification providing additional specificity within the audit type. For example, within a payroll_tax_audit: FICA, FUTA, SUTA, or worker classification (W-2 vs 1099/IC). Enables granular reporting and trend analysis by compliance sub-domain.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Total Findings Count' ;
    rdfs:comment 'Total number of audit findings identified during the audit engagement. Includes all severity levels. Used for KPI reporting and trend analysis across audit cycles.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workerClassificationScope rdf:type rdf:Property ;
    rdfs:label 'Worker Classification Scope' ;
    rdfs:comment 'Indicates whether the audit covers W-2 employees, 1099 independent contractors (IC), both classifications, or is not applicable to worker classification. Critical for IRS worker misclassification audits and FLSA compliance reviews.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorDeterminationWageHourDeterminationId rdf:type rdf:Property ;
    rdfs:label 'Prior Determination Wage Hour Determination Id' ;
    rdfs:comment 'Reference to the previous wage and hour determination record that this determination supersedes or replaces. Supports determination versioning and audit trail for changes in classification or pay rate over time.' ;
    rdfs:domain ind:WageHourDetermination ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WageHourDetermination .

ind:applicableLaw rdf:type rdf:Property ;
    rdfs:label 'Applicable Law' ;
    rdfs:comment 'The primary federal or state law or regulation governing this determination (e.g., FLSA, Davis-Bacon Act, Service Contract Act, California Labor Code §510, New York Minimum Wage Order). Supports multi-jurisdiction compliance tracking.' ;
    rdfs:domain ind:WageHourDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coEmploymentRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Co Employment Risk Level' ;
    rdfs:comment 'Assessed level of co-employment or joint employment risk for this worker engagement based on the degree of client control over the worker. High or critical risk may require EOR arrangement or contract restructuring to mitigate joint employer liability.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:determinationNumber rdf:type rdf:Property ;
    rdfs:label 'Determination Number' ;
    rdfs:comment 'Externally-known business identifier for this determination record, used in DOL audit correspondence, compliance officer sign-off documentation, and FLSA litigation defense filings. Format: WHD-YYYY-NNNNNN.' ;
    rdfs:domain ind:WageHourDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:determinationStatus rdf:type rdf:Property ;
    rdfs:label 'Determination Status' ;
    rdfs:comment 'Current lifecycle state of the wage and hour determination record. draft indicates initial assessment in progress; pending_review awaits compliance officer sign-off; approved is finalized and operative; superseded replaced by a newer determination; appealed under formal challenge; closed no longer active.' ;
    rdfs:domain ind:WageHourDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dolAuditFlag rdf:type rdf:Property ;
    rdfs:label 'Dol Audit Flag' ;
    rdfs:comment 'Indicates whether this determination record has been flagged as part of an active or anticipated DOL Wage and Hour Division audit. True triggers enhanced documentation retention and compliance officer review.' ;
    rdfs:domain ind:WageHourDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dolWageDeterminationNumber rdf:type rdf:Property ;
    rdfs:label 'Dol Wage Determination Number' ;
    rdfs:comment 'The official U.S. Department of Labor wage determination number (from SAM.gov or DOL Wage Determinations Online) applicable to this engagement under Davis-Bacon or Service Contract Act. Null if prevailing wage does not apply.' ;
    rdfs:domain ind:WageHourDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dtThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Dt Threshold Hours' ;
    rdfs:comment 'The daily or weekly hour threshold beyond which double-time (DT) pay is required. Applicable in states such as California where hours over 12 in a day or over 8 on the 7th consecutive day trigger DT. Null if DT does not apply to this engagement.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exemptionBasis rdf:type rdf:Property ;
    rdfs:label 'Exemption Basis' ;
    rdfs:comment 'The specific FLSA white-collar or other exemption category applied when the worker is classified as exempt. none applies to non-exempt workers. Required for DOL audit documentation and FLSA litigation defense to demonstrate the basis for exemption. [ENUM-REF-CANDIDATE: executive|administrative|professional|computer_employee|outside_sales|highly_compensated|motor_carrier|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WageHourDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'The job title of the worker at the time of this determination. Used to validate FLSA exemption basis (e.g., executive, professional), prevailing wage job classification, and pay equity peer group comparisons.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:litigationHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Litigation Hold Flag' ;
    rdfs:comment 'Indicates whether this determination record is subject to a litigation hold due to active or threatened FLSA litigation. Records under litigation hold must not be modified or deleted.' ;
    rdfs:domain ind:WageHourDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumWageApplicable rdf:type rdf:Property ;
    rdfs:label 'Minimum Wage Applicable' ;
    rdfs:comment 'The minimum wage rate (per hour, USD) applicable to this worker based on federal, state, or local law — whichever is highest. Used to validate that pay_rate_validated meets or exceeds the legal floor. Supports state-specific minimum wage compliance tracking.' ;
    rdfs:domain ind:WageHourDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumWageJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Minimum Wage Jurisdiction' ;
    rdfs:comment 'The jurisdiction (federal, state, or local municipality) whose minimum wage rate was applied as the floor for this determination. Examples: Federal, California, New York City. Supports multi-jurisdiction compliance reporting.' ;
    rdfs:domain ind:WageHourDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Ot Threshold Hours' ;
    rdfs:comment 'The weekly (or daily, for states like California) hour threshold beyond which overtime pay is required for this worker. Standard federal FLSA threshold is 40 hours/week; California requires daily OT after 8 hours. Drives timesheet OT calculation rules.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payEquityOutcome rdf:type rdf:Property ;
    rdfs:label 'Pay Equity Outcome' ;
    rdfs:comment 'Result of the pay equity review for this worker engagement. compliant indicates no pay disparity found; gap_identified flags a potential pay equity issue requiring remediation; remediated indicates a gap was corrected; not_applicable when no pay equity review was required.' ;
    rdfs:domain ind:WageHourDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payEquityReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Pay Equity Review Flag' ;
    rdfs:comment 'Indicates whether a pay equity assessment was conducted as part of this determination. True triggers documentation of the pay equity analysis outcome. Supports EEOC and OFCCP pay equity compliance reporting.' ;
    rdfs:domain ind:WageHourDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payRateValidated rdf:type rdf:Property ;
    rdfs:label 'Pay Rate Validated' ;
    rdfs:comment 'The workers pay rate (per hour) that was validated against applicable minimum wage, prevailing wage, or FLSA salary threshold requirements as part of this determination. Expressed in USD per hour. Core field for DOL audit readiness and pay equity assessments.' ;
    rdfs:domain ind:WageHourDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prevailingWageType rdf:type rdf:Property ;
    rdfs:label 'Prevailing Wage Type' ;
    rdfs:comment 'Specifies the prevailing wage framework applicable to this engagement. davis_bacon for federal construction projects; service_contract_act for federal service contracts; state_prevailing_wage for state-mandated prevailing wage laws; none when no prevailing wage applies.' ;
    rdfs:domain ind:WageHourDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTrigger rdf:type rdf:Property ;
    rdfs:label 'Review Trigger' ;
    rdfs:comment 'The business event or reason that initiated this wage and hour determination. [ENUM-REF-CANDIDATE: new_placement|rate_change|law_change|periodic_review|dol_audit|client_request|worker_complaint — promote to reference product]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryThresholdMet rdf:type rdf:Property ;
    rdfs:label 'Salary Threshold Met' ;
    rdfs:comment 'Indicates whether the workers salary meets the current FLSA minimum salary threshold required for white-collar exemption ($684/week as of 2024 federal standard). True is required for exempt classification under executive, administrative, or professional exemptions.' ;
    rdfs:domain ind:WageHourDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signOffDate rdf:type rdf:Property ;
    rdfs:label 'Sign Off Date' ;
    rdfs:comment 'Date on which the compliance officer formally approved and signed off on this wage and hour determination. Required for DOL audit trail documentation.' ;
    rdfs:domain ind:WageHourDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workState rdf:type rdf:Property ;
    rdfs:label 'Work State' ;
    rdfs:comment 'Two-letter US state code where the worker performs services. Determines applicable state minimum wage, state overtime rules, state prevailing wage laws, SUTA jurisdiction, and workers compensation requirements.' ;
    rdfs:domain ind:WageHourDetermination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialId rdf:type rdf:Property ;
    rdfs:label 'Credential Id' ;
    rdfs:comment 'Foreign key linking to credentialing.credential. Business justification: Compliance requirements define which credentials are mandatory for regulatory compliance (e.g., state-specific licenses, federal contractor requirements). Business process: Compliance rule engine maps' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Credential .

ind:supersededByRequirementId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Requirement Id' ;
    rdfs:comment 'Reference to the compliance_requirement_id of the newer requirement that replaces this record when status is superseded. Enables forward-chaining of requirement version history for audit and compliance lineage.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Requirement .

ind:applicablePlacementType rdf:type rdf:Property ;
    rdfs:label 'Applicable Placement Type' ;
    rdfs:comment 'Specifies which placement types this requirement governs (e.g., temporary, permanent, contract_to_hire, direct_placement, all). Drives requirement-to-placement enforcement checks in the compliance engine. [ENUM-REF-CANDIDATE: temporary|permanent|contract_to_hire|direct_placement|temp_to_perm|sow|all — promote to reference product]' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableWorkerType rdf:type rdf:Property ;
    rdfs:label 'Applicable Worker Type' ;
    rdfs:comment 'Specifies which worker classification this requirement applies to: W-2 employees, 1099 independent contractors (IC), both, or all workers regardless of classification. Critical for FLSA worker classification enforcement and IRS co-employment risk management.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliesToOffboarding rdf:type rdf:Property ;
    rdfs:label 'Applies To Offboarding' ;
    rdfs:comment 'Indicates whether this requirement must be fulfilled during the worker offboarding process (True), such as final I-9 retention checks, COBRA notification, or non-compete enforcement at assignment end.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToOnboarding rdf:type rdf:Property ;
    rdfs:label 'Applies To Onboarding' ;
    rdfs:comment 'Indicates whether this requirement must be fulfilled during the worker onboarding process (True). Drives onboarding checklist generation in SAP SuccessFactors and Bullhorn ATS/CRM for new placements.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditTrailRequired rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Required' ;
    rdfs:comment 'Indicates whether this requirement mandates a formal audit trail of compliance actions (True). When True, all enforcement checks, document submissions, and status changes must be logged for DOL, OSHA, IRS, or EEOC audit defense purposes.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientSpecificFlag rdf:type rdf:Property ;
    rdfs:label 'Client Specific Flag' ;
    rdfs:comment 'Indicates whether this requirement is specific to a particular clients contractual mandate (True) rather than a universal federal or industry standard (False). Client-specific requirements are typically defined in the clients MSA or SOW.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceFrequency rdf:type rdf:Property ;
    rdfs:label 'Compliance Frequency' ;
    rdfs:comment 'How often this requirement must be fulfilled or re-verified: one_time (at hire/placement), per_placement (each new assignment), annual (yearly renewal), quarterly, monthly, or ongoing (continuous monitoring). Drives scheduling of compliance checks.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOwnerRole rdf:type rdf:Property ;
    rdfs:label 'Compliance Owner Role' ;
    rdfs:comment 'The organizational role responsible for ensuring this requirement is met and enforced (e.g., compliance_team, legal_counsel, hr_operations, recruiter, branch_manager, payroll_team). Used for workflow routing and accountability assignment.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementActionRequired rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Required' ;
    rdfs:comment 'Specifies the system or operational action to take when this requirement is not met: block_placement (prevent assignment activation), notify_compliance (alert compliance team), flag_for_review (queue for manual review), document_only (record non-compliance without blocking), escalate_to_legal (route to legal counsel).' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceUrl rdf:type rdf:Property ;
    rdfs:label 'External Reference Url' ;
    rdfs:comment 'URL link to the official regulatory text, governing body publication, or client contract clause that defines this requirement (e.g., link to eCFR, EEOC.gov guidance, OSHA standard). Enables compliance officers to access authoritative source documentation.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:federalContractorApplicable rdf:type rdf:Property ;
    rdfs:label 'Federal Contractor Applicable' ;
    rdfs:comment 'Indicates whether this requirement applies specifically or additionally to federal contractor placements (True), as governed by OFCCP, E-Verify Executive Order 13465, or FAR clauses. Drives enhanced compliance checks for federal contract assignments.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingBody rdf:type rdf:Property ;
    rdfs:label 'Governing Body' ;
    rdfs:comment 'The regulatory authority, agency, or organization that issued or enforces this requirement (e.g., U.S. Department of Labor, EEOC, OSHA, OFCCP, IRS, ASA, SHRM, USCIS). Used for audit trail and regulatory reporting alignment.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Grace Period Days' ;
    rdfs:comment 'Number of calendar days after a triggering event (e.g., hire date, placement start) within which this requirement must be fulfilled before enforcement action is triggered. For example, I-9 must be completed within 3 business days of hire.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:industrySectorScope rdf:type rdf:Property ;
    rdfs:label 'Industry Sector Scope' ;
    rdfs:comment 'Specifies the industry sector(s) to which this requirement applies (e.g., Healthcare, Finance, Government, All). Some compliance requirements are sector-specific (e.g., OSHA 300 log for manufacturing, drug screening for DOT-regulated industries). Pipe-delimited for multi-sector applicability.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobCategoryScope rdf:type rdf:Property ;
    rdfs:label 'Job Category Scope' ;
    rdfs:comment 'Specifies the job categories or occupational classifications to which this requirement applies (e.g., All, CDL Drivers, Healthcare Workers, IT Professionals). Drives targeted enforcement for role-specific compliance mandates such as drug screening or credentialing.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionScope rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Scope' ;
    rdfs:comment 'Geographic or contractual scope of applicability for this requirement: federal (applies nationwide), state (applies within specific states — detail in state_compliance_rule), local (city/county level), client_specific (applies only to placements under a specific client contract), international (GDPR, CCPA cross-border), multi_jurisdiction (spans multiple levels).' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryDocumentationChecklist rdf:type rdf:Property ;
    rdfs:label 'Mandatory Documentation Checklist' ;
    rdfs:comment 'Pipe-delimited or structured list of required documents that must be collected and retained to satisfy this compliance requirement (e.g., I-9 Form|Passport Copy|E-Verify Case Number or EEO-1 Report|Workforce Census Data). Drives document collection workflows in onboarding and placement management.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmountMax rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount Max' ;
    rdfs:comment 'Maximum monetary penalty (in USD) that can be assessed per violation of this requirement, as published by the governing regulatory body. Used in risk scoring and compliance prioritization. Expressed in USD.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyDescription rdf:type rdf:Property ;
    rdfs:label 'Penalty Description' ;
    rdfs:comment 'Narrative description of the regulatory or contractual penalties for failing to meet this requirement (e.g., Civil penalty up to $2,320 per I-9 violation per USCIS schedule, Contract termination per MSA Section 12.3). Used in risk assessment and compliance training.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reVerificationIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Re Verification Interval Days' ;
    rdfs:comment 'Number of days between required re-verifications when re_verification_required is True. Used to calculate next due dates for compliance tracking and automated reminders. Null when re_verification_required is False.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requirementCategory rdf:type rdf:Property ;
    rdfs:label 'Requirement Category' ;
    rdfs:comment 'Functional compliance domain grouping this requirement belongs to (e.g., I-9 / E-Verify, EEOC Reporting, OFCCP Reporting, FLSA Classification, OSHA Safety, Background Check / FCRA, Co-Employment Risk, Non-Compete / NDA, Tax / IRS, Workers Compensation). Drives requirement-to-enforcement routing. [ENUM-REF-CANDIDATE: i9_everify|eeoc_reporting|ofccp_reporting|flsa_classification|osha_safety|bgc_fcra|co_employment|non_compete_nda|tax_irs|workers_comp — promote to reference product]' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementCode rdf:type rdf:Property ;
    rdfs:label 'Requirement Code' ;
    rdfs:comment 'Externally-known, human-readable unique code identifying this compliance requirement (e.g., I9-FED-001, EEOC-RPT-002, OSHA-300-LOG). Used as the business key across systems and in compliance checklists.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementDescription rdf:type rdf:Property ;
    rdfs:label 'Requirement Description' ;
    rdfs:comment 'Full narrative description of the compliance requirement, including what is mandated, who it applies to, and the business process it governs. Serves as the authoritative definition in the compliance rule catalog for enforcement checks and training.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementName rdf:type rdf:Property ;
    rdfs:label 'Requirement Name' ;
    rdfs:comment 'Short, human-readable title of the compliance requirement (e.g., I-9 Employment Eligibility Verification, EEOC Annual EEO-1 Report, FLSA Worker Classification Determination). Used in dashboards, checklists, and audit reports.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementStatus rdf:type rdf:Property ;
    rdfs:label 'Requirement Status' ;
    rdfs:comment 'Current lifecycle state of this compliance requirement record: active (currently enforceable), inactive (no longer applicable), pending_review (under legal/compliance review), superseded (replaced by a newer version), draft (not yet published for enforcement).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementType rdf:type rdf:Property ;
    rdfs:label 'Requirement Type' ;
    rdfs:comment 'Categorical classification of the requirement source: federal_regulation (mandated by U.S. federal law), client_contractual (mandated by client MSA/SOW), industry_standard (ASA, SIA, SHRM best practice), state_regulation (state-level law — note: detailed state rules live in state_compliance_rule), internal_policy (Staffing Hr internal mandate).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'Number of years that compliance documentation for this requirement must be retained per regulatory mandate (e.g., I-9 forms must be retained for 3 years after hire or 1 year after termination, whichever is later; OSHA 300 logs for 5 years). Drives records management and data lifecycle policies.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'The next scheduled date for the compliance team to review this requirement for regulatory changes, updates, or continued applicability. Supports proactive compliance management and audit readiness.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Risk severity classification for non-compliance with this requirement: critical (immediate legal/financial exposure, placement must be blocked), high (significant regulatory risk), medium (moderate risk requiring timely remediation), low (administrative or best-practice requirement).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCourseReference rdf:type rdf:Property ;
    rdfs:label 'Training Course Reference' ;
    rdfs:comment 'Identifier or name of the training course in the Learning Management System (LMS) that satisfies the training requirement for this compliance item. Populated when training_required is True. Links to SAP SuccessFactors LMS course catalog.' ;
    rdfs:domain ind:Requirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequired rdf:type rdf:Property ;
    rdfs:label 'Training Required' ;
    rdfs:comment 'Indicates whether completion of a specific training program is required to satisfy this compliance requirement (True). For example, OSHA safety training, EEOC harassment prevention training, or FLSA classification training for recruiters.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skillsAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Skills Assessment Id' ;
    rdfs:comment 'Foreign key linking to credentialing.skills_assessment. Business justification: For IT, healthcare, and finance placements, skills assessment is a mandatory compliance gate. The placement_compliance_check has no current link to skills_assessment despite tracking overall complianc' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkillsAssessment .

ind:assignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Date' ;
    rdfs:comment 'The scheduled or actual start date of the worker assignment or placement. Compliance clearance must be achieved prior to this date. Used to flag placements where clearance was obtained after assignment start.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bgcCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Bgc Completion Date' ;
    rdfs:comment 'The date on which the background check screening was completed and a final result was returned by Sterling Background Check. Used to assess BGC turnaround time and compliance with client SLA requirements.' ;
    rdfs:domain ind:PlacementComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bgcStatus rdf:type rdf:Property ;
    rdfs:label 'Bgc Status' ;
    rdfs:comment 'Status of the background check (BGC) screening for this placement as reported by Sterling Background Check. clear indicates no disqualifying findings. adverse_action indicates findings requiring pre-adverse and adverse action notices per FCRA. waived indicates client or internal authorization to proceed without BGC.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingCheckCount rdf:type rdf:Property ;
    rdfs:label 'Blocking Check Count' ;
    rdfs:comment 'Count of individual compliance check items that are currently in a failed or pending status that would block placement activation. A value of 0 with check_status = cleared confirms full compliance. Used in real-time compliance dashboards to prioritize remediation.' ;
    rdfs:domain ind:PlacementComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Check Initiated Date' ;
    rdfs:comment 'The business date on which the compliance gate-check process was initiated for this placement. Represents the principal real-world event time for this transaction. Used to measure compliance processing cycle time and SLA adherence.' ;
    rdfs:domain ind:PlacementComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:checkReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Check Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this compliance check record, used in audit trails, compliance dashboards, and cross-system references. Typically formatted as CHK-YYYY-NNNNNN.' ;
    rdfs:domain ind:PlacementComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkStatus rdf:type rdf:Property ;
    rdfs:label 'Check Status' ;
    rdfs:comment 'Overall lifecycle status of the placement compliance gate-check. cleared indicates all required checks passed and placement may go active. failed blocks placement from generating billable hours. waived indicates authorized exception granted. expired indicates a previously cleared check has lapsed and requires renewal.' ;
    rdfs:domain ind:PlacementComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkType rdf:type rdf:Property ;
    rdfs:label 'Check Type' ;
    rdfs:comment 'Classifies the nature of the compliance gate-check. initial applies to new placements, extension to assignment extensions, reactivation to returning workers, annual_renewal for ongoing long-term assignments, client_change when a worker transfers to a new client.' ;
    rdfs:domain ind:PlacementComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceDate rdf:type rdf:Property ;
    rdfs:label 'Clearance Date' ;
    rdfs:comment 'The date on which all required compliance checks were satisfied and the placement was granted compliance clearance to go active. Null if clearance has not yet been granted. Used to calculate time-to-clearance metrics.' ;
    rdfs:domain ind:PlacementComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientSpecificReqStatus rdf:type rdf:Property ;
    rdfs:label 'Client Specific Req Status' ;
    rdfs:comment 'Status of any additional compliance requirements mandated by the clients MSA or VMS program beyond standard federal and state requirements. Examples include client-specific background check panels, additional drug test panels, site-specific safety certifications, or vendor credentialing requirements in Beeline VMS.' ;
    rdfs:domain ind:PlacementComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Credential Verification Status' ;
    rdfs:comment 'Status of required professional credential and license verification for this placement. Applies to placements requiring specific certifications (e.g., nursing licenses, CDL, OSHA certifications, IT certifications). Verified through Sterling Background Check and internal credentialing processes.' ;
    rdfs:domain ind:PlacementComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugScreenDate rdf:type rdf:Property ;
    rdfs:label 'Drug Screen Date' ;
    rdfs:comment 'The date on which the drug screen specimen was collected and/or the final result was reported. Used to validate that drug screening was completed within the required pre-placement window.' ;
    rdfs:domain ind:PlacementComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drugScreenStatus rdf:type rdf:Property ;
    rdfs:label 'Drug Screen Status' ;
    rdfs:comment 'Status of the pre-placement drug screening for this worker. negative clears the worker for placement. positive blocks placement and may trigger adverse action. not_required applies when client or placement type does not mandate drug screening. Managed through Sterling Background Check.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eeocSelfIdCollected rdf:type rdf:Property ;
    rdfs:label 'Eeoc Self Id Collected' ;
    rdfs:comment 'Indicates whether the EEOC voluntary self-identification form (race, ethnicity, gender, disability, veteran status) has been collected from the worker for this placement. Required for EEOC and OFCCP reporting compliance for federal contractor clients.' ;
    rdfs:domain ind:PlacementComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noncompeteNdaCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Noncompete Nda Check Status' ;
    rdfs:comment 'Status of the review for existing non-compete agreements and NDAs that could restrict the workers placement with the target client. conflict_identified requires legal review before placement proceeds. Tracked via DocuSign CLM.' ;
    rdfs:domain ind:PlacementComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ofccpApplicabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Ofccp Applicability Flag' ;
    rdfs:comment 'Indicates whether this placement is subject to OFCCP affirmative action and equal employment opportunity requirements because the client is a federal contractor or subcontractor. Drives additional compliance obligations including AAP tracking and adverse impact analysis.' ;
    rdfs:domain ind:PlacementComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onboardingStatus rdf:type rdf:Property ;
    rdfs:label 'Onboarding Status' ;
    rdfs:comment 'Status of the worker onboarding process in SAP SuccessFactors, including completion of required forms, policy acknowledgments, direct deposit setup, and benefits enrollment. complete is required before a placement can generate billable hours.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallComplianceResult rdf:type rdf:Property ;
    rdfs:label 'Overall Compliance Result' ;
    rdfs:comment 'The final aggregated compliance determination for this placement. pass authorizes the placement to go active and generate billable hours. fail blocks activation. conditional_pass indicates clearance granted with documented exceptions or waivers. pending_review indicates escalation to compliance team.' ;
    rdfs:domain ind:PlacementComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementType rdf:type rdf:Property ;
    rdfs:label 'Placement Type' ;
    rdfs:comment 'The type of placement being compliance-checked. Determines which compliance requirements are applicable (e.g., I-9 requirements differ for SOW vs. direct placement; workers comp requirements differ for temporary vs. direct hire). [ENUM-REF-CANDIDATE: temporary|contract_to_hire|direct_placement|per_diem|sow|rpo — promote to reference product]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverAuthorization rdf:type rdf:Property ;
    rdfs:label 'Waiver Authorization' ;
    rdfs:comment 'Name or identifier of the authorized approver who granted a compliance waiver for this placement (if applicable). Required when check_status = waived or overall_compliance_result = conditional_pass. Provides audit trail for waiver accountability.' ;
    rdfs:domain ind:PlacementComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Expiry Date' ;
    rdfs:comment 'The date on which a granted compliance waiver expires. After this date, the outstanding compliance item must be completed or the placement may be suspended. Drives automated compliance expiry alerts.' ;
    rdfs:domain ind:PlacementComplianceCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Documented business justification for any compliance waiver granted for this placement. Required for audit trail integrity. Examples include client-approved exceptions, emergency placements with post-start completion commitments, or regulatory exemptions.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySupersededByRuleStateComplianceRuleId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Rule State Compliance Rule Id' ;
    rdfs:comment 'Reference to the state_compliance_rule_id of the newer rule that supersedes this rule. Null if this rule is current and not superseded.' ;
    rdfs:domain ind:StateComplianceRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StateComplianceRule .

ind:templateId rdf:type rdf:Property ;
    rdfs:label 'Template Id' ;
    rdfs:comment 'Foreign key linking to contract.template. Business justification: State compliance rules directly drive contract template clause selection (includes_flsa_compliance_clause, includes_eeoc_compliance_clause, includes_workers_comp_clause). Staffing contract teams must ' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Template .

ind:applicabilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Applicability Criteria' ;
    rdfs:comment 'Detailed business logic and conditions that determine when this compliance rule must be applied, including employer size, industry, worker type, and other qualifying factors.' ;
    rdfs:domain ind:StateComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableIndustrySector rdf:type rdf:Property ;
    rdfs:label 'Applicable Industry Sector' ;
    rdfs:comment 'Industry sector or North American Industry Classification System (NAICS) code range to which this rule applies. Null if applies to all industries.' ;
    rdfs:domain ind:StateComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationRequired rdf:type rdf:Property ;
    rdfs:label 'Documentation Required' ;
    rdfs:comment 'Description of documentation, records, or forms that must be maintained to demonstrate compliance with this state rule.' ;
    rdfs:domain ind:StateComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerSizeThreshold rdf:type rdf:Property ;
    rdfs:label 'Employer Size Threshold' ;
    rdfs:comment 'Minimum number of employees or Full-Time Equivalents (FTE) that triggers applicability of this compliance rule. Null if applies to all employer sizes.' ;
    rdfs:domain ind:StateComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enforcementAgency rdf:type rdf:Property ;
    rdfs:label 'Enforcement Agency' ;
    rdfs:comment 'Name of the state or local government agency responsible for enforcing this compliance rule (e.g., California Labor Commissioner, New York Department of Labor).' ;
    rdfs:domain ind:StateComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icTestType rdf:type rdf:Property ;
    rdfs:label 'Ic Test Type' ;
    rdfs:comment 'Type of legal test used by this jurisdiction to determine independent contractor classification (e.g., ABC test in California, common law test in other states). Only applicable for independent contractor classification rules.' ;
    rdfs:domain ind:StateComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionLevel rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Level' ;
    rdfs:comment 'Geographic scope level of the compliance rule indicating whether it applies at state, county, city, or municipal level.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionLocality rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Locality' ;
    rdfs:comment 'City, county, or local jurisdiction name where this rule applies if more granular than state-level (e.g., San Francisco, Cook County). Null for state-wide rules.' ;
    rdfs:domain ind:StateComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date when this compliance rule was last reviewed by the compliance team to verify accuracy and currency.' ;
    rdfs:domain ind:StateComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next periodic review of this compliance rule to ensure it remains current with legislative changes.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:penaltyAmountMin rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount Min' ;
    rdfs:comment 'Minimum monetary penalty amount in USD that may be assessed for violation of this compliance rule. Null if no minimum specified.' ;
    rdfs:domain ind:StateComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyPerViolation rdf:type rdf:Property ;
    rdfs:label 'Penalty Per Violation' ;
    rdfs:comment 'Indicates whether penalties are assessed per individual violation (True) or as a single penalty regardless of violation count (False).' ;
    rdfs:domain ind:StateComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postingRequirement rdf:type rdf:Property ;
    rdfs:label 'Posting Requirement' ;
    rdfs:comment 'Indicates whether this compliance rule requires physical posting of notices at worksites or inclusion in job postings (True) or not (False).' ;
    rdfs:domain ind:StateComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preemptsLocalLaw rdf:type rdf:Property ;
    rdfs:label 'Preempts Local Law' ;
    rdfs:comment 'Indicates whether this state-level rule preempts or supersedes more restrictive local ordinances (True) or allows local jurisdictions to impose stricter requirements (False).' ;
    rdfs:domain ind:StateComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Business identifier for the state compliance rule, typically formatted as state abbreviation followed by rule category code (e.g., CA-BTB001 for California Ban-the-Box).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name of the state compliance rule (e.g., California Ban-the-Box Law, New York Salary Transparency Act).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the state compliance rule indicating whether it is currently enforceable.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceUrl rdf:type rdf:Property ;
    rdfs:label 'Source Url' ;
    rdfs:comment 'Web URL link to the authoritative source document, legislative text, or regulatory guidance for this compliance rule.' ;
    rdfs:domain ind:StateComplianceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialTypeId rdf:type rdf:Property ;
    rdfs:label 'Credential Type Id' ;
    rdfs:comment 'Foreign key linking to credentialing.credential_type. Business justification: The credential master record must be classified by credential_type. credential_type is the reference table defining categories, validity periods, verification methods, and compliance frameworks for ea' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CredentialType .

ind:advanceNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Advance Notice Days' ;
    rdfs:comment 'Number of days before expiration that the system should trigger a renewal notification to the candidate and recruiter (e.g., 30, 60, 90 days). Enables proactive credential management to prevent placement disruptions due to lapsed credentials.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentPassingScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Passing Score' ;
    rdfs:comment 'Minimum passing score required for skills assessments or competency tests associated with this credential type (e.g., 70.00 for 70%). Null for non-assessment credential types. Used to evaluate candidate assessment results against the required threshold.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentScoreType rdf:type rdf:Property ;
    rdfs:label 'Assessment Score Type' ;
    rdfs:comment 'Defines how the assessment result is measured and reported for this credential type. Percentage (0-100%), raw score (numeric count), pass/fail (binary outcome), or grade (letter grade). Determines how passing_score is interpreted.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bgcCheckType rdf:type rdf:Property ;
    rdfs:label 'Bgc Check Type' ;
    rdfs:comment 'Specifies the type of background check (BGC) associated with this credential when it involves a Sterling Background Check screening. Drives the BGC order type submitted to Sterling. None indicates the credential does not involve a background check component. [ENUM-REF-CANDIDATE: criminal|drug_screen|employment_verification|education_verification|license_verification|credit|none|reference_check|sex_offender|mvr — promote to reference product]' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceuHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Ceu Hours Required' ;
    rdfs:comment 'Number of Continuing Education Unit (CEU) or professional development hours required per renewal cycle for this credential. Null if CEU is not required. Used to validate renewal completeness before credential re-issuance.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ceuRequired rdf:type rdf:Property ;
    rdfs:label 'Ceu Required' ;
    rdfs:comment 'Indicates whether this credential requires completion of Continuing Education Units (CEU) or Continuing Professional Development (CPD) hours as part of the renewal process. When True, the renewal workflow must capture CEU completion evidence.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceLevel rdf:type rdf:Property ;
    rdfs:label 'Clearance Level' ;
    rdfs:comment 'For security clearance credential types, specifies the clearance level (e.g., Confidential, Secret, Top Secret, Top Secret/SCI). Null or none for non-clearance credentials. Critical for government staffing vertical placement eligibility.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialCode rdf:type rdf:Property ;
    rdfs:label 'Credential Code' ;
    rdfs:comment 'Externally-known, human-readable unique code identifying this credential type across all systems (e.g., RN_LICENSE, OSHA_30, CDL_CLASS_A, CPA_CERT). Used as the business key in ATS, VMS, and compliance systems. Satisfies MASTER_RESOURCE BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialDescription rdf:type rdf:Property ;
    rdfs:label 'Credential Description' ;
    rdfs:comment 'Full narrative description of the credential, including its purpose, scope, and any special requirements or conditions. Provides context for recruiters, compliance officers, and candidates about what the credential entails and why it is required.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialName rdf:type rdf:Property ;
    rdfs:label 'Credential Name' ;
    rdfs:comment 'Full human-readable name of the credential, certification, license, or qualification (e.g., Registered Nurse License, OSHA 30-Hour Construction Safety, Commercial Driver License Class A, Certified Public Accountant). Satisfies MASTER_RESOURCE IDENTITY_LABEL category.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialStatus rdf:type rdf:Property ;
    rdfs:label 'Credential Status' ;
    rdfs:comment 'Current lifecycle state of this credential definition in the Staffing Hr catalog. Active credentials are available for assignment to candidates and placement eligibility checks. Deprecated credentials are retained for historical reference only. Satisfies MASTER_RESOURCE LIFECYCLE_STATUS category.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugScreenPanel rdf:type rdf:Property ;
    rdfs:label 'Drug Screen Panel' ;
    rdfs:comment 'Specifies the drug screening panel type when this credential involves a drug screen (e.g., 5-Panel, 10-Panel, 12-Panel, DOT 5-Panel). Null if the credential does not involve drug screening. Aligns with DOT and employer-specific drug testing requirements.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:everifyRequired rdf:type rdf:Property ;
    rdfs:label 'Everify Required' ;
    rdfs:comment 'Indicates whether this credential type triggers an E-Verify case submission requirement. Relevant for federal contractor placements and states with mandatory E-Verify laws. Integrates with the compliance.everify_case product.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalCredentialCode rdf:type rdf:Property ;
    rdfs:label 'External Credential Code' ;
    rdfs:comment 'The identifier for this credential type as recorded in the originating source system (e.g., Bullhorn credential type ID, Sterling check type code, SAP SuccessFactors qualification ID). Enables cross-system reconciliation and deduplication.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flsaRelevance rdf:type rdf:Property ;
    rdfs:label 'Flsa Relevance' ;
    rdfs:comment 'Indicates whether this credential is relevant to FLSA worker classification determinations (e.g., professional exemption credentials like CPA, PE, RN may support exempt classification). Supports wage and hour compliance analysis.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:i9SupportingDoc rdf:type rdf:Property ;
    rdfs:label 'I9 Supporting Doc' ;
    rdfs:comment 'Indicates whether this credential type can serve as a supporting document for I-9 Employment Eligibility Verification (e.g., U.S. Passport, Permanent Resident Card, Employment Authorization Document). Drives I-9 document collection workflows during onboarding.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:immunizationType rdf:type rdf:Property ;
    rdfs:label 'Immunization Type' ;
    rdfs:comment 'For immunization credential types, specifies the vaccine or immunization name (e.g., Hepatitis B, MMR, TB Test, COVID-19, Influenza, Varicella). Null for non-immunization credentials. Required for healthcare staffing vertical compliance.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryVertical rdf:type rdf:Property ;
    rdfs:label 'Industry Vertical' ;
    rdfs:comment 'The staffing industry vertical for which this credential is applicable. Drives placement eligibility rules and compliance checks by vertical. [ENUM-REF-CANDIDATE: healthcare|information_technology|skilled_trades|finance|government|general|education|energy|legal|manufacturing — promote to reference product]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExpirable rdf:type rdf:Property ;
    rdfs:label 'Is Expirable' ;
    rdfs:comment 'Indicates whether this credential type has an expiration date. When True, candidate credential instances must track expiration and renewal. When False, the credential is considered permanent once earned (e.g., some degree-based certifications). Drives renewal workflow triggers.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPlacementMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Placement Mandatory' ;
    rdfs:comment 'Indicates whether possession of this credential is a mandatory prerequisite for placement eligibility in the applicable industry vertical or job type. When True, candidates without a valid instance of this credential cannot be submitted or placed. Drives automated compliance gates in the ATS and VMS.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Name of the organization, agency, or body that issues this credential (e.g., State Board of Nursing, OSHA, PMI, CompTIA, IRS, Department of Transportation). Critical for verification routing and compliance validation.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingCountry rdf:type rdf:Property ;
    rdfs:label 'Issuing Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the country in which this credential is issued and recognized (e.g., USA, CAN, GBR). Supports international staffing operations and GDPR/CCPA compliance scoping.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Issuing State Province' ;
    rdfs:comment 'Two-letter state or province code where this credential is issued and valid (e.g., CA, NY, TX). Applicable for state-specific professional licenses (e.g., state nursing licenses, state CPA licenses, state CDL). Null for nationally or internationally recognized credentials.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseNumberFormat rdf:type rdf:Property ;
    rdfs:label 'License Number Format' ;
    rdfs:comment 'Regular expression or format pattern that defines the valid format for license or certification numbers issued under this credential type (e.g., ^RN[0-9]{6}$ for a state nursing license). Used for data validation when candidates enter their credential instance details.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaStandardRef rdf:type rdf:Property ;
    rdfs:label 'Osha Standard Ref' ;
    rdfs:comment 'For safety certifications, the specific OSHA standard or regulation that mandates or governs this credential (e.g., 29 CFR 1926.503 for fall protection, 29 CFR 1910.120 for HAZWOPER). Null for non-safety credentials. Supports OSHA compliance reporting.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redeploymentEligible rdf:type rdf:Property ;
    rdfs:label 'Redeployment Eligible' ;
    rdfs:comment 'Indicates whether a valid instance of this credential contributes to a candidates eligibility for redeployment to a new assignment without re-credentialing. Supports the redeployment workflow in the placement domain.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Cycle Months' ;
    rdfs:comment 'Standard renewal period for this credential expressed in months (e.g., 12 for annual, 24 for biennial, 36 for triennial). Null if the credential does not expire. Used to calculate expected renewal dates and trigger advance notification workflows. Satisfies MASTER_RESOURCE MEASUREMENT_OR_VALUE category.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'The date on which this credential definition was retired or deprecated from the Staffing Hr catalog. Null if the credential is still active. Retained for historical reference and audit trail purposes.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'More granular classification within the credential category (e.g., within license: nursing, engineering, financial, transportation; within certification: project management, IT, healthcare). Enables fine-grained filtering and reporting across staffing verticals.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'The required method for verifying this credential type. Primary source verification contacts the issuing authority directly (required for healthcare licenses). Document review accepts copies of certificates. Third-party uses services like Sterling Background Check. Self-attestation accepts candidate declaration. Automated uses API-based verification.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationSource rdf:type rdf:Property ;
    rdfs:label 'Verification Source' ;
    rdfs:comment 'The specific system, database, or service used to verify this credential (e.g., Sterling Background Check, NURSYS National Nurse License Verification, SAM.gov Exclusions, State DOT CDL Database, FINRA BrokerCheck). Informs the verification workflow routing.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialDocumentId rdf:type rdf:Property ;
    rdfs:label 'Credential Document Id' ;
    rdfs:comment 'Foreign key linking to credentialing.credential_document. Business justification: A credential instance (e.g., RN license held by candidate) should reference the primary supporting document (e.g., scanned license PDF). This creates a direct link from the credential instance to its ' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CredentialDocument .

ind:alertThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold Days' ;
    rdfs:comment 'The number of days before expiration at which automated renewal alerts should be triggered for this credential instance. Allows per-credential override of the default system alert threshold to accommodate varying renewal lead times by credential type.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bgcResult rdf:type rdf:Property ;
    rdfs:label 'Bgc Result' ;
    rdfs:comment 'The adjudicated result of the background check from Sterling BGC. Clear = no disqualifying findings; Consider = findings requiring individualized assessment per FCRA adverse action rules; Adverse = disqualifying finding. Applicable only when credential_category = background_check.' ;
    rdfs:domain ind:CredentialInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceuCompleted rdf:type rdf:Property ;
    rdfs:label 'Ceu Completed' ;
    rdfs:comment 'The number of Continuing Education Units (CEUs) or contact hours the candidate has completed toward the current renewal cycle requirement. Compared against ceu_required to determine renewal readiness.' ;
    rdfs:domain ind:CredentialInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearanceGrantingAgency rdf:type rdf:Property ;
    rdfs:label 'Clearance Granting Agency' ;
    rdfs:comment 'The U.S. government agency that granted the security clearance (e.g., DoD, DHS, CIA, NSA). Applicable only when credential_category = security_clearance. Required for government contract staffing compliance.' ;
    rdfs:domain ind:CredentialInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialCategory rdf:type rdf:Property ;
    rdfs:label 'Credential Category' ;
    rdfs:comment 'High-level classification of the credential type for reporting and eligibility filtering. Drives specialized attribute applicability (e.g., titer results for immunizations, clearance level for security clearances). [ENUM-REF-CANDIDATE: license|certification|background_check|drug_screen|immunization|security_clearance|training|assessment|education — promote to reference product]' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysUntilExpiration rdf:type rdf:Property ;
    rdfs:label 'Days Until Expiration' ;
    rdfs:comment 'Calculated number of calendar days remaining until this credential expires as of the last refresh. Stored for alerting threshold comparisons and dashboard KPI reporting without requiring real-time date arithmetic. Negative values indicate already-expired credentials.' ;
    rdfs:domain ind:CredentialInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'Secure URL or storage path to the scanned or digital copy of the credential document (certificate, license card, BGC report, immunization record) stored in the document management system. Access is role-restricted per SOC 2 Type II controls.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationType rdf:type rdf:Property ;
    rdfs:label 'Investigation Type' ;
    rdfs:comment 'The type of background investigation conducted for the security clearance (e.g., NACLC, SSBI, Tier 1-5). Applicable only when credential_category = security_clearance. Determines depth of vetting and clearance eligibility.' ;
    rdfs:domain ind:CredentialInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPlacementEligible rdf:type rdf:Property ;
    rdfs:label 'Is Placement Eligible' ;
    rdfs:comment 'Indicates whether this credential instance currently satisfies placement eligibility requirements. Computed and stored as an operational flag to enable fast eligibility gate checks in the Bullhorn ATS without real-time recalculation. True = eligible; False = ineligible.' ;
    rdfs:domain ind:CredentialInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Indicates whether this is the primary active instance of this credential type for the candidate when multiple instances exist (e.g., multi-state licenses, renewed credentials with overlapping validity). True = primary instance used for eligibility checks.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Name' ;
    rdfs:comment 'The name of the organization, government body, or professional association that issued this credential (e.g., State of California Board of Registered Nursing, OSHA Training Institute, PMI, DOT). Used for primary source verification routing.' ;
    rdfs:domain ind:CredentialInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingState rdf:type rdf:Property ;
    rdfs:label 'Issuing State' ;
    rdfs:comment 'The U.S. state (two-letter USPS abbreviation) or country subdivision in which this credential was issued. Critical for multi-state license portability analysis and compact license determinations (e.g., Nurse Licensure Compact).' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'The manufacturer lot number of the vaccine administered for immunization credentials. Applicable only when credential_category = immunization. Required for healthcare facility compliance documentation and adverse event tracking.' ;
    rdfs:domain ind:CredentialInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newExpirationDate rdf:type rdf:Property ;
    rdfs:label 'New Expiration Date' ;
    rdfs:comment 'The updated expiration date assigned to this credential instance upon successful renewal approval. Populated when renewal_status = approved. Replaces the prior expiration_date for ongoing validity tracking.' ;
    rdfs:domain ind:CredentialInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:polygraphCompleted rdf:type rdf:Property ;
    rdfs:label 'Polygraph Completed' ;
    rdfs:comment 'Indicates whether a polygraph examination was completed as part of the security clearance investigation. Applicable only when credential_category = security_clearance. Required for TS/SCI and certain agency-specific clearances.' ;
    rdfs:domain ind:CredentialInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalApplicationDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Application Date' ;
    rdfs:comment 'The date on which the candidate or staffing coordinator initiated the renewal application with the issuing authority. Marks the start of the renewal lifecycle and is used to calculate renewal processing lead time.' ;
    rdfs:domain ind:CredentialInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Renewal Authority Name' ;
    rdfs:comment 'The name of the organization or body responsible for processing the credential renewal (may differ from the original issuing authority in cases of delegated renewal processing).' ;
    rdfs:domain ind:CredentialInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Renewal Fee Amount' ;
    rdfs:comment 'The monetary fee charged by the issuing authority for processing the credential renewal. Used for cost tracking, candidate reimbursement workflows, and workforce program budgeting.' ;
    rdfs:domain ind:CredentialInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalFeePaidBy rdf:type rdf:Property ;
    rdfs:label 'Renewal Fee Paid By' ;
    rdfs:comment 'Indicates which party is responsible for paying the credential renewal fee. Drives accounts payable routing and candidate reimbursement processing in Oracle NetSuite ERP.' ;
    rdfs:domain ind:CredentialInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Current state of the credential renewal lifecycle for this instance. Drives renewal workflow routing and compliance alerting. Pending_documentation indicates the candidate must supply additional materials before the renewal authority can process the application.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Submission Date' ;
    rdfs:comment 'The date on which the completed renewal application and supporting documentation were formally submitted to the issuing authority. Distinct from renewal_application_date (initiation) — this is the official submission date.' ;
    rdfs:domain ind:CredentialInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:titerResult rdf:type rdf:Property ;
    rdfs:label 'Titer Result' ;
    rdfs:comment 'The quantitative titer test result indicating immunity level for immunization credentials (e.g., 1:8 positive for Hepatitis B). Applicable only when credential_category = immunization. Required for healthcare staffing placements in clinical settings.' ;
    rdfs:domain ind:CredentialInstance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'The name or system identifier of the person or automated process that performed the most recent verification of this credential. Supports audit trail and accountability requirements for credentialing compliance reviews.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualTurnaroundHours rdf:type rdf:Property ;
    rdfs:label 'Actual Turnaround Hours' ;
    rdfs:comment 'The actual number of hours elapsed from order placement to completion of the background check. Compared against sla_turnaround_hours to assess vendor SLA compliance and Time to Fill (TTF) impact.' ;
    rdfs:domain ind:BgcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjudicationStatus rdf:type rdf:Property ;
    rdfs:label 'Adjudication Status' ;
    rdfs:comment 'The hiring decision outcome based on the background check results. clear = no disqualifying findings; consider = findings require review; adverse_action_initiated = pre-adverse action notice sent to candidate; adverse_action_final = final adverse action taken; withdrawn = adjudication process stopped.' ;
    rdfs:domain ind:BgcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adverseActionNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Adverse Action Notice Date' ;
    rdfs:comment 'The date the pre-adverse action notice was sent to the candidate, as required by FCRA when a hiring decision is being made based on background check findings. Null if no adverse action was initiated.' ;
    rdfs:domain ind:BgcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientPackageCode rdf:type rdf:Property ;
    rdfs:label 'Client Package Code' ;
    rdfs:comment 'Client-specific package code or identifier that maps to the clients required screening package as defined in their VMS program or MSA. Used when client mandates a specific vendor package configuration.' ;
    rdfs:domain ind:BgcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientRequired rdf:type rdf:Property ;
    rdfs:label 'Client Required' ;
    rdfs:comment 'Indicates whether this background check was mandated by the client as a condition of placement, as specified in the clients Master Service Agreement (MSA) or program requirements.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:completedDate rdf:type rdf:Property ;
    rdfs:label 'Completed Date' ;
    rdfs:comment 'The date and time the background check order was fully completed and results were received from the screening vendor.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'The date the candidate provided written authorization for the background check. Required for FCRA compliance documentation.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentObtained rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained' ;
    rdfs:comment 'Indicates whether the candidate has provided written authorization for the background check to be conducted, as required by FCRA before a consumer report may be procured.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditCheckResult rdf:type rdf:Property ;
    rdfs:label 'Credit Check Result' ;
    rdfs:comment 'Result of the credit history check component, typically ordered for finance, accounting, or fiduciary roles. Governed by FCRA permissible purpose requirements. Classified confidential due to sensitive financial history.' ;
    rdfs:domain ind:BgcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criminalCheckResult rdf:type rdf:Property ;
    rdfs:label 'Criminal Check Result' ;
    rdfs:comment 'Result of the criminal history check component, covering county, state, and federal criminal records searches. consider indicates reportable criminal records were found per FCRA guidelines.' ;
    rdfs:domain ind:BgcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Initiated Date' ;
    rdfs:comment 'The date the candidate formally initiated a dispute of the background check results with the screening vendor or consumer reporting agency, as permitted under FCRA. Null if no dispute was filed.' ;
    rdfs:domain ind:BgcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'The date the candidates dispute was resolved by the screening vendor. Null if no dispute was filed or if dispute is still pending.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drugScreenResult rdf:type rdf:Property ;
    rdfs:label 'Drug Screen Result' ;
    rdfs:comment 'Result of the drug screening component. negative = no substances detected; positive = prohibited substance detected; dilute = specimen did not meet concentration thresholds; cancelled = specimen could not be tested.' ;
    rdfs:domain ind:BgcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:educationVerificationResult rdf:type rdf:Property ;
    rdfs:label 'Education Verification Result' ;
    rdfs:comment 'Result of the education credential verification component, confirming degrees, diplomas, and certifications as reported by the candidate.' ;
    rdfs:domain ind:BgcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentVerificationResult rdf:type rdf:Property ;
    rdfs:label 'Employment Verification Result' ;
    rdfs:comment 'Result of the employment history verification component, confirming prior employer details, dates of employment, and job titles as reported by the candidate.' ;
    rdfs:domain ind:BgcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalAdverseActionDate rdf:type rdf:Property ;
    rdfs:label 'Final Adverse Action Date' ;
    rdfs:comment 'The date the final adverse action decision was communicated to the candidate, following the mandatory waiting period after the pre-adverse action notice. Null if adverse action was not finalized.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mvrResult rdf:type rdf:Property ;
    rdfs:label 'Mvr Result' ;
    rdfs:comment 'Result of the motor vehicle record check component, ordered for roles requiring driving. Evaluates license validity, violations, and suspensions.' ;
    rdfs:domain ind:BgcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oigExclusionCheckResult rdf:type rdf:Property ;
    rdfs:label 'Oig Exclusion Check Result' ;
    rdfs:comment 'Result of the OIG exclusion list check, required for healthcare staffing placements to ensure the candidate is not excluded from participation in federal healthcare programs (Medicare, Medicaid).' ;
    rdfs:domain ind:BgcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'The date and time the background check order was placed with the screening vendor. Represents the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Human-readable, externally-known business identifier for this background check order, used in communications with the candidate, client, and screening vendor.' ;
    rdfs:domain ind:BgcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the background check order. ordered = submitted to vendor; in_progress = vendor is processing; completed = results received; disputed = candidate has filed a dispute; cancelled = order voided before completion.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderedByUser rdf:type rdf:Property ;
    rdfs:label 'Ordered By User' ;
    rdfs:comment 'The internal Staffing Hr user (recruiter, coordinator, or compliance officer) who initiated and submitted the background check order. Used for audit trail and accountability.' ;
    rdfs:domain ind:BgcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallResult rdf:type rdf:Property ;
    rdfs:label 'Overall Result' ;
    rdfs:comment 'The consolidated result returned by the screening vendor summarizing all checks in the package. clear = all checks passed; consider = one or more checks returned findings requiring review; suspended = check could not be completed.' ;
    rdfs:domain ind:BgcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'The screening package ordered, defining the scope of checks included. Common packages include criminal, employment verification, education verification, drug screen, credit check, and motor vehicle record (MVR). [ENUM-REF-CANDIDATE: criminal_only|employment_verification|education_verification|drug_screen|credit_check|mvr|criminal_plus_employment|comprehensive — promote to reference product]' ;
    rdfs:domain ind:BgcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionType rdf:type rdf:Property ;
    rdfs:label 'Position Type' ;
    rdfs:comment 'The employment classification of the position for which the background check was ordered. Determines applicable screening requirements and regulatory obligations (e.g., W-2 vs 1099, co-employment considerations).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportUrl rdf:type rdf:Property ;
    rdfs:label 'Report Url' ;
    rdfs:comment 'Secure URL or document reference to the full background check report stored in the Sterling portal or Staffing Hr document management system. Access is restricted to authorized compliance and HR personnel. Classified confidential due to sensitive screening results.' ;
    rdfs:domain ind:BgcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningType rdf:type rdf:Property ;
    rdfs:label 'Screening Type' ;
    rdfs:comment 'Classification of when and why the background check is being conducted in the employment lifecycle. Pre-employment and post-offer are most common; annual, random, and reasonable suspicion apply to ongoing workforce compliance programs.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sexOffenderRegistryResult rdf:type rdf:Property ;
    rdfs:label 'Sex Offender Registry Result' ;
    rdfs:comment 'Result of the national sex offender registry check component. Particularly required for placements in healthcare, education, childcare, and other vulnerable population settings.' ;
    rdfs:domain ind:BgcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMet rdf:type rdf:Property ;
    rdfs:label 'Sla Met' ;
    rdfs:comment 'Indicates whether the background check order was completed within the contracted SLA turnaround time. Derived operationally from comparing actual_turnaround_hours to sla_turnaround_hours; stored for reporting and vendor scorecard purposes.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTurnaroundHours rdf:type rdf:Property ;
    rdfs:label 'Sla Turnaround Hours' ;
    rdfs:comment 'The contracted or expected turnaround time in hours for the background check order to be completed, as defined in the SLA with the screening vendor. Used to measure vendor performance against KPIs.' ;
    rdfs:domain ind:BgcOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sterlingOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sterling Order Number' ;
    rdfs:comment 'External order identifier assigned by Sterling Background Check system upon order submission. Used for cross-referencing and status lookups in the Sterling vendor portal.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bgcResultId rdf:type rdf:Property ;
    rdfs:label 'Bgc Result Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual background check component result record. Entity role: TRANSACTION_LINE — each bgc_result is one component line within a parent bgc_order screening event.' ;
    rdfs:domain ind:BgcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjudicationDecision rdf:type rdf:Property ;
    rdfs:label 'Adjudication Decision' ;
    rdfs:comment 'The internal hiring team or compliance officer adjudication decision applied to this result component after reviewing findings. Distinct from the vendor-returned result_status — this is the employers individualized assessment per EEOC guidance.' ;
    rdfs:domain ind:BgcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adverseActionFlag rdf:type rdf:Property ;
    rdfs:label 'Adverse Action Flag' ;
    rdfs:comment 'Indicates whether this result component triggered or contributed to an adverse action (pre-adverse or final adverse) against the candidate. Required for FCRA adverse action workflow tracking and compliance reporting.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checkComponentType rdf:type rdf:Property ;
    rdfs:label 'Check Component Type' ;
    rdfs:comment 'The type of screening component this result record represents. Drives which component-specific extended attributes are populated. [ENUM-REF-CANDIDATE: criminal_search|employment_verification|education_verification|reference_check|drug_screen|credit_check|mvr|sex_offender_registry|global_watchlist — promote to reference product]' ;
    rdfs:domain ind:BgcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionDate rdf:type rdf:Property ;
    rdfs:label 'Collection Date' ;
    rdfs:comment 'The date the drug screen specimen was collected from the candidate. Populated only when check_component_type = drug_screen. Used for chain-of-custody and turnaround time tracking.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collectionSite rdf:type rdf:Property ;
    rdfs:label 'Collection Site' ;
    rdfs:comment 'Name or identifier of the collection facility where the drug screen specimen was collected. Populated only when check_component_type = drug_screen. Used for chain-of-custody tracking.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:degreeType rdf:type rdf:Property ;
    rdfs:label 'Degree Type' ;
    rdfs:comment 'The type of academic degree or credential being verified for the education verification component. Populated only when check_component_type = education_verification. [ENUM-REF-CANDIDATE: high_school|associate|bachelor|master|doctorate|certificate|professional|other — promote to reference product]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyFoundFlag rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Found Flag' ;
    rdfs:comment 'Indicates whether a discrepancy was identified between the candidates stated information and the verified information for employment or education verification components. Triggers adjudication review when true.' ;
    rdfs:domain ind:BgcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dotRegulatedFlag rdf:type rdf:Property ;
    rdfs:label 'Dot Regulated Flag' ;
    rdfs:comment 'Indicates whether this check component is subject to U.S. Department of Transportation (DOT) regulations. Applicable primarily to drug screens and MVR checks for safety-sensitive transportation positions.' ;
    rdfs:domain ind:BgcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drugPanelType rdf:type rdf:Property ;
    rdfs:label 'Drug Panel Type' ;
    rdfs:comment 'The drug testing panel configuration used for this drug screen component. Specifies the number and types of substances tested. Populated only when check_component_type = drug_screen.' ;
    rdfs:domain ind:BgcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:educationVerificationSource rdf:type rdf:Property ;
    rdfs:label 'Education Verification Source' ;
    rdfs:comment 'The method or source used to verify the education credential. NSC = National Student Clearinghouse; direct_institution = contacted school registrar directly; third_party = alternate verification service. Populated only when check_component_type = education_verification.' ;
    rdfs:domain ind:BgcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerName rdf:type rdf:Property ;
    rdfs:label 'Employer Name' ;
    rdfs:comment 'Name of the employer whose employment record is being verified. Populated only when check_component_type = employment_verification.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Employment End Date' ;
    rdfs:comment 'The verified end date of the candidates employment with the employer being checked. Null if currently employed. Populated only when check_component_type = employment_verification.' ;
    rdfs:domain ind:BgcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Employment Start Date' ;
    rdfs:comment 'The verified start date of the candidates employment with the employer being checked. Populated only when check_component_type = employment_verification.' ;
    rdfs:domain ind:BgcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employmentVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Employment Verification Method' ;
    rdfs:comment 'The method used to verify employment history. direct = employer contacted directly; the_work_number = Equifax The Work Number automated service; equifax = Equifax employment data; third_party = other verification service. Populated only when check_component_type = employment_verification.' ;
    rdfs:domain ind:BgcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fcraCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Fcra Compliant Flag' ;
    rdfs:comment 'Indicates whether all FCRA procedural requirements were satisfied for this result component, including permissible purpose, disclosure, authorization, and adverse action notice obligations.' ;
    rdfs:domain ind:BgcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fieldOfStudy rdf:type rdf:Property ;
    rdfs:label 'Field Of Study' ;
    rdfs:comment 'The academic major, concentration, or field of study associated with the degree being verified. Populated only when check_component_type = education_verification.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDate rdf:type rdf:Property ;
    rdfs:label 'Finding Date' ;
    rdfs:comment 'The date associated with the derogatory finding (e.g., date of criminal offense, date of driving violation). Used for look-back period analysis and individualized assessment under EEOC guidance.' ;
    rdfs:domain ind:BgcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingDetail rdf:type rdf:Property ;
    rdfs:label 'Finding Detail' ;
    rdfs:comment 'Narrative description of the specific finding or derogatory information returned by the screening vendor for this component. Populated only when result_status is consider or adverse. Confidential — used by adjudicators and compliance officers only.' ;
    rdfs:domain ind:BgcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:graduationDate rdf:type rdf:Property ;
    rdfs:label 'Graduation Date' ;
    rdfs:comment 'The date the candidate graduated or completed the degree program being verified. Populated only when check_component_type = education_verification.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:institutionName rdf:type rdf:Property ;
    rdfs:label 'Institution Name' ;
    rdfs:comment 'Name of the educational institution whose degree or credential is being verified. Populated only when check_component_type = education_verification.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionSearched rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Searched' ;
    rdfs:comment 'The county, state, or geographic jurisdiction in which this check component was conducted. Relevant for criminal searches, sex offender registry, and MVR checks. Format: County, State or state abbreviation for statewide searches.' ;
    rdfs:domain ind:BgcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labProcessingDate rdf:type rdf:Property ;
    rdfs:label 'Lab Processing Date' ;
    rdfs:comment 'The date the laboratory completed initial analysis of the drug screen specimen. Populated only when check_component_type = drug_screen. Used for TAT measurement between collection and lab result.' ;
    rdfs:domain ind:BgcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mroDecision rdf:type rdf:Property ;
    rdfs:label 'Mro Decision' ;
    rdfs:comment 'The final verified result determination issued by the Medical Review Officer (MRO) after reviewing the laboratory result and any candidate explanation. This is the authoritative drug screen outcome. [ENUM-REF-CANDIDATE: negative|positive|dilute_negative|dilute_positive|substituted|adulterated|cancelled — promote to reference product]' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mroReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Mro Review Status' ;
    rdfs:comment 'Current status of the Medical Review Officer (MRO) review for this drug screen result. MRO review is required for all DOT-regulated tests and non-negative results. Populated only when check_component_type = drug_screen.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ordered Timestamp' ;
    rdfs:comment 'The date and time this specific check component was ordered from the screening vendor. Used to calculate component-level turnaround time.' ;
    rdfs:domain ind:BgcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:overallRecommendation rdf:type rdf:Property ;
    rdfs:label 'Overall Recommendation' ;
    rdfs:comment 'The reference contacts overall recommendation rating for the candidate as captured in the structured reference check interview. Populated only when check_component_type = reference_check.' ;
    rdfs:domain ind:BgcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preAdverseActionDate rdf:type rdf:Property ;
    rdfs:label 'Pre Adverse Action Date' ;
    rdfs:comment 'Date the pre-adverse action notice was sent to the candidate as required by FCRA before a final adverse employment decision is made. Mandatory waiting period tracking starts from this date.' ;
    rdfs:domain ind:BgcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referenceContactName rdf:type rdf:Property ;
    rdfs:label 'Reference Contact Name' ;
    rdfs:comment 'Full name of the professional reference contact interviewed for this reference check component. PII — restricted access. Populated only when check_component_type = reference_check.' ;
    rdfs:domain ind:BgcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceRelationship rdf:type rdf:Property ;
    rdfs:label 'Reference Relationship' ;
    rdfs:comment 'The professional relationship of the reference contact to the candidate. Used to assess the credibility and relevance of the reference feedback. Populated only when check_component_type = reference_check.' ;
    rdfs:domain ind:BgcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rehireEligibility rdf:type rdf:Property ;
    rdfs:label 'Rehire Eligibility' ;
    rdfs:comment 'The reference contacts stated eligibility recommendation for rehiring the candidate. A key structured rating from the reference check interview. Populated only when check_component_type = reference_check.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Result Received Timestamp' ;
    rdfs:comment 'The date and time this component result was received from the screening vendor (Sterling or alternate). Used for turnaround time (TAT) measurement and SLA compliance tracking.' ;
    rdfs:domain ind:BgcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resultStatus rdf:type rdf:Property ;
    rdfs:label 'Result Status' ;
    rdfs:comment 'The overall outcome status of this check component as returned by the screening vendor. clear = no derogatory findings; consider = findings present requiring adjudication review; adverse = disqualifying finding; pending = result not yet received; cancelled = component cancelled before completion.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenType rdf:type rdf:Property ;
    rdfs:label 'Specimen Type' ;
    rdfs:comment 'The biological specimen type collected for drug screen testing. Populated only when check_component_type = drug_screen. Urine is the standard DOT-mandated specimen type.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sterlingResultNumber rdf:type rdf:Property ;
    rdfs:label 'Sterling Result Number' ;
    rdfs:comment 'External component-level result identifier assigned by Sterling or the screening vendor. Used for vendor-side traceability and dispute resolution.' ;
    rdfs:domain ind:BgcResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substancesDetected rdf:type rdf:Property ;
    rdfs:label 'Substances Detected' ;
    rdfs:comment 'Comma-separated list of substance names or drug classes detected in the drug screen specimen as reported by the MRO. Populated only when mro_decision is positive. Confidential — restricted to compliance and HR personnel.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentScreenDrugScreenId rdf:type rdf:Property ;
    rdfs:label 'Parent Screen Drug Screen Id' ;
    rdfs:comment 'Reference to the original drug screen record when this record represents a recollection or follow-up screen. Enables lineage tracking between an initial screen and any subsequent recollections ordered due to dilute, adulterated, or cancelled results.' ;
    rdfs:domain ind:DrugScreen ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrugScreen .

ind:candidateConsentObtained rdf:type rdf:Property ;
    rdfs:label 'Candidate Consent Obtained' ;
    rdfs:comment 'Indicates whether the candidate provided written authorization and consent for the drug screen prior to specimen collection. Required under FCRA for background screening and state-specific drug testing consent laws.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chainOfCustodyNumber rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Number' ;
    rdfs:comment 'Unique chain-of-custody form number assigned at the time of specimen collection. The COC number tracks the specimen from collection through laboratory analysis and is required for DOT-regulated and legally defensible drug testing programs.' ;
    rdfs:domain ind:DrugScreen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionSiteCity rdf:type rdf:Property ;
    rdfs:label 'Collection Site City' ;
    rdfs:comment 'City where the specimen collection site is located. Supports geographic coverage analysis and candidate convenience reporting.' ;
    rdfs:domain ind:DrugScreen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionSiteCode rdf:type rdf:Property ;
    rdfs:label 'Collection Site Code' ;
    rdfs:comment 'Unique identifier for the collection site as assigned by Sterling Background Check or the collection network provider. Enables site-level performance and compliance reporting.' ;
    rdfs:domain ind:DrugScreen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionSiteName rdf:type rdf:Property ;
    rdfs:label 'Collection Site Name' ;
    rdfs:comment 'Name of the collection facility or clinic where the specimen was collected from the candidate. Used for vendor management, geographic coverage analysis, and chain-of-custody documentation.' ;
    rdfs:domain ind:DrugScreen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionSiteState rdf:type rdf:Property ;
    rdfs:label 'Collection Site State' ;
    rdfs:comment 'U.S. state (two-letter abbreviation) where the specimen collection site is located. Used for state-specific compliance reporting and geographic coverage analysis.' ;
    rdfs:domain ind:DrugScreen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Collection Timestamp' ;
    rdfs:comment 'Precise date and time at which the specimen was collected from the candidate. Required for DOT-regulated screenings and chain-of-custody documentation.' ;
    rdfs:domain ind:DrugScreen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:diluteResultAction rdf:type rdf:Property ;
    rdfs:label 'Dilute Result Action' ;
    rdfs:comment 'Action taken or required when a specimen is reported as dilute. Under DOT regulations, employers may require a second collection under direct observation for dilute results. Non-DOT programs follow client-specific policies. Populated only when result_status is dilute.' ;
    rdfs:domain ind:DrugScreen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotAgency rdf:type rdf:Property ;
    rdfs:label 'Dot Agency' ;
    rdfs:comment 'The specific DOT modal agency whose regulations govern this drug screen when is_dot_regulated is true. Federal Motor Carrier Safety Administration (FMCSA) applies to CDL drivers; Federal Aviation Administration (FAA) to aviation; Federal Railroad Administration (FRA) to rail; Federal Transit Administration (FTA) to transit; Pipeline and Hazardous Materials Safety Administration (PHMSA) to pipeline workers. [ENUM-REF-CANDIDATE: FMCSA|FAA|FRA|FTA|PHMSA|USCG|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DrugScreen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDotRegulated rdf:type rdf:Property ;
    rdfs:label 'Is Dot Regulated' ;
    rdfs:comment 'Indicates whether this drug screen is subject to U.S. Department of Transportation (DOT) regulations under 49 CFR Part 40. DOT-regulated screens apply to safety-sensitive transportation positions (CDL drivers, aviation, rail, pipeline, transit). Non-DOT screens follow SAMHSA guidelines but without federal mandate.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isObservedCollection rdf:type rdf:Property ;
    rdfs:label 'Is Observed Collection' ;
    rdfs:comment 'Indicates whether the specimen collection was conducted under direct observation by a trained collector. Observed collections are required under DOT regulations for return-to-duty, follow-up, and certain dilute recollection scenarios.' ;
    rdfs:domain ind:DrugScreen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Lab Received Date' ;
    rdfs:comment 'Date on which the specimen was received by the testing laboratory for processing. Used to measure lab turnaround time and identify chain-of-custody gaps.' ;
    rdfs:domain ind:DrugScreen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labReportedDate rdf:type rdf:Property ;
    rdfs:label 'Lab Reported Date' ;
    rdfs:comment 'Date on which the laboratory reported the initial test result to the Medical Review Officer (MRO) or directly to the ordering party. Supports turnaround time SLA measurement.' ;
    rdfs:domain ind:DrugScreen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:laboratoryName rdf:type rdf:Property ;
    rdfs:label 'Laboratory Name' ;
    rdfs:comment 'Name of the SAMHSA-certified laboratory that processed and analyzed the specimen. Required for chain-of-custody documentation and regulatory audit trails.' ;
    rdfs:domain ind:DrugScreen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mroDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Mro Decision Date' ;
    rdfs:comment 'Date on which the MRO issued the final verified result decision. Used to measure MRO review turnaround time and for compliance audit documentation.' ;
    rdfs:domain ind:DrugScreen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mroName rdf:type rdf:Property ;
    rdfs:label 'Mro Name' ;
    rdfs:comment 'Full name of the licensed physician serving as the Medical Review Officer for this drug screen. Required for DOT compliance documentation and chain-of-custody records.' ;
    rdfs:domain ind:DrugScreen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passFailDetermination rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Determination' ;
    rdfs:comment 'Business-level pass or fail determination applied by the staffing firm based on the MRO decision and client-specific drug testing policy. A negative MRO decision typically results in pass; positive results in fail. Inconclusive applies when the result requires further review or recollection.' ;
    rdfs:domain ind:DrugScreen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recollectionRequired rdf:type rdf:Property ;
    rdfs:label 'Recollection Required' ;
    rdfs:comment 'Indicates whether a second specimen collection is required due to a dilute, adulterated, substituted, or cancelled result. Triggers a follow-up screening workflow in the credentialing process.' ;
    rdfs:domain ind:DrugScreen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resultDate rdf:type rdf:Property ;
    rdfs:label 'Result Date' ;
    rdfs:comment 'Date on which the final verified result was reported and made available to the staffing firm. Represents the completion of the screening lifecycle.' ;
    rdfs:domain ind:DrugScreen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:screenOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Screen Order Number' ;
    rdfs:comment 'Externally-known order number assigned by Sterling Background Check for this drug screening event. Used for vendor tracking, status inquiries, and reconciliation with Sterling invoices.' ;
    rdfs:domain ind:DrugScreen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenStatus rdf:type rdf:Property ;
    rdfs:label 'Screen Status' ;
    rdfs:comment 'Current lifecycle status of the drug screening event from order placement through final result delivery. Drives workflow routing and compliance tracking.' ;
    rdfs:domain ind:DrugScreen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundDays rdf:type rdf:Property ;
    rdfs:label 'Turnaround Days' ;
    rdfs:comment 'Number of calendar days elapsed from the specimen collection date to the final result date. Used to measure screening program efficiency, vendor SLA compliance, and impact on Time to Start (TTS) for placements.' ;
    rdfs:domain ind:DrugScreen ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adverseActionDate rdf:type rdf:Property ;
    rdfs:label 'Adverse Action Date' ;
    rdfs:comment 'Date on which the FCRA-required adverse action notification was sent to the candidate following an adverse verification outcome. Null if no adverse action was required. Required for FCRA compliance documentation.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billableToClient rdf:type rdf:Property ;
    rdfs:label 'Billable To Client' ;
    rdfs:comment 'Indicates whether the cost of this license verification is billable to the client as part of the staffing engagement or MSA terms. Supports accounts receivable and client billing workflows in Salesforce Revenue Cloud.' ;
    rdfs:domain ind:LicenseVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Client Required Flag' ;
    rdfs:comment 'Indicates whether this license verification was mandated by a specific clients credentialing requirements (e.g., hospital system, government agency) as opposed to being a standard internal credentialing policy check.' ;
    rdfs:domain ind:LicenseVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compactStates rdf:type rdf:Property ;
    rdfs:label 'Compact States' ;
    rdfs:comment 'Comma-separated list of two-letter state codes in which this compact license authorizes practice (e.g., CA,TX,FL,NY). Populated only when is_compact_license is True. Supports multi-state placement eligibility checks.' ;
    rdfs:domain ind:LicenseVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationAlertDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Alert Date' ;
    rdfs:comment 'Date on which the license expiration alert notification was sent to the candidate and/or credentialing team. Populated when expiration_alert_sent is True.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expirationAlertSent rdf:type rdf:Property ;
    rdfs:label 'Expiration Alert Sent' ;
    rdfs:comment 'Indicates whether an automated expiration alert notification has been sent to the candidate and/or credentialing team ahead of the license expiration date. Prevents duplicate alert sends and tracks notification compliance.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCompactLicense rdf:type rdf:Property ;
    rdfs:label 'Is Compact License' ;
    rdfs:comment 'Indicates whether the license is issued under a multi-state compact agreement (e.g., Nurse Licensure Compact (NLC), Physical Therapy Compact). Compact licenses allow practice in multiple member states without separate licensure, which affects placement eligibility across state lines.' ;
    rdfs:domain ind:LicenseVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'License Expiration Date' ;
    rdfs:comment 'Date on which the license expires or must be renewed as recorded on the license or registry. Null for licenses with no expiration. Critical for expiration tracking and automated renewal alerts.' ;
    rdfs:domain ind:LicenseVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseHolderName rdf:type rdf:Property ;
    rdfs:label 'License Holder Name' ;
    rdfs:comment 'Full legal name of the individual as it appears on the license at the time of verification. Used to confirm name match between the candidate record and the registry entry. May differ from current candidate name due to legal name changes.' ;
    rdfs:domain ind:LicenseVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseIssueDate rdf:type rdf:Property ;
    rdfs:label 'License Issue Date' ;
    rdfs:comment 'Date the license was originally issued by the licensing authority. Used to calculate license tenure and assess experience level for credentialing compliance.' ;
    rdfs:domain ind:LicenseVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'The official license number as issued by the licensing authority (e.g., state nursing board, NASBA CPA registry, NCEES PE registry, DMV CDL number). This is the primary identifier submitted to the registry for verification lookup.' ;
    rdfs:domain ind:LicenseVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseRestrictions rdf:type rdf:Property ;
    rdfs:label 'License Restrictions' ;
    rdfs:comment 'Free-text description of any restrictions, conditions, or limitations noted on the license at the time of verification (e.g., Probationary - supervised practice only, Restricted to outpatient settings). Null if no restrictions apply.' ;
    rdfs:domain ind:LicenseVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseStatusAtVerification rdf:type rdf:Property ;
    rdfs:label 'License Status At Verification' ;
    rdfs:comment 'The status of the license as reported by the issuing authority or registry at the exact time of verification. Captures the point-in-time state independent of subsequent changes. Critical for compliance audit trails.' ;
    rdfs:domain ind:LicenseVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Next Verification Date' ;
    rdfs:comment 'The date on which this license must be re-verified per credentialing policy or client SLA requirements. Drives automated renewal alerts and compliance scheduling. Typically set based on license expiration date or periodic re-verification intervals.' ;
    rdfs:domain ind:LicenseVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recheckReason rdf:type rdf:Property ;
    rdfs:label 'Recheck Reason' ;
    rdfs:comment 'Reason code explaining why a recheck is required for this verification. Populated when recheck_required is True. Supports credentialing workflow prioritization and root cause analysis.' ;
    rdfs:domain ind:LicenseVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recheckRequired rdf:type rdf:Property ;
    rdfs:label 'Recheck Required' ;
    rdfs:comment 'Indicates whether this verification record requires a follow-up recheck due to an inconclusive result, registry unavailability, or pending license renewal. Drives credentialing workflow queues.' ;
    rdfs:domain ind:LicenseVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:staffingVertical rdf:type rdf:Property ;
    rdfs:label 'Staffing Vertical' ;
    rdfs:comment 'The staffing industry vertical for which this license verification is being performed. Determines applicable credentialing standards and regulatory requirements (e.g., Joint Commission for healthcare, OFCCP for government). [ENUM-REF-CANDIDATE: healthcare|information_technology|finance|government|skilled_trades|engineering|other — promote to reference product]' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationCost rdf:type rdf:Property ;
    rdfs:label 'Verification Cost' ;
    rdfs:comment 'The fee charged by the verification source or third-party provider (e.g., Sterling, Nursys) for performing this license verification. Used for credentialing cost tracking and client billing reconciliation.' ;
    rdfs:domain ind:LicenseVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'The calendar date on which the license verification was performed against the registry or source. This is the principal business event date for the verification transaction, distinct from the record creation timestamp.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationNotes rdf:type rdf:Property ;
    rdfs:label 'Verification Notes' ;
    rdfs:comment 'Free-text field for credentialing staff to record observations, discrepancies, follow-up actions, or contextual notes related to this verification (e.g., Name mismatch - candidate confirmed maiden name change, Registry temporarily unavailable - manual call to board completed).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationNumber rdf:type rdf:Property ;
    rdfs:label 'Verification Number' ;
    rdfs:comment 'Externally-known business identifier for this verification transaction, used in correspondence with candidates, clients, and licensing boards. Format: LV-{YYYY}-{sequence}.' ;
    rdfs:domain ind:LicenseVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationOutcome rdf:type rdf:Property ;
    rdfs:label 'Verification Outcome' ;
    rdfs:comment 'The result of the license verification process as determined by the verification source. verified means the license was confirmed active and valid; not_found means no matching record was located; other values reflect adverse findings. This is the primary lifecycle status of the verification transaction.' ;
    rdfs:domain ind:LicenseVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationSourceName rdf:type rdf:Property ;
    rdfs:label 'Verification Source Name' ;
    rdfs:comment 'Name of the specific registry, database, or organization used as the verification source (e.g., Nursys, NASBA CPA Verify, NCEES MyNCEES, California DMV, Sterling Background Check). Provides audit traceability to the exact source consulted.' ;
    rdfs:domain ind:LicenseVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationSourceUrl rdf:type rdf:Property ;
    rdfs:label 'Verification Source Url' ;
    rdfs:comment 'Web address of the registry or database used for verification (e.g., https://www.nursys.com). Supports audit documentation and re-verification by compliance staff.' ;
    rdfs:domain ind:LicenseVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone) when the verification query was executed against the source registry or system. Provides sub-day audit precision required for automated API verifications and SLA measurement.' ;
    rdfs:domain ind:LicenseVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:skillRequirementId rdf:type rdf:Property ;
    rdfs:label 'Skill Requirement Id' ;
    rdfs:comment 'Foreign key linking to joborder.skill_requirement. Business justification: Skills assessments validate candidates against specific skill requirements defined on a job order. Linking skills_assessment to skill_requirement enables pass/fail determination against the exact prof' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkillRequirement .

ind:accommodationNotes rdf:type rdf:Property ;
    rdfs:label 'Accommodation Notes' ;
    rdfs:comment 'Description of any ADA or other accommodations applied during the assessment. Classified as confidential due to sensitivity of disability-related information. Only populated when ada_accommodation_applied is true.' ;
    rdfs:domain ind:SkillsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adaAccommodationApplied rdf:type rdf:Property ;
    rdfs:label 'Ada Accommodation Applied' ;
    rdfs:comment 'Indicates whether an Americans with Disabilities Act (ADA) reasonable accommodation was applied during this assessment administration (e.g., extended time, alternative format). Required for EEOC and OFCCP compliance documentation.' ;
    rdfs:domain ind:SkillsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allottedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Allotted Duration Minutes' ;
    rdfs:comment 'The maximum time in minutes permitted for the candidate to complete the assessment as defined by the assessment instrument. Supports ADA accommodation tracking and time-limit compliance.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'The calendar date on which the skills assessment was administered to the candidate. Principal business event date for this transaction.' ;
    rdfs:domain ind:SkillsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assessment End Timestamp' ;
    rdfs:comment 'Precise date and time when the candidate completed or exited the skills assessment. Used alongside start timestamp to compute actual duration.' ;
    rdfs:domain ind:SkillsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assessmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Number' ;
    rdfs:comment 'Externally-known business identifier for this skills assessment record, used in candidate communications, recruiter workflows, and ATS tracking. Follows the format ASA-XXXXXXXXXX.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assessment Start Timestamp' ;
    rdfs:comment 'Precise date and time when the candidate began the skills assessment. Used for duration calculation and proctoring audit trails.' ;
    rdfs:domain ind:SkillsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current lifecycle state of the skills assessment record. Tracks progression from scheduling through completion or cancellation.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Classification of the assessment format administered to the candidate. Determines the evaluation methodology and scoring approach. [ENUM-REF-CANDIDATE: written_test|practical_evaluation|simulation|coding_challenge|trade_skills_test|behavioral_assessment|psychometric|situational_judgment — promote to reference product]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentVersion rdf:type rdf:Property ;
    rdfs:label 'Assessment Version' ;
    rdfs:comment 'The version or form identifier of the assessment instrument administered. Ensures score comparability over time as assessment content is updated by the provider.' ;
    rdfs:domain ind:SkillsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attemptNumber rdf:type rdf:Property ;
    rdfs:label 'Attempt Number' ;
    rdfs:comment 'Sequential attempt count for this candidate on this specific assessment. Tracks retake history and enforces maximum attempt policies per assessment provider or client requirements.' ;
    rdfs:domain ind:SkillsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryChannel rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel' ;
    rdfs:comment 'The method or channel through which the assessment was delivered to the candidate. Impacts proctoring requirements, result validity, and client acceptance criteria.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrentResult rdf:type rdf:Property ;
    rdfs:label 'Is Current Result' ;
    rdfs:comment 'Indicates whether this assessment record represents the most recent and active result for the candidate on this skill. Set to false for superseded attempts. Supports efficient querying of current credential status without full history scans.' ;
    rdfs:domain ind:SkillsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isProctored rdf:type rdf:Property ;
    rdfs:label 'Is Proctored' ;
    rdfs:comment 'Indicates whether the assessment was administered under supervised proctoring conditions (in-person or remote). Affects result credibility weighting and client acceptance of assessment outcomes.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'The language in which the assessment was administered, using ISO 639-1 or ISO 639-2 language codes (e.g., EN, ES, FR). Supports multilingual workforce programs and EEOC non-discrimination compliance.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxAttemptsAllowed rdf:type rdf:Property ;
    rdfs:label 'Max Attempts Allowed' ;
    rdfs:comment 'The maximum number of times a candidate is permitted to attempt this assessment before a waiting period or permanent disqualification applies. Enforced per assessment provider policy or client mandate.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxPossibleScore rdf:type rdf:Property ;
    rdfs:label 'Max Possible Score' ;
    rdfs:comment 'The highest achievable score on this assessment instrument. Required to compute score percentage and normalize results across different assessment providers and versions.' ;
    rdfs:domain ind:SkillsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passThreshold rdf:type rdf:Property ;
    rdfs:label 'Pass Threshold' ;
    rdfs:comment 'The minimum score required to achieve a passing result on this assessment. May be set by the staffing firm, client, or assessment provider. Used to determine pass/fail result status.' ;
    rdfs:domain ind:SkillsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passThresholdType rdf:type rdf:Property ;
    rdfs:label 'Pass Threshold Type' ;
    rdfs:comment 'Indicates whether the pass_threshold value is expressed as a raw score, a percentage, or a percentile rank. Required to correctly interpret and apply the threshold in result determination logic.' ;
    rdfs:domain ind:SkillsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:percentileRank rdf:type rdf:Property ;
    rdfs:label 'Percentile Rank' ;
    rdfs:comment 'The candidates performance relative to the normative population, expressed as a percentile (0-100). Indicates what percentage of the reference population scored at or below this candidate. Supports QoS (Quality of Submission) candidate ranking.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proficiencyLevel rdf:type rdf:Property ;
    rdfs:label 'Proficiency Level' ;
    rdfs:comment 'Qualitative proficiency tier assigned to the candidate based on their assessment score. Used for candidate ranking, job matching, and QoS reporting in recruiter workflows.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerAssessmentCode rdf:type rdf:Property ;
    rdfs:label 'Provider Assessment Code' ;
    rdfs:comment 'The external assessment product code or catalog identifier assigned by the assessment provider (e.g., Criteria Corp test ID, Wonderlic WPT-Q). Enables cross-referencing with provider platforms and normative databases.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerType rdf:type rdf:Property ;
    rdfs:label 'Provider Type' ;
    rdfs:comment 'Classification of the assessment provider as internal (staffing firm-administered), third-party vendor, client-mandated, or industry body. Affects scoring normalization and result validity rules.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rawScore rdf:type rdf:Property ;
    rdfs:label 'Raw Score' ;
    rdfs:comment 'The candidates actual numeric score as returned by the assessment instrument before normalization or scaling. Represents the principal quantitative result of the assessment event.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resultNotes rdf:type rdf:Property ;
    rdfs:label 'Result Notes' ;
    rdfs:comment 'Free-text notes entered by the recruiter or assessor regarding the assessment outcome, candidate performance observations, or any anomalies noted during administration. Supports qualitative context for QoS reporting.' ;
    rdfs:domain ind:SkillsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Name of the internal recruiter, credentialing specialist, or assessor who reviewed and validated the assessment result. Applicable for practical evaluations and trade skills tests requiring human judgment.' ;
    rdfs:domain ind:SkillsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorePercentage rdf:type rdf:Property ;
    rdfs:label 'Score Percentage' ;
    rdfs:comment 'The candidates score expressed as a percentage of the maximum possible score (raw_score / max_possible_score * 100). Enables standardized comparison across assessments with different scales.' ;
    rdfs:domain ind:SkillsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validityExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Validity Expiry Date' ;
    rdfs:comment 'The date on which the assessment result expires and the candidate must be reassessed to maintain qualification. Critical for credential expiration tracking and compliance with client or regulatory requirements.' ;
    rdfs:domain ind:SkillsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validityStartDate rdf:type rdf:Property ;
    rdfs:label 'Validity Start Date' ;
    rdfs:comment 'The date from which the assessment result is considered valid and can be used to qualify the candidate for job orders. Typically the assessment_date or the date of official result issuance.' ;
    rdfs:domain ind:SkillsAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignedBy rdf:type rdf:Property ;
    rdfs:label 'Assigned By' ;
    rdfs:comment 'Name or user identifier of the recruiter, compliance officer, or system process that assigned this training to the worker. Supports accountability and audit trail.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attemptsCount rdf:type rdf:Property ;
    rdfs:label 'Attempts Count' ;
    rdfs:comment 'Number of times the worker has attempted the training assessment or course. Used to enforce maximum attempt policies and identify workers needing additional support.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Unique certificate or credential number issued by the training provider upon successful completion. Used for verification, audit, and regulatory reporting.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateUrl rdf:type rdf:Property ;
    rdfs:label 'Certificate Url' ;
    rdfs:comment 'URL or file path to the digital copy of the training completion certificate stored in the document management system. Supports audit and verification workflows.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceuCreditsEarned rdf:type rdf:Property ;
    rdfs:label 'Ceu Credits Earned' ;
    rdfs:comment 'Number of Continuing Education Unit (CEU) credits awarded upon successful completion of the training. Relevant for professional license maintenance and credentialing requirements.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Date the worker successfully completed the training course. Null if not yet completed. Used as the primary business event timestamp for compliance certification.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Current lifecycle status of the training record indicating whether the worker has completed, is in progress, has not started, failed, had the requirement waived, or the training has expired. Core status field for compliance tracking.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseCode rdf:type rdf:Property ;
    rdfs:label 'Course Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the training course as defined in the LMS course catalog (e.g., OSHA-10, HIPAA-101, HARASS-PREV-01). Used as the business identifier for the course.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseName rdf:type rdf:Property ;
    rdfs:label 'Course Name' ;
    rdfs:comment 'Full descriptive name of the training course as it appears in the LMS catalog (e.g., OSHA 10-Hour General Industry Safety, HIPAA Privacy and Security Compliance, Preventing Workplace Harassment).' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Total number of hours of instruction or seat time for the training course. Used for compliance reporting (e.g., OSHA 10-hour, OSHA 30-hour) and workforce analytics.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date the candidate or worker was enrolled or assigned to the training course in the LMS. Represents the business event start of the training lifecycle.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:instructorName rdf:type rdf:Property ;
    rdfs:label 'Instructor Name' ;
    rdfs:comment 'Name of the instructor or facilitator who delivered the training. Applicable for in-person and virtual instructor-led delivery methods. Null for self-paced e-learning.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isClientRequired rdf:type rdf:Property ;
    rdfs:label 'Is Client Required' ;
    rdfs:comment 'Indicates whether this specific training was mandated by the client as a condition of placement. Distinct from regulatory mandates; used for client SLA and compliance reporting.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether this training is mandatory for the workers current placement, client engagement, or regulatory compliance. Mandatory trainings block placement activation if not completed.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPlacementPrerequisite rdf:type rdf:Property ;
    rdfs:label 'Is Placement Prerequisite' ;
    rdfs:comment 'Indicates whether completion of this training is a prerequisite before the worker can begin or continue a placement assignment. Drives onboarding workflow gating.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lmsRecordCode rdf:type rdf:Property ;
    rdfs:label 'Lms Record Code' ;
    rdfs:comment 'External identifier from SAP SuccessFactors LMS for this training completion record. Used for reconciliation and audit trail with the source system of record.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passFailResult rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Result' ;
    rdfs:comment 'Outcome of the training assessment or evaluation. not_applicable is used for informational or attendance-only courses with no graded assessment.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passingScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Passing Score Threshold' ;
    rdfs:comment 'Minimum score required to pass the training assessment, expressed as a percentage. Enables automated pass/fail determination and compliance validation.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryRequirementCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Code' ;
    rdfs:comment 'Code or citation of the specific regulatory requirement that mandates this training (e.g., OSHA-29CFR1910.132, HIPAA-164.530, FLSA-CHILD-LABOR). Links training records to compliance obligations for regulatory reporting.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency Days' ;
    rdfs:comment 'Number of days between required renewals of this training certification (e.g., 365 for annual, 730 for biennial). Used to calculate the next due date upon completion.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalRequired rdf:type rdf:Property ;
    rdfs:label 'Renewal Required' ;
    rdfs:comment 'Indicates whether this training certification requires periodic renewal. Drives automated expiration alerts and renewal workflow initiation.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Numeric score achieved by the worker on the training assessment or final exam, expressed as a percentage (0.00–100.00). Nullable for courses without a graded assessment.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingLocation rdf:type rdf:Property ;
    rdfs:label 'Training Location' ;
    rdfs:comment 'Physical location, virtual platform URL, or LMS module path where the training was conducted (e.g., Chicago Training Center, Zoom Webinar, SuccessFactors LMS Module 3). Applicable for in-person and virtual instructor-led sessions.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved By' ;
    rdfs:comment 'Name or identifier of the manager or compliance officer who approved the training waiver. Required for audit trail when a mandatory training is waived.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptableExpiryWindowDays rdf:type rdf:Property ;
    rdfs:label 'Acceptable Expiry Window Days' ;
    rdfs:comment 'Maximum number of days before a credentials expiration date that it is still considered acceptable for placement. For example, a value of 30 means a credential expiring within 30 days of the assignment start date is not acceptable. Drives automated expiration alerts and gap analysis.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliesToAssignmentStart rdf:type rdf:Property ;
    rdfs:label 'Applies To Assignment Start' ;
    rdfs:comment 'Indicates whether this credential must be verified and on file before the candidates assignment start date. When True, the credential is a pre-placement gate. When False, the credential may be obtained during or after onboarding within a grace period.' ;
    rdfs:domain ind:CredentialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bgcPackageCode rdf:type rdf:Property ;
    rdfs:label 'Bgc Package Code' ;
    rdfs:comment 'The specific Background Check (BGC) package code from Sterling Background Check that must be ordered for this requirement. Applicable when credential_category is BGC. Maps to the client_package_code used in the bgc_order product to ensure the correct screening scope is ordered.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientContractRef rdf:type rdf:Property ;
    rdfs:label 'Client Contract Ref' ;
    rdfs:comment 'Reference to the specific clause, section, or exhibit in the clients Master Service Agreement (MSA) or Statement of Work (SOW) that mandates this credential requirement. Supports compliance audit trails and contract-driven credentialing enforcement. Confidential as it references contract terms.' ;
    rdfs:domain ind:CredentialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Client Override Flag' ;
    rdfs:comment 'Indicates whether this requirement record represents a client-specific override of the default credential requirement for this placement type or job order. When True, the client_account_id is the source of the override rule, superseding the standard requirement.' ;
    rdfs:domain ind:CredentialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gapAnalysisBlocking rdf:type rdf:Property ;
    rdfs:label 'Gap Analysis Blocking' ;
    rdfs:comment 'Indicates whether a gap in this credential (missing or expired) will block a candidate submittal in the Applicant Tracking System (ATS). When True, the ATS prevents submission until the credential is satisfied. When False, a warning is raised but submission is permitted.' ;
    rdfs:domain ind:CredentialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:i9Required rdf:type rdf:Property ;
    rdfs:label 'I9 Required' ;
    rdfs:comment 'Indicates whether a completed I-9 Employment Eligibility Verification form is required before placement under this requirement. Standard for all US-based placements but may be explicitly flagged for audit and compliance tracking purposes.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseStateCode rdf:type rdf:Property ;
    rdfs:label 'License State Code' ;
    rdfs:comment 'Two-letter US state code indicating the jurisdiction in which the professional license must be valid. Applicable for state-issued licenses such as RN, LPN, CPA, or contractor licenses. Null when the credential is federally issued or not state-specific.' ;
    rdfs:domain ind:CredentialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxCredentialAgeDays rdf:type rdf:Property ;
    rdfs:label 'Max Credential Age Days' ;
    rdfs:comment 'Maximum age in days that a credential result remains valid from its completion or issue date. For example, a BGC result may only be valid for 365 days. After this period, a new credential must be obtained. Null indicates no age restriction.' ;
    rdfs:domain ind:CredentialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oigExclusionRequired rdf:type rdf:Property ;
    rdfs:label 'Oig Exclusion Required' ;
    rdfs:comment 'Indicates whether an Office of Inspector General (OIG) exclusion list check is required as part of this credential requirement. Mandatory for healthcare staffing placements to ensure candidates are not excluded from federally funded programs.' ;
    rdfs:domain ind:CredentialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placementTypeCode rdf:type rdf:Property ;
    rdfs:label 'Placement Type Code' ;
    rdfs:comment 'Classification of the placement type to which this credential requirement applies when not tied to a specific job order. Supports requirement templates across placement categories such as Contract, Temp-to-Perm (Contract-to-Hire), Direct Hire, Statement of Work (SOW), or Per Diem engagements.' ;
    rdfs:domain ind:CredentialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Lead Time Days' ;
    rdfs:comment 'Number of days before credential expiration that a renewal notification should be triggered. Enables proactive credentialing management to prevent assignment disruptions due to lapsed credentials. Applicable only when renewal_required is True.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:securityClearanceLevel rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Level' ;
    rdfs:comment 'Required federal security clearance level for government staffing placements. Applicable when industry_vertical is GOVERNMENT. Values align with US federal clearance tiers: Public Trust, Secret, Top Secret, and Top Secret/Sensitive Compartmented Information (TS/SCI).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemReqCode rdf:type rdf:Property ;
    rdfs:label 'Source System Req Code' ;
    rdfs:comment 'The native identifier of this credential requirement record in the originating operational system (e.g., Bullhorn requirement ID, Beeline compliance rule ID). Supports data lineage, reconciliation, and bi-directional sync with source systems.' ;
    rdfs:domain ind:CredentialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCourseCode rdf:type rdf:Property ;
    rdfs:label 'Training Course Code' ;
    rdfs:comment 'Identifier for the specific training course or Learning Management System (LMS) module required when credential_category is TRAINING. Maps to the course catalog in SAP SuccessFactors Learning Management System. Examples include OSHA 10, OSHA 30, HIPAA Awareness, or client-specific safety training.' ;
    rdfs:domain ind:CredentialRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationLevel rdf:type rdf:Property ;
    rdfs:label 'Verification Level' ;
    rdfs:comment 'Required level of verification rigor for this credential. PRIMARY_SOURCE requires direct confirmation from the issuing authority (e.g., state licensing board). SELF_REPORTED accepts candidate attestation. THIRD_PARTY requires an independent verification vendor such as Sterling. EMPLOYER_VERIFIED requires confirmation from a prior employer.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverAllowed rdf:type rdf:Property ;
    rdfs:label 'Waiver Allowed' ;
    rdfs:comment 'Indicates whether a client or compliance officer can grant a waiver for this credential requirement on a case-by-case basis. When True, a waiver workflow is available in the ATS. When False, no exceptions are permitted regardless of circumstances.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverApprovalLevel rdf:type rdf:Property ;
    rdfs:label 'Waiver Approval Level' ;
    rdfs:comment 'The organizational role level required to approve a waiver for this credential requirement. Applicable only when waiver_allowed is True. Drives the waiver approval workflow routing in the ATS and compliance management system.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByPackageCredentialPackageId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Package Credential Package Id' ;
    rdfs:comment 'Reference to the newer credential package that replaces this one when package_status is superseded. Enables version chain navigation for compliance audits and candidate re-credentialing workflows.' ;
    rdfs:domain ind:CredentialPackage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CredentialPackage .

ind:bgcComponentsRequired rdf:type rdf:Property ;
    rdfs:label 'Bgc Components Required' ;
    rdfs:comment 'Pipe-delimited list of required BGC components for this package (e.g., criminal_check|employment_verification|education_verification|mvr|oig_exclusion|sex_offender_registry|credit_check). Drives the BGC order configuration in Sterling.' ;
    rdfs:domain ind:CredentialPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialValidityDays rdf:type rdf:Property ;
    rdfs:label 'Credential Validity Days' ;
    rdfs:comment 'The number of days for which a completed credential package remains valid before re-credentialing is required. Drives expiration tracking and renewal alerts for active placements (e.g., 365 days for annual re-credentialing).' ;
    rdfs:domain ind:CredentialPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drugScreenPanelType rdf:type rdf:Property ;
    rdfs:label 'Drug Screen Panel Type' ;
    rdfs:comment 'The specific drug screen panel required by this credential package (e.g., 5-panel, 10-panel, DOT 5-panel, hair follicle). Null if drug_screen_required is false.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugScreenRequired rdf:type rdf:Property ;
    rdfs:label 'Drug Screen Required' ;
    rdfs:comment 'Indicates whether a drug screen is a mandatory component of this credential package. When true, the drug_screen_panel_type field specifies the required panel.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'The date on which this credential package version expires and is no longer valid for new placements. Null for open-ended packages. Supports version lifecycle management and ensures compliance with updated client or regulatory requirements.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:immunizationRequired rdf:type rdf:Property ;
    rdfs:label 'Immunization Required' ;
    rdfs:comment 'Indicates whether proof of immunization records is required as part of this credential package. Primarily applicable to healthcare staffing verticals (e.g., flu shot, hepatitis B, MMR, TB test).' ;
    rdfs:domain ind:CredentialPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseVerificationRequired rdf:type rdf:Property ;
    rdfs:label 'License Verification Required' ;
    rdfs:comment 'Indicates whether professional license verification is a mandatory component of this credential package. When true, the required_license_types field specifies which license types must be verified.' ;
    rdfs:domain ind:CredentialPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oigExclusionCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Oig Exclusion Check Required' ;
    rdfs:comment 'Indicates whether an Office of Inspector General (OIG) exclusion list check is required. Mandatory for healthcare placements to ensure candidates are not excluded from federally funded programs (Medicare/Medicaid).' ;
    rdfs:domain ind:CredentialPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onboardingChecklistTemplate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Checklist Template' ;
    rdfs:comment 'Code or identifier referencing the onboarding checklist template in SAP SuccessFactors or the ATS that is automatically assigned to candidates when this credential package is applied. Ensures consistent onboarding task generation.' ;
    rdfs:domain ind:CredentialPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageCode rdf:type rdf:Property ;
    rdfs:label 'Package Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this credential package across systems (e.g., HC-TRV-NURSE-V2, FED-IT-CLR-V1, LI-WH-STD-V3). Used for cross-system reference in Bullhorn, Sterling, and Beeline VMS.' ;
    rdfs:domain ind:CredentialPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageDescription rdf:type rdf:Property ;
    rdfs:label 'Package Description' ;
    rdfs:comment 'Detailed narrative description of the credential package, including its intended use case, applicable roles, and any special compliance notes. Used by recruiters and compliance teams to understand the full scope of requirements.' ;
    rdfs:domain ind:CredentialPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageName rdf:type rdf:Property ;
    rdfs:label 'Package Name' ;
    rdfs:comment 'Human-readable name of the credential package (e.g., Healthcare Travel Nurse Package, Federal Government IT Clearance Package, Light Industrial Warehouse Package). Used in candidate-facing and recruiter-facing workflows.' ;
    rdfs:domain ind:CredentialPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageStatus rdf:type rdf:Property ;
    rdfs:label 'Package Status' ;
    rdfs:comment 'Current lifecycle state of the credential package. Active packages are available for assignment to candidates. Superseded packages have been replaced by a newer version. Archived packages are retained for historical compliance reference.' ;
    rdfs:domain ind:CredentialPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageVersion rdf:type rdf:Property ;
    rdfs:label 'Package Version' ;
    rdfs:comment 'Integer version number of this credential package definition, incremented each time the package requirements are materially changed. Enables change tracking and ensures candidates are evaluated against the correct version at time of placement.' ;
    rdfs:domain ind:CredentialPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:physicalExamRequired rdf:type rdf:Property ;
    rdfs:label 'Physical Exam Required' ;
    rdfs:comment 'Indicates whether a pre-placement physical examination is required as part of this credential package. Common for healthcare, light industrial, and safety-sensitive positions.' ;
    rdfs:domain ind:CredentialPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalLeadDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Lead Days' ;
    rdfs:comment 'The number of days before credential expiration that the renewal process should be initiated. Used to trigger automated renewal alerts and recruiter tasks in the ATS (e.g., 30 days before expiry).' ;
    rdfs:domain ind:CredentialPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiredAssessmentCodes rdf:type rdf:Property ;
    rdfs:label 'Required Assessment Codes' ;
    rdfs:comment 'Pipe-delimited list of skills assessment or competency test codes required by this package (e.g., MS_OFFICE_BASIC|TYPING_40WPM|FORKLIFT_WRITTEN|CLINICAL_SKILLS_RN). Drives assessment assignment in the ATS onboarding workflow.' ;
    rdfs:domain ind:CredentialPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredImmunizations rdf:type rdf:Property ;
    rdfs:label 'Required Immunizations' ;
    rdfs:comment 'Pipe-delimited list of required immunizations or health screenings for this credential package (e.g., FLU|HEP_B|MMR|VARICELLA|TB_TEST|COVID_VAX). Null if immunization_required is false.' ;
    rdfs:domain ind:CredentialPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredLicenseTypes rdf:type rdf:Property ;
    rdfs:label 'Required License Types' ;
    rdfs:comment 'Pipe-delimited list of professional license types that must be verified as part of this credential package (e.g., RN|LPN|CNA|CDL_A|PMP|CISSP). Drives license verification workflows in Sterling and the credentialing team.' ;
    rdfs:domain ind:CredentialPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredTrainingCodes rdf:type rdf:Property ;
    rdfs:label 'Required Training Codes' ;
    rdfs:comment 'Pipe-delimited list of training course codes or LMS module identifiers that must be completed as part of this credential package (e.g., OSHA_10|HIPAA_PRIVACY|BLOODBORNE_PATHOGENS|FORKLIFT_CERT). Maps to SAP SuccessFactors LMS course catalog.' ;
    rdfs:domain ind:CredentialPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Required' ;
    rdfs:comment 'Indicates whether a government security clearance is required as part of this credential package. Applicable to federal government IT and defense staffing placements.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skillsAssessmentRequired rdf:type rdf:Property ;
    rdfs:label 'Skills Assessment Required' ;
    rdfs:comment 'Indicates whether a formal skills assessment or competency test is required as part of this credential package. When true, the required_assessment_codes field specifies which assessments must be passed.' ;
    rdfs:domain ind:CredentialPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizationNotes rdf:type rdf:Property ;
    rdfs:label 'Authorization Notes' ;
    rdfs:comment 'Free-text field for compliance officers or recruiters to capture additional context about the candidates work authorization status, including pending renewals, special conditions, attorney notes, or immigration counsel observations. Not used for structured data — structured fields take precedence.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Authorization Status' ;
    rdfs:comment 'Current lifecycle status of the work authorization record. active indicates the candidate is currently authorized to work; expired indicates the authorization period has lapsed; pending indicates verification or renewal is in progress; revoked indicates authorization was withdrawn; under_review indicates a compliance review is ongoing. Critical for placement eligibility gating.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedEndDate rdf:type rdf:Property ;
    rdfs:label 'Authorized End Date' ;
    rdfs:comment 'The date on which the candidates work authorization expires. Null for permanent authorizations (e.g., US Citizens, Permanent Residents with no expiry). Drives credential expiration alerts, renewal workflows, and assignment end-date compliance checks. Critical for avoiding unauthorized employment liability.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizedStartDate rdf:type rdf:Property ;
    rdfs:label 'Authorized Start Date' ;
    rdfs:comment 'The date on which the candidates work authorization becomes effective. Used to determine earliest eligible placement start date and to enforce compliance with immigration law. Corresponds to the authorized to work from date on the underlying visa or EAD document.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizedToWorkUnrestricted rdf:type rdf:Property ;
    rdfs:label 'Authorized To Work Unrestricted' ;
    rdfs:comment 'Indicates whether the candidate has unrestricted authorization to work for any employer without limitation (e.g., US Citizens, Permanent Residents). True = no employer or occupation restrictions; False = authorization is tied to a specific employer, occupation, or time period. Used for rapid placement eligibility screening.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bullhornCandidateRef rdf:type rdf:Property ;
    rdfs:label 'Bullhorn Candidate Ref' ;
    rdfs:comment 'The external candidate identifier from Bullhorn ATS/CRM corresponding to this work authorization record. Enables cross-system reconciliation between the Staffing Hr data lakehouse and the Bullhorn operational system without relying solely on the internal surrogate key.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capExempt rdf:type rdf:Property ;
    rdfs:label 'Cap Exempt' ;
    rdfs:comment 'Indicates whether the candidates H-1B petition is exempt from the annual USCIS H-1B numerical cap (e.g., employed by a cap-exempt institution such as a university, nonprofit research organization, or government research entity). True = cap-exempt; False = subject to annual cap lottery. Relevant only for H-1B authorization type.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryOfAuthorization rdf:type rdf:Property ;
    rdfs:label 'Country Of Authorization' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the jurisdiction in which the candidate is authorized to work (e.g., USA, CAN, GBR). Supports multi-jurisdiction staffing operations and international placement compliance.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eadCardNumber rdf:type rdf:Property ;
    rdfs:label 'Ead Card Number' ;
    rdfs:comment 'The USCIS-issued Employment Authorization Document (EAD) card number (Form I-766) for candidates whose work authorization is evidenced by an EAD card. Distinct from visa_number. Applicable for OPT, CPT, H-4 EAD, TPS, and other EAD-based authorization types. Sensitive PII.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:greenCardPriorityDate rdf:type rdf:Property ;
    rdfs:label 'Green Card Priority Date' ;
    rdfs:comment 'The priority date established when a PERM labor certification or I-140 immigrant petition was filed on behalf of the candidate. Determines the candidates place in the immigrant visa queue. Null if no green card process is underway. Used for long-term workforce planning and retention risk assessment.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:i140Approved rdf:type rdf:Property ;
    rdfs:label 'I140 Approved' ;
    rdfs:comment 'Indicates whether USCIS has approved an I-140 Immigrant Petition for Alien Workers on behalf of the candidate. True = I-140 approved; False = not approved or not filed. An approved I-140 enables H-1B extensions beyond the standard 6-year cap and supports AC21 portability analysis.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lcaNumber rdf:type rdf:Property ;
    rdfs:label 'Lca Number' ;
    rdfs:comment 'The Department of Labor (DOL)-assigned Labor Condition Application (LCA) case number associated with an H-1B or H-1B1 visa. The LCA certifies that the employer will pay the prevailing wage and maintain required working conditions. Required for H-1B compliance tracking and DOL audit readiness.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optStemExtension rdf:type rdf:Property ;
    rdfs:label 'Opt Stem Extension' ;
    rdfs:comment 'Indicates whether the candidate is on a 24-month STEM OPT extension (applicable to F-1 students with STEM degrees). True = STEM extension applies, extending OPT authorization by 24 months beyond standard 12-month OPT. Relevant only when authorization_type = OPT. Drives extended placement eligibility windows.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optStemExtensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Opt Stem Extension End Date' ;
    rdfs:comment 'The end date of the 24-month STEM OPT extension period. Null if opt_stem_extension is False or not applicable. Used to track the outer boundary of OPT-based work authorization for STEM candidates and to trigger timely H-1B sponsorship or transition planning.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passportCountry rdf:type rdf:Property ;
    rdfs:label 'Passport Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country that issued the candidates passport (e.g., IND, CHN, MEX, CAN). Used for immigration compliance, co-employment risk assessment, and OFCCP reporting. Distinct from country_of_authorization.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passportExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Passport Expiration Date' ;
    rdfs:comment 'The expiration date of the candidates passport as presented during work authorization verification. Used to ensure the underlying identity document remains valid throughout the placement period. Triggers renewal alerts when approaching expiry.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passportNumber rdf:type rdf:Property ;
    rdfs:label 'Passport Number' ;
    rdfs:comment 'The candidates passport number as presented during work authorization verification. Used as a supporting identity document for I-9 compliance and immigration record-keeping. Sensitive government-issued PII — access restricted to authorized compliance personnel.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Placement Restriction Flag' ;
    rdfs:comment 'Indicates whether the candidates work authorization imposes restrictions on placement (e.g., H-1B candidates restricted to the petitioning employers worksite, TN candidates restricted to specific occupations). True = placement restrictions apply; False = no restrictions. Triggers compliance review before assignment to a new client or location.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placementRestrictionNotes rdf:type rdf:Property ;
    rdfs:label 'Placement Restriction Notes' ;
    rdfs:comment 'Free-text description of any specific placement restrictions associated with the work authorization (e.g., H-1B restricted to client XYZ worksite in Chicago, IL per LCA, TN restricted to Software Engineer occupation only). Null if placement_restriction_flag is False. Used by recruiters and compliance teams during placement eligibility review.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portabilityEligible rdf:type rdf:Property ;
    rdfs:label 'Portability Eligible' ;
    rdfs:comment 'Indicates whether the candidate is eligible for H-1B portability under AC21 (American Competitiveness in the 21st Century Act), allowing them to change employers while an I-140 petition is pending. True = portability applies; False = not eligible. Critical for assessing whether a candidate can be placed with a new client without a new H-1B petition.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsoringEmployer rdf:type rdf:Property ;
    rdfs:label 'Sponsoring Employer' ;
    rdfs:comment 'The legal name of the employer currently sponsoring the candidates work visa or authorization (e.g., the H-1B petitioner or PERM sponsor). May be Staffing Hr itself (as Employer of Record) or a client company. Null if no sponsorship is required. Critical for co-employment risk management and portability analysis.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsoringEmployerEin rdf:type rdf:Property ;
    rdfs:label 'Sponsoring Employer Ein' ;
    rdfs:comment 'The IRS-assigned Employer Identification Number (EIN) of the sponsoring employer. Used to verify the legal entity responsible for the sponsorship obligation and to support DOL Labor Condition Application (LCA) compliance. Format: XX-XXXXXXX. Confidential business financial identifier.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipRequired rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Required' ;
    rdfs:comment 'Indicates whether the candidate requires employer sponsorship (e.g., H-1B petition, PERM labor certification) to maintain or obtain work authorization. True = sponsorship required; False = no sponsorship needed. Critical for client placement eligibility screening — many clients explicitly exclude candidates requiring sponsorship.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:uscisCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Uscis Case Number' ;
    rdfs:comment 'The official case number assigned by the United States Citizenship and Immigration Services (USCIS) for the candidates immigration petition or application (e.g., I-129 H-1B petition receipt number). Format: three-letter service center code followed by 10 digits (e.g., EAC2312345678). Used to track petition status and employer sponsorship obligations.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visaCategory rdf:type rdf:Property ;
    rdfs:label 'Visa Category' ;
    rdfs:comment 'The specific visa category or classification code as issued by the relevant immigration authority (e.g., H-1B, L-1A, L-1B, O-1A, O-1B, TN-1, TN-2, F-1 OPT, J-1). More granular than authorization_type and maps directly to the visa stamp classification. Used for precise immigration compliance reporting.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visaNumber rdf:type rdf:Property ;
    rdfs:label 'Visa Number' ;
    rdfs:comment 'The official visa number or foil number as printed on the candidates visa stamp or entry document. Uniquely identifies the specific visa issuance. Required for immigration compliance tracking and USCIS case management. Sensitive PII — access restricted to authorized compliance personnel.' ;
    rdfs:domain ind:WorkAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByDocumentCredentialDocumentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Document Credential Document Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the newer credential document record that replaced this one. Enables document version lineage tracking and audit trail for FCRA and client audit compliance.' ;
    rdfs:domain ind:CredentialDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CredentialDocument .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Externally-known unique identifier or reference number assigned to the document by the issuing authority or institution (e.g., license number on a license copy, diploma serial number, passport number). Serves as the BUSINESS_IDENTIFIER for this master resource.' ;
    rdfs:domain ind:CredentialDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStatus rdf:type rdf:Property ;
    rdfs:label 'Document Status' ;
    rdfs:comment 'Current operational status of the document itself, independent of its verification status. Tracks whether the document is currently valid, expired, revoked by the issuing authority, or superseded by a newer version.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTitle rdf:type rdf:Property ;
    rdfs:label 'Document Title' ;
    rdfs:comment 'Human-readable title or name of the document as it appears on the physical or digital artifact (e.g., Registered Nurse License, Bachelor of Science in Computer Science, CPR Certification Card). Serves as the IDENTITY_LABEL for this master resource.' ;
    rdfs:domain ind:CredentialDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Categorical classification of the credential document type submitted by the candidate. Drives downstream routing, verification workflows, and compliance checks. [ENUM-REF-CANDIDATE: license|certification|diploma|transcript|government_id|immunization_record|drug_screen_result|reference_letter|background_check_consent|other — promote to reference product]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fcraCompliant rdf:type rdf:Property ;
    rdfs:label 'Fcra Compliant' ;
    rdfs:comment 'Indicates whether the collection, storage, and use of this document complies with Fair Credit Reporting Act (FCRA) requirements, including candidate consent and permissible purpose. Critical for background check document types.' ;
    rdfs:domain ind:CredentialDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'File format of the stored digital document (e.g., PDF, JPG, PNG, TIFF). Used for document rendering, archival compliance, and integration with document management systems.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeKb rdf:type rdf:Property ;
    rdfs:label 'File Size Kb' ;
    rdfs:comment 'Size of the stored document file in kilobytes. Used for storage management, upload validation, and document vault capacity planning.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipaaApplicable rdf:type rdf:Property ;
    rdfs:label 'Hipaa Applicable' ;
    rdfs:comment 'Indicates whether this document contains Protected Health Information (PHI) subject to HIPAA regulations (e.g., immunization records, drug screen results, medical clearance letters). Drives PHI handling, access controls, and retention policies.' ;
    rdfs:domain ind:CredentialDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryDocument rdf:type rdf:Property ;
    rdfs:label 'Is Primary Document' ;
    rdfs:comment 'Indicates whether this document is the primary or most current version of a given document type for the candidate. When false, the document may be a historical or superseded version retained for audit purposes.' ;
    rdfs:domain ind:CredentialDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Date' ;
    rdfs:comment 'The calculated or manually set date by which the candidate must renew this document to maintain credentialing compliance. Drives scheduling of renewal outreach and placement hold triggers.' ;
    rdfs:domain ind:CredentialDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storageUri rdf:type rdf:Property ;
    rdfs:label 'Storage Uri' ;
    rdfs:comment 'Uniform Resource Identifier (URI) pointing to the physical or digital document stored in DocuSign CLM or the enterprise document vault. Enables retrieval for audits, client requests, and FCRA/HIPAA compliance reviews. Access is governed by role-based security controls.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedDate rdf:type rdf:Property ;
    rdfs:label 'Submitted Date' ;
    rdfs:comment 'The date on which the candidate submitted this document to the staffing organization for credentialing review. Serves as the principal business event date (BUSINESS_EVENT_TIMESTAMP at day granularity) for the document intake lifecycle.' ;
    rdfs:domain ind:CredentialDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verifiedDate rdf:type rdf:Property ;
    rdfs:label 'Verified Date' ;
    rdfs:comment 'The date on which the document was confirmed as authentic and valid by the credentialing team or automated verification system. Null until verification is completed.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:packageRequirementId rdf:type rdf:Property ;
    rdfs:label 'Package Requirement Id' ;
    rdfs:comment 'Unique system-generated identifier for this package requirement record. Primary key.' ;
    rdfs:domain ind:PackageRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:displayOrder rdf:type rdf:Property ;
    rdfs:label 'Display Order' ;
    rdfs:comment 'Numeric sort order for displaying this credential requirement within the package checklist presented to candidates and recruiters.' ;
    rdfs:domain ind:Credentialing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'System timestamp when this package requirement record was last modified.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:parentCredentialTypeId rdf:type rdf:Property ;
    rdfs:label 'Parent Credential Type Id' ;
    rdfs:comment 'Self-referencing FK on credential_type (parent_credential_type_id)' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CredentialType .

ind:allowedDocumentTypes rdf:type rdf:Property ;
    rdfs:label 'Allowed Document Types' ;
    rdfs:comment 'Comma-separated list of acceptable document file types or formats for this credential type (e.g., PDF, JPG, PNG). Null if document upload is not required or any type is accepted.' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckScope rdf:type rdf:Property ;
    rdfs:label 'Background Check Scope' ;
    rdfs:comment 'For background check credential types, specifies the scope or type of background check (e.g., criminal, employment verification, education verification). Null for non-BGC credential types.' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFramework rdf:type rdf:Property ;
    rdfs:label 'Compliance Framework' ;
    rdfs:comment 'Name of the regulatory or compliance framework that mandates or governs this credential type (e.g., Joint Commission, OSHA, state licensing board). Null if not tied to a specific framework.' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Usd' ;
    rdfs:comment 'Estimated average cost in USD for obtaining or renewing this credential type, including application fees, exam fees, and verification costs. Null if cost is not tracked or highly variable.' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:credentialTypeCategory rdf:type rdf:Property ;
    rdfs:label 'Credential Type Category' ;
    rdfs:comment 'High-level category classifying the credential type into major groupings for reporting and filtering.' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialTypeCode rdf:type rdf:Property ;
    rdfs:label 'Credential Type Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the credential type (e.g., RN_LIC, CPR_CERT, BGC_BASIC). Used as a business key for system integration and reporting.' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Credential Type Description' ;
    rdfs:comment 'Detailed description of the credential type, including its purpose, scope, and any special requirements or notes.' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialTypeName rdf:type rdf:Property ;
    rdfs:label 'Credential Type Name' ;
    rdfs:comment 'Full descriptive name of the credential type (e.g., Registered Nurse License, CPR Certification, Basic Background Check).' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Credential Type Status' ;
    rdfs:comment 'Current lifecycle status of the credential type in the system. Active types are available for assignment; inactive or deprecated types are retained for historical reference only.' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultValidityPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Default Validity Period Days' ;
    rdfs:comment 'Standard number of days this credential type remains valid from issuance or renewal date. Null if credential does not expire or validity varies by issuer.' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Date when this credential type was or will be retired or deprecated. Null if the credential type is still active or has no planned end date.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isClientVisible rdf:type rdf:Property ;
    rdfs:label 'Is Client Visible' ;
    rdfs:comment 'Indicates whether this credential type should be visible to client users in client-facing portals and reports (True) or is for internal use only (False).' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMandatoryForPlacement rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory For Placement' ;
    rdfs:comment 'Indicates whether this credential type is commonly required as a mandatory prerequisite for candidate placement in roles within its industry vertical (True) or is optional/preferred (False).' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAuthorityType rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Type' ;
    rdfs:comment 'Type of organization or entity that issues or validates this credential (e.g., government agency, professional association, third-party vendor).' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingTimeDays rdf:type rdf:Property ;
    rdfs:label 'Processing Time Days' ;
    rdfs:comment 'Typical number of days required to complete verification or obtain results for this credential type. Null if processing time is not tracked or highly variable.' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalReminderDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Reminder Days' ;
    rdfs:comment 'Number of days before expiration when renewal reminders should be triggered for candidates holding this credential type. Null if no reminder is configured.' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresDocumentUpload rdf:type rdf:Property ;
    rdfs:label 'Requires Document Upload' ;
    rdfs:comment 'Indicates whether candidates or staff must upload supporting documentation (e.g., certificate, license scan) when recording this credential type (True) or if documentation is optional or not required (False).' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresRenewal rdf:type rdf:Property ;
    rdfs:label 'Requires Renewal' ;
    rdfs:comment 'Indicates whether this credential type has an expiration date and requires periodic renewal (True) or is valid indefinitely once obtained (False).' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skillsAssessmentDomain rdf:type rdf:Property ;
    rdfs:label 'Skills Assessment Domain' ;
    rdfs:comment 'For skills assessment credential types, specifies the skill domain or competency area being assessed (e.g., Java Programming, Welding, Clinical Nursing Skills). Null for non-assessment credential types.' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingProviderType rdf:type rdf:Property ;
    rdfs:label 'Training Provider Type' ;
    rdfs:comment 'For training credential types, specifies the type of organization that provides the training (e.g., internal company training, external vendor, accredited institution). Null for non-training credential types.' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessType rdf:type rdf:Property ;
    rdfs:label 'Business Type' ;
    rdfs:comment 'Categorical classification of the suppliers primary business model within the contingent workforce program. Drives workflow routing, compliance requirements, and rate card applicability. Values: staffing_agency (W-2 or 1099 temp placement), ic_supplier (Independent Contractor supplier), sow_provider (Statement of Work delivery), subcontractor (tier-2 supplier), peo (Professional Employer Organization).' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversityCertExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Diversity Cert Expiry Date' ;
    rdfs:comment 'Expiration date of the suppliers most current diversity certification. Triggers renewal workflow and flags suppliers with lapsed certifications for OFCCP compliance reporting.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:diversityCertifications rdf:type rdf:Property ;
    rdfs:label 'Diversity Certifications' ;
    rdfs:comment 'Pipe-delimited list of active diversity certifications held by the supplier (e.g., MBE=Minority Business Enterprise, WBE=Women Business Enterprise, SDVOB=Service-Disabled Veteran-Owned Business, HUBZone, 8(a)). Required for OFCCP supplier diversity reporting and client diversity spend commitments. [ENUM-REF-CANDIDATE: MBE|WBE|SDVOB|HUBZone|8a|VOSB|LGBTBE|AABE — promote to reference product]' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Dun & Bradstreet Data Universal Numbering System (DUNS) 9-digit identifier for the supplier. Used for supplier credentialing, federal contractor verification, and OFCCP compliance reporting.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallOffRate rdf:type rdf:Property ;
    rdfs:label 'Fall Off Rate' ;
    rdfs:comment 'Percentage of placements made by this supplier that ended prematurely (fall-offs) within the defined measurement period. A key quality KPI used in supplier scorecarding and tier classification decisions.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hqAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Hq Address Line1' ;
    rdfs:comment 'Primary street address of the suppliers headquarters location. Used for legal correspondence, MSA execution, and AP remittance.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hqCity rdf:type rdf:Property ;
    rdfs:label 'Hq City' ;
    rdfs:comment 'City of the suppliers headquarters location.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hqCountry rdf:type rdf:Property ;
    rdfs:label 'Hq Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the suppliers headquarters. Supports international supplier programs and GDPR/CCPA jurisdiction determination.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hqPostalCode rdf:type rdf:Property ;
    rdfs:label 'Hq Postal Code' ;
    rdfs:comment 'ZIP/postal code of the suppliers headquarters. Used for geographic analytics, tax jurisdiction mapping, and remittance address validation.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hqState rdf:type rdf:Property ;
    rdfs:label 'Hq State' ;
    rdfs:comment 'Two-letter U.S. state code (or equivalent) for the suppliers headquarters. Used for SUTA jurisdiction determination, workers compensation rate assignment, and state-level compliance.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icBusinessStructure rdf:type rdf:Property ;
    rdfs:label 'Ic Business Structure' ;
    rdfs:comment 'Legal business structure of the IC supplier entity. Determines tax treatment, liability exposure, and co-employment risk profile. Applicable only when business_type = ic_supplier.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icComplianceEnrolled rdf:type rdf:Property ;
    rdfs:label 'Ic Compliance Enrolled' ;
    rdfs:comment 'Indicates whether the IC supplier subtype is enrolled in a formal Independent Contractor (IC) compliance program (e.g., MBO Partners, Shiftpixy, WorkMarket). Applicable only when business_type = ic_supplier. Required for IRS worker classification risk mitigation.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:icComplianceVendor rdf:type rdf:Property ;
    rdfs:label 'Ic Compliance Vendor' ;
    rdfs:comment 'Name of the third-party IC compliance management vendor (e.g., MBO Partners, Shiftpixy, WorkMarket, Openforce) engaged by the IC supplier to manage worker classification compliance, IC agreements, and tax administration.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icRiskScore rdf:type rdf:Property ;
    rdfs:label 'Ic Risk Score' ;
    rdfs:comment 'Numeric risk score (typically 1–100) assigned to the IC supplier based on IRS worker classification criteria, co-employment exposure, indemnification coverage, and compliance program enrollment. Higher scores indicate greater misclassification risk. Used for IC supplier risk tiering and audit prioritization.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:icWorkerClassification rdf:type rdf:Property ;
    rdfs:label 'Ic Worker Classification' ;
    rdfs:comment 'IRS worker classification determination status for the IC supplier subtype. Reflects the outcome of the classification assessment against IRS common law rules and DOL economic reality test. Applicable only when business_type = ic_supplier.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indemnificationAgreement rdf:type rdf:Property ;
    rdfs:label 'Indemnification Agreement' ;
    rdfs:comment 'Indicates whether the supplier has executed an indemnification agreement protecting the MSP/client from worker misclassification claims, co-employment liability, and related legal exposure. Critical for IC supplier risk management.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceGlLimit rdf:type rdf:Property ;
    rdfs:label 'Insurance Gl Limit' ;
    rdfs:comment 'Minimum required general liability insurance coverage amount (in USD) that the supplier must maintain as a condition of program participation. Validated during onboarding and annual compliance review.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Verified Date' ;
    rdfs:comment 'Most recent date on which the suppliers insurance certificates (general liability, workers compensation, E&O) were verified and confirmed to meet program minimums.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceWcLimit rdf:type rdf:Property ;
    rdfs:label 'Insurance Wc Limit' ;
    rdfs:comment 'Minimum required Workers Compensation (WC) insurance coverage amount (in USD) that the supplier must maintain. Applicable to staffing agencies placing W-2 workers. Validated during onboarding.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full legal registered name of the supplier entity as it appears on government filings, MSA, and tax documents. Used for contract execution, invoicing, and compliance reporting.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msaEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Msa Effective Date' ;
    rdfs:comment 'Date on which the Master Service Agreement (MSA) with the supplier became legally binding and operative.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:msaExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Msa Expiry Date' ;
    rdfs:comment 'Date on which the Master Service Agreement (MSA) with the supplier expires. Triggers contract renewal workflow in DocuSign CLM. Null indicates an evergreen/open-ended agreement.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:msaStatus rdf:type rdf:Property ;
    rdfs:label 'Msa Status' ;
    rdfs:comment 'Current status of the Master Service Agreement (MSA) between the MSP/staffing firm and the supplier. Governs the legal framework for all placements and SOW engagements. Managed via DocuSign CLM.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaExecuted rdf:type rdf:Property ;
    rdfs:label 'Nda Executed' ;
    rdfs:comment 'Indicates whether a Non-Disclosure Agreement (NDA) has been fully executed between the MSP/staffing firm and the supplier. Managed via DocuSign CLM.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonCompeteExecuted rdf:type rdf:Property ;
    rdfs:label 'Non Compete Executed' ;
    rdfs:comment 'Indicates whether a non-compete or non-solicitation agreement has been executed with the supplier, restricting direct placement of workers with clients outside the MSP program.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalRegions rdf:type rdf:Property ;
    rdfs:label 'Operational Regions' ;
    rdfs:comment 'Comma-delimited list of geographic regions (U.S. states, metro areas, or country codes) where the supplier actively places workers or delivers services. Used for job order routing, geographic coverage analytics, and program expansion planning.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceScore rdf:type rdf:Property ;
    rdfs:label 'Performance Score' ;
    rdfs:comment 'Composite performance score (0.00–100.00) from the suppliers most recent scorecard evaluation. Derived from KPIs including Quality of Submission (QoS), Time to Fill (TTF), fill rate, fall-off rate, and SLA compliance. Used for tier reclassification and program allocation decisions.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceScoreDate rdf:type rdf:Property ;
    rdfs:label 'Performance Score Date' ;
    rdfs:comment 'Date of the most recent supplier performance scorecard evaluation. Used to determine score currency and trigger re-evaluation workflows.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredSupplier rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier' ;
    rdfs:comment 'Indicates whether the supplier holds preferred supplier status within the MSP program, granting priority job order routing, higher volume allocation, and preferred rate card terms.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Business email address of the suppliers primary program contact. Used for job order notifications, compliance communications, and VMS system alerts.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary business contact at the supplier organization responsible for program management, escalations, and relationship management with the MSP.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Business phone number of the suppliers primary program contact for operational communications and escalation.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightToAudit rdf:type rdf:Property ;
    rdfs:label 'Right To Audit' ;
    rdfs:comment 'Indicates whether the suppliers MSA or IC compliance agreement includes a right-to-audit clause allowing the MSP or client to audit the suppliers worker classification practices, payroll records, and compliance documentation.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxClassification rdf:type rdf:Property ;
    rdfs:label 'Tax Classification' ;
    rdfs:comment 'IRS tax classification governing how workers supplied by this vendor are compensated and taxed. Determines payroll tax obligations, worker classification risk, and billing structure. W-2 = employer-employee; 1099 = independent contractor; Corp-to-Corp (C2C) = business-to-business engagement.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Doing-business-as (DBA) or trade name used in day-to-day operations, marketing, and client-facing communications when different from the legal entity name.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmsEnrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Vms Enrollment Status' ;
    rdfs:comment 'Enrollment status of the supplier within the Beeline Vendor Management System (VMS). Indicates whether the supplier is actively enrolled and eligible to participate in VMS-managed requisitions and rate card agreements.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmsSupplierCode rdf:type rdf:Property ;
    rdfs:label 'Vms Supplier Code' ;
    rdfs:comment 'Supplier identifier assigned by the Beeline Vendor Management System (VMS) at enrollment. Used for cross-system reconciliation between Beeline VMS, Bullhorn ATS/CRM, and Oracle NetSuite ERP.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceScorecardId rdf:type rdf:Property ;
    rdfs:label 'Performance Scorecard Id' ;
    rdfs:comment 'Foreign key linking to vendor.performance_scorecard. Business justification: A tier reclassification event is triggered by and references a specific performance scorecard evaluation. The tier_classification table currently denormalizes scorecard_score_at_review, scorecard_peri' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceScorecard .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether the vendor has an active compliance issue (e.g., expired insurance, failed background check, I-9 deficiency, E-Verify non-compliance) that is a factor in this tier classification or review. True = compliance issue present.' ;
    rdfs:domain ind:TierClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceIssueType rdf:type rdf:Property ;
    rdfs:label 'Compliance Issue Type' ;
    rdfs:comment 'Categorizes the type of compliance deficiency flagged for this vendor at the time of tier review (e.g., insurance_lapse, background_check_failure, i9_deficiency, everify_non_compliance, license_expiry). Populated when compliance_flag is True. [ENUM-REF-CANDIDATE: insurance_lapse|background_check_failure|i9_deficiency|everify_non_compliance|license_expiry|drug_screen_failure|osha_violation — promote to reference product]' ;
    rdfs:domain ind:TierClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionOutcome rdf:type rdf:Property ;
    rdfs:label 'Decision Outcome' ;
    rdfs:comment 'The final decision made by the review committee regarding the vendors tier classification. upgraded = moved to a higher-preference tier; downgraded = moved to a lower-preference tier; maintained = no change; suspended = tier privileges temporarily halted; terminated = removed from program.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExclusiveSupplier rdf:type rdf:Property ;
    rdfs:label 'Is Exclusive Supplier' ;
    rdfs:comment 'Indicates whether the vendor has been designated as the exclusive supplier for a specific skill category, geography, or client within this program tier. True = exclusive supplier designation applies.' ;
    rdfs:domain ind:TierClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPreferredVendor rdf:type rdf:Property ;
    rdfs:label 'Is Preferred Vendor' ;
    rdfs:comment 'Indicates whether the vendor holds preferred status within this tier, granting first-right-of-refusal on requisitions before other vendors at the same tier level. True = preferred vendor within tier.' ;
    rdfs:domain ind:TierClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxFillRatePct rdf:type rdf:Property ;
    rdfs:label 'Max Fill Rate Pct' ;
    rdfs:comment 'The maximum percentage of total program requisition fill volume that vendors at this tier level are permitted to fulfill. Used to enforce program diversity and prevent over-concentration with a single tier. Expressed as a percentage (e.g., 60.00 = 60%).' ;
    rdfs:domain ind:TierClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minScorecardScore rdf:type rdf:Property ;
    rdfs:label 'Min Scorecard Score' ;
    rdfs:comment 'The minimum vendor performance scorecard score required to qualify for or maintain this tier level. Scores below this threshold trigger a tier review or automatic downgrade. Expressed as a numeric score (e.g., 75.00 out of 100).' ;
    rdfs:domain ind:TierClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousTierCode rdf:type rdf:Property ;
    rdfs:label 'Previous Tier Code' ;
    rdfs:comment 'The tier code held by the vendor immediately prior to a reclassification event. Populated only for tier_review records. Enables full audit trail of tier movement history and trend analysis.' ;
    rdfs:domain ind:TierClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programEligibilityRules rdf:type rdf:Property ;
    rdfs:label 'Program Eligibility Rules' ;
    rdfs:comment 'Structured text or rule expression defining the criteria a vendor must meet to qualify for this tier level. May include minimum scorecard thresholds, compliance certification requirements, insurance minimums, and contract status conditions.' ;
    rdfs:domain ind:TierClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposedTierCode rdf:type rdf:Property ;
    rdfs:label 'Proposed Tier Code' ;
    rdfs:comment 'The tier code proposed for the vendor as a result of a review event. May differ from the final decision outcome if the review committee overrides the initial proposal. Populated only for tier_review records.' ;
    rdfs:domain ind:TierClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rationaleNotes rdf:type rdf:Property ;
    rdfs:label 'Rationale Notes' ;
    rdfs:comment 'Free-text narrative documenting the business rationale for the tier review decision, including key performance factors, compliance issues, or client feedback that influenced the outcome. Required for audit trail completeness.' ;
    rdfs:domain ind:TierClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordType rdf:type rdf:Property ;
    rdfs:label 'Record Type' ;
    rdfs:comment 'Discriminator indicating whether this record represents a tier definition (the tier level itself), a tier assignment (a vendor assigned to a tier), or a tier review event (a reclassification decision). Enables the table to serve as both reference and history.' ;
    rdfs:domain ind:TierClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCommitteeMembers rdf:type rdf:Property ;
    rdfs:label 'Review Committee Members' ;
    rdfs:comment 'Comma-separated list of names or identifiers of individuals who participated in the tier review committee. Provides governance accountability and audit trail for the review decision.' ;
    rdfs:domain ind:TierClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycleFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Frequency' ;
    rdfs:comment 'The scheduled frequency at which vendors assigned to this tier are reviewed for potential reclassification. Drives the automated review scheduling in the MSP governance calendar.' ;
    rdfs:domain ind:TierClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaFillRateTargetPct rdf:type rdf:Property ;
    rdfs:label 'Sla Fill Rate Target Pct' ;
    rdfs:comment 'The target fill rate percentage that vendors at this tier are contractually expected to achieve. Expressed as a percentage of requisitions successfully filled (e.g., 85.00 = 85%). Used in SLA compliance monitoring and tier review scoring.' ;
    rdfs:domain ind:TierClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaQualityOfSubmissionTarget rdf:type rdf:Property ;
    rdfs:label 'Sla Quality Of Submission Target' ;
    rdfs:comment 'The minimum Quality of Submission (QoS) score that vendors at this tier must maintain. QoS measures the percentage of submitted candidates who meet the job requirements and advance to interview or placement. Expressed as a percentage.' ;
    rdfs:domain ind:TierClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTimeToSubmitHours rdf:type rdf:Property ;
    rdfs:label 'Sla Time To Submit Hours' ;
    rdfs:comment 'The maximum number of hours within which a vendor at this tier must submit qualified candidates after receiving a requisition. This is the SLA requirement specific to this tier level, used to enforce vendor responsiveness in the VMS.' ;
    rdfs:domain ind:TierClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionPriorityOrder rdf:type rdf:Property ;
    rdfs:label 'Submission Priority Order' ;
    rdfs:comment 'The sequential order in which vendors at this tier level receive job requisition submissions from the MSP. Determines the cascade sequence when a higher-tier vendor does not fill a requisition within the SLA window.' ;
    rdfs:domain ind:TierClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierCode rdf:type rdf:Property ;
    rdfs:label 'Tier Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the tier level within the program (e.g., T1, T2, T3, T4). Used as the primary routing key in Beeline VMS vendor dispatch logic and rate card lookups.' ;
    rdfs:domain ind:TierClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierDescription rdf:type rdf:Property ;
    rdfs:label 'Tier Description' ;
    rdfs:comment 'Detailed narrative description of the tier level, including eligibility criteria, expected performance standards, and program privileges associated with this tier. Used for program documentation and vendor communication.' ;
    rdfs:domain ind:TierClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierName rdf:type rdf:Property ;
    rdfs:label 'Tier Name' ;
    rdfs:comment 'Human-readable name of the tier level as displayed in the VMS and MSP program documentation (e.g., Tier 1 Preferred, Tier 2 Approved, Tier 3 Conditional, Tier 4 Probationary). Drives vendor routing labels in Beeline VMS.' ;
    rdfs:domain ind:TierClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierRank rdf:type rdf:Property ;
    rdfs:label 'Tier Rank' ;
    rdfs:comment 'Numeric rank indicating the priority order of this tier relative to other tiers within the same program. Lower values indicate higher preference (e.g., 1 = most preferred). Drives submission priority sequencing in Beeline VMS requisition routing.' ;
    rdfs:domain ind:TierClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierStatus rdf:type rdf:Property ;
    rdfs:label 'Tier Status' ;
    rdfs:comment 'Current lifecycle status of this tier classification record. active indicates the tier definition is in use; inactive means retired; suspended means temporarily halted; pending_review means under evaluation for change.' ;
    rdfs:domain ind:TierClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmsTierCode rdf:type rdf:Property ;
    rdfs:label 'Vms Tier Code' ;
    rdfs:comment 'The native tier identifier assigned by the Beeline VMS system for this tier classification record. Used for system-of-record reconciliation and integration with Beeline VMS vendor routing and rate management modules.' ;
    rdfs:domain ind:TierClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversityCertificationId rdf:type rdf:Property ;
    rdfs:label 'Diversity Certification Id' ;
    rdfs:comment 'Foreign key linking to vendor.diversity_certification. Business justification: VMS enrollment records carry diversity_certification_expiry (DATE) and diversity_certification_type (STRING) — both are denormalized from the diversity_certification record. Adding diversity_certifica' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DiversityCertification .

ind:ndaId rdf:type rdf:Property ;
    rdfs:label 'Nda Id' ;
    rdfs:comment 'Foreign key linking to contract.nda. Business justification: VMS enrollment requires NDA execution as a prerequisite. vms_enrollment tracks nda_executed (boolean) but has no FK to the actual NDA record. Linking to the specific executed NDA enables compliance au' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Nda .

ind:primaryClientProgramVmsProgramId rdf:type rdf:Property ;
    rdfs:label 'Primary Client Program Vms Program Id' ;
    rdfs:comment 'The client-assigned or VMS-assigned identifier for the specific contingent workforce program, as referenced in client-facing documentation, SOW agreements, and MSP reporting.' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VmsProgram .

ind:primaryLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Location Id' ;
    rdfs:comment 'Foreign key linking to client.location. Business justification: VMS supplier enrollments are scoped to specific client locations in multi-site programs. The primary location FK identifies the client site for which the supplier is primarily enrolled, enabling site-' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:approvedJobCategories rdf:type rdf:Property ;
    rdfs:label 'Approved Job Categories' ;
    rdfs:comment 'Comma-separated list or free-text description of the job categories or labor categories for which the vendor is approved to submit candidates within this VMS program (e.g., IT, Engineering, Administrative). Governs which requisitions the vendor may respond to.' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedWorkLocations rdf:type rdf:Property ;
    rdfs:label 'Approved Work Locations' ;
    rdfs:comment 'Comma-separated list or free-text description of geographic locations or client site identifiers where the vendor is approved to place workers under this VMS program enrollment. Restricts vendor activity to authorized geographies.' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedReviewer rdf:type rdf:Property ;
    rdfs:label 'Assigned Reviewer' ;
    rdfs:comment 'Name or identifier of the MSP program staff member or VMS administrator assigned to review and manage this vendors enrollment and onboarding workflow tasks.' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingTaskFlag rdf:type rdf:Property ;
    rdfs:label 'Blocking Task Flag' ;
    rdfs:comment 'Indicates whether any onboarding task is currently flagged as blocking, meaning the vendor cannot achieve full program activation until the blocking task is resolved. True = one or more blocking tasks outstanding; False = no blocking tasks.' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceAttestationStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Attestation Status' ;
    rdfs:comment 'Status of the vendors completion of required compliance attestations within the VMS onboarding workflow, including acknowledgment of program rules, EEOC/OFCCP policies, co-employment guidelines, and data security requirements.' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractExecutionStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Execution Status' ;
    rdfs:comment 'Status of the vendors enrollment contract execution within the DocuSign CLM workflow. Executed = fully signed by all parties; Pending_Signature = awaiting one or more signatures; Under_Review = legal or compliance review in progress; Expired = contract term has ended.' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentSubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Document Submission Status' ;
    rdfs:comment 'Overall status of the vendors required document submission task within the VMS onboarding workflow. Documents typically include W-9, certificates of insurance, business licenses, and diversity certifications.' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicOnboardingComplete rdf:type rdf:Property ;
    rdfs:label 'Electronic Onboarding Complete' ;
    rdfs:comment 'Indicates whether the vendor has completed all required electronic onboarding steps within the VMS portal, including document submission, system training, and compliance attestation. True = fully completed; False = incomplete or in progress.' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrollmentAgreementRef rdf:type rdf:Property ;
    rdfs:label 'Enrollment Agreement Ref' ;
    rdfs:comment 'Reference number or document identifier for the executed enrollment agreement between the vendor and the MSP/client program. Links to the DocuSign CLM contract record for audit and compliance purposes.' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Expiry Date' ;
    rdfs:comment 'The date on which the vendors enrollment in the VMS program expires or is scheduled for renewal review. Null for open-ended enrollments. Satisfies EFFECTIVE_UNTIL category for MASTER_AGREEMENT role.' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentNotes rdf:type rdf:Property ;
    rdfs:label 'Enrollment Notes' ;
    rdfs:comment 'Free-text notes entered by the MSP program administrator or VMS coordinator regarding special conditions, exceptions, escalations, or context relevant to this vendors enrollment record.' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Externally-known business identifier for this enrollment record, assigned by the VMS system or MSP program administrator. Used in correspondence, audit trails, and supplier communications. Satisfies BUSINESS_IDENTIFIER category for MASTER_AGREEMENT role.' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle state of the vendors participation in the VMS program. Active = fully enrolled and eligible to submit workers; Pending = enrollment initiated but not yet complete; Under_Review = compliance or performance issue under investigation; Suspended = temporarily barred from submitting; Terminated = permanently removed from program. Satisfies LIFECYCLE_STATUS category for MASTER_AGREEMENT role.' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiry Date' ;
    rdfs:comment 'The date on which the vendors primary insurance coverage (e.g., general liability, workers compensation) expires. Used to trigger renewal reminders and compliance holds within the VMS program.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Insurance Verification Status' ;
    rdfs:comment 'Status of the vendors required insurance documentation verification within the VMS onboarding workflow. Verified = all required certificates of insurance confirmed; Pending = documents submitted but not yet reviewed; Expired = previously verified but coverage has lapsed; Waived = requirement waived by program administrator.' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msaReference rdf:type rdf:Property ;
    rdfs:label 'Msa Reference' ;
    rdfs:comment 'Reference identifier for the Master Service Agreement (MSA) governing the vendors participation in the program. The MSA establishes the overarching legal and commercial terms under which the vendor operates.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mspSponsor rdf:type rdf:Property ;
    rdfs:label 'Msp Sponsor' ;
    rdfs:comment 'Name of the Managed Service Provider (MSP) organization that sponsors and manages this vendors enrollment in the VMS program. Identifies the MSP entity responsible for vendor oversight and program compliance.' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingDueDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Due Date' ;
    rdfs:comment 'Target date by which the vendor must complete all onboarding tasks to achieve full program activation. Used for SLA tracking and escalation management within the MSP program.' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingTaskCount rdf:type rdf:Property ;
    rdfs:label 'Onboarding Task Count' ;
    rdfs:comment 'Total number of onboarding workflow tasks defined for this vendors enrollment in the VMS program. Used to calculate completion percentage and track overall onboarding progress.' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onboardingTasksCompleted rdf:type rdf:Property ;
    rdfs:label 'Onboarding Tasks Completed' ;
    rdfs:comment 'Number of onboarding workflow tasks that have been completed for this vendors enrollment. Compared against onboarding_task_count to determine overall completion progress.' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portalCredentialsStatus rdf:type rdf:Property ;
    rdfs:label 'Portal Credentials Status' ;
    rdfs:comment 'Status of the vendors VMS portal access credentials. Provisioned = active login credentials issued; Pending = credentials requested but not yet issued; Revoked = access removed due to termination or suspension; Expired = credentials have lapsed and require renewal.' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programActivationDate rdf:type rdf:Property ;
    rdfs:label 'Program Activation Date' ;
    rdfs:comment 'The date on which the vendor achieved full program activation status, meaning all onboarding tasks were completed and the vendor was cleared to submit workers or SOW resources into the program.' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'The date on which the vendors enrollment was suspended. Null if the vendor has never been suspended. Used for compliance tracking and reinstatement workflows.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:systemAccessStatus rdf:type rdf:Property ;
    rdfs:label 'System Access Status' ;
    rdfs:comment 'Status of the vendors VMS system access provisioning task, distinct from portal credentials status. Tracks whether IT/system access provisioning workflow has been completed for the vendor organizations designated users.' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Reason code for the termination of the vendors enrollment. Performance = removed due to poor performance metrics; Compliance_Failure = removed due to compliance violations; Voluntary_Exit = vendor chose to exit the program; Program_Restructure = program eliminated or restructured; Contract_Expiry = enrollment agreement expired without renewal.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompletionStatus rdf:type rdf:Property ;
    rdfs:label 'Training Completion Status' ;
    rdfs:comment 'Status of the vendors completion of required VMS portal and program training modules. Training typically covers system usage, submission workflows, timesheet approval processes, and compliance requirements.' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorType rdf:type rdf:Property ;
    rdfs:label 'Vendor Type' ;
    rdfs:comment 'Classification of the vendors business model within the program. Staffing_Agency = traditional temp/perm staffing; IC_Supplier = Independent Contractor (IC) supplier; SOW_Vendor = Statement of Work (SOW) project vendor; RPO_Provider = Recruitment Process Outsourcing (RPO) partner; MSP_Subvendor = subvendor operating under the MSP umbrella.' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:w9OnFile rdf:type rdf:Property ;
    rdfs:label 'W9 On File' ;
    rdfs:comment 'Indicates whether a valid IRS Form W-9 (Request for Taxpayer Identification Number and Certification) has been received and is on file for this vendor. Required for tax reporting and 1099 issuance. True = W-9 on file; False = not on file.' ;
    rdfs:domain ind:VmsEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:burdenRate rdf:type rdf:Property ;
    rdfs:label 'Burden Rate' ;
    rdfs:comment 'The total employer cost rate applied on top of the base pay rate to cover mandatory employer taxes and insurance costs including FICA, FUTA, SUTA, Workers Compensation (Workers Comp), and benefits. Expressed as a decimal (e.g., 0.18 = 18%). Used in gross margin and profitability analysis.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the country in which this rate card applies (e.g., USA, CAN, GBR). Supports international MSP programs and multi-country vendor rate management.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dtPayRate rdf:type rdf:Property ;
    rdfs:label 'Dt Pay Rate' ;
    rdfs:comment 'The negotiated hourly rate paid to the worker or vendor for double time (DT) hours. Expressed in the currency defined by the currency_code field. Applicable in states or contracts requiring double-time compensation.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrevailingWage rdf:type rdf:Property ;
    rdfs:label 'Is Prevailing Wage' ;
    rdfs:comment 'Indicates whether this rate card is subject to prevailing wage requirements under the Davis-Bacon Act, Service Contract Act (SCA), or state prevailing wage laws. When True, the pay rate must meet or exceed the applicable prevailing wage determination.' ;
    rdfs:domain ind:VendorRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnionRate rdf:type rdf:Property ;
    rdfs:label 'Is Union Rate' ;
    rdfs:comment 'Indicates whether this rate card applies to unionized workers governed by a Collective Bargaining Agreement (CBA). When True, the rates must comply with the applicable CBA wage scales and benefit requirements.' ;
    rdfs:domain ind:VendorRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobCategory rdf:type rdf:Property ;
    rdfs:label 'Job Category' ;
    rdfs:comment 'The broad occupational category for which this rate card applies (e.g., Information Technology, Light Industrial, Clerical, Professional, Healthcare, Engineering, Finance). Aligns with VMS job category taxonomy used in Beeline for rate benchmarking. [ENUM-REF-CANDIDATE: information_technology|light_industrial|clerical|professional|healthcare|engineering|finance|legal|creative|scientific — promote to reference product]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborCategory rdf:type rdf:Property ;
    rdfs:label 'Labor Category' ;
    rdfs:comment 'The labor engagement classification that determines how the worker is engaged and billed. staff_augmentation covers standard contingent placements; sow_resource covers Statement of Work (SOW) deliverable-based engagements; independent_contractor covers IC/1099 supplier resources; temp_to_perm covers contract-to-hire arrangements; direct_hire covers permanent placement; managed_service covers MSP-managed resources.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minBillRate rdf:type rdf:Property ;
    rdfs:label 'Min Bill Rate' ;
    rdfs:comment 'The floor bill rate below which the vendor may not submit candidates for this job category and skill level within the VMS program. Enforces rate card compliance and prevents below-floor rate submissions in the Beeline VMS.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiationNotes rdf:type rdf:Property ;
    rdfs:label 'Negotiation Notes' ;
    rdfs:comment 'Free-text field capturing key points, concessions, or conditions from the rate card negotiation process. Confidential business information used by MSP program managers and procurement teams for future rate renegotiations.' ;
    rdfs:domain ind:VendorRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otPayRate rdf:type rdf:Property ;
    rdfs:label 'Ot Pay Rate' ;
    rdfs:comment 'The negotiated hourly rate paid to the worker or vendor for overtime (OT) hours. Must comply with FLSA overtime requirements (minimum 1.5x regular pay rate). Expressed in the currency defined by the currency_code field.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCardDescription rdf:type rdf:Property ;
    rdfs:label 'Rate Card Description' ;
    rdfs:comment 'Free-text description providing additional context about the scope, applicability, or special conditions of this rate card (e.g., specific client programs, project types, or negotiation notes).' ;
    rdfs:domain ind:VendorRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardName rdf:type rdf:Property ;
    rdfs:label 'Rate Card Name' ;
    rdfs:comment 'Human-readable descriptive name for this rate card (e.g., FY2025 IT Staff Aug - Northeast - Senior). Used in VMS program management, vendor communications, and reporting dashboards for easy identification.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardNumber rdf:type rdf:Property ;
    rdfs:label 'Rate Card Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for this rate card, used in vendor communications, contract references, and VMS system cross-referencing. Typically prefixed with RC- followed by a program-specific code.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Card Status' ;
    rdfs:comment 'Current lifecycle state of the rate card. draft indicates pending negotiation; active indicates currently in effect; expired indicates past the expiration date; superseded indicates replaced by a newer version; suspended indicates temporarily inactive.' ;
    rdfs:domain ind:VendorRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRateCardCode rdf:type rdf:Property ;
    rdfs:label 'Source System Rate Card Code' ;
    rdfs:comment 'The native identifier of this rate card record in the originating source system (e.g., Beeline VMS rate card ID). Enables cross-system reconciliation and traceability between the lakehouse Silver layer and the operational system of record.' ;
    rdfs:domain ind:VendorRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardBillRate rdf:type rdf:Property ;
    rdfs:label 'Standard Bill Rate' ;
    rdfs:comment 'The negotiated hourly rate charged to the client for a worker at this job category and skill level during standard (straight-time) hours. Expressed in the currency defined by the currency_code field. This is the primary rate used for client invoicing.' ;
    rdfs:domain ind:VendorRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardPayRate rdf:type rdf:Property ;
    rdfs:label 'Standard Pay Rate' ;
    rdfs:comment 'The negotiated hourly rate paid to the worker or vendor for standard (straight-time) hours. Expressed in the currency defined by the currency_code field. Used in spread analysis and gross margin calculations.' ;
    rdfs:domain ind:VendorRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version identifier for this rate card (e.g., v1.0, v2.1), enabling tracking of rate card revisions over time and supporting historical rate benchmarking and audit trails.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Human-readable descriptive name of the rate agreement, typically including vendor name, client program, and engagement period (e.g., Acme Staffing — TechCorp IT Program FY2025).' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this executed rate agreement, used for cross-system reconciliation between Beeline VMS, DocuSign CLM, and Oracle NetSuite ERP.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the rate agreement. Controls whether rates under this agreement may be applied to active placements and job orders.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the rate agreement by engagement model. Determines applicable rate structures and compliance obligations. [ENUM-REF-CANDIDATE: msp_vendor|sow_vendor|ic_supplier|direct_placement|temp_to_perm|rpo_vendor — promote to reference product]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewal rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal' ;
    rdfs:comment 'Indicates whether this rate agreement automatically renews upon expiration unless either party provides written notice of termination within the notice period.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:burdenRateIncluded rdf:type rdf:Property ;
    rdfs:label 'Burden Rate Included' ;
    rdfs:comment 'Indicates whether the employer burden rate (FICA, FUTA, SUTA, Workers Compensation, benefits) is embedded within the agreed markup percentage or billed separately as a pass-through cost.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clmDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Clm Document Reference' ;
    rdfs:comment 'The internal DocuSign CLM document reference number or URL for the executed rate agreement, used for contract audit trail and legal record retention.' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dtMarkupPercentage rdf:type rdf:Property ;
    rdfs:label 'Dt Markup Percentage' ;
    rdfs:comment 'Negotiated markup percentage applied to double time (DT) hours billed under this agreement, applicable in states or contracts requiring double-time pay.' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationClause rdf:type rdf:Property ;
    rdfs:label 'Escalation Clause' ;
    rdfs:comment 'Indicates whether this rate agreement contains a rate escalation clause permitting periodic rate adjustments (e.g., annual CPI-linked increases) after the rate lock period expires.' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationFrequency rdf:type rdf:Property ;
    rdfs:label 'Escalation Frequency' ;
    rdfs:comment 'The frequency at which rate escalations may be applied under the escalation clause. Null if escalation_clause is False.' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationPercentage rdf:type rdf:Property ;
    rdfs:label 'Escalation Percentage' ;
    rdfs:comment 'The maximum allowable rate escalation percentage per escalation period as defined in the escalation clause. Null if escalation_clause is False. Expressed as a decimal (e.g., 0.0300 = 3%).' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'The date on which all required signatories completed execution of the rate agreement, making it legally binding. Captured from DocuSign CLM completion event.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:governingLawState rdf:type rdf:Property ;
    rdfs:label 'Governing Law State' ;
    rdfs:comment 'Two-letter US state code indicating the jurisdiction whose laws govern interpretation and enforcement of this rate agreement.' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxExceptionMarkupPct rdf:type rdf:Property ;
    rdfs:label 'Max Exception Markup Pct' ;
    rdfs:comment 'The maximum markup percentage permitted for approved rate exceptions under this agreement. Null if rate_exception_allowed is False.' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mspFeePercentage rdf:type rdf:Property ;
    rdfs:label 'Msp Fee Percentage' ;
    rdfs:comment 'The MSP program management fee percentage charged to the vendor supplier under this agreement, deducted from the bill rate or invoiced separately depending on program structure.' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otMarkupPercentage rdf:type rdf:Property ;
    rdfs:label 'Ot Markup Percentage' ;
    rdfs:comment 'Negotiated markup percentage applied to overtime (OT) hours billed under this agreement. May differ from the standard markup percentage per FLSA overtime billing conventions.' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perDiemIncluded rdf:type rdf:Property ;
    rdfs:label 'Per Diem Included' ;
    rdfs:comment 'Indicates whether per diem allowances for travel, lodging, and meals are included within the rate structure of this agreement or handled as separate expense reimbursements.' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programScope rdf:type rdf:Property ;
    rdfs:label 'Program Scope' ;
    rdfs:comment 'Geographic or organizational scope of this rate agreement — whether rates apply nationally, regionally, to a specific site, or globally across the clients enterprise.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateExceptionAllowed rdf:type rdf:Property ;
    rdfs:label 'Rate Exception Allowed' ;
    rdfs:comment 'Indicates whether approved rate exceptions above the negotiated rate card are permitted under this agreement for specialized skill sets or market-driven rate adjustments.' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateLockEndDate rdf:type rdf:Property ;
    rdfs:label 'Rate Lock End Date' ;
    rdfs:comment 'End date of the rate lock period. After this date, rates may be renegotiated per the escalation clause terms defined in this agreement.' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateLockStartDate rdf:type rdf:Property ;
    rdfs:label 'Rate Lock Start Date' ;
    rdfs:comment 'Start date of the rate lock period during which negotiated bill rates and pay rates cannot be unilaterally modified by either party.' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of calendar days prior to expiration that written notice must be provided to prevent auto-renewal or to initiate renegotiation of terms.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spreadCeilingAmount rdf:type rdf:Property ;
    rdfs:label 'Spread Ceiling Amount' ;
    rdfs:comment 'The maximum dollar spread (Bill Rate minus Pay Rate) permitted under this agreement, capping the MSP/staffing firms margin to protect vendor competitiveness. Expressed in USD.' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spreadFloorAmount rdf:type rdf:Property ;
    rdfs:label 'Spread Floor Amount' ;
    rdfs:comment 'The minimum dollar spread (Bill Rate minus Pay Rate) guaranteed under this agreement, ensuring the MSP/staffing firm retains a minimum gross margin regardless of pay rate fluctuations. Expressed in USD.' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of calendar days of advance written notice required by either party to terminate this rate agreement prior to its expiration date.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Vendor Signatory Name' ;
    rdfs:comment 'Full name of the authorized signatory representing the vendor supplier who executed this rate agreement.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmsFeePercentage rdf:type rdf:Property ;
    rdfs:label 'Vms Fee Percentage' ;
    rdfs:comment 'The VMS technology platform fee percentage (e.g., Beeline transaction fee) applicable to placements under this agreement, distinct from the MSP management fee.' ;
    rdfs:domain ind:RateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beelineSowId rdf:type rdf:Property ;
    rdfs:label 'Beeline Sow Id' ;
    rdfs:comment 'Unique identifier assigned to this SOW agreement within the Beeline Vendor Management System (VMS). Enables reconciliation between the vendor domain data product and the operational VMS platform.' ;
    rdfs:domain ind:SowAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sow .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Running count of formal amendments executed against this SOW agreement. Tracks the number of change orders or modifications to scope, value, or timeline since original execution.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coEmploymentRiskClassification rdf:type rdf:Property ;
    rdfs:label 'Co Employment Risk Classification' ;
    rdfs:comment 'Assessment of co-employment risk associated with this SOW engagement. High-risk SOWs may involve workers who could be deemed joint employees of the client, triggering FLSA, EEOC, or IRS worker classification concerns. Supports compliance monitoring.' ;
    rdfs:domain ind:SowAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverablesSummary rdf:type rdf:Property ;
    rdfs:label 'Deliverables Summary' ;
    rdfs:comment 'Summarized list or description of the specific outputs, work products, or outcomes the vendor is contractually obligated to deliver under this SOW. Supports deliverable-based program management.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docusignClmReference rdf:type rdf:Property ;
    rdfs:label 'Docusign Clm Reference' ;
    rdfs:comment 'Contract Lifecycle Management (CLM) reference number or document ID assigned by DocuSign CLM for the executed SOW agreement. Used for legal document retrieval and audit trail.' ;
    rdfs:domain ind:SowAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Ic Compliance Verified' ;
    rdfs:comment 'Indicates whether the Independent Contractor (IC) compliance review has been completed for this SOW engagement, confirming the vendors workers meet IRS and state-level IC classification criteria.' ;
    rdfs:domain ind:SowAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceCertificateRequired rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Required' ;
    rdfs:comment 'Indicates whether the vendor is required to provide a certificate of insurance (COI) as a condition of this SOW. Typically required for general liability, workers compensation, and professional liability coverage.' ;
    rdfs:domain ind:SowAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latestAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Latest Amendment Date' ;
    rdfs:comment 'Date of the most recent formal amendment executed against this SOW agreement. Null if no amendments have been executed. Supports amendment history tracking.' ;
    rdfs:domain ind:SowAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneCount rdf:type rdf:Property ;
    rdfs:label 'Milestone Count' ;
    rdfs:comment 'Total number of payment or delivery milestones defined in the SOW milestone schedule. Used for milestone-based pricing structures and progress tracking.' ;
    rdfs:domain ind:SowAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ndaRequired rdf:type rdf:Property ;
    rdfs:label 'Nda Required' ;
    rdfs:comment 'Indicates whether a Non-Disclosure Agreement (NDA) is required as a condition of this SOW engagement. When true, the NDA must be executed before work commences.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonCompeteRequired rdf:type rdf:Property ;
    rdfs:label 'Non Compete Required' ;
    rdfs:comment 'Indicates whether a non-compete clause or agreement is required for workers engaged under this SOW. Relevant for sensitive client engagements involving proprietary processes or competitive intelligence.' ;
    rdfs:domain ind:SowAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notToExceedAmount rdf:type rdf:Property ;
    rdfs:label 'Not To Exceed Amount' ;
    rdfs:comment 'Maximum authorized spend ceiling for T&M or NTE-structured SOW agreements. Vendor billings may not exceed this threshold without a formal amendment. Null for fixed-price SOWs.' ;
    rdfs:domain ind:SowAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingStructure rdf:type rdf:Property ;
    rdfs:label 'Pricing Structure' ;
    rdfs:comment 'Defines the commercial pricing model for the SOW engagement. Fixed Price (FP) means a set total cost regardless of effort; Time and Materials (T&M) means billing based on hours and expenses; Milestone-Based ties payments to deliverable completion; Not-to-Exceed (NTE) caps total spend.' ;
    rdfs:domain ind:SowAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectTitle rdf:type rdf:Property ;
    rdfs:label 'Project Title' ;
    rdfs:comment 'Human-readable title or name of the project or engagement described in this Statement of Work. Used in reporting, dashboards, and client communications.' ;
    rdfs:domain ind:SowAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Narrative description of the project scope, objectives, and work to be performed under this SOW. Captures the high-level summary of deliverables and responsibilities as defined in the executed agreement.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sowStatus rdf:type rdf:Property ;
    rdfs:label 'Sow Status' ;
    rdfs:comment 'Current lifecycle state of the SOW agreement. Tracks progression from initial drafting through execution, active delivery, and final closure or early termination.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sowType rdf:type rdf:Property ;
    rdfs:label 'Sow Type' ;
    rdfs:comment 'Classification of the SOW engagement type. Project-Based SOWs have defined scope and timeline; Deliverable-Based SOWs are tied to specific outputs; Managed Service SOWs involve ongoing operational management; Consulting SOWs cover advisory services; Staffing SOWs are distinct from staff augmentation. [ENUM-REF-CANDIDATE: project_based|deliverable_based|managed_service|consulting|staffing_sow — promote to reference product]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'The contractually agreed date on which the SOW engagement commences and the vendor begins work or deliverable execution. Represents the effective-from date of the agreement.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalContractValue rdf:type rdf:Property ;
    rdfs:label 'Total Contract Value' ;
    rdfs:comment 'The total monetary value of the SOW agreement as executed, representing the maximum authorized spend or fixed price for the full scope of work. Expressed in USD.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activeAssignmentCount rdf:type rdf:Property ;
    rdfs:label 'Active Assignment Count' ;
    rdfs:comment 'Number of active worker assignments managed by this vendor at the end of the evaluation period. Reflects the vendors current headcount contribution to the program.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentCompletionRate rdf:type rdf:Property ;
    rdfs:label 'Assignment Completion Rate' ;
    rdfs:comment 'Percentage of assignments placed by this vendor that were completed through the scheduled end date during the evaluation period. Expressed as a decimal (e.g., 0.9200 = 92%). Complement of the fall-off rate.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Client Satisfaction Rating' ;
    rdfs:comment 'Average client satisfaction rating for this vendor during the evaluation period, collected via structured client feedback surveys. Expressed on a 1.00–5.00 scale. Distinct from NPS — captures direct satisfaction rather than likelihood to recommend.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceRate rdf:type rdf:Property ;
    rdfs:label 'Compliance Rate' ;
    rdfs:comment 'Percentage of vendor-placed workers who met all required compliance and credentialing requirements (I-9, background checks, drug screens, certifications) on time during the evaluation period. Expressed as a decimal.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Submitted Date' ;
    rdfs:comment 'Calendar date on which the vendor formally submitted a dispute against this scorecard. Populated when scorecard_status is disputed. Used to track dispute resolution SLA compliance.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'Last calendar date of the performance measurement window covered by this scorecard. Defines the inclusive end boundary for all KPI calculations.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'First calendar date of the performance measurement window covered by this scorecard. Defines the inclusive start boundary for all KPI calculations.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodType rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Type' ;
    rdfs:comment 'Frequency cadence of the scorecard evaluation cycle. Determines how often vendor KPIs are formally assessed and published within the MSP/VMS program.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluatorNotes rdf:type rdf:Property ;
    rdfs:label 'Evaluator Notes' ;
    rdfs:comment 'Free-text qualitative commentary entered by the MSP program manager or evaluator summarizing vendor performance highlights, concerns, and context for the evaluation period. Supports narrative reporting alongside quantitative KPIs.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalizedDate rdf:type rdf:Property ;
    rdfs:label 'Finalized Date' ;
    rdfs:comment 'Calendar date on which the scorecard was finalized and locked, either after the dispute window expired without challenge or after dispute resolution was completed. Marks the record as immutable for historical reporting.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:improvementPlanDueDate rdf:type rdf:Property ;
    rdfs:label 'Improvement Plan Due Date' ;
    rdfs:comment 'Deadline by which the vendor must submit their Performance Improvement Plan in response to a below-threshold scorecard. Populated when improvement_plan_required is True.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:improvementPlanRequired rdf:type rdf:Property ;
    rdfs:label 'Improvement Plan Required' ;
    rdfs:comment 'Indicates whether this scorecard evaluation has triggered a requirement for the vendor to submit a formal Performance Improvement Plan (PIP). True when overall score falls below the program-defined minimum threshold.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interviewToOfferRatio rdf:type rdf:Property ;
    rdfs:label 'Interview To Offer Ratio' ;
    rdfs:comment 'Ratio of candidate interviews that resulted in a job offer during the evaluation period. Expressed as a decimal (e.g., 0.5000 = 50%). Indicates vendor effectiveness in presenting placeable candidates.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jobOrderFillRate rdf:type rdf:Property ;
    rdfs:label 'Job Order Fill Rate' ;
    rdfs:comment 'Percentage of job orders assigned to this vendor that were successfully filled during the evaluation period. Expressed as a decimal (e.g., 0.8500 = 85%). Measures vendor responsiveness and capacity to fulfill requisitions.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'Net Promoter Score reflecting client satisfaction with this vendors performance during the evaluation period. Ranges from -100 to +100. Derived from client survey responses collected through the MSP program.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerToStartRatio rdf:type rdf:Property ;
    rdfs:label 'Offer To Start Ratio' ;
    rdfs:comment 'Ratio of job offers extended that resulted in a candidate starting the assignment during the evaluation period. Expressed as a decimal (e.g., 0.9000 = 90%). Measures vendor reliability in converting offers to active placements.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTimeSubmittalRate rdf:type rdf:Property ;
    rdfs:label 'On Time Submittal Rate' ;
    rdfs:comment 'Percentage of candidate submittals delivered by this vendor within the program-defined SLA submittal window during the evaluation period. Expressed as a decimal. Measures adherence to program SLA timelines.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallScore rdf:type rdf:Property ;
    rdfs:label 'Overall Score' ;
    rdfs:comment 'Composite weighted performance score for the vendor across all KPI dimensions for the evaluation period. Expressed as a numeric value on a 0–100 scale. Drives tier reclassification and program allocation decisions.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallScoreGrade rdf:type rdf:Property ;
    rdfs:label 'Overall Score Grade' ;
    rdfs:comment 'Letter grade derived from the overall performance score, providing a simplified qualitative summary for executive reporting and vendor communications. A=Excellent, B=Good, C=Satisfactory, D=Below Standard, F=Failing.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Program Allocation Pct' ;
    rdfs:comment 'Percentage of total program job order volume allocated to this vendor during the evaluation period. Expressed as a percentage (e.g., 25.00 = 25%). Used to assess vendor share-of-wallet and inform future allocation decisions.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publishedDate rdf:type rdf:Property ;
    rdfs:label 'Published Date' ;
    rdfs:comment 'Calendar date on which the scorecard was formally published and made available to the vendor. Marks the transition from draft to published status and starts the vendor review/dispute window.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qosScore rdf:type rdf:Property ;
    rdfs:label 'Qos Score' ;
    rdfs:comment 'KPI score measuring the quality of candidate submittals from this vendor — assessing how well submitted candidates match job order requirements. Scored on a 0–100 scale. A core MSP/VMS program metric.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedTier rdf:type rdf:Property ;
    rdfs:label 'Recommended Tier' ;
    rdfs:comment 'The vendor tier classification recommended as a result of this scorecard evaluation. Populated only when tier_change_recommended is True. Subject to program manager approval before taking effect. [ENUM-REF-CANDIDATE: tier_1|tier_2|tier_3|preferred|approved|probation — promote to reference product]' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redeploymentRate rdf:type rdf:Property ;
    rdfs:label 'Redeployment Rate' ;
    rdfs:comment 'Percentage of workers placed by this vendor who were successfully redeployed to a new assignment upon completion of their prior assignment during the evaluation period. Expressed as a decimal. Measures vendors ability to retain and redeploy talent.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scorecardNumber rdf:type rdf:Property ;
    rdfs:label 'Scorecard Number' ;
    rdfs:comment 'Externally-visible business identifier for the scorecard, used in vendor communications, dispute resolution, and program reporting. Format: SC-YYYY-NNNNNN.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardStatus rdf:type rdf:Property ;
    rdfs:label 'Scorecard Status' ;
    rdfs:comment 'Current lifecycle state of the vendor performance scorecard. Draft: under preparation; Published: shared with vendor; Disputed: vendor has raised a formal challenge; Finalized: accepted and locked; Archived: historical record.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Score' ;
    rdfs:comment 'Composite score measuring the vendors overall adherence to all program-defined SLA requirements during the evaluation period. Scored on a 0–100 scale. Encompasses submittal timeliness, onboarding compliance, and reporting obligations.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submittalCount rdf:type rdf:Property ;
    rdfs:label 'Submittal Count' ;
    rdfs:comment 'Total number of candidate submittals made by this vendor during the evaluation period. Denominator for submittal-to-interview and QoS ratio calculations.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submittalToInterviewRatio rdf:type rdf:Property ;
    rdfs:label 'Submittal To Interview Ratio' ;
    rdfs:comment 'Ratio of candidate submittals that resulted in a client interview during the evaluation period. Expressed as a decimal (e.g., 0.4000 = 40%). Measures the relevance and quality of vendor submissions.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierChangeRecommended rdf:type rdf:Property ;
    rdfs:label 'Tier Change Recommended' ;
    rdfs:comment 'Indicates whether this scorecard evaluation has triggered a recommendation to reclassify the vendors tier designation. True if the overall score warrants a tier upgrade or downgrade per program thresholds.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ttfAvgDays rdf:type rdf:Property ;
    rdfs:label 'Ttf Avg Days' ;
    rdfs:comment 'Average number of calendar days from job order receipt to first qualified submittal by this vendor during the evaluation period. Raw metric underlying the TTF score.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ttfScore rdf:type rdf:Property ;
    rdfs:label 'Ttf Score' ;
    rdfs:comment 'KPI score measuring the vendors performance on Time to Fill — the elapsed time from job order receipt to candidate submittal or placement confirmation. Scored on a 0–100 scale relative to program SLA benchmarks.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorTier rdf:type rdf:Property ;
    rdfs:label 'Vendor Tier' ;
    rdfs:comment 'Vendor tier designation at the time of this scorecard evaluation. Captures the tier in effect during the evaluation period and may trigger reclassification upon finalization. [ENUM-REF-CANDIDATE: tier_1|tier_2|tier_3|preferred|approved|probation — promote to reference product]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactId rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Id' ;
    rdfs:comment 'Unique system-generated identifier for the vendor contact record. Primary key for the vendor_contact data product.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorContact .

ind:communicationOptOut rdf:type rdf:Property ;
    rdfs:label 'Communication Opt Out' ;
    rdfs:comment 'Indicates whether this vendor contact has opted out of non-essential communications such as marketing, newsletters, or program announcements. Mandatory for GDPR/CCPA compliance.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactSource rdf:type rdf:Property ;
    rdfs:label 'Contact Source' ;
    rdfs:comment 'Originating system or method through which this vendor contact record was created. Used for data lineage tracking and source system reconciliation.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the vendor contact record. Drives whether the contact is included in active communication routing and program operations.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'The department or business unit within the vendor organization where this contact works (e.g., Recruiting, Operations, Finance, Compliance). Supports organizational mapping and routing.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary business email address of the vendor contact. Used for MSP program communications, submittal notifications, compliance alerts, and billing correspondence.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalContactCode rdf:type rdf:Property ;
    rdfs:label 'External Contact Code' ;
    rdfs:comment 'Identifier for this vendor contact as recorded in the originating source system (e.g., Beeline VMS contact ID, Bullhorn contact ID). Used for cross-system reconciliation and data integration.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Legal first (given) name of the vendor contact individual. Used for personalized communication and formal correspondence.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Full display name of the vendor contact (first + last name). Used in UI displays, reports, and communication templates within MSP program operations.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBillingContact rdf:type rdf:Property ;
    rdfs:label 'Is Billing Contact' ;
    rdfs:comment 'Indicates whether this contact is designated to receive billing-related communications including invoices, payment remittances, and billing dispute notifications.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isComplianceContact rdf:type rdf:Property ;
    rdfs:label 'Is Compliance Contact' ;
    rdfs:comment 'Indicates whether this contact is designated to receive compliance-related communications including I-9 verification notices, credentialing alerts, and regulatory audit requests.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this individual is the designated primary contact for the vendor organization within the MSP/VMS program. Only one contact per vendor should be flagged as primary at any given time.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVmsPortalUser rdf:type rdf:Property ;
    rdfs:label 'Is Vms Portal User' ;
    rdfs:comment 'Indicates whether this vendor contact has an active user account in the Beeline VMS portal for submitting candidates, managing timesheets, and accessing program data.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'Most recent date on which the MSP program team had a documented interaction with this vendor contact. Used for relationship health monitoring and engagement cadence management.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Legal last (family/surname) name of the vendor contact individual. Used for formal identification and correspondence.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedinUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Url' ;
    rdfs:comment 'LinkedIn professional profile URL for the vendor contact. Used for professional verification, relationship management, and talent acquisition partnership activities.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'Mobile/cell phone number for the vendor contact. Used for urgent communications, SMS notifications, and after-hours contact in time-sensitive staffing situations.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaSignedDate rdf:type rdf:Property ;
    rdfs:label 'Nda Signed Date' ;
    rdfs:comment 'Date on which the vendor contact executed the Non-Disclosure Agreement. Used for compliance tracking and NDA renewal management.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextScheduledContactDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Contact Date' ;
    rdfs:comment 'Planned date for the next scheduled outreach or business review with this vendor contact. Supports proactive relationship management and QBR (Quarterly Business Review) scheduling.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:officeAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Office Address Line1' ;
    rdfs:comment 'Primary street address line for the vendor contacts office location. Used for formal correspondence, site visit coordination, and geographic program mapping.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeCity rdf:type rdf:Property ;
    rdfs:label 'Office City' ;
    rdfs:comment 'City of the vendor contacts office location. Supports geographic segmentation and regional program management.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeCountry rdf:type rdf:Property ;
    rdfs:label 'Office Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the vendor contacts office location (e.g., USA, CAN, GBR). Supports international MSP program operations and regulatory jurisdiction determination.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officePostalCode rdf:type rdf:Property ;
    rdfs:label 'Office Postal Code' ;
    rdfs:comment 'ZIP/postal code of the vendor contacts office location. Used for geographic routing and regional program management.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeState rdf:type rdf:Property ;
    rdfs:label 'Office State' ;
    rdfs:comment 'U.S. state or territory code (2-letter USPS abbreviation) of the vendor contacts office location. Used for regional program assignment and compliance jurisdiction determination.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary office/desk phone number for the vendor contact. Used for direct business communication within MSP program operations.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneExtension rdf:type rdf:Property ;
    rdfs:label 'Phone Extension' ;
    rdfs:comment 'Office phone extension number for the vendor contact. Required when the vendor organization uses a PBX system and direct dial is not available.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'The vendor contacts preferred channel for receiving communications from the MSP program team. Drives automated notification routing and outreach strategy.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programAccessLevel rdf:type rdf:Property ;
    rdfs:label 'Program Access Level' ;
    rdfs:comment 'Level of access granted to this vendor contact within the Beeline VMS program portal. Controls what program data, rate cards, and candidate submissions the contact can view or manage.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleType rdf:type rdf:Property ;
    rdfs:label 'Role Type' ;
    rdfs:comment 'Functional role classification of the vendor contact within the MSP/VMS program relationship. Determines communication routing and program responsibilities. [ENUM-REF-CANDIDATE: account_manager|recruiter|compliance_officer|billing_contact|executive_sponsor|operations_manager|technical_contact|onboarding_coordinator — promote to reference product]' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the vendor contacts primary work location (e.g., America/New_York, America/Chicago). Used to schedule communications and meetings at appropriate local times.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmsPortalUsername rdf:type rdf:Property ;
    rdfs:label 'Vms Portal Username' ;
    rdfs:comment 'Username assigned to the vendor contact for accessing the Beeline VMS supplier portal. Used for portal access tracking and account management.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programAllocationId rdf:type rdf:Property ;
    rdfs:label 'Program Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for each vendor program allocation record within the Beeline VMS-managed contingent workforce program. Primary key for this entity.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgramAllocation .

ind:allocationCode rdf:type rdf:Property ;
    rdfs:label 'Allocation Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this allocation record within the Beeline VMS program. Used in MSP reporting and vendor communications to reference a specific fill-rate assignment.' ;
    rdfs:domain ind:ProgramAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPct rdf:type rdf:Property ;
    rdfs:label 'Allocation Pct' ;
    rdfs:comment 'The requisition fill-rate allocation percentage assigned to this vendor for the specified job category within the VMS program. Represents the share of job orders this vendor is expected to fill relative to total program volume. Sum of all active vendor allocations per program and job category should equal 100%.' ;
    rdfs:domain ind:ProgramAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current lifecycle state of this vendor program allocation. Active: vendor is receiving job order distributions. Suspended: temporarily halted due to compliance or performance issues. Exhausted: submission quota has been fully consumed. Pending: awaiting activation. Expired: past expiration date. Terminated: permanently removed from program.' ;
    rdfs:domain ind:ProgramAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoDistribute rdf:type rdf:Property ;
    rdfs:label 'Auto Distribute' ;
    rdfs:comment 'Indicates whether job orders matching this allocations job category are automatically distributed to this vendor by Beeline VMS without manual MSP intervention. When True, the VMS auto-routes requisitions based on tier and allocation percentage. When False, manual distribution is required.' ;
    rdfs:domain ind:ProgramAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceVerified rdf:type rdf:Property ;
    rdfs:label 'Compliance Verified' ;
    rdfs:comment 'Indicates whether the vendor has completed all required compliance verifications (insurance certificates, E-Verify enrollment, background check program agreement, OFCCP compliance attestation) to be active under this program allocation.' ;
    rdfs:domain ind:ProgramAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Verified Date' ;
    rdfs:comment 'The date on which the vendors compliance credentials were last verified and confirmed as meeting program requirements. Used to track compliance currency and trigger re-verification workflows.' ;
    rdfs:domain ind:ProgramAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusiveCategory rdf:type rdf:Property ;
    rdfs:label 'Exclusive Category' ;
    rdfs:comment 'Indicates whether this vendor holds exclusive rights to fill requisitions in the specified job category within this VMS program. When True, no other vendor may receive job order distributions for this category. Typically reserved for niche or specialized labor categories.' ;
    rdfs:domain ind:ProgramAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstLookDays rdf:type rdf:Property ;
    rdfs:label 'First Look Days' ;
    rdfs:comment 'The number of business days this vendor has exclusive or priority access to a new requisition before it is released to lower-tier vendors. Enforces preferred supplier first-look access per MSP program rules. Applicable only to Tier 1 and Preferred vendors.' ;
    rdfs:domain ind:ProgramAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'The date on which this allocation was last reviewed by the MSP program manager, typically as part of a periodic scorecard-driven tier reclassification cycle. Supports governance audit trails and ensures allocations are not stale.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxConcurrentSubmissions rdf:type rdf:Property ;
    rdfs:label 'Max Concurrent Submissions' ;
    rdfs:comment 'The maximum number of candidate submittals this vendor is permitted to have active simultaneously for a single requisition within this program and job category. Controls submission quota per Beeline VMS program configuration to enforce Quality of Submission (QoS) standards.' ;
    rdfs:domain ind:ProgramAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxMarkupPct rdf:type rdf:Property ;
    rdfs:label 'Max Markup Pct' ;
    rdfs:comment 'The maximum markup percentage (bill rate minus pay rate, divided by pay rate) the vendor is permitted to apply for placements under this allocation. Enforces MSP program margin controls and prevents rate gouging. Expressed as a percentage.' ;
    rdfs:domain ind:ProgramAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxPayRate rdf:type rdf:Property ;
    rdfs:label 'Max Pay Rate' ;
    rdfs:comment 'The maximum hourly pay rate the vendor is authorized to pay workers placed under this allocation and job category. Used to enforce spread and markup controls within the MSP program. Expressed in USD.' ;
    rdfs:domain ind:ProgramAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minFillRatePct rdf:type rdf:Property ;
    rdfs:label 'Min Fill Rate Pct' ;
    rdfs:comment 'The minimum requisition fill rate percentage the vendor is contractually required to achieve for this job category within the program period. Used as a performance threshold in scorecard evaluations and tier reclassification decisions. Expressed as a percentage of assigned requisitions successfully filled.' ;
    rdfs:domain ind:ProgramAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otBillRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Ot Bill Rate Multiplier' ;
    rdfs:comment 'The multiplier applied to the standard bill rate for overtime hours billed by the vendor under this allocation. Typically 1.5x for OT and 2.0x for double time (DT). Governs how overtime billing is calculated for workers placed under this program.' ;
    rdfs:domain ind:ProgramAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric rank of this vendor within its assigned tier for the job category. Lower values indicate higher priority for job order distribution when multiple vendors share the same tier. Used by Beeline VMS to sequence first-look access among same-tier suppliers.' ;
    rdfs:domain ind:ProgramAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the workforce program under which this allocation operates. MSP: Managed Service Provider program. VMS: Vendor Management System-only program. RPO: Recruitment Process Outsourcing. SOW: Statement of Work-based engagement. IC: Independent Contractor supplier program. Direct: direct client-managed program.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCycle rdf:type rdf:Property ;
    rdfs:label 'Review Cycle' ;
    rdfs:comment 'The frequency at which this vendor program allocation is reviewed and potentially updated based on scorecard performance and tier reclassification decisions. Governs the cadence of MSP program management activities.' ;
    rdfs:domain ind:ProgramAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'The reason code for why this allocation was suspended, if applicable. Populated when allocation_status is suspended. Supports MSP program governance and vendor remediation tracking. [ENUM-REF-CANDIDATE: performance|compliance|rate_violation|contract_breach|client_request|audit_hold|other — promote to reference product if additional values needed]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTimeToFillDays rdf:type rdf:Property ;
    rdfs:label 'Target Time To Fill Days' ;
    rdfs:comment 'The target number of business days within which the vendor is expected to submit qualified candidates for a requisition under this allocation. Represents the Time to Fill (TTF) SLA commitment for this vendor-program-job category combination.' ;
    rdfs:domain ind:ProgramAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetTimeToStartDays rdf:type rdf:Property ;
    rdfs:label 'Target Time To Start Days' ;
    rdfs:comment 'The target number of calendar days from requisition approval to worker start date for placements made under this allocation. Represents the Time to Start (TTS) SLA commitment for this vendor-program-job category combination.' ;
    rdfs:domain ind:ProgramAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vmsAllocationRef rdf:type rdf:Property ;
    rdfs:label 'Vms Allocation Ref' ;
    rdfs:comment 'The native allocation or supplier program enrollment reference number assigned by Beeline VMS for this vendor-program-job category combination. Used for cross-system reconciliation between the lakehouse silver layer and the Beeline VMS operational system.' ;
    rdfs:domain ind:ProgramAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorComplianceId rdf:type rdf:Property ;
    rdfs:label 'Vendor Compliance Id' ;
    rdfs:comment 'Unique surrogate identifier for each vendor compliance record in the MSP/VMS program. Primary key for the vendor_compliance data product.' ;
    rdfs:domain ind:VendorCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertTriggered rdf:type rdf:Property ;
    rdfs:label 'Alert Triggered' ;
    rdfs:comment 'Indicates whether a compliance expiration alert has been triggered for this record based on the configured alert threshold. True when the current date is within alert_threshold_days of document_expiration_date.' ;
    rdfs:domain ind:VendorCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateHolder rdf:type rdf:Property ;
    rdfs:label 'Certificate Holder' ;
    rdfs:comment 'Name of the entity listed as the certificate holder on the COI — typically the MSP, the end client, or both. The certificate holder is notified by the carrier in the event of policy cancellation or material change. Applicable only when is_insurance_record is True.' ;
    rdfs:domain ind:VendorCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coiDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Coi Document Reference' ;
    rdfs:comment 'File path, document management system reference, or DocuSign CLM document ID for the actual Certificate of Insurance (COI) PDF submitted by the vendor. Distinct from the general document_reference field; specifically tracks the COI artifact. Applicable only when is_insurance_record is True.' ;
    rdfs:domain ind:VendorCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCategory rdf:type rdf:Property ;
    rdfs:label 'Compliance Category' ;
    rdfs:comment 'High-level category of the compliance obligation being tracked. Covers insurance certificates, E-Verify enrollment, EEOC/OFCCP obligations, OSHA safety programs, FCRA background check policies, I-9 audit readiness, workers compensation registration, FUTA/SUTA tax registration, non-compete policy, and data security (SOC 2). [ENUM-REF-CANDIDATE: insurance|e_verify|eeoc|ofccp|osha|fcra|i9_audit|workers_comp|futa_suta|non_compete|data_security|other — promote to reference product]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current compliance disposition for this obligation. compliant indicates all requirements are met; non_compliant indicates a deficiency exists; pending_review indicates documents have been submitted and are under evaluation; waived indicates the MSP or client has formally waived this requirement for the vendor.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Coverage Limit Amount' ;
    rdfs:comment 'Maximum dollar amount of coverage provided under the insurance policy per occurrence or in aggregate, as stated on the Certificate of Insurance (COI). Expressed in USD. Used to verify that vendor coverage meets MSP/client minimum requirements. Applicable only when is_insurance_record is True.' ;
    rdfs:domain ind:VendorCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageLimitType rdf:type rdf:Property ;
    rdfs:label 'Coverage Limit Type' ;
    rdfs:comment 'Specifies whether the coverage_limit_amount represents a per-occurrence limit, an aggregate annual limit, or a per-claim limit. Critical for accurately assessing whether vendor coverage meets program requirements. Applicable only when is_insurance_record is True.' ;
    rdfs:domain ind:VendorCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Document Effective Date' ;
    rdfs:comment 'Date on which the submitted compliance document or certificate becomes effective and valid. For insurance certificates, this is the policy inception date. For regulatory filings, this is the filing effective date.' ;
    rdfs:domain ind:VendorCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Document Expiration Date' ;
    rdfs:comment 'Date on which the compliance document or certificate expires and must be renewed. Triggers automated compliance alerts when the expiration date is within the configured alert threshold. Critical for insurance COIs, SOC 2 reports, and E-Verify MOUs.' ;
    rdfs:domain ind:VendorCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:everifyEmployerNumber rdf:type rdf:Property ;
    rdfs:label 'Everify Employer Number' ;
    rdfs:comment 'The E-Verify employer identification number assigned by USCIS to the vendor upon enrollment in the E-Verify program. Required for vendors operating under federal contracts subject to FAR E-Verify clause. Applicable for compliance_category = e_verify.' ;
    rdfs:domain ind:VendorCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:everifyEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Everify Enrollment Date' ;
    rdfs:comment 'Date on which the vendor enrolled in the E-Verify program with USCIS. Used to verify continuous enrollment and compliance with federal contractor E-Verify requirements. Applicable for compliance_category = e_verify.' ;
    rdfs:domain ind:VendorCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceType rdf:type rdf:Property ;
    rdfs:label 'Insurance Type' ;
    rdfs:comment 'Type of insurance coverage documented in this compliance record. Covers the five standard insurance types required in MSP/VMS programs: general liability, professional liability (Errors & Omissions/E&O), workers compensation, cyber liability, and umbrella/excess liability. Applicable only when is_insurance_record is True.' ;
    rdfs:domain ind:VendorCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isInsuranceRecord rdf:type rdf:Property ;
    rdfs:label 'Is Insurance Record' ;
    rdfs:comment 'Indicates whether this compliance record is an insurance-category record requiring additional insurance-specific fields (certificate number, carrier, policy number, coverage limit, etc.). When True, all insurance sub-fields must be populated.' ;
    rdfs:domain ind:VendorCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemDescription rdf:type rdf:Property ;
    rdfs:label 'Item Description' ;
    rdfs:comment 'Detailed narrative describing the compliance obligation, regulatory basis, and what the vendor must demonstrate to satisfy the requirement. Provides context for compliance officers and auditors reviewing the record.' ;
    rdfs:domain ind:VendorCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemName rdf:type rdf:Property ;
    rdfs:label 'Item Name' ;
    rdfs:comment 'Short, human-readable name of the specific compliance item or obligation (e.g., General Liability Insurance Certificate, E-Verify Employer Enrollment, OSHA 300 Log Submission, SOC 2 Type II Report). Used as the display label in compliance dashboards and audit reports.' ;
    rdfs:domain ind:VendorCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonCompetePolicyOnFile rdf:type rdf:Property ;
    rdfs:label 'Non Compete Policy On File' ;
    rdfs:comment 'Indicates whether the vendor has a documented non-compete or non-solicitation policy on file with the MSP program, as required by the Master Service Agreement (MSA). Prevents vendors from directly soliciting placed workers or end clients.' ;
    rdfs:domain ind:VendorCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Policy Effective Date' ;
    rdfs:comment 'Date on which the insurance policy becomes effective, as stated on the Certificate of Insurance. May differ from document_effective_date if the COI was issued after the policy inception date. Applicable only when is_insurance_record is True.' ;
    rdfs:domain ind:VendorCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Policy Expiration Date' ;
    rdfs:comment 'Date on which the insurance policy expires, as stated on the Certificate of Insurance. Used as the primary expiration trigger for insurance-category compliance alerts. Applicable only when is_insurance_record is True.' ;
    rdfs:domain ind:VendorCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationNotes rdf:type rdf:Property ;
    rdfs:label 'Remediation Notes' ;
    rdfs:comment 'Free-text notes documenting the remediation plan, corrective actions taken, or outstanding steps required to bring a non-compliant vendor into compliance. Captured by the assigned compliance officer and visible in audit trails.' ;
    rdfs:domain ind:VendorCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredDocumentType rdf:type rdf:Property ;
    rdfs:label 'Required Document Type' ;
    rdfs:comment 'Type of document the vendor must submit to satisfy this compliance item (e.g., Certificate of Insurance (COI), E-Verify MOU, OSHA 300 Log, SOC 2 Report, W-9, I-9 Audit Report). Drives document collection workflows in the VMS program.' ;
    rdfs:domain ind:VendorCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soc2ReportType rdf:type rdf:Property ;
    rdfs:label 'Soc2 Report Type' ;
    rdfs:comment 'Specifies whether the vendors data security compliance is evidenced by a SOC 2 Type I (point-in-time design assessment) or SOC 2 Type II (operational effectiveness over a period) report. Type II is the standard requirement for MSP/VMS data security compliance. Applicable for compliance_category = data_security.' ;
    rdfs:domain ind:VendorCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source Record Code' ;
    rdfs:comment 'The native record identifier from the originating source system (e.g., Beeline VMS compliance record ID, DocuSign envelope ID). Used for cross-system reconciliation and deduplication in the Silver Layer.' ;
    rdfs:domain ind:VendorCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Expiration Date' ;
    rdfs:comment 'Date on which an approved compliance waiver expires and the vendor must re-demonstrate compliance or obtain a new waiver. Prevents indefinite waivers from masking persistent compliance gaps.' ;
    rdfs:domain ind:VendorCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredSupplierListId rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier List Id' ;
    rdfs:comment 'Unique system-generated identifier for a Preferred Supplier List (PSL) entry. Primary key for this entity. Entity role: JUNCTION — associates a vendor with a client program and job category within a governed PSL framework, carrying its own lifecycle attributes (status, dates, approval authority, version).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PreferredSupplierList .

ind:clientNotes rdf:type rdf:Property ;
    rdfs:label 'Client Notes' ;
    rdfs:comment 'Free-text field for client-specific instructions, preferences, or annotations related to this vendors PSL entry. May include preferred contact protocols, special billing instructions, or program-specific requirements communicated by the client.' ;
    rdfs:domain ind:PreferredSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionalNotes rdf:type rdf:Property ;
    rdfs:label 'Conditional Notes' ;
    rdfs:comment 'Free-text field capturing client-specific conditions, restrictions, or instructions applicable to this PSL entry when the status is conditional. Examples include geographic restrictions, role-level caps, or specific compliance prerequisites the vendor must meet.' ;
    rdfs:domain ind:PreferredSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversityCertified rdf:type rdf:Property ;
    rdfs:label 'Diversity Certified' ;
    rdfs:comment 'Indicates whether the vendor holds a current, verified diversity certification applicable to this PSL entry. Supports client diversity spend reporting and OFCCP compliance without requiring the full classification detail.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diversityClassification rdf:type rdf:Property ;
    rdfs:label 'Diversity Classification' ;
    rdfs:comment 'Diversity certification category of the vendor as recognized under this PSL entry (e.g., MBE, WBE, SDVOSB, HUBZone, LGBTBE, SBE). Used for client diversity spend reporting and OFCCP compliance tracking. [ENUM-REF-CANDIDATE: MBE|WBE|SDVOSB|HUBZone|LGBTBE|SBE|DBE|VOSB — promote to reference product]' ;
    rdfs:domain ind:PreferredSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionDate rdf:type rdf:Property ;
    rdfs:label 'Exclusion Date' ;
    rdfs:comment 'The date on which the vendor was removed or excluded from the Preferred Supplier List for this client program and job category. Null if the vendor remains active on the PSL. Marks the end of the vendors eligibility window.' ;
    rdfs:domain ind:PreferredSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusionReason rdf:type rdf:Property ;
    rdfs:label 'Exclusion Reason' ;
    rdfs:comment 'Documented reason for the vendors exclusion or suspension from this PSL entry. Required when psl_status is excluded or suspended. Supports audit trails, vendor dispute resolution, and governance reporting.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusiveSupplier rdf:type rdf:Property ;
    rdfs:label 'Exclusive Supplier' ;
    rdfs:comment 'Indicates whether this vendor holds exclusive rights to supply workers for the specified job category within the client program. When true, no other vendor on the PSL may submit candidates for that category.' ;
    rdfs:domain ind:PreferredSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:icSupplier rdf:type rdf:Property ;
    rdfs:label 'Ic Supplier' ;
    rdfs:comment 'Indicates whether this vendor is classified as an Independent Contractor (IC) supplier, providing 1099 workers rather than W-2 employees. Affects worker classification compliance checks and tax treatment for placements under this PSL entry.' ;
    rdfs:domain ind:PreferredSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inclusionDate rdf:type rdf:Property ;
    rdfs:label 'Inclusion Date' ;
    rdfs:comment 'The date on which the vendor was added to the Preferred Supplier List for this client program and job category. Marks the start of the vendors eligibility window under this PSL entry.' ;
    rdfs:domain ind:PreferredSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceVerified rdf:type rdf:Property ;
    rdfs:label 'Insurance Verified' ;
    rdfs:comment 'Indicates whether the vendors required insurance certificates (general liability, workers compensation, professional liability) have been verified and are current for this PSL entry. A prerequisite for PSL active status in most client programs.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Job Category Code' ;
    rdfs:comment 'Standardized alphanumeric code representing the job category within the VMS or client program. Used for system-level routing of requisitions to eligible vendors and for cross-program reporting.' ;
    rdfs:domain ind:PreferredSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pslNumber rdf:type rdf:Property ;
    rdfs:label 'Psl Number' ;
    rdfs:comment 'Externally-known business identifier for this PSL entry, used in VMS communications, audit trails, and client-facing documentation. Follows the format PSL-{alphanumeric code}.' ;
    rdfs:domain ind:PreferredSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pslStatus rdf:type rdf:Property ;
    rdfs:label 'Psl Status' ;
    rdfs:comment 'Current lifecycle status of the vendor on this PSL entry. preferred = top-tier vendor with priority routing; approved = eligible to receive requisitions; conditional = eligible with restrictions or conditions; excluded = blocked from receiving requisitions; suspended = temporarily ineligible pending review.' ;
    rdfs:domain ind:PreferredSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pslVersion rdf:type rdf:Property ;
    rdfs:label 'Psl Version' ;
    rdfs:comment 'Version identifier of the PSL under which this entry was created or last revised (e.g., v1.0, v2.3). Supports PSL versioning and audit trails when the client program updates its approved vendor roster.' ;
    rdfs:domain ind:PreferredSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionVisibility rdf:type rdf:Property ;
    rdfs:label 'Requisition Visibility' ;
    rdfs:comment 'Controls whether the vendor can see and respond to open requisitions in the VMS for this client program and job category. visible = vendor sees all eligible reqs; hidden = vendor is on PSL but not shown reqs; restricted = vendor sees only specific reqs per conditional rules.' ;
    rdfs:domain ind:PreferredSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightToRepresentRequired rdf:type rdf:Property ;
    rdfs:label 'Right To Represent Required' ;
    rdfs:comment 'Indicates whether the vendor must obtain a Right to Represent (RTR) confirmation from the candidate before submitting to this client program. When true, the VMS enforces RTR capture prior to submittal acceptance.' ;
    rdfs:domain ind:PreferredSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sowEligible rdf:type rdf:Property ;
    rdfs:label 'Sow Eligible' ;
    rdfs:comment 'Indicates whether the vendor is authorized to deliver Statement of Work (SOW) engagements under this PSL entry, in addition to or instead of contingent staffing. Governs SOW requisition routing in the VMS.' ;
    rdfs:domain ind:PreferredSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionCap rdf:type rdf:Property ;
    rdfs:label 'Submission Cap' ;
    rdfs:comment 'Maximum number of candidate submittals the vendor is permitted to make per requisition for this client program and job category. Enforced by the VMS to manage submittal volume and ensure quality of submission (QoS).' ;
    rdfs:domain ind:PreferredSupplierList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousCertificationDiversityCertificationId rdf:type rdf:Property ;
    rdfs:label 'Previous Certification Diversity Certification Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the prior certification record that this record supersedes or renews. Enables certification history chain tracking for audit and compliance reporting.' ;
    rdfs:domain ind:DiversityCertification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DiversityCertification .

ind:annualRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Usd' ;
    rdfs:comment 'The vendors annual gross revenue in US dollars as reported at the time of certification, used to verify small business size standard eligibility for applicable certification types (HUBZone, 8(a), SDVOB).' ;
    rdfs:domain ind:DiversityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether this certification type supports automatic renewal processing through the certifying bodys online portal or VMS integration. True = auto-renewal available; False = manual renewal required.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationNotes rdf:type rdf:Property ;
    rdfs:label 'Certification Notes' ;
    rdfs:comment 'Free-text field for compliance officers or supplier diversity program managers to record observations, exceptions, conditions, or special circumstances related to this diversity certification (e.g., conditional approval, pending documentation, audit findings).' ;
    rdfs:domain ind:DiversityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'The official certificate number or registration identifier issued by the certifying body (e.g., NMSDC, WBENC, SBA) for this diversity designation. Used for verification and OFCCP supplier diversity reporting.' ;
    rdfs:domain ind:DiversityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationScope rdf:type rdf:Property ;
    rdfs:label 'Certification Scope' ;
    rdfs:comment 'The geographic scope of this diversity certification. National = recognized across the US; Regional = recognized within a multi-state region; State = state-level certification only; Local = city or county level certification.' ;
    rdfs:domain ind:DiversityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current lifecycle status of the diversity certification. Active = valid and in good standing; Expired = past expiration date without renewal; Pending Renewal = renewal application submitted and under review; Revoked = certification withdrawn by certifying body; Suspended = temporarily inactive pending investigation or documentation.' ;
    rdfs:domain ind:DiversityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'The category of diversity designation held by the vendor. MBE = Minority Business Enterprise; WBE = Women Business Enterprise; SDVOB = Service-Disabled Veteran-Owned Business; HUBZone = Historically Underutilized Business Zone; 8(a) = SBA 8(a) Business Development Program; LGBTBE = LGBT Business Enterprise; VOSB = Veteran-Owned Small Business. [ENUM-REF-CANDIDATE: MBE|WBE|SDVOB|HUBZone|8(a)|LGBTBE|VOSB|AABE|DBE|SBE — promote to reference product]' ;
    rdfs:domain ind:DiversityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingBody rdf:type rdf:Property ;
    rdfs:label 'Certifying Body' ;
    rdfs:comment 'The organization that issued and validates this diversity certification. NMSDC = National Minority Supplier Development Council; WBENC = Womens Business Enterprise National Council; SBA = Small Business Administration; USVBA = U.S. Veteran Business Alliance; NGLCC = National LGBT Chamber of Commerce; NVBDC = National Veteran Business Development Council; DOT = Department of Transportation; STATE = State-level certifying authority. [ENUM-REF-CANDIDATE: NMSDC|WBENC|SBA|USVBA|NGLCC|NVBDC|DOT|STATE|CITY|OTHER — promote to reference product]' ;
    rdfs:domain ind:DiversityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingBodyRegion rdf:type rdf:Property ;
    rdfs:label 'Certifying Body Region' ;
    rdfs:comment 'The regional chapter or affiliate of the certifying body that issued this certification (e.g., NMSDC regional council name, WBENC regional partner organization). Relevant for multi-regional supplier diversity programs.' ;
    rdfs:domain ind:DiversityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Client Reportable Flag' ;
    rdfs:comment 'Indicates whether this certification is eligible to be reported as qualifying diverse spend to the client under their supplier diversity program requirements. True = reportable; False = not reportable (e.g., expired, unverified, or excluded by client program rules).' ;
    rdfs:domain ind:DiversityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlAndOperations rdf:type rdf:Property ;
    rdfs:label 'Control And Operations' ;
    rdfs:comment 'Indicates whether the diverse owner(s) exercise day-to-day control and management of the business operations, as required by certifying body standards. True = confirmed control; False = control not confirmed or under review.' ;
    rdfs:domain ind:DiversityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diversitySpendCategory rdf:type rdf:Property ;
    rdfs:label 'Diversity Spend Category' ;
    rdfs:comment 'The tier classification of diversity spend associated with this certification. Tier 1 = direct spend with certified diverse vendor; Tier 2 = spend through prime vendor with certified diverse subcontractor; Tier 3 = indirect diversity spend. Used for client diversity spend reporting and OFCCP compliance.' ;
    rdfs:domain ind:DiversityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Document Verified Flag' ;
    rdfs:comment 'Indicates whether the supporting certification document has been reviewed and verified by the MSP compliance team or supplier diversity program manager. True = document verified; False = pending verification.' ;
    rdfs:domain ind:DiversityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeCount rdf:type rdf:Property ;
    rdfs:label 'Employee Count' ;
    rdfs:comment 'The number of employees at the vendor organization as reported at the time of certification. Used for SBA size standard verification and diversity program eligibility assessment.' ;
    rdfs:domain ind:DiversityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorityGroup rdf:type rdf:Property ;
    rdfs:label 'Minority Group' ;
    rdfs:comment 'For MBE (Minority Business Enterprise) certifications, the specific minority group classification as defined by NMSDC and EEOC guidelines. Applicable only when certification_type = MBE. [ENUM-REF-CANDIDATE: Asian|Black|Hispanic|Native_American|Pacific_Islander|Multi|Other — promote to reference product]' ;
    rdfs:domain ind:DiversityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ofccpReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Ofccp Reportable Flag' ;
    rdfs:comment 'Indicates whether this certification qualifies for inclusion in OFCCP federal contractor supplier diversity compliance reporting. True = qualifies for OFCCP reporting; False = does not qualify.' ;
    rdfs:domain ind:DiversityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'The percentage of the vendor business owned by the qualifying diverse individual(s) as documented in the certification application. Must meet minimum thresholds (typically 51%) set by certifying bodies for certification eligibility.' ;
    rdfs:domain ind:DiversityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalAlertDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Alert Days' ;
    rdfs:comment 'Number of days before the certification expiration date at which automated renewal alerts should be triggered to the vendor and compliance team. Configurable per certification type or program requirements (e.g., 90 days for WBENC, 60 days for NMSDC).' ;
    rdfs:domain ind:DiversityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'The date on which the vendor submitted or completed the renewal application for this diversity certification. Distinct from expiration date; tracks the actual renewal action taken.' ;
    rdfs:domain ind:DiversityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'The stated reason for revocation or suspension of this diversity certification, as communicated by the certifying body. Populated only when certification_status = revoked or suspended. Required for OFCCP audit trail.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smallBusinessFlag rdf:type rdf:Property ;
    rdfs:label 'Small Business Flag' ;
    rdfs:comment 'Indicates whether the vendor also qualifies as a small business under SBA size standards at the time of certification. Relevant for HUBZone, 8(a), and SDVOB certifications that require small business status.' ;
    rdfs:domain ind:DiversityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backgroundCheckRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Background Check Required Flag' ;
    rdfs:comment 'Indicates whether background checks are mandatory for all candidates placed under this MSA.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confidentialityTermYears rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Term Years' ;
    rdfs:comment 'Number of years that confidentiality obligations survive after MSA termination.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'Primary method specified in the MSA for resolving disputes between parties.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugScreenRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Drug Screen Required Flag' ;
    rdfs:comment 'Indicates whether drug screening is mandatory for all candidates placed under this MSA.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:errorsOmissionsMinimumUsd rdf:type rdf:Property ;
    rdfs:label 'Errors Omissions Minimum Usd' ;
    rdfs:comment 'Minimum required errors and omissions (professional liability) insurance coverage amount in USD that the staffing firm must maintain.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:everifyRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Everify Required Flag' ;
    rdfs:comment 'Indicates whether E-Verify employment eligibility verification is required for all placements under this MSA.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:executedDate rdf:type rdf:Property ;
    rdfs:label 'Executed Date' ;
    rdfs:comment 'Date when all parties signed the MSA and it became fully executed. May differ from effective date.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:generalLiabilityMinimumUsd rdf:type rdf:Property ;
    rdfs:label 'General Liability Minimum Usd' ;
    rdfs:comment 'Minimum required general liability insurance coverage amount in USD that the staffing firm must maintain.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'State or country whose laws govern the interpretation and enforcement of the MSA (e.g., State of Delaware, England and Wales).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indemnificationScope rdf:type rdf:Property ;
    rdfs:label 'Indemnification Scope' ;
    rdfs:comment 'Description of the scope and limitations of indemnification obligations between parties, including covered claims and exclusions.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialTermMonths rdf:type rdf:Property ;
    rdfs:label 'Initial Term Months' ;
    rdfs:comment 'Duration of the initial contract term in months before any renewal periods.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment to this MSA. Nullable if no amendments have been executed.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liabilityCapAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Cap Amount' ;
    rdfs:comment 'Maximum aggregate liability amount that either party can be held liable for under the MSA, excluding certain carve-outs.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liabilityCapCurrency rdf:type rdf:Property ;
    rdfs:label 'Liability Cap Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the liability cap amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msaNumber rdf:type rdf:Property ;
    rdfs:label 'Msa Number' ;
    rdfs:comment 'Externally-known unique business identifier for the MSA. Used in all client communications and legal references.' ;
    rdfs:domain ind:Msa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaAttachedFlag rdf:type rdf:Property ;
    rdfs:label 'Nda Attached Flag' ;
    rdfs:comment 'Indicates whether a separate NDA document is attached to or incorporated into this MSA.' ;
    rdfs:domain ind:Msa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonSolicitationFlag rdf:type rdf:Property ;
    rdfs:label 'Non Solicitation Flag' ;
    rdfs:comment 'Indicates whether the MSA includes a non-solicitation clause prohibiting direct hire of placed candidates.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonSolicitationPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Non Solicitation Period Months' ;
    rdfs:comment 'Duration in months during which the client is prohibited from directly hiring placed candidates without paying a conversion fee.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Months' ;
    rdfs:comment 'Duration of each automatic renewal period in months, if auto-renewal is enabled.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaAttachedFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Attached Flag' ;
    rdfs:comment 'Indicates whether a formal SLA document with performance metrics and penalties is attached to this MSA.' ;
    rdfs:domain ind:Msa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Descriptive title of the MSA, typically including client name and agreement type.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Vendor Signatory Title' ;
    rdfs:comment 'Job title of the vendor signatory (e.g., President, VP Sales, Regional Director).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workersCompMinimumUsd rdf:type rdf:Property ;
    rdfs:label 'Workers Comp Minimum Usd' ;
    rdfs:comment 'Minimum required workers compensation insurance coverage amount in USD that the staffing firm must maintain.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acceptanceCriteria rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria' ;
    rdfs:comment 'Conditions and standards that must be met for the client to accept deliverables and authorize payment.' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDurationDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Days' ;
    rdfs:comment 'Estimated total duration of the SOW engagement in calendar days, from start to completion.' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedFteCount rdf:type rdf:Property ;
    rdfs:label 'Estimated Fte Count' ;
    rdfs:comment 'Estimated number of full-time equivalent resources required to deliver this SOW. May be fractional (e.g., 2.5 FTEs).' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedHeadcount rdf:type rdf:Property ;
    rdfs:label 'Estimated Headcount' ;
    rdfs:comment 'Estimated number of individual workers or consultants to be assigned to this SOW, regardless of full-time or part-time status.' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:insuranceRequirements rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirements' ;
    rdfs:comment 'Description of insurance coverage requirements (e.g., general liability, professional liability, workers compensation) that the staffing firm must maintain for this SOW.' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceFrequency rdf:type rdf:Property ;
    rdfs:label 'Invoice Frequency' ;
    rdfs:comment 'Frequency at which invoices are issued for this SOW. Weekly: every 7 days. Biweekly: every 14 days. Monthly: once per calendar month. Milestone: upon completion of defined milestones. Upon completion: single invoice at project end. Custom: non-standard schedule.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Nda Required Flag' ;
    rdfs:comment 'Indicates whether workers assigned to this SOW must sign a Non-Disclosure Agreement. True: NDA required. False: NDA not required.' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netPaymentDays rdf:type rdf:Property ;
    rdfs:label 'Net Payment Days' ;
    rdfs:comment 'Number of days from invoice date within which payment is due (e.g., Net 30, Net 45).' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nonCompeteClause rdf:type rdf:Property ;
    rdfs:label 'Non Compete Clause' ;
    rdfs:comment 'Description of any non-compete restrictions applicable to workers or the staffing firm during and after the SOW engagement.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingModel rdf:type rdf:Property ;
    rdfs:label 'Pricing Model' ;
    rdfs:comment 'Financial structure of the SOW. Time and materials: hourly/daily rates. Fixed fee: predetermined total price. Cost plus: actual costs plus markup. Retainer: recurring periodic fee. Milestone-based: payment tied to deliverable completion. Hybrid: combination of models.' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Eligible Flag' ;
    rdfs:comment 'Indicates whether this SOW is eligible for renewal or extension upon expiration. True: renewal allowed. False: one-time engagement only.' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Date when the SOW was fully executed (signed by all parties) and became legally binding.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaTerms rdf:type rdf:Property ;
    rdfs:label 'Sla Terms' ;
    rdfs:comment 'Summary of service level commitments, performance metrics, response times, and quality standards defined in this SOW.' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationClause rdf:type rdf:Property ;
    rdfs:label 'Termination Clause' ;
    rdfs:comment 'Description of conditions, notice periods, and penalties under which either party may terminate the SOW prior to completion.' ;
    rdfs:domain ind:Sow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentMsaId rdf:type rdf:Property ;
    rdfs:label 'Parent Msa Id' ;
    rdfs:comment 'Reference to the parent MSA if this NDA is ancillary to or incorporated into a broader master service agreement. Nullable for standalone NDAs.' ;
    rdfs:domain ind:Nda ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Msa .

ind:carveOuts rdf:type rdf:Property ;
    rdfs:label 'Carve Outs' ;
    rdfs:comment 'Exceptions to confidentiality obligations. Standard carve-outs include information that is publicly available, independently developed, already known, or required to be disclosed by law.' ;
    rdfs:domain ind:Nda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Duration Months' ;
    rdfs:comment 'Duration in months that confidentiality obligations remain in effect from the effective date. Common values are 12, 24, 36, or 60 months. Nullable for perpetual NDAs.' ;
    rdfs:domain ind:Nda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confidentialityScope rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Scope' ;
    rdfs:comment 'Description of the types of information covered by the NDA. May include business plans, financial data, candidate information, client requirements, proprietary processes, trade secrets, or other confidential materials.' ;
    rdfs:domain ind:Nda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyTitle rdf:type rdf:Property ;
    rdfs:label 'Counterparty Title' ;
    rdfs:comment 'Job title or role of the counterparty representative who signed the NDA. Used to verify signing authority.' ;
    rdfs:domain ind:Nda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'Legal jurisdiction whose laws govern the interpretation and enforcement of the NDA. Typically the state or country where the disclosing party is headquartered.' ;
    rdfs:domain ind:Nda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Court jurisdiction or venue where disputes arising from the NDA must be resolved. May differ from governing law jurisdiction.' ;
    rdfs:domain ind:Nda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liquidatedDamagesAmount rdf:type rdf:Property ;
    rdfs:label 'Liquidated Damages Amount' ;
    rdfs:comment 'Pre-determined monetary amount payable for breach of the NDA. Nullable if liquidated damages are not specified or if actual damages apply.' ;
    rdfs:domain ind:Nda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ndaNumber rdf:type rdf:Property ;
    rdfs:label 'Nda Number' ;
    rdfs:comment 'Business identifier for the NDA. Externally-known unique document number assigned by DocuSign CLM or internal contract management system.' ;
    rdfs:domain ind:Nda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaStatus rdf:type rdf:Property ;
    rdfs:label 'Nda Status' ;
    rdfs:comment 'Current lifecycle status of the NDA. Tracks progression from draft through execution to expiration or termination. [ENUM-REF-CANDIDATE: draft|pending_signature|executed|active|expired|terminated|superseded — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Nda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaType rdf:type rdf:Property ;
    rdfs:label 'Nda Type' ;
    rdfs:comment 'Classification of the NDA based on directionality of confidentiality obligations. Mutual means both parties protect each others information; one-way means only one party discloses confidential information.' ;
    rdfs:domain ind:Nda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonSolicitationClause rdf:type rdf:Property ;
    rdfs:label 'Non Solicitation Clause' ;
    rdfs:comment 'Indicates whether the NDA includes a non-solicitation provision prohibiting the receiving party from soliciting employees, candidates, or clients of the disclosing party.' ;
    rdfs:domain ind:Nda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permittedUse rdf:type rdf:Property ;
    rdfs:label 'Permitted Use' ;
    rdfs:comment 'Specific purposes for which the receiving party may use the confidential information. Typically limited to evaluation of business relationship, recruitment activities, or specific project scope.' ;
    rdfs:domain ind:Nda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnDestructionRequired rdf:type rdf:Property ;
    rdfs:label 'Return Destruction Required' ;
    rdfs:comment 'Indicates whether the receiving party must return or destroy confidential information upon termination or expiration of the NDA. True if return/destruction is mandatory.' ;
    rdfs:domain ind:Nda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signedByCounterparty rdf:type rdf:Property ;
    rdfs:label 'Signed By Counterparty' ;
    rdfs:comment 'Name of the authorized representative from the counterparty (client, candidate, or vendor) who signed the NDA.' ;
    rdfs:domain ind:Nda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedByStaffingHr rdf:type rdf:Property ;
    rdfs:label 'Signed By Staffing Hr' ;
    rdfs:comment 'Name of the authorized representative from Staffing Hr who signed the NDA on behalf of the company.' ;
    rdfs:domain ind:Nda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:survivalPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Survival Period Months' ;
    rdfs:comment 'Number of months that confidentiality obligations survive after termination or expiration of the NDA. Ensures continued protection of disclosed information beyond the agreement term.' ;
    rdfs:domain ind:Nda ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationClientContactId rdf:type rdf:Property ;
    rdfs:label 'Escalation Client Contact Id' ;
    rdfs:comment 'Foreign key linking to client.client_contact. Business justification: SLA breach escalation routing to the correct client contact is a critical staffing ops governance process. Normalizing escalation_contact (currently plain text) to a client_contact FK enables automate' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientContact .

ind:amendmentDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Date' ;
    rdfs:comment 'The date of the most recent amendment or revision to this SLA commitment.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Sequential number tracking amendments or revisions to this SLA commitment. Zero indicates the original version.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Flag' ;
    rdfs:comment 'Indicates whether this SLA automatically renews at the end of its term or requires explicit renegotiation.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachThreshold rdf:type rdf:Property ;
    rdfs:label 'Breach Threshold' ;
    rdfs:comment 'The performance level at which an SLA breach is triggered, potentially different from the target (e.g., target 15 days, breach at 20 days).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'Detailed explanation of the formula or logic used to calculate the SLA metric from source data, including any exclusions or adjustments.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Required Flag' ;
    rdfs:comment 'Indicates whether an SLA breach requires formal escalation to client management or executive leadership.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographyScope rdf:type rdf:Property ;
    rdfs:label 'Geography Scope' ;
    rdfs:comment 'Geographic regions, states, or locations to which this SLA applies (e.g., USA - West Coast, EMEA, Chicago Metro).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement End Date' ;
    rdfs:comment 'The date when SLA measurement and tracking ends for this commitment. Null if ongoing.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'How often the SLA metric is measured and reported (e.g., weekly, monthly, quarterly, per placement, per requisition). [ENUM-REF-CANDIDATE: daily|weekly|biweekly|monthly|quarterly|annually|per_placement|per_requisition — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Measurement Source System' ;
    rdfs:comment 'The operational system or platform from which SLA metric data is sourced (e.g., Bullhorn ATS, Beeline VMS, Power BI Analytics).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Start Date' ;
    rdfs:comment 'The date when SLA measurement and tracking begins for this commitment.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:metricDescription rdf:type rdf:Property ;
    rdfs:label 'Metric Description' ;
    rdfs:comment 'Detailed definition of how the SLA metric is calculated, including numerator, denominator, exclusions, and any special conditions.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricName rdf:type rdf:Property ;
    rdfs:label 'Metric Name' ;
    rdfs:comment 'The specific performance metric being measured under this SLA. Common metrics include TTF (Time to Fill), TTS (Time to Start), QoS (Quality of Submission), fill rate, NPS (Net Promoter Score), submittal-to-interview ratio, and first-day no-show rate. [ENUM-REF-CANDIDATE: TTF|TTS|QoS|fill_rate|NPS|submittal_to_interview_ratio|first_day_no_show_rate|time_to_start|quality_of_submission|net_promoter_score — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCapAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Cap Amount' ;
    rdfs:comment 'The maximum cumulative penalty or credit amount that can be applied within a given measurement period or contract term.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyPercentage rdf:type rdf:Property ;
    rdfs:label 'Penalty Percentage' ;
    rdfs:comment 'The percentage-based penalty or credit applied to the invoice or contract value when the SLA is breached.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyType rdf:type rdf:Property ;
    rdfs:label 'Penalty Type' ;
    rdfs:comment 'The type of financial or service remedy applied when the SLA is breached (e.g., credit, rebate, discount, penalty fee, service credit, none).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFormat rdf:type rdf:Property ;
    rdfs:label 'Reporting Format' ;
    rdfs:comment 'The format in which SLA performance results are delivered to the client (e.g., dashboard, PDF report, Excel spreadsheet, email summary, API feed).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingRecipient rdf:type rdf:Property ;
    rdfs:label 'Reporting Recipient' ;
    rdfs:comment 'Name, role, or email address of the client stakeholder who receives SLA performance reports.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reporting Required Flag' ;
    rdfs:comment 'Indicates whether periodic SLA performance reporting is contractually required (e.g., for QBRs or monthly business reviews).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeFilter rdf:type rdf:Property ;
    rdfs:label 'Scope Filter' ;
    rdfs:comment 'Business rules defining which placements, requisitions, or transactions are included in the SLA measurement (e.g., IT roles only, permanent placements only, exclude rush orders).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaName rdf:type rdf:Property ;
    rdfs:label 'Sla Name' ;
    rdfs:comment 'Business-friendly name or title of the SLA commitment (e.g., Time to Fill - IT Roles, Quality of Submission - Healthcare).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaNumber rdf:type rdf:Property ;
    rdfs:label 'Sla Number' ;
    rdfs:comment 'Externally-known unique identifier or reference number for this SLA commitment, often used in client communications and QBRs.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Status' ;
    rdfs:comment 'Current lifecycle status of the SLA commitment (e.g., active, suspended, expired, terminated, draft, pending approval).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetOperator rdf:type rdf:Property ;
    rdfs:label 'Target Operator' ;
    rdfs:comment 'The comparison operator defining how actual performance is evaluated against the target (e.g., less_than for TTF, greater_than_or_equal for fill rate).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'The contractually committed target threshold or goal for this SLA metric (e.g., 15 days for TTF, 85% for fill rate, 8.0 for NPS).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'The unit in which the SLA metric is expressed (e.g., days, hours, percentage, ratio, score, count).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doubleTimeMultiplier rdf:type rdf:Property ;
    rdfs:label 'Double Time Multiplier' ;
    rdfs:comment 'The multiplier applied to the standard bill rate for double-time hours, typically 2.0x or as contractually agreed.' ;
    rdfs:domain ind:ContractRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Boolean flag indicating whether this rate schedule is currently active and available for use in placements and billing.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborClassification rdf:type rdf:Property ;
    rdfs:label 'Labor Classification' ;
    rdfs:comment 'The labor classification or job title covered by this rate schedule, aligned with client job requisition taxonomy.' ;
    rdfs:domain ind:ContractRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overtimeMultiplier rdf:type rdf:Property ;
    rdfs:label 'Overtime Multiplier' ;
    rdfs:comment 'The multiplier applied to the standard bill rate for overtime hours, typically 1.5x or as contractually agreed.' ;
    rdfs:domain ind:ContractRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCardVersion rdf:type rdf:Property ;
    rdfs:label 'Rate Card Version' ;
    rdfs:comment 'Version identifier for the rate card, used to track amendments and revisions over time.' ;
    rdfs:domain ind:ContractRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateScheduleName rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Name' ;
    rdfs:comment 'Descriptive name for the rate schedule, often indicating the job category, skill level, or labor classification it covers.' ;
    rdfs:domain ind:ContractRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateScheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Number' ;
    rdfs:comment 'Business identifier for the rate schedule, typically referenced in contract documents and invoices.' ;
    rdfs:domain ind:ContractRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateScheduleType rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Type' ;
    rdfs:comment 'Classification of the rate schedule structure, such as standard, custom, blended, tiered, or project-based.' ;
    rdfs:domain ind:ContractRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Unit' ;
    rdfs:comment 'The unit of measure for the rate, such as hourly, daily, weekly, monthly, or per unit of work delivered.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spread rdf:type rdf:Property ;
    rdfs:label 'Spread' ;
    rdfs:comment 'The difference between the bill rate and pay rate, representing gross margin before burden costs.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededByAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Amendment Id' ;
    rdfs:comment 'Reference to a subsequent amendment that supersedes or replaces this amendment. Used to track amendment version chains. Null if this is the current active amendment.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:amendmentDescription rdf:type rdf:Property ;
    rdfs:label 'Amendment Description' ;
    rdfs:comment 'Detailed narrative description of the changes being made, including business rationale and impact. May include before/after values for modified terms.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentStatus rdf:type rdf:Property ;
    rdfs:label 'Amendment Status' ;
    rdfs:comment 'Current lifecycle status of the amendment in the approval and execution workflow. Tracks progression from draft through legal review, approvals, signatures, and final execution. [ENUM-REF-CANDIDATE: draft|pending_legal_review|pending_finance_approval|pending_client_signature|pending_vendor_signature|executed|rejected|superseded|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'Classification of the amendment by the nature of the change being made to the parent contract. Determines approval workflow and legal review requirements. [ENUM-REF-CANDIDATE: rate_change|scope_change|term_extension|party_addition|party_removal|insurance_requirement_change|sla_modification|billing_terms_change|termination_clause_change|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Explanation of why the amendment was cancelled before execution. Null if not cancelled.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeSummary rdf:type rdf:Property ;
    rdfs:label 'Change Summary' ;
    rdfs:comment 'Structured summary of specific contract terms being modified, added, or removed. Includes section references and explicit before/after values for key terms (e.g., Section 3.2 Bill Rate: $85/hr → $92/hr).' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Client Signature Date' ;
    rdfs:comment 'Date when the client signatory executed the amendment via DocuSign or other signature method.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financeApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Finance Approval Date' ;
    rdfs:comment 'Date when finance approval was granted for the amendment.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financeApprovalNotes rdf:type rdf:Property ;
    rdfs:label 'Finance Approval Notes' ;
    rdfs:comment 'Comments from finance regarding budget impact, revenue implications, or cost considerations related to the amendment.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financeApprover rdf:type rdf:Property ;
    rdfs:label 'Finance Approver' ;
    rdfs:comment 'Name or identifier of the finance manager who approved the amendment for financial impact and budget alignment.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Estimated annual financial impact of the amendment in USD. Positive for revenue increases, negative for cost increases or revenue decreases. Used for finance approval thresholds.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initiatedBy rdf:type rdf:Property ;
    rdfs:label 'Initiated By' ;
    rdfs:comment 'Name or identifier of the person or role who initiated the amendment request (e.g., Account Manager, Client, Legal Counsel).' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'Date when the amendment request was formally initiated and entered into the contract management system.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Legal Review Date' ;
    rdfs:comment 'Date when legal review was completed and the amendment was approved by legal counsel.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReviewNotes rdf:type rdf:Property ;
    rdfs:label 'Legal Review Notes' ;
    rdfs:comment 'Comments and recommendations from legal counsel regarding the amendment, including any risk factors or required modifications.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewer rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewer' ;
    rdfs:comment 'Name or identifier of the legal counsel who reviewed and approved the amendment for legal compliance and risk.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Date' ;
    rdfs:comment 'Date when notification of the executed amendment was sent to all affected stakeholders (account managers, operations, billing, compliance).' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorTermsExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Prior Terms Expiration Date' ;
    rdfs:comment 'Date when the prior contract terms being replaced by this amendment cease to be effective. Typically matches the amendment effective date but may differ for transition periods.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiresRateScheduleUpdate rdf:type rdf:Property ;
    rdfs:label 'Requires Rate Schedule Update' ;
    rdfs:comment 'Indicates whether this amendment requires updates to associated rate schedules in the billing system. True if rate changes are included.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresSlaUpdate rdf:type rdf:Property ;
    rdfs:label 'Requires Sla Update' ;
    rdfs:comment 'Indicates whether this amendment modifies SLA terms and requires updates to SLA measurement and tracking systems. True if SLA changes are included.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Sequential order of this amendment within the parent contract lifecycle (1, 2, 3, etc.). Used to reconstruct full contract version history.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Signature Date' ;
    rdfs:comment 'Date when the vendor signatory executed the amendment via DocuSign or other signature method.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalId rdf:type rdf:Property ;
    rdfs:label 'Renewal Id' ;
    rdfs:comment 'Unique identifier for the contract renewal record. Primary key for the renewal entity.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Renewal .

ind:acknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Date' ;
    rdfs:comment 'Date when the renewal owner formally acknowledged the renewal alert and committed to action. Null if not yet acknowledged.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgmentStatus rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Status' ;
    rdfs:comment 'Status of stakeholder acknowledgment of the renewal alert. Tracks whether the renewal owner has acknowledged the alert and taken required action.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Alert Lead Time Days' ;
    rdfs:comment 'Number of days prior to the renewal trigger date that alerts should be sent. Configurable per contract type and priority level.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertSentDate rdf:type rdf:Property ;
    rdfs:label 'Alert Sent Date' ;
    rdfs:comment 'Date when the first renewal alert notification was sent. Used to track compliance with internal notification lead-time requirements.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:alertSentFlag rdf:type rdf:Property ;
    rdfs:label 'Alert Sent Flag' ;
    rdfs:comment 'Indicates whether proactive renewal alert notifications have been sent to stakeholders. True if alerts sent; False if not yet sent.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoRenewalEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled Flag' ;
    rdfs:comment 'Indicates whether the contract has an auto-renewal clause that will execute unless explicitly opted out. True if auto-renewal is active; False if manual renewal required.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceFilingDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Filing Deadline Date' ;
    rdfs:comment 'Date by which regulatory compliance filings (EEOC, OFCCP, OSHA) related to this contract must be submitted. Tracks critical compliance dates tied to contract renewal.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceCertificateRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Renewal Date' ;
    rdfs:comment 'Date when insurance certificates (Workers Comp, General Liability, Professional Liability) must be renewed to maintain contract compliance. Critical for risk management.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:negotiationEndDate rdf:type rdf:Property ;
    rdfs:label 'Negotiation End Date' ;
    rdfs:comment 'Date when renewal negotiations concluded. Marks the completion of discussions and agreement on renewed terms.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:negotiationStartDate rdf:type rdf:Property ;
    rdfs:label 'Negotiation Start Date' ;
    rdfs:comment 'Date when renewal negotiation discussions formally began. Tracks the start of the renegotiation process for rate schedules, terms, or service levels.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:negotiationStatus rdf:type rdf:Property ;
    rdfs:label 'Negotiation Status' ;
    rdfs:comment 'Current state of renewal negotiation activities. Tracks whether negotiations are active, paused, successfully completed, or failed.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Notice Deadline Date' ;
    rdfs:comment 'Final date by which notice of intent to renew or not renew must be provided per contract terms. Critical for compliance with contractual notification requirements.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'Number of days prior to renewal effective date that notice must be provided. Typically 30, 60, or 90 days per Master Service Agreement (MSA) terms.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optOutDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Opt Out Deadline Date' ;
    rdfs:comment 'Final date by which a party can opt out of an auto-renewal without penalty. Missing this deadline results in automatic contract extension.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optOutParty rdf:type rdf:Property ;
    rdfs:label 'Opt Out Party' ;
    rdfs:comment 'Identifies which party initiated the opt-out. Client indicates the client opted out; vendor indicates a vendor/supplier opted out; staffing_hr indicates internal decision; mutual indicates both parties agreed.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optOutReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Opt Out Received Date' ;
    rdfs:comment 'Date when opt-out notice was formally received. Null if no opt-out was received. Used to verify compliance with opt-out deadline requirements.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optOutReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Opt Out Received Flag' ;
    rdfs:comment 'Indicates whether an opt-out notice was received from either party prior to the opt-out deadline. True if opt-out received; False if no opt-out.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outcomeDate rdf:type rdf:Property ;
    rdfs:label 'Outcome Date' ;
    rdfs:comment 'Date when the final renewal outcome was determined and recorded. Marks the conclusion of the renewal decision process.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateChangePercentage rdf:type rdf:Property ;
    rdfs:label 'Rate Change Percentage' ;
    rdfs:comment 'Percentage change in rates from the prior term to the renewed term. Positive values indicate rate increases; negative values indicate decreases. Expressed as a percentage (e.g., 3.50 for 3.5% increase).' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateScheduleReviewDate rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Review Date' ;
    rdfs:comment 'Scheduled date for formal review of bill rates and pay rates as part of the renewal process. Ensures rates remain competitive and aligned with market conditions.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalNumber rdf:type rdf:Property ;
    rdfs:label 'Renewal Number' ;
    rdfs:comment 'Business-facing identifier for the renewal event. Format typically follows contract number with renewal sequence suffix (e.g., MSA-2024-001-R2).' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalType rdf:type rdf:Property ;
    rdfs:label 'Renewal Type' ;
    rdfs:comment 'Classification of the renewal mechanism. Auto-renewal executes automatically unless opted out; manual renewal requires explicit action; evergreen continues indefinitely; one-time is non-renewable; conditional depends on performance or other criteria.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionActionTaken rdf:type rdf:Property ;
    rdfs:label 'Resolution Action Taken' ;
    rdfs:comment 'Free-text description of the action taken to resolve the renewal. Documents decisions made, approvals obtained, and next steps executed.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Review Required Flag' ;
    rdfs:comment 'Indicates whether Service Level Agreement (SLA) terms must be reviewed and potentially renegotiated as part of the renewal. True if SLA review required; False if existing SLA continues unchanged.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termLengthMonths rdf:type rdf:Property ;
    rdfs:label 'Term Length Months' ;
    rdfs:comment 'Duration of the renewal term expressed in months. Common values include 12 (annual), 24 (biennial), 36 (triennial), or custom durations per contract terms.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggerDate rdf:type rdf:Property ;
    rdfs:label 'Trigger Date' ;
    rdfs:comment 'Date when the renewal process is initiated or triggered. For auto-renewals, this is when the system begins the renewal workflow. For manual renewals, this is when stakeholders must begin review.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:replacementTemplateId rdf:type rdf:Property ;
    rdfs:label 'Replacement Template Id' ;
    rdfs:comment 'Identifier of the template that supersedes this one when deprecated. Null if this is the current active version.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Template .

ind:applicableClientSegments rdf:type rdf:Property ;
    rdfs:label 'Applicable Client Segments' ;
    rdfs:comment 'Comma-separated list of client segments this template is appropriate for (e.g., Enterprise,Mid-Market,SMB,Government). Supports segment-specific contract terms.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableIndustries rdf:type rdf:Property ;
    rdfs:label 'Applicable Industries' ;
    rdfs:comment 'Comma-separated list of industries or sectors this template is designed for (e.g., Healthcare,Technology,Finance). Enables industry-specific clause selection.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurableParameters rdf:type rdf:Property ;
    rdfs:label 'Configurable Parameters' ;
    rdfs:comment 'JSON or comma-separated list of parameters that can be customized during contract generation (e.g., payment_terms,notice_period,liability_cap,indemnification_limit).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Type of contract this template generates: Master Service Agreement (MSA), Statement of Work (SOW), Non-Disclosure Agreement (NDA), Non-Compete Agreement, Amendment, or Independent Contractor (IC) Agreement.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Default Jurisdiction' ;
    rdfs:comment 'Default legal jurisdiction or governing law for contracts generated from this template (e.g., State of Delaware, State of California, Federal).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultLiabilityCapAmount rdf:type rdf:Property ;
    rdfs:label 'Default Liability Cap Amount' ;
    rdfs:comment 'Default maximum liability amount specified in the templates limitation of liability clause. Can be overridden during contract generation.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultLiabilityCapCurrency rdf:type rdf:Property ;
    rdfs:label 'Default Liability Cap Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the default liability cap amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Default Notice Period Days' ;
    rdfs:comment 'Default number of days required for contract termination notice as specified in the template. Can be overridden during contract generation.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defaultPaymentTerms rdf:type rdf:Property ;
    rdfs:label 'Default Payment Terms' ;
    rdfs:comment 'Default payment terms embedded in the template (e.g., Net 30, Net 45, 50% upfront, 50% on completion). Can be overridden during contract generation.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deprecatedDate rdf:type rdf:Property ;
    rdfs:label 'Deprecated Date' ;
    rdfs:comment 'Date when the template was marked as deprecated and replaced by a newer version. Null if the template is still active.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:docusignTemplateReference rdf:type rdf:Property ;
    rdfs:label 'Docusign Template Reference' ;
    rdfs:comment 'External identifier linking this template to the corresponding template in DocuSign CLM for e-signature workflow integration.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eSignatureEnabled rdf:type rdf:Property ;
    rdfs:label 'E Signature Enabled' ;
    rdfs:comment 'Indicates whether contracts generated from this template support electronic signature workflows via DocuSign or other e-signature platforms.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesCoeRiskClause rdf:type rdf:Property ;
    rdfs:label 'Includes Coe Risk Clause' ;
    rdfs:comment 'Indicates whether the template includes language addressing co-employment risk mitigation and liability allocation between staffing firm and client.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesDataPrivacyClause rdf:type rdf:Property ;
    rdfs:label 'Includes Data Privacy Clause' ;
    rdfs:comment 'Indicates whether the template includes data privacy and protection clauses compliant with GDPR, CCPA, or other applicable regulations.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesEeocComplianceClause rdf:type rdf:Property ;
    rdfs:label 'Includes Eeoc Compliance Clause' ;
    rdfs:comment 'Indicates whether the template includes EEOC compliance language ensuring non-discrimination in employment practices.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesFlsaComplianceClause rdf:type rdf:Property ;
    rdfs:label 'Includes Flsa Compliance Clause' ;
    rdfs:comment 'Indicates whether the template includes FLSA compliance language covering wage and hour requirements.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesIndemnificationClause rdf:type rdf:Property ;
    rdfs:label 'Includes Indemnification Clause' ;
    rdfs:comment 'Indicates whether the template includes a standard indemnification clause protecting the company from third-party claims.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesIpOwnershipClause rdf:type rdf:Property ;
    rdfs:label 'Includes Ip Ownership Clause' ;
    rdfs:comment 'Indicates whether the template includes a clause defining intellectual property ownership and work-for-hire provisions.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesNonSolicitationClause rdf:type rdf:Property ;
    rdfs:label 'Includes Non Solicitation Clause' ;
    rdfs:comment 'Indicates whether the template includes a non-solicitation clause preventing clients from directly hiring placed candidates.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesOfccpComplianceClause rdf:type rdf:Property ;
    rdfs:label 'Includes Ofccp Compliance Clause' ;
    rdfs:comment 'Indicates whether the template includes OFCCP compliance language for federal contractor obligations.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesWorkersCompClause rdf:type rdf:Property ;
    rdfs:label 'Includes Workers Comp Clause' ;
    rdfs:comment 'Indicates whether the template includes workers compensation insurance requirements and liability allocation.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Internal notes for legal and contracts teams regarding template usage, known issues, or special handling requirements. Not visible to end users.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'Most recent date a contract was generated from this template. Used to identify unused or obsolete templates.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optionalClauseMenu rdf:type rdf:Property ;
    rdfs:label 'Optional Clause Menu' ;
    rdfs:comment 'Comma-separated list of clause IDs or clause type codes that are available for selection during contract generation but not mandatory (e.g., NON_SOL,DATA_PRIV,WORKERS_COMP).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredClauseSet rdf:type rdf:Property ;
    rdfs:label 'Required Clause Set' ;
    rdfs:comment 'Comma-separated list of clause IDs or clause type codes that are mandatory in every contract generated from this template (e.g., INDEM_STD,LIM_LIAB,IP_OWN,EEOC_COMP).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateCode rdf:type rdf:Property ;
    rdfs:label 'Template Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the template for system integration and reference (e.g., MSA_TECH_V3, SOW_HC_STD).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateDescription rdf:type rdf:Property ;
    rdfs:label 'Template Description' ;
    rdfs:comment 'Detailed description of the templates purpose, intended use cases, and any special considerations for contract generation.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateName rdf:type rdf:Property ;
    rdfs:label 'Template Name' ;
    rdfs:comment 'Business-friendly name of the contract template (e.g., Standard MSA - Technology Sector, SOW Template - Healthcare Staffing).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateStatus rdf:type rdf:Property ;
    rdfs:label 'Template Status' ;
    rdfs:comment 'Current lifecycle status of the template. Only Active templates can be used for new contract generation.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Total number of contracts generated from this template. Used for template effectiveness analysis and retirement decisions.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementTitle rdf:type rdf:Property ;
    rdfs:label 'Agreement Title' ;
    rdfs:comment 'Descriptive title or name of the vendor agreement, summarizing the scope or purpose of the commercial relationship.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckStandard rdf:type rdf:Property ;
    rdfs:label 'Background Check Standard' ;
    rdfs:comment 'Description of the background check standard or level required for workers placed under this agreement, such as criminal history, employment verification, education verification, or credit check requirements.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversityCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Diversity Certification Status' ;
    rdfs:comment 'Diversity certification status of the vendor. MBE indicates Minority Business Enterprise; WBE indicates Women Business Enterprise; SDVOB indicates Service-Disabled Veteran-Owned Business; DBE indicates Disadvantaged Business Enterprise; VBE indicates Veteran Business Enterprise; LGBTBE indicates LGBT Business Enterprise; none indicates no diversity certification; multiple indicates vendor holds multiple certifications. [ENUM-REF-CANDIDATE: mbe|wbe|sdvob|dbe|vbe|lgbtbe|none|multiple — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeScheduleType rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule Type' ;
    rdfs:comment 'Type of fee structure governing vendor compensation. Flat fee indicates fixed amount per placement or period; percentage of bill rate indicates fee calculated as percentage of worker bill rate; tiered indicates fee varies by volume or worker level; cost plus indicates cost reimbursement plus fixed margin; negotiated indicates custom fee arrangement.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Internal Signatory Name' ;
    rdfs:comment 'Full name of the authorized representative who signed the vendor agreement on behalf of Staffing Hr.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Internal Signatory Title' ;
    rdfs:comment 'Job title or role of the authorized representative who signed the vendor agreement on behalf of Staffing Hr.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markupCapPercentage rdf:type rdf:Property ;
    rdfs:label 'Markup Cap Percentage' ;
    rdfs:comment 'Maximum allowable markup percentage that the vendor may apply to pay rates when billing the client. Used to control vendor margin and ensure competitive pricing within VMS programs.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierClassification rdf:type rdf:Property ;
    rdfs:label 'Tier Classification' ;
    rdfs:comment 'Tier or classification level of the vendor within the supply chain hierarchy. Tier 1 represents preferred or strategic vendors; Tier 2 represents standard approved vendors; Tier 3 represents conditional or limited-use vendors.' ;
    rdfs:domain ind:VendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorProfileId rdf:type rdf:Property ;
    rdfs:label 'Contractor Profile Id' ;
    rdfs:comment 'Reference to the independent contractors candidate profile in the system.' ;
    rdfs:domain ind:IcAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:clientSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Client Signatory Name' ;
    rdfs:comment 'Name of the authorized representative from the client organization who signed the independent contractor agreement.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Client Signatory Title' ;
    rdfs:comment 'Job title or position of the client signatory who executed the independent contractor agreement.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Contractor Signatory Name' ;
    rdfs:comment 'Name of the independent contractor or their authorized representative who signed the agreement.' ;
    rdfs:domain ind:IcAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenseReimbursementFlag rdf:type rdf:Property ;
    rdfs:label 'Expense Reimbursement Flag' ;
    rdfs:comment 'Indicates whether the independent contractor is eligible for reimbursement of approved business expenses incurred during service delivery.' ;
    rdfs:domain ind:IcAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:form1099ReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Form 1099 Reporting Flag' ;
    rdfs:comment 'Indicates whether payments to this independent contractor are subject to IRS Form 1099-NEC reporting requirements. Critical for tax compliance.' ;
    rdfs:domain ind:IcAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Required Flag' ;
    rdfs:comment 'Indicates whether the independent contractor is required to maintain specific insurance coverage (e.g., general liability, professional liability, errors and omissions) as a condition of the agreement.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipAssignmentClause rdf:type rdf:Property ;
    rdfs:label 'Ip Assignment Clause' ;
    rdfs:comment 'Terms governing ownership and assignment of intellectual property created by the independent contractor during the engagement (work-for-hire, full assignment to client, shared ownership, contractor retains rights, or custom negotiated terms).' ;
    rdfs:domain ind:IcAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonCompeteFlag rdf:type rdf:Property ;
    rdfs:label 'Non Compete Flag' ;
    rdfs:comment 'Indicates whether the agreement includes a non-compete clause restricting the contractor from competing with the client during or after the engagement.' ;
    rdfs:domain ind:IcAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonCompetePeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Non Compete Period Months' ;
    rdfs:comment 'Duration in months that the non-compete restriction remains in effect after agreement termination. Null if non_compete_flag is false.' ;
    rdfs:domain ind:IcAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentCurrency rdf:type rdf:Property ;
    rdfs:label 'Payment Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the payment rate and all financial terms in this agreement.' ;
    rdfs:domain ind:IcAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentRate rdf:type rdf:Property ;
    rdfs:label 'Payment Rate' ;
    rdfs:comment 'Agreed-upon rate of compensation for the independent contractor. Interpretation depends on payment_structure (e.g., hourly rate, project fee, monthly retainer).' ;
    rdfs:domain ind:IcAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentStructure rdf:type rdf:Property ;
    rdfs:label 'Payment Structure' ;
    rdfs:comment 'Method by which the independent contractor is compensated (hourly, daily, weekly, monthly, per project, per deliverable, milestone-based, or commission). [ENUM-REF-CANDIDATE: hourly|daily|weekly|monthly|per_project|per_deliverable|milestone|commission — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IcAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:professionalLiabilityMinimumUsd rdf:type rdf:Property ;
    rdfs:label 'Professional Liability Minimum Usd' ;
    rdfs:comment 'Minimum required professional liability or errors and omissions insurance coverage amount in USD that the independent contractor must maintain. Null if not required.' ;
    rdfs:domain ind:IcAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scopeOfServices rdf:type rdf:Property ;
    rdfs:label 'Scope Of Services' ;
    rdfs:comment 'Detailed description of the services, deliverables, and work to be performed by the independent contractor under this agreement.' ;
    rdfs:domain ind:IcAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationForCauseAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Termination For Cause Allowed Flag' ;
    rdfs:comment 'Indicates whether the agreement permits immediate termination for cause (e.g., breach of contract, misconduct, failure to perform).' ;
    rdfs:domain ind:IcAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:w9OnFileFlag rdf:type rdf:Property ;
    rdfs:label 'W9 On File Flag' ;
    rdfs:comment 'Indicates whether a completed IRS Form W-9 (Request for Taxpayer Identification Number and Certification) has been received and is on file for this independent contractor.' ;
    rdfs:domain ind:IcAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workerClassificationBasis rdf:type rdf:Property ;
    rdfs:label 'Worker Classification Basis' ;
    rdfs:comment 'Legal and regulatory basis for classifying the worker as an independent contractor (e.g., IRS 20-factor test, ABC test, economic realities test, common law test). Critical for co-employment risk management and IRS compliance.' ;
    rdfs:domain ind:IcAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentId rdf:type rdf:Property ;
    rdfs:label 'Document Id' ;
    rdfs:comment 'Unique identifier for the contract document record. Primary key.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentDocumentContractDocumentId rdf:type rdf:Property ;
    rdfs:label 'Parent Document Contract Document Id' ;
    rdfs:comment 'Reference to the contract document ID that this document amends or supersedes. Nullable for original documents.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:primarySupersededByDocumentContractDocumentId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Document Contract Document Id' ;
    rdfs:comment 'Reference to the contract document ID that supersedes or replaces this document. Nullable if this is the current active version.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:amendmentFlag rdf:type rdf:Property ;
    rdfs:label 'Amendment Flag' ;
    rdfs:comment 'Boolean indicator whether this document is an amendment to an existing contract (True) or an original contract document (False).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditTrailAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Available Flag' ;
    rdfs:comment 'Boolean indicator whether a complete audit trail of document creation, modification, and signature events is available (True) or not (False).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checksumHash rdf:type rdf:Property ;
    rdfs:label 'Checksum Hash' ;
    rdfs:comment 'Cryptographic hash (e.g., SHA-256) of the document file content to ensure integrity and detect tampering.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientSignatoryEmail rdf:type rdf:Property ;
    rdfs:label 'Client Signatory Email' ;
    rdfs:comment 'Email address of the client signatory used for e-signature delivery and notifications.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityClassification rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Classification' ;
    rdfs:comment 'Data classification level of the contract document content (Public, Internal, Confidential, Restricted) per organizational information security policy.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Date when the contract document record was first created in the system.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentName rdf:type rdf:Property ;
    rdfs:label 'Document Name' ;
    rdfs:comment 'Human-readable name or title of the contract document file (e.g., MSA Amendment 3 - Rate Schedule Update).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esignatureCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Esignature Completed Flag' ;
    rdfs:comment 'Boolean indicator whether all required e-signatures have been collected via DocuSign CLM (True) or signatures are still pending (False).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Date when the contract document record or file was last updated or modified.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReviewCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Legal Review Completed Date' ;
    rdfs:comment 'Date when legal department review and approval of this contract document was completed. Nullable if not yet reviewed or review not required.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Review Required Flag' ;
    rdfs:comment 'Boolean indicator whether this document requires legal department review and approval before execution (True) or not (False).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pageCount rdf:type rdf:Property ;
    rdfs:label 'Page Count' ;
    rdfs:comment 'Total number of pages in the contract document file.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiry Date' ;
    rdfs:comment 'Date after which the contract document may be purged or archived per the applicable retention policy.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retentionPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Retention Policy Code' ;
    rdfs:comment 'Code identifying the data retention policy classification governing how long this document must be retained per FCRA, GDPR, CCPA, and internal compliance requirements.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryCount rdf:type rdf:Property ;
    rdfs:label 'Signatory Count' ;
    rdfs:comment 'Total number of signatories required to fully execute this contract document.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Reference path or URI to the physical storage location of the document file in the DocuSign CLM vault or enterprise document repository.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorSignatoryEmail rdf:type rdf:Property ;
    rdfs:label 'Vendor Signatory Email' ;
    rdfs:comment 'Email address of the vendor signatory used for e-signature delivery and notifications.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskChecklistId rdf:type rdf:Property ;
    rdfs:label 'Task Checklist Id' ;
    rdfs:comment 'Foreign key linking to payroll.task_checklist. Business justification: Each onboarding engagement uses a specific task checklist template. This links the engagement to the checklist definition and enables tracking which checklist template is being used for this onboardin' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaskChecklist .

ind:actualOnboardingDays rdf:type rdf:Property ;
    rdfs:label 'Actual Onboarding Days' ;
    rdfs:comment 'Actual number of business days taken to complete the onboarding process from start to ready-for-assignment.' ;
    rdfs:domain ind:OnboardingEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualReadyDate rdf:type rdf:Property ;
    rdfs:label 'Actual Ready Date' ;
    rdfs:comment 'Actual date when the worker completed all onboarding requirements and became ready for assignment start.' ;
    rdfs:domain ind:OnboardingEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completedTasksCount rdf:type rdf:Property ;
    rdfs:label 'Completed Tasks Count' ;
    rdfs:comment 'Number of onboarding tasks that have been completed.' ;
    rdfs:domain ind:OnboardingEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'Percentage of onboarding tasks and requirements completed, calculated as (completed_tasks / total_tasks) * 100.' ;
    rdfs:domain ind:OnboardingEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:directDepositStatus rdf:type rdf:Property ;
    rdfs:label 'Direct Deposit Status' ;
    rdfs:comment 'Current status of the workers direct deposit banking information setup for payroll.' ;
    rdfs:domain ind:OnboardingEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentProvisioningStatus rdf:type rdf:Property ;
    rdfs:label 'Equipment Provisioning Status' ;
    rdfs:comment 'Current status of equipment and asset provisioning for the worker (laptop, phone, badge, etc.). [ENUM-REF-CANDIDATE: not_required|pending|ordered|shipped|delivered|assigned|returned — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OnboardingEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fteValue rdf:type rdf:Property ;
    rdfs:label 'Fte Value' ;
    rdfs:comment 'Full-Time Equivalent value representing the workers scheduled work capacity (1.0 = full-time, 0.5 = half-time).' ;
    rdfs:domain ind:OnboardingEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdReason rdf:type rdf:Property ;
    rdfs:label 'Hold Reason' ;
    rdfs:comment 'Reason why the onboarding engagement was placed on hold.' ;
    rdfs:domain ind:OnboardingEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Completion Date' ;
    rdfs:comment 'Date when all onboarding tasks, documents, and requirements were fully completed and the engagement was closed.' ;
    rdfs:domain ind:OnboardingEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingNotes rdf:type rdf:Property ;
    rdfs:label 'Onboarding Notes' ;
    rdfs:comment 'Free-text notes and comments related to this onboarding engagement, capturing special instructions, issues, or coordinator observations.' ;
    rdfs:domain ind:OnboardingEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingNumber rdf:type rdf:Property ;
    rdfs:label 'Onboarding Number' ;
    rdfs:comment 'Human-readable business identifier for this onboarding engagement, used for tracking and reference across systems.' ;
    rdfs:domain ind:OnboardingEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingPriority rdf:type rdf:Property ;
    rdfs:label 'Onboarding Priority' ;
    rdfs:comment 'Priority level assigned to this onboarding engagement based on business urgency and client requirements.' ;
    rdfs:domain ind:OnboardingEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingStartDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Start Date' ;
    rdfs:comment 'Date when the onboarding process was initiated for this worker.' ;
    rdfs:domain ind:OnboardingEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingType rdf:type rdf:Property ;
    rdfs:label 'Onboarding Type' ;
    rdfs:comment 'Classification of the onboarding engagement based on the employment arrangement type.' ;
    rdfs:domain ind:OnboardingEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orientationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Orientation Completion Date' ;
    rdfs:comment 'Date when the worker completed the orientation session.' ;
    rdfs:domain ind:OnboardingEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orientationStatus rdf:type rdf:Property ;
    rdfs:label 'Orientation Status' ;
    rdfs:comment 'Current status of the worker orientation session completion.' ;
    rdfs:domain ind:OnboardingEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overdueTasksCount rdf:type rdf:Property ;
    rdfs:label 'Overdue Tasks Count' ;
    rdfs:comment 'Number of onboarding tasks that are past their due date.' ;
    rdfs:domain ind:OnboardingEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pendingTasksCount rdf:type rdf:Property ;
    rdfs:label 'Pending Tasks Count' ;
    rdfs:comment 'Number of onboarding tasks that are still pending completion.' ;
    rdfs:domain ind:OnboardingEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetReadyDate rdf:type rdf:Property ;
    rdfs:label 'Target Ready Date' ;
    rdfs:comment 'Target date by which the worker should be fully onboarded and ready to start their assignment.' ;
    rdfs:domain ind:OnboardingEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxFormsStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Forms Status' ;
    rdfs:comment 'Current status of required tax withholding forms completion (W-4, state withholding forms).' ;
    rdfs:domain ind:OnboardingEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTasksCount rdf:type rdf:Property ;
    rdfs:label 'Total Tasks Count' ;
    rdfs:comment 'Total number of onboarding tasks assigned to this engagement.' ;
    rdfs:domain ind:OnboardingEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'Date when all required training modules were completed by the worker.' ;
    rdfs:domain ind:OnboardingEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingStatus rdf:type rdf:Property ;
    rdfs:label 'Training Status' ;
    rdfs:comment 'Current status of required training assignments via Learning Management System (LMS).' ;
    rdfs:domain ind:OnboardingEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitsTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Benefits Termination Date' ;
    rdfs:comment 'Date when the workers health, dental, vision, and other benefits coverage ends. Typically end of month following separation or last day worked.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientFeedbackRating rdf:type rdf:Property ;
    rdfs:label 'Client Feedback Rating' ;
    rdfs:comment 'Numeric rating provided by the client regarding the workers overall performance during the assignment. Scale typically 1-5 or 1-10.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clientFeedbackReceived rdf:type rdf:Property ;
    rdfs:label 'Client Feedback Received' ;
    rdfs:comment 'Flag indicating whether feedback was received from the client regarding the workers performance and the reason for assignment end.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cobraNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Cobra Notification Date' ;
    rdfs:comment 'Date when COBRA continuation coverage notification was sent to the worker. Must occur within 14 days of separation per federal law.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cobraNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Cobra Notification Required' ;
    rdfs:comment 'Flag indicating whether the worker is eligible for COBRA continuation coverage and must receive notification. Based on benefits enrollment and separation circumstances.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conversionToPermFlag rdf:type rdf:Property ;
    rdfs:label 'Conversion To Perm Flag' ;
    rdfs:comment 'Indicates whether the worker is being converted to a permanent employee of the client. Triggers conversion fee billing and positive outcome tracking.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentReturnDate rdf:type rdf:Property ;
    rdfs:label 'Equipment Return Date' ;
    rdfs:comment 'Date when all required equipment was returned and verified. Null if equipment return is pending or not applicable.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentReturnRequired rdf:type rdf:Property ;
    rdfs:label 'Equipment Return Required' ;
    rdfs:comment 'Flag indicating whether the worker has company or client equipment that must be returned as part of offboarding.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentReturnStatus rdf:type rdf:Property ;
    rdfs:label 'Equipment Return Status' ;
    rdfs:comment 'Current status of equipment return process. Tracks whether all issued equipment has been returned and accounted for.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitInterviewDate rdf:type rdf:Property ;
    rdfs:label 'Exit Interview Date' ;
    rdfs:comment 'Date when the exit interview was conducted. Null if exit interview was not completed.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exitInterviewStatus rdf:type rdf:Property ;
    rdfs:label 'Exit Interview Status' ;
    rdfs:comment 'Indicates whether an exit interview was conducted with the departing worker. Used for retention analytics and quality improvement.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitReasonCategory rdf:type rdf:Property ;
    rdfs:label 'Exit Reason Category' ;
    rdfs:comment 'High-level categorization of the reason for separation. Used for turnover analytics and retention strategy development. [ENUM-REF-CANDIDATE: compensation|career_growth|work_environment|personal|relocation|performance|client_relationship|commute|benefits|workload|culture — promote to reference product]' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitReasonNotes rdf:type rdf:Property ;
    rdfs:label 'Exit Reason Notes' ;
    rdfs:comment 'Detailed notes capturing the specific reasons for separation as provided by the worker or client. Confidential information used for internal analysis.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalPayrollDate rdf:type rdf:Property ;
    rdfs:label 'Final Payroll Date' ;
    rdfs:comment 'Date when the workers final paycheck was processed. Used for payroll reconciliation and compliance reporting.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalTimesheetStatus rdf:type rdf:Property ;
    rdfs:label 'Final Timesheet Status' ;
    rdfs:comment 'Status of the workers final timesheet submission and approval. Critical for ensuring complete and accurate final payroll processing.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDayWorked rdf:type rdf:Property ;
    rdfs:label 'Last Day Worked' ;
    rdfs:comment 'The final date the worker performed work for the client. Used for payroll cutoff, benefits termination, and compliance reporting.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noticeDate rdf:type rdf:Property ;
    rdfs:label 'Notice Date' ;
    rdfs:comment 'Date when notice of separation was provided by either the worker, client, or staffing company. Used to track notice period compliance.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offboardingChecklistCompletionPct rdf:type rdf:Property ;
    rdfs:label 'Offboarding Checklist Completion Pct' ;
    rdfs:comment 'Percentage of required offboarding tasks completed. Calculated from offboarding task checklist. Used to track offboarding process progress.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offboardingCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Offboarding Completed Date' ;
    rdfs:comment 'Date when all offboarding tasks were completed and the offboarding record was closed. Represents the official end of the offboarding workflow.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offboardingInitiatedBy rdf:type rdf:Property ;
    rdfs:label 'Offboarding Initiated By' ;
    rdfs:comment 'Party that initiated the separation or assignment end. Used for turnover analytics and client relationship management.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offboardingStatus rdf:type rdf:Property ;
    rdfs:label 'Offboarding Status' ;
    rdfs:comment 'Current state of the offboarding workflow. Tracks progress through the offboarding process from initiation to completion.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offboardingType rdf:type rdf:Property ;
    rdfs:label 'Offboarding Type' ;
    rdfs:comment 'Classification of the offboarding event. Indicates the reason and nature of the assignment end or separation. [ENUM-REF-CANDIDATE: assignment_end|voluntary_resignation|client_termination|conversion_to_perm|redeployment|involuntary_termination|performance_termination|contract_completion|mutual_separation|no_call_no_show — promote to reference product]' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ptoPayoutAmount rdf:type rdf:Property ;
    rdfs:label 'Pto Payout Amount' ;
    rdfs:comment 'Dollar amount of unused PTO paid out to the worker upon separation. Calculated based on accrued balance and applicable state laws.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ptoPayoutHours rdf:type rdf:Property ;
    rdfs:label 'Pto Payout Hours' ;
    rdfs:comment 'Number of unused PTO hours paid out to the worker upon separation. Used for payroll calculation and benefits reconciliation.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redeploymentFlag rdf:type rdf:Property ;
    rdfs:label 'Redeployment Flag' ;
    rdfs:comment 'Indicates whether the worker is being placed on the bench for redeployment to another assignment rather than full separation. Links to redeployment_candidate when true.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rehireEligibilityReason rdf:type rdf:Property ;
    rdfs:label 'Rehire Eligibility Reason' ;
    rdfs:comment 'Explanation for the rehire eligibility determination. Documents performance issues, policy violations, or positive separation circumstances.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:separationDate rdf:type rdf:Property ;
    rdfs:label 'Separation Date' ;
    rdfs:comment 'Official date of employment separation from the staffing company. May differ from last day worked due to notice periods or administrative processing.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:systemAccessRevocationDate rdf:type rdf:Property ;
    rdfs:label 'System Access Revocation Date' ;
    rdfs:comment 'Date when all system access was revoked. Should typically occur on or before the last day worked for security purposes.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:systemAccessRevoked rdf:type rdf:Property ;
    rdfs:label 'System Access Revoked' ;
    rdfs:comment 'Flag indicating whether all system access credentials (email, VPN, applications) have been deactivated. Critical for information security compliance.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unemploymentClaimFiled rdf:type rdf:Property ;
    rdfs:label 'Unemployment Claim Filed' ;
    rdfs:comment 'Flag indicating whether the worker filed for unemployment benefits following separation. Used for SUTA rate management and compliance tracking.' ;
    rdfs:domain ind:OffboardingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:activeStatus rdf:type rdf:Property ;
    rdfs:label 'Active Status' ;
    rdfs:comment 'Current lifecycle status of the checklist template: active (in use), inactive (temporarily disabled), draft (under development), or archived (retired but retained for historical reference).' ;
    rdfs:domain ind:TaskChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether completion of this checklist requires formal approval or sign-off before the worker can start assignment (True) or is informational only (False).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checklistCode rdf:type rdf:Property ;
    rdfs:label 'Checklist Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the checklist template for system integration and reporting (e.g., HC-TEMP-ONB, IT-CTR-ONB).' ;
    rdfs:domain ind:TaskChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistName rdf:type rdf:Property ;
    rdfs:label 'Checklist Name' ;
    rdfs:comment 'Business-friendly name of the task checklist template (e.g., Healthcare Temp Onboarding, IT Contractor Onboarding, Light Industrial Assignment End).' ;
    rdfs:domain ind:TaskChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistType rdf:type rdf:Property ;
    rdfs:label 'Checklist Type' ;
    rdfs:comment 'Category of the checklist template indicating the business process it supports: onboarding (new worker start), offboarding (assignment end), redeployment (worker reassignment), or extension (assignment continuation).' ;
    rdfs:domain ind:TaskChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDrivenFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Driven Flag' ;
    rdfs:comment 'Indicates whether this checklist is driven by regulatory or compliance requirements (True) such as I-9, E-Verify, background checks, or is purely operational (False).' ;
    rdfs:domain ind:TaskChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:divisionCode rdf:type rdf:Property ;
    rdfs:label 'Division Code' ;
    rdfs:comment 'Business division or vertical this checklist is designed for (e.g., Healthcare, IT, Light Industrial, Professional). Nullable if checklist is division-agnostic.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCompletionDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Completion Days' ;
    rdfs:comment 'Expected number of business days required to complete all tasks in this checklist under normal circumstances. Used for planning and Service Level Agreement (SLA) management.' ;
    rdfs:domain ind:TaskChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Flag' ;
    rdfs:comment 'Indicates whether completion of this checklist is mandatory (True) for the associated placement type and scenario, or optional (False).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownerRole rdf:type rdf:Property ;
    rdfs:label 'Owner Role' ;
    rdfs:comment 'Business role or department responsible for maintaining and updating this checklist template (e.g., Onboarding Team, Compliance Department, Credentialing Team).' ;
    rdfs:domain ind:TaskChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Business priority level of this checklist template indicating urgency and resource allocation: critical (blocking), high (time-sensitive), medium (standard), or low (best-effort).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresEquipmentFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Equipment Flag' ;
    rdfs:comment 'Indicates whether this checklist includes equipment provisioning tasks (laptop, phone, badge, tools, Personal Protective Equipment (PPE), etc.).' ;
    rdfs:domain ind:TaskChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresEverifyFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Everify Flag' ;
    rdfs:comment 'Indicates whether this checklist includes E-Verify electronic employment eligibility verification as a required task, typically for federal contractors or specific state requirements.' ;
    rdfs:domain ind:TaskChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresI9Flag rdf:type rdf:Property ;
    rdfs:label 'Requires I9 Flag' ;
    rdfs:comment 'Indicates whether this checklist includes I-9 Employment Eligibility Verification as a required task, per Immigration and Nationality Act (INA) requirements.' ;
    rdfs:domain ind:TaskChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresLmsTrainingFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Lms Training Flag' ;
    rdfs:comment 'Indicates whether this checklist includes Learning Management System (LMS) training assignments via SAP SuccessFactors or similar platform.' ;
    rdfs:domain ind:TaskChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresOrientationFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Orientation Flag' ;
    rdfs:comment 'Indicates whether this checklist includes worker orientation or onboarding training as a required task.' ;
    rdfs:domain ind:TaskChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaHours rdf:type rdf:Property ;
    rdfs:label 'Sla Hours' ;
    rdfs:comment 'Service Level Agreement (SLA) target in hours for completing all tasks in this checklist from initiation. Used for performance measurement and client commitments.' ;
    rdfs:domain ind:TaskChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskChecklistDescription rdf:type rdf:Property ;
    rdfs:label 'Task Checklist Description' ;
    rdfs:comment 'Detailed description of the checklist template purpose, scope, and intended use cases. Provides context for users selecting appropriate templates.' ;
    rdfs:domain ind:TaskChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskCount rdf:type rdf:Property ;
    rdfs:label 'Task Count' ;
    rdfs:comment 'Total number of individual tasks defined within this checklist template. Used for progress tracking and workload estimation.' ;
    rdfs:domain ind:TaskChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Task Assignment Id' ;
    rdfs:comment 'Unique identifier for the task assignment record. Primary key.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaskAssignment .

ind:dependencyTaskTaskAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Dependency Task Task Assignment Id' ;
    rdfs:comment 'Reference to another task assignment that must be completed before this task can begin. Supports sequential task workflows and conditional logic.' ;
    rdfs:domain ind:TaskAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaskAssignment .

ind:documentCollectionId rdf:type rdf:Property ;
    rdfs:label 'Document Collection Id' ;
    rdfs:comment 'Foreign key linking to payroll.document_collection. Business justification: Task assignments can track collection of specific documents. This links the task to the document collection record and enables tracking document submission as a task completion criterion. The existing' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocumentCollection .

ind:firstShiftId rdf:type rdf:Property ;
    rdfs:label 'First Shift Id' ;
    rdfs:comment 'Foreign key linking to timesheet.shift. Business justification: Onboarding task completion verification requires confirming the worker completed their first scheduled shift. This is a standard gate for orientation effectiveness measurement, early-tenure quality ch' ;
    rdfs:domain ind:TaskAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shift .

ind:scheduleId rdf:type rdf:Property ;
    rdfs:label 'Schedule Id' ;
    rdfs:comment 'Foreign key linking to timesheet.schedule. Business justification: Schedule setup is a distinct onboarding task in staffing — confirming the worker\'s recurring shift schedule is configured before first day. Distinct from first_shift_id (single shift occurrence); sche' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Schedule .

ind:accessGrantedDate rdf:type rdf:Property ;
    rdfs:label 'Access Granted Date' ;
    rdfs:comment 'The date when system access was successfully provisioned. Null if access has not yet been granted or task is not access-related.' ;
    rdfs:domain ind:TaskAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accessRevokedDate rdf:type rdf:Property ;
    rdfs:label 'Access Revoked Date' ;
    rdfs:comment 'The date when system access was revoked during offboarding. Null if access has not been revoked or task is not access-related.' ;
    rdfs:domain ind:TaskAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'The precise date and time when the task was marked as completed. Provides audit trail for compliance and SLA reporting.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:equipmentItemCode rdf:type rdf:Property ;
    rdfs:label 'Equipment Item Code' ;
    rdfs:comment 'Reference to the specific equipment item being provisioned or returned as part of this task. Examples: laptop, phone, badge, uniform, tools.' ;
    rdfs:domain ind:TaskAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Minutes' ;
    rdfs:comment 'The estimated time in minutes required to complete this task. Used for workload planning and worker communication.' ;
    rdfs:domain ind:TaskAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalTaskReference rdf:type rdf:Property ;
    rdfs:label 'External Task Reference' ;
    rdfs:comment 'The unique identifier for this task in the source system. Enables cross-system reconciliation and integration.' ;
    rdfs:domain ind:TaskAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBlocking rdf:type rdf:Property ;
    rdfs:label 'Is Blocking' ;
    rdfs:comment 'Indicates whether this task must be completed before the worker can start their assignment. True for critical compliance tasks like I-9, background checks, drug screens.' ;
    rdfs:domain ind:TaskAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReminderSentDate rdf:type rdf:Property ;
    rdfs:label 'Last Reminder Sent Date' ;
    rdfs:comment 'The date when the most recent reminder notification was sent for this task. Used to control reminder frequency and escalation timing.' ;
    rdfs:domain ind:TaskAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'The role or party responsible for completing or facilitating this task. Identifies who must take action to move the task forward. [ENUM-REF-CANDIDATE: worker|recruiter|onboarding_coordinator|client|hr_admin|it_admin|facilities|payroll — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TaskAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'The date when the task becomes active and available for completion. Supports phased onboarding workflows where tasks unlock sequentially.' ;
    rdfs:domain ind:TaskAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:systemAccessType rdf:type rdf:Property ;
    rdfs:label 'System Access Type' ;
    rdfs:comment 'The type of system access being provisioned or revoked. Examples: ATS, VMS, ERP, Email, VPN, Client Portal, Timekeeping System.' ;
    rdfs:domain ind:TaskAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskCategory rdf:type rdf:Property ;
    rdfs:label 'Task Category' ;
    rdfs:comment 'Classification of the task type. Categorizes tasks into functional groups for reporting and workflow management. [ENUM-REF-CANDIDATE: document_collection|orientation|training|equipment|compliance|credentialing|system_access|benefits_enrollment|exit_interview|knowledge_transfer — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TaskAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskDescription rdf:type rdf:Property ;
    rdfs:label 'Task Description' ;
    rdfs:comment 'Detailed description of the task requirements, instructions, and expected deliverables. Provides context and guidance for task completion.' ;
    rdfs:domain ind:TaskAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskName rdf:type rdf:Property ;
    rdfs:label 'Task Name' ;
    rdfs:comment 'Short descriptive name of the task assignment. Examples: Complete I-9 Form, Submit Direct Deposit Form, Complete Safety Orientation, Return Equipment.' ;
    rdfs:domain ind:TaskAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskPriority rdf:type rdf:Property ;
    rdfs:label 'Task Priority' ;
    rdfs:comment 'Priority level of the task assignment. Critical tasks block assignment start; high priority tasks are time-sensitive; medium and low priority tasks are standard workflow items.' ;
    rdfs:domain ind:TaskAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current lifecycle status of the task assignment. Tracks progression from assignment through completion or cancellation. [ENUM-REF-CANDIDATE: not_started|in_progress|pending_review|completed|waived|cancelled|overdue — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TaskAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskSubcategory rdf:type rdf:Property ;
    rdfs:label 'Task Subcategory' ;
    rdfs:comment 'More granular classification within the task category. Examples: Tax Forms, Safety Training, Background Check, Laptop Return.' ;
    rdfs:domain ind:TaskAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompletionScore rdf:type rdf:Property ;
    rdfs:label 'Training Completion Score' ;
    rdfs:comment 'The score or percentage achieved by the worker on the training assessment. Null if training does not include assessment or not yet completed.' ;
    rdfs:domain ind:TaskAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waivedDate rdf:type rdf:Property ;
    rdfs:label 'Waived Date' ;
    rdfs:comment 'The date when this task was waived. Null if task was not waived.' ;
    rdfs:domain ind:TaskAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxFormSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Tax Form Submission Id' ;
    rdfs:comment 'Unique identifier for the tax form submission record. Primary key.' ;
    rdfs:domain ind:TaxFormSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersedesSubmissionTaxFormSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Supersedes Submission Tax Form Submission Id' ;
    rdfs:comment 'Identifier of the prior tax form submission that this submission replaces. Workers may submit updated forms when life events (marriage, dependents, income changes) affect withholding. Null for initial submissions.' ;
    rdfs:domain ind:TaxFormSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxFormSubmission .

ind:backupWithholdingIndicator rdf:type rdf:Property ;
    rdfs:label 'Backup Withholding Indicator' ;
    rdfs:comment 'Indicates whether the payee is subject to backup withholding (currently 24% federal rate). IRS notifies payers when backup withholding is required due to TIN mismatch or underreporting.' ;
    rdfs:domain ind:TaxFormSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessName rdf:type rdf:Property ;
    rdfs:label 'Business Name' ;
    rdfs:comment 'Legal business name for independent contractors (1099 workers) who operate as business entities. Captured on W-9 forms.' ;
    rdfs:domain ind:TaxFormSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependentsAmount rdf:type rdf:Property ;
    rdfs:label 'Dependents Amount' ;
    rdfs:comment 'Dollar amount of dependent credits claimed on the W-4 (Step 3). Reduces withholding based on qualifying dependents.' ;
    rdfs:domain ind:TaxFormSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exemptExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Exempt Expiration Date' ;
    rdfs:comment 'Date on which the workers exemption from withholding expires. IRS requires annual renewal of exemption claims by February 15.' ;
    rdfs:domain ind:TaxFormSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exemptStatus rdf:type rdf:Property ;
    rdfs:label 'Exempt Status' ;
    rdfs:comment 'Indicates whether the worker claims exemption from federal and/or state income tax withholding. Workers must meet IRS criteria (no tax liability prior year and current year) to claim exemption.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extraWithholdingAmount rdf:type rdf:Property ;
    rdfs:label 'Extra Withholding Amount' ;
    rdfs:comment 'Additional dollar amount the worker requests to be withheld from each paycheck, declared on W-4 Step 4(c). Used to avoid underpayment penalties or increase refund.' ;
    rdfs:domain ind:TaxFormSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:formVersion rdf:type rdf:Property ;
    rdfs:label 'Form Version' ;
    rdfs:comment 'Version or year of the tax form template used (e.g., 2023, 2024). IRS and state agencies periodically update form layouts and calculation rules.' ;
    rdfs:domain ind:TaxFormSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localExemptions rdf:type rdf:Property ;
    rdfs:label 'Local Exemptions' ;
    rdfs:comment 'Number of exemptions claimed for local tax withholding purposes.' ;
    rdfs:domain ind:TaxFormSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:localTaxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Local Tax Jurisdiction' ;
    rdfs:comment 'Name or code of the local tax jurisdiction (city, county, school district) for which local withholding applies. Relevant in states with local income taxes (e.g., Ohio, Pennsylvania, Indiana).' ;
    rdfs:domain ind:TaxFormSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multipleJobsIndicator rdf:type rdf:Property ;
    rdfs:label 'Multiple Jobs Indicator' ;
    rdfs:comment 'Indicates whether the worker has multiple jobs or a working spouse, requiring adjusted withholding calculation per IRS W-4 Step 2.' ;
    rdfs:domain ind:TaxFormSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payrollSystemSyncDate rdf:type rdf:Property ;
    rdfs:label 'Payroll System Sync Date' ;
    rdfs:comment 'Timestamp when the withholding configuration was successfully synchronized to the payroll system.' ;
    rdfs:domain ind:TaxFormSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:payrollSystemSyncStatus rdf:type rdf:Property ;
    rdfs:label 'Payroll System Sync Status' ;
    rdfs:comment 'Indicates whether the withholding configuration from this form has been successfully transmitted to and applied in the payroll processing system (TempWorks Payroll).' ;
    rdfs:domain ind:TaxFormSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureDate rdf:type rdf:Property ;
    rdfs:label 'Signature Date' ;
    rdfs:comment 'Date on which the worker signed the tax form, certifying the information is accurate under penalty of perjury. Required for legal validity of the form.' ;
    rdfs:domain ind:TaxFormSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signatureMethod rdf:type rdf:Property ;
    rdfs:label 'Signature Method' ;
    rdfs:comment 'Method by which the worker signed the form. Electronic signatures via DocuSign or similar platforms are legally equivalent to wet signatures under ESIGN Act.' ;
    rdfs:domain ind:TaxFormSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateAllowances rdf:type rdf:Property ;
    rdfs:label 'State Allowances' ;
    rdfs:comment 'Number of state withholding allowances claimed. Some states still use allowance-based withholding systems (pre-2020 federal model).' ;
    rdfs:domain ind:TaxFormSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stateExtraWithholdingAmount rdf:type rdf:Property ;
    rdfs:label 'State Extra Withholding Amount' ;
    rdfs:comment 'Additional dollar amount the worker requests to be withheld for state taxes from each paycheck.' ;
    rdfs:domain ind:TaxFormSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date on which the worker submitted the completed tax form. Used for compliance tracking and audit trail.' ;
    rdfs:domain ind:TaxFormSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tinType rdf:type rdf:Property ;
    rdfs:label 'Tin Type' ;
    rdfs:comment 'Type of Taxpayer Identification Number provided on the form. SSN (Social Security Number) for W-2 employees, EIN (Employer Identification Number) for business entities, ITIN (Individual Taxpayer Identification Number) for non-resident aliens.' ;
    rdfs:domain ind:TaxFormSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tinValue rdf:type rdf:Property ;
    rdfs:label 'Tin Value' ;
    rdfs:comment 'The actual Taxpayer Identification Number (SSN, EIN, or ITIN) provided by the worker. Highly sensitive PII used for tax reporting and payroll processing.' ;
    rdfs:domain ind:TaxFormSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountNumberLastFour rdf:type rdf:Property ;
    rdfs:label 'Account Number Last Four' ;
    rdfs:comment 'Last four digits of the bank account number. Used for display and worker verification purposes without exposing the full account number.' ;
    rdfs:domain ind:DirectDepositSetup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:achReturnCode rdf:type rdf:Property ;
    rdfs:label 'Ach Return Code' ;
    rdfs:comment 'Standard NACHA return code if the direct deposit transaction was returned by the receiving bank. Examples: R01 (insufficient funds), R02 (account closed), R03 (no account/unable to locate), R04 (invalid account number).' ;
    rdfs:domain ind:DirectDepositSetup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Method by which pay is allocated to this account. Full amount deposits entire net pay; fixed amount deposits a specific dollar value; percentage deposits a specified percentage of net pay. Supports split-deposit configurations.' ;
    rdfs:domain ind:DirectDepositSetup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationValue rdf:type rdf:Property ;
    rdfs:label 'Allocation Value' ;
    rdfs:comment 'Numeric value for the allocation. For fixed_amount type, this is the dollar amount (e.g., 500.00). For percentage type, this is the percentage (e.g., 25.00 for 25%). Null for full_amount type.' ;
    rdfs:domain ind:DirectDepositSetup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'Name of the financial institution where the account is held. Used for worker reference and audit purposes.' ;
    rdfs:domain ind:DirectDepositSetup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentObtainedFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained Flag' ;
    rdfs:comment 'Indicates whether the worker provided explicit consent for direct deposit enrollment. Required for compliance with electronic funds transfer regulations and company policy.' ;
    rdfs:domain ind:DirectDepositSetup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryAccount rdf:type rdf:Property ;
    rdfs:label 'Is Primary Account' ;
    rdfs:comment 'Indicates whether this is the workers primary direct deposit account. True for the main account; false for secondary split-deposit accounts. Only one account per worker should be marked primary at any given time.' ;
    rdfs:domain ind:DirectDepositSetup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prenoteClearedDate rdf:type rdf:Property ;
    rdfs:label 'Prenote Cleared Date' ;
    rdfs:comment 'Date when the prenotification was successfully cleared by the bank, confirming the account is valid and ready for live payroll deposits. Typically 2-3 business days after prenote_sent_date.' ;
    rdfs:domain ind:DirectDepositSetup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prenoteSentDate rdf:type rdf:Property ;
    rdfs:label 'Prenote Sent Date' ;
    rdfs:comment 'Date when the prenotification (zero-dollar test transaction) was sent to the bank to verify account validity. Required by NACHA rules before live direct deposit can begin.' ;
    rdfs:domain ind:DirectDepositSetup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prioritySequence rdf:type rdf:Property ;
    rdfs:label 'Priority Sequence' ;
    rdfs:comment 'Order in which this deposit instruction is processed when multiple accounts are configured (split deposit). Lower numbers are processed first. Typically 1 for primary account, 2+ for secondary accounts.' ;
    rdfs:domain ind:DirectDepositSetup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:setupMethod rdf:type rdf:Property ;
    rdfs:label 'Setup Method' ;
    rdfs:comment 'Method by which the direct deposit information was captured. Worker self-service is most common during onboarding via SAP SuccessFactors portal. HR manual entry used for exceptions. Bulk import and API integration used for large-scale onboarding events.' ;
    rdfs:domain ind:DirectDepositSetup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentVersion rdf:type rdf:Property ;
    rdfs:label 'Document Version' ;
    rdfs:comment 'Version identifier of the document template or form used (e.g., v2.1, 2024-Q1), ensuring compliance with the correct policy or legal version.' ;
    rdfs:domain ind:DocumentCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptFlag rdf:type rdf:Property ;
    rdfs:label 'Exempt Flag' ;
    rdfs:comment 'Indicates whether the worker claimed exempt status from federal or state withholding on the tax form (True = exempt, False = not exempt). Applicable to W-4 and state withholding document types.' ;
    rdfs:domain ind:DocumentCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Form Submission Date' ;
    rdfs:comment 'Date the worker submitted the completed form to the employer or staffing agency. May differ from signed_date for forms that require additional processing or manual submission.' ;
    rdfs:domain ind:DocumentCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isElectronicSignature rdf:type rdf:Property ;
    rdfs:label 'Is Electronic Signature' ;
    rdfs:comment 'Indicates whether the document was signed electronically via DocuSign or similar platform (True) or via wet signature/manual process (False).' ;
    rdfs:domain ind:DocumentCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRequired rdf:type rdf:Property ;
    rdfs:label 'Is Required' ;
    rdfs:comment 'Indicates whether this document is mandatory for the worker to complete onboarding or offboarding (True) or optional (False).' ;
    rdfs:domain ind:DocumentCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onboardingPhase rdf:type rdf:Property ;
    rdfs:label 'Onboarding Phase' ;
    rdfs:comment 'Phase of the onboarding or offboarding lifecycle during which this document was collected (e.g., pre-hire, post-offer, first day, orientation, assignment start, offboarding).' ;
    rdfs:domain ind:DocumentCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'Free-text notes or comments entered by the reviewer regarding the document review, any issues identified, or follow-up actions required.' ;
    rdfs:domain ind:DocumentCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentDate rdf:type rdf:Property ;
    rdfs:label 'Sent Date' ;
    rdfs:comment 'Date the document was sent to the worker for review or signature.' ;
    rdfs:domain ind:DocumentCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signerIpAddress rdf:type rdf:Property ;
    rdfs:label 'Signer Ip Address' ;
    rdfs:comment 'IP address from which the worker signed the document electronically, captured for audit and compliance purposes.' ;
    rdfs:domain ind:DocumentCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersedesPriorFlag rdf:type rdf:Property ;
    rdfs:label 'Supersedes Prior Flag' ;
    rdfs:comment 'Indicates whether this document supersedes or replaces a previously submitted document of the same type (True) or is a new submission (False). Particularly relevant for tax forms (W-4, state withholding) when workers update their withholding elections.' ;
    rdfs:domain ind:DocumentCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:viewedDate rdf:type rdf:Property ;
    rdfs:label 'Viewed Date' ;
    rdfs:comment 'Date the worker first viewed or opened the document.' ;
    rdfs:domain ind:DocumentCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:talentPoolId rdf:type rdf:Property ;
    rdfs:label 'Talent Pool Id' ;
    rdfs:comment 'Foreign key linking to candidate.talent_pool. Business justification: Orientation sessions in staffing are frequently designed and targeted for specific talent pools (e.g., a light industrial pool onboarding session, a healthcare compliance orientation for a specific be' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentPool .

ind:actualEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual End Time' ;
    rdfs:comment 'Actual timestamp when the orientation session concluded. Used for duration tracking and compliance reporting.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Time' ;
    rdfs:comment 'Actual timestamp when the orientation session began. May differ from scheduled time.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assessmentRequired rdf:type rdf:Property ;
    rdfs:label 'Assessment Required' ;
    rdfs:comment 'Indicates whether workers must pass an assessment or quiz to complete the orientation.' ;
    rdfs:domain ind:OrientationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:attendedCount rdf:type rdf:Property ;
    rdfs:label 'Attended Count' ;
    rdfs:comment 'Number of workers who actually attended the orientation session. Updated after session completion.' ;
    rdfs:domain ind:OrientationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Average Satisfaction Score' ;
    rdfs:comment 'Average satisfaction rating from attendee feedback surveys, typically on a scale of 1-5 or 1-10.' ;
    rdfs:domain ind:OrientationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completedCount rdf:type rdf:Property ;
    rdfs:label 'Completed Count' ;
    rdfs:comment 'Number of workers who successfully completed all orientation requirements and passed any assessments.' ;
    rdfs:domain ind:OrientationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costPerAttendee rdf:type rdf:Property ;
    rdfs:label 'Cost Per Attendee' ;
    rdfs:comment 'Cost incurred per worker attending the orientation, including facilitator time, materials, and facility costs. Used for internal cost allocation.' ;
    rdfs:domain ind:OrientationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilitatorEmail rdf:type rdf:Property ;
    rdfs:label 'Facilitator Email' ;
    rdfs:comment 'Email address of the orientation facilitator for coordination and follow-up.' ;
    rdfs:domain ind:OrientationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilitatorName rdf:type rdf:Property ;
    rdfs:label 'Facilitator Name' ;
    rdfs:comment 'Name of the person conducting or leading the orientation session (internal staff or client representative).' ;
    rdfs:domain ind:OrientationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilitatorPhone rdf:type rdf:Property ;
    rdfs:label 'Facilitator Phone' ;
    rdfs:comment 'Contact phone number for the orientation facilitator.' ;
    rdfs:domain ind:OrientationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackSurveySent rdf:type rdf:Property ;
    rdfs:label 'Feedback Survey Sent' ;
    rdfs:comment 'Indicates whether a post-orientation feedback survey was sent to attendees.' ;
    rdfs:domain ind:OrientationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interpreterProvided rdf:type rdf:Property ;
    rdfs:label 'Interpreter Provided' ;
    rdfs:comment 'Indicates whether language interpretation services are provided for this orientation session.' ;
    rdfs:domain ind:OrientationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Category of physical or virtual location where the orientation is conducted.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialsProvided rdf:type rdf:Property ;
    rdfs:label 'Materials Provided' ;
    rdfs:comment 'Description of materials distributed during orientation (e.g., Employee Handbook, Safety Manual, Benefits Guide, ID Badge).' ;
    rdfs:domain ind:OrientationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orientationType rdf:type rdf:Property ;
    rdfs:label 'Orientation Type' ;
    rdfs:comment 'Delivery method for the orientation session. Determines logistics and technology requirements.' ;
    rdfs:domain ind:OrientationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passingScorePercentage rdf:type rdf:Property ;
    rdfs:label 'Passing Score Percentage' ;
    rdfs:comment 'Minimum percentage score required to pass the orientation assessment, if applicable.' ;
    rdfs:domain ind:OrientationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:physicalLocation rdf:type rdf:Property ;
    rdfs:label 'Physical Location' ;
    rdfs:comment 'Physical address or facility name where in-person orientation is held (e.g., Main Office - Conference Room A, Client Site - Building 3).' ;
    rdfs:domain ind:OrientationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordingAvailable rdf:type rdf:Property ;
    rdfs:label 'Recording Available' ;
    rdfs:comment 'Indicates whether a recording of the orientation session is available for workers who missed the live session.' ;
    rdfs:domain ind:OrientationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordingUrl rdf:type rdf:Property ;
    rdfs:label 'Recording Url' ;
    rdfs:comment 'URL or storage location of the orientation session recording. Confidential to control access.' ;
    rdfs:domain ind:OrientationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCount rdf:type rdf:Property ;
    rdfs:label 'Registered Count' ;
    rdfs:comment 'Number of workers currently registered for this orientation session.' ;
    rdfs:domain ind:OrientationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'Date the orientation session is scheduled to occur. Used for planning and worker notification.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'Precise timestamp when the orientation session is scheduled to end.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'Precise timestamp when the orientation session is scheduled to begin.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionCapacity rdf:type rdf:Property ;
    rdfs:label 'Session Capacity' ;
    rdfs:comment 'Maximum number of workers that can attend this orientation session. Used for scheduling and logistics planning.' ;
    rdfs:domain ind:OrientationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionCode rdf:type rdf:Property ;
    rdfs:label 'Session Code' ;
    rdfs:comment 'Business identifier for the orientation session, used for external reference and scheduling systems.' ;
    rdfs:domain ind:OrientationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionName rdf:type rdf:Property ;
    rdfs:label 'Session Name' ;
    rdfs:comment 'Descriptive name of the orientation session (e.g., New Hire Orientation - Healthcare Division, Client-Site Safety Training).' ;
    rdfs:domain ind:OrientationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionStatus rdf:type rdf:Property ;
    rdfs:label 'Session Status' ;
    rdfs:comment 'Current lifecycle status of the orientation session. Tracks progression from planning through completion.' ;
    rdfs:domain ind:OrientationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topicsCovered rdf:type rdf:Property ;
    rdfs:label 'Topics Covered' ;
    rdfs:comment 'Comma-separated or structured list of topics covered in the orientation (e.g., Company Policies, Safety Procedures, Benefits Overview, Timekeeping, Compliance Training).' ;
    rdfs:domain ind:OrientationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualMeetingLink rdf:type rdf:Property ;
    rdfs:label 'Virtual Meeting Link' ;
    rdfs:comment 'URL or meeting link for virtual orientation sessions (e.g., Zoom, Teams, WebEx). Confidential to prevent unauthorized access.' ;
    rdfs:domain ind:OrientationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualMeetingReference rdf:type rdf:Property ;
    rdfs:label 'Virtual Meeting Reference' ;
    rdfs:comment 'Meeting ID or access code for virtual orientation platform. Confidential credential.' ;
    rdfs:domain ind:OrientationSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusEventId rdf:type rdf:Property ;
    rdfs:label 'Status Event Id' ;
    rdfs:comment 'Primary key for status_event' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:candidateScreeningId rdf:type rdf:Property ;
    rdfs:label 'Candidate Screening Id' ;
    rdfs:comment 'Foreign key linking to recruitment.candidate_screening. Business justification: Candidate screenings have status transitions (scheduled, in_progress, completed, passed, failed, waived) that should be captured in the status_event log. Adding candidate_screening_id to status_event ' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CandidateScreening .

ind:interviewId rdf:type rdf:Property ;
    rdfs:label 'Interview Id' ;
    rdfs:comment 'Foreign key linking to recruitment.interview. Business justification: Interviews generate multiple status events: scheduled, confirmed by candidate, confirmed by client, rescheduled, completed, cancelled. The status_event table is the immutable event log for all such tr' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Interview .

ind:rtrAgreementId rdf:type rdf:Property ;
    rdfs:label 'Rtr Agreement Id' ;
    rdfs:comment 'Foreign key linking to recruitment.rtr_agreement. Business justification: RTR agreements have a defined status lifecycle (requested, acknowledged, granted, expired, revoked, conflict_flagged) that generates status events. Adding rtr_agreement_id to status_event enables comp' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RtrAgreement .

ind:communicationChannel rdf:type rdf:Property ;
    rdfs:label 'Communication Channel' ;
    rdfs:comment 'The channel through which communication was sent or received for this event. Set to none for status transitions that do not involve direct communication.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationDirection rdf:type rdf:Property ;
    rdfs:label 'Communication Direction' ;
    rdfs:comment 'Indicates whether the communication was sent to the worker (outbound), received from the worker (inbound), or not applicable for non-communication events.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'The delivery and engagement status for outbound communications. Tracks whether emails or SMS messages were successfully delivered and opened by the recipient. [ENUM-REF-CANDIDATE: sent|delivered|opened|clicked|bounced|failed|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventNotes rdf:type rdf:Property ;
    rdfs:label 'Event Notes' ;
    rdfs:comment 'Free-text notes or comments recorded by the coordinator or system about this event. Provides additional context for manual overrides, exceptions, or worker-specific details.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'The precise date and time when this status event or communication occurred in the onboarding lifecycle. Represents the real-world business event time, not the system record creation time.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:externalEventReference rdf:type rdf:Property ;
    rdfs:label 'External Event Reference' ;
    rdfs:comment 'The unique identifier of this event in the source system (e.g., SAP SuccessFactors event ID, Bullhorn activity ID). Used for reconciliation and troubleshooting.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMilestoneEvent rdf:type rdf:Property ;
    rdfs:label 'Is Milestone Event' ;
    rdfs:comment 'Boolean flag indicating whether this event represents a major milestone in the onboarding lifecycle (e.g., orientation complete, ready for assignment, assignment start). Used for high-level timeline visualization.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:messageBodyPreview rdf:type rdf:Property ;
    rdfs:label 'Message Body Preview' ;
    rdfs:comment 'A preview or excerpt of the message body content for outbound or inbound communications. Truncated for storage efficiency; full content stored in document management system.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageSubject rdf:type rdf:Property ;
    rdfs:label 'Message Subject' ;
    rdfs:comment 'The subject line or title of the communication sent or received. Applicable for email and portal notifications.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The onboarding or offboarding status after this event occurred. Represents the current state following the transition or milestone. [ENUM-REF-CANDIDATE: not_started|documents_pending|bgc_in_progress|orientation_scheduled|training_assigned|equipment_pending|ready_for_assignment|assignment_active|offboarding_initiated|offboarding_complete — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorStatus rdf:type rdf:Property ;
    rdfs:label 'Prior Status' ;
    rdfs:comment 'The onboarding or offboarding status immediately before this event occurred. Nullable for the first event in a case lifecycle. [ENUM-REF-CANDIDATE: not_started|documents_pending|bgc_in_progress|orientation_scheduled|training_assigned|equipment_pending|ready_for_assignment|assignment_active|offboarding_initiated|offboarding_complete — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientEmail rdf:type rdf:Property ;
    rdfs:label 'Recipient Email' ;
    rdfs:comment 'The email address to which an outbound communication was sent. Applicable for email-based events.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientPhone rdf:type rdf:Property ;
    rdfs:label 'Recipient Phone' ;
    rdfs:comment 'The phone number to which an outbound SMS or phone call was directed. Applicable for SMS and phone-based events.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Target Timestamp' ;
    rdfs:comment 'The target date and time by which this onboarding milestone or task should be completed according to the Service Level Agreement (SLA). Used for Time to Fill (TTF) and Time to Start (TTS) measurement.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:systemSource rdf:type rdf:Property ;
    rdfs:label 'System Source' ;
    rdfs:comment 'The source system or application that generated or recorded this event. Identifies the operational system of record for traceability and integration auditing. [ENUM-REF-CANDIDATE: bullhorn|sap_successfactors|sterling_bgc|docusign|kronos|internal_portal|api — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerSource rdf:type rdf:Property ;
    rdfs:label 'Trigger Source' ;
    rdfs:comment 'The specific action, system event, or integration that caused this status event to be recorded. Provides traceability for automated workflows and manual interventions. [ENUM-REF-CANDIDATE: task_completion|document_signing|bgc_clearance|lms_completion|manual_override|scheduled_reminder|api_integration|portal_submission — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringActorType rdf:type rdf:Property ;
    rdfs:label 'Triggering Actor Type' ;
    rdfs:comment 'The type of actor (person or system) that triggered or initiated this event. Distinguishes between automated system actions and human-initiated actions.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerResponseReceived rdf:type rdf:Property ;
    rdfs:label 'Worker Response Received' ;
    rdfs:comment 'Boolean flag indicating whether the worker provided a response or acknowledgment for this event. True for inbound responses or completed actions.' ;
    rdfs:domain ind:StatusEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address line for the candidates current residence. Used for tax jurisdiction determination (SUTA, FUTA, state income tax withholding), workers compensation policy assignment, and I-9 documentation.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address line for the candidates residence (apartment, suite, unit number). Supplements address_line1 for complete mailing address used in payroll tax filings and compliance documentation.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atsCandidateRef rdf:type rdf:Property ;
    rdfs:label 'Ats Candidate Ref' ;
    rdfs:comment 'External candidate identifier assigned by the source Applicant Tracking System (ATS), e.g., Bullhorn candidate record ID. Used for cross-system reconciliation and deduplication between the lakehouse and the operational ATS.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionModel rdf:type rdf:Property ;
    rdfs:label 'Attribution Model' ;
    rdfs:comment 'Attribution model applied to assign sourcing credit for this candidate. First-touch = credit to initial channel; Last-touch = credit to final channel before application; Multi-touch = distributed credit; Linear = equal credit across all touchpoints. Drives cost-per-source and channel ROI calculations.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityDate rdf:type rdf:Property ;
    rdfs:label 'Availability Date' ;
    rdfs:comment 'Earliest date the candidate is available to begin a new assignment or placement. Critical for Time to Fill (TTF) and Time to Start (TTS) KPI calculations and for matching candidates to job orders with specific start date requirements.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:birthDate rdf:type rdf:Property ;
    rdfs:label 'Birth Date' ;
    rdfs:comment 'Candidates date of birth in yyyy-MM-dd format. Used for age verification, I-9 eligibility, background check identity matching, and EEOC reporting. Stored masked or access-controlled per GDPR/CCPA.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:candidateStatus rdf:type rdf:Property ;
    rdfs:label 'Candidate Status' ;
    rdfs:comment 'Current lifecycle status of the candidate in the ATS talent pool. Active = available and engaged; Placed = currently on assignment; On Bench = unassigned but available for redeployment; Inactive = not currently pursuing opportunities; Do Not Use = flagged for exclusion; Pending Onboarding = offer accepted, onboarding in progress.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:candidateType rdf:type rdf:Property ;
    rdfs:label 'Candidate Type' ;
    rdfs:comment 'Classification of the candidates engagement model with the staffing firm. W-2 = employee on firms payroll; 1099 = independent contractor (IC); EOR = employer of record arrangement; C2C = corp-to-corp; PEO = professional employer organization. Drives payroll tax treatment, workers comp assignment, and co-employment risk assessment.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Consent Flag' ;
    rdfs:comment 'Indicates whether the candidate has acknowledged CCPA privacy rights disclosure and provided consent for data processing. Required for California residents. Supports CCPA opt-out and data deletion request workflows.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City of the candidates current residential address. Used for geographic talent pool analytics, commute radius matching, and state/local tax jurisdiction determination.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerSource rdf:type rdf:Property ;
    rdfs:label 'Cost Per Source' ;
    rdfs:comment 'Monetary cost attributed to sourcing this specific candidate, in USD. Includes job board fees, advertising spend, referral bonuses, or RPO campaign costs allocated per candidate. Used for sourcing ROI and cost-per-hire analytics.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataClassification rdf:type rdf:Property ;
    rdfs:label 'Data Classification' ;
    rdfs:comment 'Data governance classification level assigned to this candidate profile record. Drives access control policies, data masking rules, and retention schedules. Restricted = highest sensitivity (PII-heavy); Confidential = sensitive business data; Internal = standard operational; Public = no sensitivity.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotContactFlag rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact Flag' ;
    rdfs:comment 'Indicates whether the candidate has opted out of all recruiter outreach and communications. When True, all automated and manual contact must cease immediately. Enforced per GDPR right to erasure/restriction and CCPA opt-out rights.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Candidates current employment situation at the time of last profile update. Used to prioritize outreach urgency, assess availability, and tailor placement strategy (temp vs. perm vs. contract-to-hire).' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Flag' ;
    rdfs:comment 'Indicates whether the candidate has provided explicit GDPR consent for the firm to store and process their personal data. Required for candidates in EU/EEA jurisdictions. Must be True before any data processing occurs for covered individuals.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'Self-reported gender identity of the candidate. Collected voluntarily for EEOC workforce diversity reporting and OFCCP compliance. Not used in placement decisions per EEOC guidelines.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Legal middle name or initial of the candidate. Required for background check (BGC) identity matching via Sterling and for I-9 employment eligibility verification.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioUrl rdf:type rdf:Property ;
    rdfs:label 'Portfolio Url' ;
    rdfs:comment 'URL to the candidates professional portfolio, personal website, or GitHub profile. Relevant for creative, technical, and IT roles where work samples are evaluated during screening.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'ZIP or postal code of the candidates current residential address. Used for geographic proximity matching to job orders, tax jurisdiction lookup, and workforce density analytics.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredName rdf:type rdf:Property ;
    rdfs:label 'Preferred Name' ;
    rdfs:comment 'Name the candidate prefers to be addressed by in communications and recruiter interactions. May differ from legal name. Used in outreach, interview scheduling, and placement correspondence.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'Primary email address used for all recruiter outreach, ATS communications, onboarding workflows, and digital document delivery (DocuSign). Must be unique per active candidate profile.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'Primary phone number for candidate contact, stored in E.164 international format. Used for recruiter outreach, interview scheduling, and urgent placement communications.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pronouns rdf:type rdf:Property ;
    rdfs:label 'Pronouns' ;
    rdfs:comment 'Candidates self-reported preferred pronouns (e.g., he/him, she/her, they/them). Collected voluntarily to support inclusive recruiter communications and workplace culture alignment.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceChannelName rdf:type rdf:Property ;
    rdfs:label 'Source Channel Name' ;
    rdfs:comment 'Specific name of the sourcing channel or platform (e.g., Indeed, LinkedIn Recruiter, ZipRecruiter, Employee Referral, Beeline VMS Portal, Company Career Site). Provides granular sourcing attribution below the channel type level.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceChannelType rdf:type rdf:Property ;
    rdfs:label 'Source Channel Type' ;
    rdfs:comment 'Category of the channel through which the candidate was originally sourced into the ATS. Used for sourcing ROI analysis, cost-per-source reporting, and channel attribution modeling. Supports talent acquisition strategy optimization. [ENUM-REF-CANDIDATE: job_board|referral|social_media|direct_outreach|rpo_campaign|vms_portal|career_site|walk_in — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingDate rdf:type rdf:Property ;
    rdfs:label 'Sourcing Date' ;
    rdfs:comment 'Date the candidate was first sourced and entered into the ATS talent pool. Used to calculate candidate pipeline age, sourcing velocity metrics, and Time to Fill (TTF) baseline measurements.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ssnMasked rdf:type rdf:Property ;
    rdfs:label 'Ssn Masked' ;
    rdfs:comment 'Last four digits of the candidates Social Security Number stored in masked format (XXX-XX-NNNN). Used for identity verification, payroll tax processing (W-2), and E-Verify matching. Full SSN is never stored in the lakehouse.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State or province of the candidates current residential address (ISO 3166-2 subdivision code, e.g., CA, TX, NY). Critical for SUTA tax assignment, workers compensation rate determination, and FLSA/state labor law compliance.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmCampaign rdf:type rdf:Property ;
    rdfs:label 'Utm Campaign' ;
    rdfs:comment 'UTM campaign parameter captured from the candidates application URL. Identifies the specific marketing campaign name or code for multi-touch attribution modeling and recruitment marketing ROI reporting.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmMedium rdf:type rdf:Property ;
    rdfs:label 'Utm Medium' ;
    rdfs:comment 'UTM medium parameter captured from the candidates application URL (e.g., cpc, organic, email, social). Identifies the marketing medium for digital sourcing attribution analysis.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmSource rdf:type rdf:Property ;
    rdfs:label 'Utm Source' ;
    rdfs:comment 'UTM source parameter captured from the candidates application URL (e.g., indeed, linkedin, google). Used for digital marketing attribution and cost-per-source analytics in conjunction with utm_medium and utm_campaign.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visaExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Visa Expiry Date' ;
    rdfs:comment 'Expiration date of the candidates work visa or employment authorization document (EAD). Used to trigger re-verification workflows, prevent non-compliant placements, and manage I-9 re-verification timelines.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workAuthorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Work Authorization Status' ;
    rdfs:comment 'Candidates legal authorization to work in the applicable jurisdiction. Determines eligibility for placement, I-9 document requirements, and E-Verify processing. [ENUM-REF-CANDIDATE: us_citizen|permanent_resident|tn_visa|h1b|opt|stem_opt|other_visa|not_authorized — promote to reference product]' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resumeId rdf:type rdf:Property ;
    rdfs:label 'Resume Id' ;
    rdfs:comment 'Unique system-generated identifier for each resume record in the Staffing Hr platform. Primary key for the resume data product within the candidate domain.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Resume .

ind:bullhornResumeRef rdf:type rdf:Property ;
    rdfs:label 'Bullhorn Resume Ref' ;
    rdfs:comment 'External identifier for this resume record as assigned by the Bullhorn ATS/CRM system of record. Used for cross-system reconciliation, data lineage tracking, and integration with Bullhorn API workflows.' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:candidateConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Candidate Consent Flag' ;
    rdfs:comment 'Indicates whether the candidate has provided explicit consent for their resume data to be stored, processed, and used for talent matching and placement activities. Required for GDPR and CCPA compliance in international and California-based operations.' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'Date and time when the candidate provided consent for resume data processing. Required for GDPR and CCPA audit trails. Null if consent has not been obtained or is not applicable.' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'Original file name of the uploaded resume document as provided by the candidate or recruiter. Used for document identification and retrieval from the storage system.' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Size of the resume file in bytes. Used for storage management, upload validation, and ensuring compliance with maximum file size limits enforced by the ATS or candidate portal.' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:highestEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Highest Education Level' ;
    rdfs:comment 'Highest academic degree or credential level attained as extracted from the resume. Used for candidate qualification filtering against job order education requirements. [ENUM-REF-CANDIDATE: High School|Associate|Bachelor|Master|Doctorate|Professional|Certificate|None — promote to reference product]' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActiveVersion rdf:type rdf:Property ;
    rdfs:label 'Is Active Version' ;
    rdfs:comment 'Indicates whether this resume version is the current active version used for ATS search, talent pool matching, and recruiter review in Bullhorn. Only one resume per candidate should be flagged as active at any time.' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isParsed rdf:type rdf:Property ;
    rdfs:label 'Is Parsed' ;
    rdfs:comment 'Indicates whether the resume has been successfully processed by the parsing engine and structured data has been extracted. False indicates the resume is raw/unprocessed or parsing failed.' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSearchable rdf:type rdf:Property ;
    rdfs:label 'Is Searchable' ;
    rdfs:comment 'Indicates whether this resume is indexed and available for full-text search and talent pool matching queries in the ATS. May be set to false for resumes pending parsing, under compliance hold, or for candidates who have opted out of search.' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'ISO 639-1 or BCP 47 language code identifying the primary language in which the resume is written (e.g., en, es, fr). Supports multilingual candidate pools and international staffing operations.' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mostRecentEmployer rdf:type rdf:Property ;
    rdfs:label 'Most Recent Employer' ;
    rdfs:comment 'Name of the most recent employer extracted from the resume work history. Used for quick candidate qualification review and employment gap analysis in recruiter workflows.' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mostRecentJobTitle rdf:type rdf:Property ;
    rdfs:label 'Most Recent Job Title' ;
    rdfs:comment 'The most recent or current job title extracted from the resume. Used as the primary candidate headline in ATS search results, talent pool displays, and recruiter-facing candidate summaries.' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parseConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Parse Confidence Score' ;
    rdfs:comment 'Numeric confidence score (0.00–100.00) assigned by the parsing engine indicating the quality and completeness of the structured data extracted from the resume. Low scores may trigger manual review workflows in the ATS.' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parseStatus rdf:type rdf:Property ;
    rdfs:label 'Parse Status' ;
    rdfs:comment 'Current processing status of the resume through the parsing pipeline. Indicates whether the resume has been successfully parsed, is awaiting parsing, encountered a failure, or requires manual review by a recruiter.' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Parse Timestamp' ;
    rdfs:comment 'Date and time when the resume parsing process was completed. Distinct from upload timestamp; captures the processing event time for SLA tracking of the parsing pipeline.' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:parsedEducation rdf:type rdf:Property ;
    rdfs:label 'Parsed Education' ;
    rdfs:comment 'Structured education history extracted from the resume by the parsing engine, including degree levels, institutions, and fields of study. Supports candidate qualification screening and compliance with client education requirements.' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parsedEmployers rdf:type rdf:Property ;
    rdfs:label 'Parsed Employers' ;
    rdfs:comment 'Structured list of employer names extracted from the resume work history by the parsing engine. Used for employment verification cross-referencing, candidate background check initiation via Sterling, and work history completeness assessment.' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parsedJobTitles rdf:type rdf:Property ;
    rdfs:label 'Parsed Job Titles' ;
    rdfs:comment 'Structured list of job titles extracted from the resume work history by the parsing engine. Used for candidate classification, talent pool segmentation, and job order matching in Bullhorn ATS.' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parsedSkills rdf:type rdf:Property ;
    rdfs:label 'Parsed Skills' ;
    rdfs:comment 'Structured representation of skills extracted from the resume by the parsing engine, stored as a delimited string or serialized list. Feeds the candidate skills inventory and ATS job-order matching algorithms. Examples include technical skills, certifications, and soft skills.' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parsingEngine rdf:type rdf:Property ;
    rdfs:label 'Parsing Engine' ;
    rdfs:comment 'Name of the automated resume parsing engine used to extract structured data from the raw resume document. Enables quality benchmarking across parsing vendors and troubleshooting of parse failures.' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parsingEngineVersion rdf:type rdf:Property ;
    rdfs:label 'Parsing Engine Version' ;
    rdfs:comment 'Version identifier of the parsing engine used at the time of resume processing. Supports reproducibility audits and regression analysis when parsing engine versions are upgraded.' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySkillCategory rdf:type rdf:Property ;
    rdfs:label 'Primary Skill Category' ;
    rdfs:comment 'Top-level skill category or discipline assigned to the candidate based on parsed resume content (e.g., Information Technology, Healthcare, Finance, Engineering). Supports talent pool segmentation and workforce planning analytics.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'Composite quality score (0.00–100.00) assigned to the resume based on completeness, formatting, keyword density, and parse confidence. Used for talent pool ranking and Quality of Submission (QoS) reporting in recruiter dashboards.' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rawText rdf:type rdf:Property ;
    rdfs:label 'Raw Text' ;
    rdfs:comment 'Full plain-text extraction of the resume document content prior to structured parsing. Stored as a text blob to support full-text search, keyword matching, and AI/ML talent matching workflows in Bullhorn ATS.' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recruiterNotes rdf:type rdf:Property ;
    rdfs:label 'Recruiter Notes' ;
    rdfs:comment 'Free-text notes entered by the recruiter during resume review, including observations about candidate qualifications, formatting issues, or follow-up actions required. Supports recruiter collaboration and ATS workflow documentation.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceJobBoard rdf:type rdf:Property ;
    rdfs:label 'Source Job Board' ;
    rdfs:comment 'Name of the external job board or sourcing platform from which the resume was originally obtained (e.g., Indeed, LinkedIn, Monster, CareerBuilder, Dice). Supports sourcing channel attribution and cost-per-hire analytics.' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uploadSource rdf:type rdf:Property ;
    rdfs:label 'Upload Source' ;
    rdfs:comment 'Channel or method through which the resume was submitted or ingested into the system. Supports sourcing channel attribution analytics and ATS workflow routing. [ENUM-REF-CANDIDATE: candidate_portal|recruiter_upload|email_parse|linkedin_import|job_board|vms_import|api_integration — promote to reference product]' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uploadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Upload Timestamp' ;
    rdfs:comment 'Date and time when the resume file was uploaded or ingested into the system. Serves as the principal business event timestamp for the resume record lifecycle. Stored in ISO 8601 format with timezone offset.' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:wordCount rdf:type rdf:Property ;
    rdfs:label 'Word Count' ;
    rdfs:comment 'Total number of words in the resume document as extracted during parsing. Used as a proxy for resume completeness and quality scoring in ATS workflows and talent pool management.' ;
    rdfs:domain ind:Resume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yearsOfExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience' ;
    rdfs:comment 'Total years of professional work experience calculated or extracted from the resume work history by the parsing engine. Used as a primary screening criterion for job order matching and candidate ranking in ATS workflows.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workHistoryId rdf:type rdf:Property ;
    rdfs:label 'Work History Id' ;
    rdfs:comment 'Unique surrogate identifier for each candidate work history record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:WorkHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorClientAccountId rdf:type rdf:Property ;
    rdfs:label 'Prior Client Account Id' ;
    rdfs:comment 'Foreign key linking to client.client_account. Business justification: Recruiters routinely check whether a candidate has previously worked at a client account (prior placement history) before submitting — this affects RTR eligibility, DNP status, and relationship contex' ;
    rdfs:domain ind:WorkHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientAccount .

ind:bullhornWorkHistoryRef rdf:type rdf:Property ;
    rdfs:label 'Bullhorn Work History Ref' ;
    rdfs:comment 'The native record identifier for this work history entry in the Bullhorn ATS/CRM system. Used for cross-system reconciliation, data lineage tracking, and incremental data loads from the source system.' ;
    rdfs:domain ind:WorkHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationCurrency rdf:type rdf:Property ;
    rdfs:label 'Compensation Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the compensation reported in this work history record. Defaults to USD for domestic U.S. placements. Required for international candidate records.' ;
    rdfs:domain ind:WorkHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Numeric score (0.00–100.00) representing the completeness and reliability of this work history record based on field population, verification status, and source system confidence. Used for talent pool quality reporting and AI/ML feature weighting.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:directReportsCount rdf:type rdf:Property ;
    rdfs:label 'Direct Reports Count' ;
    rdfs:comment 'Number of direct reports the candidate managed in this role. Zero for individual contributor roles. Used to assess leadership experience for management-level placements.' ;
    rdfs:domain ind:WorkHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employerLocationCity rdf:type rdf:Property ;
    rdfs:label 'Employer Location City' ;
    rdfs:comment 'City where the candidate performed work for this employer. Used for geographic placement matching and commute analysis.' ;
    rdfs:domain ind:WorkHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerLocationCountry rdf:type rdf:Property ;
    rdfs:label 'Employer Location Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country where the candidate performed work for this employer. Supports international placement matching and cross-border compliance tracking.' ;
    rdfs:domain ind:WorkHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerLocationState rdf:type rdf:Property ;
    rdfs:label 'Employer Location State' ;
    rdfs:comment 'U.S. state (or province/region for international) where the candidate performed work for this employer. Used for geographic placement matching, state-specific compliance, and labor law applicability.' ;
    rdfs:domain ind:WorkHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapDurationDays rdf:type rdf:Property ;
    rdfs:label 'Gap Duration Days' ;
    rdfs:comment 'Number of days in the employment gap immediately preceding this work history records start date. Populated only when has_employment_gap is True. Used for tenure analysis and candidate risk scoring.' ;
    rdfs:domain ind:WorkHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hasEmploymentGap rdf:type rdf:Property ;
    rdfs:label 'Has Employment Gap' ;
    rdfs:comment 'Indicates whether there is a notable gap in employment immediately preceding this work history records start date. Computed during ingestion from chronological work history analysis. Used for candidate screening and placement suitability assessment.' ;
    rdfs:domain ind:WorkHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:industrySector rdf:type rdf:Property ;
    rdfs:label 'Industry Sector' ;
    rdfs:comment 'The industry sector of the employer for this work history record (e.g., Healthcare, Technology, Manufacturing, Finance). Used for industry-specific placement matching and talent pool segmentation. Aligned with NAICS or SIC classification.' ;
    rdfs:domain ind:WorkHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrent rdf:type rdf:Property ;
    rdfs:label 'Is Current' ;
    rdfs:comment 'Indicates whether this is the candidates current active employer and role. When True, end_date is expected to be null. Used to identify active employment status during placement suitability assessment.' ;
    rdfs:domain ind:WorkHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRelevantExperience rdf:type rdf:Property ;
    rdfs:label 'Is Relevant Experience' ;
    rdfs:comment 'Recruiter-assigned flag indicating whether this work history record is considered relevant experience for current active job orders. Supports targeted talent pool filtering and placement suitability scoring.' ;
    rdfs:domain ind:WorkHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStaffingAgencyPlacement rdf:type rdf:Property ;
    rdfs:label 'Is Staffing Agency Placement' ;
    rdfs:comment 'Indicates whether this work history record represents a placement made through a staffing agency (including Staffing Hr). Used to distinguish direct employment from contingent staffing experience and to identify redeployment candidates.' ;
    rdfs:domain ind:WorkHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVerified rdf:type rdf:Property ;
    rdfs:label 'Is Verified' ;
    rdfs:comment 'Indicates whether this work history record has been independently verified through a background check or employment verification process. Verified records carry higher confidence for placement decisions.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobFunction rdf:type rdf:Property ;
    rdfs:label 'Job Function' ;
    rdfs:comment 'Standardized functional category of the role held (e.g., Engineering, Sales, Finance, Operations, Healthcare). Used for talent pool segmentation, placement matching, and workforce analytics reporting in Power BI.' ;
    rdfs:domain ind:WorkHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementLevel rdf:type rdf:Property ;
    rdfs:label 'Management Level' ;
    rdfs:comment 'Seniority or management level of the role held during this work history period. Used for placement suitability scoring and headcount planning analytics. [ENUM-REF-CANDIDATE: individual_contributor|team_lead|manager|director|vp|c_suite|executive — promote to reference product]' ;
    rdfs:domain ind:WorkHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonForLeaving rdf:type rdf:Property ;
    rdfs:label 'Reason For Leaving' ;
    rdfs:comment 'Candidate-provided or recruiter-captured reason for departing this employer. Used for candidate risk assessment, fall-off rate analysis, and placement suitability evaluation. [ENUM-REF-CANDIDATE: resignation|layoff|contract_end|termination|retirement|relocation|career_growth|other — promote to reference product]' ;
    rdfs:domain ind:WorkHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Lifecycle status of this work history record within the data platform (active, deleted by candidate request, flagged as duplicate, or pending verification). Supports GDPR/CCPA right-to-erasure workflows and data quality management.' ;
    rdfs:domain ind:WorkHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedPayRate rdf:type rdf:Property ;
    rdfs:label 'Reported Pay Rate' ;
    rdfs:comment 'Candidate-reported compensation rate for this work history record, expressed in the unit defined by pay_rate_type and compensation_currency. Used for pay rate benchmarking and spread analysis in placement pricing. Classified confidential as candidate financial data.' ;
    rdfs:domain ind:WorkHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibilitiesSummary rdf:type rdf:Property ;
    rdfs:label 'Responsibilities Summary' ;
    rdfs:comment 'Free-text summary of the candidates key duties, responsibilities, and accomplishments in this role. Sourced from resume parsing or candidate-submitted data in Bullhorn. Used for skill inference, keyword matching, and placement suitability scoring.' ;
    rdfs:domain ind:WorkHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resumeSectionOrder rdf:type rdf:Property ;
    rdfs:label 'Resume Section Order' ;
    rdfs:comment 'Sequential position of this work history entry as it appeared in the candidates parsed resume (1 = most recent). Used to preserve resume ordering for recruiter review and ATS display.' ;
    rdfs:domain ind:WorkHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skillsInferred rdf:type rdf:Property ;
    rdfs:label 'Skills Inferred' ;
    rdfs:comment 'Comma-delimited list of skills inferred or extracted from the responsibilities_summary and job_title for this work history record via resume parsing. Used to populate the candidate skills inventory and drive placement matching in Bullhorn ATS.' ;
    rdfs:domain ind:WorkHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenureMonths rdf:type rdf:Property ;
    rdfs:label 'Tenure Months' ;
    rdfs:comment 'Duration of employment at this employer in this role, expressed in whole months. Calculated from start_date and end_date (or current date if is_current). Stored for efficient tenure analysis and placement suitability scoring without repeated computation.' ;
    rdfs:domain ind:WorkHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workArrangement rdf:type rdf:Property ;
    rdfs:label 'Work Arrangement' ;
    rdfs:comment 'The physical work arrangement for this role (on-site, remote, or hybrid). Used for placement preference matching and workforce planning analytics.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billableRatePremium rdf:type rdf:Property ;
    rdfs:label 'Billable Rate Premium' ;
    rdfs:comment 'Incremental bill rate premium (in USD) associated with this skill when pricing candidate placements. Reflects the market premium clients pay for candidates with this specific skill. Used in rate card configuration and spread/markup calculations. Confidential pricing data.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandIndex rdf:type rdf:Property ;
    rdfs:label 'Demand Index' ;
    rdfs:comment 'Relative market demand score for this skill based on open job order frequency, client request patterns, and labor market data. Used in workforce planning, bench management, and redeployment prioritization. Higher values indicate higher current market demand.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date from which this skill record is considered valid and active for talent matching and placement purposes. Supports slowly changing dimension (SCD) patterns in the Silver Layer and enables point-in-time skill profile reconstruction for compliance and audit.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date on which this skill record version expires or is superseded. Null for currently active records. Supports SCD Type 2 history tracking in the Silver Layer lakehouse for point-in-time candidate skill profile reconstruction.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endorsementCount rdf:type rdf:Property ;
    rdfs:label 'Endorsement Count' ;
    rdfs:comment 'Number of endorsements or validations this skill has received from recruiters, clients, or peers. Higher endorsement counts increase the skills credibility weight in QoS scoring and talent pool ranking algorithms.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:languageProficiencyStandard rdf:type rdf:Property ;
    rdfs:label 'Language Proficiency Standard' ;
    rdfs:comment 'Common European Framework of Reference (CEFR) proficiency level applicable when skill_category is language. A1/A2: basic user; B1/B2: independent user; C1/C2: proficient user. Null for non-language skills. Enables standardized language skill matching for multilingual placement requirements.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:normalizedSkillName rdf:type rdf:Property ;
    rdfs:label 'Normalized Skill Name' ;
    rdfs:comment 'Canonical, taxonomy-normalized version of the skill name after standardization processing (e.g., MS Excel normalized to Microsoft Excel, JS normalized to JavaScript). Enables consistent cross-candidate skill comparison, deduplication, and job order matching across ATS and VMS platforms.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payRatePremium rdf:type rdf:Property ;
    rdfs:label 'Pay Rate Premium' ;
    rdfs:comment 'Incremental pay rate premium (in USD) associated with this skill when compensating placed candidates. Reflects the market premium paid to candidates possessing this skill. Used alongside billable_rate_premium to calculate spread and gross margin for skill-based placements.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:placementTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Placement Type Applicability' ;
    rdfs:comment 'Indicates which worker classification or placement type this skill is relevant for. W-2 (employee), 1099 (independent contractor), EOR (Employer of Record), or all placement types. Used to filter talent pools by worker classification in Bullhorn ATS and Beeline VMS matching workflows.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proficiencyScore rdf:type rdf:Property ;
    rdfs:label 'Proficiency Score' ;
    rdfs:comment 'Numeric proficiency score assigned through a formal assessment or standardized test (e.g., 0.00–100.00 scale). Complements the categorical proficiency_level with a precise quantitative measure for advanced talent matching and QoS scoring. Null when no formal assessment has been conducted.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qosWeight rdf:type rdf:Property ;
    rdfs:label 'Qos Weight' ;
    rdfs:comment 'Numeric weight assigned to this skill for Quality of Submission (QoS) scoring in Bullhorn ATS. Reflects the relative importance of this skill in candidate-to-job-order matching. Higher weights indicate skills that are more critical to placement success. Expressed as a decimal between 0.0000 and 1.0000.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:skillCategory rdf:type rdf:Property ;
    rdfs:label 'Skill Category' ;
    rdfs:comment 'High-level classification of the skill type used to segment the talent pool and drive job order matching logic. Values: technical (programming, engineering), soft_skill (communication, leadership), domain_expertise (industry knowledge), language (spoken/written languages), tool_platform (software applications and platforms).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillDescription rdf:type rdf:Property ;
    rdfs:label 'Skill Description' ;
    rdfs:comment 'Free-text description providing additional context about the candidates application of this skill, including specific tools, methodologies, or contexts in which the skill was used. Supports recruiter notes and enhances submittal quality in Bullhorn ATS.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillName rdf:type rdf:Property ;
    rdfs:label 'Skill Name' ;
    rdfs:comment 'Human-readable name of the skill or competency (e.g., Python, Payroll Processing, Conflict Resolution, SAP SuccessFactors). Normalized to a controlled taxonomy where available to support consistent talent pool search and job order matching in Bullhorn ATS.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillSource rdf:type rdf:Property ;
    rdfs:label 'Skill Source' ;
    rdfs:comment 'Provenance indicator describing how this skill was attributed to the candidate. Self_reported: candidate entered directly; resume_parsed: extracted via ATS resume parsing in Bullhorn; assessment_verified: confirmed through a formal skills assessment; recruiter_tagged: added by a recruiter; certification_derived: inferred from a verified credential or certification record.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillStatus rdf:type rdf:Property ;
    rdfs:label 'Skill Status' ;
    rdfs:comment 'Current lifecycle status of the skill record. Active: skill is current and searchable in talent pool; inactive: skill has been deactivated by recruiter or candidate; pending_verification: skill awaiting assessment or credential confirmation; archived: historical record retained for compliance and audit purposes.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemSkillRef rdf:type rdf:Property ;
    rdfs:label 'Source System Skill Ref' ;
    rdfs:comment 'The native identifier for this skill record in the originating operational system (e.g., Bullhorn skill record ID, SuccessFactors competency ID). Enables bidirectional reconciliation between the Silver Layer lakehouse and source systems for data quality and lineage purposes.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyCode rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Code' ;
    rdfs:comment 'Standardized code from a controlled skill taxonomy (e.g., O*NET SOC skill codes, ESCO skill URIs, or internal Staffing Hr taxonomy identifiers) used to normalize skill names across ATS, VMS, and job board integrations. Enables cross-system skill-to-requirement mapping in Beeline VMS and Bullhorn.' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomySource rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Source' ;
    rdfs:comment 'Identifies the controlled vocabulary or taxonomy system from which the taxonomy_code is drawn. Supports multi-taxonomy normalization across ATS and VMS platforms. Values: onet (U.S. DOL O*NET), esco (EU ESCO framework), internal (Staffing Hr proprietary taxonomy), linkedin (LinkedIn Skills taxonomy), custom (client-specific taxonomy).' ;
    rdfs:domain ind:Skill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityId rdf:type rdf:Property ;
    rdfs:label 'Availability Id' ;
    rdfs:comment 'Unique surrogate identifier for the candidate availability and preference record. Primary key for this data product.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Availability .

ind:availabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Availability Status' ;
    rdfs:comment 'Current placement availability state of the candidate. available indicates actively seeking work; on_assignment indicates currently placed; bench indicates between assignments but still engaged; unavailable indicates not seeking work; do_not_contact indicates candidate has opted out of outreach. Critical for bench tracking and redeployment workflows in Bullhorn ATS.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableEndDate rdf:type rdf:Property ;
    rdfs:label 'Available End Date' ;
    rdfs:comment 'The date through which the candidate has indicated availability, if bounded. Null indicates open-ended availability. Useful for temporary or project-based candidates with known commitment windows.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:availableStartDate rdf:type rdf:Property ;
    rdfs:label 'Available Start Date' ;
    rdfs:comment 'The earliest date on which the candidate is available to begin a new assignment or placement. Used by recruiters for job order matching and dispatch scheduling. Sourced from Bullhorn ATS candidate record.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmedDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Date' ;
    rdfs:comment 'Date on which the candidates current availability status was last confirmed by a recruiter or by the candidate directly. Distinct from preference_last_updated_date; specifically tracks confirmation of the availability_status field.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:desiredBillRateAware rdf:type rdf:Property ;
    rdfs:label 'Desired Bill Rate Aware' ;
    rdfs:comment 'Indicates whether the candidate has been informed of or is aware of the client bill rate associated with their placement. True = candidate is aware of bill rate; False = candidate has not been informed. Relevant for co-employment risk management and transparency compliance.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:desiredPayRateMax rdf:type rdf:Property ;
    rdfs:label 'Desired Pay Rate Max' ;
    rdfs:comment 'Maximum hourly or annual pay rate the candidate is targeting, expressed in USD. Represents the upper bound of the candidates compensation expectation. Used alongside desired_pay_rate_min for range-based matching.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:desiredPayRateMin rdf:type rdf:Property ;
    rdfs:label 'Desired Pay Rate Min' ;
    rdfs:comment 'Minimum hourly or annual pay rate the candidate is willing to accept, expressed in USD. Used by recruiters to qualify candidates against job order pay rate budgets and to calculate spread and gross margin. Confidential compensation data.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:doNotPlaceFlag rdf:type rdf:Property ;
    rdfs:label 'Do Not Place Flag' ;
    rdfs:comment 'Indicates whether the candidate has been flagged as ineligible for placement (e.g., due to performance issues, compliance violations, or client restrictions). True = do not place; False = eligible for placement. Critical compliance and risk management control.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doNotPlaceReason rdf:type rdf:Property ;
    rdfs:label 'Do Not Place Reason' ;
    rdfs:comment 'Reason code or description explaining why the candidate has been flagged as do-not-place. Populated only when do_not_place_flag is True. Examples: client_restriction, compliance_violation, performance_issue, voluntary_withdrawal.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoCity rdf:type rdf:Property ;
    rdfs:label 'Geo City' ;
    rdfs:comment 'City within which the candidate is willing to accept placements. Used for geographic matching in job order dispatch and sourcing outreach workflows.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRadiusMiles rdf:type rdf:Property ;
    rdfs:label 'Geo Radius Miles' ;
    rdfs:comment 'Maximum commute radius in miles from the candidates home location that they are willing to travel for an assignment. Used in proximity-based job order matching and sourcing outreach.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geoState rdf:type rdf:Property ;
    rdfs:label 'Geo State' ;
    rdfs:comment 'U.S. state (two-letter USPS abbreviation) within which the candidate is willing to accept placements. Supports state-level labor law compliance checks (e.g., SUTA, state wage-hour laws).' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openToPerDiem rdf:type rdf:Property ;
    rdfs:label 'Open To Per Diem' ;
    rdfs:comment 'Indicates whether the candidate is willing to accept per diem compensation arrangements (daily allowances for travel, lodging, meals). True = willing to accept per diem; False = not interested. Relevant for travel nursing, field services, and project-based placements.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openToTempToPerm rdf:type rdf:Property ;
    rdfs:label 'Open To Temp To Perm' ;
    rdfs:comment 'Indicates whether the candidate is open to a Temp-to-Perm (contract-to-hire) arrangement where a temporary assignment may convert to a permanent position. True = open to conversion; False = not interested in conversion. Drives conversion fee eligibility tracking.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferenceLastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Preference Last Updated Date' ;
    rdfs:comment 'Date on which the candidate last updated their placement preferences (job titles, industries, pay rate, work arrangement, etc.). Used to assess preference data freshness and trigger re-engagement when preferences are stale.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredCompanySize rdf:type rdf:Property ;
    rdfs:label 'Preferred Company Size' ;
    rdfs:comment 'Candidates stated preference for the size of the client organization they wish to work with. Supports matching candidates to client accounts by headcount tier. [ENUM-REF-CANDIDATE: startup|small|mid_market|enterprise — promote to reference product if additional tiers are needed]' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredEmploymentType rdf:type rdf:Property ;
    rdfs:label 'Preferred Employment Type' ;
    rdfs:comment 'Candidates stated preference for the type of engagement. temp = temporary/contract; contract_to_hire = Contract-to-Hire (CTH); direct_placement = Direct Hire/Permanent; fte = Full-Time Equivalent salaried role; per_diem = per diem/daily rate engagement. Drives job order matching logic in Bullhorn ATS.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredHoursPerWeekMax rdf:type rdf:Property ;
    rdfs:label 'Preferred Hours Per Week Max' ;
    rdfs:comment 'Maximum number of hours per week the candidate is willing to work. Prevents over-scheduling and supports overtime (OT) management. Relevant for FLSA compliance and ACA hour-tracking thresholds.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredHoursPerWeekMin rdf:type rdf:Property ;
    rdfs:label 'Preferred Hours Per Week Min' ;
    rdfs:comment 'Minimum number of hours per week the candidate is willing to work. Used to qualify candidates for part-time versus full-time job orders. Supports FLSA classification analysis.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredIndustries rdf:type rdf:Property ;
    rdfs:label 'Preferred Industries' ;
    rdfs:comment 'Comma-separated list of industries the candidate prefers to work in (e.g., Healthcare, Technology, Finance). Used to match candidates to client accounts by industry vertical. Aligns with SIC/NAICS industry classification.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredJobTitles rdf:type rdf:Property ;
    rdfs:label 'Preferred Job Titles' ;
    rdfs:comment 'Comma-separated list of job titles the candidate is actively seeking. Used for keyword-based job order matching and proactive sourcing outreach in Bullhorn ATS. Examples: Software Engineer, Senior Developer, Tech Lead.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLocations rdf:type rdf:Property ;
    rdfs:label 'Preferred Locations' ;
    rdfs:comment 'Comma-separated list of specific cities, metro areas, or regions the candidate prefers for placement (e.g., Austin TX, Dallas TX, Remote). More granular than geo_city/geo_state for multi-location preferences.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredShift rdf:type rdf:Property ;
    rdfs:label 'Preferred Shift' ;
    rdfs:comment 'Candidates preferred work shift. Used in workforce scheduling and dispatch workflows, particularly for light industrial, healthcare, and manufacturing placements managed through Kronos Workforce Ready.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredWorkArrangement rdf:type rdf:Property ;
    rdfs:label 'Preferred Work Arrangement' ;
    rdfs:comment 'Candidates stated preference for physical work location arrangement: fully on-site, fully remote, or hybrid. Used to filter and match job orders by work model in ATS and VMS platforms.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredWorkCulture rdf:type rdf:Property ;
    rdfs:label 'Preferred Work Culture' ;
    rdfs:comment 'Free-text or comma-separated description of the candidates preferred workplace culture attributes (e.g., collaborative, fast-paced, diverse, mission-driven). Used in qualitative matching for direct hire and FTE placements.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when this availability record was first created in the system. Supports data lineage, audit trail, and GDPR/CCPA data retention compliance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp when this availability record was last modified. Used for change data capture (CDC) in the Databricks Silver Layer pipeline and for identifying recently updated availability records for recruiter workflows.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:redeploymentCandidate rdf:type rdf:Property ;
    rdfs:label 'Redeployment Candidate' ;
    rdfs:comment 'Indicates whether this candidate has been flagged for proactive redeployment outreach before their current assignment ends. True = flagged for redeployment; False = not flagged. Supports bench management and redeployment workflows to reduce fall-off rate.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:redeploymentTargetDate rdf:type rdf:Property ;
    rdfs:label 'Redeployment Target Date' ;
    rdfs:comment 'Target date by which the recruiter aims to redeploy the candidate into a new assignment. Typically set relative to the current assignment end date. Drives redeployment pipeline reporting in Power BI.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemRecordRef rdf:type rdf:Property ;
    rdfs:label 'Source System Record Ref' ;
    rdfs:comment 'The native identifier of this availability record in the originating source system (e.g., Bullhorn candidate ID or availability record ID). Enables traceability back to the system of record for reconciliation and audit purposes.' ;
    rdfs:domain ind:Candidate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingChannel rdf:type rdf:Property ;
    rdfs:label 'Sourcing Channel' ;
    rdfs:comment 'The channel through which the candidates current availability record was captured or updated (e.g., recruiter_call, job_board, referral, linkedin, career_site, vms_portal). Supports sourcing channel attribution analytics in Power BI.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelPercentageMax rdf:type rdf:Property ;
    rdfs:label 'Travel Percentage Max' ;
    rdfs:comment 'Maximum percentage of work time the candidate is willing to spend traveling (0–100). Used to qualify candidates for roles with travel requirements. Null if willing_to_travel is False.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:willingToRelocate rdf:type rdf:Property ;
    rdfs:label 'Willing To Relocate' ;
    rdfs:comment 'Indicates whether the candidate is open to relocating for a permanent or long-term placement opportunity. True = willing to relocate; False = not willing. Relevant for direct hire and FTE placement matching.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:willingToTravel rdf:type rdf:Property ;
    rdfs:label 'Willing To Travel' ;
    rdfs:comment 'Indicates whether the candidate is willing to travel for work assignments. True = willing to travel; False = not willing. Used in conjunction with travel_percentage_max for travel-intensive roles.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workerClassificationPreference rdf:type rdf:Property ;
    rdfs:label 'Worker Classification Preference' ;
    rdfs:comment 'Candidates preferred worker classification for engagement: W-2 (employee of staffing firm), 1099 (independent contractor), EOR (Employer of Record), or C2C (Corp-to-Corp). Critical for IRS worker classification compliance and co-employment risk management.' ;
    rdfs:domain ind:Availability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Status History Id' ;
    rdfs:comment 'Unique surrogate primary key for each candidate status transition record in the immutable audit log.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctedRecordStatusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Corrected Record Status History Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original status_history record that this correction supersedes. Null when is_correction is false. Maintains immutable audit chain integrity.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StatusHistory .

ind:atsWorkflowStep rdf:type rdf:Property ;
    rdfs:label 'Ats Workflow Step' ;
    rdfs:comment 'The specific ATS workflow step or stage name within Bullhorn that corresponds to this status transition (e.g., Initial Screen, Client Submittal, Offer Extended). Provides granular workflow context beyond the high-level status.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchStartDate rdf:type rdf:Property ;
    rdfs:label 'Bench Start Date' ;
    rdfs:comment 'The date the candidate entered bench status (unassigned but available for redeployment). Populated when new_status is bench. Null for non-bench transitions.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceHold rdf:type rdf:Property ;
    rdfs:label 'Compliance Hold' ;
    rdfs:comment 'Indicates whether this status transition was triggered by or resulted in a compliance hold (e.g., pending I-9 verification, background check failure, credential expiration). Drives compliance workflow routing.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceHoldReason rdf:type rdf:Property ;
    rdfs:label 'Compliance Hold Reason' ;
    rdfs:comment 'The specific compliance issue causing the hold when compliance_hold is true: I-9 pending, background check (BGC) failed, drug screen pending, credential expired, E-Verify pending, or other. Null when compliance_hold is false.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysInPriorStatus rdf:type rdf:Property ;
    rdfs:label 'Days In Prior Status' ;
    rdfs:comment 'Number of calendar days the candidate spent in the prior status before this transition. Captured at transition time for pipeline velocity and Time-to-Fill (TTF) / Time-to-Start (TTS) analytics.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dnpExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Dnp Expiration Date' ;
    rdfs:comment 'The date on which the DNP restriction expires and the candidate becomes eligible for placement consideration again. Null for permanent DNP designations or non-DNP transitions.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dnpInitiator rdf:type rdf:Property ;
    rdfs:label 'Dnp Initiator' ;
    rdfs:comment 'The role or party that initiated the DNP designation: recruiter, branch_manager, compliance_officer, client, system (automated rule), or legal. Null for non-DNP transitions. Supports compliance audit and accountability tracking.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dnpReasonCode rdf:type rdf:Property ;
    rdfs:label 'Dnp Reason Code' ;
    rdfs:comment 'Standardized reason code for the DNP designation (e.g., CONDUCT_VIOLATION, SAFETY_INCIDENT, CLIENT_REQUEST, BACKGROUND_FAILURE, POLICY_VIOLATION, PERFORMANCE_ISSUE). Null for non-DNP transitions. [ENUM-REF-CANDIDATE: promote to reference product — values exceed 6]' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dnpReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Dnp Review Required' ;
    rdfs:comment 'Indicates whether this DNP designation requires a formal compliance or legal review before the restriction can be lifted or modified. Drives DNP enforcement workflow routing. Null for non-DNP transitions.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dnpScope rdf:type rdf:Property ;
    rdfs:label 'Dnp Scope' ;
    rdfs:comment 'Defines the breadth of the Do-Not-Place restriction: client_specific (restricted from a single client account), program_specific (restricted from a VMS/MSP program), or global (restricted from all placements across the enterprise). Null for non-DNP transitions.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallOffDays rdf:type rdf:Property ;
    rdfs:label 'Fall Off Days' ;
    rdfs:comment 'Number of days the candidate was on assignment before the fall-off occurred. Calculated at the time of the fall-off transition and stored for reporting. Null for non-fall-off transitions.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Interview Outcome' ;
    rdfs:comment 'Result of the interview when the transition involves an interview stage. Null for non-interview transitions. Drives pipeline conversion analytics.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewType rdf:type rdf:Property ;
    rdfs:label 'Interview Type' ;
    rdfs:comment 'Type of interview conducted when the transition is to the interviewed status. Null for non-interview transitions.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCorrection rdf:type rdf:Property ;
    rdfs:label 'Is Correction' ;
    rdfs:comment 'Indicates whether this record represents a correction to a previously recorded status transition (e.g., a data entry error was corrected). When true, corrected_record_id should reference the original erroneous record.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDnp rdf:type rdf:Property ;
    rdfs:label 'Is Dnp' ;
    rdfs:comment 'Indicates whether this status transition represents a Do-Not-Place (DNP) designation. When true, the DNP-specific fields (dnp_scope, dnp_reason_code, dnp_initiator, dnp_expiration_date, dnp_review_required) are populated.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pipelineStageSequence rdf:type rdf:Property ;
    rdfs:label 'Pipeline Stage Sequence' ;
    rdfs:comment 'Ordinal sequence number of this status transition within the candidates overall ATS pipeline for a given job order. Enables pipeline velocity analysis and stage-by-stage conversion funnel reporting.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transitionNotes rdf:type rdf:Property ;
    rdfs:label 'Transition Notes' ;
    rdfs:comment 'Free-text notes entered by the recruiter or system describing the context, rationale, or details of the status transition. Supports compliance audit trails and recruiter activity documentation.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Transition Reason Code' ;
    rdfs:comment 'Standardized reason code explaining why the status transition occurred (e.g., CANDIDATE_WITHDREW, CLIENT_REJECTED, ASSIGNMENT_ENDED, SCREENING_FAILED, OFFER_ACCEPTED). Drives fall-off rate analysis and pipeline quality reporting. [ENUM-REF-CANDIDATE: promote to reference product — values exceed 6]' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transition Timestamp' ;
    rdfs:comment 'The precise date and time when the candidate status transition occurred. This is the authoritative business event time used for pipeline velocity, TTF, and TTS calculations.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transitionTrigger rdf:type rdf:Property ;
    rdfs:label 'Transition Trigger' ;
    rdfs:comment 'Identifies the actor or mechanism that initiated the status transition: system (automated ATS rule), recruiter (manual recruiter action), candidate (candidate self-service or withdrawal), or client (client feedback or rejection).' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionId rdf:type rdf:Property ;
    rdfs:label 'Interaction Id' ;
    rdfs:comment 'Unique system-generated identifier for each candidate interaction event record in the Bullhorn CRM activity log.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atsActivityRef rdf:type rdf:Property ;
    rdfs:label 'Ats Activity Ref' ;
    rdfs:comment 'The native activity or note record identifier from the Bullhorn ATS/CRM source system. Enables traceability and reconciliation between the lakehouse silver layer and the operational system of record.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:candidateLifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Candidate Lifecycle Stage' ;
    rdfs:comment 'The candidates lifecycle stage at the time of this interaction, captured as a snapshot to enable stage-level engagement analytics and funnel conversion reporting. Distinct from the current status in the candidate master record. [ENUM-REF-CANDIDATE: sourced|applied|screened|submitted|interviewing|offered|placed|on_assignment|bench|offboarded — promote to reference product]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Email address used for this specific interaction, captured at the time of the interaction. May differ from the candidates current primary email. Classified as restricted PII per GDPR and CCPA.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Phone number used for this specific interaction, captured at the time of the interaction. May differ from the candidates current primary phone if the candidate provided an alternate number. Classified as restricted PII per FCRA and GDPR.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Identifies the originating system or entry method for this interaction record (e.g., Bullhorn ATS/CRM, Salesforce, manual entry, API integration). Supports data lineage, reconciliation, and source system attribution in the lakehouse.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Indicates whether the interaction was initiated by the recruiter/system (outbound) or by the candidate (inbound). Critical for measuring candidate engagement and recruiter outreach activity KPIs.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotContact rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact' ;
    rdfs:comment 'Indicates whether the candidate has requested to not be contacted at the time of this interaction. Captured as a snapshot at interaction time for compliance audit purposes. Supports GDPR, CCPA, and TCPA opt-out compliance.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interactionStatus rdf:type rdf:Property ;
    rdfs:label 'Interaction Status' ;
    rdfs:comment 'Current lifecycle state of the interaction record. Completed indicates the communication occurred; Attempted indicates outreach was made but no contact was established; Scheduled indicates a future interaction is planned; Cancelled or Failed indicate the interaction did not proceed.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Interaction Timestamp' ;
    rdfs:comment 'The precise date and time when the interaction event occurred (real-world event time). This is the principal business event timestamp used for SLA compliance monitoring, recruiter activity KPI reporting, and candidate engagement timeline analysis.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'Classifies the mode of communication used for this interaction event (e.g., phone call, email, SMS, in-person meeting, video interview, portal message). Drives channel analytics and recruiter activity reporting in Bullhorn CRM.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewFormat rdf:type rdf:Property ;
    rdfs:label 'Interview Format' ;
    rdfs:comment 'Specific format of the interview when interaction_type is video_interview or in_person_meeting (e.g., phone screen, video, in-person, panel, technical, behavioral). Null for non-interview interaction types. Supports interview pipeline analytics.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAutomated rdf:type rdf:Property ;
    rdfs:label 'Is Automated' ;
    rdfs:comment 'Indicates whether this interaction was generated by an automated system (True) or by a human recruiter (False). Distinguishes system-to-candidate automated communications (e.g., ATS status emails, drip campaigns) from recruiter-initiated outreach for activity KPI accuracy.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextAction rdf:type rdf:Property ;
    rdfs:label 'Next Action' ;
    rdfs:comment 'Free-text description of the agreed or planned next step following this interaction (e.g., Send job description, Schedule technical screen, Submit to client). Drives recruiter task management and pipeline progression in Bullhorn CRM.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Action Due Date' ;
    rdfs:comment 'Target date by which the next action following this interaction should be completed. Used for recruiter task prioritization, SLA compliance monitoring, and pipeline velocity management.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:npsEligible rdf:type rdf:Property ;
    rdfs:label 'Nps Eligible' ;
    rdfs:comment 'Indicates whether this interaction qualifies as a trigger event for an NPS survey to be sent to the candidate. Used to manage NPS survey cadence and avoid survey fatigue in candidate experience measurement programs.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsSurveySent rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Sent' ;
    rdfs:comment 'Indicates whether an NPS survey was actually dispatched to the candidate following this interaction. Supports NPS program tracking and ensures survey delivery accountability.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optOutChannel rdf:type rdf:Property ;
    rdfs:label 'Opt Out Channel' ;
    rdfs:comment 'Specifies the communication channel(s) from which the candidate has opted out at the time of this interaction (email, SMS, phone, or all channels). Null if no opt-out is in effect. Supports GDPR, CCPA, and TCPA compliance.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purpose rdf:type rdf:Property ;
    rdfs:label 'Purpose' ;
    rdfs:comment 'Business purpose or intent of the interaction within the candidate lifecycle (e.g., sourcing outreach, screening call, submittal preparation, interview prep, offer discussion, onboarding, assignment check-in, redeployment, compliance). Enables lifecycle stage attribution and funnel analytics. [ENUM-REF-CANDIDATE: sourcing|screening|submittal_prep|interview_prep|offer_discussion|onboarding|assignment_check_in|redeployment|compliance|general_follow_up — promote to reference product]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseReceived rdf:type rdf:Property ;
    rdfs:label 'Response Received' ;
    rdfs:comment 'Indicates whether the candidate responded to this interaction. True if a response was received; False if no response was obtained. Key metric for candidate engagement rate and outreach effectiveness reporting.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'The date and time when the candidate responded to the interaction. Populated only when response_received is True. Used to calculate response time metrics and SLA compliance for candidate communications.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Timestamp' ;
    rdfs:comment 'The date and time when the interaction was originally scheduled to occur, if pre-planned (e.g., a scheduled video interview or callback). Distinct from interaction_timestamp which records when it actually happened.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sentimentTag rdf:type rdf:Property ;
    rdfs:label 'Sentiment Tag' ;
    rdfs:comment 'Recruiter-assigned or system-derived sentiment classification of the interaction outcome (positive, neutral, negative). Supports Net Promoter Score (NPS) tracking, candidate experience measurement, and early identification of at-risk candidates.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResponseTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Response Target Hours' ;
    rdfs:comment 'The contracted or internal SLA target for candidate response time in hours, applicable to this interaction type and channel. Used to evaluate whether the recruiter met response time commitments and for SLA compliance reporting.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Brief subject line or title of the interaction (e.g., email subject line, call topic, meeting agenda title). Used for searchability and quick reference in the Bullhorn CRM activity feed.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:summary rdf:type rdf:Property ;
    rdfs:label 'Summary' ;
    rdfs:comment 'Free-text narrative summary or notes captured by the recruiter describing the substance of the interaction, key discussion points, candidate feedback, and any agreed next steps. Core field for recruiter activity documentation in Bullhorn CRM.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:administeredDate rdf:type rdf:Property ;
    rdfs:label 'Administered Date' ;
    rdfs:comment 'The calendar date on which the assessment was administered or conducted. Used for validity tracking, expiration calculation, and Time to Fill (TTF) analytics.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:administeredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Administered Timestamp' ;
    rdfs:comment 'Precise date and time when the assessment was started or administered. Supports duration calculation and audit trail requirements.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:competencyLevel rdf:type rdf:Property ;
    rdfs:label 'Competency Level' ;
    rdfs:comment 'The proficiency level demonstrated by the candidate on this assessment, mapped to a standardized competency scale. Used for candidate ranking and job matching in the ATS.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isReqSpecific rdf:type rdf:Property ;
    rdfs:label 'Is Req Specific' ;
    rdfs:comment 'Indicates whether this assessment was administered specifically for a particular job order/requisition (True) or as a general talent pool qualification assessment (False). Drives reusability logic for candidate redeployment.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalReviewOfficer rdf:type rdf:Property ;
    rdfs:label 'Medical Review Officer' ;
    rdfs:comment 'Name or identifier of the licensed Medical Review Officer (MRO) who reviewed and certified the drug screen result. Required for DOT-regulated positions and federally mandated drug testing programs.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:normalizedScore rdf:type rdf:Property ;
    rdfs:label 'Normalized Score' ;
    rdfs:comment 'The standardized score after applying normalization logic (e.g., percentile conversion, scale adjustment) to enable cross-assessment and cross-candidate comparison. Drives Quality of Submission (QoS) and candidate ranking workflows.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passingThreshold rdf:type rdf:Property ;
    rdfs:label 'Passing Threshold' ;
    rdfs:comment 'The minimum score required for a candidate to pass this assessment. Used to derive pass/fail result and enforce client-specific or role-specific screening standards.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:providerName rdf:type rdf:Property ;
    rdfs:label 'Provider Name' ;
    rdfs:comment 'Name of the third-party vendor or platform that administered the assessment (e.g., HireVue, Codility, Wonderlic, Sterling Background Check). Used for vendor performance tracking and cost allocation.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceSourceName rdf:type rdf:Property ;
    rdfs:label 'Reference Source Name' ;
    rdfs:comment 'Name of the individual who provided a reference check response, applicable when assessment_type is reference_check. Stored for audit and compliance purposes.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceSourceRelationship rdf:type rdf:Property ;
    rdfs:label 'Reference Source Relationship' ;
    rdfs:comment 'The professional relationship of the reference provider to the candidate (e.g., supervisor, colleague). Applicable when assessment_type is reference_check. Informs the weight given to the reference in QoS scoring.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultDetail rdf:type rdf:Property ;
    rdfs:label 'Result Detail' ;
    rdfs:comment 'Narrative or structured detail describing the assessment outcome beyond the pass/fail result (e.g., drug screen substance detected, reference check summary, behavioral competency ratings). Supports recruiter review and compliance documentation.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reusableFlag rdf:type rdf:Property ;
    rdfs:label 'Reusable Flag' ;
    rdfs:comment 'Indicates whether the assessment result can be reused for other job orders or placements without re-administration, subject to expiration date. Supports candidate redeployment and bench management efficiency.' ;
    rdfs:domain ind:Assessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scoreScaleMax rdf:type rdf:Property ;
    rdfs:label 'Score Scale Max' ;
    rdfs:comment 'The maximum possible score on the assessment instruments scoring scale. Required to interpret raw and normalized scores in context and calculate score percentages.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scoreScaleMin rdf:type rdf:Property ;
    rdfs:label 'Score Scale Min' ;
    rdfs:comment 'The minimum possible score on the assessment instruments scoring scale. Required to interpret raw and normalized scores in context.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:educationId rdf:type rdf:Property ;
    rdfs:label 'Education Id' ;
    rdfs:comment 'Unique surrogate identifier for each candidate education record in the Silver Layer lakehouse. Primary key for the education data product within the candidate domain.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accreditationBody rdf:type rdf:Property ;
    rdfs:label 'Accreditation Body' ;
    rdfs:comment 'Name of the regional or national accreditation body that accredits the institution (e.g., HLC, SACSCOC, ABET, ACEN for nursing programs). Used to validate institutional legitimacy for compliance-sensitive placements in healthcare, government, and defense sectors.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentration rdf:type rdf:Property ;
    rdfs:label 'Concentration' ;
    rdfs:comment 'Specific academic concentration, specialization, or track within the major (e.g., Data Analytics within a Computer Science major, Corporate Finance within an MBA). Provides additional granularity for advanced qualification matching on specialized job orders.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialEvaluationBody rdf:type rdf:Property ;
    rdfs:label 'Credential Evaluation Body' ;
    rdfs:comment 'Name of the accredited foreign credential evaluation organization that assessed the international degree (e.g., World Education Services (WES), Educational Credential Evaluators (ECE)). Required for OFCCP and I-9 compliance documentation.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialEvaluationStatus rdf:type rdf:Property ;
    rdfs:label 'Credential Evaluation Status' ;
    rdfs:comment 'Status of the foreign credential evaluation process for internationally-earned degrees. Applicable only when is_international_credential is True. Required for OFCCP compliance on federal contractor placements and I-9 employment eligibility workflows.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:degreeName rdf:type rdf:Property ;
    rdfs:label 'Degree Name' ;
    rdfs:comment 'Full verbatim name of the degree or certificate as it appears on the official credential document (e.g., Bachelor of Science in Computer Engineering, AWS Certified Solutions Architect). Preserves the exact credential title for client-facing submittals and compliance documentation.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpa rdf:type rdf:Property ;
    rdfs:label 'Gpa' ;
    rdfs:comment 'Candidates reported Grade Point Average (GPA) on a 4.0 scale, if provided. Optional field sourced from resume parsing or candidate self-submission. Some client job orders specify minimum GPA thresholds for entry-level placements.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpaScale rdf:type rdf:Property ;
    rdfs:label 'Gpa Scale' ;
    rdfs:comment 'The maximum GPA scale used by the institution (e.g., 4.0, 5.0, 10.0). Required to normalize GPA values across institutions with different grading scales for accurate qualification comparison.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:graduationYear rdf:type rdf:Property ;
    rdfs:label 'Graduation Year' ;
    rdfs:comment 'Four-digit calendar year of graduation or program completion. Stored separately from graduation_date to support cases where only the year is known (e.g., resume-parsed data). Used for cohort analytics and workforce planning.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:honors rdf:type rdf:Property ;
    rdfs:label 'Honors' ;
    rdfs:comment 'Academic honors designation awarded at graduation (e.g., Cum Laude, Magna Cum Laude, Summa Cum Laude). Used for premium candidate profiling and client-facing talent quality reporting.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:institutionCity rdf:type rdf:Property ;
    rdfs:label 'Institution City' ;
    rdfs:comment 'City where the educational institution is located. Used for geographic context in credential verification and compliance reporting.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:institutionCountry rdf:type rdf:Property ;
    rdfs:label 'Institution Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the country where the educational institution is located. Supports international credential evaluation and EEOC/OFCCP reporting.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:institutionState rdf:type rdf:Property ;
    rdfs:label 'Institution State' ;
    rdfs:comment 'Two-letter US state abbreviation (or equivalent province/territory code) where the educational institution is located. Used for regional compliance and credential verification routing.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:institutionType rdf:type rdf:Property ;
    rdfs:label 'Institution Type' ;
    rdfs:comment 'Categorical classification of the educational institution. Drives qualification matching logic for job orders requiring specific institution types. [ENUM-REF-CANDIDATE: university|community_college|trade_school|bootcamp|online_platform|high_school|vocational|seminary|other — promote to reference product]' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAccredited rdf:type rdf:Property ;
    rdfs:label 'Is Accredited' ;
    rdfs:comment 'Indicates whether the institution holds recognized regional or national accreditation (True). Many client job orders, particularly in healthcare, government, and defense, require degrees from accredited institutions. Drives qualification gate logic in the ATS.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCompleted rdf:type rdf:Property ;
    rdfs:label 'Is Completed' ;
    rdfs:comment 'Indicates whether the candidate completed and received the degree or certificate (True) or attended without completing (False). Critical for qualification matching — incomplete degrees may not satisfy job order minimum education requirements.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHighestDegree rdf:type rdf:Property ;
    rdfs:label 'Is Highest Degree' ;
    rdfs:comment 'Flags this education record as the candidates highest level of academic achievement (True). Used by ATS qualification matching logic to quickly identify the most advanced credential without scanning all education records.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInternationalCredential rdf:type rdf:Property ;
    rdfs:label 'Is International Credential' ;
    rdfs:comment 'Indicates whether the education credential was earned at a non-US institution (True) and therefore may require foreign credential evaluation. Triggers the international credential evaluation workflow for EEOC and OFCCP compliance on federal contracts.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:major rdf:type rdf:Property ;
    rdfs:label 'Major' ;
    rdfs:comment 'Primary academic concentration or major declared by the candidate within their degree program (e.g., Software Engineering, Accounting, Registered Nursing). Provides granular qualification detail beyond field of study for precise job order matching.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minor rdf:type rdf:Property ;
    rdfs:label 'Minor' ;
    rdfs:comment 'Secondary academic concentration or minor declared by the candidate within their degree program. Supplementary qualification data used for advanced candidate matching and talent pool analytics.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'The channel or method through which this education record was originally captured. Tracks whether data originated from automated resume parsing, candidate self-entry via portal, recruiter manual entry in Bullhorn, or a background check report. Supports data quality scoring and sourcing analytics. [ENUM-REF-CANDIDATE: resume_parse|candidate_portal|recruiter_entry|ats_import|vms_import|background_check|linkedin_import|other — promote to reference product]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thesisTitle rdf:type rdf:Property ;
    rdfs:label 'Thesis Title' ;
    rdfs:comment 'Title of the candidates thesis or dissertation for graduate-level degrees (Masters or Doctorate). Used for highly specialized technical placements where research expertise is a qualification criterion.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Verification Reference Number' ;
    rdfs:comment 'External reference or case number assigned by the credential verification provider (e.g., Sterling BGC order ID, National Student Clearinghouse transaction ID). Enables traceability back to the source verification record for audit and dispute resolution.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payRateAgreementId rdf:type rdf:Property ;
    rdfs:label 'Pay Rate Agreement Id' ;
    rdfs:comment 'Unique system-generated identifier for the pay rate agreement record. Primary key for this entity. Role: MASTER_AGREEMENT.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayRateAgreement .

ind:engagementType rdf:type rdf:Property ;
    rdfs:label 'Engagement Type' ;
    rdfs:comment 'The type of staffing engagement for which this pay rate agreement applies. Temp (temporary), contract, temp-to-perm (Contract-to-Hire), direct hire (permanent placement), or SOW (Statement of Work) project-based engagement. Drives payroll and billing treatment.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRateNegotiable rdf:type rdf:Property ;
    rdfs:label 'Is Rate Negotiable' ;
    rdfs:comment 'Indicates whether the pay rate in this agreement is open to further negotiation by the candidate or recruiter. True if negotiable; False if the rate is fixed (e.g., set by a VMS program or client rate card). Supports recruiter workflow guidance.' ;
    rdfs:domain ind:PayRateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxWeeklyHours rdf:type rdf:Property ;
    rdfs:label 'Max Weekly Hours' ;
    rdfs:comment 'The maximum number of hours per week the candidate is authorized to work under this agreement before requiring manager or client approval for additional hours. Supports overtime cost control and ACA compliance monitoring.' ;
    rdfs:domain ind:PayRateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiationDate rdf:type rdf:Property ;
    rdfs:label 'Negotiation Date' ;
    rdfs:comment 'The date on which the pay rate was negotiated and agreed between the recruiter and the candidate. Represents the principal business event timestamp for this agreement. Distinct from the effective date when the rate becomes active.' ;
    rdfs:domain ind:PayRateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateChangeReason rdf:type rdf:Property ;
    rdfs:label 'Rate Change Reason' ;
    rdfs:comment 'Free-text or coded explanation for why this pay rate agreement was created or modified (e.g., initial placement, merit increase, market adjustment, assignment extension, client rate change, cost-of-living adjustment). Supports audit and analytics.' ;
    rdfs:domain ind:PayRateAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorRtrRightToRepresentId rdf:type rdf:Property ;
    rdfs:label 'Prior Rtr Right To Represent Id' ;
    rdfs:comment 'Reference to the previous RTR record that this record supersedes or replaces, enabling lineage tracking when an RTR is renewed, extended, or re-scoped. Null for original grants.' ;
    rdfs:domain ind:RightToRepresent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RightToRepresent .

ind:acknowledgmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Timestamp' ;
    rdfs:comment 'Date and time the candidate formally acknowledged the RTR terms. Distinct from grant_timestamp in cases where consent is captured asynchronously (e.g., portal consent with delayed confirmation).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:candidateAcknowledged rdf:type rdf:Property ;
    rdfs:label 'Candidate Acknowledged' ;
    rdfs:comment 'Indicates whether the candidate has explicitly acknowledged the RTR terms, including understanding that the staffing firm will represent them to the specified client or program. True = acknowledged; False = not yet acknowledged.' ;
    rdfs:domain ind:RightToRepresent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:candidateIpAddress rdf:type rdf:Property ;
    rdfs:label 'Candidate Ip Address' ;
    rdfs:comment 'IP address of the device used by the candidate when granting RTR consent via a digital portal. Captured for audit and legal evidence purposes. Applicable when grant_method is portal_consent. Classified as confidential PII per GDPR and CCPA.' ;
    rdfs:domain ind:RightToRepresent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Consent Document Url' ;
    rdfs:comment 'Secure URL or storage path to the RTR consent document (e.g., signed PDF, DocuSign completed envelope). Confidential as it may contain candidate signature and personal details. Null when no document was captured.' ;
    rdfs:domain ind:RightToRepresent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Notes' ;
    rdfs:comment 'Free-text notes documenting the outcome and resolution of an RTR dispute, including the basis for the decision (e.g., timestamp comparison, client confirmation). Populated only when dispute_flag is True.' ;
    rdfs:domain ind:RightToRepresent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eeocDispositionCode rdf:type rdf:Property ;
    rdfs:label 'Eeoc Disposition Code' ;
    rdfs:comment 'Standardized EEOC disposition code associated with the candidates submittal outcome linked to this RTR, used for adverse action tracking and OFCCP/EEOC reporting. Populated after submittal disposition is determined. [ENUM-REF-CANDIDATE: interviewed|not_selected|hired|withdrawn|no_show|position_cancelled — promote to reference product]' ;
    rdfs:domain ind:RightToRepresent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailThreadReference rdf:type rdf:Property ;
    rdfs:label 'Email Thread Reference' ;
    rdfs:comment 'Message ID or thread reference from the email system capturing the candidates email-based RTR consent. Applicable when grant_method is email. Used for audit evidence retrieval.' ;
    rdfs:domain ind:RightToRepresent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Expiration Date' ;
    rdfs:comment 'The date on which the exclusivity period of the RTR grant ends, after which the candidate may be submitted by other vendors. Null when exclusivity_flag is False or exclusivity is open-ended.' ;
    rdfs:domain ind:RightToRepresent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether the RTR grant is exclusive to this staffing firm for the specified scope, preventing the candidate from being submitted by competing vendors to the same client or requisition. True = exclusive; False = non-exclusive.' ;
    rdfs:domain ind:RightToRepresent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grantMethod rdf:type rdf:Property ;
    rdfs:label 'Grant Method' ;
    rdfs:comment 'The channel or mechanism by which the candidate provided RTR consent. verbal — spoken consent captured by recruiter; email — written consent via email; portal_consent — self-service ATS/candidate portal click-through; signed_form — wet or e-signature on RTR document; vms_portal — consent captured through a Vendor Management System (VMS) portal such as Beeline.' ;
    rdfs:domain ind:RightToRepresent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grantTimestamp rdf:type rdf:Property ;
    rdfs:label 'Grant Timestamp' ;
    rdfs:comment 'The exact date and time the candidate granted the Right to Represent authorization. This is the principal business event timestamp for this transaction, distinct from the record audit timestamp.' ;
    rdfs:domain ind:RightToRepresent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isRevoked rdf:type rdf:Property ;
    rdfs:label 'Is Revoked' ;
    rdfs:comment 'Indicates whether the candidate has revoked the RTR grant prior to its natural expiration. True = revoked; False = not revoked. Used as a fast-path filter in submittal eligibility checks.' ;
    rdfs:domain ind:RightToRepresent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ndaSigned rdf:type rdf:Property ;
    rdfs:label 'Nda Signed' ;
    rdfs:comment 'Indicates whether the required NDA has been executed by the candidate prior to or concurrent with the RTR grant. Relevant when nda_required is True. True = NDA signed; False = NDA not yet signed.' ;
    rdfs:domain ind:RightToRepresent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ofccpAuditReady rdf:type rdf:Property ;
    rdfs:label 'Ofccp Audit Ready' ;
    rdfs:comment 'Indicates whether this RTR record has all required documentation and metadata to satisfy an Office of Federal Contract Compliance Programs (OFCCP) audit, including consent evidence, timestamps, and scope definition. True = audit-ready; False = documentation incomplete.' ;
    rdfs:domain ind:RightToRepresent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revocationInitiatedBy rdf:type rdf:Property ;
    rdfs:label 'Revocation Initiated By' ;
    rdfs:comment 'Identifies who initiated the revocation of the RTR grant. candidate — candidate self-revoked; recruiter — recruiter revoked on behalf of candidate; system — automated revocation triggered by business rule (e.g., placement made); client — client requested removal.' ;
    rdfs:domain ind:RightToRepresent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Revocation Timestamp' ;
    rdfs:comment 'The exact date and time the candidate revoked the RTR grant. Null when is_revoked is False. Required for audit trail and to determine the window during which submittals were authorized.' ;
    rdfs:domain ind:RightToRepresent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rtrNumber rdf:type rdf:Property ;
    rdfs:label 'Rtr Number' ;
    rdfs:comment 'Human-readable, externally referenceable identifier for the RTR grant, used in recruiter communications, audit trails, and submittal documentation. Format: RTR-YYYY-NNNNNN.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtrScope rdf:type rdf:Property ;
    rdfs:label 'Rtr Scope' ;
    rdfs:comment 'Defines the breadth of the RTR authorization. single_req — limited to one specific requisition/job order; client_wide — covers all open requisitions at the named client; program_wide — covers all requisitions within a managed service program (MSP/VMS program).' ;
    rdfs:domain ind:RightToRepresent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtrStatus rdf:type rdf:Property ;
    rdfs:label 'Rtr Status' ;
    rdfs:comment 'Current lifecycle state of the RTR grant. active — valid and usable for submittal; expired — past expiration date; revoked — candidate withdrew consent; pending — awaiting candidate confirmation; superseded — replaced by a newer RTR for the same scope.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRtrRef rdf:type rdf:Property ;
    rdfs:label 'Source System Rtr Ref' ;
    rdfs:comment 'The native identifier of this RTR record in the originating source system (e.g., Bullhorn submittal ID, Beeline VMS consent token). Used for cross-system reconciliation and data lineage.' ;
    rdfs:domain ind:RightToRepresent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validDaysDuration rdf:type rdf:Property ;
    rdfs:label 'Valid Days Duration' ;
    rdfs:comment 'The number of calendar days for which the RTR grant is valid from the grant_timestamp. Used to calculate expiration_date and to standardize RTR validity policies across client programs.' ;
    rdfs:domain ind:RightToRepresent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verbalConsentNotes rdf:type rdf:Property ;
    rdfs:label 'Verbal Consent Notes' ;
    rdfs:comment 'Recruiter-entered notes documenting the circumstances of a verbal RTR consent, including date, time, and summary of conversation. Required when grant_method is verbal to satisfy audit requirements.' ;
    rdfs:domain ind:RightToRepresent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentPoolMembershipId rdf:type rdf:Property ;
    rdfs:label 'Talent Pool Membership Id' ;
    rdfs:comment 'Unique surrogate identifier for each talent pool membership record. Primary key for the talent_pool_membership entity in the candidate domain Silver layer.' ;
    rdfs:domain ind:TalentPoolMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redeploymentAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Redeployment Assignment Id' ;
    rdfs:comment 'Reference to the assignment that is ending and triggering the redeployment of this candidate into the talent pool. Null for non-redeployment pool memberships. Links to the placement.assignment product.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assignment .

ind:addedDate rdf:type rdf:Property ;
    rdfs:label 'Added Date' ;
    rdfs:comment 'Calendar date on which the candidate was added to the talent pool. Used for tenure-in-pool analytics and redeployment SLA tracking.' ;
    rdfs:domain ind:TalentPoolMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contactAttemptCount rdf:type rdf:Property ;
    rdfs:label 'Contact Attempt Count' ;
    rdfs:comment 'Total number of recruiter contact attempts made to the candidate since being added to this talent pool. Used to identify unresponsive candidates and trigger escalation or exit workflows.' ;
    rdfs:domain ind:TalentPoolMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementScore rdf:type rdf:Property ;
    rdfs:label 'Engagement Score' ;
    rdfs:comment 'Numeric score (0–100) reflecting the candidates level of engagement with the talent pool, based on recruiter interactions, response rates, and activity signals. Higher scores indicate more responsive and engaged candidates. Used to prioritize outreach and predict placement likelihood.' ;
    rdfs:domain ind:TalentPoolMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exitDate rdf:type rdf:Property ;
    rdfs:label 'Exit Date' ;
    rdfs:comment 'Calendar date on which the candidate exited or was removed from the talent pool. Null if the membership is still active. Used for pool churn analysis and redeployment outcome tracking.' ;
    rdfs:domain ind:TalentPoolMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exitReason rdf:type rdf:Property ;
    rdfs:label 'Exit Reason' ;
    rdfs:comment 'Reason the candidate exited the talent pool. placed indicates a successful placement was made; declined_offer indicates the candidate declined a placement offer; unresponsive indicates the candidate became unreachable; disqualified indicates the candidate no longer meets pool criteria; converted_to_perm indicates a temp-to-perm conversion occurred. [ENUM-REF-CANDIDATE: placed|declined_offer|unresponsive|disqualified|converted_to_perm|pool_dissolved|candidate_request|credential_lapse — promote to reference product]' ;
    rdfs:domain ind:TalentPoolMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:i9Verified rdf:type rdf:Property ;
    rdfs:label 'I9 Verified' ;
    rdfs:comment 'Indicates whether the candidate has a valid, completed I-9 Employment Eligibility Verification on file, confirming work authorization in the United States. Required for all W-2 placements. Sourced from compliance.i9_verification.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interviewCount rdf:type rdf:Property ;
    rdfs:label 'Interview Count' ;
    rdfs:comment 'Number of client interviews the candidate has completed as a result of submittals from this talent pool membership. Used to measure pool conversion effectiveness and recruiter performance.' ;
    rdfs:domain ind:TalentPoolMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isRedeploymentCandidate rdf:type rdf:Property ;
    rdfs:label 'Is Redeployment Candidate' ;
    rdfs:comment 'Indicates whether this pool membership record was created as part of a formal redeployment workflow triggered by an ending assignment. True when the candidate is being actively redeployed; False for general talent pool members. Supports bench and redeployment tracking KPIs.' ;
    rdfs:domain ind:TalentPoolMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWillingToRelocate rdf:type rdf:Property ;
    rdfs:label 'Is Willing To Relocate' ;
    rdfs:comment 'Indicates whether the candidate is willing to relocate for a placement sourced from this talent pool. True if the candidate has expressed willingness to relocate; False if the candidate requires local placements only. Expands the geographic matching radius for job order fulfillment.' ;
    rdfs:domain ind:TalentPoolMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWillingToTravel rdf:type rdf:Property ;
    rdfs:label 'Is Willing To Travel' ;
    rdfs:comment 'Indicates whether the candidate is willing to travel for assignments sourced from this talent pool. Relevant for travel nursing, per diem, and project-based staffing programs where travel is required.' ;
    rdfs:domain ind:TalentPoolMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current lifecycle status of the candidates membership in the talent pool. active indicates the candidate is actively managed within the pool; pending_review indicates awaiting recruiter qualification; suspended indicates temporarily paused; exited indicates the candidate has been removed from the pool.' ;
    rdfs:domain ind:TalentPoolMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipType rdf:type rdf:Property ;
    rdfs:label 'Membership Type' ;
    rdfs:comment 'Classification of the nature of the candidates pool membership. redeployment indicates the candidate is being actively redeployed from an ending assignment; bench indicates an unassigned worker available for dispatch; talent_community indicates a passive talent community member; client_specific indicates a pool curated for a specific client program; specialty_practice indicates a domain-specific skill pool. [ENUM-REF-CANDIDATE: redeployment|bench|talent_community|client_specific|specialty_practice|pipeline|vms_preferred|msp_approved — promote to reference product]' ;
    rdfs:domain ind:TalentPoolMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payRateCurrency rdf:type rdf:Property ;
    rdfs:label 'Pay Rate Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the pay rate values (pay_rate_min, pay_rate_max). Defaults to USD for domestic U.S. operations. Supports multi-currency operations for international staffing programs.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolQualificationDate rdf:type rdf:Property ;
    rdfs:label 'Pool Qualification Date' ;
    rdfs:comment 'Date on which the candidate was formally qualified and approved for inclusion in this talent pool by a recruiter or pool manager. May differ from added_date if a review/approval workflow is required before activation.' ;
    rdfs:domain ind:TalentPoolMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredLocationCity rdf:type rdf:Property ;
    rdfs:label 'Preferred Location City' ;
    rdfs:comment 'The candidates preferred city for work assignments sourced from this talent pool. Used for geographic matching of job orders to pool members. Supports workforce scheduling and dispatch workflows.' ;
    rdfs:domain ind:TalentPoolMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLocationState rdf:type rdf:Property ;
    rdfs:label 'Preferred Location State' ;
    rdfs:comment 'Two-letter U.S. state code for the candidates preferred work location. Used for geographic filtering during job order matching and for state-specific compliance checks (SUTA, workers comp, wage-hour laws).' ;
    rdfs:domain ind:TalentPoolMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredWorkType rdf:type rdf:Property ;
    rdfs:label 'Preferred Work Type' ;
    rdfs:comment 'The candidates preferred employment classification or engagement type within this pool. Reflects whether the candidate prefers W-2 temporary, 1099 independent contractor, Employer of Record (EOR), or direct hire arrangements. Informs compliance and worker classification checks.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityTier rdf:type rdf:Property ;
    rdfs:label 'Priority Tier' ;
    rdfs:comment 'Recruiter-assigned priority tier indicating the urgency and desirability of placing this candidate from the pool. Tier 1 represents highest priority (e.g., actively redeploying workers with imminent assignment end dates); Tier 4 represents passive pipeline members. Drives recruiter workflow prioritization.' ;
    rdfs:domain ind:TalentPoolMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationNotes rdf:type rdf:Property ;
    rdfs:label 'Qualification Notes' ;
    rdfs:comment 'Free-text notes entered by the recruiter or pool manager documenting the rationale for the candidates inclusion in the talent pool, any qualification criteria met, or special considerations for placement matching.' ;
    rdfs:domain ind:TalentPoolMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountPlanId rdf:type rdf:Property ;
    rdfs:label 'Headcount Plan Id' ;
    rdfs:comment 'Foreign key linking to joborder.headcount_plan. Business justification: Workforce planning process: talent pools are proactively built to fulfill approved headcount plans before requisitions open. MSP/VMS programs require linking pool inventory to headcount_plan for capac' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HeadcountPlan .

ind:parentTalentPoolId rdf:type rdf:Property ;
    rdfs:label 'Parent Talent Pool Id' ;
    rdfs:comment 'Self-referencing FK on talent_pool (parent_talent_pool_id)' ;
    rdfs:domain ind:TalentPool ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TalentPool .

ind:atsPoolCode rdf:type rdf:Property ;
    rdfs:label 'Ats Pool Code' ;
    rdfs:comment 'External identifier for this talent pool in the source Applicant Tracking System (e.g., Bullhorn pool ID).' ;
    rdfs:domain ind:TalentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableCandidateCount rdf:type rdf:Property ;
    rdfs:label 'Available Candidate Count' ;
    rdfs:comment 'The number of candidates in this talent pool who are currently available for immediate placement (not on assignment).' ;
    rdfs:domain ind:TalentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bullhornPoolCode rdf:type rdf:Property ;
    rdfs:label 'Bullhorn Pool Code' ;
    rdfs:comment 'Specific identifier for this talent pool in the Bullhorn ATS system, supporting integration and synchronization.' ;
    rdfs:domain ind:TalentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentCandidateCount rdf:type rdf:Property ;
    rdfs:label 'Current Candidate Count' ;
    rdfs:comment 'The current number of active candidates assigned to this talent pool.' ;
    rdfs:domain ind:TalentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:experienceLevel rdf:type rdf:Property ;
    rdfs:label 'Experience Level' ;
    rdfs:comment 'The target experience or seniority level of candidates in this talent pool (entry, junior, mid-level, senior, executive, expert).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBenchPool rdf:type rdf:Property ;
    rdfs:label 'Is Bench Pool' ;
    rdfs:comment 'Boolean flag indicating whether this talent pool represents bench candidates (employees between assignments awaiting redeployment).' ;
    rdfs:domain ind:TalentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isClientSpecific rdf:type rdf:Property ;
    rdfs:label 'Is Client Specific' ;
    rdfs:comment 'Boolean flag indicating whether this talent pool is dedicated to a specific client organization.' ;
    rdfs:domain ind:TalentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRedeploymentPool rdf:type rdf:Property ;
    rdfs:label 'Is Redeployment Pool' ;
    rdfs:comment 'Boolean flag indicating whether this talent pool is specifically used for redeploying existing employees to new assignments.' ;
    rdfs:domain ind:TalentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCandidateAddedDate rdf:type rdf:Property ;
    rdfs:label 'Last Candidate Added Date' ;
    rdfs:comment 'The date when the most recent candidate was added to this talent pool.' ;
    rdfs:domain ind:TalentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPlacementDate rdf:type rdf:Property ;
    rdfs:label 'Last Placement Date' ;
    rdfs:comment 'The date when the most recent candidate from this talent pool was successfully placed in a position.' ;
    rdfs:domain ind:TalentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumYearsExperience rdf:type rdf:Property ;
    rdfs:label 'Maximum Years Experience' ;
    rdfs:comment 'The maximum number of years of professional experience for candidates in this talent pool, if applicable.' ;
    rdfs:domain ind:TalentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumYearsExperience rdf:type rdf:Property ;
    rdfs:label 'Minimum Years Experience' ;
    rdfs:comment 'The minimum number of years of professional experience required for candidates in this talent pool.' ;
    rdfs:domain ind:TalentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:poolCode rdf:type rdf:Property ;
    rdfs:label 'Pool Code' ;
    rdfs:comment 'Externally-known unique code or identifier for the talent pool used in reporting and integrations.' ;
    rdfs:domain ind:TalentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolName rdf:type rdf:Property ;
    rdfs:label 'Pool Name' ;
    rdfs:comment 'Human-readable name of the talent pool (e.g., Java Developers - Senior, Healthcare RNs - West Coast, Finance Contractors - Available).' ;
    rdfs:domain ind:TalentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolStatus rdf:type rdf:Property ;
    rdfs:label 'Pool Status' ;
    rdfs:comment 'Current lifecycle status of the talent pool indicating whether it is actively used for candidate sourcing and placement.' ;
    rdfs:domain ind:TalentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolType rdf:type rdf:Property ;
    rdfs:label 'Pool Type' ;
    rdfs:comment 'Classification of the talent pool based on its segmentation criteria (skill-based, industry-based, geography-based, availability-based, client-specific, project-based).' ;
    rdfs:domain ind:TalentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCountry rdf:type rdf:Property ;
    rdfs:label 'Primary Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the primary geographic location of the talent pool (e.g., USA, GBR, CAN).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRegion rdf:type rdf:Property ;
    rdfs:label 'Primary Region' ;
    rdfs:comment 'The primary state, province, or region within the country where this talent pool is focused.' ;
    rdfs:domain ind:TalentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:talentPoolDescription rdf:type rdf:Property ;
    rdfs:label 'Talent Pool Description' ;
    rdfs:comment 'Detailed business description of the talent pool, including its purpose, target candidate profiles, and intended use cases.' ;
    rdfs:domain ind:TalentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCandidateCount rdf:type rdf:Property ;
    rdfs:label 'Target Candidate Count' ;
    rdfs:comment 'The target or goal number of candidates to maintain in this talent pool for optimal sourcing capacity.' ;
    rdfs:domain ind:TalentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetIndustry rdf:type rdf:Property ;
    rdfs:label 'Target Industry' ;
    rdfs:comment 'The industry or sector this talent pool is designed to serve (e.g., Healthcare, Financial Services, Technology).' ;
    rdfs:domain ind:TalentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactEmail rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Email' ;
    rdfs:comment 'Email address of the designated billing contact at the client organization. Primary channel for electronic invoice delivery, payment reminders, and accounts receivable communications.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactName rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Name' ;
    rdfs:comment 'Full name of the designated billing contact at the client organization responsible for receiving and approving invoices. Used by Salesforce Revenue Cloud and accounts receivable for invoice delivery and payment follow-up.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bullhornClientCode rdf:type rdf:Property ;
    rdfs:label 'Bullhorn Client Code' ;
    rdfs:comment 'The native record identifier assigned to this client account within Bullhorn ATS/CRM. Used for cross-system reconciliation and data lineage tracing between the Silver layer and the operational source system.' ;
    rdfs:domain ind:ClientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientType rdf:type rdf:Property ;
    rdfs:label 'Client Type' ;
    rdfs:comment 'Classifies the commercial relationship model under which Staffing Hr serves this client. Values: direct (standard staffing client), vms_msp (client managed through a Vendor Management System or Managed Service Provider program), rpo (Recruitment Process Outsourcing engagement), eor (Employer of Record arrangement), peo (Professional Employer Organization), sow (Statement of Work-based engagement). [ENUM-REF-CANDIDATE: direct|vms_msp|rpo|eor|peo|sow — promote to reference product]' ;
    rdfs:domain ind:ClientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companySizeTier rdf:type rdf:Property ;
    rdfs:label 'Company Size Tier' ;
    rdfs:comment 'Categorical classification of the client organization by employee headcount or revenue band. Used for account segmentation, service tier assignment, pricing strategy, and sales territory management. Values: small (<100 FTE), mid_market (100–999 FTE), enterprise (1,000–9,999 FTE), global_enterprise (10,000+ FTE).' ;
    rdfs:domain ind:ClientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'The trade name or Doing Business As (DBA) name under which the client operates commercially, if different from the legal entity name. Used in client-facing communications, invoices, and CRM displays.' ;
    rdfs:domain ind:ClientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeHeadcount rdf:type rdf:Property ;
    rdfs:label 'Employee Headcount' ;
    rdfs:comment 'Approximate total number of full-time equivalent (FTE) employees at the client organization at the time of account creation or last update. Used to validate company size tier classification and inform workforce planning and capacity estimates.' ;
    rdfs:domain ind:ClientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fein rdf:type rdf:Property ;
    rdfs:label 'Fein' ;
    rdfs:comment 'The Federal Employer Identification Number (FEIN) assigned by the IRS to uniquely identify the client as a tax entity. Required for W-2 co-employment compliance, tax reporting, and workers compensation administration.' ;
    rdfs:domain ind:ClientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceGroupingRule rdf:type rdf:Property ;
    rdfs:label 'Invoice Grouping Rule' ;
    rdfs:comment 'Defines how timesheet and placement charges are consolidated onto invoices for this client. Values: consolidated (single invoice for all activity), by_location (separate invoice per work site), by_department (separate invoice per client department), by_cost_center (separate invoice per cost center), by_po (separate invoice per Purchase Order number). Configured per client MSA terms.' ;
    rdfs:domain ind:ClientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mainPhone rdf:type rdf:Property ;
    rdfs:label 'Main Phone' ;
    rdfs:comment 'Primary switchboard or main office phone number for the client organization. Used for account management outreach, service delivery coordination, and CRM contact records.' ;
    rdfs:domain ind:ClientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerName rdf:type rdf:Property ;
    rdfs:label 'Manager Name' ;
    rdfs:comment 'Full name of the Staffing Hr account manager responsible for day-to-day service delivery, relationship management, and SLA compliance for this client. May differ from the CRM account owner (sales rep). Used for operational escalation and KPI reporting.' ;
    rdfs:domain ind:ClientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msaExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Msa Expiration Date' ;
    rdfs:comment 'The date on which the current Master Service Agreement (MSA) is scheduled to expire or must be renewed. Null for evergreen agreements with no fixed end date. Used to trigger renewal workflows in DocuSign CLM and Salesforce.' ;
    rdfs:domain ind:ClientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mspProviderName rdf:type rdf:Property ;
    rdfs:label 'Msp Provider Name' ;
    rdfs:comment 'Name of the Managed Service Provider (MSP) that administers the clients contingent workforce program on their behalf. Relevant when client_type = vms_msp. Staffing Hr submits requisitions and invoices through the MSP rather than directly to the client.' ;
    rdfs:domain ind:ClientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Date' ;
    rdfs:comment 'The date on which the most recent Net Promoter Score (NPS) survey response was recorded for this client. Used to determine survey recency and schedule next survey cycle.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onHoldReason rdf:type rdf:Property ;
    rdfs:label 'On Hold Reason' ;
    rdfs:comment 'Free-text description of the reason the client account has been placed on hold (account_status = on_hold). Examples include credit limit exceeded, compliance issue pending, contract renewal in progress, or client-requested pause. Null when account is not on hold.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poRequired rdf:type rdf:Property ;
    rdfs:label 'Po Required' ;
    rdfs:comment 'Indicates whether the client requires a valid Purchase Order (PO) number on all invoices before payment will be processed. When True, invoices without a PO number are blocked from submission. Enforced in Salesforce Revenue Cloud billing workflow.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Primary Address Line1' ;
    rdfs:comment 'First line of the clients primary registered business address (street number and street name). Used for invoice delivery, compliance filings, and geographic territory assignment.' ;
    rdfs:domain ind:ClientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Primary Address Line2' ;
    rdfs:comment 'Second line of the clients primary registered business address (suite, floor, building, or unit number). Supplements address line 1 for complete mailing and compliance address records.' ;
    rdfs:domain ind:ClientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCity rdf:type rdf:Property ;
    rdfs:label 'Primary City' ;
    rdfs:comment 'City of the clients primary registered business address. Used for geographic segmentation, territory assignment, state tax jurisdiction determination, and SUTA rate mapping.' ;
    rdfs:domain ind:ClientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPostalCode rdf:type rdf:Property ;
    rdfs:label 'Primary Postal Code' ;
    rdfs:comment 'ZIP or ZIP+4 postal code of the clients primary registered business address. Used for geographic routing, tax jurisdiction lookup, and territory management.' ;
    rdfs:domain ind:ClientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryState rdf:type rdf:Property ;
    rdfs:label 'Primary State' ;
    rdfs:comment 'Two-letter U.S. state or territory code of the clients primary registered business address (ISO 3166-2:US). Drives state tax jurisdiction, SUTA rate assignment, workers compensation classification, and OFCCP reporting.' ;
    rdfs:domain ind:ClientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sicCode rdf:type rdf:Property ;
    rdfs:label 'Sic Code' ;
    rdfs:comment 'The four-digit Standard Industrial Classification (SIC) code for the clients primary industry. Maintained alongside NAICS for legacy system compatibility, EEOC reporting, and OFCCP compliance tracking.' ;
    rdfs:domain ind:ClientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTier rdf:type rdf:Property ;
    rdfs:label 'Sla Tier' ;
    rdfs:comment 'The SLA service tier assigned to this client, which defines response time commitments, submittal quality standards (QoS), time-to-fill (TTF) targets, and escalation protocols. Values: standard, premium, enterprise, custom. Drives SLA configuration and KPI reporting in Power BI Analytics Platform.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmsPlatform rdf:type rdf:Property ;
    rdfs:label 'Vms Platform' ;
    rdfs:comment 'Name of the Vendor Management System (VMS) platform used by this client to manage contingent workforce requisitions and supplier interactions (e.g., Beeline, Fieldglass, IQNavigator, Coupa). Populated only for client_type = vms_msp. Drives integration configuration with Beeline VMS.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'The primary public website URL of the client organization. Used for client profile enrichment, candidate research, and CRM account verification.' ;
    rdfs:domain ind:ClientAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportsToContactId rdf:type rdf:Property ;
    rdfs:label 'Reports To Contact Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the contacts manager or superior within the client organizations contact hierarchy. Supports org chart modeling and escalation path identification for complex enterprise client accounts.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientContact .

ind:bullhornContactCode rdf:type rdf:Property ;
    rdfs:label 'Bullhorn Contact Code' ;
    rdfs:comment 'Source system identifier for this contact record as assigned by Bullhorn ATS/CRM. Used for cross-system reconciliation and data lineage tracing between the lakehouse and the operational CRM.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessEmail rdf:type rdf:Property ;
    rdfs:label 'Business Email' ;
    rdfs:comment 'Primary business email address of the client contact. Used for job order submissions, submittal notifications, interview scheduling, and all formal CRM-driven communications. Governed by GDPR and CCPA for opt-in/opt-out management.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classification of the contacts functional role in the staffing relationship. Determines routing of communications, invoices, and requisitions. Key values: hiring_manager (submits reqs and approves submittals), procurement (manages MSA and rate cards), accounts_payable (AP — receives invoices), executive_sponsor (strategic relationship owner), vms_coordinator (manages VMS program interactions). [ENUM-REF-CANDIDATE: hiring_manager|procurement|accounts_payable|executive_sponsor|vms_coordinator|recruiter_liaison|legal|it_admin — promote to reference product]' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directPhone rdf:type rdf:Property ;
    rdfs:label 'Direct Phone' ;
    rdfs:comment 'Direct office or desk phone number for the client contact. Primary synchronous communication channel for recruiters and account managers to reach hiring managers and procurement contacts. Stored in E.164 international format.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotCall rdf:type rdf:Property ;
    rdfs:label 'Do Not Call' ;
    rdfs:comment 'Indicates whether the contact has requested to not be contacted by phone. True = do not call; False = phone contact is permitted. Enforced in CRM dialing workflows to ensure compliance with TCPA and internal communication policies.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailOptIn rdf:type rdf:Property ;
    rdfs:label 'Email Opt In' ;
    rdfs:comment 'Indicates whether the contact has opted in to receive marketing and promotional email communications from Staffing Hr. True = opted in; False = opted out or not consented. Critical for GDPR and CAN-SPAM compliance in outbound marketing campaigns.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDecisionMaker rdf:type rdf:Property ;
    rdfs:label 'Is Decision Maker' ;
    rdfs:comment 'Indicates whether this contact has authority to approve staffing requisitions, rate cards, or MSA terms. True = has decision-making authority; False = influencer or end-user without final approval authority. Used to prioritize executive engagement strategies.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent CRM-logged interaction with this contact (call, email, meeting, note). Used to identify dormant contacts, trigger re-engagement workflows, and measure account manager activity against SLA targets.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastActivityType rdf:type rdf:Property ;
    rdfs:label 'Last Activity Type' ;
    rdfs:comment 'Type of the most recent CRM-logged interaction with this contact. Provides context for the last_activity_date and supports analysis of engagement channel effectiveness across the client contact portfolio.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:namePrefix rdf:type rdf:Property ;
    rdfs:label 'Name Prefix' ;
    rdfs:comment 'Honorific or salutation prefix for the contact (e.g., Mr., Ms., Dr.). Used in formal written correspondence and client-facing communications to ensure professional address.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nameSuffix rdf:type rdf:Property ;
    rdfs:label 'Name Suffix' ;
    rdfs:comment 'Professional or generational suffix appended to the contact name (e.g., Jr., Sr., III, CPA, MBA). Supports accurate formal correspondence and professional credential display.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officePhoneExt rdf:type rdf:Property ;
    rdfs:label 'Office Phone Ext' ;
    rdfs:comment 'Phone extension number associated with the contacts direct office line. Required when the client organization uses a PBX system and the direct_phone field contains the main switchboard number.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'The contacts stated preferred method of communication for staffing-related outreach. Drives CRM engagement workflows and ensures recruiter and account manager interactions align with the contacts preferences, improving response rates and relationship quality.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceContactCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Contact Code' ;
    rdfs:comment 'Source system identifier for this contact record as assigned by Salesforce Revenue Cloud CRM. Enables bi-directional sync and deduplication between Bullhorn and Salesforce contact records.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:source rdf:type rdf:Property ;
    rdfs:label 'Source' ;
    rdfs:comment 'The originating system or channel through which this contact record was first created or imported into the Staffing Hr data platform. Supports data lineage tracking, deduplication analysis, and source quality reporting.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmsUserCode rdf:type rdf:Property ;
    rdfs:label 'Vms User Code' ;
    rdfs:comment 'The contacts user identifier within the clients Vendor Management System (VMS) platform (e.g., Beeline). Required for VMS-managed programs where job orders, submittals, and timesheets are processed through the VMS portal. Enables mapping of VMS workflow actions to the CRM contact record.' ;
    rdfs:domain ind:ClientContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Id' ;
    rdfs:comment 'Unique surrogate identifier for each parent-child account hierarchy relationship record in the staffing client account structure.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childAccountClientAccountId rdf:type rdf:Property ;
    rdfs:label 'Child Account Client Account Id' ;
    rdfs:comment 'Reference to the child (subordinate) client account in the hierarchy. Represents the subsidiary, division, franchise, or local site that rolls up to the parent account.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientAccount .

ind:primaryClientAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Client Account Id' ;
    rdfs:comment 'Reference to the parent (superior) client account in the hierarchy. Represents the owning entity such as a global corporate parent, regional holding company, or divisional umbrella account.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientAccount .

ind:billingConsolidationFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Consolidation Flag' ;
    rdfs:comment 'Indicates whether invoices and billing activity for the child account should be consolidated and rolled up to the parent account level. When true, Oracle NetSuite ERP and Salesforce Revenue Cloud aggregate charges at the parent account for enterprise billing.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this specific parent-child relationship within the enterprise account structure. Used for cross-system reconciliation between Bullhorn, Salesforce, and Beeline VMS.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyDescription rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Description' ;
    rdfs:comment 'Free-text narrative describing the business rationale or context for this parent-child account relationship, such as organizational restructuring notes or program scope details.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric depth of the child account within the overall account tree, where level 1 represents the ultimate global parent. Used for territory planning, consolidated reporting, and enterprise SLA management across account families.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyName rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Name' ;
    rdfs:comment 'Human-readable label for this parent-child relationship, typically combining parent and child account names (e.g., Acme Corp > Acme Northeast Division). Used in reporting dashboards and CRM displays.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Materialized path string representing the full ancestry chain from the root parent to the current child node (e.g., /1001/1045/1078). Enables efficient tree traversal queries for enterprise roll-up reporting and consolidated billing in the Databricks Silver layer.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyStatus rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Status' ;
    rdfs:comment 'Current lifecycle state of the parent-child account hierarchy relationship. Controls whether the relationship is used in active billing roll-ups, SLA aggregations, and VMS program management.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyType rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Type' ;
    rdfs:comment 'Classifies the purpose or dimension of this hierarchy relationship. An account may participate in multiple hierarchy types simultaneously (e.g., organizational for CRM, billing for consolidated invoicing, VMS program for Beeline roll-ups).' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryRelationship rdf:type rdf:Property ;
    rdfs:label 'Is Primary Relationship' ;
    rdfs:comment 'Indicates whether this is the primary (canonical) parent-child relationship for the child account when multiple hierarchy relationships exist (e.g., a subsidiary may belong to both a geographic and a functional hierarchy). Ensures unambiguous roll-up for consolidated billing.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxDepth rdf:type rdf:Property ;
    rdfs:label 'Max Depth' ;
    rdfs:comment 'The maximum number of levels in the account hierarchy subtree rooted at this node. Used for enterprise account structure validation and to enforce organizational depth limits in VMS program configurations.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npsRollupFlag rdf:type rdf:Property ;
    rdfs:label 'Nps Rollup Flag' ;
    rdfs:comment 'Indicates whether Net Promoter Score (NPS) survey responses collected at the child account level should be aggregated and rolled up to the parent account for enterprise client satisfaction reporting.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateCardInheritanceFlag rdf:type rdf:Property ;
    rdfs:label 'Rate Card Inheritance Flag' ;
    rdfs:comment 'Indicates whether the child account inherits bill rates, pay rates, and markup percentages from the parent accounts rate card. When true, Beeline VMS and Salesforce Revenue Cloud apply parent-level rate structures to child account job orders.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Categorical classification of the structural relationship between the parent and child accounts. Drives consolidated billing rules, SLA inheritance, and MSP/VMS program roll-up logic. [ENUM-REF-CANDIDATE: corporate_parent|division|subsidiary|franchise|affiliate|joint_venture — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rollupHeadcountFlag rdf:type rdf:Property ;
    rdfs:label 'Rollup Headcount Flag' ;
    rdfs:comment 'Indicates whether the active worker headcount (Full-Time Equivalent and contingent) for the child account should be aggregated and rolled up to the parent account for enterprise workforce planning and reporting in Power BI.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rollupSpendFlag rdf:type rdf:Property ;
    rdfs:label 'Rollup Spend Flag' ;
    rdfs:comment 'Indicates whether contingent workforce spend (bill amounts, gross margin, markup) for the child account should be aggregated to the parent account level for enterprise spend analytics and MSP program reporting.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaInheritanceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Inheritance Flag' ;
    rdfs:comment 'Indicates whether the child account inherits Service Level Agreement (SLA) configurations from the parent account. When true, SLA targets such as Time to Fill (TTF) and Quality of Submission (QoS) defined at the parent level apply to the child account.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemHierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Source System Hierarchy Code' ;
    rdfs:comment 'The native identifier for this account hierarchy relationship as recorded in the originating operational system (e.g., Bullhorn relationship ID, Salesforce AccountTeamMember ID, Beeline program node ID). Enables bidirectional traceability for reconciliation.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Background Check Required' ;
    rdfs:comment 'Indicates whether a background check (BGC) is mandatory for all workers placed at this location. Drives Sterling Background Check initiation during the onboarding workflow.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:badgeInstructions rdf:type rdf:Property ;
    rdfs:label 'Badge Instructions' ;
    rdfs:comment 'Free-text instructions for obtaining and using site access badges or security credentials. Provided to workers during onboarding and assignment dispatch to ensure day-one site access.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bullhornLocationCode rdf:type rdf:Property ;
    rdfs:label 'Bullhorn Location Code' ;
    rdfs:comment 'External identifier for this location as stored in Bullhorn ATS/CRM. Used for system-of-record traceability and cross-system reconciliation.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:county rdf:type rdf:Property ;
    rdfs:label 'County' ;
    rdfs:comment 'County or parish in which the work site is located. Used for local tax jurisdiction mapping, workers comp rate tables, and OSHA regional compliance reporting.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentHeadcount rdf:type rdf:Property ;
    rdfs:label 'Current Headcount' ;
    rdfs:comment 'Current number of active contingent workers deployed at this location. Sourced from active placement records and used for real-time capacity monitoring and workforce analytics dashboards in Power BI.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dressCode rdf:type rdf:Property ;
    rdfs:label 'Dress Code' ;
    rdfs:comment 'Description of the dress code or personal protective equipment (PPE) requirements for workers at this site. Communicated during assignment dispatch and onboarding.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDrugFreeWorkplace rdf:type rdf:Property ;
    rdfs:label 'Is Drug Free Workplace' ;
    rdfs:comment 'Indicates whether the client has designated this site as a drug-free workplace, requiring pre-placement and random drug screening for all workers. Triggers Sterling Background Check drug screen requirements during onboarding.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRemote rdf:type rdf:Property ;
    rdfs:label 'Is Remote' ;
    rdfs:comment 'Indicates whether this location represents a remote or virtual work designation rather than a physical facility. Drives workers comp classification, tax nexus determination, and I-9 remote verification workflows.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnionSite rdf:type rdf:Property ;
    rdfs:label 'Is Union Site' ;
    rdfs:comment 'Indicates whether the work site operates under a collective bargaining agreement (CBA). Affects pay rate floors, overtime rules, and worker eligibility requirements for placements at this location.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the work site in decimal degrees (WGS 84). Used for geospatial workforce analytics, proximity-based candidate matching, and mapping integrations.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current lifecycle status of the work site location. Active locations are eligible for new job orders and worker assignments. Inactive or closed locations are retained for historical reporting.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the work site in decimal degrees (WGS 84). Used for geospatial workforce analytics, proximity-based candidate matching, and mapping integrations.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxHeadcount rdf:type rdf:Property ;
    rdfs:label 'Max Headcount' ;
    rdfs:comment 'Maximum number of contingent workers (headcount) authorized by the client to be deployed at this location simultaneously. Used for workforce planning, VMS (Vendor Management System) program controls, and capacity analytics.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oshaEstablishmentNumber rdf:type rdf:Property ;
    rdfs:label 'Osha Establishment Number' ;
    rdfs:comment 'OSHA-assigned establishment identifier for this work site. Required for OSHA 300 log recordkeeping, injury and illness reporting, and OSHA inspection compliance under 29 CFR 1904.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingInstructions rdf:type rdf:Property ;
    rdfs:label 'Parking Instructions' ;
    rdfs:comment 'Free-text instructions for worker parking at the site (e.g., designated lot, permit requirements, street parking rules). Included in worker onboarding and assignment dispatch communications.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCode rdf:type rdf:Property ;
    rdfs:label 'Site Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the work site within the client account hierarchy. Used in timesheets, billing, and workforce scheduling systems such as Kronos Workforce Ready.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteContactEmail rdf:type rdf:Property ;
    rdfs:label 'Site Contact Email' ;
    rdfs:comment 'Email address of the primary on-site contact. Used for timesheet approvals, assignment confirmations, and SLA (Service Level Agreement) communications.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteContactName rdf:type rdf:Property ;
    rdfs:label 'Site Contact Name' ;
    rdfs:comment 'Full name of the primary on-site contact person (e.g., hiring manager, facility supervisor) responsible for coordinating worker assignments, timesheets, and day-to-day staffing operations at this location.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteContactPhone rdf:type rdf:Property ;
    rdfs:label 'Site Contact Phone' ;
    rdfs:comment 'Direct phone number for the primary on-site contact. Used by staffing coordinators for dispatch coordination, worker check-in issues, and urgent placement communications.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteName rdf:type rdf:Property ;
    rdfs:label 'Site Name' ;
    rdfs:comment 'Human-readable name of the physical or virtual work site (e.g., Chicago Distribution Center, Austin HQ – Tower 2, Remote – Pacific Time Zone). Used in assignment dispatch, job orders, and worker communications.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workersCompClassCode rdf:type rdf:Property ;
    rdfs:label 'Workers Comp Class Code' ;
    rdfs:comment 'NCCI (National Council on Compensation Insurance) four-digit classification code assigned to the work site based on the nature of work performed. Determines workers comp premium rates for temporary workers placed at this location.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beelineRateCardCode rdf:type rdf:Property ;
    rdfs:label 'Beeline Rate Card Code' ;
    rdfs:comment 'Native rate card identifier from the Beeline VMS system. Used for cross-system reconciliation between the Staffing Hr lakehouse and the clients Beeline VMS program.' ;
    rdfs:domain ind:ClientRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billRateDt rdf:type rdf:Property ;
    rdfs:label 'Bill Rate Dt' ;
    rdfs:comment 'Negotiated hourly bill rate charged to the client for double-time (DT) hours, applicable in jurisdictions or client agreements requiring double-time pay (e.g., California labor law, holiday work).' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billRateOt rdf:type rdf:Property ;
    rdfs:label 'Bill Rate Ot' ;
    rdfs:comment 'Negotiated hourly bill rate charged to the client for overtime (OT) hours, typically hours worked beyond 40 per week. Governed by FLSA overtime provisions and client MSA terms.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billRateRegular rdf:type rdf:Property ;
    rdfs:label 'Bill Rate Regular' ;
    rdfs:comment 'Negotiated hourly bill rate charged to the client for straight-time (regular) hours worked. This is the primary pricing field used in invoice generation and revenue recognition.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holidayBillRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Holiday Bill Rate Multiplier' ;
    rdfs:comment 'Multiplier applied to the regular bill rate for hours worked on client-designated holidays (e.g., 1.5 = time-and-a-half, 2.0 = double time). Null if no holiday premium is negotiated.' ;
    rdfs:domain ind:ClientRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payRateGuidance rdf:type rdf:Property ;
    rdfs:label 'Pay Rate Guidance' ;
    rdfs:comment 'Recommended or maximum hourly pay rate for the worker under this rate card line. Used as a pricing guardrail during candidate submittal to ensure spread and margin targets are maintained. Not a contractual pay commitment.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesforcePricebookCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Pricebook Code' ;
    rdfs:comment 'Native price book entry identifier from Salesforce Revenue Cloud. Used for cross-system reconciliation between the lakehouse rate card and the Salesforce billing and invoicing configuration.' ;
    rdfs:domain ind:ClientRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beelineProgramCode rdf:type rdf:Property ;
    rdfs:label 'Beeline Program Code' ;
    rdfs:comment 'Native program identifier assigned by the Beeline VMS platform. Used for system-of-record reconciliation and integration with the Beeline API. Serves as the BUSINESS_IDENTIFIER for this agreement as known externally in the VMS ecosystem.' ;
    rdfs:domain ind:VmsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bgcRequired rdf:type rdf:Property ;
    rdfs:label 'Bgc Required' ;
    rdfs:comment 'Indicates whether a background check (BGC) is mandatory for all workers placed through this VMS program prior to assignment start. Drives onboarding workflow and Sterling Background Check integration requirements.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billRateCapCurrency rdf:type rdf:Property ;
    rdfs:label 'Bill Rate Cap Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code applicable to bill rate caps and financial terms within this VMS program (e.g., USD, CAD, GBP). Ensures correct currency context for rate card enforcement and financial reporting.' ;
    rdfs:domain ind:VmsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionFeePct rdf:type rdf:Property ;
    rdfs:label 'Conversion Fee Pct' ;
    rdfs:comment 'Percentage fee charged to the client when a temporary worker placed through this VMS program converts to a permanent (direct hire) employee. Governs temp-to-perm and contract-to-hire financial terms within the program.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataPrivacyAddendumOnFile rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Addendum On File' ;
    rdfs:comment 'Indicates whether a Data Privacy Addendum (DPA) or data processing agreement has been executed for this VMS program. Required for programs subject to GDPR, CCPA, or other data privacy regulations where worker personal data is shared with the clients VMS platform.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eorRequired rdf:type rdf:Property ;
    rdfs:label 'Eor Required' ;
    rdfs:comment 'Indicates whether the VMS program mandates use of an Employer of Record (EOR) arrangement for worker engagement. When true, Staffing Hr or a designated EOR entity assumes employer obligations including payroll, benefits, and compliance.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Description of the geographic scope of this VMS program (e.g., National, Northeast Region, California Only, Global — North America and EMEA). Determines which Staffing Hr branch offices and recruiters are eligible to fulfill requisitions under the program.' ;
    rdfs:domain ind:VmsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icAllowed rdf:type rdf:Property ;
    rdfs:label 'Ic Allowed' ;
    rdfs:comment 'Indicates whether Independent Contractor (IC) worker classifications are permitted within this VMS program. Impacts worker classification compliance, IRS 1099 obligations, and co-employment risk management.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markupCapPct rdf:type rdf:Property ;
    rdfs:label 'Markup Cap Pct' ;
    rdfs:comment 'Maximum allowable markup percentage that Staffing Hr may apply above the pay rate when billing through this VMS program. Enforced by the VMS platform at time of rate submission. Critical financial constraint governing gross margin potential on all placements within the program. Expressed as a percentage (e.g., 35.00 = 35%).' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mspPartnerName rdf:type rdf:Property ;
    rdfs:label 'Msp Partner Name' ;
    rdfs:comment 'Name of the Managed Service Provider (MSP) that administers the VMS program on behalf of the client (e.g., Allegis Global Solutions, Pontoon, Workforce Logiq). Null when program_type is self-managed. Critical for understanding the intermediary controlling requisition flow and supplier tiering.' ;
    rdfs:domain ind:VmsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onSiteCoordinatorRequired rdf:type rdf:Property ;
    rdfs:label 'On Site Coordinator Required' ;
    rdfs:comment 'Indicates whether the VMS program requires Staffing Hr to provide a dedicated on-site coordinator or account manager at the client location. Impacts staffing firm resource allocation and cost structure for program participation.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otMarkupCapPct rdf:type rdf:Property ;
    rdfs:label 'Ot Markup Cap Pct' ;
    rdfs:comment 'Maximum allowable markup percentage for overtime (OT) hours billed through this VMS program. May differ from the standard markup cap. Governs gross margin on OT billing and ensures FLSA-compliant rate submissions.' ;
    rdfs:domain ind:VmsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perDiemAllowed rdf:type rdf:Property ;
    rdfs:label 'Per Diem Allowed' ;
    rdfs:comment 'Indicates whether per diem expense reimbursements are permitted for workers placed through this VMS program. Relevant for travel-intensive assignments and impacts payroll burden calculations in TempWorks.' ;
    rdfs:domain ind:VmsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryLaborCategory rdf:type rdf:Property ;
    rdfs:label 'Primary Labor Category' ;
    rdfs:comment 'The dominant workforce labor category served by this VMS program (e.g., Information Technology, Light Industrial, Professional Services, Healthcare, Finance and Accounting). Used for program segmentation, analytics, and workforce planning reporting in Power BI.' ;
    rdfs:domain ind:VmsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programEndDate rdf:type rdf:Property ;
    rdfs:label 'Program End Date' ;
    rdfs:comment 'Date on which the VMS program is scheduled to expire or was terminated. Nullable for open-ended programs. Defines the EFFECTIVE_UNTIL boundary for supplier participation and rate applicability.' ;
    rdfs:domain ind:VmsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Official name of the VMS contingent workforce program as configured in the VMS platform (e.g., Acme Corp Global Contingent Workforce Program). Used in reporting, supplier communications, and requisition routing. Serves as the IDENTITY_LABEL for this agreement.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStartDate rdf:type rdf:Property ;
    rdfs:label 'Program Start Date' ;
    rdfs:comment 'Date on which the VMS program became or is scheduled to become operationally active. Defines the EFFECTIVE_FROM boundary for supplier participation, rate caps, and requisition routing rules.' ;
    rdfs:domain ind:VmsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle state of the VMS program. Drives requisition routing eligibility, supplier participation, and rate card applicability. LIFECYCLE_STATUS for this MASTER_AGREEMENT entity.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionRoutingRule rdf:type rdf:Property ;
    rdfs:label 'Requisition Routing Rule' ;
    rdfs:comment 'Rule or logic governing how new requisitions are distributed to suppliers within this VMS program (e.g., sequential by tier, broadcast to all tier-1, round-robin, category-based routing). Determines how Staffing Hr receives job orders and the competitive dynamics of the program.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionLimitPerReq rdf:type rdf:Property ;
    rdfs:label 'Submission Limit Per Req' ;
    rdfs:comment 'Maximum number of candidate submittals Staffing Hr is permitted to submit per requisition within this VMS program. Enforced by the VMS platform. Impacts sourcing strategy and Quality of Submission (QoS) focus.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierPortalUrl rdf:type rdf:Property ;
    rdfs:label 'Supplier Portal Url' ;
    rdfs:comment 'URL of the VMS supplier portal through which Staffing Hr accesses requisitions, submits candidates, and manages worker records for this program. Operational reference for recruiter and account management teams.' ;
    rdfs:domain ind:VmsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierTier rdf:type rdf:Property ;
    rdfs:label 'Supplier Tier' ;
    rdfs:comment 'Staffing Hrs designated tier level within the clients VMS supplier hierarchy. Tier 1 suppliers receive first-look requisition routing; lower tiers receive overflow or secondary routing. Directly impacts requisition volume, fill rate opportunity, and competitive positioning within the program.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeToFillDays rdf:type rdf:Property ;
    rdfs:label 'Time To Fill Days' ;
    rdfs:comment 'Target number of calendar days from requisition open date to placement confirmation as defined in the VMS program SLA. Key performance indicator (KPI) for program compliance and client satisfaction measurement.' ;
    rdfs:domain ind:VmsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timeToSubmitHours rdf:type rdf:Property ;
    rdfs:label 'Time To Submit Hours' ;
    rdfs:comment 'Maximum number of hours from requisition release to candidate submittal allowed under this VMS programs SLA. Drives internal sourcing urgency and recruiter workflow prioritization. Measured in business hours unless otherwise specified.' ;
    rdfs:domain ind:VmsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timesheetApprovalCycle rdf:type rdf:Property ;
    rdfs:label 'Timesheet Approval Cycle' ;
    rdfs:comment 'Frequency at which worker timesheets are submitted and approved within this VMS program. Drives Kronos Workforce Ready scheduling, payroll processing cycles in TempWorks, and billing cadence in Salesforce Revenue Cloud.' ;
    rdfs:domain ind:VmsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmsFeePct rdf:type rdf:Property ;
    rdfs:label 'Vms Fee Pct' ;
    rdfs:comment 'Percentage fee charged by the VMS platform or MSP to Staffing Hr on each placement or billing transaction within this program. Deducted from the spread and directly reduces gross margin. Expressed as a percentage of bill rate (e.g., 2.50 = 2.5%).' ;
    rdfs:domain ind:VmsProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engagementId rdf:type rdf:Property ;
    rdfs:label 'Engagement Id' ;
    rdfs:comment 'Unique surrogate primary key for each client engagement activity record in the Staffing Hr CRM system. Serves as the authoritative identifier for all touchpoints and interactions between Staffing Hr staff and client contacts. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedStaffName rdf:type rdf:Property ;
    rdfs:label 'Assigned Staff Name' ;
    rdfs:comment 'Full name of the internal Staffing Hr employee (recruiter or account manager) who conducted or owns this engagement. Denormalized for reporting convenience and historical accuracy in case of staff record changes.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedStaffRole rdf:type rdf:Property ;
    rdfs:label 'Assigned Staff Role' ;
    rdfs:comment 'Business role of the Staffing Hr staff member who conducted the engagement. Enables segmentation of engagement activity by function (e.g., recruiter-led vs. account manager-led touchpoints).' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attendeeCount rdf:type rdf:Property ;
    rdfs:label 'Attendee Count' ;
    rdfs:comment 'Total number of participants (both Staffing Hr staff and client contacts) who attended this engagement. Used for meeting complexity analysis and resource investment tracking.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bullhornActivityCode rdf:type rdf:Property ;
    rdfs:label 'Bullhorn Activity Code' ;
    rdfs:comment 'Source system identifier for this engagement activity as recorded in Bullhorn ATS/CRM. Used for data lineage, deduplication, and cross-system reconciliation between Bullhorn and Salesforce.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'The date and time the engagement activity concluded. Used in conjunction with engagement_timestamp to calculate actual duration. Nullable for instantaneous engagements such as emails.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:engagementStatus rdf:type rdf:Property ;
    rdfs:label 'Engagement Status' ;
    rdfs:comment 'Current lifecycle state of the engagement activity record. Indicates whether the engagement was successfully completed, cancelled, or requires follow-up action. Supports pipeline and cadence tracking.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Engagement Timestamp' ;
    rdfs:comment 'The actual date and time the engagement activity occurred or was initiated. This is the principal real-world business event timestamp, distinct from record audit timestamps. Stored in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:followUpRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required' ;
    rdfs:comment 'Flag indicating whether a follow-up action or engagement is required as a result of this interaction. Drives account management task queues and ensures no client touchpoint falls through the cracks.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExecutiveSponsorPresent rdf:type rdf:Property ;
    rdfs:label 'Is Executive Sponsor Present' ;
    rdfs:comment 'Flag indicating whether a Staffing Hr executive sponsor (e.g., VP, Director) participated in this engagement. Supports executive engagement tracking and strategic account management reporting.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isQbr rdf:type rdf:Property ;
    rdfs:label 'Is Qbr' ;
    rdfs:comment 'Flag indicating whether this engagement constitutes a formal Quarterly Business Review (QBR) with the client. Used to track QBR cadence compliance and account management quality metrics.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsVerbatim rdf:type rdf:Property ;
    rdfs:label 'Nps Verbatim' ;
    rdfs:comment 'Free-text verbatim feedback provided by the client contact during an NPS survey engagement. Null for non-NPS engagement types. Classified as confidential due to commercially sensitive client sentiment data.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineStage rdf:type rdf:Property ;
    rdfs:label 'Pipeline Stage' ;
    rdfs:comment 'CRM pipeline stage of the client account at the time of this engagement. Enables analysis of engagement activity by sales funnel stage and supports pipeline development reporting. [ENUM-REF-CANDIDATE: prospect|qualification|proposal|negotiation|closed_won|closed_lost|existing_client — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceActivityCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Activity Code' ;
    rdfs:comment 'Source system identifier for this engagement activity as recorded in Salesforce CRM. Used for data lineage and cross-system reconciliation between Salesforce and Bullhorn.' ;
    rdfs:domain ind:Engagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountSegmentId rdf:type rdf:Property ;
    rdfs:label 'Account Segment Id' ;
    rdfs:comment 'Unique surrogate identifier for the account segment record. Primary key for the account_segment data product in the client domain. Entity role: MASTER_RESOURCE — this product defines a commercial segmentation and classification record for a client account, carrying its own identity, lifecycle, and quantitative facts.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activePlacementCount rdf:type rdf:Property ;
    rdfs:label 'Active Placement Count' ;
    rdfs:comment 'Current number of active worker placements (temporary assignments and permanent placements) at this account segment as of the last data refresh. Key operational metric for workforce density and account health assessment. Sourced from Bullhorn ATS/CRM placement records.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activeReqCount rdf:type rdf:Property ;
    rdfs:label 'Active Req Count' ;
    rdfs:comment 'Current number of open job requisitions (Reqs) active for this account segment at the time of the last data refresh. Provides a real-time demand signal for recruiter capacity planning and segment health monitoring. Sourced from Bullhorn ATS/CRM job order data.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualRevenueBand rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Band' ;
    rdfs:comment 'Banded classification of the client companys estimated annual revenue, used for market sizing, credit risk assessment, and service tier alignment. Bands: under_1m, 1m_to_10m, 10m_to_50m, 50m_to_250m, over_250m (USD). Confidential business intelligence used in go-to-market prioritization.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directHireFeePct rdf:type rdf:Property ;
    rdfs:label 'Direct Hire Fee Pct' ;
    rdfs:comment 'Agreed placement fee percentage charged to the client for direct hire (permanent placement) engagements, expressed as a percentage of the placed candidates first-year base salary. Confidential commercial pricing term negotiated at the account segment level.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedAnnualStaffingSpend rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Staffing Spend' ;
    rdfs:comment 'Estimated total annual spend (in USD) the client account allocates to contingent and permanent staffing services across all providers. Used to calculate wallet share and prioritize account investment. This is the principal quantitative fact (MEASUREMENT_OR_VALUE) for this MASTER_RESOURCE entity. Sourced from Salesforce Revenue Cloud opportunity data and market intelligence.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fallOffRatePct rdf:type rdf:Property ;
    rdfs:label 'Fall Off Rate Pct' ;
    rdfs:comment 'Percentage of placements at this account segment that ended prematurely (fall-offs) within the trailing 12-month period, calculated as (fall-off placements / total placements) * 100. Fall-off rate is a key quality metric in staffing, indicating placement quality and candidate-client fit. Used to assess recruiter performance and account health.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossMarginTargetPct rdf:type rdf:Property ;
    rdfs:label 'Gross Margin Target Pct' ;
    rdfs:comment 'Target gross margin percentage for this account segment, representing the spread (bill rate minus pay rate and burden costs) as a percentage of the bill rate. Used to evaluate account profitability and guide pricing decisions. Confidential financial target data.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headcountBand rdf:type rdf:Property ;
    rdfs:label 'Headcount Band' ;
    rdfs:comment 'Banded classification of the client companys total employee headcount, used to estimate staffing demand potential and align service model complexity. Bands represent total FTE (Full-Time Equivalent) employees at the client organization.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mspProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Msp Program Flag' ;
    rdfs:comment 'Indicates whether this client account is managed through a Managed Service Provider (MSP) program, where a third-party MSP intermediary manages the contingent workforce program on behalf of the client. Affects supplier tier, rate card access, and billing routing.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onSiteProgramFlag rdf:type rdf:Property ;
    rdfs:label 'On Site Program Flag' ;
    rdfs:comment 'Indicates whether this client account has an on-site staffing program where a Staffing Hr on-site manager or coordinator is physically embedded at the client location to manage the contingent workforce. Drives on-site headcount budgeting and operational cost allocation.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredSupplierStatus rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Status' ;
    rdfs:comment 'Staffing Hrs supplier status designation within the clients vendor program. Preferred indicates highest-priority routing of requisitions. Tier_1 and Tier_2 reflect VMS/MSP program supplier tiers. Approved indicates active but non-preferred status. Not_listed indicates no formal supplier agreement in place.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryServiceLine rdf:type rdf:Property ;
    rdfs:label 'Primary Service Line' ;
    rdfs:comment 'The principal staffing service line through which this client account is primarily served. Temp Staffing (temporary placement), Direct Hire (permanent placement), RPO (Recruitment Process Outsourcing), MSP (Managed Service Provider program), Contract-to-Hire (temp-to-perm), SOW (Statement of Work-based project staffing). Drives billing model, recruiter assignment, and operational workflow.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorSegmentTier rdf:type rdf:Property ;
    rdfs:label 'Prior Segment Tier' ;
    rdfs:comment 'The segment tier assigned to this account immediately before the most recent reclassification event. Enables trend analysis of account movement across tiers (upgrades vs. downgrades). Null if this is the initial segment assignment.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reclassificationReason rdf:type rdf:Property ;
    rdfs:label 'Reclassification Reason' ;
    rdfs:comment 'Free-text or coded reason explaining why this account segment was reclassified from a prior tier or service model. Supports audit trail and trend analysis of segment movement (e.g., Revenue decline below key tier threshold, New MSP program win — upgraded to strategic). Populated only when a reclassification event occurs.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rpoProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Rpo Program Flag' ;
    rdfs:comment 'Indicates whether this client account has an active Recruitment Process Outsourcing (RPO) engagement with Staffing Hr, where Staffing Hr manages some or all of the clients permanent hiring process. Drives RPO-specific SLA tracking and dedicated recruiter team assignment.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this segment classification record, used in territory planning reports, go-to-market materials, and CRM tagging (e.g., SEG-STRAT-001). Serves as the BUSINESS_IDENTIFIER for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentNotes rdf:type rdf:Property ;
    rdfs:label 'Segment Notes' ;
    rdfs:comment 'Free-text field for account managers and strategic planners to capture qualitative context about this account segment, including competitive intelligence, relationship history, strategic initiatives, or special handling instructions not captured in structured fields.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentReviewDate rdf:type rdf:Property ;
    rdfs:label 'Segment Review Date' ;
    rdfs:comment 'Scheduled date for the next periodic review and potential reclassification of this account segment. Ensures segment tiers remain current with client revenue performance and strategic fit. Typically set on an annual or semi-annual cadence per territory planning policy.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle state of the account segment record. Active indicates the segmentation is in force and driving territory and resource decisions. Under_review indicates a pending reclassification. Inactive indicates the segment assignment has lapsed. Archived indicates historical record retained for audit. Serves as the LIFECYCLE_STATUS for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentTier rdf:type rdf:Property ;
    rdfs:label 'Segment Tier' ;
    rdfs:comment 'Strategic classification tier assigned to the client account, defining the level of investment, service intensity, and executive attention. Values: strategic (top-tier, highest revenue potential), key (established high-value), growth (emerging high-potential), transactional (volume-based, lower-touch). Serves as the primary CLASSIFICATION_OR_TYPE for this entity.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTtfDays rdf:type rdf:Property ;
    rdfs:label 'Target Ttf Days' ;
    rdfs:comment 'Target number of business days from job order receipt to candidate submittal, as defined for this account segments SLA tier. TTF (Time to Fill) is a core KPI in staffing operations. Used to set recruiter performance expectations and measure delivery quality against segment commitments.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetTtsDays rdf:type rdf:Property ;
    rdfs:label 'Target Tts Days' ;
    rdfs:comment 'Target number of calendar days from job order receipt to candidate start date, as defined for this account segments SLA tier. TTS (Time to Start) measures the full cycle from requisition to placement and is a key client satisfaction metric in staffing.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verticalIndustry rdf:type rdf:Property ;
    rdfs:label 'Vertical Industry' ;
    rdfs:comment 'Primary industry vertical the client account operates in, used to align staffing service delivery, recruiter specialization, and go-to-market strategy (e.g., Healthcare, Technology, Manufacturing, Financial Services, Logistics). Aligns with NAICS/SIC classification on the parent client_account record. [ENUM-REF-CANDIDATE: healthcare|technology|manufacturing|financial_services|logistics|retail|energy|government|education|professional_services — promote to reference product]' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmsProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Vms Program Flag' ;
    rdfs:comment 'Indicates whether this client account operates through a Vendor Management System (VMS) program, requiring Staffing Hr to submit candidates and timesheets through a third-party VMS platform (e.g., Beeline, SAP Fieldglass, Coupa). Drives operational workflow routing and VMS compliance requirements.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:walletSharePct rdf:type rdf:Property ;
    rdfs:label 'Wallet Share Pct' ;
    rdfs:comment 'Estimated percentage of the clients total annual staffing spend currently captured by Staffing Hr, expressed as a decimal percentage (e.g., 35.50 = 35.5%). Calculated as (Staffing Hr annual billings / estimated_annual_staffing_spend) * 100. Used to identify whitespace and cross-sell opportunities. Stored as a raw business estimate, not a computed KPI.' ;
    rdfs:domain ind:AccountSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programSupplierId rdf:type rdf:Property ;
    rdfs:label 'Program Supplier Id' ;
    rdfs:comment 'Unique surrogate identifier for the program supplier association record. Primary key for this entity in the Databricks Silver Layer. Entity role: JUNCTION (extended) — links a staffing supplier/vendor to a specific VMS program and carries its own participation terms, tier assignments, and performance metrics.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgramSupplier .

ind:authorizedJobCategories rdf:type rdf:Property ;
    rdfs:label 'Authorized Job Categories' ;
    rdfs:comment 'Comma-delimited list of job category codes or names that this supplier is authorized to fill within the program (e.g., IT, Finance, Engineering, Light Industrial). Restricts the suppliers submission eligibility to approved labor categories only.' ;
    rdfs:domain ind:ProgramSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avgTimeToFillDays rdf:type rdf:Property ;
    rdfs:label 'Avg Time To Fill Days' ;
    rdfs:comment 'Average number of calendar days from requisition release to candidate placement for this supplier within the program. A core SLA and KPI metric used to evaluate supplier responsiveness and efficiency. Sourced from Beeline VMS supplier scorecard.' ;
    rdfs:domain ind:ProgramSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beelineSupplierProgramCode rdf:type rdf:Property ;
    rdfs:label 'Beeline Supplier Program Code' ;
    rdfs:comment 'The externally-known unique identifier assigned by Beeline VMS to this supplier-program enrollment record. Used for cross-system reconciliation and integration with the source VMS platform.' ;
    rdfs:domain ind:ProgramSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversityCertificationType rdf:type rdf:Property ;
    rdfs:label 'Diversity Certification Type' ;
    rdfs:comment 'The specific type of diversity certification held by this supplier, if applicable. Used for OFCCP compliance reporting and corporate diversity spend analytics. [ENUM-REF-CANDIDATE: MBE|WBE|SDVOSB|HUBZone|LGBTBE|DVBE|none — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:ProgramSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment End Date' ;
    rdfs:comment 'The date on which the suppliers participation in the VMS program is scheduled to end or was terminated. Null for open-ended enrollments. Used for contract lifecycle management and program renewal tracking.' ;
    rdfs:domain ind:ProgramSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fallOffRatePercent rdf:type rdf:Property ;
    rdfs:label 'Fall Off Rate Percent' ;
    rdfs:comment 'Percentage of placements made by this supplier within the program that ended prematurely (before the scheduled assignment end date). High fall-off rates indicate poor candidate quality or fit. Used in tier review and supplier performance management.' ;
    rdfs:domain ind:ProgramSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fillRatePercent rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Percent' ;
    rdfs:comment 'Percentage of requisitions assigned to this supplier that were successfully filled within the program period. Calculated as filled requisitions divided by total requisitions routed to the supplier. Key KPI for supplier performance evaluation and tier assignment.' ;
    rdfs:domain ind:ProgramSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiration Date' ;
    rdfs:comment 'The expiration date of the suppliers most recently verified insurance certificate on file for this program. Used to trigger renewal alerts and compliance reviews before coverage lapses.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Performance Review Date' ;
    rdfs:comment 'The date of the most recent formal performance review conducted for this supplier within the program. Used to track review cadence and ensure timely tier reassessment based on performance metrics.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:markupCapPercent rdf:type rdf:Property ;
    rdfs:label 'Markup Cap Percent' ;
    rdfs:comment 'The maximum markup percentage this supplier is permitted to apply above the pay rate when billing within this program. Enforced by the VMS platform at submission time. Expressed as a percentage (e.g., 35.00 = 35%). Represents the Spread/Markup ceiling negotiated for this supplier within the program.' ;
    rdfs:domain ind:ProgramSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Performance Review Date' ;
    rdfs:comment 'The scheduled date for the next formal performance review of this supplier within the program. Supports proactive program management and ensures regular supplier evaluation cadence.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingComplete rdf:type rdf:Property ;
    rdfs:label 'Onboarding Complete' ;
    rdfs:comment 'Indicates whether the supplier has completed all required onboarding steps for this program, including document submission, compliance verification, system access provisioning, and training acknowledgments. Prerequisite for receiving live requisitions.' ;
    rdfs:domain ind:ProgramSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredWorkerType rdf:type rdf:Property ;
    rdfs:label 'Preferred Worker Type' ;
    rdfs:comment 'The worker classification type(s) this supplier primarily places within the program (W-2 employees, 1099 independent contractors, Corp-to-Corp, or Employer of Record). Relevant for IRS worker classification compliance and co-employment risk management.' ;
    rdfs:domain ind:ProgramSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programContactEmail rdf:type rdf:Property ;
    rdfs:label 'Program Contact Email' ;
    rdfs:comment 'Email address of the primary contact person at the supplier organization for this program. Used for requisition notifications, compliance alerts, and program communications via Beeline VMS.' ;
    rdfs:domain ind:ProgramSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programContactName rdf:type rdf:Property ;
    rdfs:label 'Program Contact Name' ;
    rdfs:comment 'Full name of the primary contact person at the supplier organization responsible for managing this program relationship. This is the supplier-side account manager or program coordinator for the VMS engagement.' ;
    rdfs:domain ind:ProgramSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionRoutingOrder rdf:type rdf:Property ;
    rdfs:label 'Requisition Routing Order' ;
    rdfs:comment 'Numeric sequence position determining the order in which this supplier receives requisition notifications within the program tier. Lower numbers receive requisitions first. Used to implement tiered routing logic (e.g., preferred suppliers receive reqs before approved suppliers).' ;
    rdfs:domain ind:ProgramSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseTimeSlaHours rdf:type rdf:Property ;
    rdfs:label 'Response Time Sla Hours' ;
    rdfs:comment 'The maximum number of hours within which this supplier is contractually required to respond to a new requisition notification within the program. Defines the SLA commitment for supplier responsiveness. Tracked against actual response times for SLA compliance reporting.' ;
    rdfs:domain ind:ProgramSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierStatus rdf:type rdf:Property ;
    rdfs:label 'Supplier Status' ;
    rdfs:comment 'Current participation status of the supplier within this specific VMS program. Active suppliers can receive and respond to requisitions; suspended suppliers are temporarily blocked; removed suppliers have been permanently disqualified from the program.' ;
    rdfs:domain ind:ProgramSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSubmittalsYtd rdf:type rdf:Property ;
    rdfs:label 'Total Submittals Ytd' ;
    rdfs:comment 'Total number of candidate submittals made by this supplier within the program in the current calendar year. Used to assess supplier engagement level and submission volume relative to program activity.' ;
    rdfs:domain ind:ProgramSupplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Sla Measurement Id' ;
    rdfs:comment 'Unique surrogate primary key for each SLA measurement record. Identifies a single periodic performance measurement instance against a defined SLA configuration. Entity role: TRANSACTION_HEADER — a discrete business event capturing actual vs. target SLA performance for a reporting window.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountHealthScore rdf:type rdf:Property ;
    rdfs:label 'Account Health Score' ;
    rdfs:comment 'A composite numeric score (0–100) representing the overall health of the client account based on this measurement periods SLA performance. Derived from weighted SLA compliance results and used for account risk segmentation and QBR preparation.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Amount' ;
    rdfs:comment 'The contractual bonus dollar amount earned by over-performance in this measurement period, as calculated per the bonus formula in the SLA configuration. Populated only when bonus_triggered is True. Used for billing adjustments and incentive tracking.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusTriggered rdf:type rdf:Property ;
    rdfs:label 'Bonus Triggered' ;
    rdfs:comment 'Boolean flag indicating whether the SLA over-performance in this measurement period has triggered a contractual bonus or incentive clause. True = bonus applies; False = no bonus. Drives positive billing adjustments in Salesforce Revenue Cloud.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceDirection rdf:type rdf:Property ;
    rdfs:label 'Compliance Direction' ;
    rdfs:comment 'Indicates whether a higher or lower measured value represents better performance for this metric type. higher_is_better applies to fill_rate, qos, retention_rate; lower_is_better applies to TTF and TTS (fewer days is better). Required to correctly interpret variance sign for compliance determination.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolvedDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolved Date' ;
    rdfs:comment 'The date on which a disputed SLA measurement was formally resolved between the staffing firm and the client. Populated only when a dispute has been closed. Used to track dispute resolution cycle times and SLA governance compliance.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:excludedReqCount rdf:type rdf:Property ;
    rdfs:label 'Excluded Req Count' ;
    rdfs:comment 'Number of requisitions excluded from the SLA measurement scope due to agreed exclusion criteria (e.g., client holds, force majeure, late job order submissions). Provides transparency into the effective denominator used in SLA calculations.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fallOffCount rdf:type rdf:Property ;
    rdfs:label 'Fall Off Count' ;
    rdfs:comment 'Number of placements that ended prematurely (fall-offs) during the measurement period before the expected assignment end date. High fall-off counts negatively impact retention rate SLA metrics and may trigger penalty clauses.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fillCount rdf:type rdf:Property ;
    rdfs:label 'Fill Count' ;
    rdfs:comment 'Number of requisitions that were successfully filled (placement confirmed) within the measurement period. Used as the numerator in fill rate calculations and as a direct performance indicator for talent acquisition effectiveness.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fillRateActual rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Actual' ;
    rdfs:comment 'The actual fill rate for the measurement period expressed as a percentage (0–100), calculated as fill_count divided by req_count multiplied by 100. Measures the staffing firms ability to fulfill client demand within the period.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Compliant' ;
    rdfs:comment 'Boolean flag indicating whether the measured performance met or exceeded the SLA target for this measurement period. True = SLA met (compliant); False = SLA missed (breach). Primary compliance indicator used in account health scoring and QBR reporting.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'The actual observed performance value for the SLA metric during the measurement period. Interpretation depends on sla_metric_type: for TTF/TTS this is average calendar days; for fill_rate/qos/retention_rate this is a percentage (0–100); for submittal_ratio this is a ratio. This is the QUANTITATIVE_RESULT for this transaction.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementNotes rdf:type rdf:Property ;
    rdfs:label 'Measurement Notes' ;
    rdfs:comment 'Free-text field for account managers or operations staff to document contextual notes about this measurement record, such as explanations for SLA misses, data quality caveats, client-agreed exclusions, or force majeure circumstances affecting performance.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementNumber rdf:type rdf:Property ;
    rdfs:label 'Measurement Number' ;
    rdfs:comment 'Externally-known business identifier for this measurement record, used in client-facing QBR (Quarterly Business Review) reports, penalty/bonus calculations, and audit trails. Format: SLA-MEAS-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Status' ;
    rdfs:comment 'Current lifecycle state of the SLA measurement record. draft indicates data is being collected; pending_review awaits account manager sign-off; finalized is locked for reporting; disputed is under client challenge; voided has been invalidated.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyTriggered rdf:type rdf:Property ;
    rdfs:label 'Penalty Triggered' ;
    rdfs:comment 'Boolean flag indicating whether the SLA breach in this measurement period has triggered a contractual penalty clause as defined in the MSA or SLA addendum. True = penalty applies; False = no penalty. Drives billing adjustments in Salesforce Revenue Cloud.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Categorizes the cadence of the measurement window. Determines how frequently SLA compliance is evaluated and reported to the client. Drives QBR preparation and penalty/bonus calculation cycles.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qbrPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Qbr Period Flag' ;
    rdfs:comment 'Boolean flag indicating whether this measurement record falls within a QBR reporting period and should be included in the formal Quarterly Business Review package presented to the client. True = include in QBR; False = standard operational measurement only.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qosActualRate rdf:type rdf:Property ;
    rdfs:label 'Qos Actual Rate' ;
    rdfs:comment 'The actual QoS rate for the measurement period, expressed as a percentage (0–100). Typically calculated as the ratio of client-accepted submittals to total submittals, or interview-to-submittal ratio. Measures the quality and relevance of candidate submittals.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reqCount rdf:type rdf:Property ;
    rdfs:label 'Req Count' ;
    rdfs:comment 'Total number of open requisitions (job orders) that fell within the measurement period scope and were included in the SLA calculation. Provides the denominator context for fill rate and submittal ratio calculations.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionRateActual rdf:type rdf:Property ;
    rdfs:label 'Retention Rate Actual' ;
    rdfs:comment 'The actual assignment retention rate for the measurement period expressed as a percentage (0–100). Measures the proportion of placed workers who remained on assignment through the expected end date, excluding early terminations and fall-offs.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaMetricType rdf:type rdf:Property ;
    rdfs:label 'Sla Metric Type' ;
    rdfs:comment 'The specific KPI (Key Performance Indicator) being measured in this record. TTF = Time to Fill; TTS = Time to Start; fill_rate = percentage of requisitions filled; QoS = Quality of Submission rate; submittal_ratio = submittals per req; retention_rate = assignment retention. [ENUM-REF-CANDIDATE: ttf|tts|fill_rate|qos|submittal_ratio|retention_rate|on_time_start|absence_rate — promote to reference product]' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ttfActualAvgDays rdf:type rdf:Property ;
    rdfs:label 'Ttf Actual Avg Days' ;
    rdfs:comment 'The actual average number of calendar days from requisition open date to confirmed placement (fill) across all in-scope requisitions during the measurement period. Core TTF KPI metric used in SLA compliance evaluation and client QBR reporting.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ttsActualAvgDays rdf:type rdf:Property ;
    rdfs:label 'Tts Actual Avg Days' ;
    rdfs:comment 'The actual average number of calendar days from requisition open date to the workers first day on assignment across all in-scope placements during the measurement period. TTS measures end-to-end speed including onboarding and credentialing.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePct rdf:type rdf:Property ;
    rdfs:label 'Variance Pct' ;
    rdfs:comment 'The variance expressed as a percentage of the target value ((measured_value - target_value) / target_value * 100). Enables normalized comparison of SLA performance across different metric types and clients regardless of unit scale.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceValue rdf:type rdf:Property ;
    rdfs:label 'Variance Value' ;
    rdfs:comment 'The arithmetic difference between measured_value and target_value (measured_value minus target_value). Positive variance indicates over-performance; negative variance indicates under-performance. Used to quantify the degree of SLA compliance or breach for penalty/bonus triggers.' ;
    rdfs:domain ind:SlaMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditProfileId rdf:type rdf:Property ;
    rdfs:label 'Credit Profile Id' ;
    rdfs:comment 'Unique identifier for the credit profile record. Primary key.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditProfile .

ind:priorCreditProfileId rdf:type rdf:Property ;
    rdfs:label 'Prior Credit Profile Id' ;
    rdfs:comment 'Self-referencing FK on credit_profile (prior_credit_profile_id)' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreditProfile .

ind:aging30DaysAmount rdf:type rdf:Property ;
    rdfs:label 'Aging 30 Days Amount' ;
    rdfs:comment 'Total outstanding receivables aged 31-60 days past invoice date. Indicates early payment delays.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aging60DaysAmount rdf:type rdf:Property ;
    rdfs:label 'Aging 60 Days Amount' ;
    rdfs:comment 'Total outstanding receivables aged 61-90 days past invoice date. Signals moderate collection risk.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aging90PlusDaysAmount rdf:type rdf:Property ;
    rdfs:label 'Aging 90 Plus Days Amount' ;
    rdfs:comment 'Total outstanding receivables aged 91+ days past invoice date. High collection risk; may require write-off or legal action.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingCurrentAmount rdf:type rdf:Property ;
    rdfs:label 'Aging Current Amount' ;
    rdfs:comment 'Total outstanding receivables in the current bucket (0-30 days past invoice date). Part of AR aging summary.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'Name or role of the individual or committee who approved the credit decision (e.g., Credit Manager, CFO, Credit Committee).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableCredit rdf:type rdf:Property ;
    rdfs:label 'Available Credit' ;
    rdfs:comment 'Remaining credit capacity calculated as credit_limit minus total_outstanding_balance. Negative values indicate over-limit condition.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankReference rdf:type rdf:Property ;
    rdfs:label 'Bank Reference' ;
    rdfs:comment 'Name and contact information of the clients primary banking institution, used for credit verification and reference checks.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankruptcyDate rdf:type rdf:Property ;
    rdfs:label 'Bankruptcy Date' ;
    rdfs:comment 'Date of the most recent bankruptcy filing, if applicable. Null if no bankruptcy on record.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankruptcyFlag rdf:type rdf:Property ;
    rdfs:label 'Bankruptcy Flag' ;
    rdfs:comment 'Indicates whether the client has an active or recent bankruptcy filing on record. True triggers automatic credit hold and legal review.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditDecision rdf:type rdf:Property ;
    rdfs:label 'Credit Decision' ;
    rdfs:comment 'Final credit decision outcome from the most recent review. Approved allows full credit; conditional requires additional controls; declined blocks business.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHoldDate rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Date' ;
    rdfs:comment 'Date when the credit hold was placed. Null if client is not on hold.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Flag' ;
    rdfs:comment 'Indicates whether the client is currently on credit hold. True blocks new placements, timesheet approvals, and invoice generation until resolved.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditHoldReason rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Reason' ;
    rdfs:comment 'Reason code explaining why the client is on credit hold. None if credit_hold_flag is false. [ENUM-REF-CANDIDATE: exceeded_limit|past_due_aging|bankruptcy|litigation|fraud_risk|manual_review|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditScoreInternal rdf:type rdf:Property ;
    rdfs:label 'Credit Score Internal' ;
    rdfs:comment 'Internally calculated composite credit score combining D&B data, payment history, DSO trends, and account behavior. Scale 0-1000.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditScorePaydex rdf:type rdf:Property ;
    rdfs:label 'Credit Score Paydex' ;
    rdfs:comment 'D&B PAYDEX score ranging from 1-100, measuring payment performance. Scores 80+ indicate prompt payment; scores below 50 indicate slow payment or default risk.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'Date when the credit decision was finalized and approved by the credit authority.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dnbCreditRating rdf:type rdf:Property ;
    rdfs:label 'Dnb Credit Rating' ;
    rdfs:comment 'D&B composite credit rating code (e.g., 5A1, 4A2) indicating financial strength and risk classification. Higher ratings indicate stronger credit.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dnbReportDate rdf:type rdf:Property ;
    rdfs:label 'Dnb Report Date' ;
    rdfs:comment 'Date when the most recent D&B credit report was pulled for this client. Used to determine report freshness and review cadence.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dsoActualDays rdf:type rdf:Property ;
    rdfs:label 'Dso Actual Days' ;
    rdfs:comment 'Actual Days Sales Outstanding for this client, calculated as average number of days to collect payment. Lower is better; values exceeding payment terms indicate collection risk.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Policy number for credit insurance or surety bond covering this client, if applicable. Null if insurance not required or not on file.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCreditReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Credit Review Date' ;
    rdfs:comment 'Date of the most recent credit review conducted by the credit committee or credit analyst.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:litigationFlag rdf:type rdf:Property ;
    rdfs:label 'Litigation Flag' ;
    rdfs:comment 'Indicates whether the client is currently involved in litigation with the company or has unresolved legal disputes affecting creditworthiness.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profileNumber rdf:type rdf:Property ;
    rdfs:label 'Profile Number' ;
    rdfs:comment 'Business identifier for the credit profile, used for external reference and reporting.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle status of the credit profile. Active profiles are used for credit decisions; suspended profiles block new business.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTier rdf:type rdf:Property ;
    rdfs:label 'Risk Tier' ;
    rdfs:comment 'Overall credit risk classification. Low = minimal risk, prompt payer; Medium = acceptable risk with monitoring; High = elevated risk requiring controls; Watch = critical risk, potential default.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOutstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Total Outstanding Balance' ;
    rdfs:comment 'Sum of all aging buckets; total amount currently owed by the client. Compared against credit_limit to determine available credit.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeReferences rdf:type rdf:Property ;
    rdfs:label 'Trade References' ;
    rdfs:comment 'Summary of trade references provided by the client, including vendor names and payment history feedback. Used for credit assessment.' ;
    rdfs:domain ind:CreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentManagedProgramId rdf:type rdf:Property ;
    rdfs:label 'Parent Managed Program Id' ;
    rdfs:comment 'Self-referencing FK on managed_program (parent_managed_program_id)' ;
    rdfs:domain ind:ManagedProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManagedProgram .

ind:annualSpendEstimate rdf:type rdf:Property ;
    rdfs:label 'Annual Spend Estimate' ;
    rdfs:comment 'Estimated annual staffing spend for this managed program in the program currency.' ;
    rdfs:domain ind:ManagedProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governanceModel rdf:type rdf:Property ;
    rdfs:label 'Governance Model' ;
    rdfs:comment 'Defines the decision-making and oversight structure for the managed program.' ;
    rdfs:domain ind:ManagedProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mspFeePct rdf:type rdf:Property ;
    rdfs:label 'Msp Fee Pct' ;
    rdfs:comment 'Management fee percentage charged by the MSP for program administration and oversight.' ;
    rdfs:domain ind:ManagedProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceReviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Performance Review Frequency' ;
    rdfs:comment 'Frequency of formal performance reviews and Quarterly Business Reviews (QBR) for this managed program.' ;
    rdfs:domain ind:ManagedProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programNumber rdf:type rdf:Property ;
    rdfs:label 'Program Number' ;
    rdfs:comment 'Externally-known unique business identifier for the managed program, used in client communications and contracts.' ;
    rdfs:domain ind:ManagedProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierTierCount rdf:type rdf:Property ;
    rdfs:label 'Supplier Tier Count' ;
    rdfs:comment 'Number of supplier tiers configured in the managed program for requisition routing and vendor management.' ;
    rdfs:domain ind:ManagedProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetFillRate rdf:type rdf:Property ;
    rdfs:label 'Target Fill Rate' ;
    rdfs:comment 'Target percentage of requisitions successfully filled under this managed program, as defined in the SLA.' ;
    rdfs:domain ind:ManagedProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetQosRate rdf:type rdf:Property ;
    rdfs:label 'Target Qos Rate' ;
    rdfs:comment 'Target percentage of submitted candidates that meet client quality standards, as defined in the SLA.' ;
    rdfs:domain ind:ManagedProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCardLineId rdf:type rdf:Property ;
    rdfs:label 'Rate Card Line Id' ;
    rdfs:comment 'Unique surrogate identifier for this rate card line item record' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateCardLine .

ind:overtimeThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Threshold Hours' ;
    rdfs:comment 'Number of hours per week (or per day, per overtime_threshold_period) after which overtime bill rates apply. Defaults to 40 hours per week per FLSA; may differ for daily OT jurisdictions (e.g., California 8-hour daily OT rule). [Moved from rate_card: Overtime threshold may vary by job category within a rate card (e.g., exempt vs. non-exempt roles) and belongs in the association.]' ;
    rdfs:domain ind:RateCardLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeThresholdPeriod rdf:type rdf:Property ;
    rdfs:label 'Overtime Threshold Period' ;
    rdfs:comment 'Period over which the overtime threshold hours are measured. daily applies in jurisdictions with daily OT rules (e.g., California); weekly applies under standard FLSA rules. [Moved from rate_card: Overtime threshold period may vary by job category within a rate card and belongs in the association.]' ;
    rdfs:domain ind:RateCardLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualSpend rdf:type rdf:Property ;
    rdfs:label 'Actual Spend' ;
    rdfs:comment 'Total monetary amount actually spent on this sourcing campaign to date in USD. Compared against budget_amount to compute budget utilization and variance for financial reporting.' ;
    rdfs:domain ind:SourcingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:atsCampaignRef rdf:type rdf:Property ;
    rdfs:label 'Ats Campaign Ref' ;
    rdfs:comment 'The native campaign identifier or reference number from the Bullhorn ATS/CRM system of record. Used for cross-system reconciliation and audit trail between the lakehouse and the operational ATS.' ;
    rdfs:domain ind:SourcingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billRateTarget rdf:type rdf:Property ;
    rdfs:label 'Bill Rate Target' ;
    rdfs:comment 'The target bill rate per hour to be charged to the client for placements resulting from this campaign. Used for gross margin and spread analysis (Bill Rate minus Pay Rate).' ;
    rdfs:domain ind:SourcingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'Total approved monetary budget allocated to this sourcing campaign in USD. Covers job board postings, advertising spend, referral bonuses, and agency fees. Used for cost-per-hire and ROI analysis.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the campaign across systems (e.g., SRC-2024-IT-CHI-001). Used for cross-system reconciliation and billing attribution.' ;
    rdfs:domain ind:SourcingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignDescription rdf:type rdf:Property ;
    rdfs:label 'Campaign Description' ;
    rdfs:comment 'Free-text narrative describing the campaign objectives, sourcing strategy, target candidate profile, and any special instructions for recruiters executing the campaign.' ;
    rdfs:domain ind:SourcingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'Human-readable name assigned to the sourcing campaign (e.g., Q3 2024 IT Contract Sourcing — Chicago). Used for identification in ATS dashboards and reporting.' ;
    rdfs:domain ind:SourcingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Classification of the sourcing campaign by channel or delivery model. Drives channel effectiveness analysis and cost-per-hire attribution. [ENUM-REF-CANDIDATE: job_board|social_media|referral|rpo|msp|direct_outreach|internal_database — promote to reference product]' ;
    rdfs:domain ind:SourcingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelMix rdf:type rdf:Property ;
    rdfs:label 'Channel Mix' ;
    rdfs:comment 'Comma-delimited list of sourcing channels activated in this campaign (e.g., LinkedIn, Indeed, ZipRecruiter, Internal ATS, Employee Referral). Supports channel effectiveness and cost-per-source analysis.' ;
    rdfs:domain ind:SourcingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceLevelRequired rdf:type rdf:Property ;
    rdfs:label 'Clearance Level Required' ;
    rdfs:comment 'The minimum government security clearance level required for candidates sourced through this campaign. Only applicable when is_security_clearance_required is true.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryModel rdf:type rdf:Property ;
    rdfs:label 'Delivery Model' ;
    rdfs:comment 'Indicates whether the campaign is executed under a standard staffing model, Recruitment Process Outsourcing (RPO), Managed Service Provider (MSP), or a hybrid arrangement. Affects billing, SLA, and reporting structures.' ;
    rdfs:domain ind:Recruitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversitySourcingFlag rdf:type rdf:Property ;
    rdfs:label 'Diversity Sourcing Flag' ;
    rdfs:comment 'Indicates whether this campaign includes targeted diversity sourcing initiatives (e.g., HBCU outreach, veteran hiring, disability inclusion). Supports EEOC and OFCCP compliance reporting.' ;
    rdfs:domain ind:SourcingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRemoteEligible rdf:type rdf:Property ;
    rdfs:label 'Is Remote Eligible' ;
    rdfs:comment 'Indicates whether the positions being sourced in this campaign are eligible for fully remote work arrangements. Expands the candidate pool beyond the defined geographic scope when true.' ;
    rdfs:domain ind:SourcingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSecurityClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Is Security Clearance Required' ;
    rdfs:comment 'Indicates whether candidates sourced through this campaign must hold an active government security clearance. Restricts the eligible candidate pool and triggers specialized credentialing workflows.' ;
    rdfs:domain ind:SourcingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryChannel rdf:type rdf:Property ;
    rdfs:label 'Primary Channel' ;
    rdfs:comment 'The single dominant sourcing channel expected to generate the highest candidate volume for this campaign. Used for channel ROI benchmarking and budget allocation decisions. [ENUM-REF-CANDIDATE: linkedin|indeed|ziprecruiter|internal_ats|referral|dice|monster|careerbuilder — promote to reference product]' ;
    rdfs:domain ind:SourcingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionCount rdf:type rdf:Property ;
    rdfs:label 'Requisition Count' ;
    rdfs:comment 'The number of open requisitions (reqs) this campaign is designed to address. A single campaign may target multiple related job orders, particularly in high-volume or RPO engagements.' ;
    rdfs:domain ind:SourcingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourcingCampaignStatus rdf:type rdf:Property ;
    rdfs:label 'Sourcing Campaign Status' ;
    rdfs:comment 'Current lifecycle state of the sourcing campaign. Drives operational workflows: draft (being configured), active (live sourcing), paused (temporarily halted), completed (target met or end date reached), cancelled (terminated before completion).' ;
    rdfs:domain ind:SourcingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCountryCode rdf:type rdf:Property ;
    rdfs:label 'Target Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the primary country where candidates are being sourced (e.g., USA, CAN, GBR). Drives compliance requirements including I-9, E-Verify, and GDPR applicability.' ;
    rdfs:domain ind:SourcingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetFillDate rdf:type rdf:Property ;
    rdfs:label 'Target Fill Date' ;
    rdfs:comment 'The business-committed date by which the associated job order(s) must be filled. Drives urgency scoring and SLA compliance tracking for TTF (Time to Fill) KPI measurement.' ;
    rdfs:domain ind:Recruitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetHeadcount rdf:type rdf:Property ;
    rdfs:label 'Target Headcount' ;
    rdfs:comment 'The number of positions (headcount) this sourcing campaign is designed to fill. Drives submittal volume targets and sourcing capacity planning.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetJobTitle rdf:type rdf:Property ;
    rdfs:label 'Target Job Title' ;
    rdfs:comment 'The primary job title or role designation being sourced in this campaign (e.g., Senior Java Developer, Registered Nurse). Used for job board posting titles and candidate matching.' ;
    rdfs:domain ind:SourcingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSkillSet rdf:type rdf:Property ;
    rdfs:label 'Target Skill Set' ;
    rdfs:comment 'Comma-delimited list or free-text description of the primary skills, certifications, or competencies this campaign is sourcing for (e.g., Java, AWS, Agile, PMP). Drives Boolean search strings and job board targeting.' ;
    rdfs:domain ind:SourcingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStateProvince rdf:type rdf:Property ;
    rdfs:label 'Target State Province' ;
    rdfs:comment 'Two-letter US state or Canadian province code for the primary sourcing geography (e.g., IL, NY, CA). Used for SUTA, workers comp, and state-specific labor law compliance.' ;
    rdfs:domain ind:SourcingCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSubmittalCount rdf:type rdf:Property ;
    rdfs:label 'Target Submittal Count' ;
    rdfs:comment 'The planned number of qualified candidate submittals this campaign aims to generate. Used to set QoS (Quality of Submission) benchmarks and recruiter productivity targets.' ;
    rdfs:domain ind:Recruitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jobPostingId rdf:type rdf:Property ;
    rdfs:label 'Job Posting Id' ;
    rdfs:comment 'Unique surrogate identifier for the job posting record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:Recruitment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobPosting .

ind:orderLocationId rdf:type rdf:Property ;
    rdfs:label 'Order Location Id' ;
    rdfs:comment 'Foreign key linking to joborder.order_location. Business justification: Job postings advertise work at a specific order work site (order_location). job_posting carries denormalized city/state_province/postal_code/country_code from order_location. Normalizing via FK enable' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderLocation .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'Anticipated end date of the temporary or contract assignment being advertised. Null for permanent direct placement roles. Used for workforce planning, redeployment scheduling, and bench management.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billRateMax rdf:type rdf:Property ;
    rdfs:label 'Bill Rate Max' ;
    rdfs:comment 'Maximum bill rate range for this posting, representing the upper bound of the rate charged to the client. Used for internal pricing analysis, Spread calculation, and Gross Margin forecasting. Not disclosed to candidates.' ;
    rdfs:domain ind:JobPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billRateMin rdf:type rdf:Property ;
    rdfs:label 'Bill Rate Min' ;
    rdfs:comment 'Minimum bill rate range for this posting, representing the lower bound of the rate charged to the client. Used for internal pricing analysis, Spread calculation, and Gross Margin forecasting. Not disclosed to candidates.' ;
    rdfs:domain ind:JobPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bullhornPostingRef rdf:type rdf:Property ;
    rdfs:label 'Bullhorn Posting Ref' ;
    rdfs:comment 'External reference identifier assigned by Bullhorn ATS/CRM to this job posting. Used for cross-system reconciliation and deep-link navigation into the source system.' ;
    rdfs:domain ind:JobPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:educationRequirement rdf:type rdf:Property ;
    rdfs:label 'Education Requirement' ;
    rdfs:comment 'Minimum educational attainment level required for the role. Used for candidate screening and EEOC-compliant job requirement documentation. [ENUM-REF-CANDIDATE: none|high_school|associate|bachelor|master|doctorate|professional_certification — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filledCount rdf:type rdf:Property ;
    rdfs:label 'Filled Count' ;
    rdfs:comment 'Number of openings that have been successfully filled with a placed candidate as of the current record state. Compared against openings_count to determine remaining unfilled positions.' ;
    rdfs:domain ind:JobPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:filledDate rdf:type rdf:Property ;
    rdfs:label 'Filled Date' ;
    rdfs:comment 'The calendar date on which the job posting was marked as filled following a successful candidate placement. Used to calculate Time-to-Fill (TTF) as the difference between posting_date and filled_date.' ;
    rdfs:domain ind:JobPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jobDescription rdf:type rdf:Property ;
    rdfs:label 'Job Description' ;
    rdfs:comment 'Full externally-published job description text including responsibilities, qualifications, and role overview. This is the candidate-facing content distributed across all posting channels.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minYearsExperience rdf:type rdf:Property ;
    rdfs:label 'Min Years Experience' ;
    rdfs:comment 'Minimum number of years of relevant professional experience required for the role. Used as a candidate screening threshold in the Applicant Tracking System (ATS).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openingsCount rdf:type rdf:Property ;
    rdfs:label 'Openings Count' ;
    rdfs:comment 'Total number of positions available under this job posting. A single posting may represent multiple headcount openings for the same role. Used for Headcount planning and fill-rate tracking.' ;
    rdfs:domain ind:JobPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postingChannel rdf:type rdf:Property ;
    rdfs:label 'Posting Channel' ;
    rdfs:comment 'The distribution channel through which this job posting is published. Supports multi-channel job distribution analytics and sourcing effectiveness measurement. Includes job boards (Indeed, LinkedIn), career site, Vendor Management System (VMS), social media, internal postings, referral programs, and email campaigns. [ENUM-REF-CANDIDATE: job_board|career_site|vms|social_media|internal|referral|email_campaign — promote to reference product]' ;
    rdfs:domain ind:JobPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The calendar date on which the job posting was first published and made visible to candidates. Used as the start anchor for Time-to-Fill (TTF) and Time-to-Start (TTS) KPI calculations.' ;
    rdfs:domain ind:JobPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current lifecycle state of the job posting. Controls visibility and candidate application eligibility. filled indicates a successful placement; paused indicates temporarily suspended distribution. [ENUM-REF-CANDIDATE: draft|active|paused|closed|filled|expired|cancelled — promote to reference product]' ;
    rdfs:domain ind:JobPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingTitle rdf:type rdf:Property ;
    rdfs:label 'Posting Title' ;
    rdfs:comment 'The externally-visible job title displayed on job boards, career sites, and VMS portals. May differ from the internal job order title to optimize for candidate search discoverability.' ;
    rdfs:domain ind:JobPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSkills rdf:type rdf:Property ;
    rdfs:label 'Preferred Skills' ;
    rdfs:comment 'Comma-delimited or free-text list of desired but non-mandatory skills, technologies, or competencies. Used to differentiate candidates during submittal ranking and Quality of Submission (QoS) evaluation.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredSkills rdf:type rdf:Property ;
    rdfs:label 'Required Skills' ;
    rdfs:comment 'Comma-delimited or free-text list of mandatory skills, technologies, certifications, or competencies required for the role. Used for candidate matching, ATS keyword search, and Quality of Submission (QoS) scoring.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftType rdf:type rdf:Property ;
    rdfs:label 'Shift Type' ;
    rdfs:comment 'The work shift schedule associated with the posted role. Used for candidate matching, scheduling, and Kronos Workforce Ready integration for shift-based workforce dispatch. [ENUM-REF-CANDIDATE: day|evening|night|rotating|weekend|flexible|on_call — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStartDate rdf:type rdf:Property ;
    rdfs:label 'Target Start Date' ;
    rdfs:comment 'The clients desired date for the placed candidate to begin the assignment or employment. Used to calculate Time-to-Start (TTS) KPI and to prioritize urgent requisitions in the sourcing queue.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Sla Commitment Id' ;
    rdfs:comment 'Foreign key linking to joborder.sla_commitment. Business justification: Submittals must be delivered within SLA commitment windows (submittal_sla_hours, submission_window_close_date). Direct FK enables real-time SLA compliance tracking per submittal, penalty breach calcul' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaCommitment .

ind:submittalOrderHeaderId rdf:type rdf:Property ;
    rdfs:label 'Submittal Order Header Id' ;
    rdfs:comment 'Reference to the job order (requisition) for which the candidate is being submitted. Links this submittal to the job order that originated the talent need.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderHeader .

ind:submittalReqOrderHeaderId rdf:type rdf:Property ;
    rdfs:label 'Submittal Req Order Header Id' ;
    rdfs:comment 'The client-assigned requisition number associated with the job order for this submittal. Used in VMS and client procurement systems to cross-reference the staffing firms job order with the clients internal requisition tracking.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderHeader .

ind:bullhornSubmittalCode rdf:type rdf:Property ;
    rdfs:label 'Bullhorn Submittal Code' ;
    rdfs:comment 'External identifier assigned by Bullhorn ATS/CRM to this submittal record. Used for cross-system reconciliation between the lakehouse silver layer and the operational ATS source system.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientFeedbackDate rdf:type rdf:Property ;
    rdfs:label 'Client Feedback Date' ;
    rdfs:comment 'The date on which the client provided formal feedback (shortlist, rejection, interview request) on this submittal. Used to measure client response time SLA compliance and pipeline velocity.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientFeedbackNotes rdf:type rdf:Property ;
    rdfs:label 'Client Feedback Notes' ;
    rdfs:comment 'Free-text notes capturing the clients qualitative feedback on the submitted candidate. May include reasons for rejection, interest level, or specific concerns. Used for recruiter coaching and future submittal quality improvement.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientViewedDate rdf:type rdf:Property ;
    rdfs:label 'Client Viewed Date' ;
    rdfs:comment 'The date on which the client contact first viewed or opened the candidate submittal. Tracked via VMS or ATS portal activity. Used to measure client responsiveness and calculate submittal-to-feedback cycle time.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:convertedToPlacement rdf:type rdf:Property ;
    rdfs:label 'Converted To Placement' ;
    rdfs:comment 'Indicates whether this submittal resulted in an active placement or assignment. True when the candidate was hired and a placement record was created. Key metric for submittal-to-hire conversion ratio reporting.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eeocDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Eeoc Disclosure Flag' ;
    rdfs:comment 'Indicates whether EEOC-required equal opportunity disclosures were provided to the candidate prior to submittal. Supports compliance with EEOC regulations and OFCCP requirements for federal contractor clients.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interviewRequestedDate rdf:type rdf:Property ;
    rdfs:label 'Interview Requested Date' ;
    rdfs:comment 'The date on which the client formally requested an interview with the submitted candidate. Marks the transition from submittal review to active interview stage in the recruitment pipeline.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interviewScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Interview Scheduled Date' ;
    rdfs:comment 'The date on which the interview between the client and the submitted candidate is scheduled to take place. Used for pipeline management, recruiter follow-up scheduling, and TTF milestone tracking.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isBackfill rdf:type rdf:Property ;
    rdfs:label 'Is Backfill' ;
    rdfs:comment 'Indicates whether this submittal is for a backfill position — replacing a worker who has left or been removed from an assignment. Backfill submittals are tracked separately for workforce planning and client relationship analytics.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRedeployment rdf:type rdf:Property ;
    rdfs:label 'Is Redeployment' ;
    rdfs:comment 'Indicates whether the submitted candidate is being redeployed from a previous or ending assignment within the same client or another client. Redeployment tracking is a key metric for bench utilization and workforce retention.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offerAcceptedDate rdf:type rdf:Property ;
    rdfs:label 'Offer Accepted Date' ;
    rdfs:comment 'The date on which the candidate formally accepted the offer for this submittal. Marks the conversion of a submittal to a placement. Used for submittal-to-hire ratio and TTS calculations.' ;
    rdfs:domain ind:Recruitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerExtendedDate rdf:type rdf:Property ;
    rdfs:label 'Offer Extended Date' ;
    rdfs:comment 'The date on which a formal employment or engagement offer was extended to the candidate following a successful interview. Used for offer-to-acceptance cycle time measurement and TTF milestone tracking.' ;
    rdfs:domain ind:Recruitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposedBillRate rdf:type rdf:Property ;
    rdfs:label 'Proposed Bill Rate' ;
    rdfs:comment 'The hourly or periodic bill rate proposed to the client at the time of submittal. Represents the rate charged to the client for the candidates services. Used in spread and gross margin calculations. Part of MONETARY_TRIPLET category per TRANSACTION_HEADER role.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedPayRate rdf:type rdf:Property ;
    rdfs:label 'Proposed Pay Rate' ;
    rdfs:comment 'The hourly or periodic pay rate proposed for the candidate at the time of submittal. Represents the compensation offered to the worker. Used in spread and gross margin calculations. Part of MONETARY_TRIPLET category per TRANSACTION_HEADER role.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qosNotes rdf:type rdf:Property ;
    rdfs:label 'Qos Notes' ;
    rdfs:comment 'Free-text notes accompanying the QoS rating, providing qualitative context on why the candidate was rated at that quality level. May include match strengths, gaps, or client-specific considerations.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qosRating rdf:type rdf:Property ;
    rdfs:label 'Qos Rating' ;
    rdfs:comment 'Numeric quality score assigned to this submittal reflecting how well the candidate profile matches the job order requirements. Scored on a defined scale (e.g., 1.0–5.0). Used as a KPI for recruiter performance, submittal quality benchmarking, and client satisfaction analysis.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Rate Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code applicable to the proposed pay rate and bill rate on this submittal (e.g., USD, CAD, GBP). Part of MONETARY_TRIPLET category per TRANSACTION_HEADER role.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason a submittal was rejected by the client or withdrawn by the candidate. Used for pipeline analytics, fall-off rate analysis, and process improvement. [ENUM-REF-CANDIDATE: overqualified|underqualified|rate_mismatch|availability|culture_fit|position_filled|no_response|candidate_withdrew — promote to reference product]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtrDate rdf:type rdf:Property ;
    rdfs:label 'Rtr Date' ;
    rdfs:comment 'The date on which the candidate granted Right to Represent (RTR) authorization to the staffing firm for this submittal. Used for compliance tracking and dispute resolution in cases of duplicate representation claims.' ;
    rdfs:domain ind:Recruitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rtrFlag rdf:type rdf:Property ;
    rdfs:label 'Rtr Flag' ;
    rdfs:comment 'Indicates whether the candidate has granted the staffing firm the Right to Represent (RTR) them for this specific job order and client. A True value confirms the candidate has authorized the submittal, preventing duplicate representation conflicts.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rtrMethod rdf:type rdf:Property ;
    rdfs:label 'Rtr Method' ;
    rdfs:comment 'The channel or method through which the candidate provided Right to Represent (RTR) consent (e.g., email, phone, text, verbal, self-service portal). Supports compliance documentation and audit trail for RTR disputes.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Sla Response Due Date' ;
    rdfs:comment 'The date by which the client is contractually required to respond to this submittal per the Master Service Agreement (MSA) or VMS program SLA. Used to flag overdue submittals and measure client SLA compliance.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submittalDate rdf:type rdf:Property ;
    rdfs:label 'Submittal Date' ;
    rdfs:comment 'The date and time the candidate profile was formally submitted to the client contact for the specified job order. Represents the principal real-world business event timestamp. Used as the start point for Time-to-Fill (TTF) and Time-to-Start (TTS) KPI calculations. BUSINESS_EVENT_TIMESTAMP category per TRANSACTION_HEADER role.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:submittalNumber rdf:type rdf:Property ;
    rdfs:label 'Submittal Number' ;
    rdfs:comment 'Human-readable, externally-visible business identifier for this submittal (e.g., SUB-2024-00123). Used in client communications, ATS references, and operational reporting. BUSINESS_IDENTIFIER category per TRANSACTION_HEADER role.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittalSource rdf:type rdf:Property ;
    rdfs:label 'Submittal Source' ;
    rdfs:comment 'The channel or method through which the candidate submittal was delivered to the client (e.g., ATS portal, VMS portal, email, phone, direct). Used for channel effectiveness analysis and process standardization.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittalStatus rdf:type rdf:Property ;
    rdfs:label 'Submittal Status' ;
    rdfs:comment 'Current workflow state of the candidate submittal in the recruitment pipeline. Tracks progression from initial submission through client review to hiring decision. LIFECYCLE_STATUS category per TRANSACTION_HEADER role. [ENUM-REF-CANDIDATE: submitted|viewed|shortlisted|interview_requested|rejected|offer_extended|hired|withdrawn — promote to reference product if additional states are needed]' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmsSubmittalCode rdf:type rdf:Property ;
    rdfs:label 'Vms Submittal Code' ;
    rdfs:comment 'External identifier assigned by the clients Vendor Management System (VMS), such as Beeline, to this submittal. Required for MSP/VMS-managed programs to reconcile submittal records between the staffing firms ATS and the clients VMS platform.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentMethod rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Method' ;
    rdfs:comment 'The channel or method by which the candidate acknowledged and granted the RTR. Supports audit and legal defensibility. Values: email = email reply confirmation; portal = candidate self-service portal; verbal = phone/in-person verbal consent (requires recruiter attestation); sms = text message confirmation; signed_document = formal signed RTR form.' ;
    rdfs:domain ind:RtrAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bullhornRtrCode rdf:type rdf:Property ;
    rdfs:label 'Bullhorn Rtr Code' ;
    rdfs:comment 'The native record identifier for this RTR agreement as stored in Bullhorn ATS/CRM. Used for system-of-record cross-referencing, data lineage, and reconciliation between the lakehouse silver layer and the operational ATS.' ;
    rdfs:domain ind:RtrAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:candidateConsentDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Candidate Consent Document Ref' ;
    rdfs:comment 'Reference identifier or URL to the stored consent document (e.g., signed RTR form, email thread ID, DocuSign envelope ID) that evidences the candidates acknowledgment. Supports FCRA and GDPR audit requirements.' ;
    rdfs:domain ind:RtrAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictAgencyName rdf:type rdf:Property ;
    rdfs:label 'Conflict Agency Name' ;
    rdfs:comment 'Name of the competing staffing agency that has also claimed representation rights for the same candidate-client pairing, triggering a co-representation conflict. Populated only when conflict_flag is True.' ;
    rdfs:domain ind:RtrAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Flag' ;
    rdfs:comment 'Indicates whether a co-representation conflict has been detected for this RTR agreement — i.e., another agency has also claimed the right to represent the same candidate to the same client or job order.' ;
    rdfs:domain ind:RtrAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Conflict Resolution Date' ;
    rdfs:comment 'The date on which the co-representation conflict was formally resolved. Populated only when conflict_resolution_status is not unresolved.' ;
    rdfs:domain ind:RtrAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conflictResolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Conflict Resolution Status' ;
    rdfs:comment 'Outcome of the co-representation conflict resolution process. unresolved = conflict is open; resolved_in_favor = this firms RTR was upheld; resolved_against = competing agencys RTR was upheld; withdrawn = one party withdrew the claim.' ;
    rdfs:domain ind:RtrAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionCount rdf:type rdf:Property ;
    rdfs:label 'Extension Count' ;
    rdfs:comment 'The number of times this RTR agreement has been extended beyond its original expiration date. Tracks repeated extensions that may indicate slow client decision-making or candidate availability issues.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grantDate rdf:type rdf:Property ;
    rdfs:label 'Grant Date' ;
    rdfs:comment 'The calendar date on which the RTR agreement was formally granted and the staffing firms right to represent the candidate to the specified client or job order became effective.' ;
    rdfs:domain ind:RtrAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Exclusive' ;
    rdfs:comment 'Indicates whether the RTR agreement grants exclusive representation rights to this staffing firm for the specified candidate-client pairing. True = exclusive (candidate cannot be submitted by another agency); False = non-exclusive.' ;
    rdfs:domain ind:RtrAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastExtensionDate rdf:type rdf:Property ;
    rdfs:label 'Last Extension Date' ;
    rdfs:comment 'The most recent date on which the RTR agreement expiration was extended. Null if no extensions have been granted.' ;
    rdfs:domain ind:RtrAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonCompeteCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Non Compete Check Required' ;
    rdfs:comment 'Indicates whether a non-compete agreement review is required for this candidate before representation can proceed. True = recruiter must verify no active non-compete conflicts exist with the target client.' ;
    rdfs:domain ind:RtrAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:representationScope rdf:type rdf:Property ;
    rdfs:label 'Representation Scope' ;
    rdfs:comment 'Defines the breadth of the representation right. job_order = limited to a single requisition; client = covers all open roles at the client account; client_division = covers all roles within a specific client division or business unit.' ;
    rdfs:domain ind:RtrAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'The exact date and time when the RTR request was initiated by the recruiter and sent to the candidate for acknowledgment. Serves as the principal business event timestamp for this agreement.' ;
    rdfs:domain ind:RtrAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'The calendar date on which the RTR agreement was formally revoked. Populated only when rtr_status is revoked.' ;
    rdfs:domain ind:RtrAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rtrDurationDays rdf:type rdf:Property ;
    rdfs:label 'Rtr Duration Days' ;
    rdfs:comment 'The agreed-upon duration of the RTR agreement in calendar days, measured from grant_date to expiration_date. Standard industry practice ranges from 30 to 90 days. Used for SLA monitoring and TTF (Time-to-Fill) analytics.' ;
    rdfs:domain ind:RtrAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reqPipelineId rdf:type rdf:Property ;
    rdfs:label 'Req Pipeline Id' ;
    rdfs:comment 'Foreign key linking to recruitment.req_pipeline. Business justification: An interview event is a stage within the req_pipeline progression. Linking interview to req_pipeline_id allows direct association between the interview event and the pipeline record tracking the candi' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReqPipeline .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'The actual date and time the interview commenced. Compared against scheduled_start_timestamp to measure punctuality and scheduling adherence. Null if the interview was cancelled or the candidate was a no-show.' ;
    rdfs:domain ind:Interview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:candidateConfirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Candidate Confirmation Status' ;
    rdfs:comment 'Tracks whether the candidate has confirmed attendance for the scheduled interview. Critical for no-show risk management, coordinator follow-up workflows, and fall-off rate analysis.' ;
    rdfs:domain ind:Interview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:candidateConfirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Candidate Confirmation Timestamp' ;
    rdfs:comment 'Date and time when the candidate confirmed their attendance for the interview. Used to measure confirmation lead time and coordinator responsiveness metrics.' ;
    rdfs:domain ind:Interview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clientConfirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Client Confirmation Status' ;
    rdfs:comment 'Tracks whether the client-side interviewer(s) have confirmed availability for the scheduled interview. Supports SLA measurement and client engagement analytics.' ;
    rdfs:domain ind:Interview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationRating rdf:type rdf:Property ;
    rdfs:label 'Communication Rating' ;
    rdfs:comment 'Numeric rating for the candidates communication skills as assessed during the interview, typically on a scale of 1.0 to 5.0. Key competency dimension for client satisfaction and placement quality analytics.' ;
    rdfs:domain ind:Recruitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cultureFitRating rdf:type rdf:Property ;
    rdfs:label 'Culture Fit Rating' ;
    rdfs:comment 'Numeric rating for the candidates perceived cultural alignment with the client organization, typically on a scale of 1.0 to 5.0. Supports placement quality and retention analytics.' ;
    rdfs:domain ind:Interview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedbackNotes rdf:type rdf:Property ;
    rdfs:label 'Feedback Notes' ;
    rdfs:comment 'Detailed qualitative feedback provided by the client interviewer(s) regarding the candidates performance, strengths, and areas of concern. Confidential business data used for recruiter coaching, candidate debriefs, and QoS improvement. Must be handled per GDPR/CCPA data minimization principles.' ;
    rdfs:domain ind:Recruitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackRequestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Feedback Requested Timestamp' ;
    rdfs:comment 'Date and time when the recruiter or coordinator formally requested interview feedback from the client. Combined with feedback_submitted_timestamp to calculate feedback turnaround time and client responsiveness metrics.' ;
    rdfs:domain ind:Interview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:feedbackSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Feedback Submitted Timestamp' ;
    rdfs:comment 'Date and time when the client interviewer submitted their formal feedback and ratings. Used to measure feedback turnaround time, a key component of client SLA measurement and QoS scoring.' ;
    rdfs:domain ind:Interview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:format rdf:type rdf:Property ;
    rdfs:label 'Format' ;
    rdfs:comment 'Delivery format of the interview distinguishing the physical or virtual modality. Distinct from interview_type (which captures structure/purpose). Supports logistics planning and client preference analytics.' ;
    rdfs:domain ind:Interview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireRecommendation rdf:type rdf:Property ;
    rdfs:label 'Hire Recommendation' ;
    rdfs:comment 'Client interviewers hiring recommendation for the candidate following the interview. Drives the decision outcome workflow and is a primary input to submittal-to-hire ratio and QoS analytics.' ;
    rdfs:domain ind:Recruitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewNumber rdf:type rdf:Property ;
    rdfs:label 'Interview Number' ;
    rdfs:comment 'Externally-known business identifier for the interview event, typically generated by the Applicant Tracking System (ATS) such as Bullhorn. Used in client communications, coordinator workflows, and cross-system reconciliation (e.g., INT-2024-00451).' ;
    rdfs:domain ind:Interview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewStatus rdf:type rdf:Property ;
    rdfs:label 'Interview Status' ;
    rdfs:comment 'Current lifecycle state of the interview event. Drives coordinator workflows, scheduling efficiency metrics, and fall-off rate calculations. no_show applies when the candidate or client fails to attend without prior notice.' ;
    rdfs:domain ind:Interview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewerNames rdf:type rdf:Property ;
    rdfs:label 'Interviewer Names' ;
    rdfs:comment 'Comma-separated full names of the client-side interviewers participating in this interview event. Captured as a denormalized string for operational reference and candidate briefing. Confidential as it identifies client personnel.' ;
    rdfs:domain ind:Interview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBlindInterview rdf:type rdf:Property ;
    rdfs:label 'Is Blind Interview' ;
    rdfs:comment 'Indicates whether this interview was conducted as a blind or anonymized interview (True) to reduce unconscious bias. Supports EEOC/OFCCP diversity and inclusion compliance reporting and DEI program analytics.' ;
    rdfs:domain ind:Interview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReschedule rdf:type rdf:Property ;
    rdfs:label 'Is Reschedule' ;
    rdfs:comment 'Indicates whether this interview record represents a rescheduled event (True) or an original scheduling (False). Enables reschedule rate analytics and scheduling efficiency KPI reporting.' ;
    rdfs:domain ind:Interview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Physical address or venue description for in-person interviews (e.g., client office address, building, floor, room number). Null for virtual interviews. Used for candidate confirmation communications and logistics coordination.' ;
    rdfs:domain ind:Interview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRating rdf:type rdf:Property ;
    rdfs:label 'Overall Rating' ;
    rdfs:comment 'Aggregate numeric rating assigned by the client interviewer(s) for the candidates overall interview performance, typically on a scale of 1.0 to 5.0. Central to QoS scoring, submittal-to-hire ratio analytics, and recruiter performance measurement.' ;
    rdfs:domain ind:Recruitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rescheduleCount rdf:type rdf:Property ;
    rdfs:label 'Reschedule Count' ;
    rdfs:comment 'Total number of times this interview has been rescheduled. Tracks scheduling friction and supports QoS scoring. High reschedule counts may indicate candidate or client engagement issues.' ;
    rdfs:domain ind:Interview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rescheduleReason rdf:type rdf:Property ;
    rdfs:label 'Reschedule Reason' ;
    rdfs:comment 'Reason code for the most recent reschedule of this interview. Used for root cause analysis of scheduling inefficiencies and SLA compliance reporting.' ;
    rdfs:domain ind:Interview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:round rdf:type rdf:Property ;
    rdfs:label 'Round' ;
    rdfs:comment 'Sequential round number for this interview within the overall hiring process for the submittal (e.g., 1 = first round, 2 = second round). Enables multi-stage interview funnel analytics and time-to-hire stage tracking.' ;
    rdfs:domain ind:Interview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Timestamp' ;
    rdfs:comment 'Planned end date and time of the interview. Combined with scheduled_start_timestamp to derive interview duration for scheduling analytics and client SLA reporting.' ;
    rdfs:domain ind:Interview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'The principal real-world event timestamp representing the planned start date and time of the interview. Used for calendar coordination, scheduling efficiency metrics, and Time-to-Fill (TTF) stage duration calculations. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Interview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceSystemInterviewCode rdf:type rdf:Property ;
    rdfs:label 'Source System Interview Code' ;
    rdfs:comment 'The native identifier of this interview record in the originating source system (e.g., Bullhorn interview ID). Enables cross-system reconciliation and idempotent data loading in the Databricks Silver layer.' ;
    rdfs:domain ind:Interview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSkillsRating rdf:type rdf:Property ;
    rdfs:label 'Technical Skills Rating' ;
    rdfs:comment 'Numeric rating for the candidates technical skills competency as assessed during the interview, typically on a scale of 1.0 to 5.0. Supports competency-based analytics and QoS scoring.' ;
    rdfs:domain ind:Recruitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:videoMeetingLink rdf:type rdf:Property ;
    rdfs:label 'Video Meeting Link' ;
    rdfs:comment 'URL or dial-in details for virtual interview platforms (e.g., Zoom, Microsoft Teams, Google Meet). Populated for video and hybrid format interviews. Sent to candidate and client as part of confirmation communications.' ;
    rdfs:domain ind:Interview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewFeedbackId rdf:type rdf:Property ;
    rdfs:label 'Interview Feedback Id' ;
    rdfs:comment 'Unique system-generated identifier for each interview feedback record. Primary key for the interview_feedback data product.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InterviewFeedback .

ind:availabilityConfirmed rdf:type rdf:Property ;
    rdfs:label 'Availability Confirmed' ;
    rdfs:comment 'Indicates whether the candidates start date availability was confirmed as acceptable during the interview. Directly impacts time-to-start (TTS) KPI and assignment scheduling.' ;
    rdfs:domain ind:InterviewFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:concernsNoted rdf:type rdf:Property ;
    rdfs:label 'Concerns Noted' ;
    rdfs:comment 'Interviewers free-text description of concerns or gaps identified during the interview. Supports recruiter coaching, sourcing refinement, and risk assessment for placement quality.' ;
    rdfs:domain ind:Recruitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedStartDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Start Date' ;
    rdfs:comment 'Candidates confirmed available start date as discussed and agreed during the interview. Used to compute time-to-start (TTS) and coordinate onboarding scheduling.' ;
    rdfs:domain ind:InterviewFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:culturalFitRating rdf:type rdf:Property ;
    rdfs:label 'Cultural Fit Rating' ;
    rdfs:comment 'Interviewers numeric rating of the candidates alignment with the client organizations culture and values. Supports retention prediction and placement quality analytics.' ;
    rdfs:domain ind:InterviewFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:experienceRelevanceRating rdf:type rdf:Property ;
    rdfs:label 'Experience Relevance Rating' ;
    rdfs:comment 'Interviewers numeric rating of how relevant the candidates prior work experience is to the specific job order requirements. Informs recruiter sourcing quality feedback loops.' ;
    rdfs:domain ind:InterviewFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedbackChannel rdf:type rdf:Property ;
    rdfs:label 'Feedback Channel' ;
    rdfs:comment 'Channel through which the client submitted the interview feedback (e.g., ATS portal, VMS portal, email, phone). Supports process improvement and digital adoption analytics.' ;
    rdfs:domain ind:InterviewFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackDueDate rdf:type rdf:Property ;
    rdfs:label 'Feedback Due Date' ;
    rdfs:comment 'Target date by which the client was expected to submit interview feedback per the agreed SLA. Enables SLA compliance tracking and client responsiveness KPI reporting.' ;
    rdfs:domain ind:InterviewFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feedbackReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Feedback Reference Number' ;
    rdfs:comment 'Externally visible alphanumeric identifier for this feedback record, used in client communications, ATS workflow references, and audit trails. Distinct from the internal surrogate key.' ;
    rdfs:domain ind:InterviewFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackStatus rdf:type rdf:Property ;
    rdfs:label 'Feedback Status' ;
    rdfs:comment 'Current lifecycle state of the feedback record: pending (awaiting client input), submitted (feedback received), overdue (past due date without submission), or cancelled (interview cancelled). Drives recruiter follow-up workflows.' ;
    rdfs:domain ind:InterviewFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Feedback Submission Date' ;
    rdfs:comment 'Calendar date on which the interviewer formally submitted the feedback record. Used to measure client responsiveness SLA (time from interview to feedback receipt) and track SLA compliance.' ;
    rdfs:domain ind:InterviewFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interviewDate rdf:type rdf:Property ;
    rdfs:label 'Interview Date' ;
    rdfs:comment 'Calendar date on which the interview was conducted. Used to compute time-to-fill (TTF), time-to-start (TTS), and interview-to-offer cycle time KPIs.' ;
    rdfs:domain ind:InterviewFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interviewDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Interview Duration Minutes' ;
    rdfs:comment 'Total duration of the interview in minutes as reported or recorded. Provides context for feedback depth and supports interviewer efficiency analytics.' ;
    rdfs:domain ind:InterviewFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interviewRound rdf:type rdf:Property ;
    rdfs:label 'Interview Round' ;
    rdfs:comment 'Sequential round number of the interview within the hiring process for this job order (e.g., 1 = first round, 2 = second round). Enables stage-level funnel analysis and time-to-fill tracking.' ;
    rdfs:domain ind:InterviewFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interviewStartTime rdf:type rdf:Property ;
    rdfs:label 'Interview Start Time' ;
    rdfs:comment 'Precise date and time when the interview began. Supports scheduling analytics, interviewer availability tracking, and SLA measurement for client responsiveness.' ;
    rdfs:domain ind:InterviewFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interviewerName rdf:type rdf:Property ;
    rdfs:label 'Interviewer Name' ;
    rdfs:comment 'Full name of the client-side interviewer who conducted the interview and submitted this feedback. Used for interviewer-level QoS analytics and client relationship management. Classified as confidential business data.' ;
    rdfs:domain ind:InterviewFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interviewerTitle rdf:type rdf:Property ;
    rdfs:label 'Interviewer Title' ;
    rdfs:comment 'Job title or role of the client-side interviewer. Provides context for the seniority level of the evaluation and supports analysis of hiring decision authority.' ;
    rdfs:domain ind:InterviewFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isStructuredInterview rdf:type rdf:Property ;
    rdfs:label 'Is Structured Interview' ;
    rdfs:comment 'Indicates whether the interview followed a standardized, structured format with predefined competency-based questions. Supports EEOC compliance documentation and interview quality analytics.' ;
    rdfs:domain ind:InterviewFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextStepRecommendation rdf:type rdf:Property ;
    rdfs:label 'Next Step Recommendation' ;
    rdfs:comment 'Interviewers recommended next action for the candidate (e.g., schedule second round, extend offer, consider for future role). Guides recruiter workflow and accelerates time-to-fill.' ;
    rdfs:domain ind:InterviewFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:professionalismRating rdf:type rdf:Property ;
    rdfs:label 'Professionalism Rating' ;
    rdfs:comment 'Interviewers numeric rating of the candidates professional demeanor, presentation, and conduct during the interview. Contributes to overall QoS scoring.' ;
    rdfs:domain ind:InterviewFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qosContributionScore rdf:type rdf:Property ;
    rdfs:label 'Qos Contribution Score' ;
    rdfs:comment 'Numeric score derived from this feedback records ratings that contributes to the recruiters overall Quality of Submission (QoS) metric. Calculated at the feedback level before aggregation into the recruiter-level QoS KPI. Distinct from the aggregated KPI — this is the raw per-feedback input value.' ;
    rdfs:domain ind:InterviewFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Description' ;
    rdfs:comment 'Free-text elaboration of the rejection reason, providing additional context beyond the standardized rejection_reason_code. Supports recruiter coaching and sourcing quality improvement.' ;
    rdfs:domain ind:InterviewFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryExpectationFit rdf:type rdf:Property ;
    rdfs:label 'Salary Expectation Fit' ;
    rdfs:comment 'Interviewers assessment of whether the candidates salary expectations align with the budgeted bill rate and pay rate range for the position. Informs offer management and rejection reason analysis.' ;
    rdfs:domain ind:InterviewFeedback ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strengthsNoted rdf:type rdf:Property ;
    rdfs:label 'Strengths Noted' ;
    rdfs:comment 'Interviewers free-text description of the candidates key strengths observed during the interview. Used in recruiter feedback loops and candidate profile enrichment.' ;
    rdfs:domain ind:Recruitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atsDecisionRef rdf:type rdf:Property ;
    rdfs:label 'Ats Decision Ref' ;
    rdfs:comment 'The native record identifier for this hiring decision in the source Applicant Tracking System (ATS), typically Bullhorn. Used for cross-system data lineage and reconciliation.' ;
    rdfs:domain ind:HiringDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionNotes rdf:type rdf:Property ;
    rdfs:label 'Decision Notes' ;
    rdfs:comment 'Free-text notes recorded by the recruiter or account manager regarding the hiring decision. Captures context, client feedback, and any special circumstances not covered by structured fields.' ;
    rdfs:domain ind:HiringDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionNumber rdf:type rdf:Property ;
    rdfs:label 'Decision Number' ;
    rdfs:comment 'Externally-known business identifier for this hiring decision record, used for cross-system reference and audit trail. Typically sourced from Bullhorn ATS or VMS system.' ;
    rdfs:domain ind:HiringDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionStatus rdf:type rdf:Property ;
    rdfs:label 'Decision Status' ;
    rdfs:comment 'Current lifecycle status of the hiring decision. pending indicates awaiting client response; hired confirms placement initiation; rejected closes the submittal negatively; on_hold suspends evaluation; withdrawn indicates candidate or client retraction; backfill flags a replacement hire scenario.' ;
    rdfs:domain ind:HiringDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'Precise date and time when the hiring decision was recorded in the system. Used for audit trail, SLA measurement, and time-series analytics. Distinct from decision_date which captures the business event date.' ;
    rdfs:domain ind:HiringDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:decisionType rdf:type rdf:Property ;
    rdfs:label 'Decision Type' ;
    rdfs:comment 'Categorical classification of the hiring decision outcome. hired triggers placement initiation; rejected records a negative outcome; on_hold defers the decision; backfill indicates a replacement for a vacated position; no_decision records client non-response.' ;
    rdfs:domain ind:HiringDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eeocCategory rdf:type rdf:Property ;
    rdfs:label 'Eeoc Category' ;
    rdfs:comment 'EEOC-defined job category classification for this hiring decision, used for EEO-1 reporting and OFCCP compliance. Restricted as it may be linked to individual candidate records. [ENUM-REF-CANDIDATE: executive_senior_officials|first_mid_level_officials|professionals|technicians|sales_workers|administrative_support|craft_workers|operatives|laborers|service_workers — promote to reference product]' ;
    rdfs:domain ind:HiringDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallOffRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Fall Off Risk Flag' ;
    rdfs:comment 'Indicates whether this hiring decision has been flagged as at risk of a fall-off (placement that does not start or ends prematurely). Used for proactive placement management and fall-off rate KPI tracking.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interviewRoundCount rdf:type rdf:Property ;
    rdfs:label 'Interview Round Count' ;
    rdfs:comment 'Total number of interview rounds conducted with the candidate prior to the hiring decision. Used for process efficiency analytics and QoS (Quality of Submission) measurement.' ;
    rdfs:domain ind:HiringDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isTempToPerm rdf:type rdf:Property ;
    rdfs:label 'Is Temp To Perm' ;
    rdfs:comment 'Indicates whether this hire resulted from a temp-to-perm (contract-to-hire) conversion, where a temporary worker transitions to a permanent employee of the client. Drives conversion fee billing and fall-off rate tracking.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offerAccepted rdf:type rdf:Property ;
    rdfs:label 'Offer Accepted' ;
    rdfs:comment 'Indicates whether the candidate accepted the job offer. Used to calculate offer acceptance rate, a key recruitment KPI, and to distinguish hired decisions from declined offers.' ;
    rdfs:domain ind:HiringDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offerDate rdf:type rdf:Property ;
    rdfs:label 'Offer Date' ;
    rdfs:comment 'Date on which the formal job offer was extended to the candidate. Used for offer-to-acceptance cycle time analytics and recruitment funnel reporting.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerDeclinedReason rdf:type rdf:Property ;
    rdfs:label 'Offer Declined Reason' ;
    rdfs:comment 'Reason provided when a candidate declines a job offer. Used for competitive intelligence, compensation benchmarking, and recruiter coaching. Populated only when offer_accepted is False.' ;
    rdfs:domain ind:HiringDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerExtended rdf:type rdf:Property ;
    rdfs:label 'Offer Extended' ;
    rdfs:comment 'Indicates whether a formal job offer was extended to the candidate as part of this hiring decision. Distinguishes between decisions where an offer was made versus decisions made prior to offer stage.' ;
    rdfs:domain ind:HiringDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proposedStartDate rdf:type rdf:Property ;
    rdfs:label 'Proposed Start Date' ;
    rdfs:comment 'The candidates proposed or agreed-upon start date at the time of the hiring decision. Used for TTS calculation, workforce scheduling, and onboarding initiation.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateCurrency rdf:type rdf:Property ;
    rdfs:label 'Rate Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the bill rate and pay rate. Supports multi-currency operations for international staffing engagements.' ;
    rdfs:domain ind:HiringDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonCategory rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Category' ;
    rdfs:comment 'High-level categorical classification of the reason a candidate was rejected by the client. Used for QoS (Quality of Submission) analytics, recruiter performance measurement, and sourcing strategy improvement. [ENUM-REF-CANDIDATE: skills_mismatch|compensation|culture_fit|overqualified|availability|client_cancelled|background_check|communication|experience_gap|position_filled_internally — promote to reference product if more than 6 values needed]' ;
    rdfs:domain ind:HiringDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonDetail rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Detail' ;
    rdfs:comment 'Free-text narrative providing specific detail about why the candidate was rejected by the client. Complements rejection_reason_category with granular context for recruiter coaching and QoS improvement.' ;
    rdfs:domain ind:HiringDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittalToDecisionDays rdf:type rdf:Property ;
    rdfs:label 'Submittal To Decision Days' ;
    rdfs:comment 'Number of calendar days elapsed from the candidate submittal date to the hiring decision date. Measures client responsiveness and interview cycle efficiency. Used in SLA measurement and client engagement analytics.' ;
    rdfs:domain ind:HiringDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ttfDays rdf:type rdf:Property ;
    rdfs:label 'Ttf Days' ;
    rdfs:comment 'Calculated number of calendar days from job order open date to the date a hire decision was made. Core recruitment KPI measuring speed of talent acquisition. Stored as a calculated value at decision time for historical reporting and SLA compliance.' ;
    rdfs:domain ind:HiringDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ttsDays rdf:type rdf:Property ;
    rdfs:label 'Tts Days' ;
    rdfs:comment 'Calculated number of calendar days from the hire decision date to the candidates confirmed start date on assignment. Measures onboarding and placement initiation speed. Stored at decision time for KPI reporting.' ;
    rdfs:domain ind:HiringDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atsSubmissionCode rdf:type rdf:Property ;
    rdfs:label 'Ats Submission Code' ;
    rdfs:comment 'Native submission or candidate-job record identifier from the Bullhorn ATS/CRM system. Used for data lineage, system reconciliation, and cross-referencing pipeline records with the source system.' ;
    rdfs:domain ind:ReqPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientFeedback rdf:type rdf:Property ;
    rdfs:label 'Client Feedback' ;
    rdfs:comment 'Structured or free-text feedback provided by the client or hiring manager following a submittal or interview. Used for QoS improvement, recruiter coaching, and submittal-to-hire ratio analysis.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedStartDate rdf:type rdf:Property ;
    rdfs:label 'Expected Start Date' ;
    rdfs:comment 'Anticipated start date for the candidate if hired, as agreed between the client and the staffing firm. Used for time-to-start (TTS) forecasting and workforce scheduling.' ;
    rdfs:domain ind:ReqPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interviewCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Interview Completed Timestamp' ;
    rdfs:comment 'Date and time the interview was completed. Distinct from the scheduled timestamp; used to measure interview-to-decision cycle time and pipeline velocity.' ;
    rdfs:domain ind:ReqPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interviewScheduledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Interview Scheduled Timestamp' ;
    rdfs:comment 'Date and time the interview was scheduled with the client or hiring manager. Used for interview scheduling management and pipeline stage duration calculations.' ;
    rdfs:domain ind:ReqPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isAgingAlert rdf:type rdf:Property ;
    rdfs:label 'Is Aging Alert' ;
    rdfs:comment 'Indicates whether this pipeline record has exceeded the expected stage duration threshold and triggered an aging alert. Used by recruiters and hiring managers to prioritize action on stalled candidates.' ;
    rdfs:domain ind:ReqPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBottleneckFlag rdf:type rdf:Property ;
    rdfs:label 'Is Bottleneck Flag' ;
    rdfs:comment 'Indicates whether this pipeline record has been flagged as a bottleneck based on stage conversion rate analysis. Used for pipeline health monitoring and TTF forecasting in RPO and MSP delivery models.' ;
    rdfs:domain ind:ReqPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPriority rdf:type rdf:Property ;
    rdfs:label 'Is Priority' ;
    rdfs:comment 'Indicates whether this pipeline record has been marked as a priority by the recruiter or account manager, typically for urgent requisitions or high-value client accounts. Drives recruiter workload prioritization.' ;
    rdfs:domain ind:ReqPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offerBillRate rdf:type rdf:Property ;
    rdfs:label 'Offer Bill Rate' ;
    rdfs:comment 'Bill rate (per hour or per annum) associated with the offer for this pipeline record. Used to calculate spread (bill rate minus pay rate) and gross margin at the pipeline stage.' ;
    rdfs:domain ind:ReqPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offerPayRate rdf:type rdf:Property ;
    rdfs:label 'Offer Pay Rate' ;
    rdfs:comment 'Pay rate (per hour or per annum) offered to the candidate at the offer stage. Used for offer competitiveness analysis and spread/markup calculations. Confidential business data.' ;
    rdfs:domain ind:ReqPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipelineNotes rdf:type rdf:Property ;
    rdfs:label 'Pipeline Notes' ;
    rdfs:comment 'Free-text notes entered by the recruiter or account manager regarding the candidates progression, client feedback, or special circumstances for this pipeline record. Supports recruiter workload management and hiring manager communication.' ;
    rdfs:domain ind:ReqPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Pipeline Record Number' ;
    rdfs:comment 'Externally-known business identifier for this pipeline record, typically sourced from Bullhorn ATS (e.g., SUB-2024-00123). Used in VMS scorecards, recruiter dashboards, and RPO/MSP reporting to uniquely reference a candidate-to-requisition progression record.' ;
    rdfs:domain ind:ReqPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineStatus rdf:type rdf:Property ;
    rdfs:label 'Pipeline Status' ;
    rdfs:comment 'Lifecycle status of this pipeline record indicating whether the candidates progression is actively being managed, placed on hold, closed due to hire or rejection, or archived for historical reference.' ;
    rdfs:domain ind:ReqPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousStage rdf:type rdf:Property ;
    rdfs:label 'Previous Stage' ;
    rdfs:comment 'The pipeline stage immediately preceding the current stage for this record. Enables stage transition analysis and supports pipeline velocity reporting without requiring a full history table join. [ENUM-REF-CANDIDATE: sourced|screened|submitted|interviewing|offered|hired|rejected|withdrawn — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReqPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionStage rdf:type rdf:Property ;
    rdfs:label 'Rejection Stage' ;
    rdfs:comment 'Pipeline stage at which the candidate was rejected or withdrew. Enables stage-level fall-off rate analysis and identification of pipeline bottlenecks. Null if candidate has not been rejected or withdrawn. [ENUM-REF-CANDIDATE: sourced|screened|submitted|interviewing|offered|hired|rejected|withdrawn — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReqPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtrConfirmedDate rdf:type rdf:Property ;
    rdfs:label 'Rtr Confirmed Date' ;
    rdfs:comment 'Date the Right to Represent (RTR) authorization was confirmed by the candidate. Used for compliance auditing and to ensure submittals are made only with valid RTR.' ;
    rdfs:domain ind:ReqPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourcedDate rdf:type rdf:Property ;
    rdfs:label 'Sourced Date' ;
    rdfs:comment 'Date the candidate was first identified and added to the pipeline for this requisition. Marks the start of the recruitment lifecycle for TTF and TTS (Time to Start) calculations.' ;
    rdfs:domain ind:ReqPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stageDurationBusinessDays rdf:type rdf:Property ;
    rdfs:label 'Stage Duration Business Days' ;
    rdfs:comment 'Number of business days the candidate has spent or spent in the current pipeline stage. Calculated at each stage transition event refresh. Used for bottleneck identification and SLA compliance monitoring.' ;
    rdfs:domain ind:ReqPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stageEntryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Stage Entry Timestamp' ;
    rdfs:comment 'Date and time when the candidate entered the current pipeline stage. Used to calculate stage duration in business days and identify aging alerts for time-to-fill (TTF) forecasting.' ;
    rdfs:domain ind:ReqPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stageExitTimestamp rdf:type rdf:Property ;
    rdfs:label 'Stage Exit Timestamp' ;
    rdfs:comment 'Date and time when the candidate exited the current pipeline stage and transitioned to the next stage or a terminal state. Null if the candidate is still in the current stage.' ;
    rdfs:domain ind:ReqPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stageTransitionCount rdf:type rdf:Property ;
    rdfs:label 'Stage Transition Count' ;
    rdfs:comment 'Total number of stage transitions this pipeline record has undergone since creation. Used to identify candidates who have been recycled through stages or experienced unusual pipeline paths.' ;
    rdfs:domain ind:ReqPipeline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorScreeningCandidateScreeningId rdf:type rdf:Property ;
    rdfs:label 'Prior Screening Candidate Screening Id' ;
    rdfs:comment 'Reference to the previous screening record if this is a re-screen (is_rescreening = True). Enables longitudinal tracking of candidate screening history and improvement over time.' ;
    rdfs:domain ind:CandidateScreening ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CandidateScreening .

ind:referralId rdf:type rdf:Property ;
    rdfs:label 'Referral Id' ;
    rdfs:comment 'Foreign key linking to recruitment.referral. Business justification: When a candidate is referred via the referral program, their screening record should link back to the originating referral. This enables referral program effectiveness tracking — what percentage of re' ;
    rdfs:domain ind:Recruitment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Referral .

ind:advancedToSubmittal rdf:type rdf:Property ;
    rdfs:label 'Advanced To Submittal' ;
    rdfs:comment 'Indicates whether the candidate was advanced to the submittal stage following this screening. Key metric for submittal-to-hire ratio and QoS (Quality of Submission) reporting. True = candidate was submitted to the client.' ;
    rdfs:domain ind:CandidateScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disqualificationCategory rdf:type rdf:Property ;
    rdfs:label 'Disqualification Category' ;
    rdfs:comment 'High-level category classifying the reason for candidate disqualification. Supports EEOC/OFCCP adverse action reporting and pipeline analytics to identify systemic screening bottlenecks.' ;
    rdfs:domain ind:CandidateScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disqualificationReason rdf:type rdf:Property ;
    rdfs:label 'Disqualification Reason' ;
    rdfs:comment 'Structured reason code or description explaining why a candidate did not pass the screening (e.g., insufficient experience, salary mismatch, availability conflict, skills gap). Required for EEOC adverse action documentation and fall-off rate analysis.' ;
    rdfs:domain ind:CandidateScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eeocCompliant rdf:type rdf:Property ;
    rdfs:label 'Eeoc Compliant' ;
    rdfs:comment 'Indicates whether the screening was conducted in accordance with EEOC (Equal Employment Opportunity Commission) guidelines, including use of job-related, non-discriminatory questions and standardized evaluation criteria.' ;
    rdfs:domain ind:CandidateScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRescreening rdf:type rdf:Property ;
    rdfs:label 'Is Rescreening' ;
    rdfs:comment 'Indicates whether this screening is a re-screen of a candidate who was previously screened for the same or a different position. Supports fall-off rate analysis and redeployment tracking for bench candidates.' ;
    rdfs:domain ind:CandidateScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payRateExpectation rdf:type rdf:Property ;
    rdfs:label 'Pay Rate Expectation' ;
    rdfs:comment 'The candidates stated pay rate or salary expectation captured during the screening, expressed as an hourly or annual figure per the pay_rate_expectation_type. Critical for assessing fit against the job orders bill rate and spread targets.' ;
    rdfs:domain ind:CandidateScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payRateExpectationType rdf:type rdf:Property ;
    rdfs:label 'Pay Rate Expectation Type' ;
    rdfs:comment 'Indicates whether the candidates pay rate expectation is expressed as an hourly, annual, daily, or weekly rate. Required to correctly interpret and compare pay_rate_expectation against job order rate cards.' ;
    rdfs:domain ind:CandidateScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relocationWillingness rdf:type rdf:Property ;
    rdfs:label 'Relocation Willingness' ;
    rdfs:comment 'Indicates whether the candidate expressed willingness to relocate for the position during the screening. Relevant for permanent placement and direct hire roles where geography is a key fit criterion.' ;
    rdfs:domain ind:CandidateScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rtrObtained rdf:type rdf:Property ;
    rdfs:label 'Rtr Obtained' ;
    rdfs:comment 'Indicates whether the recruiter obtained the candidates Right to Represent (RTR) consent during or following this screening. RTR is a critical compliance step in staffing to prevent double-submission conflicts and protect the agencys exclusive right to submit the candidate to a specific client.' ;
    rdfs:domain ind:CandidateScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:screenerName rdf:type rdf:Property ;
    rdfs:label 'Screener Name' ;
    rdfs:comment 'Full name of the recruiter, hiring manager, or interviewer who conducted the screening. Used for accountability, workload reporting, and quality-of-submission (QoS) analysis by screener.' ;
    rdfs:domain ind:CandidateScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenerRole rdf:type rdf:Property ;
    rdfs:label 'Screener Role' ;
    rdfs:comment 'The organizational role of the person who conducted the screening (e.g., recruiter, account manager, hiring manager, technical lead). Supports QoS analysis and ensures appropriate screening authority.' ;
    rdfs:domain ind:CandidateScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningChannel rdf:type rdf:Property ;
    rdfs:label 'Screening Channel' ;
    rdfs:comment 'The medium or channel through which the screening was conducted (e.g., phone, video conference, in-person, email, chat). Distinct from screening_type which captures the nature of the assessment.' ;
    rdfs:domain ind:CandidateScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningDate rdf:type rdf:Property ;
    rdfs:label 'Screening Date' ;
    rdfs:comment 'The calendar date on which the screening activity was conducted or is scheduled to occur. Used for TTF (Time to Fill) and TTS (Time to Start) KPI calculations and recruiter activity reporting.' ;
    rdfs:domain ind:CandidateScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:screeningNotes rdf:type rdf:Property ;
    rdfs:label 'Screening Notes' ;
    rdfs:comment 'Free-text notes recorded by the screener capturing qualitative observations, candidate responses, behavioral indicators, and overall impressions. Confidential and used by recruiters and account managers for submittal decisions.' ;
    rdfs:domain ind:CandidateScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningNumber rdf:type rdf:Property ;
    rdfs:label 'Screening Number' ;
    rdfs:comment 'Externally-known business identifier for this screening event, used in recruiter communications, ATS tracking, and audit trails (e.g., SCR-2024-00123). Sourced from Bullhorn ATS interview/screening record number.' ;
    rdfs:domain ind:CandidateScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningSource rdf:type rdf:Property ;
    rdfs:label 'Screening Source' ;
    rdfs:comment 'Indicates how the candidate entered this screening event — whether from the ATS pipeline, an inbound application, a referral, a sourcing campaign, the talent pool, or a VMS requisition. Supports sourcing effectiveness analytics.' ;
    rdfs:domain ind:CandidateScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningStatus rdf:type rdf:Property ;
    rdfs:label 'Screening Status' ;
    rdfs:comment 'Current lifecycle state of the screening event. Tracks whether the screening has been scheduled, is in progress, has been completed, was cancelled, or the candidate was a no-show. Drives recruiter workflow and ATS pipeline stage updates.' ;
    rdfs:domain ind:CandidateScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workAuthorizationConfirmed rdf:type rdf:Property ;
    rdfs:label 'Work Authorization Confirmed' ;
    rdfs:comment 'Indicates whether the candidates work authorization status (e.g., U.S. work eligibility) was verbally confirmed during the screening. Supports I-9 and E-Verify readiness tracking. Distinct from formal I-9 verification owned by the compliance domain.' ;
    rdfs:domain ind:CandidateScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hiringManagerClientContactId rdf:type rdf:Property ;
    rdfs:label 'Hiring Manager Client Contact Id' ;
    rdfs:comment 'Foreign key linking to client.client_contact. Business justification: The hiring manager is the primary client relationship for a recruiter on a specific assignment. Recruiter-to-hiring-manager relationship tracking drives communication cadence, NPS attribution, and acc' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientContact .

ind:actualFillDate rdf:type rdf:Property ;
    rdfs:label 'Actual Fill Date' ;
    rdfs:comment 'The actual date on which the job order was filled (placement confirmed). Used to calculate realized Time-to-Fill (TTF) against the target and to measure recruiter performance against SLA commitments.' ;
    rdfs:domain ind:RecruiterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualSubmittalCount rdf:type rdf:Property ;
    rdfs:label 'Actual Submittal Count' ;
    rdfs:comment 'The actual number of candidate submittals delivered by the recruiter against this job order as of the current date. Compared against target_submittal_count to measure QoS performance and recruiter productivity.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedDate rdf:type rdf:Property ;
    rdfs:label 'Assigned Date' ;
    rdfs:comment 'The calendar date on which the recruiter was formally assigned to the job order or requisition. Used as the start anchor for Time-to-Fill (TTF) and Time-to-Start (TTS) KPI calculations and workload reporting.' ;
    rdfs:domain ind:RecruiterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle state of the recruiter assignment. active = recruiter is actively working the req; reassigned = ownership transferred to another recruiter; closed = job order filled or cancelled; on_hold = req paused by client; cancelled = assignment voided before any activity.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Classifies the nature of the recruiters role on this job order. primary = sole owner; backup = secondary coverage; split_desk = shared fee arrangement between two recruiters; rpo_team = Recruitment Process Outsourcing (RPO) team member; msp_coordinator = Managed Service Provider (MSP) program coordinator; overflow = temporary capacity relief assignment.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backfillRequired rdf:type rdf:Property ;
    rdfs:label 'Backfill Required' ;
    rdfs:comment 'Indicates whether a backfill assignment is required because the original placed candidate left the role prematurely (fall-off). When True, triggers a new recruiter assignment workflow for the same job order.' ;
    rdfs:domain ind:RecruiterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExclusiveAssignment rdf:type rdf:Property ;
    rdfs:label 'Is Exclusive Assignment' ;
    rdfs:comment 'Indicates whether this recruiter has exclusive ownership of the job order (True) or whether the req is being worked by multiple recruiters simultaneously (False). Exclusive assignments typically carry higher accountability and commission expectations.' ;
    rdfs:domain ind:RecruiterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRpoEngagement rdf:type rdf:Property ;
    rdfs:label 'Is Rpo Engagement' ;
    rdfs:comment 'Flags whether this recruiter assignment is part of a formal Recruitment Process Outsourcing (RPO) engagement where the staffing firm is acting as an embedded talent acquisition function for the client. Drives RPO-specific reporting, billing, and SLA tracking.' ;
    rdfs:domain ind:RecruiterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reassignmentDate rdf:type rdf:Property ;
    rdfs:label 'Reassignment Date' ;
    rdfs:comment 'The date on which the recruiter assignment was transferred from one recruiter to another. Used to measure the impact of reassignments on TTF and to track assignment continuity for client relationship management.' ;
    rdfs:domain ind:RecruiterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reassignmentReason rdf:type rdf:Property ;
    rdfs:label 'Reassignment Reason' ;
    rdfs:comment 'Free-text or coded explanation for why this recruiter assignment was transferred to a different recruiter. Common reasons include recruiter departure, workload rebalancing, specialization mismatch, client request, or performance issue. Populated only when assignment_status = reassigned.' ;
    rdfs:domain ind:RecruiterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTtfTargetDays rdf:type rdf:Property ;
    rdfs:label 'Sla Ttf Target Days' ;
    rdfs:comment 'The contractually or operationally agreed number of calendar days within which the recruiter must fill the job order from the assignment date. Drives TTF KPI measurement and client SLA compliance reporting.' ;
    rdfs:domain ind:RecruiterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourcingStrategy rdf:type rdf:Property ;
    rdfs:label 'Sourcing Strategy' ;
    rdfs:comment 'The primary candidate sourcing approach the recruiter is employing for this assignment. Supports sourcing effectiveness analytics and cost-per-hire analysis. [ENUM-REF-CANDIDATE: job_board|social_media|referral|database_search|headhunting|campus|redeployment|other — promote to reference product]' ;
    rdfs:domain ind:RecruiterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittalToHireRatio rdf:type rdf:Property ;
    rdfs:label 'Submittal To Hire Ratio' ;
    rdfs:comment 'The ratio of candidate submittals to confirmed hires for this assignment (e.g., 5.00 means 5 submittals per hire). A key QoS and recruiter efficiency metric. Populated at assignment closure. Lower ratios indicate higher submittal quality.' ;
    rdfs:domain ind:RecruiterAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workloadWeight rdf:type rdf:Property ;
    rdfs:label 'Workload Weight' ;
    rdfs:comment 'A numeric weight (e.g., 0.50–3.00) representing the relative complexity or effort burden of this assignment compared to a standard job order. Used in workload balancing algorithms to ensure equitable distribution across the recruiting desk. Higher values indicate more complex or time-intensive requisitions.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originatingReferralId rdf:type rdf:Property ;
    rdfs:label 'Originating Referral Id' ;
    rdfs:comment 'Self-referencing FK on referral (originating_referral_id)' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Referral .

ind:primaryOriginalReferralId rdf:type rdf:Property ;
    rdfs:label 'Primary Original Referral Id' ;
    rdfs:comment 'Identifier of the original referral record if this is a duplicate. Null if this is the first referral for this candidate.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Referral .

ind:referralProfileId rdf:type rdf:Property ;
    rdfs:label 'Referral Profile Id' ;
    rdfs:comment 'Identifier of the candidate who was referred. Links to the candidate master record.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:referralReferrerCandidateProfileId rdf:type rdf:Property ;
    rdfs:label 'Referral Referrer Candidate Profile Id' ;
    rdfs:comment 'Identifier of the placed worker or candidate who made the referral, if referrer_type is placed_worker or candidate. Null otherwise.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:referrerClientContactId rdf:type rdf:Property ;
    rdfs:label 'Referrer Client Contact Id' ;
    rdfs:comment 'Identifier of the client contact who made the referral, if referrer_type is client_contact. Null otherwise.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientContact .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date when the referral was accepted and the candidate was moved into active consideration. Null if referral was rejected.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bonusCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Bonus Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the referral bonus amount.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusDenialReason rdf:type rdf:Property ;
    rdfs:label 'Bonus Denial Reason' ;
    rdfs:comment 'Explanation for why a referral bonus was denied or cancelled, if applicable. Null if bonus was approved and paid.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusEligible rdf:type rdf:Property ;
    rdfs:label 'Bonus Eligible' ;
    rdfs:comment 'Indicates whether this referral qualifies for a referral bonus based on program rules, referrer type, and placement outcome.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bonusPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Bonus Payment Date' ;
    rdfs:comment 'Date when the referral bonus was paid to the referrer. Null if bonus has not yet been paid.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bonusPaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Bonus Payment Status' ;
    rdfs:comment 'Current status of the referral bonus payment process. Tracks approval and payment workflow.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bullhornReferralCode rdf:type rdf:Property ;
    rdfs:label 'Bullhorn Referral Code' ;
    rdfs:comment 'External identifier from Bullhorn ATS/CRM system for cross-system reconciliation and data lineage tracking.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysToPlacement rdf:type rdf:Property ;
    rdfs:label 'Days To Placement' ;
    rdfs:comment 'Number of calendar days from referral submission to successful placement. Key metric for referral program effectiveness. Null if not yet placed.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDuplicateReferral rdf:type rdf:Property ;
    rdfs:label 'Is Duplicate Referral' ;
    rdfs:comment 'Indicates whether this referral is a duplicate of an existing candidate record or prior referral. Used to manage bonus eligibility and prevent duplicate processing.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placementDate rdf:type rdf:Property ;
    rdfs:label 'Placement Date' ;
    rdfs:comment 'Date when the referred candidate was successfully placed. Used to calculate time-to-placement from referral and determine bonus eligibility timing.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referralNumber rdf:type rdf:Property ;
    rdfs:label 'Referral Number' ;
    rdfs:comment 'Business-facing unique reference number for the referral, used for tracking and communication purposes.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralStatus rdf:type rdf:Property ;
    rdfs:label 'Referral Status' ;
    rdfs:comment 'Current lifecycle status of the referral. Tracks progression from submission through placement and bonus payment. [ENUM-REF-CANDIDATE: submitted|under_review|accepted|rejected|placed|bonus_pending|bonus_paid|expired — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referrerEmail rdf:type rdf:Property ;
    rdfs:label 'Referrer Email' ;
    rdfs:comment 'Email address of the referrer for communication and bonus notification purposes.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referrerName rdf:type rdf:Property ;
    rdfs:label 'Referrer Name' ;
    rdfs:comment 'Full name of the person who made the referral. Captured for tracking and bonus payment purposes.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referrerPhone rdf:type rdf:Property ;
    rdfs:label 'Referrer Phone' ;
    rdfs:comment 'Contact phone number of the referrer.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referrerType rdf:type rdf:Property ;
    rdfs:label 'Referrer Type' ;
    rdfs:comment 'Classification of the person or entity who made the referral. Determines bonus eligibility rules and tracking requirements.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Date' ;
    rdfs:comment 'Date when the referral was rejected or declined. Null if referral was accepted or is still under review.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipToCandidate rdf:type rdf:Property ;
    rdfs:label 'Relationship To Candidate' ;
    rdfs:comment 'Description of the referrers relationship to the referred candidate (e.g., former colleague, friend, family member, professional contact). Used for quality and compliance tracking.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedDate rdf:type rdf:Property ;
    rdfs:label 'Reviewed Date' ;
    rdfs:comment 'Date when the referral was reviewed by the recruiting team. Used to track referral processing time and responsiveness.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Clearance Required' ;
    rdfs:comment 'Security clearance level required for the position. Critical for government and defense staffing engagements. Drives candidate eligibility screening and credentialing requirements.' ;
    rdfs:domain ind:OrderHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionFee rdf:type rdf:Property ;
    rdfs:label 'Conversion Fee' ;
    rdfs:comment 'The fee charged to the client upon permanent conversion of a temp-to-perm worker. May be expressed as a flat dollar amount or percentage of first-year salary. Applicable only when is_temp_to_perm is true.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employmentClassification rdf:type rdf:Property ;
    rdfs:label 'Employment Classification' ;
    rdfs:comment 'Worker tax and employment classification for this requisition. W-2 = employee on staffing firm payroll; 1099 = independent contractor; C2C = corp-to-corp engagement. Drives payroll processing, tax withholding, and co-employment risk assessment.' ;
    rdfs:domain ind:OrderHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountFilled rdf:type rdf:Property ;
    rdfs:label 'Headcount Filled' ;
    rdfs:comment 'Current count of positions on this requisition that have been successfully filled with an active placement. Derived operationally from placement records but stored here for fast reporting and SLA dashboards.' ;
    rdfs:domain ind:Joborder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headcountRemaining rdf:type rdf:Property ;
    rdfs:label 'Headcount Remaining' ;
    rdfs:comment 'Number of unfilled positions remaining on this requisition (headcount_target minus headcount_filled). Drives active recruiting prioritization and capacity planning.' ;
    rdfs:domain ind:Joborder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headcountTarget rdf:type rdf:Property ;
    rdfs:label 'Headcount Target' ;
    rdfs:comment 'Total number of positions authorized by the client for this requisition. Represents the maximum number of workers that can be placed against this job order. Used for demand planning and fulfillment tracking.' ;
    rdfs:domain ind:OrderHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Hours Per Week' ;
    rdfs:comment 'Expected number of hours per week for the position. Used to determine full-time equivalent (FTE) classification, ACA benefits eligibility thresholds, and total assignment cost projections.' ;
    rdfs:domain ind:Joborder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intakeDate rdf:type rdf:Property ;
    rdfs:label 'Intake Date' ;
    rdfs:comment 'The date the requisition was formally received and entered into the ATS/CRM. Serves as the start point for Time to Fill (TTF) and Time to Start (TTS) SLA calculations. BUSINESS_EVENT_TIMESTAMP category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:OrderHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minExperienceYears rdf:type rdf:Property ;
    rdfs:label 'Min Experience Years' ;
    rdfs:comment 'Minimum number of years of relevant work experience required for candidates to be considered for this position. Used in ATS candidate screening and quality of submission (QoS) scoring.' ;
    rdfs:domain ind:OrderHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originatingSource rdf:type rdf:Property ;
    rdfs:label 'Originating Source' ;
    rdfs:comment 'The channel or system through which this requisition was received. Tracks demand intake source for channel analytics and process efficiency measurement. VMS = Beeline or similar; CRM = Salesforce/Bullhorn direct; Direct = client phone/email; Portal = self-service client portal.' ;
    rdfs:domain ind:OrderHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reqNumber rdf:type rdf:Property ;
    rdfs:label 'Req Number' ;
    rdfs:comment 'Externally-known, human-readable requisition number assigned at intake. Used by clients, recruiters, and VMS systems to reference the job order. Corresponds to the Bullhorn Job Order external ID or VMS requisition number. BUSINESS_IDENTIFIER category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:OrderHeader ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ttfTargetDays rdf:type rdf:Property ;
    rdfs:label 'Ttf Target Days' ;
    rdfs:comment 'The SLA-committed number of calendar days from intake to first qualified submittal or fill, as agreed with the client. Used to measure recruiter and program performance against TTF KPI benchmarks.' ;
    rdfs:domain ind:Joborder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ttsTargetDays rdf:type rdf:Property ;
    rdfs:label 'Tts Target Days' ;
    rdfs:comment 'The SLA-committed number of calendar days from requisition intake to worker start date. Distinct from TTF; measures the full cycle from demand signal to worker on-site.' ;
    rdfs:domain ind:Joborder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bgcType rdf:type rdf:Property ;
    rdfs:label 'Bgc Type' ;
    rdfs:comment 'Specifies the type(s) of background check required (e.g., criminal, employment verification, education verification, credit, motor vehicle record). Drives the BGC package selection in Sterling Background Check. [ENUM-REF-CANDIDATE: criminal|employment_verification|education_verification|credit|motor_vehicle|sex_offender_registry|federal — promote to reference product]' ;
    rdfs:domain ind:PositionRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationsRequired rdf:type rdf:Property ;
    rdfs:label 'Certifications Required' ;
    rdfs:comment 'Comma-delimited list of mandatory professional certifications or licenses required for the position (e.g., PMP, RN, CPA, CDL). Drives the credentialing verification workflow and readiness status checks.' ;
    rdfs:domain ind:PositionRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientScreeningCriteria rdf:type rdf:Property ;
    rdfs:label 'Client Screening Criteria' ;
    rdfs:comment 'Free-text field capturing any client-specific screening requirements beyond standard criteria (e.g., proprietary assessments, client interviews, specific onboarding steps, NDA requirements). Sourced from client MSA or VMS program requirements.' ;
    rdfs:domain ind:PositionRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:educationFieldOfStudy rdf:type rdf:Property ;
    rdfs:label 'Education Field Of Study' ;
    rdfs:comment 'Specific academic discipline or field of study required or preferred for the position (e.g., Computer Science, Nursing, Accounting). Complements education_level for precise candidate qualification.' ;
    rdfs:domain ind:PositionRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:educationLevel rdf:type rdf:Property ;
    rdfs:label 'Education Level' ;
    rdfs:comment 'Minimum educational attainment required for the position. Used as a screening criterion in candidate qualification. Values align with standard U.S. education levels: none, high_school, associate, bachelor, master, doctorate, professional_cert. [ENUM-REF-CANDIDATE: none|high_school|associate|bachelor|master|doctorate|professional_cert — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PositionRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcount rdf:type rdf:Property ;
    rdfs:label 'Headcount' ;
    rdfs:comment 'Number of open positions (headcount) to be filled for this position requirement. Drives sourcing volume targets, TTF SLA tracking, and workforce planning analytics.' ;
    rdfs:domain ind:PositionRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxSubmittals rdf:type rdf:Property ;
    rdfs:label 'Max Submittals' ;
    rdfs:comment 'Maximum number of candidate submittals the client will accept for this position. Enforces quality of submission (QoS) discipline and prevents submittal flooding in VMS-managed programs.' ;
    rdfs:domain ind:PositionRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxYearsExperience rdf:type rdf:Property ;
    rdfs:label 'Max Years Experience' ;
    rdfs:comment 'Maximum number of years of relevant professional experience acceptable for the position. Used to prevent over-qualification mismatches and manage bill rate expectations.' ;
    rdfs:domain ind:PositionRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:physicalDemands rdf:type rdf:Property ;
    rdfs:label 'Physical Demands' ;
    rdfs:comment 'DOL physical exertion classification for the position. Used for workers compensation risk rating, OSHA compliance, and candidate physical qualification screening. Aligns with DOL Dictionary of Occupational Titles (DOT) physical demand levels.' ;
    rdfs:domain ind:PositionRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionReqNumber rdf:type rdf:Property ;
    rdfs:label 'Position Req Number' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for this position requirement, used in client communications, VMS portals, and ATS workflows. May align with the clients internal requisition number or Beeline VMS position code.' ;
    rdfs:domain ind:PositionRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionRequirementStatus rdf:type rdf:Property ;
    rdfs:label 'Position Requirement Status' ;
    rdfs:comment 'Current lifecycle state of the position requirement. Drives operational workflows: draft (intake in progress), open (actively sourcing), on_hold (client paused), filled (placement made), cancelled (client withdrew), closed (naturally ended), expired (TTF deadline passed without fill). [ENUM-REF-CANDIDATE: draft|open|on_hold|filled|cancelled|closed|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PositionRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelRequirement rdf:type rdf:Property ;
    rdfs:label 'Travel Requirement' ;
    rdfs:comment 'Expected travel frequency for the position. Used in candidate screening and per diem/expense planning. Values represent percentage of time traveling: none, occasional, up to 25%, up to 50%, up to 75%, frequent (75%+).' ;
    rdfs:domain ind:PositionRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether this skill requirement is currently active for the job order. True if active and used in candidate matching; False if deprecated or removed from requirements. Used for requirement lifecycle management.' ;
    rdfs:domain ind:SkillRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alternativeSkillNames rdf:type rdf:Property ;
    rdfs:label 'Alternative Skill Names' ;
    rdfs:comment 'Comma-separated list of synonyms or alternative names for this skill. Used to improve candidate search and matching. Examples: Java could include J2EE, Java EE, Jakarta EE.' ;
    rdfs:domain ind:SkillRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assessment Method' ;
    rdfs:comment 'The primary method used to evaluate candidate proficiency in this skill. Resume review indicates screening from candidate documents; technical test indicates formal assessment; behavioral interview indicates structured questioning; practical demonstration indicates hands-on evaluation; certification verification indicates credential validation; reference check indicates third-party validation.' ;
    rdfs:domain ind:SkillRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationName rdf:type rdf:Property ;
    rdfs:label 'Certification Name' ;
    rdfs:comment 'The name of the specific certification or credential required if certification_required_flag is True. Examples include PMP, CPA, RN, AWS Certified Solutions Architect, or Certified Welder. Null if no certification is required.' ;
    rdfs:domain ind:SkillRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Required Flag' ;
    rdfs:comment 'Indicates whether a formal certification or credential is required for this skill. True if certification is mandatory; False if experience alone is sufficient. Used for credentialing and compliance verification.' ;
    rdfs:domain ind:SkillRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientSpecificTerminology rdf:type rdf:Property ;
    rdfs:label 'Client Specific Terminology' ;
    rdfs:comment 'Client-specific name or terminology for this skill if different from the standard skill_name. Used to align with client vocabulary in submittals and communications. Null if client uses standard terminology.' ;
    rdfs:domain ind:SkillRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deactivated Timestamp' ;
    rdfs:comment 'The date and time when this skill requirement was deactivated or removed from the job order. Null if the requirement is still active. Used for requirement lifecycle analysis.' ;
    rdfs:domain ind:SkillRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deactivationReason rdf:type rdf:Property ;
    rdfs:label 'Deactivation Reason' ;
    rdfs:comment 'Free-text explanation of why this skill requirement was deactivated or removed from the job order. Examples include client request, requirement change, skill no longer needed, or job order modification. Null if still active.' ;
    rdfs:domain ind:SkillRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMarketRateSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Last Market Rate Survey Date' ;
    rdfs:comment 'The date when market rate data for this skill was last surveyed or updated. Used to ensure pay rate and bill rate competitiveness. Null if no market survey has been conducted.' ;
    rdfs:domain ind:SkillRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketDemandLevel rdf:type rdf:Property ;
    rdfs:label 'Market Demand Level' ;
    rdfs:comment 'Assessment of current market demand for this skill. Low indicates abundant supply; moderate indicates balanced supply/demand; high indicates competitive market; critical indicates severe shortage. Used for sourcing strategy and rate negotiations.' ;
    rdfs:domain ind:Joborder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Score Threshold' ;
    rdfs:comment 'The minimum acceptable score (0-100 scale) a candidate must achieve for this skill to be considered qualified. Used in automated candidate screening and QoS evaluation.' ;
    rdfs:domain ind:SkillRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:skillCode rdf:type rdf:Property ;
    rdfs:label 'Skill Code' ;
    rdfs:comment 'Standardized code or identifier for the skill from an external taxonomy or classification system. Examples include O*NET skill codes, SOC codes, or client-specific skill identifiers.' ;
    rdfs:domain ind:SkillRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillObsolescenceDate rdf:type rdf:Property ;
    rdfs:label 'Skill Obsolescence Date' ;
    rdfs:comment 'The date when this skill is expected to become obsolete or significantly less relevant. Used for workforce planning and skill gap analysis. Null if the skill has no known obsolescence timeline.' ;
    rdfs:domain ind:SkillRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:skillPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Skill Priority Rank' ;
    rdfs:comment 'Numeric ranking indicating the relative importance of this skill within the job order. Lower numbers indicate higher priority. Used for weighted candidate matching and QoS scoring algorithms.' ;
    rdfs:domain ind:SkillRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skillSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Skill Source System' ;
    rdfs:comment 'The name of the source system or taxonomy from which this skill requirement was derived. Examples include O*NET, client-provided skill list, internal skill taxonomy, or VMS skill catalog.' ;
    rdfs:domain ind:SkillRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillVerificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Skill Verification Required Flag' ;
    rdfs:comment 'Indicates whether formal verification or validation of this skill is required before candidate submission or placement. True if verification is mandatory; False if self-reported skill is acceptable. Used for compliance and quality assurance.' ;
    rdfs:domain ind:SkillRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skillWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Skill Weight Percentage' ;
    rdfs:comment 'The percentage weight assigned to this skill in the overall candidate evaluation and QoS scoring. All skill weights for a job order should sum to 100. Used in ATS matching algorithms.' ;
    rdfs:domain ind:SkillRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Training Available Flag' ;
    rdfs:comment 'Indicates whether training or upskilling programs are available for candidates who do not fully meet this skill requirement. True if training is offered; False if candidates must possess the skill prior to placement.' ;
    rdfs:domain ind:SkillRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingDurationHours rdf:type rdf:Property ;
    rdfs:label 'Training Duration Hours' ;
    rdfs:comment 'The estimated number of hours required to complete training for this skill if training_available_flag is True. Used for onboarding planning and Time to Start (TTS) calculations. Null if no training is available.' ;
    rdfs:domain ind:SkillRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearsOfExperienceRequired rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience Required' ;
    rdfs:comment 'The minimum number of years of hands-on experience required for this specific skill. Used in candidate screening and QoS scoring. Supports fractional years (e.g., 2.5 years).' ;
    rdfs:domain ind:SkillRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderExtensionId rdf:type rdf:Property ;
    rdfs:label 'Order Extension Id' ;
    rdfs:comment 'Foreign key linking to joborder.order_extension. Business justification: Rate overrides are frequently triggered by assignment extensions — when a worker\'s contract is extended, new bill/pay rates are often negotiated and captured as a rate_override. Linking rate_override ' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderExtension .

ind:clientApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Client Approval Date' ;
    rdfs:comment 'The date on which the client formally approved this rate override. Nullable if client approval is not required or not yet received.' ;
    rdfs:domain ind:Joborder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Client Approval Required' ;
    rdfs:comment 'Indicates whether this rate override requires explicit client approval before activation. True if client sign-off is mandatory per MSA or VMS rules.' ;
    rdfs:domain ind:Joborder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientApproverName rdf:type rdf:Property ;
    rdfs:label 'Client Approver Name' ;
    rdfs:comment 'Name of the client contact who approved this rate override. Typically a procurement manager, hiring manager, or VMS program manager.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideNumber rdf:type rdf:Property ;
    rdfs:label 'Override Number' ;
    rdfs:comment 'Business identifier for the rate override, used for tracking and reference in communications with clients and internal stakeholders.' ;
    rdfs:domain ind:RateOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideStatus rdf:type rdf:Property ;
    rdfs:label 'Override Status' ;
    rdfs:comment 'Current lifecycle status of the rate override. Tracks approval workflow and activation state. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|rejected|active|expired|superseded — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RateOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCap rdf:type rdf:Property ;
    rdfs:label 'Rate Cap' ;
    rdfs:comment 'Maximum bill rate ceiling negotiated with the client or imposed by VMS program rules. Rates cannot exceed this cap regardless of other factors.' ;
    rdfs:domain ind:RateOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateFloor rdf:type rdf:Property ;
    rdfs:label 'Rate Floor' ;
    rdfs:comment 'Minimum bill rate floor negotiated with the client or required by internal profitability policies. Rates cannot fall below this floor.' ;
    rdfs:domain ind:RateOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedBy rdf:type rdf:Property ;
    rdfs:label 'Requested By' ;
    rdfs:comment 'Name or identifier of the person who requested this rate override. Typically the account manager, recruiter, or client relationship owner.' ;
    rdfs:domain ind:Joborder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessDaysDefinition rdf:type rdf:Property ;
    rdfs:label 'Business Days Definition' ;
    rdfs:comment 'Definition of business days used for SLA measurement, including which days of the week and holidays are excluded.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:duplicateSubmittalPreventionRule rdf:type rdf:Property ;
    rdfs:label 'Duplicate Submittal Prevention Rule' ;
    rdfs:comment 'Rule governing how duplicate candidate submittals from multiple vendors are handled (e.g., first submittal wins, client discretion).' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Exclusive Period End Date' ;
    rdfs:comment 'Date when the exclusive submittal period expires and the requisition opens to all authorized vendors.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusiveSubmittalPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusive Submittal Period Flag' ;
    rdfs:comment 'Indicates whether an exclusive submittal period is in effect, restricting submittals to a single preferred vendor for a defined timeframe.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fillRateTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Target Percentage' ;
    rdfs:comment 'Target percentage of requisitions successfully filled within the committed timeframe, used to measure supplier performance.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interviewToOfferRatioTarget rdf:type rdf:Property ;
    rdfs:label 'Interview To Offer Ratio Target' ;
    rdfs:comment 'Target ratio of candidate interviews to offers extended, expressed as a percentage, used to measure Quality of Submission (QoS).' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumSubmittalsPerVendor rdf:type rdf:Property ;
    rdfs:label 'Maximum Submittals Per Vendor' ;
    rdfs:comment 'Maximum number of candidate submittals allowed per vendor or supplier for VMS-managed programs to ensure quality over quantity.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementMethodology rdf:type rdf:Property ;
    rdfs:label 'Measurement Methodology' ;
    rdfs:comment 'Methodology used to measure SLA performance (e.g., business days excluding holidays, calendar days, hours).' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumSubmittalsRequired rdf:type rdf:Property ;
    rdfs:label 'Minimum Submittals Required' ;
    rdfs:comment 'Minimum number of qualified candidate submittals required to fulfill the SLA commitment for this requisition.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:penaltyBreachFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Breach Fee Amount' ;
    rdfs:comment 'Monetary penalty amount assessed for SLA breach, as defined in the Master Service Agreement (MSA) or Statement of Work (SOW).' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyBreachFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Penalty Breach Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the penalty breach fee amount.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyTermsDescription rdf:type rdf:Property ;
    rdfs:label 'Penalty Terms Description' ;
    rdfs:comment 'Detailed description of penalty terms and conditions applied when SLA commitments are breached, including escalation procedures.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qosMinimumScore rdf:type rdf:Property ;
    rdfs:label 'Qos Minimum Score' ;
    rdfs:comment 'Minimum Quality of Submission (QoS) score required for candidate submittals, typically measured on a scale of 0-100.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rtrEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Rtr Enforcement Flag' ;
    rdfs:comment 'Indicates whether Right to Represent (RTR) rules are enforced, requiring vendors to obtain candidate authorization before submittal.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Sla Effective Date' ;
    rdfs:comment 'Date when this SLA commitment becomes effective and performance measurement begins.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Sla Expiration Date' ;
    rdfs:comment 'Date when this SLA commitment expires or is superseded by a new agreement.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submittalSlaHours rdf:type rdf:Property ;
    rdfs:label 'Submittal Sla Hours' ;
    rdfs:comment 'Maximum number of hours allowed from job order receipt to first candidate submittal, as committed in the SLA.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submittalWindowCloseDate rdf:type rdf:Property ;
    rdfs:label 'Submittal Window Close Date' ;
    rdfs:comment 'Date when the submittal window closes and no further candidate submittals will be accepted for this requisition.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submittalWindowOpenDate rdf:type rdf:Property ;
    rdfs:label 'Submittal Window Open Date' ;
    rdfs:comment 'Date when the submittal window opens and vendors are authorized to begin submitting candidates for this requisition.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved Date' ;
    rdfs:comment 'Date when the SLA waiver was officially approved.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Granted Flag' ;
    rdfs:comment 'Indicates whether a waiver has been granted exempting this requisition from standard SLA commitments due to exceptional circumstances.' ;
    rdfs:domain ind:SlaCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderStatusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Order Status History Id' ;
    rdfs:comment 'Unique identifier for each status transition event in the job order lifecycle. Primary key for the order status history log.' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'The actual date when the milestone was achieved. Used to calculate variance against target date and measure operational performance.' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'The specific fulfillment milestone reached in the job order lifecycle. Used to track key operational checkpoints from requisition intake through assignment completion. Null for non-milestone events. [ENUM-REF-CANDIDATE: req_received|sourcing_started|first_submittal|interview_scheduled|offer_extended|offer_accepted|placement_confirmed|worker_started|assignment_ended|req_closed — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Boolean indicator of whether automated notifications were sent to stakeholders (client, recruiter, candidate) for this status event.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Timestamp' ;
    rdfs:comment 'Date and time when automated notifications were sent for this status event. Null if no notifications were sent.' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The job order status immediately before this transition event. Null for the initial status event when the requisition is first created. [ENUM-REF-CANDIDATE: draft|open|in_progress|on_hold|filled|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Record Created By' ;
    rdfs:comment 'System user or process identifier that created this status history record. Used for audit trail and data governance.' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Record Updated By' ;
    rdfs:comment 'System user or process identifier that last modified this status history record. Used for audit trail and data governance.' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachSeverity rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Severity' ;
    rdfs:comment 'Classification of SLA breach severity based on the magnitude of variance. Used for escalation management and client communication prioritization.' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDate rdf:type rdf:Property ;
    rdfs:label 'Target Date' ;
    rdfs:comment 'The planned or Service Level Agreement (SLA) target date by which this milestone was expected to be completed. Used for variance analysis and SLA breach detection.' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:triggeringSystem rdf:type rdf:Property ;
    rdfs:label 'Triggering System' ;
    rdfs:comment 'The source system or process that generated this status event. Identifies whether the transition was user-initiated, system-automated, or triggered by external integration.' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ttfElapsedDays rdf:type rdf:Property ;
    rdfs:label 'Ttf Elapsed Days' ;
    rdfs:comment 'Cumulative business days elapsed from requisition receipt to this event. When milestone_type is placement_confirmed, this represents the complete Time to Fill metric for the job order.' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ttsElapsedDays rdf:type rdf:Property ;
    rdfs:label 'Tts Elapsed Days' ;
    rdfs:comment 'Cumulative business days elapsed from requisition receipt to worker start date. Populated when milestone_type is worker_started. Represents the complete Time to Start metric for the job order.' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceBusinessDays rdf:type rdf:Property ;
    rdfs:label 'Variance Business Days' ;
    rdfs:comment 'The difference in business days between target date and actual completion date. Positive values indicate late completion (SLA breach), negative values indicate early completion. Null if milestone not yet completed.' ;
    rdfs:domain ind:OrderStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fulfillmentTeamId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Team Id' ;
    rdfs:comment 'Primary key for fulfillment_team' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentTeam .

ind:assignmentCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Created Timestamp' ;
    rdfs:comment 'The date and time when this assignment record was first created in the system. Audit field for tracking when the assignment was initially established. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:FulfillmentTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Modified Timestamp' ;
    rdfs:comment 'The date and time when this assignment record was last updated or modified. Audit field for tracking changes to assignment details, status transitions, or workload adjustments. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:FulfillmentTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'Free-text field for capturing special instructions, context, or notes related to this specific assignment. May include handoff notes from previous recruiters, client preferences, sourcing strategies, or coordination details. Used for knowledge transfer during reassignments.' ;
    rdfs:domain ind:FulfillmentTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentPriority rdf:type rdf:Property ;
    rdfs:label 'Assignment Priority' ;
    rdfs:comment 'The priority level assigned to this team member for working this requisition, relative to their other assignments. Helps recruiters manage their workload and focus on the most urgent or strategic orders. May differ from the requisition overall priority based on individual workload and client relationships.' ;
    rdfs:domain ind:FulfillmentTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentReason rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason' ;
    rdfs:comment 'The business reason or trigger for this assignment. Indicates whether this is a new order assignment, a reassignment from another recruiter, a workload balancing action, a skill-based match, a client relationship consideration, a backfill for a departing team member, or an escalation for a struggling order. [ENUM-REF-CANDIDATE: new_order|reassignment|workload_balance|skill_match|client_relationship|backfill|escalation — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FulfillmentTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentRole rdf:type rdf:Property ;
    rdfs:label 'Assignment Role' ;
    rdfs:comment 'The functional role or responsibility that the assigned team member holds for this requisition. Defines whether they are the primary lead recruiter, a supporting sourcing specialist, the client-facing account manager, or an administrative coordinator. Used for performance attribution and commission split calculations.' ;
    rdfs:domain ind:FulfillmentTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientContactAuthorizedFlag rdf:type rdf:Property ;
    rdfs:label 'Client Contact Authorized Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether this team member is authorized to directly contact the client for this requisition. False may indicate a support role that works through the account manager. Used to manage client relationships and ensure consistent communication.' ;
    rdfs:domain ind:FulfillmentTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Commission Eligible Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether this team member is eligible to receive commission or performance credit for placements made on this requisition. May be False for coordinators or support roles that do not participate in commission plans.' ;
    rdfs:domain ind:FulfillmentTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionSplitPercentage rdf:type rdf:Property ;
    rdfs:label 'Commission Split Percentage' ;
    rdfs:comment 'The percentage of total commission or gross profit (GP) that this team member will receive for placements on this requisition, expressed as a decimal (e.g., 0.60 for 60%). Used in split-credit scenarios where multiple recruiters share commission. Sum of commission splits across all eligible assignments for a placement typically equals 1.00 (100%). Confidential business data.' ;
    rdfs:domain ind:FulfillmentTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedSubmittalCount rdf:type rdf:Property ;
    rdfs:label 'Expected Submittal Count' ;
    rdfs:comment 'The target number of candidate submittals this team member is expected to deliver for this requisition. Used for performance tracking and workload planning. May be set based on historical conversion rates, client requirements, or internal service level agreements (SLAs).' ;
    rdfs:domain ind:FulfillmentTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Qualitative performance rating for this team member on this specific assignment, typically assessed at assignment closure or during periodic reviews. Reflects quality of submittals, client feedback, time-to-fill performance, and overall contribution to order fulfillment. Used for coaching, development, and performance management.' ;
    rdfs:domain ind:FulfillmentTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementCount rdf:type rdf:Property ;
    rdfs:label 'Placement Count' ;
    rdfs:comment 'The number of successful placements this team member has achieved for this requisition. Typically 0 or 1 for single-headcount orders, but may be higher for multi-headcount requisitions. Used for commission calculations and performance attribution.' ;
    rdfs:domain ind:FulfillmentTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAssignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Assignment Flag' ;
    rdfs:comment 'Boolean indicator (True/False) identifying whether this team member is the primary or lead owner of the requisition. True indicates the main point of accountability; False indicates a supporting or secondary role. Only one assignment per requisition should typically have this flag set to True.' ;
    rdfs:domain ind:FulfillmentTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reassignmentCount rdf:type rdf:Property ;
    rdfs:label 'Reassignment Count' ;
    rdfs:comment 'The number of times this requisition has been reassigned to different team members prior to this current assignment. High reassignment counts may indicate order difficulty, client issues, or internal capacity challenges. Used for operational analytics and process improvement.' ;
    rdfs:domain ind:FulfillmentTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourcingChannelFocus rdf:type rdf:Property ;
    rdfs:label 'Sourcing Channel Focus' ;
    rdfs:comment 'Free-text or semi-structured field indicating the primary sourcing channels or strategies this team member is focusing on for this requisition (e.g., LinkedIn Recruiter, internal database, employee referrals, job boards, vendor management system (VMS) talent pools). Used for sourcing strategy tracking and channel effectiveness analysis.' ;
    rdfs:domain ind:FulfillmentTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeToFirstSubmittalDays rdf:type rdf:Property ;
    rdfs:label 'Time To First Submittal Days' ;
    rdfs:comment 'The number of calendar days from assignment start date to the first candidate submittal delivered by this team member for this requisition. Key performance indicator (KPI) for recruiter responsiveness and sourcing efficiency. Null if no submittals have been made yet.' ;
    rdfs:domain ind:FulfillmentTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vmsOrderId rdf:type rdf:Property ;
    rdfs:label 'Vms Order Id' ;
    rdfs:comment 'Unique identifier for the VMS order record in the lakehouse. Primary key for this product.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VmsOrder .

ind:primaryVmsReqOrderHeaderId rdf:type rdf:Property ;
    rdfs:label 'Primary Vms Req Order Header Id' ;
    rdfs:comment 'The unique requisition identifier assigned by the VMS platform (Beeline, Fieldglass, Wand). This is the external systems primary identifier for the requisition.' ;
    rdfs:domain ind:VmsOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderHeader .

ind:vmsOrderHeaderId rdf:type rdf:Property ;
    rdfs:label 'Vms Order Header Id' ;
    rdfs:comment 'Foreign key reference to the internal ATS requisition (job order header). Links the VMS order to the internal job order for dual-system synchronization.' ;
    rdfs:domain ind:VmsOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderHeader .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'The name of the person who approved this requisition in the VMS platform. Used for audit trail and accountability.' ;
    rdfs:domain ind:VmsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoDistributionFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Distribution Flag' ;
    rdfs:comment 'Boolean flag indicating whether this requisition was automatically distributed to vendors by the VMS platform based on program rules. True = auto-distributed, False = manually distributed.' ;
    rdfs:domain ind:VmsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentSubmittalCount rdf:type rdf:Property ;
    rdfs:label 'Current Submittal Count' ;
    rdfs:comment 'The current number of candidate submittals received for this requisition across all vendors. Used to track progress toward fulfillment and enforce submission caps.' ;
    rdfs:domain ind:VmsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Sync Timestamp' ;
    rdfs:comment 'The timestamp of the most recent synchronization event between the VMS platform and the internal ATS for this requisition. Used to track data freshness and identify sync issues.' ;
    rdfs:domain ind:VmsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxSubmittalCount rdf:type rdf:Property ;
    rdfs:label 'Max Submittal Count' ;
    rdfs:comment 'The maximum number of candidate submittals allowed per vendor for this requisition. VMS platforms enforce this limit to control submission volume and ensure quality over quantity.' ;
    rdfs:domain ind:VmsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mspName rdf:type rdf:Property ;
    rdfs:label 'Msp Name' ;
    rdfs:comment 'The name of the Managed Service Provider (MSP) managing this VMS program and requisition on behalf of the client.' ;
    rdfs:domain ind:VmsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'The clients purchase order number associated with this requisition. Used for financial tracking and invoice reconciliation.' ;
    rdfs:domain ind:VmsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtrRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rtr Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether vendors must have an active Right to Represent (RTR) agreement with the candidate before submitting them for this requisition. True = RTR required, False = RTR not required.' ;
    rdfs:domain ind:VmsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionWindowCloseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Window Close Timestamp' ;
    rdfs:comment 'The date and time when the submission window closes for this requisition. Vendors cannot submit candidates after this timestamp unless the window is extended.' ;
    rdfs:domain ind:VmsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:submissionWindowOpenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Window Open Timestamp' ;
    rdfs:comment 'The date and time when the submission window opens for vendors to submit candidates for this requisition. Vendors cannot submit before this timestamp.' ;
    rdfs:domain ind:VmsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supplierDiversityRequirement rdf:type rdf:Property ;
    rdfs:label 'Supplier Diversity Requirement' ;
    rdfs:comment 'Indicates whether this requisition has supplier diversity requirements (e.g., Minority Business Enterprise, Women Business Enterprise, Service-Disabled Veteran-Owned Small Business). Used for diversity program compliance and reporting. [ENUM-REF-CANDIDATE: None|Preferred|Required|MBE|WBE|SDVOSB|HUBZone|8a — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Joborder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:syncStatus rdf:type rdf:Property ;
    rdfs:label 'Sync Status' ;
    rdfs:comment 'The current synchronization status between the VMS platform and the internal ATS for this requisition. Indicates whether the data is in sync or requires attention.' ;
    rdfs:domain ind:VmsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorTierSequence rdf:type rdf:Property ;
    rdfs:label 'Vendor Tier Sequence' ;
    rdfs:comment 'The numeric sequence order for vendor tier access (1 = first tier, 2 = second tier, etc.). Used to control the waterfall release of requisitions to supplier tiers.' ;
    rdfs:domain ind:VmsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vmsBillRateCap rdf:type rdf:Property ;
    rdfs:label 'Vms Bill Rate Cap' ;
    rdfs:comment 'The maximum bill rate allowed by the VMS program for this requisition. Vendors cannot submit candidates with bill rates exceeding this cap.' ;
    rdfs:domain ind:VmsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vmsClientCode rdf:type rdf:Property ;
    rdfs:label 'Vms Client Code' ;
    rdfs:comment 'The client code or identifier used in the VMS platform. Used for cross-reference mapping between VMS and internal ATS client records.' ;
    rdfs:domain ind:VmsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmsClientName rdf:type rdf:Property ;
    rdfs:label 'Vms Client Name' ;
    rdfs:comment 'The client name as recorded in the VMS platform. May differ from the internal ATS client name due to naming conventions or organizational structure differences.' ;
    rdfs:domain ind:VmsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmsDepartmentCode rdf:type rdf:Property ;
    rdfs:label 'Vms Department Code' ;
    rdfs:comment 'The department or cost center code within the client organization as recorded in the VMS platform. Used for financial reporting and budget tracking.' ;
    rdfs:domain ind:VmsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmsDepartmentName rdf:type rdf:Property ;
    rdfs:label 'Vms Department Name' ;
    rdfs:comment 'The department or cost center name within the client organization as recorded in the VMS platform. Used for client-side reporting and cost allocation.' ;
    rdfs:domain ind:VmsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmsImportTimestamp rdf:type rdf:Property ;
    rdfs:label 'Vms Import Timestamp' ;
    rdfs:comment 'The timestamp when this requisition was imported from the VMS platform into the internal ATS. Used for reconciliation and synchronization tracking.' ;
    rdfs:domain ind:VmsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:vmsMarkupCapPercentage rdf:type rdf:Property ;
    rdfs:label 'Vms Markup Cap Percentage' ;
    rdfs:comment 'The maximum markup percentage (bill rate minus pay rate, expressed as a percentage of pay rate) allowed by the VMS program. Enforces margin limits on supplier pricing.' ;
    rdfs:domain ind:VmsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vmsOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Vms Order Status' ;
    rdfs:comment 'The current status of the requisition within the VMS platform workflow. Reflects the VMS-specific lifecycle state which may differ from internal ATS status. [ENUM-REF-CANDIDATE: Open|Pending Approval|Approved|Submitted|In Review|Filled|Closed|Cancelled|On Hold — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VmsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmsPayRateCap rdf:type rdf:Property ;
    rdfs:label 'Vms Pay Rate Cap' ;
    rdfs:comment 'The maximum pay rate allowed by the VMS program for this requisition. Used to enforce compensation limits and ensure budget compliance.' ;
    rdfs:domain ind:VmsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vmsPlatformName rdf:type rdf:Property ;
    rdfs:label 'Vms Platform Name' ;
    rdfs:comment 'The name of the VMS technology platform hosting this requisition (e.g., Beeline, Fieldglass, Wand). [ENUM-REF-CANDIDATE: Beeline|Fieldglass|Wand|Workday VNDLY|PRO Unlimited|Utmost|Other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VmsOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address of the work location. First line of the physical address where the worker will report.' ;
    rdfs:domain ind:OrderLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address information such as suite number, floor, building, or department. Optional address detail for the work location.' ;
    rdfs:domain ind:OrderLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:badgeAccessRequired rdf:type rdf:Property ;
    rdfs:label 'Badge Access Required' ;
    rdfs:comment 'Flag indicating whether workers need security badge or access credentials for this location. Triggers badging and credentialing workflows.' ;
    rdfs:domain ind:OrderLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:badgeSponsorName rdf:type rdf:Property ;
    rdfs:label 'Badge Sponsor Name' ;
    rdfs:comment 'Name of the client contact or security coordinator responsible for issuing badges at this location. Used for onboarding coordination.' ;
    rdfs:domain ind:OrderLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationNumber rdf:type rdf:Property ;
    rdfs:label 'Location Number' ;
    rdfs:comment 'Business identifier for this work location assignment within the requisition. Used for tracking when a single req has multiple work sites.' ;
    rdfs:domain ind:OrderLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingAvailable rdf:type rdf:Property ;
    rdfs:label 'Parking Available' ;
    rdfs:comment 'Flag indicating whether parking is available at the work location. Affects candidate acceptance and may impact compensation or reimbursement.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppeRequired rdf:type rdf:Property ;
    rdfs:label 'Ppe Required' ;
    rdfs:comment 'List of required personal protective equipment for this work location. Examples include hard hats, safety glasses, steel-toed boots, gloves, or respirators.' ;
    rdfs:domain ind:OrderLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prevailingWageApplicable rdf:type rdf:Property ;
    rdfs:label 'Prevailing Wage Applicable' ;
    rdfs:comment 'Flag indicating whether Davis-Bacon Act or state prevailing wage requirements apply to this work location. Mandates minimum wage rates for government-funded projects.' ;
    rdfs:domain ind:Joborder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prevailingWageDetermination rdf:type rdf:Property ;
    rdfs:label 'Prevailing Wage Determination' ;
    rdfs:comment 'Department of Labor wage determination number or reference for prevailing wage rates at this location. Required for compliance on government contracts.' ;
    rdfs:domain ind:OrderLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingInstructions rdf:type rdf:Property ;
    rdfs:label 'Reporting Instructions' ;
    rdfs:comment 'Detailed instructions for workers on where to report on their first day, including building entrance, reception desk, contact person, and check-in procedures.' ;
    rdfs:domain ind:OrderLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyClassification rdf:type rdf:Property ;
    rdfs:label 'Safety Classification' ;
    rdfs:comment 'OSHA hazard category or safety classification for the work site. Determines required safety training, personal protective equipment (PPE), and workers compensation insurance classification codes.' ;
    rdfs:domain ind:OrderLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Union Jurisdiction' ;
    rdfs:comment 'Union local or jurisdiction governing this work location, if applicable. Determines collective bargaining agreement (CBA) applicability, wage rates, and work rules.' ;
    rdfs:domain ind:OrderLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Flag indicating whether formal approval is required for this extension. Typically true for extensions with rate changes or significant duration.' ;
    rdfs:domain ind:OrderExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:benefitsEligibilityChange rdf:type rdf:Property ;
    rdfs:label 'Benefits Eligibility Change' ;
    rdfs:comment 'Flag indicating whether this extension triggers a change in the workers benefits eligibility status (e.g., crossing ACA threshold, tenure-based benefits).' ;
    rdfs:domain ind:OrderExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extendedBillRate rdf:type rdf:Property ;
    rdfs:label 'Extended Bill Rate' ;
    rdfs:comment 'The bill rate charged to the client for the extended assignment period. May differ from the original bill rate if rate changes are negotiated.' ;
    rdfs:domain ind:OrderExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extendedMarkupPercentage rdf:type rdf:Property ;
    rdfs:label 'Extended Markup Percentage' ;
    rdfs:comment 'The markup percentage (bill rate minus pay rate divided by pay rate) for the extended period. Key profitability metric.' ;
    rdfs:domain ind:OrderExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extendedPayRate rdf:type rdf:Property ;
    rdfs:label 'Extended Pay Rate' ;
    rdfs:comment 'The pay rate paid to the worker for the extended assignment period. May differ from the original pay rate due to tenure increases or renegotiation.' ;
    rdfs:domain ind:OrderExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extendedSpread rdf:type rdf:Property ;
    rdfs:label 'Extended Spread' ;
    rdfs:comment 'The gross margin spread (bill rate minus pay rate) for the extended period. Represents gross profit per hour or unit.' ;
    rdfs:domain ind:OrderExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extensionApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Extension Approval Date' ;
    rdfs:comment 'Date when the extension request was formally approved by the authorized approver. Nullable if not yet approved or if rejected.' ;
    rdfs:domain ind:OrderExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionDurationDays rdf:type rdf:Property ;
    rdfs:label 'Extension Duration Days' ;
    rdfs:comment 'Length of the extension period expressed in calendar days. Provides granular duration measurement for short-term extensions.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:extensionDurationWeeks rdf:type rdf:Property ;
    rdfs:label 'Extension Duration Weeks' ;
    rdfs:comment 'Length of the extension period expressed in weeks. Calculated as the difference between extension end date and extension start date.' ;
    rdfs:domain ind:OrderExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Extension End Date' ;
    rdfs:comment 'New end date for the assignment after the extension is applied. Replaces the previous assignment end date.' ;
    rdfs:domain ind:OrderExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionNumber rdf:type rdf:Property ;
    rdfs:label 'Extension Number' ;
    rdfs:comment 'Business-readable identifier for this extension event. Typically sequential or formatted per business rules (e.g., EXT-2024-00123).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionReason rdf:type rdf:Property ;
    rdfs:label 'Extension Reason' ;
    rdfs:comment 'Business reason or justification for the assignment extension. Captures why the client or business requested the extension.' ;
    rdfs:domain ind:OrderExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionReasonNotes rdf:type rdf:Property ;
    rdfs:label 'Extension Reason Notes' ;
    rdfs:comment 'Free-text detailed explanation or additional context for the extension reason. Captures business justification and client feedback.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionRequestDate rdf:type rdf:Property ;
    rdfs:label 'Extension Request Date' ;
    rdfs:comment 'Date when the extension was formally requested by the client or internal stakeholder. Marks the beginning of the extension lifecycle.' ;
    rdfs:domain ind:OrderExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Extension Sequence Number' ;
    rdfs:comment 'Sequential number indicating which extension this is for the placement (1st extension, 2nd extension, etc.). Tracks extension history.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:extensionStartDate rdf:type rdf:Property ;
    rdfs:label 'Extension Start Date' ;
    rdfs:comment 'Effective start date of the extended assignment period. Typically the day after the original assignment end date.' ;
    rdfs:domain ind:OrderExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionStatus rdf:type rdf:Property ;
    rdfs:label 'Extension Status' ;
    rdfs:comment 'Current lifecycle status of the extension request. Tracks the extension from initial request through approval and activation. [ENUM-REF-CANDIDATE: requested|pending_approval|approved|rejected|cancelled|active|completed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalEndDate rdf:type rdf:Property ;
    rdfs:label 'Original End Date' ;
    rdfs:comment 'The original scheduled end date of the assignment before this extension was applied. Used for comparison and duration calculation.' ;
    rdfs:domain ind:OrderExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalPayRate rdf:type rdf:Property ;
    rdfs:label 'Original Pay Rate' ;
    rdfs:comment 'The pay rate that was in effect before this extension. Used for comparison and rate change analysis.' ;
    rdfs:domain ind:OrderExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedRevenueImpact rdf:type rdf:Property ;
    rdfs:label 'Projected Revenue Impact' ;
    rdfs:comment 'Estimated additional revenue generated by this extension. Calculated based on extended duration and bill rate for forecasting purposes.' ;
    rdfs:domain ind:OrderExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateChangeIndicator rdf:type rdf:Property ;
    rdfs:label 'Rate Change Indicator' ;
    rdfs:comment 'Flag indicating whether the bill rate or pay rate changed as part of this extension. True if either rate differs from the original.' ;
    rdfs:domain ind:OrderExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tempToPermConversionReset rdf:type rdf:Property ;
    rdfs:label 'Temp To Perm Conversion Reset' ;
    rdfs:comment 'Flag indicating whether this extension resets the temp-to-perm conversion eligibility clock. Important for conversion fee calculation and worker expectations.' ;
    rdfs:domain ind:OrderExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vmsExtensionCode rdf:type rdf:Property ;
    rdfs:label 'Vms Extension Code' ;
    rdfs:comment 'External identifier for this extension in the clients VMS platform (e.g., Beeline). Used for system integration and reconciliation.' ;
    rdfs:domain ind:OrderExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCategoryJobCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Category Job Category Id' ;
    rdfs:comment 'Reference to a parent job category for hierarchical classification structures, enabling multi-level workforce taxonomy.' ;
    rdfs:domain ind:JobCategory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobCategory .

ind:parentJobCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Job Category Id' ;
    rdfs:comment 'Self-referencing FK on job_category (parent_job_category_id)' ;
    rdfs:domain ind:JobCategory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobCategory .

ind:averageBillRate rdf:type rdf:Property ;
    rdfs:label 'Average Bill Rate' ;
    rdfs:comment 'Average bill rate for positions in this category, used for rate card development, client proposals, and margin analysis.' ;
    rdfs:domain ind:JobCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averagePayRate rdf:type rdf:Property ;
    rdfs:label 'Average Pay Rate' ;
    rdfs:comment 'Average pay rate for workers in this category, supporting candidate compensation discussions and gross margin planning.' ;
    rdfs:domain ind:JobCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageTtfDays rdf:type rdf:Property ;
    rdfs:label 'Average Ttf Days' ;
    rdfs:comment 'Historical average time to fill positions in this category, used for SLA target setting and client expectation management.' ;
    rdfs:domain ind:JobCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bgcRequirementLevel rdf:type rdf:Property ;
    rdfs:label 'Bgc Requirement Level' ;
    rdfs:comment 'Typical background check depth required for this category, aligning with client risk tolerance and regulatory requirements.' ;
    rdfs:domain ind:JobCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationCommonlyRequired rdf:type rdf:Property ;
    rdfs:label 'Certification Commonly Required' ;
    rdfs:comment 'Professional certifications or licenses commonly required or preferred for this category (e.g., PMP, CPA, RN, CDL), supporting credentialing and compliance workflows.' ;
    rdfs:domain ind:JobCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eeocJobCategory rdf:type rdf:Property ;
    rdfs:label 'Eeoc Job Category' ;
    rdfs:comment 'EEOC EEO-1 reporting category for this job classification, required for federal contractor compliance and diversity reporting. [ENUM-REF-CANDIDATE: executive|professional|technician|sales|administrative|craft|operative|laborer|service — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobCategoryStatus rdf:type rdf:Property ;
    rdfs:label 'Job Category Status' ;
    rdfs:comment 'Current lifecycle status of the job category reference record, controlling availability for new requisition creation.' ;
    rdfs:domain ind:JobCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobFamily rdf:type rdf:Property ;
    rdfs:label 'Job Family' ;
    rdfs:comment 'Broader occupational grouping or job family that this category belongs to, enabling hierarchical classification and workforce planning analytics.' ;
    rdfs:domain ind:JobCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onetCode rdf:type rdf:Property ;
    rdfs:label 'Onet Code' ;
    rdfs:comment 'O*NET occupational code providing detailed occupational information for skills matching, job analysis, and candidate assessment alignment.' ;
    rdfs:domain ind:JobCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalDemandsLevel rdf:type rdf:Property ;
    rdfs:label 'Physical Demands Level' ;
    rdfs:comment 'Typical physical demand classification for roles in this category per DOL standards, relevant for ADA compliance and workers compensation classification.' ;
    rdfs:domain ind:JobCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteWorkEligible rdf:type rdf:Property ;
    rdfs:label 'Remote Work Eligible' ;
    rdfs:comment 'Indicates whether positions in this category are typically eligible for remote or hybrid work arrangements, supporting modern workforce planning.' ;
    rdfs:domain ind:JobCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Display sequence number for presenting job categories in user interfaces and reports, supporting consistent user experience.' ;
    rdfs:domain ind:JobCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierDiversityEligible rdf:type rdf:Property ;
    rdfs:label 'Supplier Diversity Eligible' ;
    rdfs:comment 'Indicates whether this category is typically included in supplier diversity programs and MSP diversity spend tracking.' ;
    rdfs:domain ind:JobCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:travelRequirementTypical rdf:type rdf:Property ;
    rdfs:label 'Travel Requirement Typical' ;
    rdfs:comment 'Typical travel expectation for roles in this category, informing candidate expectations and per diem eligibility.' ;
    rdfs:domain ind:JobCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Typical Education Level' ;
    rdfs:comment 'Standard education level typically required for positions in this category, guiding candidate qualification assessments. [ENUM-REF-CANDIDATE: high_school|associate|bachelor|master|doctorate|professional|certification|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:JobCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalEmploymentType rdf:type rdf:Property ;
    rdfs:label 'Typical Employment Type' ;
    rdfs:comment 'Most common employment classification for roles in this category, guiding recruiters on typical engagement models and client expectations.' ;
    rdfs:domain ind:JobCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalMarkupPercentage rdf:type rdf:Property ;
    rdfs:label 'Typical Markup Percentage' ;
    rdfs:comment 'Average markup percentage (bill rate minus pay rate divided by pay rate) for this category, used for pricing strategy and margin target setting.' ;
    rdfs:domain ind:JobCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalMinExperienceYears rdf:type rdf:Property ;
    rdfs:label 'Typical Min Experience Years' ;
    rdfs:comment 'Standard minimum years of experience expected for roles in this category, used as a baseline for requisition creation and candidate screening.' ;
    rdfs:domain ind:JobCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unionEligible rdf:type rdf:Property ;
    rdfs:label 'Union Eligible' ;
    rdfs:comment 'Indicates whether positions in this category are typically eligible for union representation, affecting placement terms and labor relations.' ;
    rdfs:domain ind:JobCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vmsCategoryMapping rdf:type rdf:Property ;
    rdfs:label 'Vms Category Mapping' ;
    rdfs:comment 'Standard category code or name used in major VMS platforms (Beeline, Fieldglass, etc.) for integration and order distribution.' ;
    rdfs:domain ind:JobCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisedHeadcountPlanId rdf:type rdf:Property ;
    rdfs:label 'Revised Headcount Plan Id' ;
    rdfs:comment 'Self-referencing FK on headcount_plan (revised_headcount_plan_id)' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HeadcountPlan .

ind:currentFilledHeadcount rdf:type rdf:Property ;
    rdfs:label 'Current Filled Headcount' ;
    rdfs:comment 'The current number of FTE positions that have been filled and are actively working. Real-time fulfillment metric.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year for which this headcount plan is defined. Used for annual planning and budget alignment.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ftePercentage rdf:type rdf:Property ;
    rdfs:label 'Fte Percentage' ;
    rdfs:comment 'The percentage of full-time work represented by each position in this plan. Used for part-time or fractional FTE planning.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumHeadcount rdf:type rdf:Property ;
    rdfs:label 'Maximum Headcount' ;
    rdfs:comment 'The maximum allowable number of FTE positions under this plan. Ceiling threshold based on budget or client constraints.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumHeadcount rdf:type rdf:Property ;
    rdfs:label 'Minimum Headcount' ;
    rdfs:comment 'The minimum acceptable number of FTE positions required to meet operational commitments. Floor threshold for workforce planning.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Descriptive name of the headcount plan, typically indicating the client program, fiscal period, or strategic initiative.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Business identifier for the headcount plan. Human-readable unique code used for tracking and reporting purposes.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the headcount plan. Tracks progression from draft through approval to active execution and eventual closure. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|suspended|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the headcount plan based on planning horizon and purpose. Determines planning cycle and refresh frequency.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period End Date' ;
    rdfs:comment 'The end date of the planning period covered by this headcount plan. Defines the conclusion of the workforce planning horizon.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period Start Date' ;
    rdfs:comment 'The start date of the planning period covered by this headcount plan. Defines the beginning of the workforce planning horizon.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remainingHeadcount rdf:type rdf:Property ;
    rdfs:label 'Remaining Headcount' ;
    rdfs:comment 'The number of FTE positions still to be filled to meet the target headcount. Calculated as target minus current filled.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetBillRate rdf:type rdf:Property ;
    rdfs:label 'Target Bill Rate' ;
    rdfs:comment 'The planned bill rate to be charged to the client for positions under this headcount plan. Used for revenue forecasting.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetGrossMarginPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Gross Margin Percentage' ;
    rdfs:comment 'The planned gross margin percentage (bill rate minus pay rate divided by bill rate) for this headcount plan. Alternative profitability metric.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMarkupPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Markup Percentage' ;
    rdfs:comment 'The planned markup percentage (bill rate minus pay rate divided by pay rate) for this headcount plan. Key profitability metric.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetPayRate rdf:type rdf:Property ;
    rdfs:label 'Target Pay Rate' ;
    rdfs:comment 'The planned pay rate to be paid to workers for positions under this headcount plan. Used for cost forecasting.' ;
    rdfs:domain ind:HeadcountPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supervisorId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Id' ;
    rdfs:comment 'Foreign key linking to placement.supervisor. Business justification: Assignment currently has supervisor_name and supervisor_email as denormalized text fields. The supervisor product is the authoritative source for client-side supervisor information (contact details, a' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supervisor .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'The date the assignment actually ended, which may differ from the scheduled end date due to early termination, extension, or conversion. Null if the assignment is still active. Used for fall-off rate and tenure analytics.' ;
    rdfs:domain ind:Placement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bullhornPlacementReference rdf:type rdf:Property ;
    rdfs:label 'Bullhorn Placement Reference' ;
    rdfs:comment 'The externally-known placement record identifier from the Bullhorn ATS/CRM system of record. Used for cross-system reconciliation and audit traceability back to the source ATS.' ;
    rdfs:domain ind:Placement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'The date on which a temp-to-perm or contract-to-hire worker was formally converted to a permanent employee of the client. Null if no conversion has occurred. Triggers conversion fee billing and assignment status change to converted.' ;
    rdfs:domain ind:Placement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'The clients internal cost center or department code to which the workers costs are allocated. Used for client billing, PO matching, and workforce cost allocation reporting in the clients ERP system.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endReason rdf:type rdf:Property ;
    rdfs:label 'End Reason' ;
    rdfs:comment 'The reason code for why the assignment ended. Used for fall-off rate analysis, quality of service reporting, and client relationship management. [ENUM-REF-CANDIDATE: assignment_completed|client_terminated|worker_resigned|converted_to_perm|cancelled|no_show — promote to reference product if additional values are needed]' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRedeploymentEligible rdf:type rdf:Property ;
    rdfs:label 'Is Redeployment Eligible' ;
    rdfs:comment 'Indicates whether the worker is eligible for redeployment to another assignment upon completion of this one. Used by recruiters to proactively manage bench workers and reduce time-to-fill on new requisitions.' ;
    rdfs:domain ind:Placement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'The originally contracted or currently scheduled end date of the assignment. Used for proactive redeployment planning, extension tracking, and workforce bench management.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Scheduled Hours Per Week' ;
    rdfs:comment 'The standard number of hours per week the worker is scheduled to work on this assignment. Used for FTE calculation, workforce planning, and prorated billing. Typically 40 for full-time placements.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryReplacementPlacementDirectHireId rdf:type rdf:Property ;
    rdfs:label 'Primary Replacement Placement Direct Hire Id' ;
    rdfs:comment 'Reference to the new direct hire placement record created to fulfill the replacement obligation after a fall-off. Null if no replacement has been initiated. Enables tracking of replacement lineage and fall-off resolution.' ;
    rdfs:domain ind:DirectHire ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DirectHire .

ind:baseSalary rdf:type rdf:Property ;
    rdfs:label 'Base Salary' ;
    rdfs:comment 'The annual base salary (in USD) agreed upon for the permanent placement. Used as the basis for conversion fee calculation (fee_percentage × base_salary). Classified as confidential financial data. MONETARY_TRIPLET component per TRANSACTION_HEADER canonical role.' ;
    rdfs:domain ind:DirectHire ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Conversion Fee Amount' ;
    rdfs:comment 'The gross dollar amount of the placement fee charged to the client for the direct hire engagement. Typically calculated as fee_percentage × base_salary. This is the primary revenue line for direct hire placements. MONETARY_TRIPLET component per TRANSACTION_HEADER canonical role.' ;
    rdfs:domain ind:DirectHire ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeCollected rdf:type rdf:Property ;
    rdfs:label 'Fee Collected' ;
    rdfs:comment 'Indicates whether the conversion fee has been fully collected (payment received) from the client for this direct hire placement. Used for cash flow reporting and accounts receivable aging analysis.' ;
    rdfs:domain ind:DirectHire ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeInvoiced rdf:type rdf:Property ;
    rdfs:label 'Fee Invoiced' ;
    rdfs:comment 'Indicates whether the conversion fee invoice has been generated and sent to the client for this direct hire placement. Used to track billing completeness and revenue recognition readiness.' ;
    rdfs:domain ind:DirectHire ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feePaymentTerms rdf:type rdf:Property ;
    rdfs:label 'Fee Payment Terms' ;
    rdfs:comment 'The agreed-upon payment terms for the conversion fee invoice. Defines when the client is obligated to remit payment after the placement start date or invoice date. Sourced from the client MSA.' ;
    rdfs:domain ind:DirectHire ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementNumber rdf:type rdf:Property ;
    rdfs:label 'Placement Number' ;
    rdfs:comment 'Human-readable, externally-known business identifier for this direct hire placement record (e.g., DH-2024-00123). Used in client communications, invoicing, and reporting. BUSINESS_IDENTIFIER per TRANSACTION_HEADER canonical role.' ;
    rdfs:domain ind:DirectHire ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementStatus rdf:type rdf:Property ;
    rdfs:label 'Placement Status' ;
    rdfs:comment 'Current lifecycle state of the direct hire placement. Tracks the progression from offer through active employment or fall-off. LIFECYCLE_STATUS per TRANSACTION_HEADER canonical role. Values: offered (offer extended to candidate), accepted (candidate accepted offer), started (candidate began employment), fell_off (candidate did not start or left within guarantee period), replaced (replacement candidate provided per guarantee obligation).' ;
    rdfs:domain ind:DirectHire ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementObligation rdf:type rdf:Property ;
    rdfs:label 'Replacement Obligation' ;
    rdfs:comment 'Indicates whether the staffing firm is currently obligated to provide a free replacement candidate due to a fall-off within the guarantee period. True when placement_status is fell_off and the guarantee period has not expired.' ;
    rdfs:domain ind:Placement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salaryCurrency rdf:type rdf:Property ;
    rdfs:label 'Salary Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the base salary (e.g., USD, CAD, GBP). Supports multi-currency operations for international placements. MONETARY_TRIPLET component per TRANSACTION_HEADER canonical role.' ;
    rdfs:domain ind:DirectHire ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Assignment Id' ;
    rdfs:comment 'Reference to the parent temporary or contract assignment record that is being extended. Core linkage to the placement assignment lifecycle.' ;
    rdfs:domain ind:Placement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assignment .

ind:bullhornExtensionReference rdf:type rdf:Property ;
    rdfs:label 'Bullhorn Extension Reference' ;
    rdfs:comment 'The native record identifier assigned to this extension event in the Bullhorn ATS/CRM source system. Used for data lineage, reconciliation, and cross-system traceability between the lakehouse silver layer and the operational system of record.' ;
    rdfs:domain ind:AssignmentExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientApproverEmail rdf:type rdf:Property ;
    rdfs:label 'Client Approver Email' ;
    rdfs:comment 'Email address of the client-side manager or supervisor who authorized the extension. Used for extension confirmation communications and audit trail.' ;
    rdfs:domain ind:AssignmentExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Conversion Eligible Flag' ;
    rdfs:comment 'Indicates whether the worker becomes eligible for temp-to-perm conversion upon completion of the extended assignment period. Triggers conversion fee tracking and direct hire workflow.' ;
    rdfs:domain ind:AssignmentExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Extension Reason Code' ;
    rdfs:comment 'Standardized reason code categorizing why the assignment extension was requested. Supports analytics on extension drivers and workforce planning. [ENUM-REF-CANDIDATE: project_continuation|headcount_backfill|client_request|worker_request|sow_extension|other — promote to reference product]' ;
    rdfs:domain ind:AssignmentExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newEndDate rdf:type rdf:Property ;
    rdfs:label 'New End Date' ;
    rdfs:comment 'The revised assignment end date established by this extension event. Becomes the active end date on the parent assignment record upon execution. Drives redeployment planning and workforce scheduling.' ;
    rdfs:domain ind:AssignmentExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorBillRate rdf:type rdf:Property ;
    rdfs:label 'Prior Bill Rate' ;
    rdfs:comment 'The hourly bill rate charged to the client that was in effect on the assignment immediately before this extension event. Stored for rate change audit and spread analysis.' ;
    rdfs:domain ind:AssignmentExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorEndDate rdf:type rdf:Property ;
    rdfs:label 'Prior End Date' ;
    rdfs:comment 'The assignment end date that was in effect immediately before this extension event was applied. Critical for auditing the extension history and calculating the duration of each extension increment.' ;
    rdfs:domain ind:AssignmentExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorPayRate rdf:type rdf:Property ;
    rdfs:label 'Prior Pay Rate' ;
    rdfs:comment 'The hourly pay rate paid to the worker that was in effect on the assignment immediately before this extension event. Stored for rate change audit and gross margin analysis.' ;
    rdfs:domain ind:AssignmentExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Rate Change Flag' ;
    rdfs:comment 'Indicates whether this extension event included a renegotiation of the bill rate or pay rate. True when either revised_bill_rate or revised_pay_rate differs from the prior rate. Enables quick filtering of rate-change extensions for financial impact analysis.' ;
    rdfs:domain ind:AssignmentExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:redeploymentCandidateFlag rdf:type rdf:Property ;
    rdfs:label 'Redeployment Candidate Flag' ;
    rdfs:comment 'Indicates whether the worker has been flagged for redeployment planning as part of this extension review. True when the extension is not approved or when the new end date triggers a redeployment workflow.' ;
    rdfs:domain ind:Placement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'The business date on which the extension request was formally submitted by the client or staffing coordinator. Used to measure lead time and SLA compliance for extension processing.' ;
    rdfs:domain ind:AssignmentExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisedBillRate rdf:type rdf:Property ;
    rdfs:label 'Revised Bill Rate' ;
    rdfs:comment 'The renegotiated hourly bill rate to be charged to the client effective upon execution of this extension. Null if the bill rate was not renegotiated as part of this extension event.' ;
    rdfs:domain ind:AssignmentExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisedPayRate rdf:type rdf:Property ;
    rdfs:label 'Revised Pay Rate' ;
    rdfs:comment 'The renegotiated hourly pay rate to be paid to the worker effective upon execution of this extension. Null if the pay rate was not renegotiated as part of this extension event.' ;
    rdfs:domain ind:AssignmentExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spreadPrior rdf:type rdf:Property ;
    rdfs:label 'Spread Prior' ;
    rdfs:comment 'The gross spread (bill rate minus pay rate) in effect on the assignment before this extension event. Stored as a business field to support margin trend analysis across extension history without requiring rate arithmetic at query time.' ;
    rdfs:domain ind:AssignmentExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spreadRevised rdf:type rdf:Property ;
    rdfs:label 'Spread Revised' ;
    rdfs:comment 'The gross spread (revised bill rate minus revised pay rate) applicable after this extension event. Null if no rate change occurred. Supports margin impact analysis for renegotiated extensions.' ;
    rdfs:domain ind:AssignmentExtension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replacementConversionId rdf:type rdf:Property ;
    rdfs:label 'Replacement Conversion Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the replacement conversion record created when a fell-off conversion is replaced within the guarantee period. Enables tracking of replacement chains and guarantee fulfillment.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Conversion .

ind:resultingDirectHireId rdf:type rdf:Property ;
    rdfs:label 'Resulting Direct Hire Id' ;
    rdfs:comment 'Foreign key linking to placement.direct_hire. Business justification: A temp-to-perm or contract-to-hire conversion event (conversion) results in the creation of a direct hire placement record (direct_hire). This is a core business lifecycle event in staffing: the conve' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DirectHire .

ind:actualHoursWorked rdf:type rdf:Property ;
    rdfs:label 'Actual Hours Worked' ;
    rdfs:comment 'Total billable hours worked by the temporary worker on the original assignment prior to the conversion date. Used to validate minimum tenure hour thresholds for fee waiver eligibility and for conversion rate analytics.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bullhornConversionReference rdf:type rdf:Property ;
    rdfs:label 'Bullhorn Conversion Reference' ;
    rdfs:comment 'External identifier assigned by Bullhorn ATS/CRM to the placement conversion workflow record. Used for system-of-record traceability and reconciliation with the source system.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientConfirmationDate rdf:type rdf:Property ;
    rdfs:label 'Client Confirmation Date' ;
    rdfs:comment 'The date on which the client formally confirmed the conversion hire in writing or via the system. Triggers the conversion fee billing process in Salesforce Revenue Cloud.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conversionStatus rdf:type rdf:Property ;
    rdfs:label 'Conversion Status' ;
    rdfs:comment 'Current lifecycle state of the conversion event. pending = conversion initiated but not yet confirmed by client; confirmed = client has confirmed the hire; invoiced = conversion fee invoice has been issued; fell_off = conversion did not complete (fall-off event); cancelled = conversion was voided.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionType rdf:type rdf:Property ;
    rdfs:label 'Conversion Type' ;
    rdfs:comment 'Classifies the nature of the conversion event. temp_to_perm indicates a temporary worker transitioning to permanent employment; contract_to_hire (CTH) indicates a contract worker being hired directly; direct_conversion covers other direct placement conversions.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:convertedWorkerAnnualSalary rdf:type rdf:Property ;
    rdfs:label 'Converted Worker Annual Salary' ;
    rdfs:comment 'The first-year annual base salary agreed upon for the converted worker in their new permanent role with the client. Used as the basis for percentage-based conversion fee calculations. Sourced from client confirmation documentation.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeBasisType rdf:type rdf:Property ;
    rdfs:label 'Fee Basis Type' ;
    rdfs:comment 'Indicates the method used to calculate the conversion fee. percentage_of_salary = fee is a percentage of the converted workers first-year annual salary; flat_fee = fixed dollar amount per the MSA rate card; negotiated = custom fee agreed upon for this specific conversion.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCurrency rdf:type rdf:Property ;
    rdfs:label 'Fee Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the conversion fee amount (e.g., USD, CAD, GBP). Supports multi-currency operations for international staffing engagements.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeWaiverApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Fee Waiver Approved By' ;
    rdfs:comment 'Name or identifier of the internal approver (e.g., account manager, branch manager, or VP) who authorized the conversion fee waiver. Required for audit and revenue exception tracking.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeWaiverFlag rdf:type rdf:Property ;
    rdfs:label 'Fee Waiver Flag' ;
    rdfs:comment 'Indicates whether the conversion fee has been waived for this conversion event. True = fee waived; False = fee applies. Fee waivers may occur due to MSA terms, client relationship considerations, or minimum tenure provisions.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeWaiverReason rdf:type rdf:Property ;
    rdfs:label 'Fee Waiver Reason' ;
    rdfs:comment 'The business reason for waiving the conversion fee when fee_waiver_flag is True. msa_tenure_clause = worker met minimum tenure hours per MSA; client_relationship = strategic client concession; negotiated_waiver = pre-negotiated waiver in contract; minimum_hours_met = minimum billable hours threshold reached; other = other documented reason.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumTenureHours rdf:type rdf:Property ;
    rdfs:label 'Minimum Tenure Hours' ;
    rdfs:comment 'The minimum number of billable hours the temporary worker must have worked on the assignment before the conversion fee is waived per the MSA terms. Used to determine fee_waiver_flag eligibility when fee_waiver_reason is minimum_hours_met.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permanentStartDate rdf:type rdf:Property ;
    rdfs:label 'Permanent Start Date' ;
    rdfs:comment 'The date on which the converted worker officially begins permanent employment with the client. May differ from conversion_date if there is a gap between conversion confirmation and the first day of permanent employment.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStatusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Assignment Status History Id' ;
    rdfs:comment 'Unique surrogate identifier for each assignment status history record. Primary key for this audit trail entity. Role: EVENT_LOG — append-only record of immutable status transition events for worker assignments.' ;
    rdfs:domain ind:AssignmentStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualTransitionHours rdf:type rdf:Property ;
    rdfs:label 'Actual Transition Hours' ;
    rdfs:comment 'The actual elapsed time in hours between the triggering business event and this status transition. Compared against sla_target_hours to determine SLA compliance. Supports TTF and TTS metric calculation in Power BI Analytics dashboards.' ;
    rdfs:domain ind:AssignmentStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Change Reason Code' ;
    rdfs:comment 'Standardized reason code explaining why the status transition occurred. Drives fall-off rate analysis, redeployment eligibility, and regulatory reporting. Values: voluntary_resignation, client_termination, assignment_end, extension_approved, no_show, fall_off, conversion. [ENUM-REF-CANDIDATE: voluntary_resignation|client_termination|assignment_end|extension_approved|no_show|fall_off|conversion|medical_leave|performance|background_check_fail — promote to reference product]' ;
    rdfs:domain ind:AssignmentStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Change Reason Description' ;
    rdfs:comment 'Free-text narrative providing additional context for the status transition beyond the standardized change_reason_code. Captures recruiter or account manager notes entered at the time of the change. Supports regulatory audit and dispute resolution.' ;
    rdfs:domain ind:AssignmentStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientContactNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Client Contact Notified Flag' ;
    rdfs:comment 'Indicates whether the client contact (hiring manager or program manager) was notified of this status transition. Critical for client relationship management and SLA compliance evidence, particularly for fall-off and cancellation events.' ;
    rdfs:domain ind:AssignmentStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Hold Flag' ;
    rdfs:comment 'Indicates whether this status transition was triggered by or resulted in a compliance hold — for example, a failed background check (BGC), incomplete I-9 verification, E-Verify mismatch, or missing credentialing. Links to compliance domain for regulatory audit.' ;
    rdfs:domain ind:AssignmentStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConversion rdf:type rdf:Property ;
    rdfs:label 'Is Conversion' ;
    rdfs:comment 'Flag indicating whether this status transition represents a temp-to-perm or contract-to-hire conversion event, where the temporary worker is being converted to a permanent employee of the client. Triggers conversion fee billing processes.' ;
    rdfs:domain ind:AssignmentStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExtension rdf:type rdf:Property ;
    rdfs:label 'Is Extension' ;
    rdfs:comment 'Flag indicating whether this status transition represents an assignment extension event, where the original end date has been pushed forward. Extensions are a key revenue retention metric and trigger redeployment planning suppression.' ;
    rdfs:domain ind:AssignmentStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'The SLA target response time in hours for this specific status transition type, as defined in the clients MSA (Master Service Agreement) or VMS program configuration. Used to evaluate whether sla_breach_flag should be set.' ;
    rdfs:domain ind:AssignmentStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemEventReference rdf:type rdf:Property ;
    rdfs:label 'Source System Event Reference' ;
    rdfs:comment 'The native event or record identifier from the originating source system (e.g., Bullhorn status change event ID, Beeline VMS transaction ID). Enables exact record traceability back to the system of record for audit and reconciliation purposes.' ;
    rdfs:domain ind:AssignmentStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionSource rdf:type rdf:Property ;
    rdfs:label 'Transition Source' ;
    rdfs:comment 'Indicates how the status transition was initiated. Distinguishes between manual recruiter actions, automated system rules, VMS (Vendor Management System) sync events from Beeline, API integrations, or bulk update operations. Critical for data lineage and audit integrity.' ;
    rdfs:domain ind:AssignmentStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redeploymentId rdf:type rdf:Property ;
    rdfs:label 'Redeployment Id' ;
    rdfs:comment 'Unique system-generated identifier for each redeployment event record. Primary key for the redeployment data product within the placement domain. Entity role: TRANSACTION_HEADER — tracks a discrete lifecycle event of a worker transitioning off an assignment into the redeployment pipeline.' ;
    rdfs:domain ind:Redeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redeploymentClientAccountId rdf:type rdf:Property ;
    rdfs:label 'Redeployment Client Account Id' ;
    rdfs:comment 'Reference to the client account associated with the ending assignment. Used to track which client the worker is departing from and to identify potential redeployment opportunities within the same client account.' ;
    rdfs:domain ind:Redeployment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientAccount .

ind:targetClientClientAccountId rdf:type rdf:Property ;
    rdfs:label 'Target Client Client Account Id' ;
    rdfs:comment 'Reference to the client account being targeted for the workers next placement during the redeployment process. Null until a specific client opportunity is identified.' ;
    rdfs:domain ind:Redeployment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientAccount .

ind:targetPlacementAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Target Placement Assignment Id' ;
    rdfs:comment 'Reference to the new placement record created as the successful outcome of this redeployment event. Null until the worker is successfully redeployed to a new assignment.' ;
    rdfs:domain ind:Redeployment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assignment .

ind:actualRedeployDate rdf:type rdf:Property ;
    rdfs:label 'Actual Redeploy Date' ;
    rdfs:comment 'The date on which the worker was successfully placed on a new assignment or converted. Null until redeployment outcome is achieved. Used to calculate actual time-to-redeploy against the target.' ;
    rdfs:domain ind:Redeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:benchCostRisk rdf:type rdf:Property ;
    rdfs:label 'Bench Cost Risk' ;
    rdfs:comment 'Estimated financial exposure (in pay_rate_currency) associated with the worker remaining on bench, calculated as the workers pay rate multiplied by projected bench days. Stored as a point-in-time snapshot for financial risk reporting. Confidential financial data.' ;
    rdfs:domain ind:Redeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interviewsCount rdf:type rdf:Property ;
    rdfs:label 'Interviews Count' ;
    rdfs:comment 'Number of client interviews the worker attended during this redeployment event. Used to measure conversion rate from submittal to interview and assess redeployment pipeline health.' ;
    rdfs:domain ind:Redeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastOutreachDate rdf:type rdf:Property ;
    rdfs:label 'Last Outreach Date' ;
    rdfs:comment 'The most recent date on which the coordinator made contact or attempted contact with the worker regarding redeployment opportunities. Used to identify stale redeployment records requiring follow-up.' ;
    rdfs:domain ind:Redeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outreachAttempts rdf:type rdf:Property ;
    rdfs:label 'Outreach Attempts' ;
    rdfs:comment 'Count of coordinator contact attempts made to the worker during the redeployment process (calls, emails, texts). Used to measure engagement effort and trigger escalation workflows when thresholds are exceeded.' ;
    rdfs:domain ind:Redeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredLocation rdf:type rdf:Property ;
    rdfs:label 'Preferred Location' ;
    rdfs:comment 'The workers preferred geographic area or city/state for their next assignment. Free-text or structured location string used by coordinators to filter and match available job orders during redeployment outreach.' ;
    rdfs:domain ind:Redeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredWorkState rdf:type rdf:Property ;
    rdfs:label 'Preferred Work State' ;
    rdfs:comment 'Two-letter US state code representing the workers preferred state for redeployment. Used for geographic filtering in job order matching and workforce planning analytics.' ;
    rdfs:domain ind:Redeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySkill rdf:type rdf:Property ;
    rdfs:label 'Primary Skill' ;
    rdfs:comment 'The workers primary professional skill or job title used as the lead matching criterion during redeployment job order search. Sourced from the candidate profile in Bullhorn ATS.' ;
    rdfs:domain ind:Redeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redeploymentNumber rdf:type rdf:Property ;
    rdfs:label 'Redeployment Number' ;
    rdfs:comment 'Externally-visible business identifier for this redeployment event, used in coordinator workflows, reporting, and communications. Format: RDP- followed by 7 digits. Serves as the BUSINESS_IDENTIFIER for the TRANSACTION_HEADER role.' ;
    rdfs:domain ind:Redeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redeploymentSource rdf:type rdf:Property ;
    rdfs:label 'Redeployment Source' ;
    rdfs:comment 'Indicates how this redeployment record was created. bullhorn_workflow = auto-generated by Bullhorn redeployment workflow trigger; manual_entry = coordinator manually created; vms_notification = triggered by Beeline VMS assignment end notification; coordinator_initiated = proactive coordinator action; system_auto = automated rule-based creation.' ;
    rdfs:domain ind:Redeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redeploymentStatus rdf:type rdf:Property ;
    rdfs:label 'Redeployment Status' ;
    rdfs:comment 'Current lifecycle state of the redeployment event. bench = worker is unassigned and available; in_process = active outreach and submittal activity underway; redeployed = successfully placed on a new assignment; converted = temp-to-perm conversion occurred; separated = worker exited the workforce pool. Serves as the LIFECYCLE_STATUS for the TRANSACTION_HEADER role.' ;
    rdfs:domain ind:Redeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redeploymentType rdf:type rdf:Property ;
    rdfs:label 'Redeployment Type' ;
    rdfs:comment 'Classification of the redeployment pathway. internal_transfer = moved to another assignment within same client; new_client = placed with a different client; temp_to_perm = converted to permanent hire; contract_extension = existing assignment extended; reactivation = previously separated worker re-engaged.' ;
    rdfs:domain ind:Redeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteEligible rdf:type rdf:Property ;
    rdfs:label 'Remote Eligible' ;
    rdfs:comment 'Indicates whether the worker is eligible and willing to accept a fully remote or hybrid assignment. Used to expand redeployment matching to remote job orders.' ;
    rdfs:domain ind:Redeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:separationReason rdf:type rdf:Property ;
    rdfs:label 'Separation Reason' ;
    rdfs:comment 'Reason code for why the worker separated from the workforce pool when redeployment_outcome is separated. Used for fall-off rate analysis and workforce retention reporting. [ENUM-REF-CANDIDATE: voluntary_resignation|involuntary_termination|retirement|contract_end|declined_opportunities|no_response|other — promote to reference product]' ;
    rdfs:domain ind:Redeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source System Record Reference' ;
    rdfs:comment 'The native identifier of this redeployment record in the originating source system (Bullhorn ATS/CRM). Enables traceability back to the operational system of record for reconciliation and lineage purposes.' ;
    rdfs:domain ind:Redeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittalsCount rdf:type rdf:Property ;
    rdfs:label 'Submittals Count' ;
    rdfs:comment 'Number of candidate submittals made to client job orders during this redeployment event. Tracks the volume of active placement attempts and supports QoS (Quality of Submission) analytics.' ;
    rdfs:domain ind:Redeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetRedeployDate rdf:type rdf:Property ;
    rdfs:label 'Target Redeploy Date' ;
    rdfs:comment 'The goal date by which the coordinator aims to have the worker placed on a new assignment. Used to measure time-to-redeploy KPI performance and drive urgency in the redeployment pipeline.' ;
    rdfs:domain ind:Redeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateId rdf:type rdf:Property ;
    rdfs:label 'Rate Id' ;
    rdfs:comment 'Primary key for rate' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:directHireFeePercentage rdf:type rdf:Property ;
    rdfs:label 'Direct Hire Fee Percentage' ;
    rdfs:comment 'The percentage of the placed candidates first-year annual salary charged as the direct hire placement fee. Applicable only for direct hire and permanent placement engagements. Defined in the client MSA.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gsaRateReference rdf:type rdf:Property ;
    rdfs:label 'Gsa Rate Reference' ;
    rdfs:comment 'The IRS General Services Administration (GSA) per diem rate reference code or location identifier used to validate per diem allowances against federally published rates. Applicable for per_diem rate types to ensure IRS compliance.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holidayBillRate rdf:type rdf:Property ;
    rdfs:label 'Holiday Bill Rate' ;
    rdfs:comment 'The hourly bill rate charged to the client for hours worked on designated holidays. Defined in the client MSA or SOW and used in holiday billing calculations.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holidayPayRate rdf:type rdf:Property ;
    rdfs:label 'Holiday Pay Rate' ;
    rdfs:comment 'The hourly pay rate for hours worked on designated holidays. Defined in the workers assignment terms and used in payroll processing for holiday-worked hours.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jobClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Job Classification Code' ;
    rdfs:comment 'The occupational classification code (e.g., DOL SOC code or client-defined job category code) associated with this rate. Drives workers compensation rate assignment, FLSA exemption status, and rate card categorization.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perDiemBudgetCap rdf:type rdf:Property ;
    rdfs:label 'Per Diem Budget Cap' ;
    rdfs:comment 'The maximum total per diem budget authorized for this rate record over the assignment period. Used to enforce spending controls and flag overages in per diem reimbursement processing.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perDiemCategory rdf:type rdf:Property ;
    rdfs:label 'Per Diem Category' ;
    rdfs:comment 'Sub-classification of per diem rate type indicating the specific allowance category. Applicable only when rate_type = per_diem. Aligns with IRS GSA per diem schedule categories for tax compliance and reimbursement tracking.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perDiemDailyAllowance rdf:type rdf:Property ;
    rdfs:label 'Per Diem Daily Allowance' ;
    rdfs:comment 'The approved daily monetary allowance for the per diem category (travel, lodging, meals, or incidentals). Represents the maximum reimbursable or taxable daily amount for the applicable per diem category.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reimbursementMethod rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Method' ;
    rdfs:comment 'The method used to calculate and process per diem reimbursements. Actual expense requires receipts; flat_rate pays a fixed daily amount regardless of actual spend; gsa_rate uses the IRS GSA published rate for the work location.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unit rdf:type rdf:Property ;
    rdfs:label 'Unit' ;
    rdfs:comment 'The time or work unit basis for the bill and pay rates. Hourly is standard for temporary staffing; daily/weekly/monthly may apply to contract or SOW engagements; fixed applies to direct hire placement fees.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmsRateReference rdf:type rdf:Property ;
    rdfs:label 'Vms Rate Reference' ;
    rdfs:comment 'The external rate identifier assigned by the Beeline VMS system for this rate record. Used for cross-system reconciliation between the staffing firms internal systems and the clients VMS program.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workersCompRate rdf:type rdf:Property ;
    rdfs:label 'Workers Comp Rate' ;
    rdfs:comment 'The workers compensation insurance rate applied to this placement, expressed as a decimal percentage of payroll. Varies by job classification code and state. Used in burden rate calculation and insurance cost allocation.' ;
    rdfs:domain ind:Rate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryWorkClientLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Work Client Location Id' ;
    rdfs:comment 'Reference to the client.location master record representing the clients own site definition. Enables cross-domain linkage between the placement work location and the client domains location hierarchy.' ;
    rdfs:domain ind:WorkLocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:bgcLevel rdf:type rdf:Property ;
    rdfs:label 'Bgc Level' ;
    rdfs:comment 'Required background check (BGC) level for workers placed at this location, as defined by the clients site security policy. Drives the Sterling Background Check screening package selection during candidate onboarding.' ;
    rdfs:domain ind:WorkLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:i9VerificationMethod rdf:type rdf:Property ;
    rdfs:label 'I9 Verification Method' ;
    rdfs:comment 'Method required for I-9 Employment Eligibility Verification for workers at this location. Physical requires in-person document inspection; remote_authorized uses DHS-authorized remote verification; e_verify triggers E-Verify case creation. Drives compliance workflow in the compliance domain.' ;
    rdfs:domain ind:WorkLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Externally-known, human-readable unique business identifier for the work location (e.g., CHI-LOOP-01, NYC-MIDTOWN-02). Used in job orders, placements, and VMS programs to reference the site without relying on the surrogate key. Sourced from Bullhorn ATS/CRM and Beeline VMS site codes.' ;
    rdfs:domain ind:WorkLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Full descriptive name of the work location as recognized by the client and staffing operations (e.g., Acme Corp — Chicago Loop Office, Remote — Pacific Time Zone). Used in placement records, dispatch, and scheduling.' ;
    rdfs:domain ind:WorkLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicTransitAccessible rdf:type rdf:Property ;
    rdfs:label 'Public Transit Accessible' ;
    rdfs:comment 'Indicates whether the work location is accessible via public transportation. Used in candidate matching and placement decisions, particularly for light industrial and clerical placements where transportation access affects fill rates.' ;
    rdfs:domain ind:WorkLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remoteWorkType rdf:type rdf:Property ;
    rdfs:label 'Remote Work Type' ;
    rdfs:comment 'Designates whether the work location supports fully remote, hybrid (partial on-site), or exclusively on-site work arrangements. Drives per diem eligibility, equipment provisioning, and remote-work compliance policy application.' ;
    rdfs:domain ind:WorkLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'Primary shift pattern or schedule type supported at this work location. Used by Kronos Workforce Ready for scheduling, overtime rule application, and shift differential pay calculation.' ;
    rdfs:domain ind:WorkLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmsSiteReference rdf:type rdf:Property ;
    rdfs:label 'Vms Site Reference' ;
    rdfs:comment 'External site identifier assigned by the clients Vendor Management System (e.g., Beeline VMS) for this work location. Required for VMS-managed programs to match staffing agency location records with the clients VMS site master.' ;
    rdfs:domain ind:WorkLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerCapacity rdf:type rdf:Property ;
    rdfs:label 'Worker Capacity' ;
    rdfs:comment 'Maximum number of placed workers (headcount) that this work location can accommodate at any given time. Used for capacity planning, workforce scheduling, and headcount management in Kronos Workforce Ready and Power BI Analytics.' ;
    rdfs:domain ind:WorkLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentCheckinContact rdf:type rdf:Property ;
    rdfs:label 'Assignment Checkin Contact' ;
    rdfs:comment 'Indicates whether this supervisor is designated to receive assignment check-in communications (e.g., weekly or mid-assignment quality check calls from the staffing account manager). Supports QoS (Quality of Submission) and SLA monitoring.' ;
    rdfs:domain ind:Supervisor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentActiveAssignments rdf:type rdf:Property ;
    rdfs:label 'Current Active Assignments' ;
    rdfs:comment 'The current count of active placed worker assignments under this supervisors oversight. Maintained as an operational snapshot field sourced from Bullhorn. Used for capacity monitoring and assignment routing decisions. Not a calculated aggregate — sourced directly from the system of record.' ;
    rdfs:domain ind:Supervisor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:i9VerificationContact rdf:type rdf:Property ;
    rdfs:label 'I9 Verification Contact' ;
    rdfs:comment 'Indicates whether this supervisor is designated as the authorized representative to physically inspect I-9 (Employment Eligibility Verification) documents for workers at the client site, as permitted under INA regulations.' ;
    rdfs:domain ind:Supervisor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'ISO 639-1 two-letter language code representing the supervisors preferred communication language (e.g., en, es, fr). Used for localized communication templates in multilingual workforce programs.' ;
    rdfs:domain ind:Supervisor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDirectReports rdf:type rdf:Property ;
    rdfs:label 'Max Direct Reports' ;
    rdfs:comment 'The maximum number of placed workers (temporary or contract) this supervisor is authorized or operationally capable of overseeing simultaneously. Used for workforce planning, headcount capacity management, and assignment routing constraints.' ;
    rdfs:domain ind:Supervisor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onboardingContact rdf:type rdf:Property ;
    rdfs:label 'Onboarding Contact' ;
    rdfs:comment 'Indicates whether this supervisor serves as the primary day-one onboarding contact for newly placed workers at the work location. When True, the supervisor receives onboarding coordination communications and is listed on worker day-one instructions.' ;
    rdfs:domain ind:Supervisor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceEscalationContact rdf:type rdf:Property ;
    rdfs:label 'Performance Escalation Contact' ;
    rdfs:comment 'Indicates whether this supervisor is the designated point of contact for worker performance escalations, disciplinary issues, or early assignment termination discussions. Used in fall-off risk management workflows.' ;
    rdfs:domain ind:Supervisor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyOrientationRequired rdf:type rdf:Property ;
    rdfs:label 'Safety Orientation Required' ;
    rdfs:comment 'Indicates whether workers assigned to this supervisors site must complete a safety orientation before beginning work. Relevant for industrial, manufacturing, and warehouse placements subject to OSHA compliance requirements.' ;
    rdfs:domain ind:Supervisor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemContactReference rdf:type rdf:Property ;
    rdfs:label 'Source System Contact Reference' ;
    rdfs:comment 'The native record identifier for this supervisor in the originating source system (e.g., Bullhorn contact ID, Beeline hiring manager ID). Used for bi-directional sync, deduplication, and cross-system reconciliation.' ;
    rdfs:domain ind:Supervisor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sowAuthorityFlag rdf:type rdf:Property ;
    rdfs:label 'Sow Authority Flag' ;
    rdfs:comment 'Indicates whether this supervisor has authority to approve or manage Statement of Work (SOW) engagements in addition to standard temporary staffing assignments. Relevant for project-based and professional services placements.' ;
    rdfs:domain ind:Supervisor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisorStatus rdf:type rdf:Property ;
    rdfs:label 'Supervisor Status' ;
    rdfs:comment 'Current lifecycle status of the supervisor record. Active supervisors are eligible for assignment routing and timesheet approval. Inactive or terminated supervisors are excluded from new assignment workflows. Supports MASTER_PARTY lifecycle tracking.' ;
    rdfs:domain ind:Supervisor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorType rdf:type rdf:Property ;
    rdfs:label 'Supervisor Type' ;
    rdfs:comment 'Categorical classification of the supervisors role in overseeing placed workers. Drives routing logic for timesheet approvals, performance escalations, and onboarding workflows. Values: direct_manager (day-to-day line manager), site_supervisor (physical site oversight), project_lead (project-scoped oversight), department_head (department-level authority), vms_manager (VMS program manager).' ;
    rdfs:domain ind:Supervisor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timesheetApprovalAuthority rdf:type rdf:Property ;
    rdfs:label 'Timesheet Approval Authority' ;
    rdfs:comment 'Indicates whether this supervisor has authority to approve worker timesheets. When True, the supervisor is included in timesheet routing workflows in Kronos Workforce Ready and VMS timesheet sync. Critical for payroll processing accuracy.' ;
    rdfs:domain ind:Supervisor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vmsContactFlag rdf:type rdf:Property ;
    rdfs:label 'Vms Contact Flag' ;
    rdfs:comment 'Indicates whether this supervisor has an active profile in the clients VMS (Vendor Management System) such as Beeline. When True, the supervisors VMS user ID is used for electronic timesheet approval and requisition management.' ;
    rdfs:domain ind:Supervisor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryFallAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Fall Assignment Id' ;
    rdfs:comment 'Reference to the originating placement record from which this fall-off event was triggered. Links the fall-off to the parent placement lifecycle.' ;
    rdfs:domain ind:FallOff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assignment .

ind:bullhornFallOffReference rdf:type rdf:Property ;
    rdfs:label 'Bullhorn Fall Off Reference' ;
    rdfs:comment 'The native identifier of this fall-off event record in the Bullhorn ATS/CRM source system. Used for data lineage, reconciliation, and cross-system traceability.' ;
    rdfs:domain ind:FallOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientNotifiedDate rdf:type rdf:Property ;
    rdfs:label 'Client Notified Date' ;
    rdfs:comment 'The date on which the client was formally notified of the fall-off event. Used for SLA compliance measurement and client relationship management.' ;
    rdfs:domain ind:FallOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysToFallOff rdf:type rdf:Property ;
    rdfs:label 'Days To Fall Off' ;
    rdfs:comment 'Number of calendar days between the assignment start date and the fall-off date. Core KPI metric for fall-off rate analysis, early warning detection, and recruiter performance benchmarking.' ;
    rdfs:domain ind:FallOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fallOffNumber rdf:type rdf:Property ;
    rdfs:label 'Fall Off Number' ;
    rdfs:comment 'Human-readable business reference number for the fall-off event (e.g., FO-2024-00123). Used in client communications, SLA reporting, and operational tracking.' ;
    rdfs:domain ind:FallOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallOffStatus rdf:type rdf:Property ;
    rdfs:label 'Fall Off Status' ;
    rdfs:comment 'Current workflow status of the fall-off event record. Drives operational queues for replacement fulfillment and SLA compliance tracking.' ;
    rdfs:domain ind:FallOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Credit Amount' ;
    rdfs:comment 'The placement fee credit or refund amount issued to the client as a result of the fall-off occurring within the guarantee period. Applicable primarily to direct hire and permanent placements.' ;
    rdfs:domain ind:FallOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:placementFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Placement Fee Amount' ;
    rdfs:comment 'The original placement fee billed to the client for the placement that fell off. Used to calculate fee credit amounts and net revenue impact for direct hire and permanent placements.' ;
    rdfs:domain ind:FallOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonDetail rdf:type rdf:Property ;
    rdfs:label 'Reason Detail' ;
    rdfs:comment 'Free-text narrative providing additional context beyond the standardized reason code. Captures recruiter or account manager notes on the specific circumstances of the fall-off.' ;
    rdfs:domain ind:FallOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementDeadline rdf:type rdf:Property ;
    rdfs:label 'Replacement Deadline' ;
    rdfs:comment 'The contractual deadline by which a replacement candidate must be placed to fulfill the replacement obligation. Derived from the fall-off date and MSA replacement terms. Critical for client SLA compliance.' ;
    rdfs:domain ind:FallOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:replacementFulfilledDate rdf:type rdf:Property ;
    rdfs:label 'Replacement Fulfilled Date' ;
    rdfs:comment 'The date on which the replacement candidate successfully started the assignment, fulfilling the replacement obligation. Used to measure replacement cycle time and SLA compliance.' ;
    rdfs:domain ind:FallOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:replacementStatus rdf:type rdf:Property ;
    rdfs:label 'Replacement Status' ;
    rdfs:comment 'Current status of the replacement fulfillment obligation for this fall-off event. Tracks whether a replacement has been sourced, placed, or if the obligation was waived or failed.' ;
    rdfs:domain ind:FallOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Impact Amount' ;
    rdfs:comment 'The gross revenue amount lost or at risk due to this fall-off event, expressed in the billing currency. For direct hire placements, represents the placement fee at risk. For temporary placements, represents estimated lost billing revenue. Critical for financial impact reporting.' ;
    rdfs:domain ind:FallOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Revenue Impact Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the revenue impact amount (e.g., USD, CAD, GBP). Supports multi-currency operations.' ;
    rdfs:domain ind:FallOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withinGuaranteePeriod rdf:type rdf:Property ;
    rdfs:label 'Within Guarantee Period' ;
    rdfs:comment 'Indicates whether the fall-off occurred within the contractual guarantee period (True) or after it expired (False). Determines replacement obligation and revenue impact applicability.' ;
    rdfs:domain ind:FallOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vmsSowId rdf:type rdf:Property ;
    rdfs:label 'Vms Sow Id' ;
    rdfs:comment 'The native SOW record identifier assigned by the Beeline VMS system for this engagement. Used for cross-system reconciliation between the Databricks Silver Layer and the Beeline VMS SOW module.' ;
    rdfs:domain ind:SowEngagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sow .

ind:coEmploymentRiskNotes rdf:type rdf:Property ;
    rdfs:label 'Co Employment Risk Notes' ;
    rdfs:comment 'Free-text notes from the compliance team documenting the basis for the co-employment risk assessment, specific risk factors identified, and any mitigation actions taken for this SOW engagement.' ;
    rdfs:domain ind:SowEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableDescription rdf:type rdf:Property ;
    rdfs:label 'Deliverable Description' ;
    rdfs:comment 'Narrative description of the primary deliverables, outcomes, or scope of work defined in the SOW. Captures the key work products the worker or vendor is contracted to produce. Sourced from the executed SOW document in DocuSign CLM.' ;
    rdfs:domain ind:SowEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementEndDate rdf:type rdf:Property ;
    rdfs:label 'Engagement End Date' ;
    rdfs:comment 'The contractually agreed date on which the SOW engagement is scheduled to conclude. Serves as the EFFECTIVE_UNTIL for this placement record. Nullable for open-ended engagements. Used for redeployment planning and assignment lifecycle management.' ;
    rdfs:domain ind:SowEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementStartDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Start Date' ;
    rdfs:comment 'The contractually agreed date on which the SOW engagement commences. Serves as the EFFECTIVE_FROM and BUSINESS_EVENT_TIMESTAMP for this placement record. Used for assignment tracking, billing period calculation, and compliance reporting.' ;
    rdfs:domain ind:SowEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fallOffFlag rdf:type rdf:Property ;
    rdfs:label 'Fall Off Flag' ;
    rdfs:comment 'Indicates whether this SOW engagement experienced a fall-off event — where the worker departed or the engagement was terminated prematurely before the contracted end date. Used for fall-off rate KPI monitoring and recruiter performance analytics.' ;
    rdfs:domain ind:SowEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:icClassificationFlag rdf:type rdf:Property ;
    rdfs:label 'Ic Classification Flag' ;
    rdfs:comment 'Indicates whether the worker engaged under this SOW is classified as an Independent Contractor (IC/1099) rather than a W-2 employee. Critical for IRS worker classification compliance, co-employment risk assessment, and FLSA determination.' ;
    rdfs:domain ind:SowEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneBillingFlag rdf:type rdf:Property ;
    rdfs:label 'Milestone Billing Flag' ;
    rdfs:comment 'Indicates whether this SOW engagement uses milestone-based billing tied to deliverable completion events rather than time-and-materials or fixed periodic billing. When True, billing events are triggered by milestone approval in Beeline VMS or Salesforce Revenue Cloud.' ;
    rdfs:domain ind:SowEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sowTitle rdf:type rdf:Property ;
    rdfs:label 'Sow Title' ;
    rdfs:comment 'Descriptive title of the Statement of Work engagement as defined in the executed SOW document. Used for identification and reporting purposes (e.g., Q3 Data Migration Project, Network Infrastructure Upgrade Phase 2).' ;
    rdfs:domain ind:SowEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalHoursBudgeted rdf:type rdf:Property ;
    rdfs:label 'Total Hours Budgeted' ;
    rdfs:comment 'Total number of hours budgeted for the SOW engagement as defined in the contract. Used for time-and-materials SOW types to track utilization against budget and for workforce planning analytics.' ;
    rdfs:domain ind:SowEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalHoursWorked rdf:type rdf:Property ;
    rdfs:label 'Total Hours Worked' ;
    rdfs:comment 'Cumulative actual hours worked by the worker under this SOW engagement to date. Sourced from Kronos Workforce Ready time and attendance records. Used for budget utilization tracking and billing reconciliation.' ;
    rdfs:domain ind:SowEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSowValue rdf:type rdf:Property ;
    rdfs:label 'Total Sow Value' ;
    rdfs:comment 'The total contracted monetary value of the SOW engagement as agreed in the executed SOW document. Represents the gross base amount for the MONETARY_TRIPLET. Used for revenue recognition, billing reconciliation, and financial reporting in Oracle NetSuite ERP and Salesforce Revenue Cloud.' ;
    rdfs:domain ind:SowEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualSalary rdf:type rdf:Property ;
    rdfs:label 'Annual Salary' ;
    rdfs:comment 'The annual base salary offered to the candidate for permanent or direct hire placements. Applicable for perm offer types. Used in compensation benchmarking and conversion fee calculations.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bullhornOfferReference rdf:type rdf:Property ;
    rdfs:label 'Bullhorn Offer Reference' ;
    rdfs:comment 'Native offer record identifier from the Bullhorn ATS/CRM system. Used for cross-system reconciliation and audit traceability back to the source system of record.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterOfferAmount rdf:type rdf:Property ;
    rdfs:label 'Counter Offer Amount' ;
    rdfs:comment 'The compensation amount proposed by the candidate as a counter-offer to the original offer. Applicable when offer_status is counter_offered. Used in negotiation tracking and compensation benchmarking.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterOfferRateType rdf:type rdf:Property ;
    rdfs:label 'Counter Offer Rate Type' ;
    rdfs:comment 'The rate basis (hourly, annual, etc.) for the candidates counter-offer amount. Required to correctly interpret counter_offer_amount in negotiation analytics.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declineReasonCode rdf:type rdf:Property ;
    rdfs:label 'Decline Reason Code' ;
    rdfs:comment 'Standardized reason code explaining why the candidate declined the offer (e.g., COMP_LOW, ACCEPTED_COMPETITOR, LOCATION, ROLE_MISMATCH, PERSONAL). Null if offer was not declined. Critical for competitive intelligence and offer strategy improvement. [ENUM-REF-CANDIDATE: comp_low|accepted_competitor|location|role_mismatch|personal|counter_accepted — promote to reference product]' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declinedDate rdf:type rdf:Property ;
    rdfs:label 'Declined Date' ;
    rdfs:comment 'The date on which the candidate formally declined the offer. Null if not declined. Used in fall-off rate monitoring and competitive compensation benchmarking.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:negotiationRoundCount rdf:type rdf:Property ;
    rdfs:label 'Negotiation Round Count' ;
    rdfs:comment 'The total number of negotiation rounds completed for this offer, including the initial offer and any counter-offers. Used to measure negotiation complexity and recruiter efficiency.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offerNumber rdf:type rdf:Property ;
    rdfs:label 'Offer Number' ;
    rdfs:comment 'Human-readable, externally-visible business identifier for the offer (e.g., OFR-2024-00123). Used in candidate communications, recruiter workflows, and reporting.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerStatus rdf:type rdf:Property ;
    rdfs:label 'Offer Status' ;
    rdfs:comment 'Current lifecycle state of the offer. Drives offer acceptance rate KPI and time-to-fill analytics. [ENUM-REF-CANDIDATE: pending|accepted|declined|rescinded|expired|counter_offered — promote to reference product if additional statuses are needed]' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerType rdf:type rdf:Property ;
    rdfs:label 'Offer Type' ;
    rdfs:comment 'Classification of the offer by engagement model: temp (temporary assignment), contract_to_hire (Contract-to-Hire / CTH), perm (permanent/direct placement), or sow (Statement of Work / SOW-based engagement).' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rescindReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rescind Reason Code' ;
    rdfs:comment 'Standardized reason code explaining why the offer was rescinded by the firm or client (e.g., BGC_FAILED, DRUG_SCREEN_FAILED, CLIENT_CANCELLED, HEADCOUNT_FREEZE, CANDIDATE_MISREPRESENTATION). Null if not rescinded. [ENUM-REF-CANDIDATE: bgc_failed|drug_screen_failed|client_cancelled|headcount_freeze|candidate_misrepresentation|other — promote to reference product]' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rescindedDate rdf:type rdf:Property ;
    rdfs:label 'Rescinded Date' ;
    rdfs:comment 'The date on which the staffing firm or client rescinded (withdrew) the offer after it had been extended. Null if not rescinded. Tracked for compliance and candidate experience reporting.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signOnBonus rdf:type rdf:Property ;
    rdfs:label 'Sign On Bonus' ;
    rdfs:comment 'One-time sign-on bonus amount offered to the candidate as part of the compensation package. Null if no sign-on bonus is included. Relevant for compensation benchmarking and candidate attraction analytics.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toAcceptanceDays rdf:type rdf:Property ;
    rdfs:label 'To Acceptance Days' ;
    rdfs:comment 'Number of calendar days elapsed between the offer_date and the accepted_date. Populated upon acceptance. Key KPI for Time-to-Fill (TTF) analytics and recruiter performance measurement.' ;
    rdfs:domain ind:Offer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentComplianceId rdf:type rdf:Property ;
    rdfs:label 'Assignment Compliance Id' ;
    rdfs:comment 'Unique surrogate identifier for each assignment-compliance requirement fulfillment record' ;
    rdfs:domain ind:AssignmentCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAssignmentRequirementId rdf:type rdf:Property ;
    rdfs:label 'Primary Assignment Requirement Id' ;
    rdfs:comment 'Foreign key linking to the specific compliance requirement that must be fulfilled for this assignment' ;
    rdfs:domain ind:AssignmentCompliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Requirement .

ind:reVerificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Re Verification Due Date' ;
    rdfs:comment 'The date by which this requirement must be re-verified for this assignment to maintain compliance. Typically set before expiration_date to allow processing time. Drives operational workflows and alerts.' ;
    rdfs:domain ind:AssignmentCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Flag' ;
    rdfs:comment 'Indicates whether a waiver or exception was granted for this requirement on this assignment, allowing the assignment to proceed despite non-completion' ;
    rdfs:domain ind:AssignmentCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billableHours rdf:type rdf:Property ;
    rdfs:label 'Billable Hours' ;
    rdfs:comment 'Total hours that are billable to the client for this pay period. Typically equals regular + OT + DT + holiday hours (excludes PTO and unpaid absences which are not client-billable). Authoritative input to Salesforce Revenue Cloud for client invoice generation. May differ from total_hours when non-billable paid time is present.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breakHours rdf:type rdf:Property ;
    rdfs:label 'Break Hours' ;
    rdfs:comment 'Total unpaid break time (meal periods) recorded during the pay period. Tracked to support state-mandated meal and rest break compliance (California IWC Wage Orders, Washington WAC 296-126-092, Oregon ORS 653.261). Ensures break deductions are correctly applied to gross hours to derive net payable hours.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDisputed rdf:type rdf:Property ;
    rdfs:label 'Is Disputed' ;
    rdfs:comment 'Flag indicating whether the timesheet has been formally disputed by the worker, client, or staffing firm. Triggers a dispute resolution workflow and places a hold on payroll processing and client billing until resolved. Supports dispute rate KPI and compliance audit.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLateSubmission rdf:type rdf:Property ;
    rdfs:label 'Is Late Submission' ;
    rdfs:comment 'Flag indicating whether the worker submitted the timesheet after the client or staffing firms defined submission deadline for the pay period. Used for late submission rate KPI reporting, worker compliance tracking, and payroll processing delay root cause analysis.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kronosTimesheetRef rdf:type rdf:Property ;
    rdfs:label 'Kronos Timesheet Ref' ;
    rdfs:comment 'Native timesheet identifier from the Kronos Workforce Ready source system. Enables direct traceability from the Silver layer record back to the operational system of record for audit, reconciliation, and support purposes.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mealBreakWaiver rdf:type rdf:Property ;
    rdfs:label 'Meal Break Waiver' ;
    rdfs:comment 'Flag indicating whether the worker signed a valid meal break waiver for this pay period, as permitted under California IWC Wage Orders for shifts of 6 hours or less, or mutual consent waivers for second meal periods. Required for California, Oregon, and Washington meal break compliance documentation. Null for non-applicable jurisdictions.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payPeriodType rdf:type rdf:Property ;
    rdfs:label 'Pay Period Type' ;
    rdfs:comment 'Frequency classification of the pay period covered by this timesheet. Determines payroll processing schedule and FLSA workweek overtime calculation methodology. weekly = 7-day period; biweekly = 14-day period; semi_monthly = twice per month; monthly = full calendar month.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timesheetNumber rdf:type rdf:Property ;
    rdfs:label 'Timesheet Number' ;
    rdfs:comment 'Human-readable, externally visible timesheet reference number used in worker communications, client invoices, and payroll remittances. Sourced from Kronos Workforce Ready and carried through to billing and payroll systems.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unpaidAbsenceHours rdf:type rdf:Property ;
    rdfs:label 'Unpaid Absence Hours' ;
    rdfs:comment 'Hours of unpaid absence recorded during the pay period (e.g., unexcused absences, unpaid leave). Not billable to the client and not payable to the worker. Tracked for attendance management, assignment compliance monitoring, and potential assignment termination triggers.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vmsTimesheetRef rdf:type rdf:Property ;
    rdfs:label 'Vms Timesheet Ref' ;
    rdfs:comment 'External timesheet identifier assigned by the clients Vendor Management System (e.g., Beeline VMS) when the client manages contingent labor through a VMS program. Used for cross-system reconciliation between the staffing firms Kronos records and the clients VMS approval records. Null for non-VMS-managed assignments.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Client-issued work order or purchase order number associated with the workers assignment for this pay period. Required on client invoices for accounts payable matching. Sourced from the clients procurement or VMS system. Null if the client does not require PO-based billing.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftId rdf:type rdf:Property ;
    rdfs:label 'Shift Id' ;
    rdfs:comment 'Foreign key linking to timesheet.shift. Business justification: A time_entry is the granular daily/shift-level record of actual work performed, and it directly corresponds to a specific shift instance. The shift entity captures the scheduled and actual shift detai' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shift .

ind:absenceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Absence Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for any absence or non-worked time within this entry period (e.g., SICK, FMLA, JURY, BEREAVEMENT, NO_SHOW, WEATHER). Null when the worker was present for the full scheduled shift. Required for FMLA tracking and workforce attendance analytics. [ENUM-REF-CANDIDATE: sick|fmla|jury_duty|bereavement|no_show|weather|personal|military — promote to reference product]' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Duration Minutes' ;
    rdfs:comment 'Total unpaid break time in minutes deducted from the gross shift duration to arrive at net hours worked. Includes all meal and rest break periods. Required for accurate net hours calculation and California Labor Code §512 meal period compliance.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The calendar date on which the worked period occurred (yyyy-MM-dd). Serves as the primary business event date for this time entry. Used for daily labor reporting, schedule variance analysis, and FLSA workweek calculations. Satisfies TRANSACTION_LINE LINE_SEQUENCE anchor date.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entrySource rdf:type rdf:Property ;
    rdfs:label 'Entry Source' ;
    rdfs:comment 'The method or system through which this time entry was captured: Kronos hardware clock (badge/biometric), Kronos mobile app, manual supervisor entry, VMS import from Beeline, or supervisor-entered correction. Supports audit trail requirements and data quality monitoring.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryStatus rdf:type rdf:Property ;
    rdfs:label 'Entry Status' ;
    rdfs:comment 'Current workflow lifecycle state of the time entry record. Controls whether the entry is editable, pending approval, approved for payroll/billing processing, rejected for correction, voided, or locked after payroll run. Satisfies TRANSACTION_LINE LINE_VALUE_OR_RESULT lifecycle dimension.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPayable rdf:type rdf:Property ;
    rdfs:label 'Is Payable' ;
    rdfs:comment 'Indicates whether the hours in this time entry are payable to the worker. May differ from is_billable in cases such as orientation (payable but not billable) or disputed hours (billable but payment withheld pending resolution). Drives TempWorks Payroll gross pay inclusion.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobCode rdf:type rdf:Property ;
    rdfs:label 'Job Code' ;
    rdfs:comment 'Standardized job classification code identifying the role or position being performed during this time entry. Aligns with the job orders position code and is used for EEOC reporting, OFCCP compliance, and workforce analytics by job classification.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kronosPunchRef rdf:type rdf:Property ;
    rdfs:label 'Kronos Punch Ref' ;
    rdfs:comment 'Source system identifier from Kronos Workforce Ready linking this time entry back to the originating raw punch event record. Enables drill-through from the Silver layer aggregated entry to the raw punch event for audit and dispute resolution. Null for manually entered records.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mealBreakCompliant rdf:type rdf:Property ;
    rdfs:label 'Meal Break Compliant' ;
    rdfs:comment 'Indicates whether the required meal break was taken in compliance with applicable state law (e.g., California Labor Code §512 requires a 30-minute unpaid meal period for shifts exceeding 5 hours). True = compliant; False = potential violation requiring premium pay or legal review.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netHoursWorked rdf:type rdf:Property ;
    rdfs:label 'Net Hours Worked' ;
    rdfs:comment 'Actual compensable hours worked during this entry period, computed as (actual_end_time − actual_start_time) − break_duration_minutes, expressed in decimal hours. Satisfies TRANSACTION_LINE LINE_QUANTITY category. This is the authoritative hours figure fed to payroll and client billing. Subject to FLSA §516 recordkeeping.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payType rdf:type rdf:Property ;
    rdfs:label 'Pay Type' ;
    rdfs:comment 'Classification of the hours worked for compensation purposes: regular straight-time (REG), overtime at 1.5x (OT), double-time at 2x (DT), holiday premium, per diem allowance, or paid time off (PTO). Drives the pay rate multiplier applied in TempWorks Payroll and the bill rate applied in Salesforce Revenue Cloud.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restBreakCompliant rdf:type rdf:Property ;
    rdfs:label 'Rest Break Compliant' ;
    rdfs:comment 'Indicates whether all required paid rest breaks were provided in compliance with applicable state law (e.g., California IWC Wage Orders require a 10-minute paid rest period for every 4 hours worked). True = compliant; False = potential premium pay obligation.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleVarianceHours rdf:type rdf:Property ;
    rdfs:label 'Schedule Variance Hours' ;
    rdfs:comment 'Delta between planned hours (derived from scheduled_start_time and scheduled_end_time) and actual net_hours_worked for this entry. Positive value indicates overtime relative to schedule; negative indicates early departure or absence. Key KPI for workforce scheduling compliance and dispatch analytics.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftDifferentialCode rdf:type rdf:Property ;
    rdfs:label 'Shift Differential Code' ;
    rdfs:comment 'Alphanumeric code identifying the applicable shift differential pay rule (e.g., EVE15, NIGHT20, WKD10). Maps to the differential rate table in TempWorks Payroll to apply the correct premium multiplier to base pay rate. Distinct from shift_type which is a broad category.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmsTimeEntryRef rdf:type rdf:Property ;
    rdfs:label 'Vms Time Entry Ref' ;
    rdfs:comment 'External reference identifier assigned by the clients Vendor Management System (VMS), such as Beeline, for this time entry when the client manages contingent labor through a VMS program. Enables reconciliation between Staffing Hrs internal records and the clients VMS for invoice matching and dispute resolution.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalWorkflowId rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Id' ;
    rdfs:comment 'Unique system-generated identifier for each timesheet approval workflow record. Serves as the primary key for this entity. Role: TRANSACTION_HEADER — tracks the multi-step approval lifecycle for a single timesheet submission.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Action Timestamp' ;
    rdfs:comment 'The exact date and time when the approver performed the approval action at this workflow stage. Serves as the principal business event timestamp for this transaction. Critical for SLA compliance measurement and audit trail.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvalAction rdf:type rdf:Property ;
    rdfs:label 'Approval Action' ;
    rdfs:comment 'The specific action taken by the approver at this workflow stage. Distinct from approval_status in that it captures the discrete action event (e.g., delegated) rather than the resulting state. Used for audit trail and workflow analytics.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalChannel rdf:type rdf:Property ;
    rdfs:label 'Approval Channel' ;
    rdfs:comment 'The interface or channel through which the approver submitted their approval action. Supports channel adoption analytics and helps identify approval bottlenecks by channel type.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalStage rdf:type rdf:Property ;
    rdfs:label 'Approval Stage' ;
    rdfs:comment 'The specific step in the multi-stage approval workflow at which this record applies. Stages include worker submission, supervisor review, client approval, back-office audit, and payroll release. Each stage represents a distinct checkpoint in the timesheet lifecycle.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverRole rdf:type rdf:Property ;
    rdfs:label 'Approver Role' ;
    rdfs:comment 'The functional role of the approver at this workflow stage. Distinguishes between worker self-submission, direct supervisor review, client manager approval, back-office audit, payroll admin release, and MSP coordinator oversight.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoApprovalRuleCode rdf:type rdf:Property ;
    rdfs:label 'Auto Approval Rule Code' ;
    rdfs:comment 'Identifier of the system-defined auto-approval rule that triggered automatic approval of this timesheet stage without manual intervention. Populated only when approval_action is auto_approved. Enables audit of automated decisions.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingReleasedFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Released Flag' ;
    rdfs:comment 'Indicates whether the approved timesheet hours have been released to the client billing system (Salesforce Revenue Cloud) for invoice generation. Enables reconciliation between approved hours and billed hours.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Reference Number' ;
    rdfs:comment 'The case or ticket number associated with a formal timesheet dispute. Populated when dispute_flag is True. Used to link the approval workflow record to the dispute management process for resolution tracking.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Free-text or coded explanation for why this approval stage was escalated to a higher authority. Populated when approval_action is escalated. Supports escalation pattern analysis and workflow optimization.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Final Approved Flag' ;
    rdfs:comment 'Indicates whether this workflow record represents the final, fully-approved state of the timesheet across all required approval stages. When True, the timesheet is cleared for payroll processing and client billing. Enables efficient filtering for downstream payroll and billing feeds.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payrollReleasedFlag rdf:type rdf:Property ;
    rdfs:label 'Payroll Released Flag' ;
    rdfs:comment 'Indicates whether the approved timesheet hours have been released to the payroll processing system (TempWorks Payroll) for worker compensation. Distinct from final_approved_flag as it confirms the downstream handoff has occurred.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:perDiemClaimed rdf:type rdf:Property ;
    rdfs:label 'Per Diem Claimed' ;
    rdfs:comment 'Indicates whether the worker claimed a per diem allowance (daily expense reimbursement for travel, meals, or lodging) on this timesheet. Per diem claims require separate approval validation against the assignment agreement.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReasonNotes rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Notes' ;
    rdfs:comment 'Free-text narrative provided by the approver explaining the specific reason for rejecting the timesheet at this stage. Supplements the rejection_reason_code with contextual detail for dispute resolution and worker communication.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionCount rdf:type rdf:Property ;
    rdfs:label 'Resubmission Count' ;
    rdfs:comment 'The number of times the worker has resubmitted this timesheet after a rejection. A high resubmission count indicates recurring errors or disputes and is used for quality-of-submission (QoS) analytics and worker coaching.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaBreachMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Minutes' ;
    rdfs:comment 'The number of minutes by which the approval action exceeded the SLA deadline. Populated only when sla_compliant_flag is False. Zero or null when SLA was met. Enables severity-based SLA breach analysis and client reporting.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliant Flag' ;
    rdfs:comment 'Indicates whether the approval action was completed within the SLA-defined deadline for this stage. True if the action_timestamp is on or before sla_due_timestamp; False if the SLA was breached. Supports SLA compliance reporting and client KPI dashboards.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaDueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Due Timestamp' ;
    rdfs:comment 'The contractually or operationally defined deadline by which this approval stage must be completed per the applicable SLA. Derived from the SLA configuration for the client or program. Used to calculate SLA compliance.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stageSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Stage Sequence Number' ;
    rdfs:comment 'Numeric ordering of this approval stage within the overall workflow. Enables reconstruction of the full approval chain in chronological order and supports multi-step workflow analytics.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDtHours rdf:type rdf:Property ;
    rdfs:label 'Total Dt Hours' ;
    rdfs:comment 'Total number of double-time (DT) hours recorded on the timesheet, applicable in jurisdictions or contracts where hours beyond a threshold (e.g., 12 hours/day or 7th consecutive day) are compensated at double the regular rate.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOtHours rdf:type rdf:Property ;
    rdfs:label 'Total Ot Hours' ;
    rdfs:comment 'Total number of overtime (OT) hours recorded on the timesheet, typically hours worked beyond 40 per week or 8 per day per FLSA or applicable state law. Requires explicit approval and is a common rejection trigger.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRegularHours rdf:type rdf:Property ;
    rdfs:label 'Total Regular Hours' ;
    rdfs:comment 'Total number of straight-time (non-overtime) hours recorded on the timesheet being reviewed in this approval workflow. Used to validate hours against scheduled hours and client purchase order limits.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vmsWorkflowRef rdf:type rdf:Property ;
    rdfs:label 'Vms Workflow Ref' ;
    rdfs:comment 'The external workflow identifier assigned by the Vendor Management System (VMS), such as Beeline, for this timesheet approval transaction. Enables cross-system reconciliation between the internal approval record and the clients VMS portal.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workWeekEndDate rdf:type rdf:Property ;
    rdfs:label 'Work Week End Date' ;
    rdfs:comment 'The last day of the work week covered by the timesheet being approved. Used to align the approval workflow with payroll processing cycles and client billing periods.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workflowInstanceNumber rdf:type rdf:Property ;
    rdfs:label 'Workflow Instance Number' ;
    rdfs:comment 'Externally-known business identifier for this approval workflow instance, used in communications, dispute resolution, and audit references. Typically formatted as a sequential or alphanumeric code (e.g., WF-2024-00123).' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAbsenceProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Absence Profile Id' ;
    rdfs:comment 'Identifier of the contingent worker associated with this absence record. Links to the worker master record in the workforce management system.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:absenceDurationDays rdf:type rdf:Property ;
    rdfs:label 'Absence Duration Days' ;
    rdfs:comment 'Total calendar duration of the absence expressed in days (may be fractional for partial-day absences). Derived from absence_start_date and absence_end_date but stored for reporting efficiency and workforce availability analytics.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:absenceEndDate rdf:type rdf:Property ;
    rdfs:label 'Absence End Date' ;
    rdfs:comment 'The last calendar date of the absence period. Null for open-ended absences (e.g., ongoing FMLA leave). Combined with absence_start_date to determine total absence duration.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:absenceHours rdf:type rdf:Property ;
    rdfs:label 'Absence Hours' ;
    rdfs:comment 'Total number of scheduled work hours missed during the absence period. Used for payroll deduction calculations, PTO balance consumption, and workforce availability reporting.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:absenceNotes rdf:type rdf:Property ;
    rdfs:label 'Absence Notes' ;
    rdfs:comment 'Free-text notes entered by the worker, manager, or HR coordinator providing additional context for the absence (e.g., nature of illness, family emergency details). Classified as confidential due to potential sensitivity of leave-related information.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:absenceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Absence Reference Number' ;
    rdfs:comment 'Externally visible, human-readable reference number assigned to this absence record (e.g., ABS-2024-00123). Used in worker communications, manager approvals, and leave management correspondence.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:absenceStartDate rdf:type rdf:Property ;
    rdfs:label 'Absence Start Date' ;
    rdfs:comment 'The first calendar date of the absence period. Used to calculate absence duration, determine pay period impact, and trigger FMLA tracking windows.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:absenceType rdf:type rdf:Property ;
    rdfs:label 'Absence Type' ;
    rdfs:comment 'Classification of the absence by leave category as defined in the leave management policy. Drives payroll treatment (paid vs. unpaid), compliance recordkeeping, and workforce availability reporting. [ENUM-REF-CANDIDATE: PTO|Sick Leave|FMLA|Holiday|Jury Duty|Bereavement|Unexcused|Personal|Military|Workers Comp — promote to reference product]' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Client Notification Timestamp' ;
    rdfs:comment 'Date and time when the client was notified of the worker absence. Null if client_notified is False. Used to measure notification SLA compliance against MSA contractual obligations.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:documentationDueDate rdf:type rdf:Property ;
    rdfs:label 'Documentation Due Date' ;
    rdfs:comment 'Deadline by which the worker must submit required leave documentation. Under FMLA, employers may require documentation within 15 calendar days of the leave request. Drives compliance follow-up workflows.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentationReceived rdf:type rdf:Property ;
    rdfs:label 'Documentation Received' ;
    rdfs:comment 'Indicates whether required supporting documentation (e.g., physician certification for FMLA, jury summons, death certificate for bereavement) has been received and verified (True) or is outstanding (False).' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fmlaHoursUsed rdf:type rdf:Property ;
    rdfs:label 'Fmla Hours Used' ;
    rdfs:comment 'Number of hours counted against the workers annual FMLA entitlement (up to 480 hours / 12 weeks per year). Populated only when fmla_qualifying is True. Required for DOL FMLA recordkeeping compliance.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fmlaQualifying rdf:type rdf:Property ;
    rdfs:label 'Fmla Qualifying' ;
    rdfs:comment 'Indicates whether this absence qualifies under the Family and Medical Leave Act (FMLA) (True) or not (False). Triggers FMLA tracking, 3-year recordkeeping retention, and DOL compliance workflows.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPaid rdf:type rdf:Property ;
    rdfs:label 'Is Paid' ;
    rdfs:comment 'Indicates whether the absence is compensated (True) or unpaid (False). Determines payroll treatment: paid absences draw from PTO/sick balances or holiday pay; unpaid absences result in payroll deductions.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPartialDay rdf:type rdf:Property ;
    rdfs:label 'Is Partial Day' ;
    rdfs:comment 'Indicates whether the absence covers only part of a scheduled workday (True) rather than full days (False). Partial-day absences require hour-level tracking for accurate payroll deduction and FMLA intermittent leave accounting.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kronosLeaveRef rdf:type rdf:Property ;
    rdfs:label 'Kronos Leave Ref' ;
    rdfs:comment 'Source system identifier for this absence record as assigned by the Kronos Workforce Ready leave management module. Used for data lineage, reconciliation, and integration with the Silver layer from the operational system of record.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaveReasonCode rdf:type rdf:Property ;
    rdfs:label 'Leave Reason Code' ;
    rdfs:comment 'Standardized reason code from the Kronos leave management module identifying the specific reason for the absence (e.g., FMLA-SELF, FMLA-FAMILY, PSL-CA, JURY, BRVMT-IMM). Supports regulatory reporting and state-specific paid sick leave law compliance.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollProcessed rdf:type rdf:Property ;
    rdfs:label 'Payroll Processed' ;
    rdfs:comment 'Indicates whether this absence record has been included in a completed payroll processing run (True) or is still pending payroll (False). Prevents double-processing and confirms the absence has been reflected in worker compensation.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:perDiemApplicable rdf:type rdf:Property ;
    rdfs:label 'Per Diem Applicable' ;
    rdfs:comment 'Indicates whether the workers per diem allowance is affected by this absence (True) or not (False). Per diem payments may be suspended or prorated for absent days depending on the assignment contract terms.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ptoBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Pto Balance Before' ;
    rdfs:comment 'Workers available PTO balance in hours immediately prior to this absence being applied. Provides a point-in-time snapshot for audit, dispute resolution, and worker self-service reporting.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ptoHoursConsumed rdf:type rdf:Property ;
    rdfs:label 'Pto Hours Consumed' ;
    rdfs:comment 'Number of accrued Paid Time Off (PTO) hours deducted from the workers PTO balance to cover this absence. Zero for unpaid absences or absences covered by other leave types (e.g., FMLA, holiday pay).' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replacementRequested rdf:type rdf:Property ;
    rdfs:label 'Replacement Requested' ;
    rdfs:comment 'Indicates whether a replacement worker has been requested to cover this absence (True) or not (False). Triggers workforce scheduling and dispatch workflows to source a backfill worker for the client site.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledHours rdf:type rdf:Property ;
    rdfs:label 'Scheduled Hours' ;
    rdfs:comment 'Total number of hours the worker was originally scheduled to work during the absence period. Provides the baseline against which absence_hours is measured for partial-day absence tracking.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateLeaveLawCode rdf:type rdf:Property ;
    rdfs:label 'State Leave Law Code' ;
    rdfs:comment 'Code identifying the applicable state-specific paid sick leave or family leave law governing this absence (e.g., CA-HWHFA for California Healthy Workplaces Healthy Families Act, NY-PFL for New York Paid Family Leave). Ensures compliance with state-level leave mandates beyond federal FMLA.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationTrigger rdf:type rdf:Property ;
    rdfs:label 'Termination Trigger' ;
    rdfs:comment 'Indicates whether this absence has triggered an assignment termination workflow (True) in Bullhorn ATS/CRM. Applicable for contingent workers with unexcused absences that breach the no-call/no-show policy threshold.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unexcusedFlag rdf:type rdf:Property ;
    rdfs:label 'Unexcused Flag' ;
    rdfs:comment 'Indicates whether this absence has been classified as unexcused (True) — i.e., the worker did not provide adequate notice or documentation. Unexcused absences for contingent workers may trigger assignment termination workflows per staffing agency policy.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confirmedByWorker rdf:type rdf:Property ;
    rdfs:label 'Confirmed By Worker' ;
    rdfs:comment 'Indicates whether the contingent worker has acknowledged and confirmed the scheduled shift in Kronos Workforce Ready. Used for workforce readiness tracking and to reduce no-show risk.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Day Of Week' ;
    rdfs:comment 'The day of the week on which this shift is scheduled. Used for recurring schedule pattern analysis, weekend/weekday differential pay identification, and workforce scheduling analytics. [ENUM-REF-CANDIDATE: Monday|Tuesday|Wednesday|Thursday|Friday|Saturday|Sunday — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Client department or business unit code associated with the scheduled shift. Used for client-side labor distribution reporting, workforce analytics, and billing breakdown by department.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedWeeklyHours rdf:type rdf:Property ;
    rdfs:label 'Expected Weekly Hours' ;
    rdfs:comment 'Total planned working hours per week for the worker on this assignment schedule. Used for FTE (Full-Time Equivalent) calculation, OT threshold monitoring, and workforce planning. Typically 40 hours for full-time contingent placements.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isHoliday rdf:type rdf:Property ;
    rdfs:label 'Is Holiday' ;
    rdfs:comment 'Indicates whether this scheduled shift falls on a recognized holiday, which may trigger holiday premium pay rates per the client MSA (Master Service Agreement) or worker contract.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPerDiemEligible rdf:type rdf:Property ;
    rdfs:label 'Is Per Diem Eligible' ;
    rdfs:comment 'Indicates whether the contingent worker is eligible to receive per diem allowance for this scheduled shift based on travel distance, assignment location, and IRS tax home rules.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kronosScheduleRef rdf:type rdf:Property ;
    rdfs:label 'Kronos Schedule Ref' ;
    rdfs:comment 'The native schedule record identifier as assigned by the Kronos Workforce Ready source system. Used for cross-system reconciliation, data lineage, and re-ingestion deduplication in the Databricks Silver Layer.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionTitle rdf:type rdf:Property ;
    rdfs:label 'Position Title' ;
    rdfs:comment 'The job title or role designation of the contingent worker for this scheduled shift, as defined in the job order. Used for workforce reporting, skill-based scheduling analytics, and compliance with EEOC job classification requirements.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Number' ;
    rdfs:comment 'Externally-known business identifier for the schedule record as assigned by Kronos Workforce Ready (e.g., SCH-2024-00123). Used for cross-system reference and operational communication.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle state of the planned schedule record. Draft indicates the schedule is being built; published indicates it has been released to the worker; confirmed indicates worker acknowledgement; modified indicates a post-publish change; cancelled indicates the shift was removed; completed indicates the shift period has passed.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledBreakMinutes rdf:type rdf:Property ;
    rdfs:label 'Scheduled Break Minutes' ;
    rdfs:comment 'Total planned unpaid break duration in minutes for this shift as defined in the schedule template. Used to calculate net scheduled working hours and to validate compliance with mandatory rest period regulations.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftDate rdf:type rdf:Property ;
    rdfs:label 'Shift Date' ;
    rdfs:comment 'The specific calendar date on which this scheduled shift is to occur. Distinct from shift_start_time in that it provides a day-level grain for schedule reporting, calendar views, and daily workforce planning without requiring timestamp precision.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shiftEndTime rdf:type rdf:Property ;
    rdfs:label 'Shift End Time' ;
    rdfs:comment 'The planned date and time at which the contingent workers shift is scheduled to end, expressed in local worksite time with timezone offset (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used in conjunction with shift_start_time to derive scheduled shift duration for variance analysis.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftStartTime rdf:type rdf:Property ;
    rdfs:label 'Shift Start Time' ;
    rdfs:comment 'The planned date and time at which the contingent workers shift is scheduled to begin, expressed in local worksite time with timezone offset (yyyy-MM-ddTHH:mm:ss.SSSXXX). Serves as the baseline for actual time-entry variance analysis and OT calculation.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workerConfirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Worker Confirmation Timestamp' ;
    rdfs:comment 'The date and time at which the contingent worker confirmed the scheduled shift. Null if the worker has not yet confirmed. Used for advance notice compliance measurement and scheduling analytics.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:absenceCode rdf:type rdf:Property ;
    rdfs:label 'Absence Code' ;
    rdfs:comment 'Code indicating the reason for a missed or partial shift absence (e.g., NCNS for no-call-no-show, SICK, FMLA, PTO, JURY). Used for attendance tracking, FMLA compliance, and workforce reliability analytics. [ENUM-REF-CANDIDATE: NCNS|SICK|FMLA|PTO|JURY|BEREAVEMENT|MILITARY — promote to reference product]' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Minutes' ;
    rdfs:comment 'Total scheduled or actual break time in minutes deducted from the shift duration. Includes meal breaks and rest periods. Used for net hours calculation and compliance with mandatory break laws (e.g., FLSA, state labor codes).' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:differentialCode rdf:type rdf:Property ;
    rdfs:label 'Differential Code' ;
    rdfs:comment 'Code identifying the pay differential applicable to this shift based on timing (e.g., evening, night, weekend, holiday). Drives premium pay rate calculations in TempWorks Payroll and corresponding bill rate adjustments. [ENUM-REF-CANDIDATE: DAY|EVE|NIGHT|WEEKEND|HOLIDAY|HAZARD|ONCALL — promote to reference product]' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geofenceVerified rdf:type rdf:Property ;
    rdfs:label 'Geofence Verified' ;
    rdfs:comment 'Indicates whether the workers clock-in/clock-out was verified within the approved geofence boundary of the worksite. Supports fraud prevention, buddy-punching detection, and client worksite compliance requirements.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWeekend rdf:type rdf:Property ;
    rdfs:label 'Is Weekend' ;
    rdfs:comment 'Indicates whether this shift falls on a Saturday or Sunday. Used to apply weekend shift differential pay codes and corresponding client bill rate adjustments per MSA terms.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payableHours rdf:type rdf:Property ;
    rdfs:label 'Payable Hours' ;
    rdfs:comment 'Total hours approved for worker compensation for this shift. May differ from worked_hours due to guaranteed minimum hours, rounding rules, or approved adjustments. Feeds TempWorks Payroll for worker pay calculation.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:punchSource rdf:type rdf:Property ;
    rdfs:label 'Punch Source' ;
    rdfs:comment 'Method or system through which the shifts time punches were captured. time_clock = physical Kronos terminal; mobile_app = Kronos mobile; web_portal = browser entry; supervisor_entry = manager-entered; vms = Beeline VMS submission; manual_adjustment = back-office correction.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVarianceMinutes rdf:type rdf:Property ;
    rdfs:label 'Schedule Variance Minutes' ;
    rdfs:comment 'Difference in minutes between actual worked hours and scheduled hours for this shift (actual minus scheduled). Positive values indicate overtime beyond schedule; negative values indicate early departure or missed time. Key metric for schedule adherence and labor analytics.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftNumber rdf:type rdf:Property ;
    rdfs:label 'Shift Number' ;
    rdfs:comment 'Externally-known business identifier for this shift instance, typically generated by Kronos Workforce Ready. Used for cross-system reference, timesheet reconciliation, and worker/supervisor communication.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftStatus rdf:type rdf:Property ;
    rdfs:label 'Shift Status' ;
    rdfs:comment 'Current lifecycle state of the shift. scheduled = future shift confirmed; in_progress = worker clocked in; completed = shift ended and hours recorded; missed = worker did not appear; cancelled = shift removed before start; no_call_no_show = worker absent without notification.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startVarianceMinutes rdf:type rdf:Property ;
    rdfs:label 'Start Variance Minutes' ;
    rdfs:comment 'Difference in minutes between actual_start_time and scheduled_start_time (actual minus scheduled). Positive values indicate tardiness; negative values indicate early arrival. Used for punctuality tracking and SLA compliance.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workedHours rdf:type rdf:Property ;
    rdfs:label 'Worked Hours' ;
    rdfs:comment 'Total actual hours worked during the shift, calculated from actual_start_time to actual_end_time minus actual break time. Represents the gross worked duration before OT/DT classification. Feeds payroll and client billing.' ;
    rdfs:domain ind:Shift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededByRuleOtRuleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rule Ot Rule Id' ;
    rdfs:comment 'Reference to the ot_rule_id of the newer rule that replaces this rule when rule_status is superseded. Enables rule version chain tracing for historical timesheet recalculation and compliance audits. Null if this rule has not been superseded.' ;
    rdfs:domain ind:OtRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OtRule .

ind:applicableLawReference rdf:type rdf:Property ;
    rdfs:label 'Applicable Law Reference' ;
    rdfs:comment 'Specific statutory or regulatory citation governing this OT rule (e.g., FLSA §207, California Labor Code §510, Nevada Revised Statutes §608.018, Davis-Bacon Act 40 U.S.C. §3141). Used for compliance documentation, legal audit trails, and regulatory reporting to DOL and OFCCP.' ;
    rdfs:domain ind:OtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliesToBillableHours rdf:type rdf:Property ;
    rdfs:label 'Applies To Billable Hours' ;
    rdfs:comment 'Indicates whether this OT rule governs the classification of billable OT hours for client invoicing purposes (True), in addition to payable hours for worker compensation. When True, OT bill rate multipliers are applied in Salesforce Revenue Cloud for client billing. When False, the rule applies only to payroll (pay side) calculations.' ;
    rdfs:domain ind:OtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billRateDtMultiplier rdf:type rdf:Property ;
    rdfs:label 'Bill Rate Dt Multiplier' ;
    rdfs:comment 'Multiplier applied to the standard bill rate to calculate the DT bill rate charged to the client for double-time hours (e.g., 2.00 means the client is billed at 2x the straight-time bill rate for DT hours). Null if the rule does not include a DT tier or if applies_to_billable_hours is False.' ;
    rdfs:domain ind:OtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billRateOtMultiplier rdf:type rdf:Property ;
    rdfs:label 'Bill Rate Ot Multiplier' ;
    rdfs:comment 'Multiplier applied to the standard bill rate to calculate the OT bill rate charged to the client for overtime hours (e.g., 1.50 means the client is billed at 1.5x the straight-time bill rate for OT hours). May differ from the pay-side OT multiplier based on client MSA terms. Null if applies_to_billable_hours is False.' ;
    rdfs:domain ind:OtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blendedRateMethod rdf:type rdf:Property ;
    rdfs:label 'Blended Rate Method' ;
    rdfs:comment 'Method used to calculate the regular rate of pay for OT purposes when a worker is on multiple concurrent assignments with different pay rates. weighted_average = FLSA §207(g)(1) weighted average of all rates; highest_rate = FLSA §207(g)(2) highest rate method; primary_assignment = rate of the primary assignment governs; not_applicable = worker is on a single assignment only.' ;
    rdfs:domain ind:OtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakDeductionApplies rdf:type rdf:Property ;
    rdfs:label 'Break Deduction Applies' ;
    rdfs:comment 'Indicates whether unpaid meal/rest break deductions are applied before OT threshold calculation under this rule. True = break time is deducted from hours worked before OT is computed; False = all clocked hours count toward OT threshold without break deduction. Affects OT calculation in Kronos Workforce Ready.' ;
    rdfs:domain ind:OtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dailyDtThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Daily Dt Threshold Hours' ;
    rdfs:comment 'Number of hours worked in a single workday beyond which double-time (DT) pay is triggered (e.g., 12.00 hours per California Labor Code §510). Hours worked above this threshold are compensated at the DT multiplier rate. Null if the rule does not include a daily DT threshold.' ;
    rdfs:domain ind:OtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyOtThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Daily Ot Threshold Hours' ;
    rdfs:comment 'Number of hours worked in a single workday beyond which daily overtime pay is triggered (e.g., 8.00 hours per California Labor Code §510). Hours worked above this threshold and below the DT threshold are compensated at the OT multiplier. Null if the rule does not apply a daily OT threshold.' ;
    rdfs:domain ind:OtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flsaExemptionCategory rdf:type rdf:Property ;
    rdfs:label 'Flsa Exemption Category' ;
    rdfs:comment 'Specific FLSA exemption category when flsa_exemption_status is exempt or partial_exempt (e.g., executive, administrative, professional, computer_employee, highly_compensated, 207k_public_safety). Null for non-exempt workers. Required for FLSA compliance documentation and OFCCP audits. [ENUM-REF-CANDIDATE: executive|administrative|professional|computer_employee|highly_compensated|207k_public_safety|outside_sales|seasonal — promote to reference product]' ;
    rdfs:domain ind:OtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holidayHoursOtTreatment rdf:type rdf:Property ;
    rdfs:label 'Holiday Hours Ot Treatment' ;
    rdfs:comment 'Defines how holiday hours are treated for OT threshold calculation. count_as_worked = holiday pay hours count toward weekly OT threshold; exclude = holiday hours are excluded from OT threshold calculation; premium_separate = holiday premium is calculated separately and does not affect OT threshold. Configured per client MSA or state law.' ;
    rdfs:domain ind:OtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prevailingWageApplies rdf:type rdf:Property ;
    rdfs:label 'Prevailing Wage Applies' ;
    rdfs:comment 'Indicates whether this OT rule incorporates prevailing wage requirements under the Davis-Bacon Act (for federal construction contracts) or the Service Contract Act (SCA) for government service contracts. True = prevailing wage OT rates apply; False = standard commercial OT rates apply. Critical for government staffing contract compliance.' ;
    rdfs:domain ind:OtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prevailingWageDeterminationNumber rdf:type rdf:Property ;
    rdfs:label 'Prevailing Wage Determination Number' ;
    rdfs:comment 'DOL wage determination number associated with the prevailing wage schedule governing this OT rule (e.g., WD 2023-0001). Populated only when prevailing_wage_applies is True. Required for Davis-Bacon Act and SCA compliance documentation on government staffing contracts.' ;
    rdfs:domain ind:OtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ptoCountsTowardOt rdf:type rdf:Property ;
    rdfs:label 'Pto Counts Toward Ot' ;
    rdfs:comment 'Indicates whether paid time off (PTO) hours are included in the weekly hours count for OT threshold purposes. True = PTO hours count toward the OT threshold (e.g., 32 hours worked + 8 PTO = 40 hours, no OT triggered); False = only actual hours worked count toward OT threshold per FLSA standard. Configurable per client MSA.' ;
    rdfs:domain ind:OtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Detailed narrative description of the overtime rule, including the legal basis, applicable thresholds, and any special conditions (e.g., seventh-consecutive-day provisions, blended rate requirements, prevailing wage applicability). Supports compliance documentation and auditor review.' ;
    rdfs:domain ind:OtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulePriority rdf:type rdf:Property ;
    rdfs:label 'Rule Priority' ;
    rdfs:comment 'Numeric priority rank used for conflict resolution when multiple OT rules are applicable to the same time entry (e.g., a worker in California on a government contract may have federal FLSA, California state, and Davis-Bacon rules all applicable). Lower integer = higher priority. Ensures deterministic OT rule selection in Kronos Workforce Ready and TempWorks Payroll.' ;
    rdfs:domain ind:OtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Classification of the overtime rule by its governing authority or applicability scope. federal = FLSA-based federal standard; state = state-specific labor law (e.g., California, Nevada); client_specific = client-negotiated OT terms in MSA; prevailing_wage = Davis-Bacon Act or SCA government contract rules; blended = multi-assignment blended rate OT calculation.' ;
    rdfs:domain ind:OtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seventhDayDtThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Seventh Day Dt Threshold Hours' ;
    rdfs:comment 'On the seventh consecutive workday, the number of hours beyond which double-time pay applies (e.g., 8.00 hours per California Labor Code §510 — first 8 hours at OT, beyond 8 at DT). Null if seventh_day_ot_applies is False or if no DT tier applies on the seventh day.' ;
    rdfs:domain ind:OtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seventhDayOtApplies rdf:type rdf:Property ;
    rdfs:label 'Seventh Day Ot Applies' ;
    rdfs:comment 'Indicates whether this rule includes the seventh-consecutive-day OT provision, where all hours worked on the seventh consecutive day of a workweek are paid at OT rate (True) per California Labor Code §510. False for rules that do not include this provision.' ;
    rdfs:domain ind:OtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemRuleRef rdf:type rdf:Property ;
    rdfs:label 'Source System Rule Ref' ;
    rdfs:comment 'Native identifier of this OT rule in the originating operational system (e.g., Kronos Workforce Ready pay rule ID, TempWorks Payroll OT rule code). Enables reconciliation between the lakehouse silver layer and the source system for audit and troubleshooting purposes.' ;
    rdfs:domain ind:OtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionAgreementApplies rdf:type rdf:Property ;
    rdfs:label 'Union Agreement Applies' ;
    rdfs:comment 'Indicates whether this OT rule is governed by or must comply with a collective bargaining agreement (CBA) or union contract. True = union OT provisions apply and may override standard FLSA or state rules; False = no union agreement governs this rule. Relevant for unionized light industrial and healthcare staffing placements.' ;
    rdfs:domain ind:OtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Union Agreement Reference' ;
    rdfs:comment 'Identifier or name of the collective bargaining agreement (CBA) that governs this OT rule when union_agreement_applies is True (e.g., SEIU Local 1199 CBA 2023-2026, Teamsters Local 25 CBA). Null when union_agreement_applies is False. Used for compliance documentation and payroll audit.' ;
    rdfs:domain ind:OtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weeklyDtThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Weekly Dt Threshold Hours' ;
    rdfs:comment 'Number of hours worked in a workweek beyond which double-time pay is triggered (e.g., some state or client rules apply DT after 60 hours/week). Null if the rule does not apply a weekly DT threshold. Distinct from the daily DT threshold.' ;
    rdfs:domain ind:OtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weeklyOtThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Weekly Ot Threshold Hours' ;
    rdfs:comment 'Number of hours worked in a workweek beyond which overtime pay is triggered (e.g., 40.00 hours per FLSA §207 federal standard). Hours worked above this threshold are compensated at the OT multiplier rate. Null if the rule does not apply a weekly OT threshold.' ;
    rdfs:domain ind:OtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workweekStartDay rdf:type rdf:Property ;
    rdfs:label 'Workweek Start Day' ;
    rdfs:comment 'The designated first day of the workweek for purposes of weekly OT threshold calculation (e.g., sunday for a Sunday–Saturday workweek per FLSA §207). Workweek definition is fixed and regularly recurring per FLSA. Configured in Kronos Workforce Ready per client or assignment. [ENUM-REF-CANDIDATE: sunday|monday|tuesday|wednesday|thursday|friday|saturday — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OtRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDeadline rdf:type rdf:Property ;
    rdfs:label 'Approval Deadline' ;
    rdfs:comment 'Precise timestamp by which client supervisors or staffing coordinators must approve submitted timesheets. Drives SLA enforcement for approval workflows and escalation triggers in Kronos Workforce Ready. Supports on-time payroll processing and client billing cycle alignment.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billingCycleDate rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Date' ;
    rdfs:comment 'The date on which client invoices are generated for billable hours worked during this pay period. May differ from check_date in cases where billing and payroll cycles are offset. Feeds Salesforce Revenue Cloud invoice generation and Oracle NetSuite Accounts Receivable.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calendarYear rdf:type rdf:Property ;
    rdfs:label 'Calendar Year' ;
    rdfs:comment 'The standard calendar year (4-digit integer, e.g., 2024) to which this pay period belongs. Distinct from fiscal_year when the business operates on a non-calendar fiscal year. Used for W-2 and 1099 tax year alignment in TempWorks Payroll.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clientSegment rdf:type rdf:Property ;
    rdfs:label 'Client Segment' ;
    rdfs:comment 'Business segment or client grouping for which this pay period definition is applicable (e.g., Healthcare, Light Industrial, IT Staffing, All). Supports multi-client staffing operations where different client verticals may operate on different pay cycles per MSA (Master Service Agreement) terms.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Month' ;
    rdfs:comment 'The fiscal month (1–12) within the fiscal year to which this pay period belongs. Supports monthly financial close processes in Oracle NetSuite ERP and monthly workforce analytics reporting in Power BI Analytics Platform.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'The fiscal quarter (1–4) within the fiscal year to which this pay period belongs. Used for quarterly payroll tax filings (941, SUTA), financial reporting, and KPI dashboards in Power BI Analytics Platform.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalWeekNumber rdf:type rdf:Property ;
    rdfs:label 'Fiscal Week Number' ;
    rdfs:comment 'The sequential fiscal week number (1–53) within the fiscal year. Used for weekly labor analytics, overtime threshold tracking, and workforce scheduling reports in Kronos Workforce Ready and Power BI Analytics Platform. Particularly important for weekly pay period types.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holidayAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Holiday Adjustment Flag' ;
    rdfs:comment 'Indicates whether this pay period contains one or more observed holidays that affect standard workday counts, holiday pay eligibility, or payroll processing schedules. When True, payroll coordinators must review holiday pay rules and adjusted cutoff dates. Sourced from Kronos Workforce Ready holiday calendar.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holidayCount rdf:type rdf:Property ;
    rdfs:label 'Holiday Count' ;
    rdfs:comment 'Number of observed holidays falling within this pay period. Used to calculate adjusted workday counts, holiday pay liability, and per diem adjustments. Supports holiday pay eligibility rules for temporary workers under client MSA (Master Service Agreement) terms.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCurrentPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Current Period' ;
    rdfs:comment 'Indicates whether this is the currently active pay period (i.e., todays date falls within start_date and end_date). Only one record per period_type should have this flag set to True at any given time. Used as a quick filter in operational dashboards and payroll processing queues.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payrollCutoffDate rdf:type rdf:Property ;
    rdfs:label 'Payroll Cutoff Date' ;
    rdfs:comment 'The deadline by which all timesheets must be submitted and approved for inclusion in this pay periods payroll run. Timesheets received after this date are held for the next pay period or processed as off-cycle adjustments. Operationally critical for TempWorks Payroll batch processing.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payrollProviderCode rdf:type rdf:Property ;
    rdfs:label 'Payroll Provider Code' ;
    rdfs:comment 'Code identifying the payroll processing provider or entity responsible for executing payroll for this pay period (e.g., TEMPWORKS, EOR_PARTNER_01). Relevant for EOR (Employer of Record) arrangements where a third-party provider processes payroll on behalf of the staffing firm.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollRunType rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Type' ;
    rdfs:comment 'Classifies the type of payroll run associated with this pay period. regular = standard scheduled payroll; off_cycle = unscheduled run for missed payments or terminations; supplemental = bonus or commission payments; correction = retroactive adjustment for prior period errors. Drives payroll processing logic in TempWorks Payroll.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perDiemPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Per Diem Period Flag' ;
    rdfs:comment 'Indicates whether per diem allowances are applicable and tracked within this pay period. When True, per diem expense records are expected to be submitted alongside timesheets. Relevant for travel-intensive placements (e.g., healthcare travel nurses, field technicians) where IRS per diem rates apply.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodCode rdf:type rdf:Property ;
    rdfs:label 'Period Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this pay period across systems (e.g., PP-2024-01-001). Used for cross-system reconciliation between Kronos Workforce Ready, TempWorks Payroll, and Salesforce Revenue Cloud billing cycles.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodName rdf:type rdf:Property ;
    rdfs:label 'Period Name' ;
    rdfs:comment 'Human-readable label for the pay period (e.g., Week 1 Jan 2024, Bi-Weekly Period 3 - Q1 2024). Used in payroll reports, worker pay stubs, and client billing statements for clear period identification.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Period Sequence Number' ;
    rdfs:comment 'Sequential ordinal number of this pay period within its fiscal year and period type (e.g., 1st bi-weekly period = 1, 2nd = 2). Used for period-over-period comparison analytics, payroll run ordering, and audit trail sequencing.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodStatus rdf:type rdf:Property ;
    rdfs:label 'Period Status' ;
    rdfs:comment 'Current lifecycle status of the pay period. open = timesheets can be submitted; processing = payroll run in progress; locked = no further timesheet changes permitted; closed = payroll finalized and disbursed; cancelled = period voided (rare, e.g., system error). Drives workflow gating in TempWorks Payroll and Kronos Workforce Ready.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ptoAccrualPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Pto Accrual Period Flag' ;
    rdfs:comment 'Indicates whether PTO (Paid Time Off) accruals are calculated and posted during this pay period. Some staffing arrangements accrue PTO on a per-pay-period basis per state law (e.g., California AB 1522, New York Paid Sick Leave). Drives PTO accrual batch processing in TempWorks Payroll and SAP SuccessFactors.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemPeriodRef rdf:type rdf:Property ;
    rdfs:label 'Source System Period Ref' ;
    rdfs:comment 'The native identifier of this pay period record in the originating source system (e.g., Kronos pay period ID, TempWorks period key). Used for cross-system reconciliation, data lineage tracing, and integration audit trails between the lakehouse silver layer and operational systems.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardHours rdf:type rdf:Property ;
    rdfs:label 'Standard Hours' ;
    rdfs:comment 'Expected number of standard straight-time hours for a full-time worker during this pay period (e.g., 40.00 for a weekly period, 80.00 for bi-weekly). Used as the baseline for overtime (OT) threshold calculations, FTE normalization, and payroll burden rate computations.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timesheetSubmissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Timesheet Submission Deadline' ;
    rdfs:comment 'Precise timestamp by which contingent workers must submit their timesheets for the pay period. Includes time-of-day precision to support automated reminder workflows in Kronos Workforce Ready and Bullhorn ATS/CRM. Distinct from payroll_cutoff_date which governs the payroll processing batch.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalCalendarDays rdf:type rdf:Property ;
    rdfs:label 'Total Calendar Days' ;
    rdfs:comment 'Total number of calendar days in this pay period (end_date minus start_date plus 1). Used for pro-ration calculations for partial-period placements, per diem allowance calculations, and FTE (Full-Time Equivalent) normalization in workforce analytics.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalWorkdays rdf:type rdf:Property ;
    rdfs:label 'Total Workdays' ;
    rdfs:comment 'Number of standard business workdays (Monday–Friday, excluding holidays) within this pay period. Used for expected hours calculations, attendance rate reporting, and workforce scheduling in Kronos Workforce Ready. Supports SLA (Service Level Agreement) headcount compliance reporting.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yearEndPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Year End Period Flag' ;
    rdfs:comment 'Indicates whether this pay period spans or falls at the calendar year-end boundary (e.g., a bi-weekly period crossing December 31 into January). When True, special year-end payroll processing rules apply including W-2 cutoff handling, FICA wage base reset, and FUTA/SUTA annual limit resets in TempWorks Payroll.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .
