ind:costPerLearner rdf:type rdf:Property ;
    rdfs:label 'Cost Per Learner' ;
    rdfs:comment 'The cost charged per learner for course enrollment or completion. Used for training budget tracking and cost allocation.' ;
    rdfs:domain ind:LmsCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:courseCategory rdf:type rdf:Property ;
    rdfs:label 'Course Category' ;
    rdfs:comment 'Broad subject area or domain to which the course belongs (e.g., Human Resources, Information Technology, Healthcare, Manufacturing). Used for course organization and filtering.' ;
    rdfs:domain ind:LmsCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseDescription rdf:type rdf:Property ;
    rdfs:label 'Course Description' ;
    rdfs:comment 'Detailed description of the course content, objectives, and learning outcomes. Provides learners with an overview of what the course covers.' ;
    rdfs:domain ind:LmsCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseTitle rdf:type rdf:Property ;
    rdfs:label 'Course Title' ;
    rdfs:comment 'The official name or title of the LMS course as displayed to learners and administrators.' ;
    rdfs:domain ind:LmsCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseType rdf:type rdf:Property ;
    rdfs:label 'Course Type' ;
    rdfs:comment 'Classification of the course based on its purpose and content area. Distinguishes between compliance training, skills development, new hire orientation, safety training, professional development, and certification programs.' ;
    rdfs:domain ind:LmsCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHours rdf:type rdf:Property ;
    rdfs:label 'Credit Hours' ;
    rdfs:comment 'The number of continuing education or professional development credit hours awarded upon successful course completion. May be required for professional certifications or licenses.' ;
    rdfs:domain ind:LmsCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:difficultyLevel rdf:type rdf:Property ;
    rdfs:label 'Difficulty Level' ;
    rdfs:comment 'The complexity or skill level required for the course. Helps learners and administrators match courses to appropriate skill levels.' ;
    rdfs:domain ind:LmsCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Is Certification Required' ;
    rdfs:comment 'Indicates whether successful completion of the course results in a formal certification or credential. True if certification is awarded, false otherwise.' ;
    rdfs:domain ind:LmsCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thumbnailUrl rdf:type rdf:Property ;
    rdfs:label 'Thumbnail Url' ;
    rdfs:comment 'The web address of the course thumbnail or preview image displayed in the course catalog.' ;
    rdfs:domain ind:LmsCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validityPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Validity Period Days' ;
    rdfs:comment 'The number of days for which the course completion or certification remains valid before recertification or renewal is required. Null indicates no expiration.' ;
    rdfs:domain ind:LmsCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorCourseCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Course Code' ;
    rdfs:comment 'The unique identifier assigned to the course by the external vendor or content provider. Used for integration and reconciliation with vendor systems.' ;
    rdfs:domain ind:LmsCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ptoPolicyId rdf:type rdf:Property ;
    rdfs:label 'Pto Policy Id' ;
    rdfs:comment 'Primary key for pto_policy' ;
    rdfs:domain ind:PtoPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:advanceNoticeRequiredDays rdf:type rdf:Property ;
    rdfs:label 'Advance Notice Required Days' ;
    rdfs:comment 'Minimum number of days advance notice required for employees to request PTO usage. Zero if no advance notice required.' ;
    rdfs:domain ind:PtoPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Allocation Amount' ;
    rdfs:comment 'Total PTO amount granted per year for lump sum policies, or maximum accrual cap for accrual policies. Expressed in accrual units.' ;
    rdfs:domain ind:PtoPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blackoutPeriodsDefined rdf:type rdf:Property ;
    rdfs:label 'Blackout Periods Defined' ;
    rdfs:comment 'Indicates whether this policy includes defined blackout periods during which PTO usage is restricted or prohibited.' ;
    rdfs:domain ind:PtoPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumBalance rdf:type rdf:Property ;
    rdfs:label 'Maximum Balance' ;
    rdfs:comment 'Maximum PTO balance an employee can accumulate under this policy. Null for unlimited policies.' ;
    rdfs:domain ind:PtoPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payoutMaximum rdf:type rdf:Property ;
    rdfs:label 'Payout Maximum' ;
    rdfs:comment 'Maximum PTO balance that will be paid out on termination if payout is allowed. Null if full balance is paid or no payout.' ;
    rdfs:domain ind:PtoPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:policyDescription rdf:type rdf:Property ;
    rdfs:label 'Policy Description' ;
    rdfs:comment 'Detailed text description of the PTO policy terms, conditions, and special provisions.' ;
    rdfs:domain ind:PtoPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyVersion rdf:type rdf:Property ;
    rdfs:label 'Policy Version' ;
    rdfs:comment 'Version number of the policy document for change tracking and compliance audit purposes (e.g., \'1.0\', \'2.3\').' ;
    rdfs:domain ind:PtoPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageIncrement rdf:type rdf:Property ;
    rdfs:label 'Usage Increment' ;
    rdfs:comment 'Minimum increment in which PTO can be used (e.g., 0.25 for quarter-hour increments, 1.0 for full-hour increments, 8.0 for full-day increments).' ;
    rdfs:domain ind:PtoPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holidayDate rdf:type rdf:Property ;
    rdfs:label 'Holiday Date' ;
    rdfs:comment 'The specific date on which the holiday occurs. Core business event date for this reference entity.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holidayType rdf:type rdf:Property ;
    rdfs:label 'Holiday Type' ;
    rdfs:comment 'Classification of the holiday indicating its nature and scope (public, federal, state-specific, company-specific, religious observance, or floating holiday).' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMandatoryClosure rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory Closure' ;
    rdfs:comment 'Indicates whether the organization mandates office/facility closure on this holiday, affecting staffing availability and client service delivery.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isObserved rdf:type rdf:Property ;
    rdfs:label 'Is Observed' ;
    rdfs:comment 'Indicates whether this holiday is actively observed by the organization for payroll, scheduling, and operational purposes.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:observanceRule rdf:type rdf:Property ;
    rdfs:label 'Observance Rule' ;
    rdfs:comment 'Defines how the holiday date is determined: fixed (same date annually), floating (varies by year based on rules), calculated (algorithmic determination), or substitute (observed on alternate date when falls on weekend).' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observedDate rdf:type rdf:Property ;
    rdfs:label 'Observed Date' ;
    rdfs:comment 'The actual date on which the holiday is observed for business purposes, which may differ from the holiday_date when substitution rules apply (e.g., Monday observance for Sunday holiday).' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:premiumPayMultiplier rdf:type rdf:Property ;
    rdfs:label 'Premium Pay Multiplier' ;
    rdfs:comment 'The multiplier applied to standard pay rates for employees working on this holiday (e.g., 1.5 for time-and-a-half, 2.0 for double-time). Used in payroll calculations.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:staffingImpactLevel rdf:type rdf:Property ;
    rdfs:label 'Staffing Impact Level' ;
    rdfs:comment 'Assessment of the impact this holiday has on staffing availability and workforce planning, ranging from none to critical.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:year rdf:type rdf:Property ;
    rdfs:label 'Year' ;
    rdfs:comment 'The calendar year in which this holiday occurs. Enables year-over-year holiday planning and historical analysis.' ;
    rdfs:domain ind:HolidayCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compensationGrade rdf:type rdf:Property ;
    rdfs:label 'Compensation Grade' ;
    rdfs:comment 'Compensation band or grade assigned to this role within the organization\'s pay structure.' ;
    rdfs:domain ind:JobRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencies rdf:type rdf:Property ;
    rdfs:label 'Competencies' ;
    rdfs:comment 'Key skills, behaviors, and competencies required for successful performance in this role, often mapped to a competency framework.' ;
    rdfs:domain ind:JobRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobPostingTemplate rdf:type rdf:Property ;
