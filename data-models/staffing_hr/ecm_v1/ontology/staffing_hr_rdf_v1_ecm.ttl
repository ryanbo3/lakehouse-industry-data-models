ind:targetIndustry rdf:type rdf:Property ;
    rdfs:label 'Target Industry' ;
    rdfs:comment 'The industry or sector this talent pool is designed to serve (e.g., \'Healthcare\', \'Financial Services\', \'Technology\').' ;
    rdfs:domain ind:TalentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentTerritoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Territory Id' ;
    rdfs:comment 'Reference to the parent territory in a hierarchical territory structure, enabling multi-level territory rollups and organizational alignment.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:activeClientCount rdf:type rdf:Property ;
    rdfs:label 'Active Client Count' ;
    rdfs:comment 'Current count of active client accounts assigned to this territory.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedRecruiterCount rdf:type rdf:Property ;
    rdfs:label 'Assigned Recruiter Count' ;
    rdfs:comment 'Number of recruiters currently assigned to cover this territory.' ;
