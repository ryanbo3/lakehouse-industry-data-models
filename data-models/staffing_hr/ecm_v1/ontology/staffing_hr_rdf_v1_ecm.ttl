ind:dayOfYear rdf:type rdf:Property ;
    rdfs:label 'Day Of Year' ;
    rdfs:comment 'The day number within the calendar year (1-365 or 1-366 for leap years). Used for year-to-date calculations and trend analysis.' ;
    rdfs:domain ind:FiscalCalendar ;
