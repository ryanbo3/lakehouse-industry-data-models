ind:postalCodeRange rdf:type rdf:Property ;
    rdfs:label 'Postal Code Range' ;
    rdfs:comment 'Postal code or ZIP code ranges defining geographic boundaries of the territory (e.g., 10000-19999, 90001-90089).' ;
