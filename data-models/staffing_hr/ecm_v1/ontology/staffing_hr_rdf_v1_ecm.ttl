ind:defaultValidityPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Default Validity Period Days' ;
    rdfs:comment 'Standard number of days this credential type remains valid from issuance or renewal date. Null if credential does not expire or validity varies by issuer.' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isClientVisible rdf:type rdf:Property ;
    rdfs:label 'Is Client Visible' ;
    rdfs:comment 'Indicates whether this credential type should be visible to client users in client-facing portals and reports (True) or is for internal use only (False).' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMandatoryForPlacement rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory For Placement' ;
    rdfs:comment 'Indicates whether this credential type is commonly required as a mandatory prerequisite for candidate placement in roles within its industry vertical (True) or is optional/preferred (False).' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAuthorityType rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Type' ;
    rdfs:comment 'Type of organization or entity that issues or validates this credential (e.g., government agency, professional association, third-party vendor).' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:name rdf:type rdf:Property ;
    rdfs:label 'Name' ;
    rdfs:comment 'Full descriptive name of the credential type (e.g., Registered Nurse License, CPR Certification, Basic Background Check).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingTimeDays rdf:type rdf:Property ;
    rdfs:label 'Processing Time Days' ;
    rdfs:comment 'Typical number of days required to complete verification or obtain results for this credential type. Null if processing time is not tracked or highly variable.' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalReminderDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Reminder Days' ;
    rdfs:comment 'Number of days before expiration when renewal reminders should be triggered for candidates holding this credential type. Null if no reminder is configured.' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresDocumentUpload rdf:type rdf:Property ;
    rdfs:label 'Requires Document Upload' ;
    rdfs:comment 'Indicates whether candidates or staff must upload supporting documentation (e.g., certificate, license scan) when recording this credential type (True) or if documentation is optional or not required (False).' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresRenewal rdf:type rdf:Property ;
    rdfs:label 'Requires Renewal' ;
    rdfs:comment 'Indicates whether this credential type has an expiration date and requires periodic renewal (True) or is valid indefinitely once obtained (False).' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skillsAssessmentDomain rdf:type rdf:Property ;
    rdfs:label 'Skills Assessment Domain' ;
    rdfs:comment 'For skills assessment credential types, specifies the skill domain or competency area being assessed (e.g., Java Programming, Welding, Clinical Nursing Skills). Null for non-assessment credential types.' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingProviderType rdf:type rdf:Property ;
    rdfs:label 'Training Provider Type' ;
    rdfs:comment 'For training credential types, specifies the type of organization that provides the training (e.g., internal company training, external vendor, accredited institution). Null for non-training credential types.' ;
    rdfs:domain ind:CredentialType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitPercentage rdf:type rdf:Property ;
    rdfs:label 'Benefit Percentage' ;
    rdfs:comment 'Percentage of salary or wages replaced by the benefit. Applicable to disability and retirement plans. Expressed as a percentage (e.g., 60.00 for 60%).' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Policy Number' ;
    rdfs:comment 'Policy or contract number assigned by the insurance carrier for this benefit plan.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobraEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Cobra Eligible Flag' ;
    rdfs:comment 'Indicates whether this benefit plan is eligible for COBRA continuation coverage after employment termination.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coinsurancePercentage rdf:type rdf:Property ;
    rdfs:label 'Coinsurance Percentage' ;
    rdfs:comment 'Percentage of costs the employee pays after meeting the deductible. Expressed as a percentage (e.g., 20.00 for 20%).' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copayAmount rdf:type rdf:Property ;
    rdfs:label 'Copay Amount' ;
    rdfs:comment 'Fixed amount the employee pays for specific services such as doctor visits or prescriptions.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageLevel rdf:type rdf:Property ;
    rdfs:label 'Coverage Level' ;
    rdfs:comment 'Scope of coverage provided by the benefit plan indicating who is eligible for benefits.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityWaitingPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Eligibility Waiting Period Days' ;
    rdfs:comment 'Number of days an employee must wait after hire date before becoming eligible to enroll in this benefit plan.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employerMatchLimitPercentage rdf:type rdf:Property ;
    rdfs:label 'Employer Match Limit Percentage' ;
    rdfs:comment 'Maximum percentage of salary up to which the employer will match contributions in retirement plans. Expressed as a percentage (e.g., 6.00 for 6%).' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerMatchPercentage rdf:type rdf:Property ;
    rdfs:label 'Employer Match Percentage' ;
    rdfs:comment 'Percentage of employee contributions that the employer will match in retirement plans. Expressed as a percentage (e.g., 50.00 for 50%).' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentType rdf:type rdf:Property ;
    rdfs:label 'Enrollment Type' ;
    rdfs:comment 'Indicates whether enrollment in this benefit plan is voluntary, mandatory, or automatic for eligible employees.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsaEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Fsa Eligible Flag' ;
    rdfs:comment 'Indicates whether this benefit plan allows employees to contribute to a Flexible Spending Account for eligible expenses.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hsaEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Hsa Eligible Flag' ;
    rdfs:comment 'Indicates whether this benefit plan qualifies as a high-deductible health plan eligible for HSA contributions.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Review Date' ;
    rdfs:comment 'Date when the benefit plan was last reviewed for regulatory compliance.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:networkType rdf:type rdf:Property ;
    rdfs:label 'Network Type' ;
    rdfs:comment 'Type of provider network associated with the benefit plan. Applicable to health, dental, and vision plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planAdministratorContact rdf:type rdf:Property ;
    rdfs:label 'Plan Administrator Contact' ;
    rdfs:comment 'Contact information (phone or email) for the benefit plan administrator.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planAdministratorName rdf:type rdf:Property ;
    rdfs:label 'Plan Administrator Name' ;
    rdfs:comment 'Name of the individual or organization responsible for administering the benefit plan.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planYearEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan Year End Date' ;
    rdfs:comment 'End date of the benefit plan year used for tracking deductibles, out-of-pocket maximums, and annual limits.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planYearStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Year Start Date' ;
    rdfs:comment 'Start date of the benefit plan year used for tracking deductibles, out-of-pocket maximums, and annual limits.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:summaryPlanDescriptionUrl rdf:type rdf:Property ;
    rdfs:label 'Summary Plan Description Url' ;
    rdfs:comment 'URL or file path to the Summary Plan Description document required by ERISA.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vestingPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Vesting Period Months' ;
    rdfs:comment 'Number of months an employee must participate in the plan before employer contributions become fully owned. Applicable to retirement plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compensationPlanId rdf:type rdf:Property ;
    rdfs:label 'Compensation Plan Id' ;
    rdfs:comment 'Primary key for compensation_plan' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByEmployeeStaffProfileId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Staff Profile Id' ;
    rdfs:comment 'Identifier of the employee who created this compensation plan record.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffProfile .

ind:lastModifiedByEmployeeStaffProfileId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By Employee Staff Profile Id' ;
    rdfs:comment 'Identifier of the employee who last modified this compensation plan record.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffProfile .

ind:bonusEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Bonus Eligibility Flag' ;
    rdfs:comment 'Indicates whether employees on this plan are eligible for discretionary or performance bonuses.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clawbackProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Clawback Provision Flag' ;
    rdfs:comment 'Indicates whether commissions or bonuses can be reclaimed if placement fails or client cancels within a specified period.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionBasis rdf:type rdf:Property ;
    rdfs:label 'Commission Basis' ;
    rdfs:comment 'The revenue metric upon which commission is calculated (gross revenue, net revenue, placement fee, margin, billable hours).' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Percentage' ;
    rdfs:comment 'Standard commission rate as a percentage of revenue or placement fees. Null if plan does not include commission component.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drawType rdf:type rdf:Property ;
    rdfs:label 'Draw Type' ;
    rdfs:comment 'Whether the draw must be repaid from future commissions (recoverable) or is guaranteed (non-recoverable). Null if no draw.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobRoleCategory rdf:type rdf:Property ;
    rdfs:label 'Job Role Category' ;
    rdfs:comment 'Primary job role category this compensation plan is designed for (recruiter, account manager, sales, operations, management, administrative, executive).' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overtimeRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Overtime Rate Multiplier' ;
    rdfs:comment 'Multiplier applied to base hourly rate for overtime hours (e.g., 1.5 for time-and-a-half). Null if not overtime eligible.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seniorityLevel rdf:type rdf:Property ;
    rdfs:label 'Seniority Level' ;
    rdfs:comment 'Target seniority level for employees assigned to this plan (entry, junior, mid, senior, principal, executive).' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:splitCommissionAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Split Commission Allowed Flag' ;
    rdfs:comment 'Indicates whether commissions under this plan can be split among multiple employees (e.g., recruiter and account manager).' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierCount rdf:type rdf:Property ;
    rdfs:label 'Tier Count' ;
    rdfs:comment 'Number of performance tiers in the compensation structure. Null if tier_structure_flag is false.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierStructureFlag rdf:type rdf:Property ;
    rdfs:label 'Tier Structure Flag' ;
    rdfs:comment 'Indicates whether this plan uses tiered commission or bonus rates based on performance thresholds.' ;
    rdfs:domain ind:CompensationPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededByPolicyId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Policy Id' ;
    rdfs:comment 'Reference to the accrual policy that replaces this policy if it has been superseded. Null if current.' ;
    rdfs:domain ind:AccrualPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccrualPolicy .

ind:accrualCalculationBasis rdf:type rdf:Property ;
    rdfs:label 'Accrual Calculation Basis' ;
    rdfs:comment 'Basis on which accrual is calculated (e.g., hours worked, days employed, calendar time).' ;
    rdfs:domain ind:AccrualPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualFrequency rdf:type rdf:Property ;
    rdfs:label 'Accrual Frequency' ;
    rdfs:comment 'Frequency at which time off accrues to employees under this policy (e.g., monthly, per pay period).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualStartEvent rdf:type rdf:Property ;
    rdfs:label 'Accrual Start Event' ;
    rdfs:comment 'Event that triggers the start of accrual for an employee under this policy.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualUnit rdf:type rdf:Property ;
    rdfs:label 'Accrual Unit' ;
    rdfs:comment 'Unit of measurement for accrued time (hours or days).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carryoverAllowed rdf:type rdf:Property ;
    rdfs:label 'Carryover Allowed' ;
    rdfs:comment 'Indicates whether unused accrued time can be carried over to the next accrual period or calendar year.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carryoverMaximum rdf:type rdf:Property ;
    rdfs:label 'Carryover Maximum' ;
    rdfs:comment 'Maximum amount of accrued time that can be carried over if carryover is allowed. Null if unlimited or carryover not allowed.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Eligibility Criteria' ;
    rdfs:comment 'Description of employee eligibility requirements for this accrual policy (e.g., full-time only, specific job levels, tenure requirements).' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumAccrualBalance rdf:type rdf:Property ;
    rdfs:label 'Maximum Accrual Balance' ;
    rdfs:comment 'Maximum amount of time that can be accrued under this policy. Null if no cap applies.' ;
    rdfs:domain ind:AccrualPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumUsageIncrement rdf:type rdf:Property ;
    rdfs:label 'Minimum Usage Increment' ;
    rdfs:comment 'Minimum increment in which accrued time can be used (e.g., 0.25 hours, 0.5 days).' ;
    rdfs:domain ind:AccrualPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negativeBalanceAllowed rdf:type rdf:Property ;
    rdfs:label 'Negative Balance Allowed' ;
    rdfs:comment 'Indicates whether employees can use time off before it has fully accrued, resulting in a negative balance.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:negativeBalanceLimit rdf:type rdf:Property ;
    rdfs:label 'Negative Balance Limit' ;
    rdfs:comment 'Maximum negative balance allowed if negative balances are permitted. Null if not applicable.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payoutOnTermination rdf:type rdf:Property ;
    rdfs:label 'Payout On Termination' ;
    rdfs:comment 'Indicates whether unused accrued time is paid out to the employee upon termination of employment.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyCode rdf:type rdf:Property ;
    rdfs:label 'Policy Code' ;
    rdfs:comment 'Unique business identifier code for the accrual policy, used for external reference and system integration.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Human-readable name of the accrual policy (e.g., \'Standard PTO\', \'Executive Leave\', \'Contractor Time Off\').' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorationMethod rdf:type rdf:Property ;
    rdfs:label 'Proration Method' ;
    rdfs:comment 'Method used to prorate accruals for employees who start mid-period or have partial eligibility.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierBased rdf:type rdf:Property ;
    rdfs:label 'Tier Based' ;
    rdfs:comment 'Indicates whether this policy uses tiered accrual rates based on tenure or other factors.' ;
    rdfs:domain ind:AccrualPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedByEmployeeStaffProfileId rdf:type rdf:Property ;
    rdfs:label 'Modified By Employee Staff Profile Id' ;
    rdfs:comment 'Identifier of the employee who last modified this review period record.' ;
    rdfs:domain ind:ReviewPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffProfile .

ind:appliesToAllEmployees rdf:type rdf:Property ;
    rdfs:label 'Applies To All Employees' ;
    rdfs:comment 'Indicates whether this review period applies to all employees (True) or only specific groups/departments (False).' ;
    rdfs:domain ind:ReviewPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compensationReviewLinked rdf:type rdf:Property ;
    rdfs:label 'Compensation Review Linked' ;
    rdfs:comment 'Indicates whether this review period is directly linked to compensation decisions such as salary increases or bonuses (True/False).' ;
    rdfs:domain ind:ReviewPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:completedReviewCount rdf:type rdf:Property ;
    rdfs:label 'Completed Review Count' ;
    rdfs:comment 'The number of performance reviews that have been completed for this review period.' ;
    rdfs:domain ind:ReviewPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eligibleEmployeeCount rdf:type rdf:Property ;
    rdfs:label 'Eligible Employee Count' ;
    rdfs:comment 'The total number of employees eligible for review during this period.' ;
    rdfs:domain ind:ReviewPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluationCriteria rdf:type rdf:Property ;
    rdfs:label 'Evaluation Criteria' ;
    rdfs:comment 'Description of the key performance criteria and competencies being evaluated during this review period.' ;
    rdfs:domain ind:ReviewPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalSettingRequired rdf:type rdf:Property ;
    rdfs:label 'Goal Setting Required' ;
    rdfs:comment 'Indicates whether employees and managers are required to set performance goals for the next period as part of this review cycle (True/False).' ;
    rdfs:domain ind:ReviewPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includes360Feedback rdf:type rdf:Property ;
    rdfs:label 'Includes 360 Feedback' ;
    rdfs:comment 'Indicates whether 360-degree feedback (manager, peer, subordinate, self) is collected during this review period (True/False).' ;
    rdfs:domain ind:ReviewPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesPeerReview rdf:type rdf:Property ;
    rdfs:label 'Includes Peer Review' ;
    rdfs:comment 'Indicates whether peer reviews are included as part of the evaluation process for this review period (True/False).' ;
    rdfs:domain ind:ReviewPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesSelfAssessment rdf:type rdf:Property ;
    rdfs:label 'Includes Self Assessment' ;
    rdfs:comment 'Indicates whether employees are required to complete a self-assessment as part of this review period (True/False).' ;
    rdfs:domain ind:ReviewPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'The date when the review period was officially launched and review activities began.' ;
    rdfs:domain ind:ReviewPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionEligibilityLinked rdf:type rdf:Property ;
    rdfs:label 'Promotion Eligibility Linked' ;
    rdfs:comment 'Indicates whether performance in this review period affects promotion eligibility decisions (True/False).' ;
    rdfs:domain ind:ReviewPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratingScaleType rdf:type rdf:Property ;
    rdfs:label 'Rating Scale Type' ;
    rdfs:comment 'The type of rating scale used for performance evaluations in this review period.' ;
    rdfs:domain ind:ReviewPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTemplateVersion rdf:type rdf:Property ;
    rdfs:label 'Review Template Version' ;
    rdfs:comment 'Version identifier of the performance review template or form used for this review period.' ;
    rdfs:domain ind:ReviewPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentPlanId rdf:type rdf:Property ;
    rdfs:label 'Development Plan Id' ;
    rdfs:comment 'Primary key for development_plan' ;
    rdfs:domain ind:DevelopmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jobRoleId rdf:type rdf:Property ;
    rdfs:label 'Job Role Id' ;
    rdfs:comment 'Reference to the target job role or position that this development plan is preparing the employee for.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobRole .

ind:linkedPerformanceReviewId rdf:type rdf:Property ;
    rdfs:label 'Linked Performance Review Id' ;
    rdfs:comment 'Reference to the performance review that triggered or is associated with this development plan.' ;
    rdfs:domain ind:DevelopmentPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceReview .

ind:managerStaffProfileId rdf:type rdf:Property ;
    rdfs:label 'Manager Staff Profile Id' ;
    rdfs:comment 'Reference to the manager or supervisor responsible for overseeing and approving this development plan.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffProfile .

ind:mentorStaffProfileId rdf:type rdf:Property ;
    rdfs:label 'Mentor Staff Profile Id' ;
    rdfs:comment 'Reference to the mentor or coach assigned to guide the employee through this development plan.' ;
    rdfs:domain ind:DevelopmentPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffProfile .

ind:budgetAllocated rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated' ;
    rdfs:comment 'The financial budget allocated for executing this development plan, including training, certifications, and resources.' ;
    rdfs:domain ind:DevelopmentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetSpent rdf:type rdf:Property ;
