    rdfs:domain ind:FiscalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period End Date' ;
    rdfs:comment 'The end date of the fiscal period or month. Defines the closing boundary for monthly financial close and reporting.' ;
    rdfs:domain ind:FiscalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiscalPeriodName rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period Name' ;
    rdfs:comment 'The display name or label for the fiscal period (e.g., P01, Period 1, Jan 2024). Used for user-friendly reporting and financial close communication.' ;
    rdfs:domain ind:FiscalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period Start Date' ;
    rdfs:comment 'The start date of the fiscal period or month. Defines the opening boundary for monthly financial transactions and accruals.' ;
    rdfs:domain ind:FiscalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiscalQuarterEndDate rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter End Date' ;
