ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'Two-letter state or province code for the establishment location.' ;
    rdfs:domain ind:StaffingHr ;
    rdf:type owl:DatatypeProperty ;
