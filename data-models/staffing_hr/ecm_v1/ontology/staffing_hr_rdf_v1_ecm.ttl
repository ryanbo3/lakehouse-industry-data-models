ind:batchType rdf:type rdf:Property ;
    rdfs:label 'Batch Type' ;
    rdfs:comment 'Classification of the payment batch based on the nature of payments included (e.g., payroll for employee wages, vendor for supplier payments, contractor for contingent worker payments).' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failedPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Failed Payment Count' ;
