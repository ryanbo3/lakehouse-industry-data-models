    rdfs:range xsd:integer .

ind:assignmentRule rdf:type rdf:Property ;
    rdfs:label 'Assignment Rule' ;
    rdfs:comment 'Business rule or logic used to automatically assign clients or opportunities to this territory (e.g., based on client location, industry, revenue size, or named account list).' ;
    rdfs:domain ind:Territory ;
