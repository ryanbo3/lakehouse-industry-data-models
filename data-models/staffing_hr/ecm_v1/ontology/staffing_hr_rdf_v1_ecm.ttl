    rdfs:comment 'Indicates whether the calendar date is the last day of a fiscal year. Used for annual financial close and year-end reporting.' ;
    rdfs:domain ind:FiscalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

