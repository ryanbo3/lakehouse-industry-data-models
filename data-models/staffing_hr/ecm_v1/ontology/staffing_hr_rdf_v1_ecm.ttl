    rdfs:range xsd:string .

ind:territoryType rdf:type rdf:Property ;
    rdfs:label 'Territory Type' ;
    rdfs:comment 'Classification of territory segmentation strategy (geographic boundaries, industry vertical focus, account-based assignment, hybrid model, named accounts, or strategic accounts).' ;
    rdfs:domain ind:Territory ;
