ind:responsibilities rdf:type rdf:Property ;
    rdfs:label 'Responsibilities' ;
    rdfs:comment 'Comprehensive list of primary duties and responsibilities expected of individuals in this role.' ;
    rdfs:domain ind:JobRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleFamily rdf:type rdf:Property ;
    rdfs:label 'Role Family' ;
    rdfs:comment 'Broad functional family or category to which this role belongs, used for workforce planning and career pathing.' ;
    rdfs:domain ind:JobRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleLevel rdf:type rdf:Property ;
    rdfs:label 'Role Level' ;
    rdfs:comment 'Hierarchical level or seniority tier of the role within the organization, used for compensation banding and career progression.' ;
    rdfs:domain ind:JobRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleTitle rdf:type rdf:Property ;
    rdfs:label 'Role Title' ;
    rdfs:comment 'Official title of the job role as used in job postings, employment contracts, and organizational charts.' ;
    rdfs:domain ind:JobRole ;
