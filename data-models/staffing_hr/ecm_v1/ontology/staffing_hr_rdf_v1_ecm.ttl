    rdfs:comment 'Standard template or boilerplate text used when creating external job postings for this role.' ;
    rdfs:domain ind:JobRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceMetrics rdf:type rdf:Property ;
    rdfs:label 'Performance Metrics' ;
    rdfs:comment 'Key performance indicators or metrics used to evaluate success and performance in this role.' ;
    rdfs:domain ind:JobRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalRequirements rdf:type rdf:Property ;
