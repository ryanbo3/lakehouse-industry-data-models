    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarDate rdf:type rdf:Property ;
    rdfs:label 'Calendar Date' ;
    rdfs:comment 'The actual calendar date in Gregorian calendar format. Bridge between fiscal periods and calendar dates for transaction mapping.' ;
