ind:fiscalQuarterStartDate rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter Start Date' ;
    rdfs:comment 'The start date of the fiscal quarter. Used for quarterly financial period boundary identification.' ;
    rdfs:domain ind:FiscalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiscalWeek rdf:type rdf:Property ;
    rdfs:label 'Fiscal Week' ;
    rdfs:comment 'The fiscal week number within the fiscal year (1-52 or 1-53). Used for weekly payroll cycles and operational reporting in staffing operations.' ;
    rdfs:domain ind:FiscalCalendar ;
