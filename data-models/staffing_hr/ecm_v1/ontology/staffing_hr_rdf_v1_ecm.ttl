    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calendarMonth rdf:type rdf:Property ;
    rdfs:label 'Calendar Month' ;
    rdfs:comment 'The Gregorian calendar month number (1-12). Used for calendar-based reporting and reconciliation with fiscal periods.' ;
    rdfs:domain ind:FiscalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarMonthName rdf:type rdf:Property ;
    rdfs:label 'Calendar Month Name' ;
    rdfs:comment 'The full name of the Gregorian calendar month. Used for user-friendly reporting and dashboards. [ENUM-REF-CANDIDATE: January|February|March|April|May|June|July|August|September|October|November|December — promote to reference product]' ;
    rdfs:domain ind:FiscalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarQuarter rdf:type rdf:Property ;
    rdfs:label 'Calendar Quarter' ;
    rdfs:comment 'The Gregorian calendar quarter (1-4). Used for calendar-based quarterly reporting and reconciliation with fiscal quarters.' ;
    rdfs:domain ind:FiscalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dayOfMonth rdf:type rdf:Property ;
    rdfs:label 'Day Of Month' ;
    rdfs:comment 'The day number within the calendar month (1-31). Used for monthly reporting and date-based business rules.' ;
    rdfs:domain ind:FiscalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dayOfWeekNumber rdf:type rdf:Property ;
    rdfs:label 'Day Of Week Number' ;
