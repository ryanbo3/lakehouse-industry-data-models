ind:establishmentType rdf:type rdf:Property ;
    rdfs:label 'Establishment Type' ;
    rdfs:comment 'Classification of the establishment based on its operational role within the organization.' ;
    rdfs:domain ind:Establishment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:federalContractValueUsd rdf:type rdf:Property ;
