ind:countryCodes rdf:type rdf:Property ;
    rdfs:label 'Country Codes' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes covered by this territory (e.g., \'USA,CAN,MEX\').' ;
