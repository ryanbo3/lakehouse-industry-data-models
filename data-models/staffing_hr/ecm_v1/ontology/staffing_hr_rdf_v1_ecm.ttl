ind:fiscalYearStartDate rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Start Date' ;
    rdfs:comment 'The start date of the fiscal year to which this calendar record belongs. Defines the beginning of the annual financial reporting cycle.' ;
    rdfs:domain ind:FiscalCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holidayName rdf:type rdf:Property ;
