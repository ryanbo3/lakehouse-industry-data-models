    rdfs:range xsd:string .

ind:openGraphTitle rdf:type rdf:Property ;
    rdfs:label 'Open Graph Title' ;
    rdfs:comment 'Title used in Open Graph metadata for social sharing.' ;
    rdfs:domain ind:SeoMetadata ;
