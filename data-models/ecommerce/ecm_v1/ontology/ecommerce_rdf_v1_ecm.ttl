    rdfs:range xsd:integer .

ind:totalVolumeCubicM rdf:type rdf:Property ;
    rdfs:label 'Total Volume Cubic M' ;
    rdfs:comment 'Combined volume of all items received, measured in cubic meters.' ;
    rdfs:domain ind:ReceivingRecord ;
