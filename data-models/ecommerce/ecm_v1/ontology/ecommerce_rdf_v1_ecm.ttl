    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributedRevenue rdf:type rdf:Property ;
    rdfs:label 'Attributed Revenue' ;
    rdfs:comment 'Monetary value of revenue credited to the touchpoint after attribution calculation.' ;
