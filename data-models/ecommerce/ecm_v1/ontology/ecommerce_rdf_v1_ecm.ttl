    rdfs:comment 'Indicates whether the content has passed legal compliance review.' ;
    rdfs:domain ind:Item ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentBody rdf:type rdf:Property ;
