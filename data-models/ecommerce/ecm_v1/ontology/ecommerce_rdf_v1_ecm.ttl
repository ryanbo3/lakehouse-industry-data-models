    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indexCode rdf:type rdf:Property ;
    rdfs:label 'Index Code' ;
    rdfs:comment 'System-generated unique code for the index, often used in API calls.' ;
