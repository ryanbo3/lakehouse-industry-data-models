    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attributionStatus rdf:type rdf:Property ;
    rdfs:label 'Attribution Status' ;
    rdfs:comment 'Current processing state of the attribution record.' ;
