    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'External purchase order identifier associated with the inbound shipment.' ;
    rdfs:domain ind:Ecommerce ;
