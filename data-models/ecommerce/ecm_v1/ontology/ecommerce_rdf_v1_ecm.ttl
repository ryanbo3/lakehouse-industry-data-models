ind:relevanceScore rdf:type rdf:Property ;
    rdfs:label 'Relevance Score' ;
    rdfs:comment 'Score (0-100) indicating the tag\'s relevance to search ranking.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:synonyms rdf:type rdf:Property ;
