ind:billingStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Status' ;
    rdfs:comment 'Current billing state of the cost line.' ;
    rdfs:domain ind:TransportCost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationCenter rdf:type rdf:Property ;
