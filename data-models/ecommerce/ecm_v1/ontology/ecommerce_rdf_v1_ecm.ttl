    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelWeightingJson rdf:type rdf:Property ;
    rdfs:label 'Channel Weighting Json' ;
    rdfs:comment 'JSON representation of channel-specific weightings used by the model.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Regulatory compliance status of the model under GDPR, CCPA, etc.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionEvent rdf:type rdf:Property ;
    rdfs:label 'Conversion Event' ;
    rdfs:comment 'Business event that qualifies a conversion for attribution.' ;
    rdfs:domain ind:AttributionModel ;
