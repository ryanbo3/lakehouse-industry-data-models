ind:targetUrl rdf:type rdf:Property ;
    rdfs:label 'Target Url' ;
    rdfs:comment 'Landing page URL that the keyword is intended to drive traffic to.' ;
    rdfs:domain ind:Keyword ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadId rdf:type rdf:Property ;
    rdfs:label 'Lead Id' ;
    rdfs:comment 'Unique system-generated identifier for the lead record.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lead .

ind:leadAgentId rdf:type rdf:Property ;
    rdfs:label 'Lead Agent Id' ;
    rdfs:comment 'Identifier of the sales rep responsible for the lead.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:sourceQueryLogId rdf:type rdf:Property ;
    rdfs:label 'Source Query Log Id' ;
    rdfs:comment 'Foreign key linking to search.query_log. Business justification: Needed for lead attribution report that ties each generated lead to the originating search query for ROI analysis.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QueryLog .

ind:address rdf:type rdf:Property ;
    rdfs:label 'Address' ;
    rdfs:comment 'Full mailing address provided by the lead (if supplied).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyName rdf:type rdf:Property ;
    rdfs:label 'Company Name' ;
    rdfs:comment 'Name of the organization the lead represents (for B2B leads).' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentDownloaded rdf:type rdf:Property ;
    rdfs:label 'Content Downloaded' ;
    rdfs:comment 'Identifiers of marketing assets (e.g., whitepapers) the lead has downloaded.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demoRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Demo Requested Flag' ;
    rdfs:comment 'Indicates whether the lead has requested a product demonstration.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedDealValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Deal Value' ;
    rdfs:comment 'Projected monetary value of the opportunity if the lead converts.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastActivityTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Activity Timestamp' ;
    rdfs:comment 'Timestamp of the most recent interaction (email open, form submit, etc.) with the lead.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:leadSource rdf:type rdf:Property ;
    rdfs:label 'Lead Source' ;
    rdfs:comment 'Origin of the lead (e.g., website form, trade show, referral).' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadStatus rdf:type rdf:Property ;
    rdfs:label 'Lead Status' ;
    rdfs:comment 'Current lifecycle status of the lead.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadType rdf:type rdf:Property ;
    rdfs:label 'Lead Type' ;
    rdfs:comment 'Indicates whether the lead is a business (B2B) or consumer (B2C).' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfVisits rdf:type rdf:Property ;
    rdfs:label 'Number Of Visits' ;
    rdfs:comment 'Count of distinct website visits recorded for the lead.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:origin rdf:type rdf:Property ;
    rdfs:label 'Origin' ;
    rdfs:comment 'High-level source classification for the lead.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pagesVisited rdf:type rdf:Property ;
    rdfs:label 'Pages Visited' ;
    rdfs:comment 'Total number of unique pages viewed by the lead.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rating rdf:type rdf:Property ;
    rdfs:label 'Rating' ;
    rdfs:comment 'Qualitative rating indicating lead quality.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoreModelVersion rdf:type rdf:Property ;
    rdfs:label 'Score Model Version' ;
    rdfs:comment 'Version identifier of the scoring algorithm used.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoreTimestamp rdf:type rdf:Property ;
    rdfs:label 'Score Timestamp' ;
    rdfs:comment 'Date and time when the lead score was last calculated.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Marketing funnel stage the lead is currently in.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingAbTestId rdf:type rdf:Property ;
    rdfs:label 'Marketing Ab Test Id' ;
    rdfs:comment 'Unique surrogate key for the marketing A/B test record.' ;
    rdfs:domain ind:MarketingAbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confidenceThreshold rdf:type rdf:Property ;
    rdfs:label 'Confidence Threshold' ;
    rdfs:comment 'Statistical confidence level (percentage) required to declare a winner.' ;
    rdfs:domain ind:MarketingAbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlConversions rdf:type rdf:Property ;
    rdfs:label 'Control Conversions' ;
    rdfs:comment 'Number of conversions recorded for the control variant.' ;
    rdfs:domain ind:MarketingAbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:controlImpressions rdf:type rdf:Property ;
    rdfs:label 'Control Impressions' ;
    rdfs:comment 'Number of times the control variant was shown.' ;
    rdfs:domain ind:MarketingAbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:controlRevenue rdf:type rdf:Property ;
    rdfs:label 'Control Revenue' ;
    rdfs:comment 'Revenue attributed to the control variant.' ;
    rdfs:domain ind:MarketingAbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlVariantName rdf:type rdf:Property ;
    rdfs:label 'Control Variant Name' ;
    rdfs:comment 'Identifier for the control group variant.' ;
    rdfs:domain ind:MarketingAbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingAbTestStatus rdf:type rdf:Property ;
    rdfs:label 'Marketing Ab Test Status' ;
    rdfs:comment 'Current lifecycle status of the test.' ;
    rdfs:domain ind:MarketingAbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricTarget rdf:type rdf:Property ;
    rdfs:label 'Metric Target' ;
    rdfs:comment 'Target value for the primary success metric expressed as a percentage or absolute value.' ;
    rdfs:domain ind:MarketingAbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalConversions rdf:type rdf:Property ;
    rdfs:label 'Total Conversions' ;
    rdfs:comment 'Aggregate number of conversion events recorded across all variants.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalImpressions rdf:type rdf:Property ;
    rdfs:label 'Total Impressions' ;
    rdfs:comment 'Aggregate number of times any variant was shown to users.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRevenue rdf:type rdf:Property ;
    rdfs:label 'Total Revenue' ;
    rdfs:comment 'Total revenue attributed to the test across all variants.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trafficSplit rdf:type rdf:Property ;
    rdfs:label 'Traffic Split' ;
    rdfs:comment 'JSON or delimited string describing how visitor traffic is allocated across variants (e.g., {"control":50,"variant_a":25,"variant_b":25}).' ;
    rdfs:domain ind:MarketingAbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantDetails rdf:type rdf:Property ;
    rdfs:label 'Variant Details' ;
    rdfs:comment 'JSON string containing an array of objects with per-variant metrics (name, allocation_pct, impressions, conversions, revenue, lift_vs_control).' ;
    rdfs:domain ind:MarketingAbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winningVariant rdf:type rdf:Property ;
    rdfs:label 'Winning Variant' ;
    rdfs:comment 'Name or identifier of the variant declared as the winner after evaluation.' ;
    rdfs:domain ind:MarketingAbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralId rdf:type rdf:Property ;
    rdfs:label 'Referral Id' ;
    rdfs:comment 'Unique system-generated identifier for the referral record.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referralCustomerProfileId rdf:type rdf:Property ;
    rdfs:label 'Referral Customer Profile Id' ;
    rdfs:comment 'Identifier of the existing customer who made the referral.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerProfile .

ind:referralRefereeCustomerProfileId rdf:type rdf:Property ;
    rdfs:label 'Referral Referee Customer Profile Id' ;
    rdfs:comment 'Identifier of the prospect who was referred (may be null until conversion).' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerProfile .

ind:sourceCampaignId rdf:type rdf:Property ;
    rdfs:label 'Source Campaign Id' ;
    rdfs:comment 'Identifier of the marketing campaign that generated the referral (if applicable).' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:incentiveAmount rdf:type rdf:Property ;
    rdfs:label 'Incentive Amount' ;
    rdfs:comment 'Monetary value of the incentive provided to the referee.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveCurrency rdf:type rdf:Property ;
    rdfs:label 'Incentive Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the referee incentive amount.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveType rdf:type rdf:Property ;
    rdfs:label 'Incentive Type' ;
    rdfs:comment 'Type of incentive offered to the referred prospect (e.g., discount, credit, gift card, cash, loyalty points).' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralDate rdf:type rdf:Property ;
    rdfs:label 'Referral Date' ;
    rdfs:comment 'Timestamp when the referral was created or sent to the prospect.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referralStatus rdf:type rdf:Property ;
    rdfs:label 'Referral Status' ;
    rdfs:comment 'Current lifecycle status of the referral.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardAmount rdf:type rdf:Property ;
    rdfs:label 'Reward Amount' ;
    rdfs:comment 'Monetary value of the reward given to the referrer.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rewardCurrency rdf:type rdf:Property ;
    rdfs:label 'Reward Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the referrer reward amount.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardType rdf:type rdf:Property ;
    rdfs:label 'Reward Type' ;
    rdfs:comment 'Type of incentive granted to the referrer (e.g., discount, store credit, gift card, cash, loyalty points).' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seoPageId rdf:type rdf:Property ;
    rdfs:label 'Seo Page Id' ;
    rdfs:comment 'Unique identifier for the SEO page record.' ;
    rdfs:domain ind:SeoPage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averagePosition rdf:type rdf:Property ;
    rdfs:label 'Average Position' ;
    rdfs:comment 'Mean ranking position of the page across all keyword queries.' ;
    rdfs:domain ind:SeoPage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countryTarget rdf:type rdf:Property ;
    rdfs:label 'Country Target' ;
    rdfs:comment 'ISO 3166-1 alpha-3 code of the primary market for the page.' ;
    rdfs:domain ind:SeoPage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crawlStatus rdf:type rdf:Property ;
    rdfs:label 'Crawl Status' ;
    rdfs:comment 'Current status of the page in the search engine crawl process.' ;
    rdfs:domain ind:SeoPage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:domainAuthority rdf:type rdf:Property ;
    rdfs:label 'Domain Authority' ;
    rdfs:comment 'Authority score of the page\'s domain as measured by third-party SEO tools.' ;
    rdfs:domain ind:SeoPage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:duplicateContentFlag rdf:type rdf:Property ;
    rdfs:label 'Duplicate Content Flag' ;
    rdfs:comment 'True when the page has substantial duplicate content detected.' ;
    rdfs:domain ind:SeoPage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalPageReference rdf:type rdf:Property ;
    rdfs:label 'External Page Reference' ;
    rdfs:comment 'Identifier used by external SEO tools or CMS for this page.' ;
    rdfs:domain ind:SeoPage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexStatus rdf:type rdf:Property ;
    rdfs:label 'Index Status' ;
    rdfs:comment 'Whether the page is indexed, excluded, or blocked from search results.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRedirect rdf:type rdf:Property ;
    rdfs:label 'Is Redirect' ;
    rdfs:comment 'True if the page URL redirects to another URL.' ;
    rdfs:domain ind:SeoPage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCrawledDate rdf:type rdf:Property ;
    rdfs:label 'Last Crawled Date' ;
    rdfs:comment 'Date when the page was most recently crawled by the search engine.' ;
    rdfs:domain ind:SeoPage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:missingMetaFlag rdf:type rdf:Property ;
    rdfs:label 'Missing Meta Flag' ;
    rdfs:comment 'True if required SEO meta tags (title, description) are missing.' ;
    rdfs:domain ind:SeoPage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mobileFriendly rdf:type rdf:Property ;
    rdfs:label 'Mobile Friendly' ;
    rdfs:comment 'Indicates if the page passes mobile usability criteria.' ;
    rdfs:domain ind:SeoPage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:organicClicks rdf:type rdf:Property ;
    rdfs:label 'Organic Clicks' ;
    rdfs:comment 'Number of clicks the page received from organic search results.' ;
    rdfs:domain ind:SeoPage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:organicImpressions rdf:type rdf:Property ;
    rdfs:label 'Organic Impressions' ;
    rdfs:comment 'Number of times the page appeared in organic search results.' ;
    rdfs:domain ind:SeoPage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pageClassification rdf:type rdf:Property ;
    rdfs:label 'Page Classification' ;
    rdfs:comment 'Business classification indicating the page\'s primary purpose.' ;
    rdfs:domain ind:SeoPage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageLoadTimeMs rdf:type rdf:Property ;
    rdfs:label 'Page Load Time Ms' ;
    rdfs:comment 'Measured page load time in milliseconds, impacting SEO performance.' ;
    rdfs:domain ind:SeoPage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redirectTargetUrl rdf:type rdf:Property ;
    rdfs:label 'Redirect Target Url' ;
    rdfs:comment 'Destination URL of the redirect, if applicable.' ;
    rdfs:domain ind:SeoPage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:robotsMeta rdf:type rdf:Property ;
    rdfs:label 'Robots Meta' ;
    rdfs:comment 'Value of the robots meta tag controlling indexing and crawling.' ;
    rdfs:domain ind:SeoPage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sitemapInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Sitemap Inclusion Flag' ;
    rdfs:comment 'True if the page URL is listed in the XML sitemap.' ;
    rdfs:domain ind:SeoPage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:structuredDataPresent rdf:type rdf:Property ;
    rdfs:label 'Structured Data Present' ;
    rdfs:comment 'True if the page contains valid schema.org structured data.' ;
    rdfs:domain ind:SeoPage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetKeywordCluster rdf:type rdf:Property ;
    rdfs:label 'Target Keyword Cluster' ;
    rdfs:comment 'Primary keyword group the page is optimized for.' ;
    rdfs:domain ind:SeoPage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adEventId rdf:type rdf:Property ;
    rdfs:label 'Ad Event Id' ;
    rdfs:comment 'Primary key for ad_event' ;
    rdfs:domain ind:AdEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adCampaignId rdf:type rdf:Property ;
    rdfs:label 'Ad Campaign Id' ;
    rdfs:comment 'Identifier of the advertising campaign to which the event belongs.' ;
    rdfs:domain ind:AdEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:adPlacementId rdf:type rdf:Property ;
    rdfs:label 'Ad Placement Id' ;
    rdfs:comment 'Unique identifier for the specific ad placement instance.' ;
    rdfs:domain ind:Marketplace ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdPlacement .

ind:sponsoredListingId rdf:type rdf:Property ;
    rdfs:label 'Sponsored Listing Id' ;
    rdfs:comment 'Reference to the sponsored product listing that generated the ad event.' ;
    rdfs:domain ind:Marketplace ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SponsoredListing .

ind:adBidAmount rdf:type rdf:Property ;
    rdfs:label 'Ad Bid Amount' ;
    rdfs:comment 'The bid price submitted for the ad placement.' ;
    rdfs:domain ind:AdEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adBidCurrency rdf:type rdf:Property ;
    rdfs:label 'Ad Bid Currency' ;
    rdfs:comment 'ISO 4217 currency code for the bid amount. [ENUM-REF-CANDIDATE: USD|EUR|GBP|JPY|CAD|AUD|... — promote to reference product]' ;
    rdfs:domain ind:AdEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adClickTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ad Click Timestamp' ;
    rdfs:comment 'Timestamp of the click event (populated when event_type = click).' ;
    rdfs:domain ind:AdEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adConversionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ad Conversion Timestamp' ;
    rdfs:comment 'Timestamp of the conversion event (populated when event_type = conversion).' ;
    rdfs:domain ind:AdEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adCostModel rdf:type rdf:Property ;
    rdfs:label 'Ad Cost Model' ;
    rdfs:comment 'Billing model for the ad: cost per mille (CPM) or cost per click (CPC).' ;
    rdfs:domain ind:AdEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adImpressionCode rdf:type rdf:Property ;
    rdfs:label 'Ad Impression Code' ;
    rdfs:comment 'Unique identifier for the impression event (if event_type is impression).' ;
    rdfs:domain ind:AdEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Ad Revenue Amount' ;
    rdfs:comment 'Revenue credited to the seller for the ad interaction (e.g., commission).' ;
    rdfs:domain ind:AdEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adRevenueCurrency rdf:type rdf:Property ;
    rdfs:label 'Ad Revenue Currency' ;
    rdfs:comment 'ISO 4217 currency code for the ad revenue amount. [ENUM-REF-CANDIDATE: USD|EUR|GBP|JPY|CAD|AUD|... — promote to reference product]' ;
    rdfs:domain ind:AdEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adStatus rdf:type rdf:Property ;
    rdfs:label 'Ad Status' ;
    rdfs:comment 'Current lifecycle status of the ad event record.' ;
    rdfs:domain ind:AdEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionWindowSeconds rdf:type rdf:Property ;
    rdfs:label 'Attribution Window Seconds' ;
    rdfs:comment 'Configured time window used to attribute conversions to clicks.' ;
    rdfs:domain ind:AdEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buyerSessionCode rdf:type rdf:Property ;
    rdfs:label 'Buyer Session Code' ;
    rdfs:comment 'Identifier of the buyer\'s browsing session associated with the ad event.' ;
    rdfs:domain ind:AdEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clickToConversionSeconds rdf:type rdf:Property ;
    rdfs:label 'Click To Conversion Seconds' ;
    rdfs:comment 'Elapsed seconds between the click event and the resulting conversion, if applicable.' ;
    rdfs:domain ind:AdEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the ad cost amount. [ENUM-REF-CANDIDATE: USD|EUR|GBP|JPY|CAD|AUD|... — promote to reference product]' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftcDisclosureRendered rdf:type rdf:Property ;
    rdfs:label 'Ftc Disclosure Rendered' ;
    rdfs:comment 'Indicates whether the required FTC advertising disclosure was displayed to the buyer.' ;
    rdfs:domain ind:AdEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placementPosition rdf:type rdf:Property ;
    rdfs:label 'Placement Position' ;
    rdfs:comment 'Logical placement identifier (e.g., top, sidebar, below_fold) where the ad was shown.' ;
    rdfs:domain ind:AdEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Viewability Flag' ;
    rdfs:comment 'True if the ad met viewability standards (e.g., 50% of pixels in view for 1 second).' ;
    rdfs:domain ind:AdEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:viewabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Viewability Percentage' ;
    rdfs:comment 'Measured percentage of the ad that was in view during the impression.' ;
    rdfs:domain ind:AdEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buyBoxRuleId rdf:type rdf:Property ;
    rdfs:label 'Buy Box Rule Id' ;
    rdfs:comment 'Unique identifier for the buy box rule definition.' ;
    rdfs:domain ind:BuyBoxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buyBoxRuleStatus rdf:type rdf:Property ;
