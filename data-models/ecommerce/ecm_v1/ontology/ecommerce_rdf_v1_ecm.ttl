    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentRuleCode rdf:type rdf:Property ;
    rdfs:label 'Assignment Rule Code' ;
    rdfs:comment 'Code of the personalization or business rule governing content assignment to the slot.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentAssignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Content Assignment Status' ;
    rdfs:comment 'Current status of content items assigned to the slot.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayPriority rdf:type rdf:Property ;
    rdfs:label 'Display Priority' ;
    rdfs:comment 'Numeric priority determining slot ordering when multiple slots share a page region (lower = higher priority).' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
