    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerResponseDate rdf:type rdf:Property ;
    rdfs:label 'Seller Response Date' ;
    rdfs:comment 'Timestamp when the seller posted a response to the review.' ;
    rdfs:domain ind:Rating ;
