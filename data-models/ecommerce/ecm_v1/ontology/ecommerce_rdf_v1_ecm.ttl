ind:walletName rdf:type rdf:Property ;
    rdfs:label 'Wallet Name' ;
    rdfs:comment 'Descriptive name for the wallet (e.g., "My Store Credit").' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:walletNumber rdf:type rdf:Property ;
    rdfs:label 'Wallet Number' ;
    rdfs:comment 'Human-readable unique wallet number assigned to the account.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:walletStatus rdf:type rdf:Property ;
    rdfs:label 'Wallet Status' ;
    rdfs:comment 'Current operational state of the wallet.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:walletType rdf:type rdf:Property ;
    rdfs:label 'Wallet Type' ;
    rdfs:comment 'Category of wallet indicating its purpose and rules (store credit, loyalty points, prepaid balance, gift, promotional).' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorPriceId rdf:type rdf:Property ;
    rdfs:label 'Competitor Price Id' ;
    rdfs:comment 'Unique surrogate key for each competitor price observation record.' ;
    rdfs:domain ind:CompetitorPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitorId rdf:type rdf:Property ;
    rdfs:label 'Competitor Id' ;
    rdfs:comment 'Internal identifier for the competitor providing the price.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Competitor .

ind:competitorProductId rdf:type rdf:Property ;
    rdfs:label 'Competitor Product Id' ;
    rdfs:comment 'Identifier used by the competitor (e.g., SKU, ASIN) for the product whose price is observed.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompetitorProduct .

ind:competitorPriceStatus rdf:type rdf:Property ;
    rdfs:label 'Competitor Price Status' ;
    rdfs:comment 'Current lifecycle status of the price observation record.' ;
    rdfs:domain ind:CompetitorPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchConfidence rdf:type rdf:Property ;
    rdfs:label 'Match Confidence' ;
    rdfs:comment 'Confidence percentage (0-100) that the competitor product correctly matches our internal product.' ;
    rdfs:domain ind:CompetitorPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:observedPrice rdf:type rdf:Property ;
    rdfs:label 'Observed Price' ;
    rdfs:comment 'Price value captured from the competitor at the observation time.' ;
    rdfs:domain ind:CompetitorPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:observedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Observed Timestamp' ;
    rdfs:comment 'Date-time when the competitor price was captured.' ;
    rdfs:domain ind:CompetitorPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priceChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Price Change Flag' ;
    rdfs:comment 'True if the observed price differs from the previous capture for the same product and competitor.' ;
    rdfs:domain ind:CompetitorPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:couponId rdf:type rdf:Property ;
    rdfs:label 'Coupon Id' ;
    rdfs:comment 'Unique surrogate key for each coupon record.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Coupon .

ind:couponDescription rdf:type rdf:Property ;
    rdfs:label 'Coupon Description' ;
    rdfs:comment 'Human-readable description of the coupon purpose and terms.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponStatus rdf:type rdf:Property ;
    rdfs:label 'Coupon Status' ;
    rdfs:comment 'Current lifecycle state of the coupon.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponType rdf:type rdf:Property ;
    rdfs:label 'Coupon Type' ;
    rdfs:comment 'Classification of the coupon instrument (e.g., public coupon, targeted voucher, batch-issued code, gift card).' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountType rdf:type rdf:Property ;
    rdfs:label 'Discount Type' ;
    rdfs:comment 'Mechanism of the discount applied by the coupon.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionMethod rdf:type rdf:Property ;
    rdfs:label 'Distribution Method' ;
    rdfs:comment 'Channel through which the coupon code was delivered to the customer.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleCategoryScope rdf:type rdf:Property ;
    rdfs:label 'Eligible Category Scope' ;
    rdfs:comment 'Comma-separated list of product category identifiers for which the coupon is valid.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleCustomerSegment rdf:type rdf:Property ;
    rdfs:label 'Eligible Customer Segment' ;
    rdfs:comment 'Customer segment (e.g., new_user, high_value, churn_risk) that qualifies for the coupon.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleProductScope rdf:type rdf:Property ;
    rdfs:label 'Eligible Product Scope' ;
    rdfs:comment 'Comma-separated list or pattern of product identifiers (SKU, ASIN, etc.) that the coupon can be applied to.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOneTimeUse rdf:type rdf:Property ;
    rdfs:label 'Is One Time Use' ;
    rdfs:comment 'True if the coupon may be redeemed only once across all customers.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuanceChannel rdf:type rdf:Property ;
    rdfs:label 'Issuance Channel' ;
    rdfs:comment 'System or process that generated the coupon (e.g., campaign engine, manual upload).' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Max Discount Amount' ;
    rdfs:comment 'Upper cap on the monetary value that can be deducted by the coupon.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Min Order Amount' ;
    rdfs:comment 'Minimum order subtotal required for the coupon to be applicable.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionCount rdf:type rdf:Property ;
    rdfs:label 'Redemption Count' ;
    rdfs:comment 'Current count of how many times the coupon has been redeemed.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRedemptionCap rdf:type rdf:Property ;
    rdfs:label 'Total Redemption Cap' ;
    rdfs:comment 'Overall maximum number of redemptions allowed across all customers.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageLimitPerCustomer rdf:type rdf:Property ;
    rdfs:label 'Usage Limit Per Customer' ;
    rdfs:comment 'Maximum number of times a single customer may redeem this coupon.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:couponRedemptionId rdf:type rdf:Property ;
    rdfs:label 'Coupon Redemption Id' ;
    rdfs:comment 'Unique surrogate key for each coupon redemption event.' ;
    rdfs:domain ind:CouponRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliedQuantity rdf:type rdf:Property ;
    rdfs:label 'Applied Quantity' ;
    rdfs:comment 'Number of units of the SKU that the coupon discount covered.' ;
    rdfs:domain ind:CouponRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliedToSku rdf:type rdf:Property ;
    rdfs:label 'Applied To Sku' ;
    rdfs:comment 'SKU of the product to which the coupon discount was applied.' ;
    rdfs:domain ind:CouponRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponRedemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Coupon Redemption Status' ;
    rdfs:comment 'Outcome of the redemption attempt: success, failure, or partial.' ;
    rdfs:domain ind:CouponRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionCode rdf:type rdf:Property ;
    rdfs:label 'Redemption Code' ;
    rdfs:comment 'The coupon or voucher code that was redeemed.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Redemption Timestamp' ;
    rdfs:comment 'Exact date and time when the coupon was redeemed.' ;
    rdfs:domain ind:CouponRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:redemptionType rdf:type rdf:Property ;
    rdfs:label 'Redemption Type' ;
    rdfs:comment 'Classification of how the coupon can be used: single-use, multi-use, or auto-apply.' ;
    rdfs:domain ind:CouponRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationEnd rdf:type rdf:Property ;
    rdfs:label 'Activation End' ;
    rdfs:comment 'Timestamp when the rule expires or is deactivated.' ;
    rdfs:domain ind:DynamicPriceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:activationStart rdf:type rdf:Property ;
    rdfs:label 'Activation Start' ;
    rdfs:comment 'Timestamp when the rule becomes effective.' ;
    rdfs:domain ind:DynamicPriceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adjustmentUnit rdf:type rdf:Property ;
    rdfs:label 'Adjustment Unit' ;
    rdfs:comment 'Unit of the adjustment value, matching the adjustment_type (percentage or currency).' ;
    rdfs:domain ind:DynamicPriceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentValue rdf:type rdf:Property ;
    rdfs:label 'Adjustment Value' ;
    rdfs:comment 'Numeric value used with the adjustment_type (e.g., 5.0 for 5% or 2.50 for $2.50).' ;
    rdfs:domain ind:DynamicPriceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicableSkuPattern rdf:type rdf:Property ;
    rdfs:label 'Applicable Sku Pattern' ;
    rdfs:comment 'Wildcard or regex pattern that matches SKUs to which the rule applies.' ;
    rdfs:domain ind:DynamicPriceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandCode rdf:type rdf:Property ;
    rdfs:label 'Brand Code' ;
    rdfs:comment 'Identifier for the brand whose products the rule may affect.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Code of the product category targeted by the rule.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceilingPrice rdf:type rdf:Property ;
    rdfs:label 'Ceiling Price' ;
    rdfs:comment 'Maximum price that the rule will not allow the SKU to exceed.' ;
    rdfs:domain ind:DynamicPriceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:floorPrice rdf:type rdf:Property ;
    rdfs:label 'Floor Price' ;
    rdfs:comment 'Minimum price that the rule will not allow the SKU to drop below.' ;
    rdfs:domain ind:DynamicPriceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isExperimental rdf:type rdf:Property ;
    rdfs:label 'Is Experimental' ;
    rdfs:comment 'Marks the rule as part of an A/B pricing experiment.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGlobal rdf:type rdf:Property ;
    rdfs:label 'Is Global' ;
    rdfs:comment 'True if the rule applies across all marketplaces and sellers.' ;
    rdfs:domain ind:DynamicPriceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceElasticityScore rdf:type rdf:Property ;
    rdfs:label 'Price Elasticity Score' ;
    rdfs:comment 'Pre-computed elasticity metric used by the rule engine to gauge demand sensitivity.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ruleCategory rdf:type rdf:Property ;
    rdfs:label 'Rule Category' ;
    rdfs:comment 'High-level classification of the rule\'s purpose.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleOwner rdf:type rdf:Property ;
    rdfs:label 'Rule Owner' ;
    rdfs:comment 'Team or individual responsible for the rule\'s lifecycle.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testGroup rdf:type rdf:Property ;
    rdfs:label 'Test Group' ;
    rdfs:comment 'Indicates the A/B test group assignment for the rule.' ;
    rdfs:domain ind:DynamicPriceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerCondition rdf:type rdf:Property ;
    rdfs:label 'Trigger Condition' ;
    rdfs:comment 'Serialized condition expression (e.g., JSON) that determines when the rule fires, based on demand, inventory, competitor price, etc.' ;
    rdfs:domain ind:DynamicPriceRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Markdown Schedule Status' ;
    rdfs:comment 'Current lifecycle state of the schedule.' ;
    rdfs:domain ind:MarkdownSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownType rdf:type rdf:Property ;
    rdfs:label 'Markdown Type' ;
    rdfs:comment 'Indicates whether the markdown is a percentage reduction or an absolute monetary amount.' ;
    rdfs:domain ind:MarkdownSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:markdownValue rdf:type rdf:Property ;
    rdfs:label 'Markdown Value' ;
    rdfs:comment 'The reduction amount: either a percentage (e.g., 0.15 for 15%) or a fixed currency amount, depending on markdown_type.' ;
    rdfs:domain ind:MarkdownSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketRegion rdf:type rdf:Property ;
    rdfs:label 'Market Region' ;
    rdfs:comment 'Geographic market region for which the markdown is valid.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxQuantity rdf:type rdf:Property ;
    rdfs:label 'Max Quantity' ;
    rdfs:comment 'Maximum purchase quantity for which the markdown is valid (optional).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minQuantity rdf:type rdf:Property ;
    rdfs:label 'Min Quantity' ;
    rdfs:comment 'Minimum purchase quantity required for the markdown to apply.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productSku rdf:type rdf:Property ;
    rdfs:label 'Product Sku' ;
    rdfs:comment 'Stock Keeping Unit of the product to which the markdown applies.' ;
    rdfs:domain ind:MarkdownSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'Business justification for the markdown (e.g., end-of-season, clearance, overstock).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runCount rdf:type rdf:Property ;
    rdfs:label 'Run Count' ;
    rdfs:comment 'Number of times the schedule has been applied to orders.' ;
    rdfs:domain ind:MarkdownSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'Specific sales channel where the markdown is offered.' ;
    rdfs:domain ind:MarkdownSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleCode rdf:type rdf:Property ;
    rdfs:label 'Schedule Code' ;
    rdfs:comment 'Business-visible code used to reference the schedule in external systems.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleDescription rdf:type rdf:Property ;
    rdfs:label 'Schedule Description' ;
    rdfs:comment 'Extended free-text description of the markdown schedule.' ;
    rdfs:domain ind:MarkdownSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverAccountId rdf:type rdf:Property ;
    rdfs:label 'Approver Account Id' ;
    rdfs:comment 'Internal identifier of the employee or role authorized to approve or reject the request.' ;
    rdfs:domain ind:PriceApproval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:affectedEntityReference rdf:type rdf:Property ;
    rdfs:label 'Affected Entity Reference' ;
    rdfs:comment 'Unique identifier of the specific product, category, seller, or order impacted by the price change.' ;
    rdfs:domain ind:PriceApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedEntityType rdf:type rdf:Property ;
    rdfs:label 'Affected Entity Type' ;
    rdfs:comment 'Type of business object whose price is being changed.' ;
    rdfs:domain ind:PriceApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Number' ;
    rdfs:comment 'Human-readable identifier assigned to the price change request for tracking and audit.' ;
    rdfs:domain ind:PriceApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationCount rdf:type rdf:Property ;
    rdfs:label 'Escalation Count' ;
    rdfs:comment 'Number of times the request has been escalated to higher authority.' ;
    rdfs:domain ind:PriceApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:justification rdf:type rdf:Property ;
    rdfs:label 'Justification' ;
    rdfs:comment 'Narrative explanation of the business reason behind the price modification.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalPrice rdf:type rdf:Property ;
    rdfs:label 'Original Price' ;
    rdfs:comment 'Current price before the proposed change, expressed in the applicable currency.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Price Approval Status' ;
    rdfs:comment 'Current lifecycle state of the price approval request.' ;
    rdfs:domain ind:PriceApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceDifference rdf:type rdf:Property ;
    rdfs:label 'Price Difference' ;
    rdfs:comment 'Calculated delta between proposed and original price (positive for increase, negative for decrease).' ;
    rdfs:domain ind:PriceApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proposedPrice rdf:type rdf:Property ;
    rdfs:label 'Proposed Price' ;
    rdfs:comment 'New price being requested, expressed in the applicable currency.' ;
    rdfs:domain ind:PriceApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rejection Timestamp' ;
    rdfs:comment 'Exact time the request was rejected.' ;
    rdfs:domain ind:PriceApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaDeadline rdf:type rdf:Property ;
    rdfs:label 'Sla Deadline' ;
    rdfs:comment 'Target date-time by which the approval decision must be completed to meet internal SLA.' ;
    rdfs:domain ind:PriceApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaMet rdf:type rdf:Property ;
    rdfs:label 'Sla Met' ;
    rdfs:comment 'Indicates whether the approval was completed within the defined SLA window.' ;
    rdfs:domain ind:PriceApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceExperimentId rdf:type rdf:Property ;
    rdfs:label 'Price Experiment Id' ;
    rdfs:comment 'System-generated unique identifier for the pricing experiment record.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceExperiment .

ind:businessIdentifier rdf:type rdf:Property ;
    rdfs:label 'Business Identifier' ;
    rdfs:comment 'External reference code used by business teams to identify the experiment.' ;
    rdfs:domain ind:PriceExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationOrType rdf:type rdf:Property ;
    rdfs:label 'Classification Or Type' ;
    rdfs:comment 'High-level classification of the experiment (e.g., pricing_experiment).' ;
    rdfs:domain ind:PriceExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlPrice rdf:type rdf:Property ;
    rdfs:label 'Control Price' ;
    rdfs:comment 'Baseline price used for the control group in the experiment.' ;
    rdfs:domain ind:PriceExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:experimentName rdf:type rdf:Property ;
    rdfs:label 'Experiment Name' ;
    rdfs:comment 'Human-readable name given to the pricing experiment for reporting and analysis.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentType rdf:type rdf:Property ;
    rdfs:label 'Experiment Type' ;
    rdfs:comment 'Classification of the experiment design: A/B test or multivariate test.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalRecommendation rdf:type rdf:Property ;
    rdfs:label 'Final Recommendation' ;
    rdfs:comment 'Business decision after experiment conclusion.' ;
    rdfs:domain ind:PriceExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successMetricAov rdf:type rdf:Property ;
    rdfs:label 'Success Metric Aov' ;
    rdfs:comment 'Primary metric used to evaluate experiment success for average order value.' ;
    rdfs:domain ind:PriceExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successMetricCvr rdf:type rdf:Property ;
    rdfs:label 'Success Metric Cvr' ;
    rdfs:comment 'Primary metric used to evaluate experiment success for conversion.' ;
    rdfs:domain ind:PriceExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successMetricGmv rdf:type rdf:Property ;
    rdfs:label 'Success Metric Gmv' ;
    rdfs:comment 'Primary metric used to evaluate experiment success for GMV.' ;
    rdfs:domain ind:PriceExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCategory rdf:type rdf:Property ;
    rdfs:label 'Target Category' ;
    rdfs:comment 'Product category (or hierarchy node) that the experiment applies to.' ;
    rdfs:domain ind:PriceExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSkuList rdf:type rdf:Property ;
    rdfs:label 'Target Sku List' ;
    rdfs:comment 'Comma-separated list of SKU identifiers included in the experiment.' ;
    rdfs:domain ind:PriceExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficSplitPercentage rdf:type rdf:Property ;
    rdfs:label 'Traffic Split Percentage' ;
    rdfs:comment 'Percentage of total traffic assigned to each variant (control and variants).' ;
    rdfs:domain ind:PriceExperiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variant1ConfidenceInterval rdf:type rdf:Property ;
