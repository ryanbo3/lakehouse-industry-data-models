    rdfs:comment 'Current status of the category performance record.' ;
    rdfs:domain ind:CategoryPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceScore rdf:type rdf:Property ;
