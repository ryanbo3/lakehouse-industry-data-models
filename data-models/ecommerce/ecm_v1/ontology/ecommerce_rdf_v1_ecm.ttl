    rdfs:range xsd:decimal .

ind:optimizationAlgorithmVersion rdf:type rdf:Property ;
    rdfs:label 'Optimization Algorithm Version' ;
    rdfs:comment 'Version identifier of the algorithm used to generate or optimize the route.' ;
