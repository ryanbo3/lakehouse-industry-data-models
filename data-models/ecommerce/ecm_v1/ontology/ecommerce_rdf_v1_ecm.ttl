    rdfs:range xsd:integer .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-form comments or remarks about the attribution calculation.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
