ind:maxUses rdf:type rdf:Property ;
    rdfs:label 'Max Uses' ;
    rdfs:comment 'Maximum number of times the campaign can be applied across all customers.' ;
    rdfs:domain ind:PromotionalCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:owningBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Owning Business Unit' ;
    rdfs:comment 'Organizational unit responsible for the campaign (e.g., marketing, pricing).' ;
    rdfs:domain ind:PromotionalCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategoryScope rdf:type rdf:Property ;
    rdfs:label 'Product Category Scope' ;
    rdfs:comment 'Comma-separated list of product categories the campaign applies to. [ENUM-REF-CANDIDATE: electronics|fashion|home|beauty|sports|toys|automotive|grocery|health|books|music|software|other — promote to reference product]' ;
    rdfs:domain ind:PromotionalCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalCampaignDescription rdf:type rdf:Property ;
    rdfs:label 'Promotional Campaign Description' ;
    rdfs:comment 'Detailed description of the campaign objectives, mechanics and any special notes.' ;
    rdfs:domain ind:PromotionalCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalCampaignName rdf:type rdf:Property ;
    rdfs:label 'Promotional Campaign Name' ;
    rdfs:comment 'Human-readable name of the promotional campaign.' ;
    rdfs:domain ind:PromotionalCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalCampaignStatus rdf:type rdf:Property ;
    rdfs:label 'Promotional Campaign Status' ;
    rdfs:comment 'Current lifecycle state of the campaign.' ;
    rdfs:domain ind:PromotionalCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionLimitPerCustomer rdf:type rdf:Property ;
    rdfs:label 'Redemption Limit Per Customer' ;
    rdfs:comment 'Maximum number of times a single customer may redeem the campaign.' ;
    rdfs:domain ind:PromotionalCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionTotalLimit rdf:type rdf:Property ;
    rdfs:label 'Redemption Total Limit' ;
    rdfs:comment 'Overall cap on the number of redemptions across all customers.' ;
    rdfs:domain ind:PromotionalCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skuInclusionCriteria rdf:type rdf:Property ;
    rdfs:label 'Sku Inclusion Criteria' ;
    rdfs:comment 'Rule expression defining which SKUs are eligible for the promotion.' ;
    rdfs:domain ind:PromotionalCampaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedVendorListId rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor List Id' ;
    rdfs:comment 'System-generated unique identifier for each record in the approved vendor list.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedSupplierId rdf:type rdf:Property ;
    rdfs:label 'Approved Supplier Id' ;
    rdfs:comment 'FK to procurement.supplier' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:primaryApprovedSupplierId rdf:type rdf:Property ;
    rdfs:label 'Primary Approved Supplier Id' ;
    rdfs:comment 'Unique identifier of the vendor (supplier) referenced in the approved list.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:complianceIsoCertified rdf:type rdf:Property ;
    rdfs:label 'Compliance Iso Certified' ;
    rdfs:comment 'True if the vendor holds a current ISO certification relevant to the business.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle state of the vendor contract.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpscCertificationExpiry rdf:type rdf:Property ;
    rdfs:label 'Cpsc Certification Expiry' ;
    rdfs:comment 'Expiration of the vendor\'s CPSC product safety certification.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cpscCompliant rdf:type rdf:Property ;
    rdfs:label 'Cpsc Compliant' ;
    rdfs:comment 'Indicates compliance with Consumer Product Safety Commission regulations.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDiversitySupplier rdf:type rdf:Property ;
    rdfs:label 'Is Diversity Supplier' ;
    rdfs:comment 'True if the vendor qualifies under the company\'s diversity supplier program.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPreferredVendor rdf:type rdf:Property ;
    rdfs:label 'Is Preferred Vendor' ;
    rdfs:comment 'Indicates whether the vendor is marked as a preferred supplier for strategic sourcing.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoCertificationExpiry rdf:type rdf:Property ;
    rdfs:label 'Iso Certification Expiry' ;
    rdfs:comment 'Expiration date of the vendor\'s ISO certification.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentCurrency rdf:type rdf:Property ;
    rdfs:label 'Payment Currency' ;
    rdfs:comment 'ISO 4217 currency code used for payments to the vendor.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciDssExpiry rdf:type rdf:Property ;
    rdfs:label 'Pci Dss Expiry' ;
    rdfs:comment 'Date when the vendor\'s PCI DSS compliance certification expires.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationCriteriaMet rdf:type rdf:Property ;
    rdfs:label 'Qualification Criteria Met' ;
    rdfs:comment 'Textual description of the specific criteria the vendor satisfied for approval.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationScore rdf:type rdf:Property ;
    rdfs:label 'Qualification Score' ;
    rdfs:comment 'Numerical score reflecting how well the vendor meets qualification criteria.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorCategory rdf:type rdf:Property ;
    rdfs:label 'Vendor Category' ;
    rdfs:comment 'Broad product or service category the vendor supplies (e.g., electronics, apparel).' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReturnId rdf:type rdf:Property ;
    rdfs:label 'Goods Return Id' ;
    rdfs:comment 'Unique system-generated identifier for the Return-to-Vendor (RTV) goods return transaction record. Primary key for this entity.' ;
    rdfs:domain ind:GoodsReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryGoodsAgentId rdf:type rdf:Property ;
    rdfs:label 'Primary Goods Agent Id' ;
    rdfs:comment 'Reference to the internal procurement buyer or purchasing agent who initiated and owns this RTV return transaction. Used for workflow routing, approval tracking, and performance reporting.' ;
    rdfs:domain ind:GoodsReturn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:chargebackAmount rdf:type rdf:Property ;
    rdfs:label 'Chargeback Amount' ;
    rdfs:comment 'Monetary amount of the vendor chargeback raised against the supplier for costs incurred due to the return (e.g., handling, inspection, re-stocking, logistics). Null if no chargeback is raised.' ;
    rdfs:domain ind:GoodsReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargebackRaised rdf:type rdf:Property ;
    rdfs:label 'Chargeback Raised' ;
    rdfs:comment 'Indicates whether a vendor chargeback has been formally raised against the supplier for this return (True = chargeback raised, False = no chargeback). Triggers the vendor chargeback workflow in accounts payable.' ;
    rdfs:domain ind:GoodsReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Credit Issued Date' ;
    rdfs:comment 'Calendar date on which the supplier issued the credit memo for the returned goods. Null until the return reaches \'credit_issued\' status. Triggers accounts payable offset in the finance domain.' ;
    rdfs:domain ind:GoodsReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditMemoActualAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Actual Amount' ;
    rdfs:comment 'Actual monetary value of the credit memo received from the supplier. May differ from the expected amount due to restocking fees, partial credit, or supplier disputes. Variance triggers chargeback resolution workflow.' ;
    rdfs:domain ind:GoodsReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditMemoExpectedAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Expected Amount' ;
    rdfs:comment 'Expected monetary value of the credit memo to be issued by the supplier for the returned goods, calculated based on the original purchase price and return quantity. Used for accounts payable offset and vendor chargeback workflows.' ;
    rdfs:domain ind:GoodsReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsDeclarationNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Number' ;
    rdfs:comment 'Customs or export declaration document number required for cross-border return shipments. Null for domestic returns. Required for WTO and EU Electronic Commerce Directive compliance.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'Calendar date on which the RTV return was formally initiated by the procurement team. Represents the principal business event date for this transaction. Used for SLA tracking and supplier performance measurement.' ;
    rdfs:domain ind:GoodsReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionResult rdf:type rdf:Property ;
    rdfs:label 'Inspection Result' ;
    rdfs:comment 'Result of the quality inspection performed on goods prior to initiating the return. PASS indicates goods confirmed defective/returnable, FAIL indicates goods do not meet return criteria, PENDING indicates inspection in progress, WAIVED indicates inspection bypassed per supplier agreement.' ;
    rdfs:domain ind:GoodsReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restockingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee Amount' ;
    rdfs:comment 'Monetary amount charged by the supplier as a restocking fee for accepting the return. Deducted from the credit memo amount. Tracked for supplier contract compliance and procurement cost management.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Return Authorization Number' ;
    rdfs:comment 'Supplier-issued authorization number approving the return of goods. Required before physical shipment of returned goods to the supplier. Distinct from the internal RTV number.' ;
    rdfs:domain ind:GoodsReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnCarrier rdf:type rdf:Property ;
    rdfs:label 'Return Carrier' ;
    rdfs:comment 'Name of the logistics carrier or 3PL (Third-Party Logistics) provider used to ship the returned goods back to the supplier (e.g., FedEx, UPS, DHL, XPO Logistics).' ;
    rdfs:domain ind:GoodsReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnQuantity rdf:type rdf:Property ;
    rdfs:label 'Return Quantity' ;
    rdfs:comment 'Number of units of the SKU being returned to the supplier in this RTV transaction. Must be a positive integer and cannot exceed the originally received quantity on the referenced Goods Receipt.' ;
    rdfs:domain ind:GoodsReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Return Reason Description' ;
    rdfs:comment 'Free-text narrative providing additional detail about the reason for the goods return, supplementing the standardized return reason code. Used for supplier dispute resolution and quality audit trails.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnStatus rdf:type rdf:Property ;
    rdfs:label 'Return Status' ;
    rdfs:comment 'Current lifecycle status of the RTV goods return transaction. Tracks progression from initiation through supplier receipt and credit issuance. Values: initiated (RTV created, pending shipment), shipped (goods dispatched to supplier), received_by_supplier (supplier confirmed receipt), credit_issued (credit memo received and applied), cancelled (return voided).' ;
    rdfs:domain ind:GoodsReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnWarehouseLocation rdf:type rdf:Property ;
    rdfs:label 'Return Warehouse Location' ;
    rdfs:comment 'Specific storage location or bin within the warehouse where returned goods are staged prior to dispatch to the supplier. Used by WMS for pick-pack-ship operations.' ;
    rdfs:domain ind:GoodsReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtvNumber rdf:type rdf:Property ;
    rdfs:label 'Rtv Number' ;
    rdfs:comment 'Externally-known business identifier for the Return-to-Vendor (RTV) transaction. Used in supplier communications, logistics documentation, and credit memo reconciliation. Format: RTV-{YEAR}-{SEQUENCE}.' ;
    rdfs:domain ind:GoodsReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierContactEmail rdf:type rdf:Property ;
    rdfs:label 'Supplier Contact Email' ;
    rdfs:comment 'Email address of the supplier representative managing this return. Used for return authorization communications and credit memo follow-up. Classified as confidential PII per GDPR.' ;
    rdfs:domain ind:GoodsReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierContactName rdf:type rdf:Property ;
    rdfs:label 'Supplier Contact Name' ;
    rdfs:comment 'Name of the supplier representative responsible for managing this return authorization and credit memo issuance. Used for procurement communication and dispute escalation.' ;
    rdfs:domain ind:GoodsReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierCountryCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the supplier\'s location to which goods are being returned. Used for customs documentation, international trade compliance, and logistics routing.' ;
    rdfs:domain ind:GoodsReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Supplier Received Date' ;
    rdfs:comment 'Calendar date on which the supplier confirmed receipt of the returned goods. Null until the return reaches \'received_by_supplier\' status. Used to calculate supplier return processing lead time.' ;
    rdfs:domain ind:GoodsReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unitReturnPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Return Price' ;
    rdfs:comment 'Per-unit price at which the goods are being returned to the supplier, typically matching the original Purchase Order unit price. Used to calculate the expected credit memo amount and for procurement cost analysis.' ;
    rdfs:domain ind:GoodsReturn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountAssignmentCategory rdf:type rdf:Property ;
    rdfs:label 'Account Assignment Category' ;
    rdfs:comment 'ERP account assignment category determining how the PO line item cost is posted in the general ledger (e.g., K=Cost Center, F=Order, P=Project, A=Asset, C=Sales Order, U=Unknown). Required for financial posting and SOX compliance.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'The delivery date confirmed by the supplier for this line item, as communicated via PO acknowledgement or supplier portal. Used for lead time analysis, on-time delivery KPI tracking, and logistics planning.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryLeadTimeVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Lead Time Variance Days' ;
    rdfs:comment 'Difference in calendar days between the confirmed delivery date and the actual delivery date for this line item. Positive value indicates late delivery; negative indicates early delivery. Key supplier on-time delivery (OTD) performance metric.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finalDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Final Delivery Flag' ;
    rdfs:comment 'Indicates whether the supplier has confirmed this as the final delivery for this PO line item, closing it against further goods receipts. True = final delivery confirmed; False = further deliveries expected. Used to close open PO lines.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptAmount rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Amount' ;
    rdfs:comment 'Total monetary value of goods received against this PO line (goods_receipt_quantity × unit_price). Used for inventory valuation, accrual accounting, and accounts payable liability recognition.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptBlockedFlag rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Blocked Flag' ;
    rdfs:comment 'Indicates whether goods receipt posting is blocked for this PO line item (e.g., due to quality inspection hold, price discrepancy, or compliance issue). True = GR blocked; False = GR allowed. Used in WMS receiving workflows.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptQuantity rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Quantity' ;
    rdfs:comment 'Total quantity of this line item received into the warehouse against this PO line. Populated from WMS goods receipt transactions. Used for partial fulfillment tracking, open quantity calculation, and 3-way invoice matching.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceVerificationFlag rdf:type rdf:Property ;
    rdfs:label 'Invoice Verification Flag' ;
    rdfs:comment 'Indicates whether invoice verification (3-way match: PO vs. GR vs. invoice) has been completed for this line item. True = verified; False = pending verification. Used for accounts payable processing and payment release.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoicedAmount rdf:type rdf:Property ;
    rdfs:label 'Invoiced Amount' ;
    rdfs:comment 'Total monetary value invoiced by the supplier for this PO line. Used for 3-way match variance analysis, accounts payable processing, and financial accrual reconciliation.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoicedQuantity rdf:type rdf:Property ;
    rdfs:label 'Invoiced Quantity' ;
    rdfs:comment 'Total quantity of this line item for which a supplier invoice has been received and matched. Used for 3-way match (PO quantity vs. GR quantity vs. invoice quantity), accounts payable processing, and payment settlement.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moqComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Moq Compliance Flag' ;
    rdfs:comment 'Indicates whether the ordered quantity on this line meets or exceeds the supplier\'s Minimum Order Quantity (MOQ) requirement. True = MOQ compliant; False = below MOQ threshold. Critical for supplier contract compliance and procurement workflow validation.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openQuantity rdf:type rdf:Property ;
    rdfs:label 'Open Quantity' ;
    rdfs:comment 'Remaining quantity yet to be received against this PO line (ordered_quantity minus goods_receipt_quantity). Supports open PO reporting, inventory replenishment monitoring, and supplier follow-up workflows.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'ERP plant or fulfillment center code to which this PO line item is being delivered. Identifies the receiving warehouse or distribution center in the fulfillment network. Used for inventory planning and logistics routing.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Price Variance Amount' ;
    rdfs:comment 'Monetary difference between the PO agreed unit price and the actual invoiced price for this line item. A key procurement KPI used for cost control, supplier negotiation analysis, and financial reporting under SOX.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason a PO line item was rejected, cancelled, or blocked (e.g., quality failure, price discrepancy, supplier non-compliance). Used for procurement analytics and supplier performance management.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'The date by which the buyer requests delivery of this line item from the supplier. Used for supply chain planning, inventory replenishment scheduling, and SLA monitoring. May differ from confirmed delivery date.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Identifier of the operational source system from which this PO line item record was ingested (e.g., SAP_S4HANA_PROD, ERP_EU, ERP_US). Supports data lineage tracking, multi-system reconciliation, and Silver Layer provenance.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'WMS storage location or warehouse bin code designated for receiving and putaway of this PO line item. Used for inventory allocation, pick-pack-ship operations, and FIFO inventory management.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Date' ;
    rdfs:comment 'Date the shipment physically arrived at the destination warehouse dock. Compared against estimated arrival date to calculate supplier on-time delivery performance (OTD KPI).' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchLotNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Lot Number' ;
    rdfs:comment 'Supplier-assigned batch or lot number for the received goods. Critical for traceability, recall management, FIFO inventory management, and quality inspection correlation. Mandatory for perishable, regulated, or serialized products.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'Supplier-issued delivery note or packing slip number accompanying the physical shipment. Used for receiving verification, three-way match, and dispute resolution with the supplier.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyQuantity rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Quantity' ;
    rdfs:comment 'Net difference between quantity shipped (per ASN) and quantity received (physically counted). Positive value indicates shortage; negative value indicates overage. Used for supplier dispute resolution and accounts payable adjustment.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Date' ;
    rdfs:comment 'Expected date of shipment arrival at the destination warehouse as communicated by the supplier or carrier via ASN. Used for dock scheduling, labor planning, and lead time performance measurement.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the freight cost is denominated (e.g., USD, EUR, GBP). Required for multi-currency freight reconciliation and FX conversion in SAP S/4HANA.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grNotes rdf:type rdf:Property ;
    rdfs:label 'Gr Notes' ;
    rdfs:comment 'Free-text notes recorded by the warehouse receiving team during the goods receipt process. Captures observations about shipment condition, packaging damage, partial delivery reasons, or special handling instructions not captured in structured fields.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grNumber rdf:type rdf:Property ;
    rdfs:label 'Gr Number' ;
    rdfs:comment 'Externally-known business identifier for the goods receipt document, used in supplier communications, three-way match, and ERP posting. Corresponds to the Material Document number in SAP S/4HANA MM (MIGO). Format: GR- followed by 10 digits.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gr Posting Date' ;
    rdfs:comment 'Accounting date on which the goods receipt is posted to the general ledger in SAP S/4HANA. Determines the financial period for inventory valuation and accounts payable accrual. Critical for period-end close and SOX compliance.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grPostingStatus rdf:type rdf:Property ;
    rdfs:label 'Gr Posting Status' ;
    rdfs:comment 'ERP posting status of the goods receipt document in SAP S/4HANA. Indicates whether the GR has been financially posted to the general ledger, is pending, has been reversed, or is blocked pending quality inspection clearance. Triggers three-way match in accounts payable upon \'posted\' status.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOverDelivery rdf:type rdf:Property ;
    rdfs:label 'Is Over Delivery' ;
    rdfs:comment 'Indicates whether the quantity received exceeds the quantity ordered on the purchase order, beyond the configured over-delivery tolerance. Triggers procurement workflow for approval or return-to-supplier action.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnderDelivery rdf:type rdf:Property ;
    rdfs:label 'Is Under Delivery' ;
    rdfs:comment 'Indicates whether the quantity received falls below the quantity ordered on the purchase order, beyond the configured under-delivery tolerance. May trigger a follow-up delivery or partial invoice processing in accounts payable.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originCountryCode rdf:type rdf:Property ;
    rdfs:label 'Origin Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the shipment origin. Required for customs declarations, import duty calculations, and trade compliance reporting under WTO regulations.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poLineNumber rdf:type rdf:Property ;
    rdfs:label 'Po Line Number' ;
    rdfs:comment 'Line item number on the originating purchase order that this goods receipt line corresponds to. Enables granular three-way match at the PO line level in accounts payable and ERP.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityReceived rdf:type rdf:Property ;
    rdfs:label 'Quantity Received' ;
    rdfs:comment 'Actual quantity of the SKU physically counted and accepted at the destination warehouse during the receiving process. Posted to WMS inventory and used for GR document creation in SAP S/4HANA.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRejected rdf:type rdf:Property ;
    rdfs:label 'Quantity Rejected' ;
    rdfs:comment 'Quantity of the SKU rejected during quality inspection due to damage, non-conformance, or specification failure. Drives Return Merchandise Authorization (RMA) creation and supplier debit note processing.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityShipped rdf:type rdf:Property ;
    rdfs:label 'Quantity Shipped' ;
    rdfs:comment 'Quantity of the SKU declared by the supplier on the Advance Shipment Notice (ASN) as dispatched. Used to identify pre-receipt discrepancies between ordered and shipped quantities.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingCompleteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receiving Complete Timestamp' ;
    rdfs:comment 'Date and time when the physical receiving process was completed and the GR document was confirmed in WMS. Used to calculate dock-to-stock cycle time and warehouse throughput metrics.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supplierInvoiceReference rdf:type rdf:Property ;
    rdfs:label 'Supplier Invoice Reference' ;
    rdfs:comment 'Supplier-provided invoice number associated with this goods receipt, used to link the GR to the corresponding accounts payable invoice for three-way match processing and payment settlement.' ;
    rdfs:domain ind:ProcurementGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blanketPoPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Blanket Po Purchase Order Id' ;
    rdfs:comment 'Reference to the parent blanket purchase order when this PO is a release against an open blanket agreement. Enables aggregation of spend and quantity consumed against the blanket PO ceiling.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:buyerAccountId rdf:type rdf:Property ;
    rdfs:label 'Buyer Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Associates drop-ship or direct-to-customer purchase orders with the buying customer.account for fulfillment and revenue reporting.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:goodsReceiptStatus rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Status' ;
    rdfs:comment 'Current status of goods receipt against this purchase order as recorded in the WMS and SAP S/4HANA MIGO. Tracks whether no goods have been received, some lines/quantities are received, or all ordered quantities have been fully received.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'International Commercial Terms (Incoterms 2020) defining the transfer of risk, cost responsibility, and delivery obligations between buyer and supplier. Determines who bears freight, insurance, and customs costs. Critical for landed cost calculation and logistics planning. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'The named place or port associated with the Incoterms condition (e.g., \'FOB Shanghai\', \'DAP Los Angeles\'). Specifies the exact point of risk transfer and cost responsibility as required by ICC Incoterms 2020.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Status of supplier invoice matching against this purchase order in the SAP S/4HANA three-way match process (PO, goods receipt, invoice). Tracks whether invoices have been received, partially matched, fully matched, or are under dispute.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isUrgent rdf:type rdf:Property ;
    rdfs:label 'Is Urgent' ;
    rdfs:comment 'Indicates whether this purchase order has been flagged as urgent, requiring expedited processing, prioritized supplier communication, and accelerated receiving. Typically set when inventory levels are critically low (OOS risk) or to fulfill a high-priority customer order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'The business date on which the purchase order was formally issued and transmitted to the supplier. Represents the principal real-world event time for this procurement transaction. Used as the baseline for lead time calculations and payment term due date computation.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order by procurement strategy. Standard = one-time discrete order; Blanket = open quantity/value agreement with releases; Consignment = supplier-owned stock held at warehouse; Drop-ship = supplier ships directly to customer; Service = non-goods procurement.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingGroup rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group' ;
    rdfs:comment 'SAP S/4HANA purchasing group code identifying the buyer team or commodity group responsible for this PO. Used for spend analytics, category management, and buyer performance reporting.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrg rdf:type rdf:Property ;
    rdfs:label 'Purchasing Org' ;
    rdfs:comment 'SAP S/4HANA purchasing organization code responsible for negotiating and issuing this purchase order. Determines the legal entity, currency, and terms applicable to the procurement transaction. Aligns with organizational hierarchy for spend reporting.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'The purchase requisition number from SAP S/4HANA ME51N that originated this purchase order. Provides the audit trail from business need (requisition) to formal commitment (PO) for SOX compliance and spend authorization tracking.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sent Timestamp' ;
    rdfs:comment 'Timestamp when the purchase order was electronically transmitted to the supplier via EDI, email, or supplier portal. Marks the start of the supplier lead time clock and is used for SLA and communication audit purposes.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shipToAddress rdf:type rdf:Property ;
    rdfs:label 'Ship To Address' ;
    rdfs:comment 'Full delivery address for the purchase order, including street, city, state/province, postal code, and country. Used for carrier routing, customs documentation, and inbound logistics coordination. May differ from the warehouse address for drop-ship or direct-to-store orders.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Reference Number' ;
    rdfs:comment 'The supplier\'s own order confirmation or reference number provided upon acknowledgement of the purchase order. Used for cross-referencing in supplier communications, EDI transactions, and invoice matching.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionId rdf:type rdf:Property ;
    rdfs:label 'Requisition Id' ;
    rdfs:comment 'Unique system-generated identifier for the internal purchase requisition record. Primary key for the requisition entity in the procurement domain.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredSupplierId rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Id' ;
    rdfs:comment 'Identifier of the recommended or preferred supplier for fulfilling this requisition, based on existing contracts, supplier performance scores, or buyer sourcing recommendations. Null if no preference is specified.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:requisitionAgentId rdf:type rdf:Property ;
    rdfs:label 'Requisition Agent Id' ;
    rdfs:comment 'Identifier of the employee, buyer, or system user who raised the purchase requisition. Links to the internal employee or user master for approval routing and spend analytics by requester.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'The approval tier required for this requisition based on spend thresholds and procurement policy delegation rules. Determines the approval chain routing (e.g., Level 1 = manager, Level 2 = director, Level 3 = VP, Executive = C-suite).' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalNotes rdf:type rdf:Property ;
    rdfs:label 'Approval Notes' ;
    rdfs:comment 'Free-text comments or justification provided by the approver during the approval or rejection action. Captures the rationale for approval decisions and supports audit trail requirements for SOX compliance.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetYear rdf:type rdf:Property ;
    rdfs:label 'Budget Year' ;
    rdfs:comment 'The fiscal or calendar year against which the requisition spend will be budgeted and tracked. Used for budget validation, annual spend planning, and financial period allocation in the ERP.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedTotalCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Cost' ;
    rdfs:comment 'Total estimated cost for the requisition line, calculated as requested_quantity multiplied by estimated_unit_cost. Used for budget validation, approval routing by spend threshold, and procurement spend analytics.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedUnitCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Unit Cost' ;
    rdfs:comment 'Estimated cost per unit of the requested item at the time of requisition creation. Used for budget validation, approval threshold checks, and spend forecasting. May be sourced from contract pricing, catalog price, or buyer estimate.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAutomatedTrigger rdf:type rdf:Property ;
    rdfs:label 'Is Automated Trigger' ;
    rdfs:comment 'Indicates whether this requisition was automatically generated by the min/max reorder point replenishment system (True) or manually raised by a business user or buyer (False). Supports process analytics and system-vs-manual sourcing performance comparison.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reorderPointTrigger rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Trigger' ;
    rdfs:comment 'The specific replenishment trigger method that initiated this requisition when is_automated_trigger is True. Values include min/max inventory rules, reorder point (ROP), MRP planning run, manual buyer action, or Kanban signal.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedQuantity rdf:type rdf:Property ;
    rdfs:label 'Requested Quantity' ;
    rdfs:comment 'The quantity of goods or services requested in the requisition, expressed in the unit of measure. Must meet or exceed the supplier Minimum Order Quantity (MOQ) for the preferred supplier where applicable.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredByDate rdf:type rdf:Property ;
    rdfs:label 'Required By Date' ;
    rdfs:comment 'The date by which the requested goods or services must be delivered or available. Drives procurement urgency classification, supplier lead time validation, and delivery SLA commitments. Key input for purchase order scheduling.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle state of the purchase requisition within the procure-to-pay workflow. Drives routing, approval actions, and downstream PO conversion eligibility.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionType rdf:type rdf:Property ;
    rdfs:label 'Requisition Type' ;
    rdfs:comment 'Classification of the requisition by procurement category and urgency. Determines applicable approval thresholds, sourcing rules, and processing SLAs. [ENUM-REF-CANDIDATE: standard|blanket|emergency|replenishment|service|capital — promote to reference product]' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingMethod rdf:type rdf:Property ;
    rdfs:label 'Sourcing Method' ;
    rdfs:comment 'Recommended or applied sourcing approach for fulfilling this requisition. Determines whether the buyer should reference an existing contract, use a catalog price, issue an RFQ, or execute a spot buy.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Supplier Lead Time Days' ;
    rdfs:comment 'Expected number of calendar days from purchase order placement to goods receipt for the preferred supplier. Used to validate the required_by_date feasibility and to calculate the latest PO creation date.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfqId rdf:type rdf:Property ;
    rdfs:label 'Rfq Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying a Request for Quotation (RFQ) or strategic sourcing event record in the procurement domain.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rfq .

ind:awardedSupplierId rdf:type rdf:Property ;
    rdfs:label 'Awarded Supplier Id' ;
    rdfs:comment 'Reference to the supplier record that was selected as the winner of this RFQ. Populated upon award decision. For split awards, references the primary/lead supplier. Links to the supplier master in the procurement domain.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:rfqAgentId rdf:type rdf:Property ;
    rdfs:label 'Rfq Agent Id' ;
    rdfs:comment 'Reference to the internal employee or procurement category manager responsible for managing this RFQ from initiation through award. Used for accountability tracking, workload management, and audit trail.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:awardDate rdf:type rdf:Property ;
    rdfs:label 'Award Date' ;
    rdfs:comment 'Date on which the sourcing event award decision was finalized and communicated to the winning supplier(s). Marks the closure of the competitive bidding phase and triggers purchase order or contract creation.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardDecision rdf:type rdf:Property ;
    rdfs:label 'Award Decision' ;
    rdfs:comment 'Outcome of the sourcing event evaluation: single_award (one supplier selected for full volume), split_award (volume distributed across multiple suppliers), no_award (no suitable bid received), re_tender (event cancelled and reissued). Drives downstream purchase order and contract creation.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardedAmount rdf:type rdf:Property ;
    rdfs:label 'Awarded Amount' ;
    rdfs:comment 'Total monetary value of the contract or purchase agreement awarded as a result of this RFQ, expressed in the RFQ currency. Used for spend commitment tracking, budget allocation, and savings realization reporting.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Human-readable name of the procurement category for the sourcing event (e.g., \'Consumer Electronics\', \'Corrugated Packaging\', \'Last-Mile Delivery Services\'). Used in reporting dashboards and supplier communications.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clarificationDeadline rdf:type rdf:Property ;
    rdfs:label 'Clarification Deadline' ;
    rdfs:comment 'Deadline by which suppliers may submit questions or requests for clarification on the RFQ requirements. Responses to clarifications are typically shared with all invited suppliers to ensure fair competition.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryWeightPct rdf:type rdf:Property ;
    rdfs:label 'Delivery Weight Pct' ;
    rdfs:comment 'Percentage weight assigned to the delivery/lead time criterion in the supplier evaluation scorecard. Reflects the importance of supply chain reliability and on-time delivery performance in the award decision.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedAnnualSpend rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Spend' ;
    rdfs:comment 'Projected total annual spend value for the goods or services covered by this RFQ, used for spend analysis, savings opportunity sizing, and procurement prioritization. Expressed in the RFQ currency. Confidential business data.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedSavings rdf:type rdf:Property ;
    rdfs:label 'Estimated Savings' ;
    rdfs:comment 'Projected cost savings expected to be realized through this sourcing event, calculated as the difference between the current/baseline spend and the anticipated awarded price. Used for procurement KPI reporting and budget planning. Expressed in the RFQ currency.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationCriteria rdf:type rdf:Property ;
    rdfs:label 'Evaluation Criteria' ;
    rdfs:comment 'Structured description of the criteria used to evaluate and score supplier responses (e.g., price, quality, delivery lead time, sustainability, financial stability, compliance). Stored as a structured text or JSON-serialized string capturing criterion names and their relative weightings.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationDeadline rdf:type rdf:Property ;
    rdfs:label 'Evaluation Deadline' ;
    rdfs:comment 'Target date by which the procurement team must complete evaluation and scoring of all supplier responses. Used to track procurement cycle time and ensure timely award decisions.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invitedSupplierCount rdf:type rdf:Property ;
    rdfs:label 'Invited Supplier Count' ;
    rdfs:comment 'Number of suppliers formally invited to participate in this RFQ or sourcing event. Used to assess competitive intensity and compliance with procurement policy (e.g., minimum 3 quotes requirement).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isMultiRound rdf:type rdf:Property ;
    rdfs:label 'Is Multi Round' ;
    rdfs:comment 'Indicates whether this sourcing event involves multiple bidding rounds (e.g., initial bid followed by best-and-final-offer round). True for complex strategic sourcing events; False for single-round tactical RFQs.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceWeightPct rdf:type rdf:Property ;
    rdfs:label 'Price Weight Pct' ;
    rdfs:comment 'Percentage weight assigned to the price criterion in the supplier evaluation scorecard. Together with other criterion weights, must sum to 100%. Used to ensure transparent and auditable supplier selection decisions.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityWeightPct rdf:type rdf:Property ;
    rdfs:label 'Quality Weight Pct' ;
    rdfs:comment 'Percentage weight assigned to the quality criterion in the supplier evaluation scorecard. Reflects the relative importance of product/service quality versus price and other factors in the award decision.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:realizedSavings rdf:type rdf:Property ;
    rdfs:label 'Realized Savings' ;
    rdfs:comment 'Actual cost savings achieved through this sourcing event, calculated as the difference between the baseline spend and the awarded amount. Populated post-award. Used for procurement performance reporting and ROI measurement.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseCount rdf:type rdf:Property ;
    rdfs:label 'Response Count' ;
    rdfs:comment 'Actual number of supplier quotation responses received by the submission deadline. Used to measure supplier engagement, assess market competitiveness, and determine if re-tendering is required.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfqDescription rdf:type rdf:Property ;
    rdfs:label 'Rfq Description' ;
    rdfs:comment 'Detailed narrative description of the scope, requirements, and objectives of the sourcing event. Includes business context, technical specifications summary, and any special conditions communicated to suppliers.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqNumber rdf:type rdf:Property ;
    rdfs:label 'Rfq Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for the RFQ or sourcing event, used in supplier communications, ERP references, and audit trails. Follows the format RFQ-YYYY-NNNNNN.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqStatus rdf:type rdf:Property ;
    rdfs:label 'Rfq Status' ;
    rdfs:comment 'Current lifecycle state of the RFQ or sourcing event: draft (being prepared), issued (sent to suppliers), responses_received (supplier bids collected), evaluated (bids scored), awarded (supplier selected and notified), cancelled (event terminated without award).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:savingsPercentage rdf:type rdf:Property ;
    rdfs:label 'Savings Percentage' ;
    rdfs:comment 'Estimated savings as a percentage of the baseline spend, providing a normalized measure of sourcing event value. Used in procurement performance dashboards and category management reporting.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourcingStrategy rdf:type rdf:Property ;
    rdfs:label 'Sourcing Strategy' ;
    rdfs:comment 'Narrative description of the procurement strategy applied to this sourcing event, such as multi-supplier diversification, preferred supplier consolidation, total cost of ownership (TCO) optimization, or category-specific strategic sourcing approach. Free-text field capturing the strategic rationale documented by the category manager.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityRequired rdf:type rdf:Property ;
    rdfs:label 'Sustainability Required' ;
    rdfs:comment 'Indicates whether this RFQ includes mandatory sustainability, ESG (Environmental, Social, Governance), or ethical sourcing compliance requirements as part of the supplier evaluation criteria.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetPrice rdf:type rdf:Property ;
    rdfs:label 'Target Price' ;
    rdfs:comment 'Internal benchmark or should-cost price per unit that the procurement team aims to achieve through the sourcing event. Used as the baseline for evaluating supplier bids and calculating estimated savings. Confidential — not disclosed to suppliers.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rfqResponseId rdf:type rdf:Property ;
    rdfs:label 'Rfq Response Id' ;
    rdfs:comment 'Unique system-generated identifier for the supplier quotation response submitted in reply to an RFQ. Primary key for this entity. Entity role: TRANSACTION_HEADER — represents a discrete procurement business event with a clear lifecycle.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awardedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Awarded Timestamp' ;
    rdfs:comment 'Date and time when this quotation response was formally awarded, resulting in a purchase order being raised. Populated only when response_status transitions to \'awarded\'. Supports procurement cycle time analytics.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryLocationCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Code' ;
    rdfs:comment 'Code identifying the destination warehouse or fulfillment center to which the supplier will deliver the goods under this quotation. Used for logistics planning and last-mile delivery coordination.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationScore rdf:type rdf:Property ;
    rdfs:label 'Evaluation Score' ;
    rdfs:comment 'Composite numerical score assigned to this quotation response during the multi-criteria sourcing evaluation (e.g., 0-100 scale). Incorporates price, lead time, quality, and compliance factors. Supports sourcing decision support and supplier performance benchmarking.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPreferredSupplier rdf:type rdf:Property ;
    rdfs:label 'Is Preferred Supplier' ;
    rdfs:comment 'Indicates whether the responding supplier holds preferred supplier status in the procurement system at the time of this RFQ response. Influences sourcing decisions and award prioritization.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netQuotedAmount rdf:type rdf:Property ;
    rdfs:label 'Net Quoted Amount' ;
    rdfs:comment 'Net total amount after applying all discounts to the total quoted amount. Represents the final payable value if this supplier is awarded the purchase order. Part of MONETARY_TRIPLET net total.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermsDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Description' ;
    rdfs:comment 'Human-readable description of the payment terms offered by the supplier (e.g., \'Net 30 days from invoice date\', \'2% discount if paid within 10 days, net 30\'). Supplements the payment terms code for business user clarity.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCertificationCodes rdf:type rdf:Property ;
    rdfs:label 'Quality Certification Codes' ;
    rdfs:comment 'Comma-separated list of quality or compliance certification codes applicable to the quoted product (e.g., ISO9001, CE, RoHS, FCC). Supports vendor compliance management and regulatory sourcing requirements.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotedLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Quoted Lead Time Days' ;
    rdfs:comment 'Number of calendar days from purchase order placement to expected delivery at the destination warehouse, as quoted by the supplier. Used for supply chain planning, inventory replenishment scheduling, and SLA compliance assessment.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quotedQuantity rdf:type rdf:Property ;
    rdfs:label 'Quoted Quantity' ;
    rdfs:comment 'Quantity of the item for which the supplier has provided this quotation. May differ from the RFQ requested quantity if the supplier can only fulfill a partial quantity.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Quoted Unit Price' ;
    rdfs:comment 'Supplier\'s quoted price per unit of the item as stated in the RFQ response. Core monetary field enabling multi-supplier price comparison and sourcing decisions. Part of MONETARY_TRIPLET category per TRANSACTION_HEADER role.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseNotes rdf:type rdf:Property ;
    rdfs:label 'Response Notes' ;
    rdfs:comment 'Free-text notes or comments provided by the supplier as part of the quotation response. May include special conditions, exclusions, assumptions, or clarifications relevant to the quoted price and terms.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseNumber rdf:type rdf:Property ;
    rdfs:label 'Response Number' ;
    rdfs:comment 'Externally-known business identifier for this quotation response, typically assigned by the supplier or the procurement system (e.g., QUOT-2024-00123). Used for cross-referencing with supplier documents and ERP purchase order creation. BUSINESS_IDENTIFIER category per TRANSACTION_HEADER role.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleAvailable rdf:type rdf:Property ;
    rdfs:label 'Sample Available' ;
    rdfs:comment 'Indicates whether the supplier can provide product samples prior to purchase order placement. Supports quality assurance processes and product evaluation before committing to full procurement.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Sample Lead Time Days' ;
    rdfs:comment 'Number of days required by the supplier to deliver product samples if sample_available is true. Used for quality evaluation scheduling and procurement timeline planning.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierSkuCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Sku Code' ;
    rdfs:comment 'Supplier\'s own part number or item code for the quoted product. Used for cross-referencing internal SKUs with supplier catalog codes during purchase order creation and goods receipt matching.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tieredPricingAvailable rdf:type rdf:Property ;
    rdfs:label 'Tiered Pricing Available' ;
    rdfs:comment 'Indicates whether the supplier offers volume-based tiered pricing for this quotation. When true, additional pricing tiers are captured in the associated RFQ response pricing tier detail records.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalQuotedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Quoted Amount' ;
    rdfs:comment 'Total quoted value for the full quantity requested in the RFQ, calculated as quoted unit price multiplied by quoted quantity. Represents the gross monetary commitment if this supplier is awarded. Part of MONETARY_TRIPLET category.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validityEndDate rdf:type rdf:Property ;
    rdfs:label 'Validity End Date' ;
    rdfs:comment 'Date after which the supplier\'s quoted prices and terms expire and are no longer binding. Procurement must raise a purchase order before this date to secure the quoted price. Critical for sourcing decision timelines.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validityStartDate rdf:type rdf:Property ;
    rdfs:label 'Validity Start Date' ;
    rdfs:comment 'Date from which the supplier\'s quoted prices and terms are valid. Defines the start of the binding quotation window during which a purchase order can be raised at the quoted price.' ;
    rdfs:domain ind:RfqResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantyPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Period Months' ;
    rdfs:comment 'Duration in months of the product warranty offered by the supplier as part of this quotation. Relevant for total cost of ownership analysis, returns management, and vendor contract negotiations.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bankAccountName rdf:type rdf:Property ;
    rdfs:label 'Bank Account Name' ;
    rdfs:comment 'Name of the bank account holder as registered for supplier payment remittance. Used in AP payment processing to validate beneficiary identity and prevent payment fraud. Subject to PCI DSS and SOX financial controls.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Default Lead Time Days' ;
    rdfs:comment 'Standard supplier lead time in calendar days from Purchase Order (PO) placement to goods receipt at the warehouse. Used as the default for inventory replenishment planning and MOQ calculations when no SKU-specific lead time is defined. Feeds into the WMS receiving schedule and ERP supply chain planning.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isoCertified rdf:type rdf:Property ;
    rdfs:label 'Iso Certified' ;
    rdfs:comment 'Indicates whether the supplier holds a valid ISO certification (e.g., ISO 9001 Quality Management, ISO 27001 Information Security, ISO 14001 Environmental Management). Drives compliance gating in the supplier onboarding workflow.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full registered legal name of the supplier entity as recorded in official business registration documents. Used for contract execution, tax filings, and regulatory compliance. Must match the name on vendor contracts and invoices.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactRole rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Role' ;
    rdfs:comment 'Business role or function of the primary contact person at the supplier. Determines routing of procurement communications (e.g., POs to account manager, invoices to finance contact, shipment queries to logistics coordinator).' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Code' ;
    rdfs:comment 'Externally-known alphanumeric code assigned to the supplier for cross-system identification. Used in Purchase Orders (POs), EDI transactions, and ERP integrations. Maps to the SAP S/4HANA vendor account number.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierTier rdf:type rdf:Property ;
    rdfs:label 'Supplier Tier' ;
    rdfs:comment 'Procurement tier classification indicating the strategic importance and relationship depth with the supplier. Strategic: top-tier partners with deep integration and long-term contracts. Preferred: vetted suppliers with negotiated terms. Approved: qualified suppliers on the approved vendor list. Transactional: one-off or spot-buy suppliers.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierType rdf:type rdf:Property ;
    rdfs:label 'Supplier Type' ;
    rdfs:comment 'Classification of the supplier by their role in the supply chain. Manufacturer: produces goods directly. Distributor: resells from manufacturers. Wholesaler: bulk reseller. 3PL (Third-Party Logistics): logistics provider. Dropshipper: ships directly to end customer. Marketplace Seller: sells via the e-commerce marketplace platform.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Operating or trade name (Doing Business As) of the supplier, which may differ from the legal name. Used in day-to-day procurement communications, catalog displays, and seller portal references.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountReference rdf:type rdf:Property ;
    rdfs:label 'Bank Account Reference' ;
    rdfs:comment 'Masked or tokenized reference to the supplier\'s bank account designated for payment of this invoice. Stored as a reference token rather than raw account number to comply with PCI DSS. Full banking details are maintained in the secure vendor master.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyAmount rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Amount' ;
    rdfs:comment 'Monetary value of the discrepancy between the invoiced amount and the expected amount based on PO and GR. Quantifies the financial exposure of the mismatch for prioritization of resolution and escalation decisions.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discrepancyReason rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Reason' ;
    rdfs:comment 'Free-text description of the specific discrepancy identified during three-way match validation or manual review. Provides context for resolution workflow, supplier dispute management, and audit trail. Populated when three_way_match_status is FAILED or PARTIAL_MATCH.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceCategory rdf:type rdf:Property ;
    rdfs:label 'Invoice Category' ;
    rdfs:comment 'Business category of the goods or services being invoiced. GOODS: physical merchandise; SERVICES: professional or managed services; FREIGHT: logistics and shipping charges; UTILITIES: energy, water, telecom; CAPEX: capital expenditure items; INTERCOMPANY: invoices between related entities. Used for spend analytics and GL account determination.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlockFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Block Flag' ;
    rdfs:comment 'Indicates whether the invoice has been blocked from payment processing. True when a payment block is active due to discrepancy, pending approval, compliance hold, or manual block. Maps to SAP S/4HANA payment block indicator (ZLSPR) on the AP document. Finance domain uses this flag to exclude the invoice from payment run.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'The date by which payment must be made to the supplier to comply with agreed payment terms and avoid late payment penalties. Derived from invoice date and supplier payment terms but stored explicitly for operational payment scheduling and cash flow planning.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplierOnboardingId rdf:type rdf:Property ;
    rdfs:label 'Supplier Onboarding Id' ;
    rdfs:comment 'Unique system-generated identifier for the supplier onboarding workflow record. Primary key for this entity.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualActivationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Activation Date' ;
    rdfs:comment 'Actual date on which the supplier was fully activated and set to operational status in the ERP and Seller Management Portal. Compared against target_activation_date for SLA performance measurement.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Application Submitted Timestamp' ;
    rdfs:comment 'Date and time when the supplier submitted their initial onboarding application via the Seller Management Portal. Marks the official start of the onboarding workflow and SLA clock.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bankRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Routing Number' ;
    rdfs:comment 'American Bankers Association (ABA) routing transit number or SWIFT/BIC code identifying the supplier\'s bank for ACH and wire transfer settlement. Required for procure-to-pay processing.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingReason rdf:type rdf:Property ;
    rdfs:label 'Blocking Reason' ;
    rdfs:comment 'Free-text description of the reason(s) why the onboarding workflow is currently blocked or on hold (e.g., missing tax certificate, KYB verification failure, incomplete bank details). Populated when onboarding_status is \'blocked\' or \'on_hold\'.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Business Registration Number' ;
    rdfs:comment 'Official government-issued business registration or incorporation number for the supplier entity. Required for Know Your Business (KYB) verification and regulatory due diligence under FTC and GDPR vendor management requirements.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'Country Of Incorporation' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the country where the supplier is legally incorporated or registered (e.g., USA, GBR, DEU). Drives applicable regulatory framework and trade compliance rules.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentChecklistComplete rdf:type rdf:Property ;
    rdfs:label 'Document Checklist Complete' ;
    rdfs:comment 'Indicates whether all required onboarding documents (business registration, tax certificates, insurance certificates, bank letters, signed agreements) have been collected and validated.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediCapable rdf:type rdf:Property ;
    rdfs:label 'Edi Capable' ;
    rdfs:comment 'Indicates whether the supplier supports Electronic Data Interchange (EDI) for automated exchange of purchase orders, invoices, and advance ship notices. Drives integration setup decisions in the ERP procure-to-pay workflow.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ediStandard rdf:type rdf:Property ;
    rdfs:label 'Edi Standard' ;
    rdfs:comment 'The EDI messaging standard supported by the supplier (e.g., ANSI X12, UN/EDIFACT, cXML, RosettaNet). Populated only when edi_capable is true. Determines the integration protocol configured in the ERP.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpVendorCode rdf:type rdf:Property ;
    rdfs:label 'Erp Vendor Code' ;
    rdfs:comment 'The vendor account code assigned to the supplier in SAP S/4HANA upon system setup completion. Used to link the onboarding record to the ERP vendor master (LFA1) for procure-to-pay processing.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprDpaSigned rdf:type rdf:Property ;
    rdfs:label 'Gdpr Dpa Signed' ;
    rdfs:comment 'Indicates whether the supplier has signed a GDPR-compliant Data Processing Agreement (DPA) as required when the supplier processes personal data on behalf of the business. Mandatory for EU-facing suppliers.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceCertificateVerified rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Verified' ;
    rdfs:comment 'Indicates whether the supplier\'s required insurance certificates (e.g., general liability, product liability) have been collected and verified as valid. Required for CPSC product safety compliance.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kybVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Kyb Verification Status' ;
    rdfs:comment 'Status of the Know Your Business (KYB) identity and legitimacy verification check performed on the supplier entity. Required for FTC compliance and fraud prevention in vendor onboarding.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kybVerifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Kyb Verified Timestamp' ;
    rdfs:comment 'Date and time when the KYB verification check was completed and a pass/fail determination was recorded. Provides audit trail for regulatory due diligence.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:onboardingNumber rdf:type rdf:Property ;
    rdfs:label 'Onboarding Number' ;
    rdfs:comment 'Externally-visible, human-readable reference number for the supplier onboarding case (e.g., ONB-2024-000123). Used in communications with the supplier and internal stakeholders.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingSourceChannel rdf:type rdf:Property ;
    rdfs:label 'Onboarding Source Channel' ;
    rdfs:comment 'Channel through which the supplier initiated the onboarding process: portal_self_service (Seller Management Portal), procurement_team (internal sourcing), referral, api_integration (B2B API), or trade_show. Used for onboarding funnel analytics.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingStage rdf:type rdf:Property ;
    rdfs:label 'Onboarding Stage' ;
    rdfs:comment 'Current stage of the supplier onboarding workflow lifecycle: application (initial submission), kyb_verification (Know Your Business identity check), document_collection (gathering required legal/tax/banking docs), compliance_review (FTC/GDPR due diligence), system_setup (ERP/EDI provisioning), activated (fully onboarded and operational).' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalAccessProvisioned rdf:type rdf:Property ;
    rdfs:label 'Portal Access Provisioned' ;
    rdfs:comment 'Indicates whether the supplier has been granted access credentials to the Seller Management Portal for order management, invoice submission, and performance monitoring.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portalAccessProvisionedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Portal Access Provisioned Timestamp' ;
    rdfs:comment 'Date and time when the supplier\'s Seller Management Portal access credentials were provisioned and activated. Used for access audit trails per ISO 27001 requirements.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:productCategories rdf:type rdf:Property ;
    rdfs:label 'Product Categories' ;
    rdfs:comment 'Comma-separated list of product category codes or names that the supplier is authorized to supply on the platform (e.g., \'Electronics, Home & Garden\'). Drives catalog management and PIM system configuration.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Status' ;
    rdfs:comment 'Result of the OFAC/sanctions list screening performed on the supplier entity and its beneficial owners. A \'flagged\' status blocks onboarding progression until legal review is completed.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetActivationDate rdf:type rdf:Property ;
    rdfs:label 'Target Activation Date' ;
    rdfs:comment 'Target date by which the supplier should be fully activated and operational in the system. Used for SLA tracking, procurement planning, and escalation management.' ;
    rdfs:domain ind:SupplierOnboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplierPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Supplier Performance Id' ;
    rdfs:comment 'Unique surrogate identifier for each supplier performance scorecard record. Primary key for the supplier_performance data product in the procurement domain.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluationPeriodId rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Id' ;
    rdfs:comment 'Reference to the fiscal or calendar evaluation period (monthly, quarterly, or annual) for which this scorecard applies. Aligns with the financial period close cycle in SAP S/4HANA.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EvaluationPeriod .

ind:primarySupplierAgentId rdf:type rdf:Property ;
    rdfs:label 'Primary Supplier Agent Id' ;
    rdfs:comment 'Reference to the internal procurement team member (buyer or category manager) who completed and submitted this supplier performance scorecard. Used for accountability and audit trail purposes.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:avgActualLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Avg Actual Lead Time Days' ;
    rdfs:comment 'Average number of calendar days between purchase order placement and goods receipt for all POs evaluated during the period. Compared against contracted lead time to compute lead_time_adherence_rate and inform replenishment planning.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractRenewalRecommendation rdf:type rdf:Property ;
    rdfs:label 'Contract Renewal Recommendation' ;
    rdfs:comment 'Procurement team\'s formal recommendation for the supplier\'s contract renewal based on this evaluation period\'s performance scorecard. Drives contract lifecycle management decisions in SAP S/4HANA. Classified as confidential due to commercial sensitivity.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Contracted Lead Time Days' ;
    rdfs:comment 'The agreed-upon lead time in calendar days as specified in the supplier\'s active vendor contract or purchase agreement. Serves as the benchmark for lead_time_adherence_rate calculation and SLA compliance assessment.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctiveActionCount rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Count' ;
    rdfs:comment 'Number of formal corrective action requests (CARs) issued to the supplier during the evaluation period due to quality, delivery, or compliance failures. High counts indicate systemic supplier issues requiring escalation or probation review.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criticalSlaBreachCount rdf:type rdf:Property ;
    rdfs:label 'Critical Sla Breach Count' ;
    rdfs:comment 'Number of high-severity SLA breaches that caused material business impact (e.g., stockouts, production stoppages, customer order cancellations) during the evaluation period. Subset of sla_breach_count; used for escalation and probation decisions.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectRateDppm rdf:type rdf:Property ;
    rdfs:label 'Defect Rate Dppm' ;
    rdfs:comment 'Number of defective units received per one million units delivered by the supplier during the evaluation period. Industry-standard quality metric (DPPM - Defective Parts Per Million) used to assess product quality compliance and drive supplier quality improvement programs.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:developmentProgramEnrolledFlag rdf:type rdf:Property ;
    rdfs:label 'Development Program Enrolled Flag' ;
    rdfs:comment 'Indicates whether the supplier has been enrolled in a formal supplier development program as a result of this evaluation period\'s performance. Typically triggered by bronze tier or probation classification.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeCount rdf:type rdf:Property ;
    rdfs:label 'Dispute Count' ;
    rdfs:comment 'Number of formal disputes raised by either Ecommerce or the supplier regarding PO terms, invoice discrepancies, or delivery claims during the evaluation period. Sourced from SAP S/4HANA dispute management module.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentationComplianceRate rdf:type rdf:Property ;
    rdfs:label 'Documentation Compliance Rate' ;
    rdfs:comment 'Percentage of shipments accompanied by complete and accurate documentation (packing lists, certificates of conformance, customs documents, safety data sheets) as required by contract and regulatory standards during the evaluation period.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationNotes rdf:type rdf:Property ;
    rdfs:label 'Evaluation Notes' ;
    rdfs:comment 'Free-text field for the procurement evaluator to capture qualitative observations, context, or exceptions that are not reflected in the quantitative KPI scores (e.g., force majeure events, supply chain disruptions, extraordinary performance).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'The last calendar date of the performance evaluation window. Paired with evaluation_period_start_date to define the full measurement interval for all KPIs.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'The first calendar date of the performance evaluation window. Used to define the measurement boundary for all KPIs captured in this scorecard.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodType rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Type' ;
    rdfs:comment 'Granularity of the performance evaluation cycle: monthly for operational monitoring, quarterly for strategic reviews, and annual for contract renewal decisions.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillRate rdf:type rdf:Property ;
    rdfs:label 'Fill Rate' ;
    rdfs:comment 'Percentage of ordered quantity actually fulfilled and shipped by the supplier during the evaluation period. Calculated as (units shipped / units ordered) × 100. Measures supplier\'s ability to meet demand without shortfalls, critical for inventory replenishment planning.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceAccuracyRate rdf:type rdf:Property ;
    rdfs:label 'Invoice Accuracy Rate' ;
    rdfs:comment 'Percentage of supplier invoices that matched the corresponding purchase order without discrepancies (price, quantity, or terms) during the evaluation period. Calculated as (accurate invoices / total invoices) × 100. Impacts accounts payable efficiency and procure-to-pay cycle time in SAP S/4HANA.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadTimeAdherenceRate rdf:type rdf:Property ;
    rdfs:label 'Lead Time Adherence Rate' ;
    rdfs:comment 'Percentage of purchase orders where the supplier\'s actual lead time met or was within the contracted lead time during the evaluation period. Calculated as (orders within lead time / total orders) × 100. Critical for inventory replenishment planning and MOQ (Minimum Order Quantity) management.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moqComplianceRate rdf:type rdf:Property ;
    rdfs:label 'Moq Compliance Rate' ;
    rdfs:comment 'Percentage of purchase orders where the supplier honored the contracted MOQ (Minimum Order Quantity) terms during the evaluation period. Non-compliance may indicate supply constraints or contract violations requiring procurement intervention.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTimeDeliveryRate rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate' ;
    rdfs:comment 'Percentage of purchase orders delivered by the supplier on or before the confirmed delivery date during the evaluation period. Calculated as (on-time deliveries / total deliveries) × 100. Key operational KPI for SLA compliance monitoring.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openCorrectiveActionCount rdf:type rdf:Property ;
    rdfs:label 'Open Corrective Action Count' ;
    rdfs:comment 'Number of corrective action requests (CARs) issued to the supplier that remain unresolved as of the scorecard evaluation date. Unresolved CARs beyond SLA timelines may trigger escalation to probation tier.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Overall Performance Score' ;
    rdfs:comment 'Composite weighted performance score (0–100) aggregating all KPI dimensions (on-time delivery, fill rate, defect rate, invoice accuracy, lead time adherence, return rate, SLA compliance, NPS) per the procurement scoring model. Primary driver for performance tier classification and contract renewal decisions.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Classified performance tier assigned to the supplier based on the weighted overall performance score for the evaluation period. Gold = top-tier preferred supplier; Silver = satisfactory; Bronze = needs improvement; Probation = at risk of contract termination. Drives supplier development programs and contract renewal decisions.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousPerformanceTier rdf:type rdf:Property ;
    rdfs:label 'Previous Performance Tier' ;
    rdfs:comment 'The supplier\'s performance tier from the immediately preceding evaluation period. Used to detect tier reclassification events and trigger automated supplier development workflows.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementCostVariancePct rdf:type rdf:Property ;
    rdfs:label 'Procurement Cost Variance Pct' ;
    rdfs:comment 'Percentage variance between the contracted unit price and the actual invoiced price across all POs in the evaluation period. Positive value indicates supplier overcharged vs. contract; negative indicates undercharge. Flags pricing compliance issues for AP reconciliation in SAP S/4HANA.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementNpsScore rdf:type rdf:Property ;
    rdfs:label 'Procurement Nps Score' ;
    rdfs:comment 'Net Promoter Score (NPS) provided by the internal procurement team rating the supplier\'s responsiveness, communication quality, and overall partnership experience during the evaluation period. Scale: -100 to +100. Captures qualitative relationship health not reflected in operational KPIs.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scorecardPublishedDate rdf:type rdf:Property ;
    rdfs:label 'Scorecard Published Date' ;
    rdfs:comment 'The date on which the finalized supplier performance scorecard was formally published and shared with the supplier. Marks the start of the supplier\'s response and dispute window.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scorecardReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Scorecard Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this supplier performance scorecard record, used in procurement communications, supplier development meetings, and audit trails. Format: SPC-YYYY-MM-SUPPID.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardStatus rdf:type rdf:Property ;
    rdfs:label 'Scorecard Status' ;
    rdfs:comment 'Current lifecycle state of the supplier performance scorecard. Draft indicates data collection in progress; pending_review awaits procurement manager sign-off; approved is finalized; published is shared with supplier; disputed is under supplier challenge; closed is archived.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachCount rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Count' ;
    rdfs:comment 'Total number of SLA (Service Level Agreement) violations recorded against the supplier during the evaluation period. Includes delivery, quality, and communication SLA breaches as defined in the vendor contract. Triggers penalty clauses and escalation workflows.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierAcknowledgedFlag rdf:type rdf:Property ;
    rdfs:label 'Supplier Acknowledged Flag' ;
    rdfs:comment 'Indicates whether the supplier has formally acknowledged receipt and review of the published performance scorecard via the Seller Management Portal. Required for audit trail and dispute resolution process initiation.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Supplier Acknowledgement Date' ;
    rdfs:comment 'The date on which the supplier formally acknowledged the performance scorecard in the Seller Management Portal. Null if supplier_acknowledged_flag is False. Used to track response timeliness.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sustainabilityComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Sustainability Compliance Score' ;
    rdfs:comment 'Score (0–100) reflecting the supplier\'s adherence to environmental, social, and governance (ESG) standards and Ecommerce\'s supplier code of conduct during the evaluation period. Assessed via audits, certifications, and self-reported data. Increasingly required for regulatory and investor reporting.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierReclassificationFlag rdf:type rdf:Property ;
    rdfs:label 'Tier Reclassification Flag' ;
    rdfs:comment 'Indicates whether the supplier\'s performance tier changed between the previous and current evaluation period. True triggers automated supplier development program enrollment or contract review workflows in the ERP.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalPosEvaluated rdf:type rdf:Property ;
    rdfs:label 'Total Pos Evaluated' ;
    rdfs:comment 'Total number of purchase orders (POs) included in the performance evaluation for this period. Provides the denominator context for rate-based KPIs and ensures statistical significance of the scorecard.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnitsReceived rdf:type rdf:Property ;
    rdfs:label 'Total Units Received' ;
    rdfs:comment 'Total quantity of units received from the supplier across all purchase orders during the evaluation period. Used as the volume denominator for defect rate, return rate, and fill rate calculations. Sourced from WMS (Warehouse Management System) receiving records.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierPriceListId rdf:type rdf:Property ;
    rdfs:label 'Supplier Price List Id' ;
    rdfs:comment 'Unique surrogate identifier for the supplier price list record. Primary key for this entity in the procurement domain Silver layer.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierPriceList .

ind:supersededBySupplierPriceListId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Supplier Price List Id' ;
    rdfs:comment 'Reference to the newer supplier_price_list record that replaced this one when status is \'superseded\'. Enables version chain traversal for price history analysis and audit. Null if this is the current active version.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierPriceList .

ind:autoPoPricingEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Po Pricing Enabled' ;
    rdfs:comment 'Indicates whether this price list is enabled for automatic price determination during purchase order creation in the ERP system. When True, the system automatically applies this price list during PO generation without manual price entry.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:erpInfoRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Erp Info Record Number' ;
    rdfs:comment 'The SAP S/4HANA Purchasing Info Record (PIR) number corresponding to this price list entry. Enables direct traceability between the Silver layer data product and the ERP system of record for procurement price determination.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightIncluded rdf:type rdf:Property ;
    rdfs:label 'Freight Included' ;
    rdfs:comment 'Indicates whether freight/shipping costs are included in the quoted unit price. When True, no separate freight charge is added during PO creation. When False, freight is billed separately or calculated via the TMS.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasVolumeTiers rdf:type rdf:Property ;
    rdfs:label 'Has Volume Tiers' ;
    rdfs:comment 'Indicates whether this price list includes a volume discount schedule (quantity break tiers) in addition to the base unit price. When True, the associated supplier_price_list_tier records define the tiered pricing structure.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermCode rdf:type rdf:Property ;
    rdfs:label 'Incoterm Code' ;
    rdfs:comment 'The International Commercial Terms (Incoterms) code defining the delivery obligations, risk transfer point, and cost responsibilities between the supplier and the e-commerce platform for shipments under this price list (e.g., FOB, DDP, EXW). [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterm Location' ;
    rdfs:comment 'The named place or port associated with the Incoterms code (e.g., \'Port of Shanghai\' for FOB, \'Buyer Warehouse\' for DDP). Required to fully specify the delivery terms per ICC Incoterms 2020 rules.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBasis rdf:type rdf:Property ;
    rdfs:label 'Price Basis' ;
    rdfs:comment 'Indicates whether the unit price represents the gross list price (before discounts), the net agreed price (after discounts), or the landed cost (inclusive of freight, duties, and insurance). Critical for correct COGS calculation and PO price validation.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListCategory rdf:type rdf:Property ;
    rdfs:label 'Price List Category' ;
    rdfs:comment 'Business category of the price list indicating its commercial purpose. \'standard\' = regular agreed pricing; \'promotional\' = time-limited promotional pricing; \'seasonal\' = seasonal pricing adjustment; \'clearance\' = end-of-life or excess inventory pricing; \'emergency\' = expedited sourcing price.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListNumber rdf:type rdf:Property ;
    rdfs:label 'Price List Number' ;
    rdfs:comment 'Externally-known business identifier for this price list, used in supplier communications, purchase order references, and ERP purchasing info records. Follows the format PL-{alphanumeric code}.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListType rdf:type rdf:Property ;
    rdfs:label 'Price List Type' ;
    rdfs:comment 'Classification of the price list by its commercial basis. \'contract_based\' = tied to a formal vendor contract; \'standalone_pir\' = standalone Purchasing Info Record (PIR) in ERP; \'spot_quote\' = one-time quoted price; \'catalog\' = supplier-published catalog price; \'blanket_order\' = price under a blanket purchase order.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListVersion rdf:type rdf:Property ;
    rdfs:label 'Price List Version' ;
    rdfs:comment 'Version number of this price list, enabling tracking of successive revisions for the same supplier-SKU combination. Incremented each time the supplier submits a revised pricing schedule.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceTolerancePercentage rdf:type rdf:Property ;
    rdfs:label 'Price Tolerance Percentage' ;
    rdfs:comment 'The maximum allowable percentage deviation between the price list unit price and the actual invoice price before a three-way match exception is raised. Used in automated invoice verification to flag price discrepancies requiring manual review.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Price Unit Quantity' ;
    rdfs:comment 'The quantity basis for which the unit price is quoted (e.g., price per 1 unit, per 100 units, per 1000 units). Used to correctly compute per-unit cost when the supplier quotes prices in bulk multiples. Corresponds to the SAP Purchasing Info Record \'Price Unit\' field.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalReminderDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Reminder Days' ;
    rdfs:comment 'The number of days before the expiry date at which a renewal reminder notification should be triggered to the procurement team. Supports proactive price list renewal management and prevents procurement disruption due to expired pricing.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Source Document Reference' ;
    rdfs:comment 'The reference number of the source document from which this price list was derived, such as a supplier quotation number, RFQ response number, or EDI catalog transmission ID. Provides traceability back to the originating supplier communication.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierPriceListStatus rdf:type rdf:Property ;
    rdfs:label 'Supplier Price List Status' ;
    rdfs:comment 'Current lifecycle state of the price list. \'active\' = currently valid for PO pricing; \'expired\' = past expiry date; \'superseded\' = replaced by a newer version; \'draft\' = under preparation; \'pending_approval\' = awaiting procurement approval; \'suspended\' = temporarily deactivated.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierSkuDescription rdf:type rdf:Property ;
    rdfs:label 'Supplier Sku Description' ;
    rdfs:comment 'The supplier\'s description of the SKU as it appears in their catalog or price list document. Used for three-way matching during invoice verification and for resolving discrepancies between internal and supplier item descriptions.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Tax Classification Code' ;
    rdfs:comment 'The tax classification code assigned to this SKU-supplier combination for VAT/GST determination during purchase order processing. Maps to the tax condition type in the ERP pricing procedure.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierCount rdf:type rdf:Property ;
    rdfs:label 'Tier Count' ;
    rdfs:comment 'The number of quantity break tiers defined in the volume discount schedule for this price list. Zero if has_volume_tiers is False. Provides a quick summary of pricing complexity without joining to tier detail records.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uomCode rdf:type rdf:Property ;
    rdfs:label 'Uom Code' ;
    rdfs:comment 'The unit of measure in which the SKU is priced and ordered (e.g., EA for each, CS for case, KG for kilogram, L for litre). Aligns with the UOM defined in the product master and used in purchase order line items.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryVendorAgentId rdf:type rdf:Property ;
    rdfs:label 'Primary Vendor Agent Id' ;
    rdfs:comment 'Reference to the internal procurement employee or category manager who owns and is accountable for this vendor contract. Used for contract governance, renewal notifications, and performance review assignments.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Total number of formal amendments (change orders) that have been executed against this contract since its original execution. Provides a quick indicator of contract stability and negotiation history. Incremented each time a change order is approved.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractTitle rdf:type rdf:Property ;
    rdfs:label 'Contract Title' ;
    rdfs:comment 'Descriptive human-readable title or short name of the vendor contract (e.g., \'Annual Packaging Materials Supply Agreement FY2025\'). Used for display in procurement dashboards and contract registers.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'The contractually agreed mechanism for resolving commercial disputes between the buyer and vendor (e.g., binding arbitration, mediation, or court litigation). Determines the legal process to follow in case of contract breach or disagreement.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether this contract grants the vendor exclusive supply rights for the specified goods or services category, preventing the buyer from sourcing from competing vendors during the contract term. True = exclusive; False = non-exclusive.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityScope rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Scope' ;
    rdfs:comment 'Free-text description of the scope of exclusivity when the exclusivity flag is True. Defines the product categories, geographic regions, or channels covered by the exclusive arrangement (e.g., \'Exclusive supplier of private-label packaging materials for APAC fulfillment centers\').' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprDpaFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Dpa Flag' ;
    rdfs:comment 'Indicates whether a GDPR-compliant Data Processing Agreement (DPA) has been executed with this vendor, required when the vendor processes personal data on behalf of the company. True = DPA in place; False = DPA not required or not yet executed. Mandatory for GDPR Article 28 compliance.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingLawCountry rdf:type rdf:Property ;
    rdfs:label 'Governing Law Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code identifying the jurisdiction whose laws govern the interpretation and enforcement of this contract (e.g., USA, GBR, DEU). Critical for cross-border procurement and dispute resolution.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'The date on which the most recent formal amendment or change order to this contract was executed and became effective. Null for contracts that have never been amended. Used to track contract evolution and trigger re-approval workflows.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastAmendmentReason rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Reason' ;
    rdfs:comment 'Free-text description of the business reason for the most recent contract amendment (e.g., \'Price adjustment due to raw material cost increase Q3 2025\', \'Extended term by 12 months following supplier performance review\'). Supports audit trail and change management documentation.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderQty rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Qty' ;
    rdfs:comment 'The minimum quantity per purchase order that the vendor requires under this contract, as negotiated in the commercial terms. MOQ is a standard e-commerce and supply chain procurement metric used for inventory planning and replenishment decisions.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moqUnit rdf:type rdf:Property ;
    rdfs:label 'Moq Unit' ;
    rdfs:comment 'Unit of measure applicable to the minimum order quantity (e.g., EA for each, CS for case, KG for kilogram, PAL for pallet). Follows ISO 80000 / UN/CEFACT unit codes as used in SAP S/4HANA.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaFlag rdf:type rdf:Property ;
    rdfs:label 'Nda Flag' ;
    rdfs:comment 'Indicates whether a Non-Disclosure Agreement (NDA) is in place with this vendor as part of or alongside this contract. True = NDA executed; False = no NDA. Relevant for IP protection, proprietary pricing, and technology sharing arrangements.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyCapAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Cap Amount' ;
    rdfs:comment 'The maximum cumulative financial penalty amount (in contract currency) that can be levied against the vendor under this contract over its full term. Caps total liability exposure for both parties. Null when no penalty cap is defined.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Flag' ;
    rdfs:comment 'Indicates whether this contract contains financial penalty clauses for SLA breaches, late delivery, or quality failures. True = penalty clauses exist; False = no financial penalties defined. Drives penalty calculation workflows in accounts payable.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyRatePct rdf:type rdf:Property ;
    rdfs:label 'Penalty Rate Pct' ;
    rdfs:comment 'The contractually defined financial penalty rate expressed as a percentage of the affected order value or invoice amount, applied when the vendor breaches SLA commitments. Null when penalty_clause_flag is False.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Procurement Category Code' ;
    rdfs:comment 'Standardized spend category code classifying the goods or services covered by this contract (e.g., UNSPSC or internal category taxonomy code). Enables spend analytics, category management, and strategic sourcing decisions.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of calendar days before the contract expiry date by which either party must provide written notice of intent to renew or terminate. Used to trigger automated procurement alerts and prevent unintended auto-renewals.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'The date on which the contract was formally executed (signed) by all authorized parties. May differ from the effective date when contracts are backdated or post-dated. Critical for legal enforceability and audit.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaDefectRatePct rdf:type rdf:Property ;
    rdfs:label 'Sla Defect Rate Pct' ;
    rdfs:comment 'Contractually agreed maximum acceptable defect/rejection rate (as a percentage) for goods delivered under this contract. Exceeding this threshold constitutes an SLA breach and may trigger return merchandise authorization (RMA) processes and financial penalties.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaFillRatePct rdf:type rdf:Property ;
    rdfs:label 'Sla Fill Rate Pct' ;
    rdfs:comment 'Contractually committed minimum order fill rate (as a percentage) representing the proportion of ordered quantity that the vendor must fulfill completely per shipment. A fill rate below this threshold triggers SLA breach notifications and potential penalties.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaOnTimeDeliveryPct rdf:type rdf:Property ;
    rdfs:label 'Sla On Time Delivery Pct' ;
    rdfs:comment 'Contractually committed minimum on-time delivery rate (as a percentage) that the vendor must achieve. Measured as the percentage of purchase orders delivered on or before the agreed delivery date. Used for vendor performance scorecards and penalty clause triggers.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Coded reason for early contract termination. Mutual agreement: both parties agreed to end early. Vendor breach: vendor failed to meet contractual obligations. Buyer breach: buyer defaulted. Force majeure: unforeseeable external event. Regulatory: compliance or legal requirement. Convenience: buyer exercised termination for convenience clause.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalContractValue rdf:type rdf:Property ;
    rdfs:label 'Total Contract Value' ;
    rdfs:comment 'The total maximum committed monetary value of the vendor contract over its full term, expressed in the contract currency. For blanket/framework agreements this is the ceiling value; for spot contracts it is the fixed order value. Used for spend analytics, budget commitment tracking, and SOX financial controls.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attributeDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Attribute Definition Id' ;
    rdfs:comment 'Unique identifier for the attribute definition within the Product Information Management (PIM) system. Primary key.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttributeDefinition .

ind:allowedValuesList rdf:type rdf:Property ;
    rdfs:label 'Allowed Values List' ;
    rdfs:comment 'Comma-separated or JSON list of allowed values for enum and multi-select attributes. Defines the controlled vocabulary for categorical attributes.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableCategoryScope rdf:type rdf:Property ;
    rdfs:label 'Applicable Category Scope' ;
    rdfs:comment 'Comma-separated list of product category codes or taxonomy nodes to which this attribute applies. Defines the scope of attribute applicability across the catalog.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributeCode rdf:type rdf:Property ;
    rdfs:label 'Attribute Code' ;
    rdfs:comment 'Machine-readable unique code for the attribute, used as the technical identifier in API calls and data integrations. Typically snake_case format.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributeGroup rdf:type rdf:Property ;
    rdfs:label 'Attribute Group' ;
    rdfs:comment 'High-level classification of the attribute for PIM governance (e.g., Core, Marketing, Technical, Compliance, Digital Asset). Used for attribute set management.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributeName rdf:type rdf:Property ;
    rdfs:label 'Attribute Name' ;
    rdfs:comment 'Human-readable name of the attribute displayed in the PIM system and administrative interfaces.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributeStatus rdf:type rdf:Property ;
    rdfs:label 'Attribute Status' ;
    rdfs:comment 'Current lifecycle status of the attribute definition. Active attributes are available for product enrichment; deprecated attributes are phased out; draft attributes are under review; archived attributes are retained for historical data.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStandard rdf:type rdf:Property ;
    rdfs:label 'Compliance Standard' ;
    rdfs:comment 'Name of the regulatory standard or governing body that mandates this attribute (e.g., CPSC, GDPR, ISO 27001, PCI DSS). Null for non-compliance attributes.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataType rdf:type rdf:Property ;
    rdfs:label 'Data Type' ;
    rdfs:comment 'The data type that defines the structure and validation rules for attribute values. Determines how the attribute is stored, validated, and rendered on Product Detail Page (PDP) and Product Listing Page (PLP). [ENUM-REF-CANDIDATE: string|numeric|boolean|enum|multi_select|date|rich_text — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultValue rdf:type rdf:Property ;
    rdfs:label 'Default Value' ;
    rdfs:comment 'Default value automatically populated for this attribute when a new product is created in the PIM system. Null if no default is defined.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:displayGroup rdf:type rdf:Property ;
    rdfs:label 'Display Group' ;
    rdfs:comment 'Logical grouping of attributes for organized presentation on PDP and PLP (e.g., Technical Specifications, Dimensions, Compliance). Used to structure attribute rendering.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayLabel rdf:type rdf:Property ;
    rdfs:label 'Display Label' ;
    rdfs:comment 'Customer-facing label for the attribute displayed on PDP and PLP. May differ from the internal attribute name for better user experience.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAttributeCode rdf:type rdf:Property ;
    rdfs:label 'External Attribute Code' ;
    rdfs:comment 'Identifier for this attribute in external systems or third-party integrations (e.g., vendor PIM, industry standard attribute codes). Used for cross-system mapping.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facetDisplayType rdf:type rdf:Property ;
    rdfs:label 'Facet Display Type' ;
    rdfs:comment 'UI component type used to render this attribute as a filter facet on PLP (e.g., checkbox for multi-select, slider for numeric ranges, swatch for colors).' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:helpText rdf:type rdf:Property ;
    rdfs:label 'Help Text' ;
    rdfs:comment 'Instructional text or tooltip displayed to catalog managers during product enrichment to guide accurate data entry.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isComparable rdf:type rdf:Property ;
    rdfs:label 'Is Comparable' ;
    rdfs:comment 'Indicates whether this attribute is displayed in side-by-side product comparison views to help customers evaluate alternatives.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFilterable rdf:type rdf:Property ;
    rdfs:label 'Is Filterable' ;
    rdfs:comment 'Indicates whether this attribute can be used as a facet filter on Product Listing Page (PLP) to narrow search results.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLocalizable rdf:type rdf:Property ;
    rdfs:label 'Is Localizable' ;
    rdfs:comment 'Indicates whether this attribute supports multi-language or region-specific values for international catalog management.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSystemAttribute rdf:type rdf:Property ;
    rdfs:label 'Is System Attribute' ;
    rdfs:comment 'Indicates whether this attribute is a core system attribute managed by the PIM platform (e.g., SKU, UPC, ASIN) versus a custom business attribute.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnique rdf:type rdf:Property ;
    rdfs:label 'Is Unique' ;
    rdfs:comment 'Indicates whether attribute values must be unique across all products (e.g., UPC, EAN, ASIN identifiers). Enforces uniqueness constraints during catalog enrichment.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVisibleOnPdp rdf:type rdf:Property ;
    rdfs:label 'Is Visible On Pdp' ;
    rdfs:comment 'Indicates whether this attribute is displayed on the Product Detail Page (PDP) for customer viewing.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:searchWeight rdf:type rdf:Property ;
    rdfs:label 'Search Weight' ;
    rdfs:comment 'Numeric weight assigned to this attribute for search relevance ranking. Higher weights increase the attributes influence on search result ordering.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationMaxValue rdf:type rdf:Property ;
    rdfs:label 'Validation Max Value' ;
    rdfs:comment 'Maximum allowed value for numeric attributes. Used to enforce data quality rules during catalog enrichment.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationMinValue rdf:type rdf:Property ;
    rdfs:label 'Validation Min Value' ;
    rdfs:comment 'Minimum allowed value for numeric attributes. Used to enforce data quality rules during catalog enrichment.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationRegexPattern rdf:type rdf:Property ;
    rdfs:label 'Validation Regex Pattern' ;
    rdfs:comment 'Regular expression pattern used to validate string attribute values. Enforces format rules such as SKU patterns, UPC format, or custom identifiers.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentBrandId rdf:type rdf:Property ;
    rdfs:label 'Parent Brand Id' ;
    rdfs:comment 'Foreign key reference to the parent brand if this brand is a sub-brand or brand extension. Null for top-level brands. Enables brand hierarchy modeling for conglomerates and brand families.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:primaryCategoryId rdf:type rdf:Property ;
    rdfs:label 'Primary Category Id' ;
    rdfs:comment 'Foreign key reference to the primary product category or taxonomy node most commonly associated with this brand. Used for brand-filtered Product Listing Pages (PLP) and merchandising.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:averageRating rdf:type rdf:Property ;
    rdfs:label 'Average Rating' ;
    rdfs:comment 'Aggregated average customer rating for all products under this brand, on a scale of 0.00 to 5.00. Calculated from product reviews. Used for brand reputation scoring and search ranking.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandDescription rdf:type rdf:Property ;
    rdfs:label 'Brand Description' ;
    rdfs:comment 'Marketing description of the brand, including brand story, heritage, and value proposition. Used for brand pages and Search Engine Optimization (SEO).' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'The official registered name of the brand as it appears in the catalog and on Product Detail Pages (PDP) and Product Listing Pages (PLP).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandStatus rdf:type rdf:Property ;
    rdfs:label 'Brand Status' ;
    rdfs:comment 'Current lifecycle status of the brand in the catalog. Active brands are visible in search and Product Listing Pages (PLP). Inactive and discontinued brands are hidden. Pending approval brands are under review. Suspended brands are temporarily blocked.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertification rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification' ;
    rdfs:comment 'Comma-separated list of compliance certifications held by the brand (e.g., ISO 9001, Fair Trade, Organic, GOTS, B-Corp). Used for compliance filtering and regulatory reporting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'The date when the brand was discontinued and removed from active catalog merchandising. Null for active brands. Used for historical reporting and compliance. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:featuredRank rdf:type rdf:Property ;
    rdfs:label 'Featured Rank' ;
    rdfs:comment 'Merchandising rank used to determine the display order of brands on featured brand pages and promotional campaigns. Lower numbers indicate higher priority. Null if not featured.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isVerified rdf:type rdf:Property ;
    rdfs:label 'Is Verified' ;
    rdfs:comment 'Boolean flag indicating whether the brand has been verified by the platform as an authentic, authorized brand. Verified brands receive trust badges on Product Detail Pages (PDP) and higher search ranking.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturerCountry rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the primary country where products under this brand are manufactured. Used for tariff classification and World Trade Organization (WTO) compliance.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metaTitle rdf:type rdf:Property ;
    rdfs:label 'Meta Title' ;
    rdfs:comment 'Search Engine Optimization (SEO) meta title tag for the brand landing page. Used for organic search ranking and Click-Through Rate (CTR) optimization.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerType rdf:type rdf:Property ;
    rdfs:label 'Owner Type' ;
    rdfs:comment 'Classification of the entity that owns and controls the brand. Values: manufacturer (brand owned by product manufacturer), distributor (brand owned by distribution partner), marketplace_seller (brand owned by third-party seller), private_label (brand owned by the e-commerce platform).' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'The date when the brand was first registered in the Product Information Management (PIM) system and made available for catalog association. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:searchKeywords rdf:type rdf:Property ;
    rdfs:label 'Search Keywords' ;
    rdfs:comment 'Comma-separated list of search keywords and synonyms associated with the brand. Used by the Search and Recommendation Engine for query expansion and Search Engine Optimization (SEO).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tier rdf:type rdf:Property ;
    rdfs:label 'Tier' ;
    rdfs:comment 'Market positioning tier of the brand. Used for pricing strategy, merchandising, and customer segmentation. Values: luxury (high-end designer), premium (aspirational quality), standard (mainstream), value (budget-friendly), private_label (retailer-owned).' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalReviews rdf:type rdf:Property ;
    rdfs:label 'Total Reviews' ;
    rdfs:comment 'Total count of customer reviews submitted for all products under this brand. Used for brand trust signals and Net Promoter Score (NPS) analysis.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSkus rdf:type rdf:Property ;
    rdfs:label 'Total Skus' ;
    rdfs:comment 'Total count of active Stock Keeping Units (SKU) associated with this brand in the catalog. Used for brand breadth analysis and merchandising planning.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trademarkCountry rdf:type rdf:Property ;
    rdfs:label 'Trademark Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the jurisdiction where the trademark is registered. Format: ISO 3166-1 alpha-3.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trademarkNumber rdf:type rdf:Property ;
    rdfs:label 'Trademark Number' ;
    rdfs:comment 'Official trademark registration number issued by the national trademark office. Used for intellectual property verification and counterfeit prevention.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueGeneralLedgerId rdf:type rdf:Property ;
    rdfs:label 'Revenue General Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.general_ledger. Business justification: Bundle sales are posted to a specific revenue GL account; linking ensures correct revenue recognition for bundled offerings.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneralLedger .

ind:bundleCode rdf:type rdf:Property ;
    rdfs:label 'Bundle Code' ;
    rdfs:comment 'Externally-known unique business identifier for the bundle, used in catalog systems, order management, and fulfillment. Typically alphanumeric SKU-style code.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleDescription rdf:type rdf:Property ;
    rdfs:label 'Bundle Description' ;
    rdfs:comment 'Detailed marketing description of the bundle, including value proposition, contents summary, and usage scenarios. Displayed on PDP for customer decision-making.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleName rdf:type rdf:Property ;
    rdfs:label 'Bundle Name' ;
    rdfs:comment 'Human-readable name of the bundle displayed on Product Detail Pages (PDP) and Product Listing Pages (PLP).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleStatus rdf:type rdf:Property ;
    rdfs:label 'Bundle Status' ;
    rdfs:comment 'Current lifecycle status of the bundle in the catalog. Controls visibility and sellability across channels.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleType rdf:type rdf:Property ;
    rdfs:label 'Bundle Type' ;
    rdfs:comment 'Classification of the bundle structure: fixed bundle (pre-defined items), configurable bundle (customer selects components), gift set (curated collection), kit (assembly required), promotional bundle (limited-time offer), subscription box (recurring delivery).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentCount rdf:type rdf:Property ;
    rdfs:label 'Component Count' ;
    rdfs:comment 'Total number of distinct Stock Keeping Units (SKUs) included in the bundle. Used for fulfillment complexity scoring and customer messaging.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crossSellBundleIds rdf:type rdf:Property ;
    rdfs:label 'Cross Sell Bundle Ids' ;
    rdfs:comment 'Comma-separated list of bundle IDs recommended for cross-sell on PDP. Supports recommendation engine and Average Order Value (AOV) optimization.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Discontinued Timestamp' ;
    rdfs:comment 'Timestamp when the bundle was marked as discontinued. Used for product lifecycle reporting and inventory liquidation planning.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:harmonizedTariffCode rdf:type rdf:Property ;
    rdfs:label 'Harmonized Tariff Code' ;
    rdfs:comment 'International trade classification code for customs and duty calculation. Required for cross-border e-commerce and Electronic Data Interchange (EDI) with customs authorities.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConfigurable rdf:type rdf:Property ;
    rdfs:label 'Is Configurable' ;
    rdfs:comment 'Indicates whether customers can customize bundle components (select variants, add-ons, or substitutions) at purchase time.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSubscriptionEligible rdf:type rdf:Property ;
    rdfs:label 'Is Subscription Eligible' ;
    rdfs:comment 'Indicates whether the bundle can be purchased as a recurring subscription with automated replenishment.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:listPrice rdf:type rdf:Property ;
    rdfs:label 'List Price' ;
    rdfs:comment 'Manufacturer\'s suggested retail price (MSRP) or original price before discounts. Used to calculate savings and display strikethrough pricing.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Quantity' ;
    rdfs:comment 'Maximum number of bundle units a customer can purchase in a single order. Used to prevent inventory depletion and manage promotional limits.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Quantity' ;
    rdfs:comment 'Minimum number of bundle units a customer must purchase in a single order. Supports bulk-buy and wholesale scenarios.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modifiedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Modified By User Code' ;
    rdfs:comment 'Reference to the user or system account that last modified the bundle record. Supports change management and SOX compliance.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageDimensionsCm rdf:type rdf:Property ;
    rdfs:label 'Package Dimensions Cm' ;
    rdfs:comment 'Physical dimensions of the bundle package in LxWxH format (centimeters). Used for warehouse slotting, cartonization, and Less Than Truck Load (LTL) / Full Truck Load (FTL) planning.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingStrategy rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy' ;
    rdfs:comment 'Method used to calculate bundle price: fixed price (single price regardless of components), sum-of-parts (total of individual SKU prices), discounted (percentage off sum-of-parts), tiered (price varies by quantity), dynamic (algorithmic pricing).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingClass rdf:type rdf:Property ;
    rdfs:label 'Shipping Class' ;
    rdfs:comment 'Shipping method classification for the bundle. Determines carrier eligibility, Service Level Agreement (SLA) targets, and last-mile delivery options.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Concise summary of the bundle for display on PLP, search results, and mobile views. Typically 150-200 characters.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upsellBundleIds rdf:type rdf:Property ;
    rdfs:label 'Upsell Bundle Ids' ;
    rdfs:comment 'Comma-separated list of higher-value bundle IDs recommended for upsell. Supports Gross Merchandise Value (GMV) growth and Customer Acquisition Cost (CAC) recovery.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleComponentId rdf:type rdf:Property ;
    rdfs:label 'Bundle Component Id' ;
    rdfs:comment 'Unique identifier for the bundle component association record. Primary key.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bundleSkuId rdf:type rdf:Property ;
    rdfs:label 'Bundle Sku Id' ;
    rdfs:comment 'Reference to the individual component SKU that is part of the bundle.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:primaryBundleSkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Bundle Sku Id' ;
    rdfs:comment 'Reference to the parent bundle product SKU that contains this component.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:assemblyInstructionText rdf:type rdf:Property ;
    rdfs:label 'Assembly Instruction Text' ;
    rdfs:comment 'Textual instructions for warehouse staff on how to assemble or package this component within the bundle. Used during pick-pack-ship operations.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentPriceOverride rdf:type rdf:Property ;
    rdfs:label 'Component Price Override' ;
    rdfs:comment 'Optional component-level pricing override for this SKU within the bundle context. Used when the component has a different price when sold as part of the bundle versus standalone. Null if standard component pricing applies.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentQuantity rdf:type rdf:Property ;
    rdfs:label 'Component Quantity' ;
    rdfs:comment 'The quantity of this component SKU required in the bundle. Supports fractional quantities for items sold by weight or volume.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentRole rdf:type rdf:Property ;
    rdfs:label 'Component Role' ;
    rdfs:comment 'The functional role of this component within the bundle (e.g., primary product, accessory, optional add-on, complementary item, replacement part, or sample).' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentStatus rdf:type rdf:Property ;
    rdfs:label 'Component Status' ;
    rdfs:comment 'Current lifecycle status of this component within the bundle. Active components are available for sale, inactive are temporarily unavailable, discontinued are permanently removed, and pending are awaiting approval.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Component Volume M3' ;
    rdfs:comment 'The volume of this component in cubic meters. Used for calculating total bundle volume for warehouse space planning and shipping container optimization.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentWeightKg rdf:type rdf:Property ;
    rdfs:label 'Component Weight Kg' ;
    rdfs:comment 'The weight of this component in kilograms. Used for calculating total bundle weight for shipping cost estimation and carrier selection.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:displaySequence rdf:type rdf:Property ;
    rdfs:label 'Display Sequence' ;
    rdfs:comment 'The order in which this component should be displayed in the bundle configurator UI, Product Detail Page (PDP), and fulfillment documentation. Lower numbers appear first.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hsCode rdf:type rdf:Property ;
    rdfs:label 'Hs Code' ;
    rdfs:comment 'Harmonized System code for this component used for international trade classification, customs duties, and tariff determination.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryReservationPriority rdf:type rdf:Property ;
    rdfs:label 'Inventory Reservation Priority' ;
    rdfs:comment 'Priority level for reserving inventory for this component during bundle order processing. Lower numbers indicate higher priority. Used by Warehouse Management System (WMS) for allocation logic.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isSubstitutable rdf:type rdf:Property ;
    rdfs:label 'Is Substitutable' ;
    rdfs:comment 'Indicates whether this component can be substituted with an alternative SKU during fulfillment if out of stock. True if substitution is allowed, False otherwise.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVisibleToCustomer rdf:type rdf:Property ;
    rdfs:label 'Is Visible To Customer' ;
    rdfs:comment 'Indicates whether this component is visible to the customer on the Product Detail Page (PDP) and Product Listing Page (PLP). False for hidden components like packaging materials or promotional inserts.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'The username or identifier of the user who last modified this bundle component record. Used for audit trail and data governance.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionGroupCode rdf:type rdf:Property ;
    rdfs:label 'Substitution Group Code' ;
    rdfs:comment 'Code identifying the substitution group for this component. Components with the same substitution group code can be interchanged during fulfillment. Null if component is not substitutable.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingContentItemId rdf:type rdf:Property ;
    rdfs:label 'Marketing Content Item Id' ;
    rdfs:comment 'Foreign key linking to content.content_item. Business justification: REQUIRED: Product detail pages pull rich HTML content from CMS; linking catalog items to content items drives PDP rendering.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Item .

ind:primarySellerProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Seller Profile Id' ;
    rdfs:comment 'Foreign key linking to seller.seller_profile. Business justification: REQUIRED: Default Seller Assignment for catalog items, needed for pricing, fulfillment routing and sales reporting; obvious to marketplace operators.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SellerProfile .

ind:color rdf:type rdf:Property ;
    rdfs:label 'Color' ;
    rdfs:comment 'Primary color or color variant of the product, used for product differentiation, filtering, and variant management.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpscComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Cpsc Compliance Status' ;
    rdfs:comment 'Indicates whether the product meets CPSC safety standards and regulations, critical for product safety compliance and recall management.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ean rdf:type rdf:Property ;
    rdfs:label 'Ean' ;
    rdfs:comment '13-digit international product identifier used globally for retail scanning and supply chain tracking.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endOfLifeDate rdf:type rdf:Property ;
    rdfs:label 'End Of Life Date' ;
    rdfs:comment 'The date when the product will be or was discontinued and removed from active catalog, used for inventory planning and clearance strategies.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isTaxable rdf:type rdf:Property ;
    rdfs:label 'Is Taxable' ;
    rdfs:comment 'Indicates whether the product is subject to sales tax, VAT, or other consumption taxes in applicable jurisdictions.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'The date when the product was first made available for sale on the platform, used for new product performance tracking and lifecycle analytics.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'The unique part number assigned by the manufacturer, used for warranty claims, technical support, and supplier coordination.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialComposition rdf:type rdf:Property ;
    rdfs:label 'Material Composition' ;
    rdfs:comment 'Description of the materials used in the product construction (e.g., 100% Cotton, Stainless Steel), used for product specifications and compliance labeling.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumAgeRequirement rdf:type rdf:Property ;
    rdfs:label 'Minimum Age Requirement' ;
    rdfs:comment 'The minimum age in years required to purchase this product, enforced during checkout for age-restricted items.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pimSourceCode rdf:type rdf:Property ;
    rdfs:label 'Pim Source Code' ;
    rdfs:comment 'Unique identifier of this product in the source PIM system, used for data lineage and system integration reconciliation.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pimSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Pim Source System' ;
    rdfs:comment 'Name of the Product Information Management system that is the authoritative source for this catalog item master data.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productSubcategory rdf:type rdf:Property ;
    rdfs:label 'Product Subcategory' ;
    rdfs:comment 'Granular subcategory classification within the product taxonomy, enabling precise product discovery and merchandising strategies.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productTitle rdf:type rdf:Property ;
    rdfs:label 'Product Title' ;
    rdfs:comment 'Extended product title optimized for Search Engine Optimization (SEO) and Search Engine Marketing (SEM), including key attributes and brand information.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'High-level classification of the product category (e.g., Electronics, Apparel, Home & Garden), used for catalog organization and merchandising.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:comment 'Size designation of the product (e.g., Small, Medium, Large, or numeric sizes), used for apparel, footwear, and size-variant products.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Duration Months' ;
    rdfs:comment 'Duration of the manufacturer or seller warranty in months, used for warranty claim validation and customer service.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyType rdf:type rdf:Property ;
    rdfs:label 'Warranty Type' ;
    rdfs:comment 'Type of warranty coverage provided with the product (manufacturer warranty, seller warranty, extended warranty, or no warranty).' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Id' ;
    rdfs:comment 'Unique identifier for the compliance certification record. Primary key for the compliance certification data product.' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expenseGeneralLedgerId rdf:type rdf:Property ;
    rdfs:label 'Expense General Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.general_ledger. Business justification: Compliance certification costs are recorded against a GL account; linking allows tracking certification expenses per catalog item.' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneralLedger .

ind:ageWarningFlag rdf:type rdf:Property ;
    rdfs:label 'Age Warning Flag' ;
    rdfs:comment 'Boolean indicator of whether the product requires an age-related warning label (e.g., not suitable for children under 3 years due to choking hazard). True if age warning is required, False otherwise.' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableMarket rdf:type rdf:Property ;
    rdfs:label 'Applicable Market' ;
    rdfs:comment 'The geographic market or jurisdiction where this certification is valid and recognized. Use 3-letter ISO country codes (e.g., USA, DEU, GBR) or regional codes (e.g., EUR for European Union).' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationCost rdf:type rdf:Property ;
    rdfs:label 'Certification Cost' ;
    rdfs:comment 'The total cost incurred to obtain this certification, including testing fees, application fees, and laboratory charges. Used for cost accounting and vendor management.' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Certification Document Url' ;
    rdfs:comment 'The URL or file path to the digital copy of the certification document, test report, or compliance declaration. Used for audit trails and regulatory reporting.' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'The unique certification or registration number issued by the certifying body. This is the externally-known identifier for the certification.' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'The type of regulatory or safety certification. CPSC (Consumer Product Safety Commission), CE (Conformité Européenne), FCC (Federal Communications Commission), RoHS (Restriction of Hazardous Substances), UL (Underwriters Laboratories), FDA (Food and Drug Administration), REACH (Registration, Evaluation, Authorisation and Restriction of Chemicals), California Prop 65 (Safe Drinking Water and Toxic Enforcement Act). [ENUM-REF-CANDIDATE: CPSC|CE|FCC|RoHS|UL|FDA|REACH|California Prop 65 — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardCategory rdf:type rdf:Property ;
    rdfs:label 'Hazard Category' ;
    rdfs:comment 'The classification of potential hazards associated with the product (e.g., choking hazard, flammability, chemical exposure, electrical shock, sharp edges). Used for CPSC compliance and consumer safety warnings.' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBody rdf:type rdf:Property ;
    rdfs:label 'Issuing Body' ;
    rdfs:comment 'The name of the regulatory authority, testing laboratory, or certification organization that issued the certification (e.g., CPSC, UL, TÜV, SGS, Intertek).' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listingEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Listing Eligibility Flag' ;
    rdfs:comment 'Boolean indicator of whether this certification makes the product eligible for marketplace listing. True if certification is sufficient for listing, False if additional certifications are required.' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumAgeYears rdf:type rdf:Property ;
    rdfs:label 'Minimum Age Years' ;
    rdfs:comment 'The minimum recommended or required age in years for safe use of the product. Nullable if no age restriction applies.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsiblePartyAddress rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Address' ;
    rdfs:comment 'The full mailing address of the responsible party. Required for CPSC compliance and regulatory reporting.' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyContactEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Contact Email' ;
    rdfs:comment 'The email address of the responsible party for certification inquiries and regulatory correspondence.' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Contact Phone' ;
    rdfs:comment 'The phone number of the responsible party for certification inquiries and regulatory correspondence.' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyName rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Name' ;
    rdfs:comment 'The name of the legal entity or individual responsible for ensuring product compliance and maintaining the certification (e.g., manufacturer, importer, private labeler).' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'The date on which the certification was revoked by the issuing body. Nullable if certification has never been revoked.' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'The reason provided by the issuing body for revoking the certification (e.g., product defect discovered, non-compliance with standard, fraudulent application).' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeOfCertification rdf:type rdf:Property ;
    rdfs:label 'Scope Of Certification' ;
    rdfs:comment 'A description of what aspects of the product are covered by this certification (e.g., electrical safety only, full product compliance, packaging materials only).' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardReference rdf:type rdf:Property ;
    rdfs:label 'Standard Reference' ;
    rdfs:comment 'The specific regulatory standard or technical specification that the product was tested against (e.g., ASTM F963, EN 71, IEC 60950, 16 CFR Part 1500).' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testReportNumber rdf:type rdf:Property ;
    rdfs:label 'Test Report Number' ;
    rdfs:comment 'The unique identifier of the laboratory test report that supports this certification. Links to the underlying test data and results.' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingLaboratory rdf:type rdf:Property ;
    rdfs:label 'Testing Laboratory' ;
    rdfs:comment 'The name of the accredited testing laboratory that performed the compliance testing (e.g., UL, Intertek, SGS, TÜV, Bureau Veritas).' ;
    rdfs:domain ind:ComplianceCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributeValueId rdf:type rdf:Property ;
    rdfs:label 'Attribute Value Id' ;
    rdfs:comment 'Unique identifier for the product attribute value record. Primary key.' ;
    rdfs:domain ind:AttributeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enrichmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrichment Status' ;
    rdfs:comment 'The current status of the attribute value in the enrichment workflow. Tracks whether the value has been validated, enriched, or requires further action.' ;
    rdfs:domain ind:AttributeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrichmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Enrichment Timestamp' ;
    rdfs:comment 'The date and time when the attribute value was last enriched or validated in the PIM system.' ;
    rdfs:domain ind:AttributeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isVariantDefining rdf:type rdf:Property ;
    rdfs:label 'Is Variant Defining' ;
    rdfs:comment 'Indicates whether this attribute value defines a product variant (e.g., size, color) that creates a distinct SKU within a product family.' ;
    rdfs:domain ind:AttributeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rawValue rdf:type rdf:Property ;
    rdfs:label 'Raw Value' ;
    rdfs:comment 'The raw string representation of the attribute value as captured from the source system or enrichment process.' ;
    rdfs:domain ind:AttributeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typedValueBoolean rdf:type rdf:Property ;
    rdfs:label 'Typed Value Boolean' ;
    rdfs:comment 'The attribute value when the attribute type is boolean. Used for yes/no or true/false product characteristics.' ;
    rdfs:domain ind:AttributeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:typedValueDate rdf:type rdf:Property ;
    rdfs:label 'Typed Value Date' ;
    rdfs:comment 'The attribute value when the attribute type is date. Used for time-based product attributes such as release date or expiration date.' ;
    rdfs:domain ind:AttributeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:typedValueNumeric rdf:type rdf:Property ;
    rdfs:label 'Typed Value Numeric' ;
    rdfs:comment 'The attribute value when the attribute type is numeric. Enables range filtering and comparison operations.' ;
    rdfs:domain ind:AttributeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typedValueString rdf:type rdf:Property ;
    rdfs:label 'Typed Value String' ;
    rdfs:comment 'The attribute value when the attribute type is string or text. Used for faceted search and filtering.' ;
    rdfs:domain ind:AttributeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Category Id' ;
    rdfs:comment 'Reference to the parent category node in the hierarchy. Null for root-level categories. Enables tree traversal and multi-level category structures.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:averageMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Average Margin Percent' ;
    rdfs:comment 'Average gross margin percentage for products in this category. Used for pricing strategy, promotional planning, and financial forecasting. Business-confidential metric.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:categoryDescription rdf:type rdf:Property ;
    rdfs:label 'Category Description' ;
    rdfs:comment 'Detailed textual description of the category displayed on PLP (Product Listing Page) headers. Provides context and improves SEO (Search Engine Optimization) content richness.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultShippingClass rdf:type rdf:Property ;
    rdfs:label 'Default Shipping Class' ;
    rdfs:comment 'Default shipping class for products in this category. Used for carrier selection, rate calculation, and SLA (Service Level Agreement) determination in TMS (Transportation Management System).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCode rdf:type rdf:Property ;
    rdfs:label 'External Code' ;
    rdfs:comment 'Identifier from the source Product Information Management (PIM) system or ERP (Enterprise Resource Planning) system. Used for data integration and reconciliation.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullPath rdf:type rdf:Property ;
    rdfs:label 'Full Path' ;
    rdfs:comment 'Complete hierarchical path from root to current node, typically slash-delimited (e.g., Electronics/Smartphones/Android Phones). Used for breadcrumb navigation and SEO (Search Engine Optimization).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iconUrl rdf:type rdf:Property ;
    rdfs:label 'Icon Url' ;
    rdfs:comment 'URL to the category icon or glyph stored in CDN (Content Delivery Network). Used for compact navigation menus and mobile interfaces.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFeatured rdf:type rdf:Property ;
    rdfs:label 'Is Featured' ;
    rdfs:comment 'Boolean flag indicating whether this category is promoted as a featured category on the homepage or main navigation. Used for merchandising campaigns.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeaf rdf:type rdf:Property ;
    rdfs:label 'Is Leaf' ;
    rdfs:comment 'Boolean flag indicating whether this category is a terminal node (leaf) with no child categories. Leaf categories typically contain SKU (Stock Keeping Unit) assignments.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNavigable rdf:type rdf:Property ;
    rdfs:label 'Is Navigable' ;
    rdfs:comment 'Boolean flag indicating whether this category appears in customer-facing navigation menus. Hidden categories may exist for internal classification only.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productCount rdf:type rdf:Property ;
    rdfs:label 'Product Count' ;
    rdfs:comment 'Total number of active SKU (Stock Keeping Unit) products currently assigned to this category. Used for merchandising analytics and empty category detection.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresAgeVerification rdf:type rdf:Property ;
    rdfs:label 'Requires Age Verification' ;
    rdfs:comment 'Boolean flag indicating whether products in this category require age verification at checkout (e.g., alcohol, tobacco). Used for compliance with FTC (Federal Trade Commission) and state regulations.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresCpscCompliance rdf:type rdf:Property ;
    rdfs:label 'Requires Cpsc Compliance' ;
    rdfs:comment 'Boolean flag indicating whether products in this category must comply with CPSC (Consumer Product Safety Commission) safety standards. Used for product onboarding validation.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seoSlug rdf:type rdf:Property ;
    rdfs:label 'Seo Slug' ;
    rdfs:comment 'URL-friendly lowercase hyphenated string used in category page URLs for SEO (Search Engine Optimization) and clean URL structure (e.g., electronics-smartphones).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyStandard rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Standard' ;
    rdfs:comment 'Industry classification standard used for this category (e.g., GS1 Global Product Classification, UNSPSC, eCl@ss). Supports multi-taxonomy mapping for B2B (Business to Business) and marketplace integration.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productDigitalAssetId rdf:type rdf:Property ;
    rdfs:label 'Product Digital Asset Id' ;
    rdfs:comment 'Unique identifier for the product digital asset record. Primary key for this entity.' ;
    rdfs:domain ind:ProductDigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessibilityComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Accessibility Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether the asset meets WCAG accessibility standards (alt text, captions, transcripts). Required for regulatory compliance.' ;
    rdfs:domain ind:ProductDigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrichmentCompletenessScore rdf:type rdf:Property ;
    rdfs:label 'Enrichment Completeness Score' ;
    rdfs:comment 'Percentage score (0-100) measuring content enrichment quality and completeness. Calculated based on presence of required attributes, SEO metadata, and multi-locale coverage.' ;
    rdfs:domain ind:ProductDigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalAssetCode rdf:type rdf:Property ;
    rdfs:label 'External Asset Code' ;
    rdfs:comment 'Unique identifier from the source system or external DAM platform. Enables cross-system reconciliation and integration.' ;
    rdfs:domain ind:ProductDigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagsMetadata rdf:type rdf:Property ;
    rdfs:label 'Tags Metadata' ;
    rdfs:comment 'Comma-separated list of descriptive tags for asset categorization and search. Supports content discovery and filtering in DAM systems.' ;
    rdfs:domain ind:ProductDigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRightsNotes rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Notes' ;
    rdfs:comment 'Free-text notes describing usage restrictions, attribution requirements, or special licensing terms. Supports legal compliance and rights management.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierId rdf:type rdf:Property ;
    rdfs:label 'Identifier Id' ;
    rdfs:comment 'Unique identifier for the product identifier record. Primary key.' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:barcodeFormat rdf:type rdf:Property ;
    rdfs:label 'Barcode Format' ;
    rdfs:comment 'The physical barcode symbology or format used to encode this identifier for scanning and automated data capture. Examples include EAN-13, UPC-A, Code 128, QR Code, Data Matrix, ITF-14. NONE if no barcode representation exists. [ENUM-REF-CANDIDATE: EAN_13|UPC_A|CODE_128|QR_CODE|DATA_MATRIX|ITF_14|NONE — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkDigit rdf:type rdf:Property ;
    rdfs:label 'Check Digit' ;
    rdfs:comment 'The check digit or validation character used to verify the integrity of the identifier value. Commonly used in UPC, EAN, and GTIN codes to detect data entry or transmission errors. Null if the identifier type does not use check digits.' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Customs Classification Code' ;
    rdfs:comment 'Harmonized System (HS) code used for international trade and customs classification. This code determines tariffs, duties, and regulatory requirements for cross-border shipments. Typically 6-10 digits depending on country-specific extensions.' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceUrl rdf:type rdf:Property ;
    rdfs:label 'External Reference Url' ;
    rdfs:comment 'A URL link to an external registry, database, or authority where additional information about this identifier can be found. Examples include GS1 registry lookup, manufacturer product pages, or regulatory databases.' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gtinType rdf:type rdf:Property ;
    rdfs:label 'Gtin Type' ;
    rdfs:comment 'The specific GTIN format used for this identifier. GTIN-8 (8 digits), GTIN-12 (UPC, 12 digits), GTIN-13 (EAN, 13 digits), GTIN-14 (case/pallet level, 14 digits). NONE if the identifier is not a GTIN.' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierStatus rdf:type rdf:Property ;
    rdfs:label 'Identifier Status' ;
    rdfs:comment 'Current lifecycle status of the product identifier. ACTIVE indicates the identifier is currently in use; INACTIVE indicates it is no longer used; DEPRECATED indicates it has been replaced by a newer identifier; PENDING indicates it is awaiting verification or activation; SUSPENDED indicates temporary deactivation.' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierType rdf:type rdf:Property ;
    rdfs:label 'Identifier Type' ;
    rdfs:comment 'The type or classification of the product identifier. Indicates the standard or system that issued the identifier (e.g., UPC for Universal Product Code, EAN for European Article Number, ASIN for Amazon Standard Identification Number, GTIN for Global Trade Item Number, ISBN for International Standard Book Number, MPN for Manufacturer Part Number, HS_CODE for Harmonized System code for customs, SELLER_SKU for marketplace seller SKU, INTERNAL_SKU for internal SKU). [ENUM-REF-CANDIDATE: UPC|EAN|ASIN|GTIN|ISBN|MPN|HS_CODE|SELLER_SKU|INTERNAL_SKU|CUSTOM — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifierValue rdf:type rdf:Property ;
    rdfs:label 'Identifier Value' ;
    rdfs:comment 'The actual identifier value or code. This is the unique alphanumeric string that represents the product in the specified identifier system (e.g., the 12-digit UPC code, the 13-digit EAN, the 10-character ASIN).' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingLevel rdf:type rdf:Property ;
    rdfs:label 'Packaging Level' ;
    rdfs:comment 'The level of packaging hierarchy that this identifier represents. EACH for individual consumer unit, INNER_PACK for multi-packs, CASE for shipping cases, PALLET for pallet-level, DISPLAY_UNIT for retail display units. Used for supply chain and logistics optimization.' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'The date and time when this identifier was last verified or validated against the issuing authority or external registry. Used for data quality auditing and compliance tracking.' ;
    rdfs:domain ind:Identifier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:productListingId rdf:type rdf:Property ;
    rdfs:label 'Product Listing Id' ;
    rdfs:comment 'Unique identifier for the product listing record. Primary key for the product listing entity.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageRestriction rdf:type rdf:Property ;
    rdfs:label 'Age Restriction' ;
    rdfs:comment 'The minimum age required to purchase this product, if applicable. Common values: 18 (alcohol, tobacco), 21 (certain regulated products), 13 (COPPA compliance for digital products). Null indicates no age restriction.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buyBoxEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Buy Box Eligible Flag' ;
    rdfs:comment 'Indicates whether this listing is eligible to compete for the buy box on marketplace channels. The buy box is the prominent \'Add to Cart\' section on a product page. Eligibility is determined by factors such as price competitiveness, fulfillment method, seller performance metrics, and inventory availability.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelListingCode rdf:type rdf:Property ;
    rdfs:label 'Channel Listing Code' ;
    rdfs:comment 'The unique identifier assigned by the sales channel for this listing. For Amazon-style marketplaces, this would be the ASIN (Amazon Standard Identification Number). For other channels, this is the channel\'s native product identifier.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compareAtPrice rdf:type rdf:Property ;
    rdfs:label 'Compare At Price' ;
    rdfs:comment 'The original or suggested retail price shown for comparison purposes to highlight discounts. Used to calculate savings percentage displayed on PDP and Product Listing Page (PLP). Null if no comparison pricing is used.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conditionType rdf:type rdf:Property ;
    rdfs:label 'Condition Type' ;
    rdfs:comment 'The physical condition of the product being sold through this listing. New: brand new in original packaging; Refurbished: restored to working condition; Used: previously owned; Open Box: new but packaging opened; Damaged: functional but with cosmetic or minor defects.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eanCode rdf:type rdf:Property ;
    rdfs:label 'Ean Code' ;
    rdfs:comment 'The 13-digit European Article Number barcode identifier for the product. Commonly used in international markets. Equivalent to UPC but with an additional digit for country code.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featuredFlag rdf:type rdf:Property ;
    rdfs:label 'Featured Flag' ;
    rdfs:comment 'Indicates whether this listing is featured or promoted on the channel\'s homepage, category pages, or marketing campaigns. Featured listings receive higher visibility and priority in search and recommendation algorithms.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastSoldTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Sold Timestamp' ;
    rdfs:comment 'The timestamp of the most recent order placed for this listing. Used to identify slow-moving inventory, calculate Daily Sales Rate (DSR), and trigger automated repricing or suppression rules.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:listingStatus rdf:type rdf:Property ;
    rdfs:label 'Listing Status' ;
    rdfs:comment 'Current operational status of the product listing on the channel. Active: live and purchasable; Suppressed: hidden due to quality or compliance issues; Pending: awaiting approval or activation; Inactive: manually disabled; Suspended: temporarily blocked; Archived: permanently removed.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'The maximum number of units a customer can purchase in a single order for this listing. Used to prevent overselling, manage high-demand products, or enforce promotional limits. Null indicates no maximum limit.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionalBadge rdf:type rdf:Property ;
    rdfs:label 'Promotional Badge' ;
    rdfs:comment 'A marketing badge or label displayed on the listing to highlight special offers or features. Examples: \'Best Seller\', \'Limited Time Offer\', \'Free Shipping\', \'New Arrival\', \'Exclusive\'. Used to increase Click-Through Rate (CTR) and Conversion Rate (CVR).' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedShippingRegions rdf:type rdf:Property ;
    rdfs:label 'Restricted Shipping Regions' ;
    rdfs:comment 'Comma-separated list of geographic regions (country codes, state codes, or postal code patterns) where this listing cannot be shipped due to regulatory, legal, or business restrictions. Examples: \'CA,NY,HI\' for US states, \'DEU,FRA\' for countries.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingDimensions rdf:type rdf:Property ;
    rdfs:label 'Shipping Dimensions' ;
    rdfs:comment 'The package dimensions in format \'Length x Width x Height\' with unit (e.g., \'30x20x10 cm\'). Used for shipping cost calculation, warehouse space planning, and carrier compatibility checks.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upcCode rdf:type rdf:Property ;
    rdfs:label 'Upc Code' ;
    rdfs:comment 'The 12-digit Universal Product Code barcode identifier for the product. Required for many retail and marketplace channels. Used for inventory tracking, point-of-sale scanning, and catalog integration.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationId rdf:type rdf:Property ;
    rdfs:label 'Relation Id' ;
    rdfs:comment 'Primary key for relation' ;
    rdfs:domain ind:Relation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSkuId rdf:type rdf:Property ;
    rdfs:label 'Source Sku Id' ;
    rdfs:comment 'Identifier of the source catalog item (SKU) from which the relationship originates. This is the product displayed on the PDP or cart page that triggers the recommendation.' ;
    rdfs:domain ind:Relation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:targetSkuId rdf:type rdf:Property ;
    rdfs:label 'Target Sku Id' ;
    rdfs:comment 'Identifier of the target catalog item (SKU) being recommended or related. This is the product suggested to the customer based on the source SKU.' ;
    rdfs:domain ind:Relation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:displayPosition rdf:type rdf:Property ;
    rdfs:label 'Display Position' ;
    rdfs:comment 'Ordinal position in which the related product should appear in the recommendation widget on the Product Detail Page (PDP) or cart page. Lower numbers indicate higher priority placement.' ;
    rdfs:domain ind:Relation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastPerformanceUpdateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Performance Update Timestamp' ;
    rdfs:comment 'Date and time when the performance metrics (impressions, clicks, conversions, revenue) were last refreshed from the analytics pipeline. Supports data freshness monitoring and Extract Transform Load (ETL) orchestration.' ;
    rdfs:domain ind:Relation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:merchandisingNotes rdf:type rdf:Property ;
    rdfs:label 'Merchandising Notes' ;
    rdfs:comment 'Free-text notes from merchandising team explaining the rationale for the product relationship, special handling instructions, or campaign context. Supports manual curation workflows and knowledge transfer.' ;
    rdfs:domain ind:Relation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationSource rdf:type rdf:Property ;
    rdfs:label 'Relation Source' ;
    rdfs:comment 'Origin or method by which the product relationship was created. Indicates whether the relation was manually curated by merchandising team, generated algorithmically by recommendation engine, submitted by marketplace seller, or derived from specific ML techniques (collaborative filtering, content-based, hybrid).' ;
    rdfs:domain ind:Relation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationType rdf:type rdf:Property ;
    rdfs:label 'Relation Type' ;
    rdfs:comment 'Type of product-to-product relationship. Defines the nature of the recommendation: cross_sell (complementary product), upsell (higher-value alternative), frequently_bought_together (bundle suggestion), accessory (add-on item), replacement (substitute product), spare_part (component or part).' ;
    rdfs:domain ind:Relation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strengthScore rdf:type rdf:Property ;
    rdfs:label 'Strength Score' ;
    rdfs:comment 'Numeric score representing the strength or confidence of the product relationship, typically ranging from 0.0000 to 1.0000. Higher scores indicate stronger associations and higher likelihood of conversion. Used by recommendation algorithms to rank suggestions.' ;
    rdfs:domain ind:Relation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalClicks rdf:type rdf:Property ;
    rdfs:label 'Total Clicks' ;
    rdfs:comment 'Cumulative count of times customers clicked on the related product recommendation. Used to calculate Click-Through Rate (CTR) and Conversion Rate (CVR).' ;
    rdfs:domain ind:Relation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sellerSkuMappingId rdf:type rdf:Property ;
    rdfs:label 'Seller Sku Mapping Id' ;
    rdfs:comment 'Unique identifier for the seller SKU mapping record. Primary key for the seller SKU mapping entity.' ;
    rdfs:domain ind:SellerSkuMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:canonicalCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Canonical Catalog Item Id' ;
    rdfs:comment 'Reference to the platform\'s authoritative catalog item (ASIN-equivalent) that this seller SKU has been mapped to. Enables buy box competition and GMV attribution. Null when mapping status is unmapped or pending_review.' ;
    rdfs:domain ind:SellerSkuMapping ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:autoRemapEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Remap Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this seller SKU is eligible for automatic remapping if the canonical catalog item is merged or deprecated. False requires manual seller intervention for catalog changes.' ;
    rdfs:domain ind:SellerSkuMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:canonicalBrandName rdf:type rdf:Property ;
    rdfs:label 'Canonical Brand Name' ;
    rdfs:comment 'The authoritative brand name from the platform\'s canonical catalog for the mapped item. Used to detect brand mismatches and potential intellectual property violations.' ;
    rdfs:domain ind:SellerSkuMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:canonicalCategoryPath rdf:type rdf:Property ;
    rdfs:label 'Canonical Category Path' ;
    rdfs:comment 'The authoritative product category hierarchy path from the platform\'s canonical taxonomy that the mapped catalog item belongs to. Used for category compliance validation.' ;
    rdfs:domain ind:SellerSkuMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFailureReason rdf:type rdf:Property ;
    rdfs:label 'Compliance Failure Reason' ;
    rdfs:comment 'Detailed explanation of compliance check failures including specific regulations violated, policy breaches, or safety concerns. Null when compliance_check_status is passed or not_required.' ;
    rdfs:domain ind:SellerSkuMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmvAttributionEnabled rdf:type rdf:Property ;
    rdfs:label 'Gmv Attribution Enabled' ;
    rdfs:comment 'Boolean flag indicating whether sales of this seller SKU are included in GMV reporting and seller commission calculations. False may indicate mapping is pending or rejected.' ;
    rdfs:domain ind:SellerSkuMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:imageMatchScore rdf:type rdf:Property ;
    rdfs:label 'Image Match Score' ;
    rdfs:comment 'Computer vision similarity score (0.0000 to 1.0000) comparing seller-provided product images to canonical catalog item images. Used when image_match mapping method is applied.' ;
    rdfs:domain ind:SellerSkuMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBuyBoxEligible rdf:type rdf:Property ;
    rdfs:label 'Is Buy Box Eligible' ;
    rdfs:comment 'Boolean flag indicating whether this mapped seller SKU is eligible to compete for the buy box on the product detail page. False may indicate seller performance issues, policy violations, or pricing problems.' ;
    rdfs:domain ind:SellerSkuMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDuplicateListing rdf:type rdf:Property ;
    rdfs:label 'Is Duplicate Listing' ;
    rdfs:comment 'Boolean flag indicating whether this seller SKU was identified as a duplicate of an existing seller listing for the same canonical catalog item. True indicates the seller is attempting to create multiple listings for the same product.' ;
    rdfs:domain ind:SellerSkuMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mappingConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Mapping Confidence Score' ;
    rdfs:comment 'Algorithmic confidence score (0.0000 to 1.0000) indicating the certainty of the mapping between seller SKU and canonical catalog item. Higher scores indicate stronger match signals. Used to prioritize manual review queue.' ;
    rdfs:domain ind:SellerSkuMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mappingMethod rdf:type rdf:Property ;
    rdfs:label 'Mapping Method' ;
    rdfs:comment 'The technique or algorithm used to establish the mapping between seller SKU and canonical catalog item. Exact_barcode_match is highest confidence; manual_review indicates human intervention was required.' ;
    rdfs:domain ind:SellerSkuMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mappingSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Mapping Source System' ;
    rdfs:comment 'The system or integration channel through which the seller submitted this SKU for mapping (e.g., Seller Portal UI, API, EDI, Bulk Upload). Used for channel performance analysis.' ;
    rdfs:domain ind:SellerSkuMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mappingStatus rdf:type rdf:Property ;
    rdfs:label 'Mapping Status' ;
    rdfs:comment 'Current lifecycle status of the seller SKU mapping. Mapped indicates successful linkage to canonical catalog; pending_review requires manual intervention; rejected indicates failed mapping with reason; unmapped indicates no match found.' ;
    rdfs:domain ind:SellerSkuMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mappingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Mapping Timestamp' ;
    rdfs:comment 'The date and time when the seller SKU was successfully mapped to the canonical catalog item. Represents the business event time when the mapping became effective for buy box competition.' ;
    rdfs:domain ind:SellerSkuMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rejectionNotes rdf:type rdf:Property ;
    rdfs:label 'Rejection Notes' ;
    rdfs:comment 'Free-text explanation provided by the reviewer detailing the specific reasons for rejection and guidance for seller remediation. Null when mapping status is not rejected.' ;
    rdfs:domain ind:SellerSkuMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerBrandName rdf:type rdf:Property ;
    rdfs:label 'Seller Brand Name' ;
    rdfs:comment 'The brand name as declared by the seller in their listing submission. Used for brand validation and intellectual property compliance checks during mapping.' ;
    rdfs:domain ind:SellerSkuMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerCategoryPath rdf:type rdf:Property ;
    rdfs:label 'Seller Category Path' ;
    rdfs:comment 'The product category hierarchy path as declared by the seller in their listing submission. Used for category validation and mismatch detection during mapping.' ;
    rdfs:domain ind:SellerSkuMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerEanCode rdf:type rdf:Property ;
    rdfs:label 'Seller Ean Code' ;
    rdfs:comment 'The 13-digit EAN barcode provided by the seller for exact barcode matching to canonical catalog items. Used in international marketplace operations.' ;
    rdfs:domain ind:SellerSkuMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerProductTitle rdf:type rdf:Property ;
    rdfs:label 'Seller Product Title' ;
    rdfs:comment 'The product title or name as provided by the seller in their listing submission. Used for fuzzy matching and manual review processes.' ;
    rdfs:domain ind:SellerSkuMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerSkuCode rdf:type rdf:Property ;
    rdfs:label 'Seller Sku Code' ;
    rdfs:comment 'The seller\'s own SKU or product identifier code used in their internal catalog system. This is the seller-provided reference that must be mapped to the platform\'s canonical catalog.' ;
    rdfs:domain ind:SellerSkuMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerUpcCode rdf:type rdf:Property ;
    rdfs:label 'Seller Upc Code' ;
    rdfs:comment 'The 12-digit UPC barcode provided by the seller for exact barcode matching to canonical catalog items. Critical for automated mapping via exact_barcode_match method.' ;
    rdfs:domain ind:SellerSkuMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleMatchScore rdf:type rdf:Property ;
    rdfs:label 'Title Match Score' ;
    rdfs:comment 'Natural language processing similarity score (0.0000 to 1.0000) comparing seller product title to canonical catalog item title. Used when fuzzy_title_match mapping method is applied.' ;
    rdfs:domain ind:SellerSkuMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryGeneralLedgerId rdf:type rdf:Property ;
    rdfs:label 'Inventory General Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.general_ledger. Business justification: Needed for inventory valuation accounting; each SKU posts inventory movements to its specific GL account for COGS and stock balance.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneralLedger .

ind:ownerSellerProfileId rdf:type rdf:Property ;
    rdfs:label 'Owner Seller Profile Id' ;
    rdfs:comment 'Foreign key linking to seller.seller_profile. Business justification: REQUIRED: Seller SKU Ownership links each SKU to its owning seller for inventory, compliance and fulfillment decisions; standard in multi-seller marketplaces.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SellerProfile .

ind:ageRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Age Restriction Flag' ;
    rdfs:comment 'Indicates whether this SKU has age verification requirements (e.g., alcohol, tobacco, adult content).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bopisEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Bopis Eligible Flag' ;
    rdfs:comment 'Indicates whether this SKU is eligible for buy online, pick up in store fulfillment.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cpscCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Cpsc Compliant Flag' ;
    rdfs:comment 'Indicates whether this SKU meets CPSC product safety standards and testing requirements.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cpscTrackingLabel rdf:type rdf:Property ;
    rdfs:label 'Cpsc Tracking Label' ;
    rdfs:comment 'CPSC-required tracking label containing manufacturer, production date, batch, and cohort information for children\'s products.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dtcEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Dtc Eligible Flag' ;
    rdfs:comment 'Indicates whether this SKU is eligible for direct-to-consumer shipping from distribution centers.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fbaEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Fba Eligible Flag' ;
    rdfs:comment 'Indicates whether this SKU is eligible for FBA-style fulfillment services (stored in marketplace fulfillment centers).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Lot Controlled Flag' ;
    rdfs:comment 'Indicates whether this SKU is tracked by lot or batch number for quality control and traceability.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packagingType rdf:type rdf:Property ;
    rdfs:label 'Packaging Type' ;
    rdfs:comment 'Type of packaging required for this SKU (e.g., standard, fragile, oversized, gift wrap, bulk, refrigerated).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perishableFlag rdf:type rdf:Property ;
    rdfs:label 'Perishable Flag' ;
    rdfs:comment 'Indicates whether this SKU is perishable and requires temperature-controlled storage and expedited fulfillment.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serializedFlag rdf:type rdf:Property ;
    rdfs:label 'Serialized Flag' ;
    rdfs:comment 'Indicates whether each unit of this SKU is tracked by unique serial number for warranty, recall, or anti-counterfeiting purposes.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Number of days this SKU remains sellable from receipt date. Null for non-perishable items.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skuCode rdf:type rdf:Property ;
    rdfs:label 'Sku Code' ;
    rdfs:comment 'Unique alphanumeric code identifying this specific sellable variant. The atomic unit tracked by inventory and order systems.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuStatus rdf:type rdf:Property ;
    rdfs:label 'Sku Status' ;
    rdfs:comment 'Current lifecycle status of the SKU (active, inactive, discontinued, pending approval, blocked, seasonal).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantColor rdf:type rdf:Property ;
    rdfs:label 'Variant Color' ;
    rdfs:comment 'Color dimension of the variant (e.g., Blue, Red, Black, Navy).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantMaterial rdf:type rdf:Property ;
    rdfs:label 'Variant Material' ;
    rdfs:comment 'Material composition of the variant (e.g., Cotton, Polyester, Leather, Stainless Steel).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantName rdf:type rdf:Property ;
    rdfs:label 'Variant Name' ;
    rdfs:comment 'Human-readable name describing this specific variant (e.g., \'Blue Cotton T-Shirt - Size M\').' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantSize rdf:type rdf:Property ;
    rdfs:label 'Variant Size' ;
    rdfs:comment 'Size dimension of the variant (e.g., S, M, L, XL, 32x34, 10.5).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantStyle rdf:type rdf:Property ;
    rdfs:label 'Variant Style' ;
    rdfs:comment 'Style or design dimension of the variant (e.g., Crew Neck, V-Neck, Slim Fit, Classic).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autocompleteSuggestionId rdf:type rdf:Property ;
    rdfs:label 'Autocomplete Suggestion Id' ;
    rdfs:comment 'Unique identifier for the autocomplete suggestion entry.' ;
    rdfs:domain ind:AutocompleteSuggestion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indexId rdf:type rdf:Property ;
    rdfs:label 'Index Id' ;
    rdfs:comment 'Foreign key linking to search.index. Business justification: Autocomplete suggestions are generated per index; the FK ties suggestions to their index.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Index .

ind:autocompleteSuggestionStatus rdf:type rdf:Property ;
    rdfs:label 'Autocomplete Suggestion Status' ;
    rdfs:comment 'Indicates whether the suggestion is currently active and served to users.' ;
    rdfs:domain ind:AutocompleteSuggestion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayRank rdf:type rdf:Property ;
    rdfs:label 'Display Rank' ;
    rdfs:comment 'Numeric rank determining the order of suggestion display; lower numbers appear higher.' ;
    rdfs:domain ind:AutocompleteSuggestion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:editorialSource rdf:type rdf:Property ;
    rdfs:label 'Editorial Source' ;
    rdfs:comment 'Identifier of the editorial source or team responsible for the suggestion.' ;
    rdfs:domain ind:AutocompleteSuggestion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressionCount rdf:type rdf:Property ;
    rdfs:label 'Impression Count' ;
    rdfs:comment 'Number of times the suggestion has been shown to users.' ;
    rdfs:domain ind:AutocompleteSuggestion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isEditorial rdf:type rdf:Property ;
    rdfs:label 'Is Editorial' ;
    rdfs:comment 'Indicates if the suggestion was manually curated by editors.' ;
    rdfs:domain ind:AutocompleteSuggestion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPersonalized rdf:type rdf:Property ;
    rdfs:label 'Is Personalized' ;
    rdfs:comment 'Indicates whether the suggestion is personalized for the user.' ;
    rdfs:domain ind:Search ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:personalizationSource rdf:type rdf:Property ;
    rdfs:label 'Personalization Source' ;
    rdfs:comment 'Source of personalization data (e.g., user profile, behavior model).' ;
    rdfs:domain ind:AutocompleteSuggestion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:popularityScore rdf:type rdf:Property ;
    rdfs:label 'Popularity Score' ;
    rdfs:comment 'Score representing the popularity of the suggestion based on query frequency.' ;
    rdfs:domain ind:AutocompleteSuggestion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:suggestionText rdf:type rdf:Property ;
    rdfs:label 'Suggestion Text' ;
    rdfs:comment 'The text displayed as an autocomplete suggestion.' ;
    rdfs:domain ind:AutocompleteSuggestion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suggestionType rdf:type rdf:Property ;
    rdfs:label 'Suggestion Type' ;
    rdfs:comment 'Classifies the suggestion as a query completion, popular search, trending term, category, or brand.' ;
    rdfs:domain ind:AutocompleteSuggestion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerPrefix rdf:type rdf:Property ;
    rdfs:label 'Trigger Prefix' ;
    rdfs:comment 'The prefix string that triggers this suggestion when a user types it.' ;
    rdfs:domain ind:AutocompleteSuggestion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:behavioralSignalId rdf:type rdf:Property ;
    rdfs:label 'Behavioral Signal Id' ;
    rdfs:comment 'Unique identifier for the aggregated behavioral signal record.' ;
    rdfs:domain ind:BehavioralSignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:behavioralSignalStatus rdf:type rdf:Property ;
    rdfs:label 'Behavioral Signal Status' ;
    rdfs:comment 'Current lifecycle status of the signal record.' ;
    rdfs:domain ind:BehavioralSignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBot rdf:type rdf:Property ;
    rdfs:label 'Is Bot' ;
    rdfs:comment 'Indicates whether the interaction was generated by an automated bot.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationCountry rdf:type rdf:Property ;
    rdfs:label 'Location Country' ;
    rdfs:comment 'Three-letter ISO country code representing the user\'s location.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationFlag rdf:type rdf:Property ;
    rdfs:label 'Personalization Flag' ;
    rdfs:comment 'True if the signal was generated in a personalized search context.' ;
    rdfs:domain ind:Search ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recencyWeightedValue rdf:type rdf:Property ;
    rdfs:label 'Recency Weighted Value' ;
    rdfs:comment 'Signal value adjusted for recency, giving higher weight to more recent interactions.' ;
    rdfs:domain ind:BehavioralSignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:signalCount rdf:type rdf:Property ;
    rdfs:label 'Signal Count' ;
    rdfs:comment 'Number of raw events of the given signal type observed within the aggregation window.' ;
    rdfs:domain ind:BehavioralSignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signalType rdf:type rdf:Property ;
    rdfs:label 'Signal Type' ;
    rdfs:comment 'Type of user interaction captured (e.g., view, add-to-cart, purchase, wishlist, dwell time, scroll depth).' ;
    rdfs:domain ind:BehavioralSignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalWeight rdf:type rdf:Property ;
    rdfs:label 'Signal Weight' ;
    rdfs:comment 'Numeric weight applied to the signal for ranking algorithms.' ;
    rdfs:domain ind:BehavioralSignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:windowEnd rdf:type rdf:Property ;
    rdfs:label 'Window End' ;
    rdfs:comment 'End of the rolling time window over which signals were aggregated.' ;
    rdfs:domain ind:BehavioralSignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:windowStart rdf:type rdf:Property ;
    rdfs:label 'Window Start' ;
    rdfs:comment 'Start of the rolling time window over which signals were aggregated.' ;
    rdfs:domain ind:BehavioralSignal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clickLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Click Latency Ms' ;
    rdfs:comment 'Elapsed time in milliseconds between result display and user click.' ;
    rdfs:domain ind:ClickEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clickRankScore rdf:type rdf:Property ;
    rdfs:label 'Click Rank Score' ;
    rdfs:comment 'Score assigned by the ranking algorithm to the clicked item at click time.' ;
    rdfs:domain ind:ClickEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clickSource rdf:type rdf:Property ;
    rdfs:label 'Click Source' ;
    rdfs:comment 'Originating UI element or channel that generated the click.' ;
    rdfs:domain ind:ClickEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickType rdf:type rdf:Property ;
    rdfs:label 'Click Type' ;
    rdfs:comment 'Classification of the click source (e.g., organic search, sponsored ad, recommendation widget).' ;
    rdfs:domain ind:ClickEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentVariant rdf:type rdf:Property ;
    rdfs:label 'Experiment Variant' ;
    rdfs:comment 'Variant of the experiment shown to the user.' ;
    rdfs:domain ind:Search ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConversion rdf:type rdf:Property ;
    rdfs:label 'Is Conversion' ;
    rdfs:comment 'True if the click later resulted in a purchase or other conversion event.' ;
    rdfs:domain ind:ClickEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pageSection rdf:type rdf:Property ;
    rdfs:label 'Page Section' ;
    rdfs:comment 'Logical section of the page where the result was displayed.' ;
    rdfs:domain ind:ClickEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationWidgetCode rdf:type rdf:Property ;
    rdfs:label 'Recommendation Widget Code' ;
    rdfs:comment 'Identifier of the recommendation widget that displayed the clicked item.' ;
    rdfs:domain ind:ClickEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultPosition rdf:type rdf:Property ;
    rdfs:label 'Result Position' ;
    rdfs:comment 'Zero-based position of the clicked item in the result list.' ;
    rdfs:domain ind:ClickEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:searchQuery rdf:type rdf:Property ;
    rdfs:label 'Search Query' ;
    rdfs:comment 'The raw text entered by the user for the search.' ;
    rdfs:domain ind:Search ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlDefinition rdf:type rdf:Property ;
    rdfs:label 'Control Definition' ;
    rdfs:comment 'Configuration details of the control group (baseline) for the experiment.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentScope rdf:type rdf:Property ;
    rdfs:label 'Experiment Scope' ;
    rdfs:comment 'Scope of the experiment, such as global, specific product category, brand, or segment.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentStatus rdf:type rdf:Property ;
    rdfs:label 'Experiment Status' ;
    rdfs:comment 'Current lifecycle state of the experiment.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRandomized rdf:type rdf:Property ;
    rdfs:label 'Is Randomized' ;
    rdfs:comment 'Indicates whether traffic allocation to arms is performed randomly.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:successMetricTarget rdf:type rdf:Property ;
    rdfs:label 'Success Metric Target' ;
    rdfs:comment 'Target value for the primary success metric that defines experiment success.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trafficAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Traffic Allocation Pct' ;
    rdfs:comment 'Percentage of total traffic directed to the treatment arm(s).' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentDefinition rdf:type rdf:Property ;
    rdfs:label 'Treatment Definition' ;
    rdfs:comment 'Configuration details of the treatment group(s) for the experiment.' ;
    rdfs:domain ind:Experiment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Experiment Assignment Id' ;
    rdfs:comment 'Unique identifier for the experiment assignment record.' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:arm rdf:type rdf:Property ;
    rdfs:label 'Arm' ;
    rdfs:comment 'Arm of the experiment assigned to the session (e.g., control or treatment).' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current status of the assignment process.' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentOwner rdf:type rdf:Property ;
    rdfs:label 'Experiment Owner' ;
    rdfs:comment 'Team or individual responsible for the experiment.' ;
    rdfs:domain ind:ExperimentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facetConfigId rdf:type rdf:Property ;
    rdfs:label 'Facet Config Id' ;
    rdfs:comment 'Unique identifier for the facet configuration record.' ;
    rdfs:domain ind:Search ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FacetConfig .

ind:applicableCategory rdf:type rdf:Property ;
    rdfs:label 'Applicable Category' ;
    rdfs:comment 'Product category (e.g., electronics, apparel) where the facet is active.' ;
    rdfs:domain ind:FacetConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableIndex rdf:type rdf:Property ;
    rdfs:label 'Applicable Index' ;
    rdfs:comment 'Name of the search index or collection to which the facet applies.' ;
    rdfs:domain ind:FacetConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Audit Created By' ;
    rdfs:comment 'User identifier recorded for audit trail of creation.' ;
    rdfs:domain ind:FacetConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayStyle rdf:type rdf:Property ;
    rdfs:label 'Display Style' ;
    rdfs:comment 'UI presentation style for the facet.' ;
    rdfs:domain ind:FacetConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facetConfigDescription rdf:type rdf:Property ;
    rdfs:label 'Facet Config Description' ;
    rdfs:comment 'Free-form description of the facet purpose and usage.' ;
    rdfs:domain ind:FacetConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facetConfigName rdf:type rdf:Property ;
    rdfs:label 'Facet Config Name' ;
    rdfs:comment 'Human-readable name shown to users for the facet.' ;
    rdfs:domain ind:FacetConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facetConfigStatus rdf:type rdf:Property ;
    rdfs:label 'Facet Config Status' ;
    rdfs:comment 'Current lifecycle status of the facet configuration.' ;
    rdfs:domain ind:FacetConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facetKey rdf:type rdf:Property ;
    rdfs:label 'Facet Key' ;
    rdfs:comment 'Technical key used in the search index to reference this facet.' ;
    rdfs:domain ind:FacetConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facetType rdf:type rdf:Property ;
    rdfs:label 'Facet Type' ;
    rdfs:comment 'Category of UI control used for the facet.' ;
    rdfs:domain ind:FacetConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMultiSelect rdf:type rdf:Property ;
    rdfs:label 'Is Multi Select' ;
    rdfs:comment 'True if users can select multiple values for this facet.' ;
    rdfs:domain ind:FacetConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxValue rdf:type rdf:Property ;
    rdfs:label 'Max Value' ;
    rdfs:comment 'Upper bound for numeric range facets.' ;
    rdfs:domain ind:FacetConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxValuesShown rdf:type rdf:Property ;
    rdfs:label 'Max Values Shown' ;
    rdfs:comment 'Maximum number of distinct facet values displayed to the user.' ;
    rdfs:domain ind:FacetConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minDocFrequency rdf:type rdf:Property ;
    rdfs:label 'Min Doc Frequency' ;
    rdfs:comment 'Minimum number of documents required for a facet value to be displayed.' ;
    rdfs:domain ind:FacetConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minValue rdf:type rdf:Property ;
    rdfs:label 'Min Value' ;
    rdfs:comment 'Lower bound for numeric range facets.' ;
    rdfs:domain ind:FacetConfig ;
