    rdfs:range ind:Tag .

ind:audience rdf:type rdf:Property ;
    rdfs:label 'Audience' ;
    rdfs:comment 'Intended audience for content using this tag.' ;
    rdfs:domain ind:Tag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorHex rdf:type rdf:Property ;
