    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleEnd rdf:type rdf:Property ;
    rdfs:label 'Schedule End' ;
    rdfs:comment 'Date when the slot is retired or no longer eligible for content assignment (nullable).' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleStart rdf:type rdf:Property ;
    rdfs:label 'Schedule Start' ;
    rdfs:comment 'Date when the slot becomes active for content assignment.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seoMetadata rdf:type rdf:Property ;
    rdfs:label 'Seo Metadata' ;
    rdfs:comment 'SEO-related metadata (e.g., meta title, description) associated with the slot.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotCode rdf:type rdf:Property ;
    rdfs:label 'Slot Code' ;
    rdfs:comment 'Business identifier or code for the slot, unique within a template.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotDescription rdf:type rdf:Property ;
    rdfs:label 'Slot Description' ;
    rdfs:comment 'Free-form description of the slot purpose and editorial notes.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotName rdf:type rdf:Property ;
    rdfs:label 'Slot Name' ;
    rdfs:comment 'Human-readable name of the slot used by content editors.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotStatus rdf:type rdf:Property ;
    rdfs:label 'Slot Status' ;
    rdfs:comment 'Current lifecycle state of the slot.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotType rdf:type rdf:Property ;
    rdfs:label 'Slot Type' ;
    rdfs:comment 'Category of the slot defining its layout and behavior.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Slot Assignment Id' ;
    rdfs:comment 'Unique identifier for the slot assignment record.' ;
    rdfs:domain ind:SlotAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:personalizationRuleId rdf:type rdf:Property ;
    rdfs:label 'Personalization Rule Id' ;
    rdfs:comment 'Identifier of the rule or model that determines when this assignment is shown to a specific audience.' ;
    rdfs:domain ind:Content ;
