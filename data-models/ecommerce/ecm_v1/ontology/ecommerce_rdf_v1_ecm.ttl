    rdfs:comment 'Foreign key linking to marketplace.listing_category. Business justification: Enables Marketplace Category Performance Report to map analytics data to marketplace listing categories for accurate category-level GMV analysis.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
