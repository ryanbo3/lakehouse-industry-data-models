ind:pageLocation rdf:type rdf:Property ;
    rdfs:label 'Page Location' ;
    rdfs:comment 'Logical page or section where the slot is rendered (e.g., homepage, product_detail).' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationEligible rdf:type rdf:Property ;
    rdfs:label 'Personalization Eligible' ;
    rdfs:comment 'Indicates whether the slot can be targeted by personalization rules.' ;
