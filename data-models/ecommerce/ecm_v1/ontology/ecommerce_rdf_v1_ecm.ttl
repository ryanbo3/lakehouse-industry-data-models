ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date-time when the dashboard received approval.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dashboardDefinitionCode rdf:type rdf:Property ;
    rdfs:label 'Dashboard Definition Code' ;
    rdfs:comment 'Business identifier or short code used to reference the dashboard in governance systems.' ;
    rdfs:domain ind:DashboardDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dashboardDefinitionDescription rdf:type rdf:Property ;
    rdfs:label 'Dashboard Definition Description' ;
    rdfs:comment 'Detailed textual description of the dashboard\'s purpose and content.' ;
    rdfs:domain ind:DashboardDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dashboardDefinitionName rdf:type rdf:Property ;
    rdfs:label 'Dashboard Definition Name' ;
    rdfs:comment 'Human-readable name of the dashboard as displayed to users.' ;
    rdfs:domain ind:DashboardDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dashboardDefinitionStatus rdf:type rdf:Property ;
    rdfs:label 'Dashboard Definition Status' ;
    rdfs:comment 'Current lifecycle state of the dashboard.' ;
    rdfs:domain ind:DashboardDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dashboardDefinitionType rdf:type rdf:Property ;
    rdfs:label 'Dashboard Definition Type' ;
    rdfs:comment 'Classification of the dashboard by primary audience or purpose.' ;
    rdfs:domain ind:DashboardDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataDomains rdf:type rdf:Property ;
    rdfs:label 'Data Domains' ;
    rdfs:comment 'Comma-separated list of data domains (customer, product, order, etc.) used by the dashboard.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deprecationDate rdf:type rdf:Property ;
    rdfs:label 'Deprecation Date' ;
    rdfs:comment 'Planned date for retiring the dashboard from active use.' ;
    rdfs:domain ind:DashboardDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isTemplate rdf:type rdf:Property ;
    rdfs:label 'Is Template' ;
    rdfs:comment 'Indicates whether the dashboard serves as a reusable template for other dashboards.' ;
    rdfs:domain ind:DashboardDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User or service that performed the most recent update to the dashboard definition.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRefreshedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Refreshed Timestamp' ;
    rdfs:comment 'Date-time when the dashboard data was last refreshed.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:layoutConfiguration rdf:type rdf:Property ;
    rdfs:label 'Layout Configuration' ;
    rdfs:comment 'JSON string describing the visual layout, tile arrangement, and sizing of the dashboard.' ;
    rdfs:domain ind:DashboardDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricCount rdf:type rdf:Property ;
    rdfs:label 'Metric Count' ;
    rdfs:comment 'Number of distinct metrics displayed on the dashboard.' ;
    rdfs:domain ind:DashboardDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publicationStatus rdf:type rdf:Property ;
    rdfs:label 'Publication Status' ;
    rdfs:comment 'Indicates whether the dashboard is publicly available, hidden, or scheduled for release.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency' ;
    rdfs:comment 'How often the dashboard data is refreshed (e.g., real-time, hourly, daily).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPolicy rdf:type rdf:Property ;
    rdfs:label 'Retention Policy' ;
    rdfs:comment 'Policy governing how long the dashboard definition is retained after deprecation.' ;
    rdfs:domain ind:DashboardDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Primary consumer group for the dashboard.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visualizationCount rdf:type rdf:Property ;
