ind:valueStep rdf:type rdf:Property ;
    rdfs:label 'Value Step' ;
    rdfs:comment 'Increment step for range sliders.' ;
    rdfs:domain ind:FacetConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filterUsageId rdf:type rdf:Property ;
