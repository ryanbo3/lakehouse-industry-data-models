    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignPerformanceStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Performance Status' ;
    rdfs:comment 'Current lifecycle status of the campaign execution.' ;
