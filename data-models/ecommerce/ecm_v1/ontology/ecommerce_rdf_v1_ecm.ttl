ind:receiptType rdf:type rdf:Property ;
    rdfs:label 'Receipt Type' ;
    rdfs:comment 'Classification of the receipt (e.g., purchase order, transfer, return).' ;
    rdfs:domain ind:ReceivingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedSkuCount rdf:type rdf:Property ;
    rdfs:label 'Received Sku Count' ;
    rdfs:comment 'Number of distinct SKU types received in this transaction.' ;
    rdfs:domain ind:ReceivingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivingRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Receiving Record Status' ;
    rdfs:comment 'Current lifecycle status of the receiving record.' ;
    rdfs:domain ind:ReceivingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalQuantityReceived rdf:type rdf:Property ;
