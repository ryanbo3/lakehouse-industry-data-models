    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowedAssetTypes rdf:type rdf:Property ;
    rdfs:label 'Allowed Asset Types' ;
    rdfs:comment 'Comma-separated list of asset types permitted in this slot.' ;
