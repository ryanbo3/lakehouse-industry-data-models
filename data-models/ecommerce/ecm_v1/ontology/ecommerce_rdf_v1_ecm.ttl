ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'Identifier of the user or system that created the model record.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionResultId rdf:type rdf:Property ;
    rdfs:label 'Attribution Result Id' ;
    rdfs:comment 'System-generated unique identifier for each attribution result record.' ;
    rdfs:domain ind:AttributionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: Attribution results must be tied to the originating marketing campaign for revenue attribution reporting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
