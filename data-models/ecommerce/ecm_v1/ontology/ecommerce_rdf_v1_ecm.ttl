ind:deploymentStatus rdf:type rdf:Property ;
    rdfs:label 'Deployment Status' ;
    rdfs:comment 'Current deployment state of the model in production.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefault rdf:type rdf:Property ;
    rdfs:label 'Is Default' ;
    rdfs:comment 'Indicates whether this model is the default attribution model for reporting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastEvaluatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Evaluated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent performance evaluation of the model.' ;
