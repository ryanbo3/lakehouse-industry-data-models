ind:maxContentItems rdf:type rdf:Property ;
    rdfs:label 'Max Content Items' ;
    rdfs:comment 'Maximum number of content assets that can be assigned to the slot at one time.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
