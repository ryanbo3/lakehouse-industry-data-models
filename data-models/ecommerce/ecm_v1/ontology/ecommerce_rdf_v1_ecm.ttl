ind:eventCode rdf:type rdf:Property ;
    rdfs:label 'Event Code' ;
    rdfs:comment 'Human-readable code or reference number for the suspension event, used in external communications and audits.' ;
    rdfs:domain ind:Suspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReinstatementDate rdf:type rdf:Property ;
    rdfs:label 'Expected Reinstatement Date' ;
    rdfs:comment 'Planned date for restoring the seller\'s account when the suspension is temporary.' ;
    rdfs:domain ind:Seller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isProbation rdf:type rdf:Property ;
    rdfs:label 'Is Probation' ;
    rdfs:comment 'Indicates if the event places the seller under a probationary period rather than a full suspension.' ;
    rdfs:domain ind:Suspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalOrderReference rdf:type rdf:Property ;
    rdfs:label 'Legal Order Reference' ;
    rdfs:comment 'Reference number of any court or regulatory order that triggered the suspension.' ;
    rdfs:domain ind:Suspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyViolationCode rdf:type rdf:Property ;
    rdfs:label 'Policy Violation Code' ;
    rdfs:comment 'Standardized code representing the specific policy that was violated.' ;
    rdfs:domain ind:Suspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinstatementDate rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Date' ;
    rdfs:comment 'Date on which the seller\'s account was actually reinstated.' ;
    rdfs:domain ind:Suspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspendingAuthority rdf:type rdf:Property ;
    rdfs:label 'Suspending Authority' ;
    rdfs:comment 'Team or system that applied the suspension.' ;
    rdfs:domain ind:Suspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionCategory rdf:type rdf:Property ;
    rdfs:label 'Suspension Category' ;
    rdfs:comment 'High-level classification such as \'policy\', \'performance\', \'fraud\', or \'legal\'.' ;
    rdfs:domain ind:Suspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionStatus rdf:type rdf:Property ;
    rdfs:label 'Suspension Status' ;
    rdfs:comment 'Current state of the suspension event in its lifecycle.' ;
    rdfs:domain ind:Suspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerReason rdf:type rdf:Property ;
    rdfs:label 'Trigger Reason' ;
    rdfs:comment 'Root cause that initiated the suspension action, such as policy violation or fraud investigation.' ;
    rdfs:domain ind:Suspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingId rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Id' ;
    rdfs:comment 'Unique system-generated identifier for the tax reporting record.' ;
    rdfs:domain ind:TaxReporting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backupWithholdingFlag rdf:type rdf:Property ;
    rdfs:label 'Backup Withholding Flag' ;
    rdfs:comment 'True if backup withholding was applied to the seller\'s payments.' ;
    rdfs:domain ind:TaxReporting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filingDeadline rdf:type rdf:Property ;
    rdfs:label 'Filing Deadline' ;
    rdfs:comment 'Date by which the filing must be submitted to the tax authority.' ;
    rdfs:domain ind:TaxReporting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmvAttributed rdf:type rdf:Property ;
    rdfs:label 'Gmv Attributed' ;
    rdfs:comment 'Total GMV amount attributed to the seller for the reporting period.' ;
    rdfs:domain ind:TaxReporting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Payment Amount' ;
    rdfs:comment 'Total gross payment amount reported for the filing period.' ;
    rdfs:domain ind:TaxReporting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'Net amount after applying any backup withholding.' ;
    rdfs:domain ind:TaxReporting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionReference rdf:type rdf:Property ;
    rdfs:label 'Submission Reference' ;
    rdfs:comment 'Reference identifier returned by the tax authority upon successful submission.' ;
    rdfs:domain ind:TaxReporting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxPeriod rdf:type rdf:Property ;
    rdfs:label 'Tax Period' ;
    rdfs:comment 'Quarter of the tax year covered by the filing.' ;
    rdfs:domain ind:TaxReporting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Status' ;
    rdfs:comment 'Current lifecycle status of the tax filing.' ;
    rdfs:domain ind:TaxReporting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxYear rdf:type rdf:Property ;
    rdfs:label 'Tax Year' ;
    rdfs:comment 'Calendar year for which the tax filing is applicable.' ;
    rdfs:domain ind:TaxReporting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thresholdMet rdf:type rdf:Property ;
    rdfs:label 'Threshold Met' ;
    rdfs:comment 'Indicates whether the filing met the regulatory transaction count or amount threshold.' ;
    rdfs:domain ind:TaxReporting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tinStatus rdf:type rdf:Property ;
    rdfs:label 'Tin Status' ;
    rdfs:comment 'Status of the seller\'s Tax Identification Number verification.' ;
    rdfs:domain ind:TaxReporting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Amount' ;
    rdfs:comment 'Amount withheld due to missing or unverified TIN.' ;
    rdfs:domain ind:TaxReporting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierId rdf:type rdf:Property ;
    rdfs:label 'Tier Id' ;
    rdfs:comment 'Primary key for tier' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dedicatedAccountManagerAgentId rdf:type rdf:Property ;
    rdfs:label 'Dedicated Account Manager Agent Id' ;
    rdfs:comment 'Foreign key linking to service.agent. Business justification: Required for Tier Management: each seller tier assigns a dedicated account manager (service.agent) to support sellers; reports on manager performance per tier depend on this link.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:apiRatePriority rdf:type rdf:Property ;
    rdfs:label 'Api Rate Priority' ;
    rdfs:comment 'Flag indicating priority access to API rate limits.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:badgeDisplayEligible rdf:type rdf:Property ;
    rdfs:label 'Badge Display Eligible' ;
    rdfs:comment 'Indicates if the tier badge can be displayed on the seller\'s storefront.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionRateDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Discount Pct' ;
    rdfs:comment 'Percentage discount applied to the standard commission rate for sellers in this tier.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demotionGracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Demotion Grace Period Days' ;
    rdfs:comment 'Number of days after a downgrade trigger before the tier is actually changed.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eligibilityCriteriaNotes rdf:type rdf:Property ;
    rdfs:label 'Eligibility Criteria Notes' ;
    rdfs:comment 'Free-text notes describing any additional eligibility criteria for the tier.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enhancedAnalyticsAccess rdf:type rdf:Property ;
    rdfs:label 'Enhanced Analytics Access' ;
    rdfs:comment 'Flag indicating access to advanced analytics dashboards.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultTier rdf:type rdf:Property ;
    rdfs:label 'Is Default Tier' ;
    rdfs:comment 'Indicates whether this tier is the default assignment for new sellers.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumGmvUsd rdf:type rdf:Property ;
    rdfs:label 'Minimum Gmv Usd' ;
    rdfs:comment 'Minimum Gross Merchandise Value in USD a seller must achieve to qualify for this tier.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumScorecardRating rdf:type rdf:Property ;
    rdfs:label 'Minimum Scorecard Rating' ;
    rdfs:comment 'Minimum average scorecard rating (0-5) required for tier eligibility.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTenureDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Tenure Days' ;
    rdfs:comment 'Minimum number of days the seller must have been active on the platform to qualify.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:premiumFeatureAccess rdf:type rdf:Property ;
    rdfs:label 'Premium Feature Access' ;
    rdfs:comment 'Indicates whether sellers in this tier have access to premium platform features.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewCadence rdf:type rdf:Property ;
    rdfs:label 'Review Cadence' ;
    rdfs:comment 'Frequency at which the seller\'s tier is reviewed.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCommitment rdf:type rdf:Property ;
    rdfs:label 'Sla Commitment' ;
    rdfs:comment 'Specific Service Level Agreement commitments associated with the tier.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierCode rdf:type rdf:Property ;
    rdfs:label 'Tier Code' ;
    rdfs:comment 'Unique short code identifying the seller tier (e.g., BRZ, SLV, GLD).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierDescription rdf:type rdf:Property ;
    rdfs:label 'Tier Description' ;
    rdfs:comment 'Detailed description of the tier, its purpose and benefits.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierName rdf:type rdf:Property ;
    rdfs:label 'Tier Name' ;
    rdfs:comment 'Human-readable name of the seller tier such as Bronze, Silver, Gold.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierRank rdf:type rdf:Property ;
    rdfs:label 'Tier Rank' ;
    rdfs:comment 'Ordinal rank of the tier; lower number indicates a higher tier.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierStatus rdf:type rdf:Property ;
    rdfs:label 'Tier Status' ;
    rdfs:comment 'Current lifecycle status of the tier.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierChangeId rdf:type rdf:Property ;
    rdfs:label 'Tier Change Id' ;
    rdfs:comment 'Primary key for tier_change' ;
    rdfs:domain ind:TierChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Created Timestamp' ;
    rdfs:comment 'Timestamp when this audit record was first created.' ;
    rdfs:domain ind:TierChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the audit record (if any).' ;
    rdfs:domain ind:TierChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:evaluationPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End' ;
    rdfs:comment 'End date of the performance evaluation period that triggered the tier change.' ;
    rdfs:domain ind:TierChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start' ;
    rdfs:comment 'Start date of the performance evaluation period that triggered the tier change.' ;
    rdfs:domain ind:TierChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmvAtTransition rdf:type rdf:Property ;
    rdfs:label 'Gmv At Transition' ;
    rdfs:comment 'Total GMV generated by the seller during the evaluation period leading to the tier change.' ;
    rdfs:domain ind:TierChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newTier rdf:type rdf:Property ;
    rdfs:label 'New Tier' ;
    rdfs:comment 'Seller tier after the transition.' ;
    rdfs:domain ind:TierChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideJustification rdf:type rdf:Property ;
    rdfs:label 'Override Justification' ;
    rdfs:comment 'Free-text explanation for any manual override or appeal outcome.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousTier rdf:type rdf:Property ;
    rdfs:label 'Previous Tier' ;
    rdfs:comment 'Seller tier before the transition.' ;
    rdfs:domain ind:TierChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardCompositeRating rdf:type rdf:Property ;
    rdfs:label 'Scorecard Composite Rating' ;
    rdfs:comment 'Aggregated performance score (0-100) used for tier evaluation.' ;
    rdfs:domain ind:TierChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitionType rdf:type rdf:Property ;
    rdfs:label 'Transition Type' ;
    rdfs:comment 'Nature of the tier change event.' ;
    rdfs:domain ind:TierChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerMechanism rdf:type rdf:Property ;
    rdfs:label 'Trigger Mechanism' ;
    rdfs:comment 'How the tier change was initiated.' ;
    rdfs:domain ind:TierChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationId rdf:type rdf:Property ;
    rdfs:label 'Verification Id' ;
    rdfs:comment 'Primary key for verification' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Document Expiry Timestamp' ;
    rdfs:comment 'Date and time when the document expires or becomes invalid.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:documentUploadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Document Upload Timestamp' ;
    rdfs:comment 'Date and time the document was uploaded to the system.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:documentUri rdf:type rdf:Property ;
    rdfs:label 'Document Uri' ;
    rdfs:comment 'S3 or blob storage reference where the document is stored.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Document Verification Status' ;
    rdfs:comment 'Result of the document verification process.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officerNotes rdf:type rdf:Property ;
    rdfs:label 'Officer Notes' ;
    rdfs:comment 'Free-form notes entered by the compliance officer reviewing the verification.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerGmvAtVerification rdf:type rdf:Property ;
    rdfs:label 'Seller Gmv At Verification' ;
    rdfs:comment 'Total GMV attributed to the seller at the time of verification.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationType rdf:type rdf:Property ;
    rdfs:label 'Verification Type' ;
    rdfs:comment 'Category of verification performed (e.g., identity, business, bank, tax).' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationId rdf:type rdf:Property ;
    rdfs:label 'Violation Id' ;
    rdfs:comment 'Primary key for violation' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appealEligibility rdf:type rdf:Property ;
    rdfs:label 'Appeal Eligibility' ;
    rdfs:comment 'Indicates whether the seller may appeal the enforcement action.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealOutcome rdf:type rdf:Property ;
    rdfs:label 'Appeal Outcome' ;
    rdfs:comment 'Result of the seller\'s appeal, if filed.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRegion rdf:type rdf:Property ;
    rdfs:label 'Compliance Region' ;
    rdfs:comment 'Geographic region (ISO 3166-1 alpha-3) governing the applicable regulations.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'How the violation was identified: automated rule, manual review, buyer report, or regulatory notice.' ;
    rdfs:domain ind:Seller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Reference' ;
    rdfs:comment 'Link (URL or internal ID) to supporting evidence such as screenshots, logs, or documents.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fineAmount rdf:type rdf:Property ;
    rdfs:label 'Fine Amount' ;
    rdfs:comment 'Monetary penalty assessed for the violation, if any.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current state of the investigation workflow.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinstatementConditions rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Conditions' ;
    rdfs:comment 'Specific requirements the seller must satisfy to have the account reinstated.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerGmvAtViolation rdf:type rdf:Property ;
    rdfs:label 'Seller Gmv At Violation' ;
    rdfs:comment 'Total GMV generated by the seller at the time the violation was recorded.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:suspensionEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Effective Date' ;
    rdfs:comment 'Date when the seller\'s account suspension becomes active.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:violationNumber rdf:type rdf:Property ;
    rdfs:label 'Violation Number' ;
    rdfs:comment 'Human-readable reference number for the violation, used in communications and reporting.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationType rdf:type rdf:Property ;
    rdfs:label 'Violation Type' ;
    rdfs:comment 'Category of policy breach (e.g., counterfeit, prohibited item, pricing manipulation, review fraud, IP infringement, data misuse).' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorAgentId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Agent Id' ;
    rdfs:comment 'FK to service.agent' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:averageHandleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Handle Time Minutes' ;
    rdfs:comment 'Rolling average time in minutes the agent takes to resolve a case from assignment to closure. Key performance indicator for agent efficiency.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Score' ;
    rdfs:comment 'Average customer satisfaction score for cases handled by this agent, typically on a 1-5 scale. Derived from post-interaction surveys.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCode rdf:type rdf:Property ;
    rdfs:label 'Employee Code' ;
    rdfs:comment 'External employee identifier from the HR system. Links the agent to their employee record in the Enterprise Resource Planning (ERP) system.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRate rdf:type rdf:Property ;
    rdfs:label 'Escalation Rate' ;
    rdfs:comment 'Percentage of cases handled by the agent that required escalation to a supervisor or specialist. Lower rates indicate higher agent competency.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstContactResolutionRate rdf:type rdf:Property ;
    rdfs:label 'First Contact Resolution Rate' ;
    rdfs:comment 'Percentage of cases resolved by the agent on first contact without escalation or follow-up. Key quality metric for agent performance.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date the agent was hired into the customer service organization. Used for tenure analysis and performance benchmarking.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:languageProficiencies rdf:type rdf:Property ;
    rdfs:label 'Language Proficiencies' ;
    rdfs:comment 'Comma-separated list of languages the agent can support with proficiency level (e.g., EN-native, ES-fluent, FR-conversational). Enables multilingual customer support routing.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxConcurrentCases rdf:type rdf:Property ;
    rdfs:label 'Max Concurrent Cases' ;
    rdfs:comment 'Maximum number of cases the agent can handle simultaneously. Used by the workload balancing engine to prevent agent overload.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netPromoterScore rdf:type rdf:Property ;
    rdfs:label 'Net Promoter Score' ;
    rdfs:comment 'Average Net Promoter Score (NPS) for interactions handled by this agent. Measures customer loyalty and likelihood to recommend based on agent service.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phoneExtension rdf:type rdf:Property ;
    rdfs:label 'Phone Extension' ;
    rdfs:comment 'Internal phone extension number for the agent within the contact center phone system.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAssuranceScore rdf:type rdf:Property ;
    rdfs:label 'Quality Assurance Score' ;
    rdfs:comment 'Average quality assurance audit score for the agent based on case review and compliance checks. Typically scored 0-100 by QA team.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftScheduleReference rdf:type rdf:Property ;
    rdfs:label 'Shift Schedule Reference' ;
    rdfs:comment 'Reference identifier to the agents current shift schedule or roster. Links to workforce management system for capacity planning.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillSetTags rdf:type rdf:Property ;
    rdfs:label 'Skill Set Tags' ;
    rdfs:comment 'Comma-separated list of agent competencies and specializations (e.g., returns, billing, technical, escalations, fraud, international). Used for intelligent case routing and workload balancing.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaComplianceRate rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Rate' ;
    rdfs:comment 'Percentage of cases where the agent met or exceeded the defined Service Level Agreement (SLA) response and resolution time targets.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportedChannels rdf:type rdf:Property ;
    rdfs:label 'Supported Channels' ;
    rdfs:comment 'Comma-separated list of customer service channels the agent is trained and authorized to handle (e.g., phone, email, chat, social media, SMS).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamAssignment rdf:type rdf:Property ;
    rdfs:label 'Team Assignment' ;
    rdfs:comment 'Name or identifier of the service team to which the agent is assigned (e.g., Returns Team, Billing Support, Technical Support, Escalations).' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCasesHandled rdf:type rdf:Property ;
    rdfs:label 'Total Cases Handled' ;
    rdfs:comment 'Cumulative count of all cases assigned to and handled by the agent since hire date. Used for productivity and experience analysis.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'Date the agent completed initial onboarding and training program and was certified to handle customer cases independently.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caseInteractionId rdf:type rdf:Property ;
    rdfs:label 'Case Interaction Id' ;
    rdfs:comment 'Unique identifier for the case interaction record. Primary key.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCaseAgentId rdf:type rdf:Property ;
    rdfs:label 'Primary Case Agent Id' ;
    rdfs:comment 'Identifier of the customer service agent who handled this interaction. Links to employee or agent entity.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:attachmentReferences rdf:type rdf:Property ;
    rdfs:label 'Attachment References' ;
    rdfs:comment 'Comma-separated list of attachment identifiers or URIs pointing to files stored in external document management system.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentSummary rdf:type rdf:Property ;
    rdfs:label 'Content Summary' ;
    rdfs:comment 'Summarized content or transcript of the interaction, capturing key points discussed without full verbatim text.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Direction of the interaction: inbound (customer-initiated) or outbound (agent-initiated).' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Reason or justification for escalating the interaction, if escalation occurred.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalInteractionReference rdf:type rdf:Property ;
    rdfs:label 'External Interaction Reference' ;
    rdfs:comment 'Unique identifier for this interaction in the external source system, used for cross-system reconciliation and traceability.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackComment rdf:type rdf:Property ;
    rdfs:label 'Feedback Comment' ;
    rdfs:comment 'Free-text feedback or comment provided by the customer about this interaction.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullTranscriptReference rdf:type rdf:Property ;
    rdfs:label 'Full Transcript Reference' ;
    rdfs:comment 'Reference pointer or URI to the full transcript or recording stored in external system (e.g., CDN (Content Delivery Network), document management system).' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionNumber rdf:type rdf:Property ;
    rdfs:label 'Interaction Number' ;
    rdfs:comment 'Human-readable business identifier for the interaction, typically formatted as INT- followed by numeric sequence.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionSequence rdf:type rdf:Property ;
    rdfs:label 'Interaction Sequence' ;
    rdfs:comment 'Sequential ordering of this interaction within the parent case lifecycle, starting from 1.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interactionStatus rdf:type rdf:Property ;
    rdfs:label 'Interaction Status' ;
    rdfs:comment 'Current status of the interaction: completed, pending follow-up, escalated to higher tier, abandoned by customer, or transferred to another agent.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Interaction Timestamp' ;
    rdfs:comment 'The exact date and time when the interaction event occurred in the format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Resolution Provided Flag' ;
    rdfs:comment 'Boolean flag indicating whether a resolution or answer was provided during this interaction (True/False).' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Response Time Seconds' ;
    rdfs:comment 'Time in seconds taken by the agent to provide the first substantive response after interaction initiation.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaBreachReason rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Reason' ;
    rdfs:comment 'Reason or explanation for SLA (Service Level Agreement) breach, if the interaction did not meet SLA targets.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether this interaction met the defined SLA (Service Level Agreement) targets for response and resolution time (True/False).' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferFlag rdf:type rdf:Property ;
    rdfs:label 'Transfer Flag' ;
    rdfs:comment 'Boolean flag indicating whether the interaction was transferred to another agent or department (True/False).' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waitTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Wait Time Seconds' ;
    rdfs:comment 'Time in seconds the customer waited before the interaction was answered or acknowledged by an agent.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:caseQueueId rdf:type rdf:Property ;
    rdfs:label 'Case Queue Id' ;
    rdfs:comment 'Unique identifier for the case queue configuration.' ;
    rdfs:domain ind:CaseQueue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedTeamId rdf:type rdf:Property ;
    rdfs:label 'Assigned Team Id' ;
    rdfs:comment 'Identifier of the support team primarily responsible for this queue.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:escalationPolicyId rdf:type rdf:Property ;
    rdfs:label 'Escalation Policy Id' ;
    rdfs:comment 'Reference to the escalation policy applied when SLA thresholds are breached.' ;
    rdfs:domain ind:CaseQueue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:averageWaitTimeTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Wait Time Target Minutes' ;
    rdfs:comment 'Desired average wait time for cases in this queue, expressed in minutes.' ;
    rdfs:domain ind:CaseQueue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityLimit rdf:type rdf:Property ;
    rdfs:label 'Capacity Limit' ;
    rdfs:comment 'Maximum number of cases that can be simultaneously assigned to the queue.' ;
    rdfs:domain ind:CaseQueue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:caseQueueDescription rdf:type rdf:Property ;
    rdfs:label 'Case Queue Description' ;
    rdfs:comment 'Detailed description of the queue purpose and behavior.' ;
    rdfs:domain ind:CaseQueue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseQueueName rdf:type rdf:Property ;
    rdfs:label 'Case Queue Name' ;
    rdfs:comment 'Human-readable name of the queue.' ;
    rdfs:domain ind:CaseQueue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseQueueStatus rdf:type rdf:Property ;
    rdfs:label 'Case Queue Status' ;
    rdfs:comment 'Current lifecycle status of the queue.' ;
    rdfs:domain ind:CaseQueue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPriorityQueue rdf:type rdf:Property ;
    rdfs:label 'Is Priority Queue' ;
    rdfs:comment 'Indicates whether the queue is designated for high-priority cases.' ;
    rdfs:domain ind:CaseQueue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxWaitTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Max Wait Time Minutes' ;
    rdfs:comment 'Hard ceiling for how long a case may wait in the queue before escalation.' ;
    rdfs:domain ind:CaseQueue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overflowRoutingRule rdf:type rdf:Property ;
    rdfs:label 'Overflow Routing Rule' ;
    rdfs:comment 'Rule applied when the queue exceeds its capacity (e.g., redirect to overflow queue).' ;
    rdfs:domain ind:CaseQueue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:queueDepthLimit rdf:type rdf:Property ;
    rdfs:label 'Queue Depth Limit' ;
    rdfs:comment 'Maximum number of cases that can be queued awaiting assignment.' ;
    rdfs:domain ind:CaseQueue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:queueType rdf:type rdf:Property ;
    rdfs:label 'Queue Type' ;
    rdfs:comment 'Classification of the queue routing strategy.' ;
    rdfs:domain ind:CaseQueue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Routing Algorithm' ;
    rdfs:comment 'Algorithm used to distribute cases to agents.' ;
    rdfs:domain ind:CaseQueue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetAbandonRatePercent rdf:type rdf:Property ;
    rdfs:label 'Sla Target Abandon Rate Percent' ;
    rdfs:comment 'Maximum acceptable percentage of cases abandoned before service.' ;
    rdfs:domain ind:CaseQueue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTargetAverageWaitMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Average Wait Minutes' ;
    rdfs:comment 'Service-level agreement target for average wait time, in minutes.' ;
    rdfs:domain ind:CaseQueue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:caseStatusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Case Status History Id' ;
    rdfs:comment 'Unique identifier for each status transition record in the support case lifecycle. Primary key for the case status history table.' ;
    rdfs:domain ind:CaseStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportCaseId rdf:type rdf:Property ;
    rdfs:label 'Support Case Id' ;
    rdfs:comment 'Reference to the parent support case that experienced this status transition. Links this history record to the originating case entity.' ;
    rdfs:domain ind:CaseStatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceSupportCase .

ind:triggeredByAgentId rdf:type rdf:Property ;
    rdfs:label 'Triggered By Agent Id' ;
    rdfs:comment 'Reference to the customer service agent who initiated this status transition. Null if the transition was system-triggered or automated.' ;
    rdfs:domain ind:CaseStatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:automationRuleCode rdf:type rdf:Property ;
    rdfs:label 'Automation Rule Code' ;
    rdfs:comment 'Reference to the workflow automation rule that triggered this status transition if it was system-initiated. Null for manual transitions.' ;
    rdfs:domain ind:CaseStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessHoursFlag rdf:type rdf:Property ;
    rdfs:label 'Business Hours Flag' ;
    rdfs:comment 'Indicates whether this status transition occurred during defined business hours. True if during business hours, False if after hours or weekend. Used for SLA calculation adjustments.' ;
    rdfs:domain ind:CaseStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:caseCategory rdf:type rdf:Property ;
    rdfs:label 'Case Category' ;
    rdfs:comment 'High-level categorization of the support case type at the time of this transition. Denormalized for workflow analysis and reporting. [ENUM-REF-CANDIDATE: order_issue|product_defect|shipping_delay|payment_issue|account_inquiry|technical_support|return_refund|complaint|feedback|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commentAddedFlag rdf:type rdf:Property ;
    rdfs:label 'Comment Added Flag' ;
    rdfs:comment 'Indicates whether an agent or system comment was added to the case at the time of this status transition. True if comment was added, False otherwise.' ;
    rdfs:domain ind:CaseStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'The escalation tier at the time of this transition. 0 for no escalation, 1 for first-level escalation, 2 for second-level, etc. Tracks case severity progression.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The status the case transitioned to at this event. Captures the to-state in the case lifecycle state machine. [ENUM-REF-CANDIDATE: new|open|in_progress|pending_customer|pending_internal|escalated|resolved|closed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CaseStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationChannel rdf:type rdf:Property ;
    rdfs:label 'Notification Channel' ;
    rdfs:comment 'The channel used to notify the customer of this status change. None if no notification was sent.' ;
    rdfs:domain ind:CaseStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether a customer notification was sent as a result of this status transition. True if notification was sent, False otherwise.' ;
    rdfs:domain ind:CaseStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'The status the case was in immediately before this transition occurred. Captures the from-state in the case lifecycle state machine. [ENUM-REF-CANDIDATE: new|open|in_progress|pending_customer|pending_internal|escalated|resolved|closed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CaseStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityAtTransition rdf:type rdf:Property ;
    rdfs:label 'Priority At Transition' ;
    rdfs:comment 'The case priority level that was in effect at the time of this status transition. Captures priority changes over the case lifecycle.' ;
    rdfs:domain ind:CaseStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeInPreviousStatusSeconds rdf:type rdf:Property ;
    rdfs:label 'Time In Previous Status Seconds' ;
    rdfs:comment 'Duration in seconds that the case spent in the previous status before this transition. Calculated as the difference between this transition timestamp and the prior transition timestamp. Critical for SLA compliance measurement and bottleneck identification.' ;
    rdfs:domain ind:CaseStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transitionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Transition Reason Code' ;
    rdfs:comment 'Standardized code indicating why the status transition occurred. Enables categorization and root cause analysis of case workflow patterns. [ENUM-REF-CANDIDATE: customer_response|agent_action|auto_escalation|sla_breach|resolution_confirmed|duplicate_case|customer_request|system_trigger|manager_override|workflow_rule — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CaseStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Transition Reason Description' ;
    rdfs:comment 'Free-text explanation providing additional context for the status transition. Captures agent notes or system-generated rationale.' ;
    rdfs:domain ind:CaseStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Transition Sequence Number' ;
    rdfs:comment 'Sequential order of this transition within the cases complete lifecycle. First transition is 1, second is 2, etc. Enables chronological ordering and lifecycle stage analysis.' ;
    rdfs:domain ind:CaseStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggeredBySystem rdf:type rdf:Property ;
    rdfs:label 'Triggered By System' ;
    rdfs:comment 'Name of the automated system or workflow engine that triggered this transition if not manually initiated by an agent. Examples: SLA Monitor, Auto-Escalation Engine, Workflow Automation.' ;
    rdfs:domain ind:CaseStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Fee Amount' ;
    rdfs:comment 'Annual subscription fee charged for this entitlement tier in base currency (USD). Null indicates no annual fee option.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessHoursCoverage rdf:type rdf:Property ;
    rdfs:label 'Business Hours Coverage' ;
    rdfs:comment 'Support availability hours under this entitlement (business hours 9-5, extended hours 7am-11pm, or 24x7).' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Cancellation Notice Days' ;
    rdfs:comment 'Number of days advance notice required for customer to cancel this entitlement without penalty.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conciergeServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Concierge Service Flag' ;
    rdfs:comment 'Indicates whether this entitlement includes white-glove concierge service for complex requests, special orders, or personalized assistance.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactChannels rdf:type rdf:Property ;
    rdfs:label 'Contact Channels' ;
    rdfs:comment 'Comma-separated list of support contact channels included in this entitlement (e.g., email, phone, chat, social_media, video_call, in_person).' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dedicatedAgentFlag rdf:type rdf:Property ;
    rdfs:label 'Dedicated Agent Flag' ;
    rdfs:comment 'Indicates whether this entitlement includes assignment of a dedicated support agent or account manager.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entitlementCode rdf:type rdf:Property ;
    rdfs:label 'Entitlement Code' ;
    rdfs:comment 'Business-readable unique code for the entitlement tier (e.g., STD_BASIC, PRIME_PRIORITY, VIP_DEDICATED, B2B_ENTERPRISE).' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementDescription rdf:type rdf:Property ;
    rdfs:label 'Entitlement Description' ;
    rdfs:comment 'Detailed description of the service entitlement benefits, coverage scope, and included features.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementName rdf:type rdf:Property ;
    rdfs:label 'Entitlement Name' ;
    rdfs:comment 'Human-readable name of the service entitlement tier (e.g., Standard Support, Prime Priority Support, VIP Dedicated Support).' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementStatus rdf:type rdf:Property ;
    rdfs:label 'Entitlement Status' ;
    rdfs:comment 'Current lifecycle status of the entitlement tier (active and assignable, inactive, deprecated and being phased out, or pending approval).' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationPath rdf:type rdf:Property ;
    rdfs:label 'Escalation Path' ;
    rdfs:comment 'Escalation path tier for unresolved cases (standard queue, expedited to management, executive escalation, or no escalation).' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeReturnShippingFlag rdf:type rdf:Property ;
    rdfs:label 'Free Return Shipping Flag' ;
    rdfs:comment 'Indicates whether return shipping costs are waived for customers under this entitlement.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageSupport rdf:type rdf:Property ;
    rdfs:label 'Language Support' ;
    rdfs:comment 'Comma-separated list of languages supported for customer service under this entitlement (e.g., en, es, fr, de, zh, ja).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxCasesPerMonth rdf:type rdf:Property ;
    rdfs:label 'Max Cases Per Month' ;
    rdfs:comment 'Maximum number of support cases the customer can open per calendar month under this entitlement. Null indicates unlimited.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monthlyFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Fee Amount' ;
    rdfs:comment 'Monthly subscription fee charged for this entitlement tier in base currency (USD). Null indicates no recurring fee.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityRoutingFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Routing Flag' ;
    rdfs:comment 'Indicates whether cases under this entitlement receive priority routing to senior agents or specialized teams.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proactiveOutreachFlag rdf:type rdf:Property ;
    rdfs:label 'Proactive Outreach Flag' ;
    rdfs:comment 'Indicates whether this entitlement includes proactive outreach for service issues, order updates, or account reviews.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refundProcessingPriority rdf:type rdf:Property ;
    rdfs:label 'Refund Processing Priority' ;
    rdfs:comment 'Priority level for refund processing under this entitlement (standard 7-10 days, expedited 3-5 days, immediate 24 hours).' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimeSlaHours rdf:type rdf:Property ;
    rdfs:label 'Resolution Time Sla Hours' ;
    rdfs:comment 'Maximum resolution time in hours guaranteed by SLA for case closure or escalation.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseTimeSlaHours rdf:type rdf:Property ;
    rdfs:label 'Response Time Sla Hours' ;
    rdfs:comment 'Maximum response time in hours guaranteed by SLA for initial agent response to customer inquiry.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rmaAutoApprovalFlag rdf:type rdf:Property ;
    rdfs:label 'Rma Auto Approval Flag' ;
    rdfs:comment 'Indicates whether RMA requests under this entitlement are automatically approved without manual review.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:selfServiceAccessLevel rdf:type rdf:Property ;
    rdfs:label 'Self Service Access Level' ;
    rdfs:comment 'Level of access to self-service tools, knowledge base, and automated resolution features (basic, advanced, premium, full).' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Sla Document Url' ;
    rdfs:comment 'URL link to the detailed SLA document specifying response times, resolution commitments, and service guarantees.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportTier rdf:type rdf:Property ;
    rdfs:label 'Support Tier' ;
    rdfs:comment 'Service support tier level defining the quality and speed of support (basic, priority, premium, dedicated, enterprise).' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSupportIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Technical Support Included Flag' ;
    rdfs:comment 'Indicates whether technical product support (setup, troubleshooting, configuration) is included in this entitlement.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termsAndConditionsUrl rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions Url' ;
    rdfs:comment 'URL link to the full terms and conditions document governing this entitlement tier.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Trial Period Days' ;
    rdfs:comment 'Number of days of free trial period offered for this entitlement tier. Null indicates no trial available.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyExtensionMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Extension Months' ;
    rdfs:comment 'Number of additional warranty months provided beyond standard manufacturer warranty under this entitlement. Null indicates no extension.' ;
    rdfs:domain ind:Entitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationId rdf:type rdf:Property ;
    rdfs:label 'Escalation Id' ;
    rdfs:comment 'Unique identifier for the escalation event. Primary key.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationEscalatingAgentId rdf:type rdf:Property ;
    rdfs:label 'Escalation Escalating Agent Id' ;
    rdfs:comment 'Reference to the support agent who initiated or triggered the escalation.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:receivingTeamId rdf:type rdf:Property ;
    rdfs:label 'Receiving Team Id' ;
    rdfs:comment 'Reference to the support team or queue to which the case was escalated.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:compensationAmount rdf:type rdf:Property ;
    rdfs:label 'Compensation Amount' ;
    rdfs:comment 'Monetary value of compensation issued to the customer as part of escalation resolution.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Compensation Issued Flag' ;
    rdfs:comment 'Boolean indicator of whether customer compensation (refund, credit, discount, gift) was issued as part of escalation resolution (True) or not (False).' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compensationType rdf:type rdf:Property ;
    rdfs:label 'Compensation Type' ;
    rdfs:comment 'The type of compensation provided to the customer (e.g., refund, account credit, discount code, gift card, free shipping, product replacement).' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationNumber rdf:type rdf:Property ;
    rdfs:label 'Escalation Number' ;
    rdfs:comment 'Human-readable business identifier for the escalation event, formatted as ESC-NNNNNNNN.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationType rdf:type rdf:Property ;
    rdfs:label 'Escalation Type' ;
    rdfs:comment 'Classification of the escalation mechanism: functional (to specialist team), hierarchical (to supervisor/manager), automatic (system-triggered), or manual (agent-initiated).' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionAtEscalatedTierFlag rdf:type rdf:Property ;
    rdfs:label 'Resolution At Escalated Tier Flag' ;
    rdfs:comment 'Boolean indicator of whether the case was successfully resolved at the escalated tier (True) or required further escalation (False).' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionCode rdf:type rdf:Property ;
    rdfs:label 'Resolution Code' ;
    rdfs:comment 'Standardized code indicating how the escalated case was resolved (e.g., refund issued, replacement shipped, technical fix applied).' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetResolutionMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Resolution Minutes' ;
    rdfs:comment 'The target resolution time in minutes as defined by the applicable SLA for the escalated case.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceTier rdf:type rdf:Property ;
    rdfs:label 'Source Tier' ;
    rdfs:comment 'The support tier or level from which the case was escalated.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTier rdf:type rdf:Property ;
    rdfs:label 'Target Tier' ;
    rdfs:comment 'The support tier or level to which the case was escalated.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeToResolutionMinutes rdf:type rdf:Property ;
    rdfs:label 'Time To Resolution Minutes' ;
    rdfs:comment 'The elapsed time in minutes from escalation timestamp to resolution timestamp, used for performance analysis and SLA compliance tracking.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feedbackResponseId rdf:type rdf:Property ;
    rdfs:label 'Feedback Response Id' ;
    rdfs:comment 'Primary key for feedback_response' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryFeedbackAgentId rdf:type rdf:Property ;
    rdfs:label 'Primary Feedback Agent Id' ;
    rdfs:comment 'Reference to the customer service agent who handled the case being evaluated. Used for agent performance tracking and coaching.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:caseResolutionTimeHours rdf:type rdf:Property ;
    rdfs:label 'Case Resolution Time Hours' ;
    rdfs:comment 'The total time in hours from case creation to case closure for the service case being evaluated. Captured at the time of survey to enable correlation analysis between resolution speed and customer satisfaction.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelOfService rdf:type rdf:Property ;
    rdfs:label 'Channel Of Service' ;
    rdfs:comment 'The channel through which the customer received service for the case being evaluated. Used to analyze satisfaction by service channel and optimize channel strategy. [ENUM-REF-CANDIDATE: phone|email|chat|social_media|in-app|self-service|store — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationCategory rdf:type rdf:Property ;
    rdfs:label 'Classification Category' ;
    rdfs:comment 'The categorical classification derived from the numeric score. For NPS: promoter (9-10), passive (7-8), detractor (0-6). For CSAT: satisfied (4-5), neutral (3), dissatisfied (1-2). For CES: low_effort (6-7), high_effort (1-3). Used for segmentation and aggregate metrics calculation. [ENUM-REF-CANDIDATE: promoter|passive|detractor|satisfied|neutral|dissatisfied|low_effort|high_effort — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactReason rdf:type rdf:Property ;
    rdfs:label 'Contact Reason' ;
    rdfs:comment 'The specific reason the customer contacted support, as classified by the service team. More granular than case_category, capturing the detailed nature of the inquiry or issue (e.g., damaged_item, late_delivery, wrong_item_shipped, refund_status, promo_code_issue).' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalSurveyReference rdf:type rdf:Property ;
    rdfs:label 'External Survey Reference' ;
    rdfs:comment 'The unique identifier for this survey response in the external survey platform or CRM system. Used for cross-system reconciliation and to link back to the source system for detailed survey metadata.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstContactResolutionFlag rdf:type rdf:Property ;
    rdfs:label 'First Contact Resolution Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer\'s issue was resolved on the first contact without requiring follow-up interactions. Key performance indicator (KPI) for service efficiency and a strong predictor of customer satisfaction.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpActionFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action Flag' ;
    rdfs:comment 'Boolean flag indicating whether this feedback response requires follow-up action from the service team. Typically set to true for detractor responses, low CSAT scores, or when verbatim feedback indicates unresolved issues. Triggers service recovery workflows.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Completed Flag' ;
    rdfs:comment 'Boolean flag indicating whether the required follow-up action has been completed. Used to track closure of service recovery loops and ensure no customer feedback is left unaddressed.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Follow Up Completed Timestamp' ;
    rdfs:comment 'The date and time when the follow-up action was completed. Used to measure time-to-resolution for service recovery and closed-loop feedback processes.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:incentiveOfferedFlag rdf:type rdf:Property ;
    rdfs:label 'Incentive Offered Flag' ;
    rdfs:comment 'Boolean flag indicating whether an incentive (discount, reward points, gift card) was offered to encourage survey completion. Used to analyze response bias and response rate impact of incentives.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interactionCount rdf:type rdf:Property ;
    rdfs:label 'Interaction Count' ;
    rdfs:comment 'The total number of customer-agent interactions required to resolve the case being evaluated. Used to measure case complexity and correlate with effort scores and satisfaction ratings.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numericScore rdf:type rdf:Property ;
    rdfs:label 'Numeric Score' ;
    rdfs:comment 'The numeric rating provided by the customer. For CSAT surveys this is typically 1-5 (1=very dissatisfied, 5=very satisfied). For NPS surveys this is 0-10 (0=not at all likely to recommend, 10=extremely likely). For CES surveys this is typically 1-7 (1=very difficult, 7=very easy).' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryFeedbackTheme rdf:type rdf:Property ;
    rdfs:label 'Primary Feedback Theme' ;
    rdfs:comment 'The main topic or theme identified in the verbatim feedback through text analytics or manual coding. Examples include product_quality, delivery_speed, agent_professionalism, resolution_time, website_usability, pricing, return_process. Used for root cause analysis and improvement prioritization.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDeviceType rdf:type rdf:Property ;
    rdfs:label 'Response Device Type' ;
    rdfs:comment 'Type of device used by the customer to submit the feedback response. Used to analyze response patterns by device and optimize survey design for different form factors.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseLanguage rdf:type rdf:Property ;
    rdfs:label 'Response Language' ;
    rdfs:comment 'ISO 639-1 two-letter language code indicating the language in which the customer provided their feedback. Used for multilingual sentiment analysis and to route feedback to appropriate language-capable service teams.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryFeedbackTheme rdf:type rdf:Property ;
    rdfs:label 'Secondary Feedback Theme' ;
    rdfs:comment 'Additional topic or theme identified in the verbatim feedback when multiple themes are present. Captures the secondary concern or compliment expressed by the customer.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentimentClassification rdf:type rdf:Property ;
    rdfs:label 'Sentiment Classification' ;
    rdfs:comment 'Categorical sentiment classification derived from sentiment score and verbatim text analysis. Positive indicates favorable feedback, negative indicates unfavorable feedback, neutral indicates balanced or no strong sentiment, mixed indicates conflicting sentiments within the same response.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveySentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Survey Sent Timestamp' ;
    rdfs:comment 'The date and time when the survey invitation was sent to the customer. Used to calculate response lag and survey completion rates.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:surveyTriggerEvent rdf:type rdf:Property ;
    rdfs:label 'Survey Trigger Event' ;
    rdfs:comment 'The specific business event that triggered the delivery of this feedback survey. Identifies the touchpoint in the customer journey being measured.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verbatimFeedbackText rdf:type rdf:Property ;
    rdfs:label 'Verbatim Feedback Text' ;
    rdfs:comment 'Free-form text comments provided by the customer explaining their rating. This qualitative feedback provides context for the numeric score and is used for sentiment analysis, theme extraction, and identifying specific improvement opportunities. Classified as confidential due to potential inclusion of customer-specific details.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knowledgeArticleId rdf:type rdf:Property ;
    rdfs:label 'Knowledge Article Id' ;
    rdfs:comment 'Unique identifier for the knowledge base article. Primary key.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KnowledgeArticle .

ind:primaryKnowledgeAuthorAgentId rdf:type rdf:Property ;
    rdfs:label 'Primary Knowledge Author Agent Id' ;
    rdfs:comment 'Identifier of the customer service agent or knowledge manager who authored the article.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:agentUsageCount rdf:type rdf:Property ;
    rdfs:label 'Agent Usage Count' ;
    rdfs:comment 'Number of times agents have referenced or attached this article during case resolution. Indicates agent knowledge utilization.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:articleNumber rdf:type rdf:Property ;
    rdfs:label 'Article Number' ;
    rdfs:comment 'Externally-visible unique article number used for reference and citation in support interactions. Format: KA-XXXXXXXX.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:articleType rdf:type rdf:Property ;
    rdfs:label 'Article Type' ;
    rdfs:comment 'Classification of the article content type. Determines presentation format and usage context.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attachmentUrls rdf:type rdf:Property ;
    rdfs:label 'Attachment Urls' ;
    rdfs:comment 'Comma-separated list of URLs pointing to supplementary attachments such as PDFs, videos, screenshots, or downloadable resources stored in Content Delivery Network (CDN).' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseDeflectionCount rdf:type rdf:Property ;
    rdfs:label 'Case Deflection Count' ;
    rdfs:comment 'Number of support cases attributed as deflected by this article through self-service resolution. Measured via customer journey tracking.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:caseTypeTags rdf:type rdf:Property ;
    rdfs:label 'Case Type Tags' ;
    rdfs:comment 'Comma-separated list of case types this article is designed to resolve. Links article to specific support case categories.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:helpfulnessScore rdf:type rdf:Property ;
    rdfs:label 'Helpfulness Score' ;
    rdfs:comment 'Calculated helpfulness percentage based on ratio of helpful to total votes. Range 0.00 to 100.00. Used to identify high-quality and low-quality content.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issueTaxonomyTags rdf:type rdf:Property ;
    rdfs:label 'Issue Taxonomy Tags' ;
    rdfs:comment 'Comma-separated list of issue taxonomy tags for categorization and search optimization. Examples: shipping_delay, payment_failure, account_access, product_defect.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knowledgeArticleStatus rdf:type rdf:Property ;
    rdfs:label 'Knowledge Article Status' ;
    rdfs:comment 'Current lifecycle status of the article in the approval and publication workflow.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Updated Date' ;
    rdfs:comment 'Date when the article content was last modified and republished.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notHelpfulVotes rdf:type rdf:Property ;
    rdfs:label 'Not Helpful Votes' ;
    rdfs:comment 'Count of negative helpfulness ratings (thumbs down) received from users who viewed the article.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publishDate rdf:type rdf:Property ;
    rdfs:label 'Publish Date' ;
    rdfs:comment 'Date when the article was first published and made available to agents or customers.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relatedArticleIds rdf:type rdf:Property ;
    rdfs:label 'Related Article Ids' ;
    rdfs:comment 'Comma-separated list of knowledge article IDs that are contextually related or frequently viewed together. Used for recommendation engine.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewByDate rdf:type rdf:Property ;
    rdfs:label 'Review By Date' ;
    rdfs:comment 'Target date by which the article should be reviewed for accuracy and relevance. Used to trigger periodic content audits.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:viewCount rdf:type rdf:Property ;
    rdfs:label 'View Count' ;
    rdfs:comment 'Total number of times the article has been viewed by agents or customers. Used to measure article popularity and relevance.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visibilityScope rdf:type rdf:Property ;
    rdfs:label 'Visibility Scope' ;
    rdfs:comment 'Defines the audience scope for article visibility. Determines which user groups can access the article.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Flag indicating whether this RMA requires manual approval by customer service or management. Triggered by policy exceptions or high-value returns.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerDeclaredCondition rdf:type rdf:Property ;
    rdfs:label 'Customer Declared Condition' ;
    rdfs:comment 'Condition of the returned item as declared by the customer at the time of RMA request. Used for initial eligibility assessment and compared against inspection findings.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerServiceNotes rdf:type rdf:Property ;
    rdfs:label 'Customer Service Notes' ;
    rdfs:comment 'Free-text notes entered by customer service representatives regarding the RMA case. Captures context, customer interactions, and special handling instructions.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReturnDate rdf:type rdf:Property ;
    rdfs:label 'Expected Return Date' ;
    rdfs:comment 'Estimated date by which the returned item is expected to arrive at the warehouse. Used for receiving planning and exception alerts.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectedCondition rdf:type rdf:Property ;
    rdfs:label 'Inspected Condition' ;
    rdfs:comment 'Actual condition of the returned item as determined by warehouse inspection team. Used to validate customer declaration and determine disposition.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Completed Date' ;
    rdfs:comment 'Date when the warehouse inspection of the returned item was completed. Triggers disposition decision and refund processing.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isWithinPolicy rdf:type rdf:Property ;
    rdfs:label 'Is Within Policy' ;
    rdfs:comment 'Flag indicating whether the RMA request complies with the applicable return policy rules. Used for auto-approval workflows and exception handling.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Label Issued Date' ;
    rdfs:comment 'Date when the return shipping label was generated and provided to the customer. Used for tracking customer action and carrier pickup scheduling.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labelPaidBy rdf:type rdf:Property ;
    rdfs:label 'Label Paid By' ;
    rdfs:comment 'Party responsible for paying the return shipping cost. Determines financial settlement and customer experience.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundProcessedDate rdf:type rdf:Property ;
    rdfs:label 'Refund Processed Date' ;
    rdfs:comment 'Date when the refund transaction was successfully processed and funds were released to the customer. Used for financial reconciliation and customer satisfaction tracking.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restockingFee rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee' ;
    rdfs:comment 'Fee charged to the customer for processing the return, deducted from the refund amount. Applied per return policy and product category.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnLabelCost rdf:type rdf:Property ;
    rdfs:label 'Return Label Cost' ;
    rdfs:comment 'Cost of the return shipping label in the transaction currency. Used for return cost analysis and customer charge-back decisions.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Return Tracking Number' ;
    rdfs:comment 'Carrier-provided tracking number for the return shipment. Enables real-time visibility into return transit status.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaStatus rdf:type rdf:Property ;
    rdfs:label 'Rma Status' ;
    rdfs:comment 'Current lifecycle status of the RMA. Tracks the return authorization workflow from initial request through final disposition. [ENUM-REF-CANDIDATE: pending_approval|approved|rejected|label_issued|in_transit|received|inspecting|completed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaLineId rdf:type rdf:Property ;
    rdfs:label 'Rma Line Id' ;
    rdfs:comment 'Unique identifier for the RMA line item. Primary key for the RMA line detail record.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispositionCode rdf:type rdf:Property ;
    rdfs:label 'Disposition Code' ;
    rdfs:comment 'The final disposition decision for the returned item. Determines how the item will be handled after inspection and processing.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Exchange Requested Flag' ;
    rdfs:comment 'Indicates whether the customer has requested an exchange rather than a refund for this item. True if exchange requested, false if refund only.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exchangeSku rdf:type rdf:Property ;
    rdfs:label 'Exchange Sku' ;
    rdfs:comment 'The SKU of the replacement product requested by the customer if this is an exchange. Null if this is a refund-only return.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Inspected By User Code' ;
    rdfs:comment 'Reference to the warehouse staff member who performed the inspection of this returned item. Supports quality control and accountability.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectedDate rdf:type rdf:Property ;
    rdfs:label 'Inspected Date' ;
    rdfs:comment 'The date the returned item completed quality inspection. Marks the completion of the inspection process and readiness for disposition.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:itemConditionCode rdf:type rdf:Property ;
    rdfs:label 'Item Condition Code' ;
    rdfs:comment 'Standardized assessment of the physical condition of the returned item upon receipt at the warehouse. Determines restocking eligibility and disposition.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineSubtotal rdf:type rdf:Property ;
    rdfs:label 'Line Subtotal' ;
    rdfs:comment 'The total amount for this line before taxes and fees, calculated as unit price multiplied by quantity approved. Represents the base refund amount.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Line Tax Amount' ;
    rdfs:comment 'The tax amount to be refunded for this line item. Calculated based on the approved quantity and applicable tax rates.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityApproved rdf:type rdf:Property ;
    rdfs:label 'Quantity Approved' ;
    rdfs:comment 'The number of units approved for refund or exchange after inspection. May be less than quantity received if some units fail inspection criteria.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'The number of units the customer has requested to return for this SKU. Represents the customer\'s initial return request quantity.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restockingEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Restocking Eligible Flag' ;
    rdfs:comment 'Indicates whether the returned item is in suitable condition to be restocked and resold as new inventory. True if eligible for resale, false if must be liquidated or disposed.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryServiceIssuingAgentId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Issuing Agent Id' ;
    rdfs:comment 'Reference to the customer service agent who initiated the refund request. Links to the employee or agent record.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:approvalTier rdf:type rdf:Property ;
    rdfs:label 'Approval Tier' ;
    rdfs:comment 'Authorization level required for this refund based on amount thresholds. Defines the approval hierarchy tier.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionImpact rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Impact' ;
    rdfs:comment 'Assessed impact of the refund on customer satisfaction based on follow-up surveys or agent assessment. Used for service quality tracking.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGoodwillGesture rdf:type rdf:Property ;
    rdfs:label 'Is Goodwill Gesture' ;
    rdfs:comment 'Indicates whether the refund was issued as a proactive goodwill gesture rather than in response to a specific complaint or return. True for retention offers.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRetentionOffer rdf:type rdf:Property ;
    rdfs:label 'Is Retention Offer' ;
    rdfs:comment 'Indicates whether the compensation was issued as part of a customer retention strategy to prevent churn. True for proactive retention gestures.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyPointsGranted rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Granted' ;
    rdfs:comment 'Number of loyalty program points awarded as compensation. Zero if compensation was not in the form of loyalty points.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managerOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Manager Override Flag' ;
    rdfs:comment 'Indicates whether the refund required manager override of standard policy or amount thresholds. True if exception was granted.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netRefundCost rdf:type rdf:Property ;
    rdfs:label 'Net Refund Cost' ;
    rdfs:comment 'Total cost to the business including refund amount and processing fees. Used for financial impact analysis and reporting.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npsSurveyResponse rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Response' ;
    rdfs:comment 'Customer NPS score (0-10) collected after refund resolution. Null if no survey response was received. Used for service quality measurement.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalPaymentMethodType rdf:type rdf:Property ;
    rdfs:label 'Original Payment Method Type' ;
    rdfs:comment 'Type of payment method used in the original order. Used to determine refund routing and processing requirements. [ENUM-REF-CANDIDATE: credit_card|debit_card|paypal|bank_transfer|gift_card|store_credit|cash_on_delivery|buy_now_pay_later — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processed Timestamp' ;
    rdfs:comment 'Date and time when the refund was submitted to the payment system for execution. Marks handoff from service to payment domain.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reasonCategory rdf:type rdf:Property ;
    rdfs:label 'Reason Category' ;
    rdfs:comment 'High-level categorization of why the refund or compensation was issued. Used for root cause analysis and service improvement. [ENUM-REF-CANDIDATE: defective_product|wrong_item_shipped|damaged_in_transit|late_delivery|service_failure|customer_dissatisfaction|pricing_error|goodwill_gesture|retention_offer|policy_exception — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDetail rdf:type rdf:Property ;
    rdfs:label 'Reason Detail' ;
    rdfs:comment 'Detailed explanation of the specific reason for issuing the refund or compensation. Free-text field for agent notes.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Redemption Status' ;
    rdfs:comment 'Tracks whether non-monetary compensation (store credit, gift card, coupon) has been used by the customer. Not applicable for direct refunds.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionValueRemaining rdf:type rdf:Property ;
    rdfs:label 'Redemption Value Remaining' ;
    rdfs:comment 'Remaining unredeemed value for partial-use compensation instruments like store credit or gift cards. Null for one-time refunds.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundNumber rdf:type rdf:Property ;
    rdfs:label 'Refund Number' ;
    rdfs:comment 'Externally visible unique business identifier for the refund. Used in customer communications and tracking.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationType rdf:type rdf:Property ;
    rdfs:label 'Remediation Type' ;
    rdfs:comment 'Category of customer remediation issued. Defines the form of compensation provided to the customer. [ENUM-REF-CANDIDATE: full_refund|partial_refund|store_credit|gift_card|coupon_code|free_shipping_voucher|loyalty_points|goodwill_compensation — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Requested Timestamp' ;
    rdfs:comment 'Date and time when the refund was initially requested by the customer or initiated by the service agent. Marks the start of the refund lifecycle.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceRefundStatus rdf:type rdf:Property ;
    rdfs:label 'Service Refund Status' ;
    rdfs:comment 'Current lifecycle state of the refund. Tracks the refund through authorization, processing, and completion stages. [ENUM-REF-CANDIDATE: pending|approved|processing|completed|failed|redeemed|expired|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Settlement Reference Number' ;
    rdfs:comment 'External reference number from the payment gateway or financial system confirming the refund transaction was settled. Links to payment domain records.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCaseServiceSupportCaseId rdf:type rdf:Property ;
    rdfs:label 'Parent Case Service Support Case Id' ;
    rdfs:comment 'Reference to a parent case if this case is a child or follow-up case. Used for linking related cases and tracking case hierarchies (e.g., original case and subsequent escalation or related inquiry).' ;
    rdfs:domain ind:ServiceSupportCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceSupportCase .

ind:assignedQueue rdf:type rdf:Property ;
    rdfs:label 'Assigned Queue' ;
    rdfs:comment 'The service queue or team to which this case is currently assigned (e.g., Tier1_Support, Billing_Team, Returns_Processing, Escalations, VIP_Support).' ;
    rdfs:domain ind:ServiceSupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactAttempts rdf:type rdf:Property ;
    rdfs:label 'Contact Attempts' ;
    rdfs:comment 'Number of times the support team attempted to contact the customer regarding this case. Used for tracking customer responsiveness and case aging.' ;
    rdfs:domain ind:ServiceSupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerEntitlementTier rdf:type rdf:Property ;
    rdfs:label 'Customer Entitlement Tier' ;
    rdfs:comment 'The service entitlement level of the customer at the time the case was created: standard (basic support), premium (priority support), VIP (dedicated support), enterprise (white-glove service). Influences SLA targets and routing.' ;
    rdfs:domain ind:ServiceSupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackComments rdf:type rdf:Property ;
    rdfs:label 'Feedback Comments' ;
    rdfs:comment 'Free-text feedback comments provided by the customer in post-case surveys. Captures qualitative insights about the support experience, agent performance, and areas for improvement.' ;
    rdfs:domain ind:ServiceSupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isVipCase rdf:type rdf:Property ;
    rdfs:label 'Is Vip Case' ;
    rdfs:comment 'Boolean flag indicating whether this case involves a VIP or high-value customer requiring special handling, expedited service, or executive attention. True for VIP cases, False otherwise.' ;
    rdfs:domain ind:ServiceSupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outcomeDisposition rdf:type rdf:Property ;
    rdfs:label 'Outcome Disposition' ;
    rdfs:comment 'Final disposition of the case: resolved (issue successfully addressed), unresolved (could not be resolved), duplicate (merged with another case), transferred (moved to another system or team), withdrawn (customer cancelled request).' ;
    rdfs:domain ind:ServiceSupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reopenedCount rdf:type rdf:Property ;
    rdfs:label 'Reopened Count' ;
    rdfs:comment 'Number of times this case has been reopened after being marked as resolved or closed. Indicates resolution quality issues or recurring customer problems.' ;
    rdfs:domain ind:ServiceSupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceSupportCaseDescription rdf:type rdf:Property ;
    rdfs:label 'Service Support Case Description' ;
    rdfs:comment 'Detailed description of the customer issue, inquiry, or request as captured during case creation. May include customer-provided details, agent notes, and initial diagnostic information.' ;
    rdfs:domain ind:ServiceSupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceSupportCaseStatus rdf:type rdf:Property ;
    rdfs:label 'Service Support Case Status' ;
    rdfs:comment 'Current lifecycle status of the support case: new (just created), open (assigned), pending_customer (awaiting customer response), pending_internal (awaiting internal action), in_progress (actively being worked), escalated (moved to higher tier), resolved (solution provided), closed (finalized), cancelled (withdrawn). [ENUM-REF-CANDIDATE: new|open|pending_customer|pending_internal|in_progress|escalated|resolved|closed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceSupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Sla Policy Code' ;
    rdfs:comment 'Reference code for the SLA policy governing response and resolution time targets for this case, based on customer tier, case priority, and case type.' ;
    rdfs:domain ind:ServiceSupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaPolicyId rdf:type rdf:Property ;
    rdfs:label 'Sla Policy Id' ;
    rdfs:comment 'Unique identifier for the SLA policy record. Primary key.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByPolicySlaPolicyId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Policy Sla Policy Id' ;
    rdfs:comment 'Reference to the newer SLA policy that replaces this one. Nullable for current active policies. Creates version chain for policy evolution tracking.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaPolicy .

ind:autoEscalationEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Escalation Enabled' ;
    rdfs:comment 'Boolean flag indicating whether automatic escalation is enabled when escalation_threshold_hours is reached. True enables automated escalation workflow, False requires manual escalation.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Breach Penalty Amount' ;
    rdfs:comment 'Monetary amount of penalty or credit applied when SLA is breached. Applicable when breach_penalty_type is financial or credit. Stored in base currency.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachPenaltyCurrency rdf:type rdf:Property ;
    rdfs:label 'Breach Penalty Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the breach penalty amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachPenaltyType rdf:type rdf:Property ;
    rdfs:label 'Breach Penalty Type' ;
    rdfs:comment 'Type of penalty or action triggered when SLA is breached. Options include no penalty, financial penalty, customer credit, automatic escalation, or notification to management.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessDays rdf:type rdf:Property ;
    rdfs:label 'Business Days' ;
    rdfs:comment 'Comma-separated list of business days when SLA is active (e.g., \'Monday,Tuesday,Wednesday,Thursday,Friday\'). Used when time_calculation_method is business_hours to exclude weekends or specific days.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Business Hours End' ;
    rdfs:comment 'End time of business hours in HH:MM format (24-hour clock) when time_calculation_method is business_hours. Used to calculate SLA compliance during operational hours only.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessHoursStart rdf:type rdf:Property ;
    rdfs:label 'Business Hours Start' ;
    rdfs:comment 'Start time of business hours in HH:MM format (24-hour clock) when time_calculation_method is business_hours. Used to calculate SLA compliance during operational hours only.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casePriority rdf:type rdf:Property ;
    rdfs:label 'Case Priority' ;
    rdfs:comment 'Priority level of cases this SLA policy applies to. Used in conjunction with case_type to form the SLA matrix (e.g., High priority order inquiries have different SLA targets than Low priority inquiries).' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Required' ;
    rdfs:comment 'Boolean flag indicating whether this SLA policy is driven by regulatory compliance requirements (e.g., GDPR data subject request response times, financial services complaint handling). True indicates regulatory mandate.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Hours' ;
    rdfs:comment 'Time threshold in hours that triggers automatic escalation if the case is not resolved. Typically set before the resolution target to allow time for escalated handling.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusions rdf:type rdf:Property ;
    rdfs:label 'Exclusions' ;
    rdfs:comment 'Description of cases or conditions excluded from this SLA policy (e.g., \'Excludes cases opened during system maintenance windows\', \'Does not apply to third-party vendor issues\'). Defines policy boundaries.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstResponseTargetHours rdf:type rdf:Property ;
    rdfs:label 'First Response Target Hours' ;
    rdfs:comment 'Target time in hours for the first response to a customer case under this SLA policy. Represents the maximum time allowed before initial acknowledgment or response to the customer.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDefaultPolicy rdf:type rdf:Property ;
    rdfs:label 'Is Default Policy' ;
    rdfs:comment 'Boolean flag indicating whether this is the default SLA policy applied when no specific policy matches a case. Only one policy per case_type should be marked as default.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Notification Enabled' ;
    rdfs:comment 'Boolean flag indicating whether automated notifications are sent when SLA thresholds are approaching or breached. True enables notification workflow.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Notification Threshold Percent' ;
    rdfs:comment 'Percentage of SLA target time elapsed that triggers a warning notification (e.g., 80 means notify when 80% of resolution_target_hours has passed). Used for proactive SLA management.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownerUserCode rdf:type rdf:Property ;
    rdfs:label 'Owner User Code' ;
    rdfs:comment 'Identifier of the business user or manager responsible for defining and maintaining this SLA policy. Typically a customer service director or operations manager.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Classification of the SLA policy indicating the service area it governs (customer support, technical support, returns processing, escalation handling, VIP service, standard service).' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Name of the regulatory framework or law that mandates this SLA policy (e.g., \'GDPR\', \'CCPA\', \'FTC Consumer Protection\', \'PCI DSS\'). Populated when compliance_required is True.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTargetHours rdf:type rdf:Property ;
    rdfs:label 'Resolution Target Hours' ;
    rdfs:comment 'Target time in hours for full resolution of a customer case under this SLA policy. Represents the maximum time allowed to completely resolve and close the case.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaPolicyDescription rdf:type rdf:Property ;
    rdfs:label 'Sla Policy Description' ;
    rdfs:comment 'Detailed description of the SLA policy including its purpose, scope, and any special conditions or exceptions. Provides context for policy application and interpretation.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaPolicyStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Policy Status' ;
    rdfs:comment 'Current lifecycle status of the SLA policy indicating whether it is actively enforced, inactive, in draft state, archived, or temporarily suspended.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Time Calculation Method' ;
    rdfs:comment 'Method used to calculate SLA time targets. Business hours counts only operational hours (e.g., 9am-5pm weekdays), while calendar hours counts all hours including nights and weekends.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamId rdf:type rdf:Property ;
    rdfs:label 'Team Id' ;
    rdfs:comment 'Unique identifier for the customer service team. Primary key.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentTeamId rdf:type rdf:Property ;
    rdfs:label 'Parent Team Id' ;
    rdfs:comment 'Reference to the parent team in a hierarchical team structure. Null for top-level teams. Enables organizational hierarchy and escalation path modeling.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:primaryEscalationTeamId rdf:type rdf:Property ;
    rdfs:label 'Primary Escalation Team Id' ;
    rdfs:comment 'Reference to the team to which cases are escalated when this team cannot resolve them. Null if this is the highest escalation tier. Enables escalation path configuration.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:capacityFte rdf:type rdf:Property ;
    rdfs:label 'Capacity Fte' ;
    rdfs:comment 'Total team capacity expressed in Full-Time Equivalent (FTE) headcount. Used for workforce planning, capacity forecasting, and case load balancing.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:csatTarget rdf:type rdf:Property ;
    rdfs:label 'Csat Target' ;
    rdfs:comment 'Target Customer Satisfaction (CSAT) score for the team, expressed as a percentage (0-100). Key performance indicator (KPI) for customer experience quality.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Geographic region or market this team serves, using 3-letter ISO country codes or region identifiers (e.g., USA, CAN, GBR, EUR, APAC, GLOBAL). Supports geo-based routing and regional SLA (Service Level Agreement) management.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRemote rdf:type rdf:Property ;
    rdfs:label 'Is Remote' ;
    rdfs:comment 'Indicates whether the team operates remotely (distributed workforce) or from a centralized physical location. True if remote, False if on-site.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsTarget rdf:type rdf:Property ;
    rdfs:label 'Nps Target' ;
    rdfs:comment 'Target Net Promoter Score (NPS) for the team, ranging from -100 to +100. Measures customer loyalty and likelihood to recommend based on team interactions.' ;
    rdfs:domain ind:Team ;
