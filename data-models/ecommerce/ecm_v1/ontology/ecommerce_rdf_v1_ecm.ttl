    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goLiveDate rdf:type rdf:Property ;
    rdfs:label 'Go Live Date' ;
    rdfs:comment 'Planned date when the seller becomes active on the marketplace after successful onboarding.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netEstimatedGmvAmount rdf:type rdf:Property ;
    rdfs:label 'Net Estimated Gmv Amount' ;
    rdfs:comment 'Estimated GMV after subtracting the marketplace commission; represents the seller\'s net revenue expectation.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sellerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Seller Contact Email' ;
    rdfs:comment 'Primary email address for communication with the seller during onboarding.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Seller Contact Phone' ;
    rdfs:comment 'Primary phone number for contacting the seller during onboarding.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingId rdf:type rdf:Property ;
    rdfs:label 'Rating Id' ;
    rdfs:comment 'Primary key for rating' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dimensionCommunication rdf:type rdf:Property ;
    rdfs:label 'Dimension Communication' ;
    rdfs:comment 'Buyer’s rating of the seller’s communication quality.' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dimensionItemAsDescribed rdf:type rdf:Property ;
    rdfs:label 'Dimension Item As Described' ;
    rdfs:comment 'Buyer’s rating of how accurately the item matched its description.' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dimensionPackaging rdf:type rdf:Property ;
    rdfs:label 'Dimension Packaging' ;
    rdfs:comment 'Buyer’s rating of the quality of the item’s packaging.' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dimensionShippingSpeed rdf:type rdf:Property ;
    rdfs:label 'Dimension Shipping Speed' ;
    rdfs:comment 'Buyer’s rating of how quickly the seller shipped the item.' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:helpfulVotes rdf:type rdf:Property ;
    rdfs:label 'Helpful Votes' ;
    rdfs:comment 'Number of other buyers who marked the review as helpful.' ;
