    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxUsers rdf:type rdf:Property ;
    rdfs:label 'Max Users' ;
    rdfs:comment 'Maximum number of distinct user accounts allowed under the plan.' ;
    rdfs:domain ind:SubscriptionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overageFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Overage Fee Amount' ;
    rdfs:comment 'Monetary charge applied per unit when usage exceeds the defined limit.' ;
