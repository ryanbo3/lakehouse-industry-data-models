    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dashboardDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Dashboard Definition Id' ;
    rdfs:comment 'Unique surrogate key for each dashboard definition record.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DashboardDefinition .

ind:ownerTeamId rdf:type rdf:Property ;
    rdfs:label 'Owner Team Id' ;
    rdfs:comment 'Foreign key linking to service.team. Business justification: Dashboards are owned by specific support teams; linking owner_team_id to team.team_id supports governance and access control.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:accessTier rdf:type rdf:Property ;
    rdfs:label 'Access Tier' ;
    rdfs:comment 'Security classification governing who may view the dashboard.' ;
