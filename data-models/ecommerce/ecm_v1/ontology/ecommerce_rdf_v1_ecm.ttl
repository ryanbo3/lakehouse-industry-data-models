    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sellerBankAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Seller Bank Account Status' ;
    rdfs:comment 'Overall lifecycle state of the bank account record.' ;
    rdfs:domain ind:SellerBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatusDate rdf:type rdf:Property ;
    rdfs:label 'Verification Status Date' ;
    rdfs:comment 'Date and time when the verification status was last updated.' ;
    rdfs:domain ind:SellerBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preferredThirdPartyFulfillmentId rdf:type rdf:Property ;
    rdfs:label 'Preferred Third Party Fulfillment Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.third_party_fulfillment. Business justification: Needed for Seller-Third-Party Logistics Contract Management, linking seller to its contracted 3PL provider.' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ThirdPartyFulfillment .

ind:sellerTierId rdf:type rdf:Property ;
    rdfs:label 'Seller Tier Id' ;
    rdfs:comment 'Foreign key linking to seller.tier. Business justification: Seller tier classification is defined in the tier reference table; replacing the string tier attribute with a foreign key enforces referential integrity and supports tier-based analytics.' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tier .

ind:businessType rdf:type rdf:Property ;
    rdfs:label 'Business Type' ;
    rdfs:comment 'Classification of the seller based on size and structure.' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationCountry rdf:type rdf:Property ;
    rdfs:label 'Incorporation Country' ;
    rdfs:comment 'Three-letter ISO country code where the seller is legally incorporated.' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Completed Date' ;
    rdfs:comment 'Date when KYC verification was successfully completed.' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Status' ;
    rdfs:comment 'Current status of Know-Your-Customer / Know-Your-Business verification.' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationPreferences rdf:type rdf:Property ;
    rdfs:label 'Notification Preferences' ;
    rdfs:comment 'Serialized preferences indicating which notification channels the seller opts into (e.g., email, SMS, in-app).' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceScoreBsr rdf:type rdf:Property ;
    rdfs:label 'Performance Score Bsr' ;
    rdfs:comment 'Numeric score derived from the seller\'s Best Seller Rank performance.' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceScoreDsr rdf:type rdf:Property ;
    rdfs:label 'Performance Score Dsr' ;
    rdfs:comment 'Numeric score reflecting the seller\'s daily sales rate performance.' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platformJoinDate rdf:type rdf:Property ;
    rdfs:label 'Platform Join Date' ;
    rdfs:comment 'Date the seller first joined the marketplace platform.' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryCategory rdf:type rdf:Property ;
    rdfs:label 'Primary Category' ;
    rdfs:comment 'Top-level product category the seller primarily operates in.' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Secondary Contact Email' ;
    rdfs:comment 'Email address of the secondary contact.' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryContactName rdf:type rdf:Property ;
    rdfs:label 'Secondary Contact Name' ;
    rdfs:comment 'Full name of the secondary point-of-contact for the seller.' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Secondary Contact Phone' ;
    rdfs:comment 'Phone number of the secondary contact.' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingName rdf:type rdf:Property ;
    rdfs:label 'Trading Name' ;
    rdfs:comment 'Public-facing name used by the seller on the marketplace.' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerSupportCaseId rdf:type rdf:Property ;
    rdfs:label 'Seller Support Case Id' ;
    rdfs:comment 'Unique identifier for the seller support case.' ;
    rdfs:domain ind:SellerSupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amountAdjustments rdf:type rdf:Property ;
    rdfs:label 'Amount Adjustments' ;
    rdfs:comment 'Sum of fees, refunds, or other adjustments applied to the case.' ;
    rdfs:domain ind:SellerSupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Category of the seller-initiated support request. [ENUM-REF-CANDIDATE: account_issue|listing_dispute|payout_query|policy_clarification|technical_issue|tier_appeal|suspension_appeal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csatScore rdf:type rdf:Property ;
    rdfs:label 'Csat Score' ;
    rdfs:comment 'Post-resolution satisfaction rating provided by the seller (1-5).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Response Timestamp' ;
    rdfs:comment 'Timestamp of the first reply sent to the seller.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originatingChannel rdf:type rdf:Property ;
    rdfs:label 'Originating Channel' ;
    rdfs:comment 'Channel through which the seller submitted the case.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerSupportCaseDescription rdf:type rdf:Property ;
    rdfs:label 'Seller Support Case Description' ;
    rdfs:comment 'Detailed free-text description of the seller\'s issue.' ;
    rdfs:domain ind:SellerSupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerSupportCaseStatus rdf:type rdf:Property ;
    rdfs:label 'Seller Support Case Status' ;
    rdfs:comment 'Current lifecycle state of the support case.' ;
    rdfs:domain ind:SellerSupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Brief title summarising the issue raised by the seller.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionId rdf:type rdf:Property ;
    rdfs:label 'Suspension Id' ;
    rdfs:comment 'Primary key for suspension' ;
    rdfs:domain ind:Suspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fraudInvestigationId rdf:type rdf:Property ;
    rdfs:label 'Fraud Investigation Id' ;
    rdfs:comment 'Identifier of the fraud investigation case linked to the suspension, if applicable.' ;
