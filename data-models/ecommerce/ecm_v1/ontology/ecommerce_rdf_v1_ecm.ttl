    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appealEligible rdf:type rdf:Property ;
    rdfs:label 'Appeal Eligible' ;
    rdfs:comment 'Indicates whether the seller may appeal the suspension decision.' ;
    rdfs:domain ind:Suspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealSubmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Appeal Submission Timestamp' ;
    rdfs:comment 'Timestamp when the seller submitted an appeal.' ;
    rdfs:domain ind:Suspension ;
