    rdfs:range xsd:integer .

ind:cac rdf:type rdf:Property ;
    rdfs:label 'Cac' ;
    rdfs:comment 'Average cost to acquire a new customer through this campaign.' ;
    rdfs:domain ind:CampaignPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignObjective rdf:type rdf:Property ;
    rdfs:label 'Campaign Objective' ;
    rdfs:comment 'Primary business objective the campaign aims to achieve (e.g., drive traffic, increase sales, boost engagement).' ;
