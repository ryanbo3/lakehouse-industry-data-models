ind:contentHash rdf:type rdf:Property ;
    rdfs:label 'Content Hash' ;
    rdfs:comment 'Hash of the page content used to detect changes.' ;
    rdfs:domain ind:SeoMetadata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hreflangTags rdf:type rdf:Property ;
    rdfs:label 'Hreflang Tags' ;
    rdfs:comment 'Comma-separated list of hreflang locale tags for language targeting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCanonical rdf:type rdf:Property ;
    rdfs:label 'Is Canonical' ;
    rdfs:comment 'Indicates if this URL is the canonical version.' ;
    rdfs:domain ind:SeoMetadata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keywordTarget rdf:type rdf:Property ;
    rdfs:label 'Keyword Target' ;
    rdfs:comment 'Primary SEO keyword targeted for the page.' ;
    rdfs:domain ind:SeoMetadata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdated rdf:type rdf:Property ;
    rdfs:label 'Last Updated' ;
    rdfs:comment 'Timestamp of the most recent update to the SEO metadata.' ;
    rdfs:domain ind:SeoMetadata ;
    rdf:type owl:DatatypeProperty ;
