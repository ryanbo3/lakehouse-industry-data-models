    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imageUrl rdf:type rdf:Property ;
    rdfs:label 'Image Url' ;
    rdfs:comment 'URL of the visual icon or image representing the tag.' ;
    rdfs:domain ind:Ecommerce ;
