    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sellerBankAccountId rdf:type rdf:Property ;
    rdfs:label 'Seller Bank Account Id' ;
    rdfs:comment 'System-generated unique identifier for the seller bank account record.' ;
    rdfs:domain ind:SellerBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountHolderName rdf:type rdf:Property ;
    rdfs:label 'Account Holder Name' ;
    rdfs:comment 'Legal name of the individual or organization that owns the bank account.' ;
