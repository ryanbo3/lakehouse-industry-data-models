    rdfs:label 'Regulatory Flag' ;
    rdfs:comment 'Indicates whether the moderation action must be reported for regulatory compliance (e.g., GDPR, FTC).' ;
    rdfs:domain ind:Moderation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ruleTriggered rdf:type rdf:Property ;
    rdfs:label 'Rule Triggered' ;
    rdfs:comment 'Name or code of the moderation rule that was triggered for this action.' ;
    rdfs:domain ind:Moderation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'Channel through which the moderation request originated.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationCategory rdf:type rdf:Property ;
    rdfs:label 'Violation Category' ;
    rdfs:comment 'Category of policy violation identified by the moderation.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceId rdf:type rdf:Property ;
    rdfs:label 'Performance Id' ;
    rdfs:comment 'Unique surrogate key for each content performance record.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:abTestVariant rdf:type rdf:Property ;
    rdfs:label 'Ab Test Variant' ;
    rdfs:comment 'Name or code of the A/B test variant presented to the user.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abTestWinning rdf:type rdf:Property ;
    rdfs:label 'Ab Test Winning' ;
    rdfs:comment 'True if the variant is the statistically winning variant for the experiment.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bounceRate rdf:type rdf:Property ;
    rdfs:label 'Bounce Rate' ;
    rdfs:comment 'Percentage of sessions where users left after a single view of the content.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clicks rdf:type rdf:Property ;
    rdfs:label 'Clicks' ;
    rdfs:comment 'Number of user clicks on the content or associated asset.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentQualityScore rdf:type rdf:Property ;
    rdfs:label 'Content Quality Score' ;
    rdfs:comment 'Composite score evaluating content relevance, readability, and compliance.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionCount rdf:type rdf:Property ;
    rdfs:label 'Conversion Count' ;
    rdfs:comment 'Number of conversion events (e.g., add-to-cart, purchase) attributed to the content.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ctr rdf:type rdf:Property ;
    rdfs:label 'Ctr' ;
    rdfs:comment 'Ratio of clicks to impressions (clicks ÷ impressions). Stored as a raw measurement captured by the analytics engine.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engagementSeconds rdf:type rdf:Property ;
    rdfs:label 'Engagement Seconds' ;
    rdfs:comment 'Total time (in seconds) users spent interacting with the content.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impressions rdf:type rdf:Property ;
    rdfs:label 'Impressions' ;
    rdfs:comment 'Number of times the content was displayed to users.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isControlGroup rdf:type rdf:Property ;
    rdfs:label 'Is Control Group' ;
    rdfs:comment 'True if the user was exposed to the control (baseline) variant.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDeleted rdf:type rdf:Property ;
    rdfs:label 'Is Deleted' ;
    rdfs:comment 'True if the record has been logically deleted.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liftPercentage rdf:type rdf:Property ;
    rdfs:label 'Lift Percentage' ;
    rdfs:comment 'Percentage lift of the winning variant over the control.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metricDate rdf:type rdf:Property ;
    rdfs:label 'Metric Date' ;
    rdfs:comment 'Calendar date (day granularity) for the performance snapshot.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueInfluenceUsd rdf:type rdf:Property ;
    rdfs:label 'Revenue Influence Usd' ;
    rdfs:comment 'Estimated revenue (in US dollars) driven by the content, as calculated by the attribution model.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:snapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Snapshot Timestamp' ;
    rdfs:comment 'Exact time when the performance measurement was captured.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:statisticalSignificance rdf:type rdf:Property ;
    rdfs:label 'Statistical Significance' ;
    rdfs:comment 'True when the observed lift meets the pre-defined significance threshold.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicationId rdf:type rdf:Property ;
    rdfs:label 'Publication Id' ;
    rdfs:comment 'Unique identifier for the publication event record.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Exact date-time when the publication event occurred.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isRollback rdf:type rdf:Property ;
    rdfs:label 'Is Rollback' ;
    rdfs:comment 'Indicates whether this event represents a rollback to a previous version.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTestVariant rdf:type rdf:Property ;
    rdfs:label 'Is Test Variant' ;
    rdfs:comment 'True if the publication is part of an A/B test or experimental variant.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledPublishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Publish Timestamp' ;
    rdfs:comment 'Planned date-time for future publication when the event is scheduled.' ;
    rdfs:domain ind:Publication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'External business identifier for the license agreement.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseTermsUrl rdf:type rdf:Property ;
    rdfs:label 'License Terms Url' ;
    rdfs:comment 'Link to the full legal terms of the license.' ;
    rdfs:domain ind:RightsLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'Classification of the license (e.g., royalty-free, rights-managed, exclusive, user-generated content).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensorName rdf:type rdf:Property ;
    rdfs:label 'Licensor Name' ;
    rdfs:comment 'Name of the party granting the content license.' ;
    rdfs:domain ind:RightsLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalCost rdf:type rdf:Property ;
    rdfs:label 'Renewal Cost' ;
    rdfs:comment 'Cost associated with renewing the license.' ;
    rdfs:domain ind:RightsLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Flag' ;
    rdfs:comment 'Indicates whether the license is set for automatic renewal.' ;
    rdfs:domain ind:RightsLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rightsLicenseStatus rdf:type rdf:Property ;
    rdfs:label 'Rights License Status' ;
    rdfs:comment 'Current lifecycle status of the license.' ;
    rdfs:domain ind:RightsLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territory rdf:type rdf:Property ;
    rdfs:label 'Territory' ;
    rdfs:comment 'Geographic region(s) where the content may be used, expressed as ISO-3166-1 alpha-3 country codes (e.g., USA, CAN).' ;
    rdfs:domain ind:RightsLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageScope rdf:type rdf:Property ;
    rdfs:label 'Usage Scope' ;
    rdfs:comment 'Intended usage channels for the licensed content.' ;
    rdfs:domain ind:RightsLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seoMetadataId rdf:type rdf:Property ;
    rdfs:label 'Seo Metadata Id' ;
    rdfs:comment 'Unique identifier for the SEO metadata record.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SeoMetadata .

ind:canonicalUrl rdf:type rdf:Property ;
    rdfs:label 'Canonical Url' ;
    rdfs:comment 'Canonical URL for the page, may differ from page_url if redirects exist.' ;
