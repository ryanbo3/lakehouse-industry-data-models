    rdfs:range xsd:dateTime .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'Number of days the seller has been suspended (calculated from effective_date to resolution).' ;
    rdfs:domain ind:Suspension ;
    rdf:type owl:DatatypeProperty ;
