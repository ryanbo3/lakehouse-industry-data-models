    rdfs:range xsd:string .

ind:openGraphImageUrl rdf:type rdf:Property ;
    rdfs:label 'Open Graph Image Url' ;
    rdfs:comment 'URL of the image used in Open Graph metadata.' ;
    rdfs:domain ind:SeoMetadata ;
