    rdfs:label 'Funnel Definition Type' ;
    rdfs:comment 'Category of funnel (e.g., purchase, seller onboarding, checkout, search-to-purchase).' ;
    rdfs:domain ind:FunnelDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stages rdf:type rdf:Property ;
    rdfs:label 'Stages' ;
    rdfs:comment 'JSON-encoded ordered list of stage identifiers that compose the funnel.' ;
    rdfs:domain ind:FunnelDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:funnelEventId rdf:type rdf:Property ;
    rdfs:label 'Funnel Event Id' ;
    rdfs:comment 'Unique identifier for the funnel event record.' ;
    rdfs:domain ind:FunnelEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clickEventId rdf:type rdf:Property ;
    rdfs:label 'Click Event Id' ;
    rdfs:comment 'Unique identifier for the click that led to the funnel entry.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClickEvent .

ind:headerId rdf:type rdf:Property ;
    rdfs:label 'Header Id' ;
    rdfs:comment 'Identifier of the order generated as a result of conversion, if any.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Header .

ind:paymentTransactionId rdf:type rdf:Property ;
    rdfs:label 'Payment Transaction Id' ;
    rdfs:comment 'Foreign key linking to payment.payment_transaction. Business justification: Conversion funnel analysis includes the payment step; linking to the transaction enables measurement of success/failure rates per payment.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentTransaction .

ind:sessionId rdf:type rdf:Property ;
    rdfs:label 'Session Id' ;
    rdfs:comment 'Unique identifier for the user session.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ecommerce .

ind:abandonmentReason rdf:type rdf:Property ;
    rdfs:label 'Abandonment Reason' ;
    rdfs:comment 'Reason code for funnel abandonment, if known.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionModel rdf:type rdf:Property ;
    rdfs:label 'Attribution Model' ;
    rdfs:comment 'Model used to attribute credit for the conversion (e.g., last_click).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:browser rdf:type rdf:Property ;
    rdfs:label 'Browser' ;
    rdfs:comment 'Name of the web browser used (e.g., Chrome, Safari).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Marketing channel through which the entity interacted (e.g., web, mobile app).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionFlag rdf:type rdf:Property ;
    rdfs:label 'Conversion Flag' ;
    rdfs:comment 'Indicates whether the entity progressed to the next funnel stage.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviceCode rdf:type rdf:Property ;
    rdfs:label 'Device Code' ;
    rdfs:comment 'Unique identifier of the device (e.g., advertising ID).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceOsVersion rdf:type rdf:Property ;
    rdfs:label 'Device Os Version' ;
    rdfs:comment 'Version number of the operating system on the device.' ;
    rdfs:domain ind:FunnelEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'Category of device used (desktop, mobile, tablet).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enteredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entered Timestamp' ;
    rdfs:comment 'Exact time the entity entered the funnel stage.' ;
    rdfs:domain ind:FunnelEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Type of entity progressing through the funnel (customer, seller, or session).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSource rdf:type rdf:Property ;
    rdfs:label 'Event Source' ;
    rdfs:comment 'System or component that generated the funnel event (e.g., web app, mobile SDK).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exited Timestamp' ;
    rdfs:comment 'Exact time the entity left the funnel stage (if applicable).' ;
    rdfs:domain ind:FunnelEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:funnelStageEntryMethod rdf:type rdf:Property ;
    rdfs:label 'Funnel Stage Entry Method' ;
    rdfs:comment 'Method by which the entity entered the stage (click, view, or automatic).' ;
    rdfs:domain ind:FunnelEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoCountry rdf:type rdf:Property ;
    rdfs:label 'Geo Country' ;
    rdfs:comment 'Three-letter ISO country code of the client location.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRegion rdf:type rdf:Property ;
    rdfs:label 'Geo Region' ;
    rdfs:comment 'State, province, or region of the client location.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'IP address of the client at event time.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAbandoned rdf:type rdf:Property ;
    rdfs:label 'Is Abandoned' ;
    rdfs:comment 'True if the entity abandoned the funnel after this stage.' ;
    rdfs:domain ind:FunnelEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNewUser rdf:type rdf:Property ;
    rdfs:label 'Is New User' ;
    rdfs:comment 'True if this is the first recorded interaction for the entity.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReturningUser rdf:type rdf:Property ;
    rdfs:label 'Is Returning User' ;
    rdfs:comment 'True if the entity has prior interactions before this event.' ;
    rdfs:domain ind:FunnelEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingSystem rdf:type rdf:Property ;
    rdfs:label 'Operating System' ;
    rdfs:comment 'Operating system of the device (e.g., Windows, iOS).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderValue rdf:type rdf:Property ;
    rdfs:label 'Order Value' ;
    rdfs:comment 'Monetary value of the order associated with the conversion.' ;
    rdfs:domain ind:FunnelEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pageUrl rdf:type rdf:Property ;
    rdfs:label 'Page Url' ;
    rdfs:comment 'URL of the page where the funnel event occurred.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referrerUrl rdf:type rdf:Property ;
    rdfs:label 'Referrer Url' ;
    rdfs:comment 'URL of the page that referred the user to the current page.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenResolution rdf:type rdf:Property ;
    rdfs:label 'Screen Resolution' ;
    rdfs:comment 'Screen resolution of the device at event time (e.g., 1920x1080).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceMedium rdf:type rdf:Property ;
    rdfs:label 'Source Medium' ;
    rdfs:comment 'Medium through which the traffic arrived (organic, paid, referral, email).' ;
    rdfs:domain ind:FunnelEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageName rdf:type rdf:Property ;
    rdfs:label 'Stage Name' ;
    rdfs:comment 'Human-readable name of the funnel stage entered.' ;
    rdfs:domain ind:FunnelEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageSequence rdf:type rdf:Property ;
    rdfs:label 'Stage Sequence' ;
    rdfs:comment 'Numeric order of the stage within the funnel.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:userAgent rdf:type rdf:Property ;
    rdfs:label 'User Agent' ;
    rdfs:comment 'Full user-agent string sent by the browser.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmvDailySnapshotId rdf:type rdf:Property ;
    rdfs:label 'Gmv Daily Snapshot Id' ;
    rdfs:comment 'Surrogate key uniquely identifying each GMV daily snapshot record.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GmvDailySnapshot .

ind:channelId rdf:type rdf:Property ;
    rdfs:label 'Channel Id' ;
    rdfs:comment 'Foreign key linking to marketing.channel. Business justification: Daily GMV snapshots are broken down by marketing channel; FK enables channel-level financial analysis.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:marketplaceTransactionId rdf:type rdf:Property ;
    rdfs:label 'Marketplace Transaction Id' ;
    rdfs:comment 'Foreign key linking to marketplace.marketplace_transaction. Business justification: Required for audit of daily GMV snapshot to trace back to source transactions for compliance and dispute resolution.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketplaceTransaction .

ind:cancellationRate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Rate' ;
    rdfs:comment 'Proportion of orders cancelled relative to total orders (decimal).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataFreshnessIndicator rdf:type rdf:Property ;
    rdfs:label 'Data Freshness Indicator' ;
    rdfs:comment 'Indicator of how current the snapshot data is relative to source system ingestion.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmvDailySnapshotCategory rdf:type rdf:Property ;
    rdfs:label 'Gmv Daily Snapshot Category' ;
    rdfs:comment 'Top-level product category aggregated for the snapshot.' ;
    rdfs:domain ind:GmvDailySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmvGross rdf:type rdf:Property ;
    rdfs:label 'Gmv Gross' ;
    rdfs:comment 'Total gross value of merchandise sold before discounts, returns, and fees.' ;
    rdfs:domain ind:GmvDailySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmvNet rdf:type rdf:Property ;
    rdfs:label 'Gmv Net' ;
    rdfs:comment 'Net GMV after deducting returns, cancellations, and platform fees.' ;
    rdfs:domain ind:GmvDailySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platform rdf:type rdf:Property ;
    rdfs:label 'Platform' ;
    rdfs:comment 'The sales platform (e.g., website, mobile app) where the transactions occurred.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Three-letter country code representing the geographic region of the snapshot. [ENUM-REF-CANDIDATE: USA|CAN|GBR|DEU|FRA|JPN|CHN|IND|BRA|AUS — promote to reference product]' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerTier rdf:type rdf:Property ;
    rdfs:label 'Seller Tier' ;
    rdfs:comment 'Classification of seller based on performance or agreement level.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snapshotDate rdf:type rdf:Property ;
    rdfs:label 'Snapshot Date' ;
    rdfs:comment 'The calendar date for which the GMV metrics are captured.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:snapshotStatus rdf:type rdf:Property ;
    rdfs:label 'Snapshot Status' ;
    rdfs:comment 'Current processing state of the snapshot record.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:takeRate rdf:type rdf:Property ;
    rdfs:label 'Take Rate' ;
    rdfs:comment 'Portion of GMV retained by the platform as revenue (percentage expressed as decimal).' ;
    rdfs:domain ind:GmvDailySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kpiDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Kpi Definition Id' ;
    rdfs:comment 'Unique surrogate key for each KPI definition. _canonical_skip_reason: Entity does not fit standard role categories and is a master registry of KPI metadata.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KpiDefinition .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Identifier of the business party (e.g., department, team, or individual) responsible for the KPI.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:priceListId rdf:type rdf:Property ;
    rdfs:label 'Price List Id' ;
    rdfs:comment 'Foreign key linking to pricing.price_list. Business justification: KPIs like "Price Elasticity per List" are defined per price list; the FK ties the KPI definition to its relevant price list.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceList .

ind:regulationId rdf:type rdf:Property ;
    rdfs:label 'Regulation Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulation. Business justification: Regulatory reporting KPIs must be tied to a specific regulation; linking KPI to regulation enables compliance reporting and audit traceability.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Regulation .

ind:aggregationLevel rdf:type rdf:Property ;
    rdfs:label 'Aggregation Level' ;
    rdfs:comment 'Granularity at which the KPI is aggregated for reporting.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessLine rdf:type rdf:Property ;
    rdfs:label 'Business Line' ;
    rdfs:comment 'High-level business line or division (e.g., Marketplace, Fulfillment) that the KPI supports.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationFormula rdf:type rdf:Property ;
    rdfs:label 'Calculation Formula' ;
    rdfs:comment 'Logical expression or algorithm used to compute the KPI from source data elements.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeLog rdf:type rdf:Property ;
    rdfs:label 'Change Log' ;
    rdfs:comment 'Free-text log of modifications made to the KPI definition, including rationale.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirements' ;
    rdfs:comment 'Regulatory or internal compliance constraints that the KPI must satisfy (e.g., GDPR, SOX).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceDomain rdf:type rdf:Property ;
    rdfs:label 'Data Source Domain' ;
    rdfs:comment 'Primary data domain (e.g., order, customer, finance) that supplies the raw inputs for the KPI.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConfidential rdf:type rdf:Property ;
    rdfs:label 'Is Confidential' ;
    rdfs:comment 'Indicates whether the KPI contains confidential information that requires restricted access.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kpiDefinitionStatus rdf:type rdf:Property ;
    rdfs:label 'Kpi Definition Status' ;
    rdfs:comment 'Current lifecycle status of the KPI definition.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiDescription rdf:type rdf:Property ;
    rdfs:label 'Kpi Description' ;
    rdfs:comment 'Detailed business description of what the KPI measures and why it matters.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kpiName rdf:type rdf:Property ;
    rdfs:label 'Kpi Name' ;
    rdfs:comment 'Human-readable name of the KPI as used in reports and dashboards.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Review Timestamp' ;
    rdfs:comment 'Timestamp of the last formal review of the KPI definition for relevance and accuracy.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:metricCategory rdf:type rdf:Property ;
    rdfs:label 'Metric Category' ;
    rdfs:comment 'Broad category of the metric such as Performance, Financial, Operational, or Customer.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerRole rdf:type rdf:Property ;
    rdfs:label 'Owner Role' ;
    rdfs:comment 'Business role or title of the KPI owner (e.g., Finance Analyst, Marketing Manager).' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshCadence rdf:type rdf:Property ;
    rdfs:label 'Refresh Cadence' ;
    rdfs:comment 'Frequency at which the KPI value is recomputed and refreshed in reporting.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingRequirement rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Requirement' ;
    rdfs:comment 'Specific regulatory reporting mandate (e.g., SEC, GDPR) that the KPI fulfills.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedKpiIds rdf:type rdf:Property ;
    rdfs:label 'Related Kpi Ids' ;
    rdfs:comment 'Comma-separated list of other KPI definition IDs that are logically related or derived.' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'How often the KPI is expected to be reported to stakeholders.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetThresholdLower rdf:type rdf:Property ;
    rdfs:label 'Target Threshold Lower' ;
    rdfs:comment 'Lower bound of the acceptable KPI range (used when threshold_type = \'range\').' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetThresholdType rdf:type rdf:Property ;
    rdfs:label 'Target Threshold Type' ;
    rdfs:comment 'Indicates whether the KPI has an upper bound, lower bound, or a range of acceptable values.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetThresholdUpper rdf:type rdf:Property ;
    rdfs:label 'Target Threshold Upper' ;
    rdfs:comment 'Upper bound of the acceptable KPI range (used when threshold_type = \'range\').' ;
    rdfs:domain ind:KpiDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'Numeric target that the KPI is expected to achieve (used for single-threshold KPIs).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:kpiTargetId rdf:type rdf:Property ;
    rdfs:label 'Kpi Target Id' ;
    rdfs:comment 'Unique surrogate key for each KPI target record.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'Foreign key linking to logistics.carrier. Business justification: Allows carrier-specific KPI targets (e.g., delivery time SLA) for performance contracts.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:obligationId rdf:type rdf:Property ;
    rdfs:label 'Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_obligation. Business justification: KPI targets are set to meet specific compliance obligations; linking provides direct traceability from performance targets to the obligation they satisfy.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:orgUnitId rdf:type rdf:Property ;
    rdfs:label 'Org Unit Id' ;
    rdfs:comment 'Reference to the specific business unit, channel, region, or seller tier.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:primaryKpiDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Primary Kpi Definition Id' ;
    rdfs:comment 'Reference to the KPI definition that this target applies to.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KpiDefinition .

ind:tertiaryKpiDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Kpi Definition Id' ;
    rdfs:comment 'FK to analytics.kpi_definition' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KpiDefinition .

ind:ceilingThreshold rdf:type rdf:Property ;
    rdfs:label 'Ceiling Threshold' ;
    rdfs:comment 'Maximum acceptable performance level; values above may indicate data issues.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceRequirement rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement' ;
    rdfs:comment 'Regulatory or internal compliance frameworks governing the KPI (e.g., GDPR, PCI, SOX).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Date when the KPI target expires or is superseded (nullable).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:floorThreshold rdf:type rdf:Property ;
    rdfs:label 'Floor Threshold' ;
    rdfs:comment 'Minimum acceptable performance level; values below trigger alerts.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'How often the target is evaluated.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCritical rdf:type rdf:Property ;
    rdfs:label 'Is Critical' ;
    rdfs:comment 'Indicates whether the target is considered critical for executive scorecards.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kpiTargetStatus rdf:type rdf:Property ;
    rdfs:label 'Kpi Target Status' ;
    rdfs:comment 'Current lifecycle status of the KPI target.' ;
    rdfs:domain ind:KpiTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date when the target was last reviewed or adjusted.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
