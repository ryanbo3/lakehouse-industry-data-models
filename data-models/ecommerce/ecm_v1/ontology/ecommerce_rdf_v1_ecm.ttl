    rdfs:range xsd:string .

ind:renewalPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Period Months' ;
    rdfs:comment 'Number of months after which the subscription is renewed when auto-renew is enabled.' ;
