    rdfs:comment 'Indicates whether the document is under legal hold and cannot be deleted.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewerNotes rdf:type rdf:Property ;
    rdfs:label 'Reviewer Notes' ;
    rdfs:comment 'Comments entered by the compliance reviewer during verification.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskClassification rdf:type rdf:Property ;
    rdfs:label 'Risk Classification' ;
    rdfs:comment 'Risk level associated with the document based on compliance and verification outcomes.' ;
    rdfs:domain ind:Seller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerGmvAtUpload rdf:type rdf:Property ;
    rdfs:label 'Seller Gmv At Upload' ;
    rdfs:comment 'Total GMV associated with the seller at the time the document was uploaded.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Verification Effective Date' ;
    rdfs:comment 'Date when the verification of the document became effective.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Verification Expiry Date' ;
    rdfs:comment 'Date when the verification of the document expires.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmvSettlementId rdf:type rdf:Property ;
    rdfs:label 'Gmv Settlement Id' ;
    rdfs:comment 'Primary key for gmv_settlement' ;
    rdfs:domain ind:GmvSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmvSource rdf:type rdf:Property ;
    rdfs:label 'Gmv Source' ;
    rdfs:comment 'Source channel of GMV attribution.' ;
    rdfs:domain ind:GmvSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payoutAmount rdf:type rdf:Property ;
    rdfs:label 'Payout Amount' ;
    rdfs:comment 'Final payout amount transferred to seller after all deductions.' ;
    rdfs:domain ind:GmvSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payoutDate rdf:type rdf:Property ;
    rdfs:label 'Payout Date' ;
    rdfs:comment 'Date on which payout was transferred to the seller\'s bank account.' ;
    rdfs:domain ind:GmvSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionalSubsidyAmount rdf:type rdf:Property ;
    rdfs:label 'Promotional Subsidy Amount' ;
    rdfs:comment 'Total promotional subsidies applied to the seller\'s sales.' ;
    rdfs:domain ind:GmvSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnsAmount rdf:type rdf:Property ;
    rdfs:label 'Returns Amount' ;
    rdfs:comment 'Total amount of returns and refunds deducted from gross GMV.' ;
    rdfs:domain ind:GmvSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onboardingId rdf:type rdf:Property ;
    rdfs:label 'Onboarding Id' ;
    rdfs:comment 'Primary key for onboarding' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementSignedDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Signed Date' ;
    rdfs:comment 'Date on which the seller signed the marketplace participation agreement.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agreementVersion rdf:type rdf:Property ;
    rdfs:label 'Agreement Version' ;
    rdfs:comment 'Version identifier of the seller agreement that was signed.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Human-readable identifier assigned to the onboarding application for tracking and reference.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessModel rdf:type rdf:Property ;
    rdfs:label 'Business Model' ;
    rdfs:comment 'Classification of the seller\'s commercial model (Business-to-Consumer, Business-to-Business, Consumer-to-Consumer).' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryRequested rdf:type rdf:Property ;
    rdfs:label 'Category Requested' ;
    rdfs:comment 'Primary product category the seller wishes to list on the marketplace.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCheckPassed rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Passed' ;
    rdfs:comment 'Result of automated compliance checks (e.g., KYC/KYB) – True if all checks passed.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedCommissionAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Commission Amount' ;
    rdfs:comment 'Projected commission the marketplace will retain from the seller\'s GMV, based on the agreed commission structure.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedGmvAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Gmv Amount' ;
    rdfs:comment 'Projected gross merchandise value the seller is expected to generate after onboarding, expressed in the transaction currency.' ;
    rdfs:domain ind:Onboarding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedGmvCurrency rdf:type rdf:Property ;
    rdfs:label 'Estimated Gmv Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated GMV amount.' ;
