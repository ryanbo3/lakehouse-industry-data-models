ind:returnReceiptStatus rdf:type rdf:Property ;
    rdfs:label 'Return Receipt Status' ;
    rdfs:comment 'Current processing status of the return receipt.' ;
    rdfs:domain ind:ReturnReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnType rdf:type rdf:Property ;
    rdfs:label 'Return Type' ;
    rdfs:comment 'High-level classification of the return.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmaNumber rdf:type rdf:Property ;
    rdfs:label 'Rma Number' ;
    rdfs:comment 'External RMA reference number associated with the return.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
