ind:boundKpi rdf:type rdf:Property ;
    rdfs:label 'Bound Kpi' ;
    rdfs:comment 'Identifier of the KPI or metric bound to the widget.' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartColorScheme rdf:type rdf:Property ;
    rdfs:label 'Chart Color Scheme' ;
    rdfs:comment 'Selected color scheme for chart visualizations.' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dashboardWidgetDescription rdf:type rdf:Property ;
    rdfs:label 'Dashboard Widget Description' ;
    rdfs:comment 'Detailed description of the widget purpose and content.' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dashboardWidgetName rdf:type rdf:Property ;
    rdfs:label 'Dashboard Widget Name' ;
    rdfs:comment 'Human readable name of the dashboard widget.' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dashboardWidgetStatus rdf:type rdf:Property ;
    rdfs:label 'Dashboard Widget Status' ;
    rdfs:comment 'Current lifecycle status of the widget.' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionFilters rdf:type rdf:Property ;
    rdfs:label 'Dimension Filters' ;
    rdfs:comment 'Serialized list of dimensional filters applied to the widget data.' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayFormat rdf:type rdf:Property ;
    rdfs:label 'Display Format' ;
    rdfs:comment 'Formatting options for the widget display, such as number format, color scheme, or unit.' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drilldownEnabled rdf:type rdf:Property ;
    rdfs:label 'Drilldown Enabled' ;
    rdfs:comment 'Flag indicating whether drill-down navigation is enabled.' ;
