ind:vehicleTypeRequirement rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type Requirement' ;
    rdfs:comment 'Required vehicle type for the route (e.g., truck, van, bike, drone, container).' ;
    rdfs:domain ind:Route ;
