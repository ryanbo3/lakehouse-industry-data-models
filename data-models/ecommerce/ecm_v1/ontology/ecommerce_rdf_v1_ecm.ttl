    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retention90DayRate rdf:type rdf:Property ;
    rdfs:label 'Retention 90 Day Rate' ;
    rdfs:comment 'Proportion of cohort customers who made a purchase within 90 days after acquisition.' ;
    rdfs:domain ind:CustomerRetentionFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrders rdf:type rdf:Property ;
    rdfs:label 'Total Orders' ;
    rdfs:comment 'Total number of orders placed by the segment/cohort in the reporting period.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRevenueUsd rdf:type rdf:Property ;
