    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'Periodicity of the performance record.' ;
    rdfs:domain ind:CategoryPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnRate rdf:type rdf:Property ;
    rdfs:label 'Return Rate' ;
    rdfs:comment 'Ratio of returned units to units sold, expressed as a decimal.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sellThroughRate rdf:type rdf:Property ;
    rdfs:label 'Sell Through Rate' ;
    rdfs:comment 'Percentage of inventory sold during the period.' ;
    rdfs:domain ind:CategoryPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:topSkuCount rdf:type rdf:Property ;
    rdfs:label 'Top Sku Count' ;
    rdfs:comment 'Number of top-selling SKUs contributing to the majority of sales.' ;
    rdfs:domain ind:CategoryPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsSold rdf:type rdf:Property ;
    rdfs:label 'Units Sold' ;
    rdfs:comment 'Total number of units sold across all orders.' ;
    rdfs:domain ind:CategoryPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cohortDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Cohort Definition Id' ;
    rdfs:comment 'Unique surrogate key for the cohort definition record.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CohortDefinition .

ind:cohortDefinitionCode rdf:type rdf:Property ;
    rdfs:label 'Cohort Definition Code' ;
    rdfs:comment 'Business identifier or short code for the cohort, unique within the analytics domain.' ;
    rdfs:domain ind:CohortDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cohortDefinitionDescription rdf:type rdf:Property ;
    rdfs:label 'Cohort Definition Description' ;
    rdfs:comment 'Detailed free-text description of the cohort purpose and business rules.' ;
    rdfs:domain ind:CohortDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cohortDefinitionName rdf:type rdf:Property ;
    rdfs:label 'Cohort Definition Name' ;
    rdfs:comment 'Human-readable name of the cohort used in reports and dashboards.' ;
    rdfs:domain ind:CohortDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cohortDefinitionStatus rdf:type rdf:Property ;
    rdfs:label 'Cohort Definition Status' ;
    rdfs:comment 'Current lifecycle status of the cohort definition.' ;
    rdfs:domain ind:CohortDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cohortDefinitionType rdf:type rdf:Property ;
    rdfs:label 'Cohort Definition Type' ;
    rdfs:comment 'Category of cohort – acquisition (first-time customers), behavioral (based on actions), value (revenue-based), or custom.' ;
    rdfs:domain ind:CohortDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cohortSizeEstimate rdf:type rdf:Property ;
    rdfs:label 'Cohort Size Estimate' ;
    rdfs:comment 'Projected number of members in the cohort at formation time.' ;
    rdfs:domain ind:CohortDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formationCriteria rdf:type rdf:Property ;
    rdfs:label 'Formation Criteria' ;
    rdfs:comment 'JSON or serialized expression defining the logical rules used to select members of the cohort.' ;
    rdfs:domain ind:CohortDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formationEndDate rdf:type rdf:Property ;
    rdfs:label 'Formation End Date' ;
    rdfs:comment 'Date on which the cohort formation period ends; null for open-ended cohorts.' ;
    rdfs:domain ind:CohortDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:formationStartDate rdf:type rdf:Property ;
    rdfs:label 'Formation Start Date' ;
    rdfs:comment 'Date on which the cohort formation period begins.' ;
    rdfs:domain ind:CohortDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isDynamic rdf:type rdf:Property ;
    rdfs:label 'Is Dynamic' ;
    rdfs:comment 'Indicates whether the cohort updates automatically as new data arrives (true) or is static (false).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:owningTeam rdf:type rdf:Property ;
    rdfs:label 'Owning Team' ;
    rdfs:comment 'Name of the analytics team responsible for maintaining the cohort.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyLevel rdf:type rdf:Property ;
    rdfs:label 'Privacy Level' ;
    rdfs:comment 'Data privacy classification governing access to the cohort data.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency Days' ;
    rdfs:comment 'How often (in days) the dynamic cohort is refreshed.' ;
    rdfs:domain ind:CohortDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionWindowDays rdf:type rdf:Property ;
    rdfs:label 'Retention Window Days' ;
    rdfs:comment 'Number of days after cohort formation that members are tracked for retention analysis.' ;
    rdfs:domain ind:CohortDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Incremental version number for changes to the cohort definition.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cohortMembershipId rdf:type rdf:Property ;
    rdfs:label 'Cohort Membership Id' ;
    rdfs:comment 'Unique identifier for the cohort membership record.' ;
    rdfs:domain ind:CohortMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sellerProfileId rdf:type rdf:Property ;
    rdfs:label 'Seller Profile Id' ;
    rdfs:comment 'Foreign key linking to seller.seller_profile. Business justification: Supports Seller Cohort Analysis; tracks each seller\'s entry/exit dates and status within retention cohorts.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SellerProfile .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'Date when the member was first added to the cohort.' ;
    rdfs:domain ind:CohortMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exitDate rdf:type rdf:Property ;
    rdfs:label 'Exit Date' ;
    rdfs:comment 'Date when the member left the cohort, if applicable.' ;
    rdfs:domain ind:CohortMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:memberType rdf:type rdf:Property ;
    rdfs:label 'Member Type' ;
    rdfs:comment 'Type of entity that is a member of the cohort (customer, seller, or SKU).' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodIndex rdf:type rdf:Property ;
    rdfs:label 'Period Index' ;
    rdfs:comment 'Zero-based index representing the period (e.g., month) relative to cohort entry for retention analysis.' ;
    rdfs:domain ind:CohortMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionStatus rdf:type rdf:Property ;
    rdfs:label 'Retention Status' ;
    rdfs:comment 'Current retention status of the member within the cohort.' ;
    rdfs:domain ind:CohortMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerRetentionFactId rdf:type rdf:Property ;
    rdfs:label 'Customer Retention Fact Id' ;
    rdfs:comment 'Unique surrogate key for each row in the customer retention fact table.' ;
    rdfs:domain ind:CustomerRetentionFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.segment. Business justification: Retention fact tables aggregate by customer segment; FK enables drill-down from fact to segment definition for reporting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:activeBuyerCount rdf:type rdf:Property ;
    rdfs:label 'Active Buyer Count' ;
    rdfs:comment 'Number of distinct customers who made at least one purchase in the reporting period.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageOrderValueUsd rdf:type rdf:Property ;
    rdfs:label 'Average Order Value Usd' ;
    rdfs:comment 'Mean monetary value of orders placed by active buyers, expressed in US dollars.' ;
    rdfs:domain ind:CustomerRetentionFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:churnCount rdf:type rdf:Property ;
    rdfs:label 'Churn Count' ;
    rdfs:comment 'Number of customers from the cohort who did not make any purchase during the reporting period and are considered churned.' ;
    rdfs:domain ind:CustomerRetentionFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:churnRate rdf:type rdf:Property ;
    rdfs:label 'Churn Rate' ;
    rdfs:comment 'Proportion of the cohort that churned during the reporting period (value between 0 and 1).' ;
    rdfs:domain ind:CustomerRetentionFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerRetentionFactStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Retention Fact Status' ;
    rdfs:comment 'Lifecycle status of the fact row (active = current, inactive = superseded, archived = retained for history).' ;
    rdfs:domain ind:CustomerRetentionFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'Business-defined segment or cohort classification of the customer (e.g., high-value, new, churn-risk).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Name of the source system that supplied the underlying raw data (e.g., OMS, CDP, Payment Gateway).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newCustomersCount rdf:type rdf:Property ;
    rdfs:label 'New Customers Count' ;
    rdfs:comment 'Number of first-time buyers acquired during the reporting period.' ;
    rdfs:domain ind:CustomerRetentionFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:purchaseFrequency rdf:type rdf:Property ;
    rdfs:label 'Purchase Frequency' ;
    rdfs:comment 'Average number of purchases per active buyer within the reporting period.' ;
    rdfs:domain ind:CustomerRetentionFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordAuditCreated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Created' ;
    rdfs:comment 'Timestamp when the fact row was first inserted into the analytics layer.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordAuditUpdated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Updated' ;
    rdfs:comment 'Timestamp of the most recent update to the fact row.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:repeatPurchaseRate rdf:type rdf:Property ;
    rdfs:label 'Repeat Purchase Rate' ;
    rdfs:comment 'Proportion of active buyers who placed more than one order during the period (value between 0 and 1).' ;
    rdfs:domain ind:CustomerRetentionFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'Last calendar date of the reporting period covered by the fact row.' ;
    rdfs:domain ind:CustomerRetentionFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodGrain rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Grain' ;
    rdfs:comment 'Temporal granularity of the reporting period (e.g., day, week, month, quarter, year).' ;
    rdfs:domain ind:CustomerRetentionFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'First calendar date of the reporting period covered by the fact row.' ;
    rdfs:domain ind:CustomerRetentionFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retention30DayRate rdf:type rdf:Property ;
    rdfs:label 'Retention 30 Day Rate' ;
    rdfs:comment 'Proportion of customers from the cohort who made a purchase within 30 days after their first purchase.' ;
    rdfs:domain ind:CustomerRetentionFact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retention60DayRate rdf:type rdf:Property ;
    rdfs:label 'Retention 60 Day Rate' ;
    rdfs:comment 'Proportion of cohort customers who made a purchase within 60 days after acquisition.' ;
