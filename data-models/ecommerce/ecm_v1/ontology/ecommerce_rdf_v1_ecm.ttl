    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotId rdf:type rdf:Property ;
    rdfs:label 'Slot Id' ;
    rdfs:comment 'Unique system-generated identifier for the slot.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
