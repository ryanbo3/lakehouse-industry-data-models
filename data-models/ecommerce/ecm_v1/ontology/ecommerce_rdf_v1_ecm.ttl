    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaActualSeconds rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Seconds' ;
    rdfs:comment 'Actual elapsed time from allocation to shipment.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTargetSeconds rdf:type rdf:Property ;
    rdfs:label 'Sla Target Seconds' ;
    rdfs:comment 'Service-level-agreement target time for allocation fulfillment.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:splitShipmentFlag rdf:type rdf:Property ;
    rdfs:label 'Split Shipment Flag' ;
    rdfs:comment 'Indicates whether the order line is split across multiple nodes.' ;
    rdfs:domain ind:FulfillmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxEstimate rdf:type rdf:Property ;
    rdfs:label 'Tax Estimate' ;
    rdfs:comment 'Estimated tax amount applicable to the allocation.' ;
    rdfs:domain ind:FulfillmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalEstimatedCost rdf:type rdf:Property ;
    rdfs:label 'Total Estimated Cost' ;
    rdfs:comment 'Sum of cost, shipping, and tax estimates for the allocation.' ;
    rdfs:domain ind:FulfillmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCubicM rdf:type rdf:Property ;
    rdfs:label 'Volume Cubic M' ;
    rdfs:comment 'Physical volume of the allocated quantity.' ;
    rdfs:domain ind:FulfillmentAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderAddressId rdf:type rdf:Property ;
    rdfs:label 'Order Address Id' ;
    rdfs:comment 'Unique surrogate key for the order address record.' ;
    rdfs:domain ind:OrderAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalAddressReference rdf:type rdf:Property ;
    rdfs:label 'External Address Reference' ;
    rdfs:comment 'Identifier assigned by an external address verification or logistics provider.' ;
    rdfs:domain ind:OrderAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodeAccuracy rdf:type rdf:Property ;
    rdfs:label 'Geocode Accuracy' ;
    rdfs:comment 'Indicates the confidence level of the geocoding result.' ;
    rdfs:domain ind:OrderAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isResidential rdf:type rdf:Property ;
    rdfs:label 'Is Residential' ;
    rdfs:comment 'True if the address is a residential location; false otherwise.' ;
    rdfs:domain ind:OrderAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:label rdf:type rdf:Property ;
    rdfs:label 'Label' ;
    rdfs:comment 'Human-readable label for the address (e.g., Home, Office).' ;
    rdfs:domain ind:OrderAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line1' ;
    rdfs:comment 'First line of the street address.' ;
    rdfs:domain ind:OrderAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line2' ;
    rdfs:comment 'Second line of the street address (optional).' ;
    rdfs:domain ind:OrderAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderAddressStatus rdf:type rdf:Property ;
    rdfs:label 'Order Address Status' ;
    rdfs:comment 'Current lifecycle status of the address record.' ;
    rdfs:domain ind:OrderAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'Date and time when the address was last validated.' ;
    rdfs:domain ind:OrderAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billingAddressOrderAddressId rdf:type rdf:Property ;
    rdfs:label 'Billing Address Order Address Id' ;
    rdfs:comment 'Reference to the address used for billing purposes.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderAddress .

ind:entitlementId rdf:type rdf:Property ;
    rdfs:label 'Entitlement Id' ;
    rdfs:comment 'Foreign key linking to service.entitlement. Business justification: Business process: Apply customer\'s support entitlement to each order for SLA and case handling; experts expect an order to reference its entitlement tier.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Entitlement .

ind:headerOrderAddressId rdf:type rdf:Property ;
    rdfs:label 'Header Order Address Id' ;
    rdfs:comment 'Reference to the address where the order will be shipped.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderAddress .

ind:merchantAccountId rdf:type rdf:Property ;
    rdfs:label 'Merchant Account Id' ;
    rdfs:comment 'Foreign key linking to payment.merchant_account. Business justification: REQUIRED: Reconciliation reports need the merchant account that processed each order; linking order_header to merchant_account enables accurate financial statements and audit trails.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchantAccount .

ind:paymentGatewayId rdf:type rdf:Property ;
    rdfs:label 'Payment Gateway Id' ;
    rdfs:comment 'Foreign key linking to payment.gateway. Business justification: REQUIRED: Operational dashboards track which payment gateway handled each order for SLA monitoring and compliance; a FK from order_header to gateway provides this linkage.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Gateway .

ind:priceApprovalId rdf:type rdf:Property ;
    rdfs:label 'Price Approval Id' ;
    rdfs:comment 'Foreign key linking to pricing.price_approval. Business justification: COMPLIANCE APPROVAL: High-value orders may need price approval; linking to the approval record satisfies audit and regulatory reporting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceApproval .

ind:priceZoneId rdf:type rdf:Property ;
    rdfs:label 'Price Zone Id' ;
    rdfs:comment 'Foreign key linking to pricing.price_zone. Business justification: REGIONAL PRICING: Orders are assigned to a price zone to apply region-specific pricing rules; FK required for zone-based revenue analysis.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceZone .

ind:queryLogId rdf:type rdf:Property ;
    rdfs:label 'Query Log Id' ;
    rdfs:comment 'Foreign key linking to search.query_log. Business justification: Attribution of each order to the originating search query for marketing ROI and search performance reporting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QueryLog .

ind:deliveryActualDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Actual Date' ;
    rdfs:comment 'Date the order was actually delivered to the customer.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryEstimatedDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Estimated Date' ;
    rdfs:comment 'Projected date for order delivery based on SLA.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Internal operational notes about the order, visible to staff only.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSplitShipment rdf:type rdf:Property ;
    rdfs:label 'Is Split Shipment' ;
    rdfs:comment 'True if the order will be fulfilled in multiple shipments.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderComments rdf:type rdf:Property ;
    rdfs:label 'Order Comments' ;
    rdfs:comment 'Free-form comments entered by the customer or support staff.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderPriority rdf:type rdf:Property ;
    rdfs:label 'Order Priority' ;
    rdfs:comment 'Priority level used for fulfillment sequencing.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoCode rdf:type rdf:Property ;
    rdfs:label 'Promo Code' ;
    rdfs:comment 'Code of any promotion applied to the order.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptReason rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Reason' ;
    rdfs:comment 'Reason code for tax exemption, if applicable.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderLineId rdf:type rdf:Property ;
    rdfs:label 'Order Line Id' ;
    rdfs:comment 'Unique identifier for the order_order_line data product (auto-inserted pre-linking).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderLine .

ind:dynamicPriceRuleId rdf:type rdf:Property ;
    rdfs:label 'Dynamic Price Rule Id' ;
    rdfs:comment 'Foreign key linking to pricing.dynamic_price_rule. Business justification: DYNAMIC PRICING LOG: When a dynamic pricing rule adjusts a line, storing the rule ID supports performance reporting and rule-impact analysis.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DynamicPriceRule .

ind:lineRegulationId rdf:type rdf:Property ;
    rdfs:label 'Line Regulation Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulation. Business justification: Product-level regulations (hazardous, restricted items) must be validated per order line; linking ensures regulatory checks and reporting.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Regulation .

ind:markdownScheduleId rdf:type rdf:Property ;
    rdfs:label 'Markdown Schedule Id' ;
    rdfs:comment 'Foreign key linking to pricing.markdown_schedule. Business justification: DISCOUNT AUDIT: A markdown schedule may be applied to a line; linking enables tracking of schedule source for discount compliance.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarkdownSchedule .

ind:asin rdf:type rdf:Property ;
    rdfs:label 'Asin' ;
    rdfs:comment 'Marketplace-specific product identifier.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Current status of the fulfillment process for this line.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBackordered rdf:type rdf:Property ;
    rdfs:label 'Is Backordered' ;
    rdfs:comment 'True if the line is currently on backorder.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Line Discount Amount' ;
    rdfs:comment 'Absolute discount applied to this line.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineDiscountPercent rdf:type rdf:Property ;
    rdfs:label 'Line Discount Percent' ;
    rdfs:comment 'Percentage discount applied to this line.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineTotalGross rdf:type rdf:Property ;
    rdfs:label 'Line Total Gross' ;
    rdfs:comment 'Total amount before tax and after discounts (quantity × unit_price – discount).' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineTotalNet rdf:type rdf:Property ;
    rdfs:label 'Line Total Net' ;
    rdfs:comment 'Final amount after tax (gross total + tax_amount).' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityFulfilled rdf:type rdf:Property ;
    rdfs:label 'Quantity Fulfilled' ;
    rdfs:comment 'Number of units actually shipped to the customer.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'Number of units requested by the customer.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedItemFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Item Flag' ;
    rdfs:comment 'True if the product is subject to sales restrictions.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction' ;
    rdfs:comment 'ISO-3166-1 alpha-3 country code indicating the tax authority for this line.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upc rdf:type rdf:Property ;
    rdfs:label 'Upc' ;
    rdfs:comment 'Global barcode identifier for the product.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderPaymentId rdf:type rdf:Property ;
    rdfs:label 'Order Payment Id' ;
    rdfs:comment 'Surrogate primary key for the order payment allocation record.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPaymentTransactionId rdf:type rdf:Property ;
    rdfs:label 'Primary Payment Transaction Id' ;
    rdfs:comment 'Identifier of the payment transaction from the payment gateway.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentTransaction .

ind:authorizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authorization Timestamp' ;
    rdfs:comment 'Timestamp when the payment was authorized.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:captureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Capture Timestamp' ;
    rdfs:comment 'Timestamp when the payment was captured.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isGiftCard rdf:type rdf:Property ;
    rdfs:label 'Is Gift Card' ;
    rdfs:comment 'True if part of the payment was made using a gift card.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRefund rdf:type rdf:Property ;
    rdfs:label 'Is Refund' ;
    rdfs:comment 'Indicates if this record represents a refund transaction.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSplitPayment rdf:type rdf:Property ;
    rdfs:label 'Is Split Payment' ;
    rdfs:comment 'Indicates if the order payment is part of a split payment across multiple methods.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStoreCredit rdf:type rdf:Property ;
    rdfs:label 'Is Store Credit' ;
    rdfs:comment 'True if part of the payment was made using store credit.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineQuantity rdf:type rdf:Property ;
    rdfs:label 'Line Quantity' ;
    rdfs:comment 'Number of payment units allocated (typically 1).' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:note rdf:type rdf:Property ;
    rdfs:label 'Note' ;
    rdfs:comment 'Additional notes or remarks about the payment.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Description' ;
    rdfs:comment 'Optional free-text description of the payment allocation.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reference rdf:type rdf:Property ;
    rdfs:label 'Reference' ;
    rdfs:comment 'External reference or token from the payment gateway for this payment transaction.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundedAmount rdf:type rdf:Property ;
    rdfs:label 'Refunded Amount' ;
    rdfs:comment 'Amount refunded for this payment allocation, if any.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency Code' ;
    rdfs:comment 'Currency code used for settlement, may differ from transaction currency.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Settlement Timestamp' ;
    rdfs:comment 'Timestamp when the payment was settled with the acquiring bank.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderPromotionId rdf:type rdf:Property ;
    rdfs:label 'Order Promotion Id' ;
    rdfs:comment 'Unique identifier for the order promotion record.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliedOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Applied Order Line Id' ;
    rdfs:comment 'Identifier of the specific order line to which the promotion was applied, when applicable.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:merchandisingRuleId rdf:type rdf:Property ;
    rdfs:label 'Merchandising Rule Id' ;
    rdfs:comment 'Foreign key linking to search.merchandising_rule. Business justification: Allows analysis of promotion effectiveness tied to specific merchandising rules, required for promotion performance reporting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchandisingRule .

ind:appliedBy rdf:type rdf:Property ;
    rdfs:label 'Applied By' ;
    rdfs:comment 'Mechanism that applied the promotion: system, customer service agent, or automated rule.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Applied Timestamp' ;
    rdfs:comment 'Exact time when the promotion was applied to the order.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Timestamp' ;
    rdfs:comment 'Timestamp of the most recent compliance verification.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:discountCurrency rdf:type rdf:Property ;
    rdfs:label 'Discount Currency' ;
    rdfs:comment 'Three-letter ISO 4217 code of the currency in which discount_amount is expressed.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityMessage rdf:type rdf:Property ;
    rdfs:label 'Eligibility Message' ;
    rdfs:comment 'Human-readable explanation when eligibility_status is ineligible or pending.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Eligibility Status' ;
    rdfs:comment 'Result of promotion eligibility validation for this order.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCombinationAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Combination Allowed' ;
    rdfs:comment 'Indicates if this promotion may be combined with other promotions beyond stacking_rule logic.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRefunded rdf:type rdf:Property ;
    rdfs:label 'Is Refunded' ;
    rdfs:comment 'Indicates whether the promotion discount was later reversed or refunded.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxUsesPerCustomer rdf:type rdf:Property ;
    rdfs:label 'Max Uses Per Customer' ;
    rdfs:comment 'Maximum total number of times a single customer may use this promotion.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxUsesPerOrder rdf:type rdf:Property ;
    rdfs:label 'Max Uses Per Order' ;
    rdfs:comment 'Maximum number of times this promotion can be applied within a single order.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Net Discount Amount' ;
    rdfs:comment 'Discount amount after tax adjustments, if applicable.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderPromotionDescription rdf:type rdf:Property ;
    rdfs:label 'Order Promotion Description' ;
    rdfs:comment 'Human-readable description of the promotion\'s purpose and mechanics.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionCategory rdf:type rdf:Property ;
    rdfs:label 'Promotion Category' ;
    rdfs:comment 'High-level classification of the promotion for reporting.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionSource rdf:type rdf:Property ;
    rdfs:label 'Promotion Source' ;
    rdfs:comment 'Origin of the promotion – marketing campaign, loyalty program, seller-funded, or system generated.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityApplied rdf:type rdf:Property ;
    rdfs:label 'Quantity Applied' ;
    rdfs:comment 'Number of discount units applied (e.g., number of items covered by a BOGO).' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Reference to the specific regulation or policy governing the promotion (e.g., GDPR, PCI DSS).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackingRule rdf:type rdf:Property ;
    rdfs:label 'Stacking Rule' ;
    rdfs:comment 'Rule that defines whether this promotion can be combined with other promotions.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExempt rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt' ;
    rdfs:comment 'Indicates whether the discount amount is exempt from sales tax.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderSlaId rdf:type rdf:Property ;
    rdfs:label 'Order Sla Id' ;
    rdfs:comment 'Unique surrogate key for each SLA commitment record.' ;
    rdfs:domain ind:OrderSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualHandlingTimeHours rdf:type rdf:Property ;
    rdfs:label 'Actual Handling Time Hours' ;
    rdfs:comment 'Observed time taken to handle the order before shipping, in hours.' ;
    rdfs:domain ind:OrderSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachFlag rdf:type rdf:Property ;
    rdfs:label 'Breach Flag' ;
    rdfs:comment 'True if any SLA metric was missed, otherwise False.' ;
    rdfs:domain ind:OrderSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachReason rdf:type rdf:Property ;
    rdfs:label 'Breach Reason' ;
    rdfs:comment 'Categorized cause for SLA breach when breach_flag is true.' ;
    rdfs:domain ind:OrderSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentType rdf:type rdf:Property ;
    rdfs:label 'Commitment Type' ;
    rdfs:comment 'Scope of the SLA (e.g., handling only, shipping only, delivery only, or full end-to-end).' ;
    rdfs:domain ind:OrderSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDateDeltaDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Date Delta Days' ;
    rdfs:comment 'Number of days the actual delivery date deviates from the promised delivery date.' ;
    rdfs:domain ind:OrderSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handlingTimeDeltaHours rdf:type rdf:Property ;
    rdfs:label 'Handling Time Delta Hours' ;
    rdfs:comment 'Difference between actual and promised handling time (positive = overrun).' ;
    rdfs:domain ind:OrderSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promisedHandlingTimeHours rdf:type rdf:Property ;
    rdfs:label 'Promised Handling Time Hours' ;
    rdfs:comment 'Maximum time allotted for order handling before shipping, expressed in hours.' ;
    rdfs:domain ind:OrderSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipDateDeltaDays rdf:type rdf:Property ;
    rdfs:label 'Ship Date Delta Days' ;
    rdfs:comment 'Number of days the actual ship date deviates from the promised ship date.' ;
    rdfs:domain ind:OrderSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaNumber rdf:type rdf:Property ;
    rdfs:label 'Sla Number' ;
    rdfs:comment 'Human-readable SLA code assigned by the Order Management System.' ;
    rdfs:domain ind:OrderSla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Status History Id' ;
    rdfs:comment 'Unique surrogate identifier for each status transition record.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actorType rdf:type rdf:Property ;
    rdfs:label 'Actor Type' ;
    rdfs:comment 'Category of the entity that triggered the status change.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comment rdf:type rdf:Property ;
    rdfs:label 'Comment' ;
    rdfs:comment 'Free-form text providing additional context for the status change.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSystemGenerated rdf:type rdf:Property ;
    rdfs:label 'Is System Generated' ;
    rdfs:comment 'Indicates whether the transition was automatically generated by the system (true) or manually entered (false).' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statusFrom rdf:type rdf:Property ;
    rdfs:label 'Status From' ;
    rdfs:comment 'The order status before the transition occurred.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusTo rdf:type rdf:Property ;
    rdfs:label 'Status To' ;
    rdfs:comment 'The order status after the transition occurred.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transition Timestamp' ;
    rdfs:comment 'Exact date-time when the status change was recorded.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxId rdf:type rdf:Property ;
    rdfs:label 'Tax Id' ;
    rdfs:comment 'Unique surrogate key for each tax line applied to an order.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tax .

ind:calculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation Timestamp' ;
    rdfs:comment 'Exact time when the tax engine performed the calculation.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:engineReference rdf:type rdf:Property ;
    rdfs:label 'Engine Reference' ;
    rdfs:comment 'Opaque identifier returned by the tax calculation engine for audit and traceability.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptFlag rdf:type rdf:Property ;
    rdfs:label 'Exempt Flag' ;
    rdfs:comment 'Indicates whether the tax was exempted for this order line (true = exempt, false = taxable).' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptionReason rdf:type rdf:Property ;
    rdfs:label 'Exemption Reason' ;
    rdfs:comment 'Reason code or description for tax exemption, if applicable.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'Code representing the tax jurisdiction (state, province, country) that governs the tax calculation.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nexusCountry rdf:type rdf:Property ;
    rdfs:label 'Nexus Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where tax nexus exists.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nexusState rdf:type rdf:Property ;
    rdfs:label 'Nexus State' ;
    rdfs:comment 'State or province code within the nexus country that creates tax liability.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rate rdf:type rdf:Property ;
    rdfs:label 'Rate' ;
    rdfs:comment 'Applicable tax rate expressed as a decimal (e.g., 0.0750 for 7.5%).' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Status' ;
    rdfs:comment 'Current processing status of the tax line.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionOrderId rdf:type rdf:Property ;
    rdfs:label 'Subscription Order Id' ;
    rdfs:comment 'Unique identifier for the subscription order record.' ;
    rdfs:domain ind:SubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subscriptionPlanId rdf:type rdf:Property ;
    rdfs:label 'Subscription Plan Id' ;
    rdfs:comment 'Identifier of the subscription plan associated with this order.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SubscriptionPlan .

ind:arrAmount rdf:type rdf:Property ;
    rdfs:label 'Arr Amount' ;
    rdfs:comment 'Revenue recognized on an annual basis from this subscription.' ;
    rdfs:domain ind:SubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoRenewFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Flag' ;
    rdfs:comment 'Indicates whether the subscription automatically renews after each cycle.' ;
    rdfs:domain ind:SubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'Recurrence interval for billing the subscription.' ;
    rdfs:domain ind:SubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPreference rdf:type rdf:Property ;
    rdfs:label 'Delivery Preference' ;
    rdfs:comment 'Customer-selected delivery option for recurring shipments.' ;
    rdfs:domain ind:SubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountRate rdf:type rdf:Property ;
    rdfs:label 'Discount Rate' ;
    rdfs:comment 'Percentage discount applied to the subscription.' ;
    rdfs:domain ind:SubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isTrial rdf:type rdf:Property ;
    rdfs:label 'Is Trial' ;
    rdfs:comment 'Indicates whether the subscription is currently in a trial period.' ;
    rdfs:domain ind:SubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date of the most recent successful payment for this subscription.' ;
    rdfs:domain ind:SubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mrrAmount rdf:type rdf:Property ;
    rdfs:label 'Mrr Amount' ;
    rdfs:comment 'Revenue recognized on a monthly basis from this subscription.' ;
    rdfs:domain ind:SubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextOrderDate rdf:type rdf:Property ;
    rdfs:label 'Next Order Date' ;
    rdfs:comment 'Date on which the next recurring order will be generated.' ;
    rdfs:domain ind:SubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Next Payment Date' ;
    rdfs:comment 'Scheduled date for the upcoming payment.' ;
    rdfs:domain ind:SubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recurringAmount rdf:type rdf:Property ;
    rdfs:label 'Recurring Amount' ;
    rdfs:comment 'Standard recurring charge for each billing cycle.' ;
    rdfs:domain ind:SubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalCycleCount rdf:type rdf:Property ;
    rdfs:label 'Renewal Cycle Count' ;
    rdfs:comment 'Number of completed renewal cycles for the subscription.' ;
    rdfs:domain ind:SubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skipCount rdf:type rdf:Property ;
    rdfs:label 'Skip Count' ;
    rdfs:comment 'Number of billing cycles the customer has chosen to skip.' ;
    rdfs:domain ind:SubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subscriptionTermMonths rdf:type rdf:Property ;
    rdfs:label 'Subscription Term Months' ;
    rdfs:comment 'Total length of the subscription contract in months.' ;
    rdfs:domain ind:SubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trialEndDate rdf:type rdf:Property ;
    rdfs:label 'Trial End Date' ;
    rdfs:comment 'Date when the trial period expires and regular billing begins.' ;
    rdfs:domain ind:SubscriptionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationId rdf:type rdf:Property ;
    rdfs:label 'Authorization Id' ;
    rdfs:comment 'System-generated unique identifier for the payment authorization record.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authAmount rdf:type rdf:Property ;
    rdfs:label 'Auth Amount' ;
    rdfs:comment 'Monetary amount requested for authorization, expressed in the transaction currency.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authCode rdf:type rdf:Property ;
    rdfs:label 'Auth Code' ;
    rdfs:comment 'Issuer-provided code confirming successful authorization.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Authorization Status' ;
    rdfs:comment 'Current lifecycle state of the authorization (e.g., authorized, declined, voided).' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avsResult rdf:type rdf:Property ;
