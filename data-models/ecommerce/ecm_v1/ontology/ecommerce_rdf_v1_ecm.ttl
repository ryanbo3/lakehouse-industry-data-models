ind:openGraphType rdf:type rdf:Property ;
    rdfs:label 'Open Graph Type' ;
    rdfs:comment 'Object type for Open Graph metadata. [ENUM-REF-CANDIDATE: website|article|product|video|profile|music|book — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SeoMetadata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageType rdf:type rdf:Property ;
    rdfs:label 'Page Type' ;
    rdfs:comment 'Classification of the page for SEO targeting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:robotsDirective rdf:type rdf:Property ;
    rdfs:label 'Robots Directive' ;
    rdfs:comment 'Robots meta tag directive controlling indexing and crawling.' ;
    rdfs:domain ind:SeoMetadata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seoMetadataStatus rdf:type rdf:Property ;
    rdfs:label 'Seo Metadata Status' ;
    rdfs:comment 'Current lifecycle status of the SEO metadata record.' ;
    rdfs:domain ind:SeoMetadata ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seoScore rdf:type rdf:Property ;
    rdfs:label 'Seo Score' ;
    rdfs:comment 'Calculated SEO quality score (0-100) for the page.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
