ind:assignmentEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment End Timestamp' ;
    rdfs:comment 'Date and time when the content assignment expires or is scheduled to be removed.' ;
    rdfs:domain ind:SlotAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assignment Method' ;
    rdfs:comment 'Process by which the assignment was created.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Timestamp' ;
    rdfs:comment 'Date and time when the content assignment becomes effective.' ;
    rdfs:domain ind:SlotAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Display priority of the assignment; lower numbers indicate higher priority for slot rendering.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slotAssignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Slot Assignment Status' ;
    rdfs:comment 'Current lifecycle state of the slot assignment.' ;
    rdfs:domain ind:SlotAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceApplication rdf:type rdf:Property ;
    rdfs:label 'Source Application' ;
    rdfs:comment 'Name of the upstream system or application that originated the assignment record.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagId rdf:type rdf:Property ;
    rdfs:label 'Tag Id' ;
    rdfs:comment 'Unique surrogate key for each tag record.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tag .

ind:parentTagId rdf:type rdf:Property ;
    rdfs:label 'Parent Tag Id' ;
    rdfs:comment 'Reference to the immediate parent tag in the hierarchy, if any.' ;
