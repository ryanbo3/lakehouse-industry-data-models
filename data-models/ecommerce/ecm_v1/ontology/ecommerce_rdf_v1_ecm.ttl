ind:partnerType rdf:type rdf:Property ;
    rdfs:label 'Partner Type' ;
    rdfs:comment 'Classification of the partner (e.g., logistics provider, carrier).' ;
    rdfs:domain ind:ThirdPartyFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Name of the main operational contact at the partner.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetTimeMinutes rdf:type rdf:Property ;
