    rdfs:range xsd:boolean .

ind:height rdf:type rdf:Property ;
    rdfs:label 'Height' ;
    rdfs:comment 'Height of the widget in grid units.' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isShared rdf:type rdf:Property ;
    rdfs:label 'Is Shared' ;
    rdfs:comment 'Indicates whether the widget is shared across multiple dashboards.' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

