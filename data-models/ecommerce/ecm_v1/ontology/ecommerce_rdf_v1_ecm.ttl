    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ratingSource rdf:type rdf:Property ;
    rdfs:label 'Rating Source' ;
    rdfs:comment 'Channel through which the rating was submitted: website, mobile app, or API.' ;
