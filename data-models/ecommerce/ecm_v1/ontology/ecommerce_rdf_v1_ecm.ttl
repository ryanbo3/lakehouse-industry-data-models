    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierPreference rdf:type rdf:Property ;
    rdfs:label 'Carrier Preference' ;
    rdfs:comment 'Preferred carrier or service level for the shipment.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimate rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate' ;
