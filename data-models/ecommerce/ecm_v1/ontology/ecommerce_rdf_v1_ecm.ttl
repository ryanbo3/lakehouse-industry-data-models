# --- Attribute Properties ---
ind:abTestResultId rdf:type rdf:Property ;
    rdfs:label 'Ab Test Result Id' ;
    rdfs:comment 'Unique identifier for the A/B test result record.' ;
    rdfs:domain ind:AbTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:abTestVariantId rdf:type rdf:Property ;
    rdfs:label 'Ab Test Variant Id' ;
    rdfs:comment 'Identifier of the specific variant (treatment) within the experiment.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AbTestVariant .

ind:attributionModelId rdf:type rdf:Property ;
    rdfs:label 'Attribution Model Id' ;
    rdfs:comment 'Foreign key linking to analytics.attribution_model. Business justification: AB test results can be analyzed using an attribution model; linking provides direct reference.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttributionModel .

ind:experimentId rdf:type rdf:Property ;
    rdfs:label 'Experiment Id' ;
    rdfs:comment 'Identifier of the experiment that generated this result.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Experiment .

ind:abTestResultStatus rdf:type rdf:Property ;
    rdfs:label 'Ab Test Result Status' ;
    rdfs:comment 'Current lifecycle status of the result record.' ;
    rdfs:domain ind:AbTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceIntervalLower rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Lower' ;
    rdfs:comment 'Lower bound of the confidence interval for the lift.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceIntervalUpper rdf:type rdf:Property ;
    rdfs:label 'Confidence Interval Upper' ;
    rdfs:comment 'Upper bound of the confidence interval for the lift.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'Confidence level (e.g., 95.0 for 95% confidence) used for the interval.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlValue rdf:type rdf:Property ;
    rdfs:label 'Control Value' ;
    rdfs:comment 'Measured value of the metric for the control group.' ;
    rdfs:domain ind:AbTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when the result record was first created in the system.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventPayload rdf:type rdf:Property ;
    rdfs:label 'Event Payload' ;
    rdfs:comment 'Serialized JSON payload containing raw result details; retained for audit.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Classification of the event; for this entity always \'result\'.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experimentEndDate rdf:type rdf:Property ;
    rdfs:label 'Experiment End Date' ;
    rdfs:comment 'Date when the experiment concluded or was stopped.' ;
    rdfs:domain ind:AbTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:experimentStartDate rdf:type rdf:Property ;
    rdfs:label 'Experiment Start Date' ;
    rdfs:comment 'Date when the experiment began.' ;
    rdfs:domain ind:AbTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isStatisticallySignificant rdf:type rdf:Property ;
    rdfs:label 'Is Statistically Significant' ;
    rdfs:comment 'True if the result meets the predefined significance threshold.' ;
    rdfs:domain ind:AbTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:metricName rdf:type rdf:Property ;
    rdfs:label 'Metric Name' ;
    rdfs:comment 'Name of the business metric evaluated in the experiment (e.g., conversion_rate, revenue_per_user).' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observedValue rdf:type rdf:Property ;
    rdfs:label 'Observed Value' ;
    rdfs:comment 'Measured value of the metric for the variant.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pValue rdf:type rdf:Property ;
    rdfs:label 'P Value' ;
    rdfs:comment 'Statistical p-value indicating significance of the observed lift.' ;
    rdfs:domain ind:AbTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relativeLift rdf:type rdf:Property ;
    rdfs:label 'Relative Lift' ;
    rdfs:comment 'Percentage lift of the variant over the control (observed_value - control_value) / control_value.' ;
    rdfs:domain ind:AbTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resultRecordedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Result Recorded Timestamp' ;
    rdfs:comment 'Timestamp when this result record was captured (event timestamp).' ;
    rdfs:domain ind:AbTestResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Number of users or sessions included in the experiment for this variant.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testType rdf:type rdf:Property ;
    rdfs:label 'Test Type' ;
    rdfs:comment 'Type of experiment: A/B test or multivariate test.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the result record.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:analyticalDatasetId rdf:type rdf:Property ;
    rdfs:label 'Analytical Dataset Id' ;
    rdfs:comment 'Unique surrogate key for each analytical dataset record.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AnalyticalDataset .

ind:categoryId rdf:type rdf:Property ;
    rdfs:label 'Category Id' ;
    rdfs:comment 'Foreign key linking to product.product_category. Business justification: Datasets that store category-level aggregates reference product_category for lineage and SLA enforcement.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:programId rdf:type rdf:Property ;
    rdfs:label 'Program Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_program. Business justification: Analytical datasets are curated for compliance program reporting; the FK identifies which program consumes the dataset for audit and monitoring.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:reportDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Report Definition Id' ;
    rdfs:comment 'Foreign key linking to analytics.report_definition. Business justification: Analytical datasets are the source for scheduled reports; linking dataset to report definition enables traceability.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReportDefinition .

ind:analyticalDatasetDescription rdf:type rdf:Property ;
    rdfs:label 'Analytical Dataset Description' ;
    rdfs:comment 'Detailed business description of the dataset purpose, contents, and usage.' ;
    rdfs:domain ind:AnalyticalDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumerSla rdf:type rdf:Property ;
    rdfs:label 'Consumer Sla' ;
    rdfs:comment 'Service-level agreement describing availability and latency expectations for dataset consumers.' ;
    rdfs:domain ind:AnalyticalDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataClassification rdf:type rdf:Property ;
    rdfs:label 'Data Classification' ;
    rdfs:comment 'Classification level indicating data sensitivity and handling requirements.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:datasetName rdf:type rdf:Property ;
    rdfs:label 'Dataset Name' ;
    rdfs:comment 'Human-readable name of the curated analytical dataset.' ;
    rdfs:domain ind:AnalyticalDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:domain rdf:type rdf:Property ;
    rdfs:label 'Domain' ;
    rdfs:comment 'Business domain to which the dataset belongs (e.g., core, marketing, finance).' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grain rdf:type rdf:Property ;
    rdfs:label 'Grain' ;
    rdfs:comment 'Level of granularity of the dataset (e.g., per order, per customer, per product). [ENUM-REF-CANDIDATE: order|customer|product|inventory|payment|session|daily|hourly — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether the dataset is currently active and available for consumption.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Timestamp' ;
    rdfs:comment 'Date-time when the dataset was last refreshed from its source systems.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'Email address of the business owner responsible for the dataset.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rowCount rdf:type rdf:Property ;
    rdfs:label 'Row Count' ;
    rdfs:comment 'Number of rows currently stored in the dataset.' ;
    rdfs:domain ind:Analytics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:schemaVersion rdf:type rdf:Property ;
    rdfs:label 'Schema Version' ;
    rdfs:comment 'Version identifier of the dataset schema following semantic versioning.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Originating operational system that supplies the raw data for the dataset (e.g., OMS, WMS, PIM, CDP, ERP). [ENUM-REF-CANDIDATE: oms|wms|pim|cdp|payment_gateway|erp|tms|marketing_automation|search_engine|seller_portal — promote to reference product]' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storagePath rdf:type rdf:Property ;
    rdfs:label 'Storage Path' ;
    rdfs:comment 'File system or object store location where the dataset resides.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updateFrequency rdf:type rdf:Property ;
    rdfs:label 'Update Frequency' ;
    rdfs:comment 'How often the dataset is refreshed or recomputed.' ;
    rdfs:domain ind:AnalyticalDataset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionModelCode rdf:type rdf:Property ;
    rdfs:label 'Attribution Model Code' ;
    rdfs:comment 'Business code used to reference the model in external systems.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionModelDescription rdf:type rdf:Property ;
    rdfs:label 'Attribution Model Description' ;
    rdfs:comment 'Detailed free-text description of the model purpose and logic.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionModelName rdf:type rdf:Property ;
    rdfs:label 'Attribution Model Name' ;
    rdfs:comment 'Human-readable name of the attribution model.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionModelStatus rdf:type rdf:Property ;
    rdfs:label 'Attribution Model Status' ;
    rdfs:comment 'Current lifecycle state of the attribution model.' ;
    rdfs:domain ind:AttributionModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionType rdf:type rdf:Property ;
    rdfs:label 'Attribution Type' ;
    rdfs:comment 'Method used to assign conversion credit across touchpoints.' ;
