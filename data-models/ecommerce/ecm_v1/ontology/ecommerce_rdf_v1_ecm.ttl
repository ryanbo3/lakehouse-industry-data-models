    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thirdPartyFulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Third Party Fulfillment Status' ;
    rdfs:comment 'Current lifecycle status of the partner relationship.' ;
    rdfs:domain ind:ThirdPartyFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Id' ;
    rdfs:comment 'Unique identifier for the inventory adjustment transaction. Primary key.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cycleCountId rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Id' ;
    rdfs:comment 'Reference to the originating cycle count event that triggered this adjustment, if applicable. Supports traceability from physical count to financial reconciliation.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CycleCount .

ind:investigationId rdf:type rdf:Property ;
    rdfs:label 'Investigation Id' ;
    rdfs:comment 'Reference to the inventory discrepancy investigation or loss prevention case that resulted in this adjustment. Links to root cause analysis workflows.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investigation .

ind:originalAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Original Adjustment Id' ;
    rdfs:comment 'Reference to the original adjustment transaction being reversed, if this record is a reversal. Maintains audit trail for corrections.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Adjustment .

ind:adjustedQuantity rdf:type rdf:Property ;
    rdfs:label 'Adjusted Quantity' ;
    rdfs:comment 'The net quantity change applied to inventory. Positive values indicate additions to stock; negative values indicate reductions. Measured in the SKU\'s unit of measure (UOM).' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustedValue rdf:type rdf:Property ;
    rdfs:label 'Adjusted Value' ;
    rdfs:comment 'The total financial value of the adjustment, calculated as adjusted_quantity × unit_cost. Represents the General Ledger (GL) impact for inventory write-offs or additions.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Number' ;
    rdfs:comment 'Human-readable business identifier for the adjustment transaction, typically formatted as ADJ-YYYYMMDD-NNNN for external reference and audit trail.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current lifecycle state of the adjustment transaction. Controls whether the adjustment has been applied to inventory balances and financial ledgers.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjustment Timestamp' ;
    rdfs:comment 'The date and time when the physical or system adjustment event occurred. Distinct from record creation timestamp; represents the real-world business event time.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Classification of the adjustment reason. Determines financial treatment and operational follow-up actions. [ENUM-REF-CANDIDATE: shrinkage|damage|count_variance|system_error|expiry_write_off|return_to_stock|transfer_correction|theft|obsolescence — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Authorized By User Code' ;
    rdfs:comment 'Identifier of the user who approved and authorized the adjustment. Required for segregation of duties and audit compliance.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByUserCode rdf:type rdf:Property ;
    rdfs:label 'Created By User Code' ;
    rdfs:comment 'Identifier of the user who initiated or recorded the adjustment transaction in the system.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'External Reference Number' ;
    rdfs:comment 'Optional reference to an external document or transaction ID, such as a Return Merchandise Authorization (RMA) number, supplier claim, or insurance case number.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedToGlFlag rdf:type rdf:Property ;
    rdfs:label 'Posted To Gl Flag' ;
    rdfs:comment 'Indicates whether the adjustment has been posted to the financial General Ledger. True when the financial impact has been recorded in the ERP system.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityAfterAdjustment rdf:type rdf:Property ;
    rdfs:label 'Quantity After Adjustment' ;
    rdfs:comment 'The resulting on-hand inventory quantity after the adjustment is applied. Calculated as quantity_before_adjustment + adjusted_quantity.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityBeforeAdjustment rdf:type rdf:Property ;
    rdfs:label 'Quantity Before Adjustment' ;
    rdfs:comment 'The on-hand inventory quantity recorded in the system immediately prior to the adjustment. Provides audit trail for variance analysis.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Detailed reason code providing granular classification for the adjustment. Used for root cause analysis and loss prevention reporting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this adjustment is a reversal of a previously posted adjustment. True when correcting an erroneous prior adjustment.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sku rdf:type rdf:Property ;
    rdfs:label 'Sku' ;
    rdfs:comment 'The unique product identifier for which inventory is being adjusted. Links to the product catalog for item-level traceability.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'The per-unit cost of the SKU at the time of adjustment, used to calculate the financial impact. Sourced from the Enterprise Resource Planning (ERP) system\'s inventory valuation layer.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zoneId rdf:type rdf:Property ;
    rdfs:label 'Zone Id' ;
    rdfs:comment 'Warehouse zone or area being counted. Used for zone-based cycle counting programs.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Zone .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'ABC classification of the SKU (Stock Keeping Unit) being counted: A (high-value, frequent count), B (medium-value, moderate count), C (low-value, infrequent count). Drives cycle count frequency.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Timestamp when the cycle count task was completed. Used to calculate count duration and productivity metrics.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Timestamp when the cycle count task actually began. Used to track SLA (Service Level Agreement) compliance and operational efficiency.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adjustmentPostedFlag rdf:type rdf:Property ;
    rdfs:label 'Adjustment Posted Flag' ;
    rdfs:comment 'Indicates whether the inventory adjustment has been posted to the WMS (Warehouse Management System) and ERP (Enterprise Resource Planning) systems. True if posted, false if pending.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustmentPostedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjustment Posted Timestamp' ;
    rdfs:comment 'Timestamp when the inventory adjustment was posted to the system of record. Used for financial reconciliation and audit trail.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Approved By User Code' ;
    rdfs:comment 'Identifier of the supervisor or manager who approved the cycle count results. Links to employee master data.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedCounterName rdf:type rdf:Property ;
    rdfs:label 'Assigned Counter Name' ;
    rdfs:comment 'Name of the warehouse employee assigned to perform the cycle count. Used for reporting and accountability.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedCounterUserCode rdf:type rdf:Property ;
    rdfs:label 'Assigned Counter User Code' ;
    rdfs:comment 'Identifier of the warehouse employee assigned to perform the cycle count. Links to employee master data.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Count Duration Minutes' ;
    rdfs:comment 'Total time in minutes taken to complete the cycle count task. Calculated from actual start and end timestamps. Used for productivity analysis.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countMethod rdf:type rdf:Property ;
    rdfs:label 'Count Method' ;
    rdfs:comment 'Method used to perform the physical count: manual (visual count), rfid (radio frequency identification), barcode_scan (handheld scanner), or automated (system-driven).' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countNumber rdf:type rdf:Property ;
    rdfs:label 'Count Number' ;
    rdfs:comment 'Business identifier for the cycle count task. Human-readable reference number used in WMS and reporting.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countStatus rdf:type rdf:Property ;
    rdfs:label 'Count Status' ;
    rdfs:comment 'Current lifecycle status of the cycle count task: scheduled (planned), assigned (allocated to counter), in_progress (counting underway), completed (count finished), reconciled (variance resolved), or cancelled.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countType rdf:type rdf:Property ;
    rdfs:label 'Count Type' ;
    rdfs:comment 'Type of cycle count being performed: full (complete inventory), partial (sample), abc (frequency-based), blind (no expected quantity shown), or spot (random verification).' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countedQuantity rdf:type rdf:Property ;
    rdfs:label 'Counted Quantity' ;
    rdfs:comment 'Actual physical quantity counted by the warehouse employee. This is the observed inventory level.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Expected Quantity' ;
    rdfs:comment 'System-recorded quantity expected to be found during the count. Sourced from WMS (Warehouse Management System) inventory records.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryValueVariance rdf:type rdf:Property ;
    rdfs:label 'Inventory Value Variance' ;
    rdfs:comment 'Financial impact of the variance calculated as variance quantity multiplied by unit cost. Used for financial reporting and shrinkage analysis.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recountNumber rdf:type rdf:Property ;
    rdfs:label 'Recount Number' ;
    rdfs:comment 'Sequential number indicating which recount attempt this is (1 for first recount, 2 for second, etc.). Zero if no recount performed.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recountRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recount Required Flag' ;
    rdfs:comment 'Indicates whether a recount is required due to variance exceeding tolerance threshold. True if recount needed, false otherwise.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'Date when the cycle count task is scheduled to be performed. Used for planning and resource allocation.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'Precise timestamp when the cycle count task is scheduled to begin. Used for shift planning and resource scheduling.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:varianceNotes rdf:type rdf:Property ;
    rdfs:label 'Variance Notes' ;
    rdfs:comment 'Free-text notes explaining the variance, corrective actions taken, or additional context. Used for root cause analysis and continuous improvement.' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'Variance expressed as a percentage of expected quantity. Used to assess inventory accuracy and trigger investigation thresholds.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'Difference between expected and counted quantities (counted minus expected). Positive indicates overage, negative indicates shortage.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Categorized reason for inventory variance: damaged (product damage), theft (shrinkage), miscount (counting error), system_error (WMS issue), receiving_error (inbound error), picking_error (outbound error), or other. [ENUM-REF-CANDIDATE: damaged|theft|miscount|system_error|receiving_error|picking_error|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CycleCount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdId rdf:type rdf:Property ;
    rdfs:label 'Hold Id' ;
    rdfs:comment 'Unique identifier for the inventory hold record. Primary key.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceSupportCaseId rdf:type rdf:Property ;
    rdfs:label 'Service Support Case Id' ;
    rdfs:comment 'Foreign key linking to service.service_support_case. Business justification: Required for audit: when a support case triggers a hold on inventory, linking enables case-to-hold traceability for SLA and compliance reporting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceSupportCase .

ind:atpImpactQuantity rdf:type rdf:Property ;
    rdfs:label 'Atp Impact Quantity' ;
    rdfs:comment 'Quantity of ATP inventory reduced due to this hold, impacting order fulfillment capacity and inventory availability reporting.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authority rdf:type rdf:Property ;
    rdfs:label 'Authority' ;
    rdfs:comment 'Name or identifier of the authority that placed the hold (e.g., QA Team, CPSC, Legal Department, Supplier Name, Regulatory Body).' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityContact rdf:type rdf:Property ;
    rdfs:label 'Authority Contact' ;
    rdfs:comment 'Contact information (email or phone) for the authority responsible for the hold, used for resolution coordination.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpscComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Cpsc Compliance Flag' ;
    rdfs:comment 'Indicates whether this hold is compliant with CPSC recall and quarantine requirements for consumer product safety.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispositionDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Date' ;
    rdfs:comment 'Date when the disposition decision was executed and the inventory was moved to its final state.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionDecision rdf:type rdf:Property ;
    rdfs:label 'Disposition Decision' ;
    rdfs:comment 'Final decision on what to do with the held inventory: return to stock (release to available), destroy (dispose of), return to supplier (RMA), donate (charitable contribution), rework (repair or repackage), or scrap (write off).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'Precise timestamp when the hold was released or resolved. Null if hold is still active.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Estimated financial impact of the hold in terms of inventory value at cost, used for financial reporting and variance analysis.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'Date when the inspection or quality review was completed. Null if inspection has not occurred.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionOutcome rdf:type rdf:Property ;
    rdfs:label 'Inspection Outcome' ;
    rdfs:comment 'Result of the inspection or quality review conducted on the held inventory: pass (cleared for release), fail (remains quarantined), conditional pass (partial release), pending (inspection in progress), or not applicable.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Required Flag' ;
    rdfs:comment 'Indicates whether a formal inspection or quality check is required before the hold can be released.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Quantity of inventory units placed under this hold, preventing allocation or shipment.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Detailed free-text explanation of why the hold was placed, including root cause and context.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recallFlag rdf:type rdf:Property ;
    rdfs:label 'Recall Flag' ;
    rdfs:comment 'Indicates whether this hold is associated with a product recall issued by CPSC or other regulatory body.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recallNumber rdf:type rdf:Property ;
    rdfs:label 'Recall Number' ;
    rdfs:comment 'Official recall identification number issued by CPSC or regulatory authority, if this hold is part of a recall action.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseConditions rdf:type rdf:Property ;
    rdfs:label 'Release Conditions' ;
    rdfs:comment 'Detailed description of the conditions that must be met before the hold can be released (e.g., pass re-inspection, receive supplier credit, legal clearance obtained).' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimelineDays rdf:type rdf:Property ;
    rdfs:label 'Resolution Timeline Days' ;
    rdfs:comment 'Target number of days within which the hold should be resolved, based on hold type and priority level.' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rootCauseClassification rdf:type rdf:Property ;
    rdfs:label 'Root Cause Classification' ;
    rdfs:comment 'Standardized classification of the root cause that led to the hold (e.g., supplier defect, transit damage, regulatory non-compliance, system error).' ;
    rdfs:domain ind:Hold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Updated By User Code' ;
    rdfs:comment 'Identifier of the user or system process that last updated this hold record.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inboundShipmentId rdf:type rdf:Property ;
    rdfs:label 'Inbound Shipment Id' ;
    rdfs:comment 'Unique identifier for the inbound shipment record. Primary key for this entity.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationWarehouseNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Warehouse Node Id' ;
    rdfs:comment 'Identifier of the destination warehouse node where this inbound shipment will be received and processed. Links to warehouse node master data.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseNode .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Actual date and time when the inbound shipment physically arrived at the destination warehouse receiving dock. Captured by WMS gate check-in.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appointmentNumber rdf:type rdf:Property ;
    rdfs:label 'Appointment Number' ;
    rdfs:comment 'Unique identifier for the scheduled receiving appointment in the warehouse dock scheduling system. Links to yard management system.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asnReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Reference Number' ;
    rdfs:comment 'External reference number from the Advanced Shipping Notice document provided by the supplier or origin facility. Used for cross-system reconciliation and tracking.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Timestamp when the inbound shipment record was administratively closed in the system. All discrepancies resolved and inventory posted to general ledger.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:discrepancyNotes rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Notes' ;
    rdfs:comment 'Free-text description of discrepancies found during receiving process. Provides detailed context for exception resolution and supplier communication.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyType rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Type' ;
    rdfs:comment 'Classification of the primary discrepancy detected during receiving. Used for root cause analysis and supplier performance tracking.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dockDoorNumber rdf:type rdf:Property ;
    rdfs:label 'Dock Door Number' ;
    rdfs:comment 'Physical dock door or bay number where this inbound shipment was received. Used for warehouse operations tracking and labor assignment.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Value Amount' ;
    rdfs:comment 'Estimated total monetary value of the inventory in this inbound shipment. Used for insurance coverage and customs declaration purposes.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Expected Arrival Date' ;
    rdfs:comment 'Planned date when the inbound shipment is expected to arrive at the destination warehouse node. Used for dock scheduling and labor planning.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hasDiscrepancyFlag rdf:type rdf:Property ;
    rdfs:label 'Has Discrepancy Flag' ;
    rdfs:comment 'Boolean indicator whether any discrepancies were detected during receiving process. Triggers exception handling workflow when true.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatClass rdf:type rdf:Property ;
    rdfs:label 'Hazmat Class' ;
    rdfs:comment 'UN hazard classification code for dangerous goods in this shipment. Determines storage location and handling procedures.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current status of quality inspection process for this inbound shipment. Determines whether inventory can be released to available stock.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originLocationCode rdf:type rdf:Property ;
    rdfs:label 'Origin Location Code' ;
    rdfs:comment 'Code identifying the origin facility, warehouse, or distribution center from which the shipment was dispatched. May be a supplier facility or internal transfer origin.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Po Reference Number' ;
    rdfs:comment 'Reference to the originating purchase order that triggered this inbound shipment. Links procurement to receiving workflows.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receiving Completed Timestamp' ;
    rdfs:comment 'Timestamp when all items in the inbound shipment have been physically received, inspected, and put away into inventory locations. Marks completion of receiving workflow.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receivingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receiving Start Timestamp' ;
    rdfs:comment 'Timestamp when warehouse personnel began the physical receiving process for this inbound shipment. Marks transition from arrived to receiving status.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requiresInspectionFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Inspection Flag' ;
    rdfs:comment 'Boolean indicator whether this inbound shipment requires quality inspection before inventory availability. Applies to regulated products or high-value items.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sealIntactFlag rdf:type rdf:Property ;
    rdfs:label 'Seal Intact Flag' ;
    rdfs:comment 'Boolean indicator whether the security seal was intact upon arrival. False value triggers security investigation and enhanced inspection.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'Security seal number applied to the container or trailer. Verified at receiving to ensure shipment integrity and prevent tampering.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentMethod rdf:type rdf:Property ;
    rdfs:label 'Shipment Method' ;
    rdfs:comment 'Transportation mode used for this inbound shipment. Determines handling requirements and expected transit times.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the inbound shipment. Tracks progression from scheduling through final closure in the warehouse management system. [ENUM-REF-CANDIDATE: scheduled|in_transit|arrived|receiving|received|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Boolean indicator whether this inbound shipment requires temperature-controlled handling. Applies to cold chain and perishable goods.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Max C' ;
    rdfs:comment 'Maximum acceptable temperature in Celsius for temperature-controlled shipments. Excursions trigger quality hold and investigation.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Min C' ;
    rdfs:comment 'Minimum acceptable temperature in Celsius for temperature-controlled shipments. Used for cold chain compliance verification.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCartonCount rdf:type rdf:Property ;
    rdfs:label 'Total Carton Count' ;
    rdfs:comment 'Total number of cartons or cases in this inbound shipment. Used for receiving verification and discrepancy detection.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPalletCount rdf:type rdf:Property ;
    rdfs:label 'Total Pallet Count' ;
    rdfs:comment 'Total number of pallets or handling units in this inbound shipment. Used for dock space planning and material handling resource allocation.' ;
    rdfs:domain ind:InboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnitCount rdf:type rdf:Property ;
    rdfs:label 'Total Unit Count' ;
    rdfs:comment 'Total number of individual units across all SKUs in this inbound shipment. Represents the sum of all line-level quantities.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryGoodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Inventory Goods Receipt Id' ;
    rdfs:comment 'Unique identifier for the inventory goods receipt transaction. Primary key for this entity.' ;
    rdfs:domain ind:InventoryGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptedUnitCount rdf:type rdf:Property ;
    rdfs:label 'Accepted Unit Count' ;
    rdfs:comment 'Total number of units that passed quality inspection and were accepted into inventory.' ;
    rdfs:domain ind:InventoryGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Bill of lading number provided by the carrier as proof of shipment and receipt.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerCount rdf:type rdf:Property ;
    rdfs:label 'Container Count' ;
    rdfs:comment 'Number of shipping containers, pallets, or packages included in this receipt.' ;
    rdfs:domain ind:InventoryGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedUnitCount rdf:type rdf:Property ;
    rdfs:label 'Expected Unit Count' ;
    rdfs:comment 'Total number of units that were expected to be received based on the purchase order or ASN.' ;
    rdfs:domain ind:InventoryGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:freightCost rdf:type rdf:Property ;
    rdfs:label 'Freight Cost' ;
    rdfs:comment 'Transportation and freight charges associated with this inbound shipment.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Completion Timestamp' ;
    rdfs:comment 'Date and time when quality inspection was completed for this receipt.' ;
    rdfs:domain ind:InventoryGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'Name of the warehouse personnel or quality inspector who performed the receiving inspection.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originLocation rdf:type rdf:Property ;
    rdfs:label 'Origin Location' ;
    rdfs:comment 'Geographic location or facility from which the shipment originated (supplier warehouse, manufacturing plant, or distribution center).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Status of the quality inspection process for this goods receipt. Determines whether goods can be released to inventory.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Completion Timestamp' ;
    rdfs:comment 'Date and time when the receiving process was completed and all items were accounted for.' ;
    rdfs:domain ind:InventoryGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Externally-known unique business identifier for this goods receipt transaction. Used for tracking and reference across systems.' ;
    rdfs:domain ind:InventoryGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Start Timestamp' ;
    rdfs:comment 'Date and time when warehouse personnel began the physical receiving process (unloading and inspection).' ;
    rdfs:domain ind:InventoryGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Current lifecycle status of the goods receipt process. Tracks progression from shipment notification through final putaway completion. [ENUM-REF-CANDIDATE: in_transit|arrived|at_dock|receiving|putaway|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InventoryGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingNotes rdf:type rdf:Property ;
    rdfs:label 'Receiving Notes' ;
    rdfs:comment 'General notes or comments recorded by receiving personnel during the goods receipt process.' ;
    rdfs:domain ind:InventoryGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordedTemperature rdf:type rdf:Property ;
    rdfs:label 'Recorded Temperature' ;
    rdfs:comment 'Temperature recorded upon receipt for temperature-sensitive shipments, measured in degrees Celsius.' ;
    rdfs:domain ind:InventoryGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectedUnitCount rdf:type rdf:Property ;
    rdfs:label 'Rejected Unit Count' ;
    rdfs:comment 'Total number of units that failed quality inspection and were rejected or quarantined.' ;
    rdfs:domain ind:InventoryGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalReceiptCost rdf:type rdf:Property ;
    rdfs:label 'Total Receipt Cost' ;
    rdfs:comment 'Total landed cost of all goods received in this transaction, including unit costs and any applicable freight or handling charges.' ;
    rdfs:domain ind:InventoryGoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotId rdf:type rdf:Property ;
    rdfs:label 'Lot Id' ;
    rdfs:comment 'Unique identifier for the inventory lot or batch record. Primary key for the lot entity.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lot .

ind:availableQuantity rdf:type rdf:Property ;
    rdfs:label 'Available Quantity' ;
    rdfs:comment 'Current quantity of units available for allocation and order fulfillment. Updated in real-time as inventory is allocated or consumed.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchReference rdf:type rdf:Property ;
    rdfs:label 'Batch Reference' ;
    rdfs:comment 'Supplier or manufacturer batch reference code used for cross-referencing with supplier records and quality documentation.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerUnit rdf:type rdf:Property ;
    rdfs:label 'Cost Per Unit' ;
    rdfs:comment 'Landed cost per unit for this lot including purchase price, freight, duties, and handling. Used for inventory valuation and Cost of Goods Sold (COGS) calculation.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'Three-letter ISO country code indicating where the product was manufactured or produced. Required for customs, trade compliance, and tariff classification.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Date' ;
    rdfs:comment 'Date of the most recent physical cycle count for this lot. Supports inventory accuracy and shrinkage tracking.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cycleCountVariance rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Variance' ;
    rdfs:comment 'Difference between system quantity and physical count during the most recent cycle count. Positive values indicate overage, negative indicate shortage.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fifoSequence rdf:type rdf:Property ;
    rdfs:label 'Fifo Sequence' ;
    rdfs:comment 'Numeric sequence position for First In First Out (FIFO) allocation logic. Lower numbers are allocated first to minimize expiry risk.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holdReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Hold Release Date' ;
    rdfs:comment 'Date when the lot was released from hold or quarantine status and made available for allocation. Null if lot is still on hold.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifoSequence rdf:type rdf:Property ;
    rdfs:label 'Lifo Sequence' ;
    rdfs:comment 'Numeric sequence position for Last In First Out (LIFO) allocation logic. Higher numbers are allocated first for specific inventory strategies.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lotStatus rdf:type rdf:Property ;
    rdfs:label 'Lot Status' ;
    rdfs:comment 'Current lifecycle status of the lot. Determines whether inventory is available for allocation, under quality hold, expired, or subject to recall.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotType rdf:type rdf:Property ;
    rdfs:label 'Lot Type' ;
    rdfs:comment 'Classification of the lot based on handling requirements. Determines storage conditions, expiry tracking, and regulatory compliance needs.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Date when the product lot was manufactured or produced. Critical for shelf-life calculation and First In First Out (FIFO) sequencing.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityGrade rdf:type rdf:Property ;
    rdfs:label 'Quality Grade' ;
    rdfs:comment 'Quality classification assigned during goods receipt inspection. Determines pricing tier, allocation priority, and disposition rules.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineQuantity rdf:type rdf:Property ;
    rdfs:label 'Quarantine Quantity' ;
    rdfs:comment 'Quantity of units placed on quality hold pending inspection or testing. Not available for allocation until released.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recallDate rdf:type rdf:Property ;
    rdfs:label 'Recall Date' ;
    rdfs:comment 'Date when the recall was initiated for this lot. Used for compliance reporting and customer notification timelines.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recallReason rdf:type rdf:Property ;
    rdfs:label 'Recall Reason' ;
    rdfs:comment 'Description of the reason for the product recall. Supports root cause analysis, customer communication, and regulatory reporting.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date when the lot was received into the warehouse. Marks the start of inventory availability and FIFO sequencing position.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'Original quantity of units received into inventory for this lot. Baseline for calculating remaining stock and depletion rate.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageZone rdf:type rdf:Property ;
    rdfs:label 'Storage Zone' ;
    rdfs:comment 'Warehouse zone classification based on environmental or security requirements. Determines handling procedures and storage costs.' ;
    rdfs:domain ind:Lot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oosEventId rdf:type rdf:Property ;
    rdfs:label 'Oos Event Id' ;
    rdfs:comment 'Unique identifier for the out-of-stock event record.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OosEvent .

ind:replenishmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Replenishment Order Id' ;
    rdfs:comment 'Identifier of the purchase order or replenishment order created to resolve this OOS event.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReplenishmentOrder .

ind:actualReplenishmentDays rdf:type rdf:Property ;
    rdfs:label 'Actual Replenishment Days' ;
    rdfs:comment 'The actual number of days it took to replenish inventory and resolve the OOS event, measured from OOS start to end.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedOrderCount rdf:type rdf:Property ;
    rdfs:label 'Affected Order Count' ;
    rdfs:comment 'Number of customer orders that were impacted, cancelled, or could not be fulfilled due to this OOS event.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedTo rdf:type rdf:Property ;
    rdfs:label 'Assigned To' ;
    rdfs:comment 'Name or identifier of the team member or role responsible for managing and resolving this OOS event.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerImpactScore rdf:type rdf:Property ;
    rdfs:label 'Customer Impact Score' ;
    rdfs:comment 'Calculated score representing the severity of customer experience impact from this OOS event, based on affected orders, customer tier, and product importance.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demandSpikeFactor rdf:type rdf:Property ;
    rdfs:label 'Demand Spike Factor' ;
    rdfs:comment 'Multiplier representing how much actual demand exceeded forecasted demand during the OOS event (e.g., 2.5 means demand was 250% of forecast).' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detectedBy rdf:type rdf:Property ;
    rdfs:label 'Detected By' ;
    rdfs:comment 'The source or method by which the OOS event was detected (automated system, manual audit, customer complaint, warehouse staff, demand planner).' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dsrAtOos rdf:type rdf:Property ;
    rdfs:label 'Dsr At Oos' ;
    rdfs:comment 'The average daily sales rate for this SKU at this location calculated at the time the OOS event occurred, used for replenishment velocity planning.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLostRevenue rdf:type rdf:Property ;
    rdfs:label 'Estimated Lost Revenue' ;
    rdfs:comment 'Calculated estimate of revenue lost due to the OOS event based on historical sales velocity and average selling price.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastAccuracyPct rdf:type rdf:Property ;
    rdfs:label 'Forecast Accuracy Pct' ;
    rdfs:comment 'The demand forecast accuracy percentage for this SKU in the period leading up to the OOS event, used to assess forecast miss as root cause.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryLevelAtOos rdf:type rdf:Property ;
    rdfs:label 'Inventory Level At Oos' ;
    rdfs:comment 'The inventory quantity recorded at the moment the OOS event was triggered (typically zero or below safety stock threshold).' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'The standard supplier lead time in days for replenishing this SKU, used to assess whether replenishment delay contributed to the OOS event.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lostUnitSales rdf:type rdf:Property ;
    rdfs:label 'Lost Unit Sales' ;
    rdfs:comment 'Estimated number of product units that could not be sold during the OOS period based on demand forecasts and historical sales rate.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oosDurationHours rdf:type rdf:Property ;
    rdfs:label 'Oos Duration Hours' ;
    rdfs:comment 'Total duration of the OOS event measured in hours from start to end (or to current time if ongoing).' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oosEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Oos End Timestamp' ;
    rdfs:comment 'The exact date and time when inventory was replenished and the OOS condition ended. Null if still out of stock.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:oosStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Oos Start Timestamp' ;
    rdfs:comment 'The exact date and time when the SKU inventory reached zero and the OOS condition began.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:oosStatus rdf:type rdf:Property ;
    rdfs:label 'Oos Status' ;
    rdfs:comment 'Current lifecycle status of the OOS event (active if still out of stock, resolved if inventory replenished, pending replenishment if order placed, cancelled if event invalidated).' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'The product category or classification of the SKU experiencing the OOS event, used for category-level OOS rate analysis.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalEventFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Event Flag' ;
    rdfs:comment 'Indicates whether a promotional campaign or marketing event was active during the OOS event, potentially causing demand spike.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'The inventory level threshold that should have triggered replenishment action to prevent this OOS event.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionActionTaken rdf:type rdf:Property ;
    rdfs:label 'Resolution Action Taken' ;
    rdfs:comment 'The primary corrective action taken to resolve the OOS event (emergency replenishment, supplier expedite, inventory transfer, customer notification, substitute offered, backorder created).' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed narrative explanation of the specific circumstances and factors that caused the OOS event.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockLevel rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Level' ;
    rdfs:comment 'The configured safety stock threshold for this SKU at this location at the time of the OOS event.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalityFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonality Flag' ;
    rdfs:comment 'Indicates whether this SKU is subject to seasonal demand patterns that may have contributed to the OOS event.' ;
    rdfs:domain ind:OosEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quarantineRecordId rdf:type rdf:Property ;
    rdfs:label 'Quarantine Record Id' ;
    rdfs:comment 'Unique identifier for the quarantine record. Primary key.' ;
    rdfs:domain ind:QuarantineRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Free-text description of the corrective actions planned or implemented to address the root cause and prevent recurrence.' ;
    rdfs:domain ind:QuarantineRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether corrective actions are required to prevent recurrence of this quarantine issue.' ;
    rdfs:domain ind:QuarantineRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Impact Flag' ;
    rdfs:comment 'Boolean flag indicating whether this quarantine has direct impact on customer orders or commitments.' ;
    rdfs:domain ind:QuarantineRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispositionNotes rdf:type rdf:Property ;
    rdfs:label 'Disposition Notes' ;
    rdfs:comment 'Free-text notes documenting the rationale, process, and details of the disposition decision and execution.' ;
    rdfs:domain ind:QuarantineRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionQuantity rdf:type rdf:Property ;
    rdfs:label 'Disposition Quantity' ;
    rdfs:comment 'The quantity of inventory units that were dispositioned. May differ from quarantined quantity if partial disposition occurred.' ;
    rdfs:domain ind:QuarantineRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Expected Resolution Date' ;
    rdfs:comment 'The anticipated date by which the quarantine hold is expected to be resolved based on inspection or review timelines.' ;
    rdfs:domain ind:QuarantineRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdAuthorityContact rdf:type rdf:Property ;
    rdfs:label 'Hold Authority Contact' ;
    rdfs:comment 'Contact information (email or phone) for the authority that initiated the quarantine hold.' ;
    rdfs:domain ind:QuarantineRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Hold Authority Name' ;
    rdfs:comment 'The name of the specific person, team, or organization that initiated the quarantine hold.' ;
    rdfs:domain ind:QuarantineRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdAuthorityType rdf:type rdf:Property ;
    rdfs:label 'Hold Authority Type' ;
    rdfs:comment 'The type of authority or entity that initiated the quarantine hold (e.g., Quality Assurance team, regulatory body, supplier, warehouse manager).' ;
    rdfs:domain ind:QuarantineRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Inspection Notes' ;
    rdfs:comment 'Free-text notes documenting findings, observations, and details from the inspection process.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'The type of inspection required or performed on the quarantined inventory (e.g., visual, functional, laboratory, regulatory, third-party).' ;
    rdfs:domain ind:QuarantineRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineEndDate rdf:type rdf:Property ;
    rdfs:label 'Quarantine End Date' ;
    rdfs:comment 'The date when the quarantine hold was lifted or the inventory was dispositioned. Null if quarantine is still active.' ;
    rdfs:domain ind:QuarantineRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quarantineEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Quarantine End Timestamp' ;
    rdfs:comment 'The precise timestamp when the quarantine hold was lifted or the inventory was dispositioned. Null if quarantine is still active.' ;
    rdfs:domain ind:QuarantineRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quarantineReasonCode rdf:type rdf:Property ;
    rdfs:label 'Quarantine Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason inventory was placed in quarantine status. [ENUM-REF-CANDIDATE: quality_hold|damage|regulatory_inspection|recall|supplier_dispute|expiry_risk|contamination — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:QuarantineRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Quarantine Reason Description' ;
    rdfs:comment 'Detailed free-text description of the specific reason for quarantine, providing additional context beyond the reason code.' ;
    rdfs:domain ind:QuarantineRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantineStartDate rdf:type rdf:Property ;
    rdfs:label 'Quarantine Start Date' ;
    rdfs:comment 'The date when the inventory was placed into quarantine status.' ;
    rdfs:domain ind:QuarantineRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quarantineStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Quarantine Start Timestamp' ;
    rdfs:comment 'The precise timestamp when the inventory was placed into quarantine status, supporting audit trail and Service Level Agreement (SLA) tracking.' ;
    rdfs:domain ind:QuarantineRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quarantineStatus rdf:type rdf:Property ;
    rdfs:label 'Quarantine Status' ;
    rdfs:comment 'Current lifecycle status of the quarantine record indicating whether the hold is active, under review, or resolved.' ;
    rdfs:domain ind:QuarantineRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quarantinedQuantity rdf:type rdf:Property ;
    rdfs:label 'Quarantined Quantity' ;
    rdfs:comment 'The quantity of inventory units placed in quarantine status.' ;
    rdfs:domain ind:QuarantineRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Number' ;
    rdfs:comment 'Reference number or case identifier from the regulatory body overseeing the quarantine or inspection.' ;
    rdfs:domain ind:QuarantineRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Actual Receipt Date' ;
    rdfs:comment 'The actual date when the replenishment inventory was received at the warehouse. Null until receipt is confirmed.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentStockLevel rdf:type rdf:Property ;
    rdfs:label 'Current Stock Level' ;
    rdfs:comment 'The on-hand inventory quantity at the warehouse node at the time this replenishment order was created.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dsr rdf:type rdf:Property ;
    rdfs:label 'Dsr' ;
    rdfs:comment 'The average daily sales rate for this SKU at the time the replenishment order was created, used in demand forecasting and order quantity calculation.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Expected Receipt Date' ;
    rdfs:comment 'The anticipated date when the replenishment inventory will arrive at the warehouse, calculated from order date plus lead time.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastDemand rdf:type rdf:Property ;
    rdfs:label 'Forecast Demand' ;
    rdfs:comment 'The projected demand for this SKU over the lead time period, used by the inventory planning engine to calculate optimal order quantity.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotTrackingRequired rdf:type rdf:Property ;
    rdfs:label 'Lot Tracking Required' ;
    rdfs:comment 'Indicates whether this SKU requires lot or batch tracking for FIFO/LIFO inventory management, expiration date tracking, or recall management.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:moq rdf:type rdf:Property ;
    rdfs:label 'Moq' ;
    rdfs:comment 'The Minimum Order Quantity constraint imposed by the supplier for this SKU. The order quantity must meet or exceed this threshold.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderQuantity rdf:type rdf:Property ;
    rdfs:label 'Order Quantity' ;
    rdfs:comment 'The quantity of the SKU requested in this replenishment order, calculated by the inventory planning engine or entered manually by the planner.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentMethod rdf:type rdf:Property ;
    rdfs:label 'Replenishment Method' ;
    rdfs:comment 'The inventory replenishment strategy applied for this SKU: fixed order quantity, fixed period review, min-max, Economic Order Quantity (EOQ), or Just-In-Time (JIT).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Replenishment Order Number' ;
    rdfs:comment 'Business-facing unique identifier for the replenishment order, used for tracking and reference in procurement and warehouse operations.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentStatus rdf:type rdf:Property ;
    rdfs:label 'Replenishment Status' ;
    rdfs:comment 'Current lifecycle status of the replenishment order in the procurement and receiving workflow. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|submitted|in_transit|partially_received|received|cancelled|rejected — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentType rdf:type rdf:Property ;
    rdfs:label 'Replenishment Type' ;
    rdfs:comment 'Classification of the replenishment order based on trigger mechanism: automatic (system-generated based on reorder point), manual (planner-initiated), emergency (urgent stockout prevention), seasonal (planned for seasonal demand), promotional (campaign-driven), or transfer (inter-warehouse movement).' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'The date and time when this replenishment order was submitted to the supplier or converted to a Purchase Order in the ERP system.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalOrderCost rdf:type rdf:Property ;
    rdfs:label 'Total Order Cost' ;
    rdfs:comment 'The total cost of this replenishment order, calculated as order quantity multiplied by unit cost, before taxes and fees.' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerEvent rdf:type rdf:Property ;
    rdfs:label 'Trigger Event' ;
    rdfs:comment 'The business event or condition that initiated the creation of this replenishment order. [ENUM-REF-CANDIDATE: reorder_point_breach|safety_stock_breach|forecast_demand|manual_request|promotional_campaign|stockout_alert|scheduled_replenishment — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReplenishmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentRuleId rdf:type rdf:Property ;
    rdfs:label 'Replenishment Rule Id' ;
    rdfs:comment 'Unique identifier for the replenishment rule configuration record. Primary key.' ;
    rdfs:domain ind:ReplenishmentRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoReplenishmentEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Replenishment Enabled' ;
    rdfs:comment 'Indicates whether automated replenishment order generation is enabled for this rule. When true, orders are created automatically when triggers are met.' ;
    rdfs:domain ind:ReplenishmentRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:demandVariabilityCoefficient rdf:type rdf:Property ;
    rdfs:label 'Demand Variability Coefficient' ;
    rdfs:comment 'Statistical measure of demand volatility for this SKU. Used in safety stock optimization to account for demand uncertainty.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dsrBaseline rdf:type rdf:Property ;
    rdfs:label 'Dsr Baseline' ;
    rdfs:comment 'The baseline average daily sales rate for this SKU at this warehouse. Used as the demand input for replenishment and safety stock calculations.' ;
    rdfs:domain ind:ReplenishmentRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastAccuracyPercentage rdf:type rdf:Property ;
    rdfs:label 'Forecast Accuracy Percentage' ;
    rdfs:comment 'Historical forecast accuracy for this SKU-warehouse combination. Used to adjust safety stock and replenishment parameters.' ;
    rdfs:domain ind:ReplenishmentRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdingCostPerUnitPerDay rdf:type rdf:Property ;
    rdfs:label 'Holding Cost Per Unit Per Day' ;
    rdfs:comment 'The daily cost of holding one unit of this SKU in inventory. Includes warehousing, capital, insurance, and obsolescence costs.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastRecalculationDate rdf:type rdf:Property ;
    rdfs:label 'Last Recalculation Date' ;
    rdfs:comment 'The date when the replenishment parameters (ROP, ROQ, safety stock) were last recalculated or optimized based on updated demand and supply data.' ;
    rdfs:domain ind:ReplenishmentRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotSizingRule rdf:type rdf:Property ;
    rdfs:label 'Lot Sizing Rule' ;
    rdfs:comment 'The rule used to determine the size of replenishment lots. Complements the replenishment method with specific quantity logic.' ;
    rdfs:domain ind:ReplenishmentRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level' ;
    rdfs:comment 'The upper inventory threshold for this SKU-warehouse combination. Used in min-max replenishment strategies to cap inventory levels.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'The smallest order quantity allowed by supplier or business rules. Replenishment orders must meet or exceed this threshold.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderMultiple rdf:type rdf:Property ;
    rdfs:label 'Order Multiple' ;
    rdfs:comment 'The quantity increment in which orders must be placed. Replenishment quantities are rounded to the nearest multiple of this value.' ;
    rdfs:domain ind:ReplenishmentRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementCategory rdf:type rdf:Property ;
    rdfs:label 'Procurement Category' ;
    rdfs:comment 'The procurement category or commodity group to which this SKU belongs. Used for sourcing strategy and supplier management.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Quantity' ;
    rdfs:comment 'The standard quantity to order when the reorder point is reached. Represents the replenishment order size.' ;
    rdfs:domain ind:ReplenishmentRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:replenishmentRuleStatus rdf:type rdf:Property ;
    rdfs:label 'Replenishment Rule Status' ;
    rdfs:comment 'Current lifecycle status of the replenishment rule. Determines whether the rule is actively used for order generation.' ;
    rdfs:domain ind:ReplenishmentRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name or label for this replenishment rule configuration.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Calculation Method' ;
    rdfs:comment 'The methodology used to calculate the safety stock quantity. Determines how demand and supply variability are factored into the buffer.' ;
    rdfs:domain ind:ReplenishmentRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockDays rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Days' ;
    rdfs:comment 'The number of days of demand coverage provided by the safety stock quantity. Used for planning and service level calculations.' ;
    rdfs:domain ind:ReplenishmentRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'The buffer inventory quantity maintained to protect against demand variability and supply uncertainty. Part of the unified replenishment and safety stock policy.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonalityFactor rdf:type rdf:Property ;
    rdfs:label 'Seasonality Factor' ;
    rdfs:comment 'Adjustment factor applied to baseline demand to account for seasonal demand patterns. Used in seasonal safety stock calculations.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLevelTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Service Level Target Percentage' ;
    rdfs:comment 'The target in-stock service level percentage for this SKU-warehouse combination. Drives safety stock sizing to meet availability goals.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockoutCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Stockout Cost Per Unit' ;
    rdfs:comment 'The estimated business cost incurred per unit when this SKU is out of stock. Used in economic optimization of safety stock levels.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierLeadTimeVariability rdf:type rdf:Property ;
    rdfs:label 'Supplier Lead Time Variability' ;
    rdfs:comment 'Statistical measure of supplier delivery time variability. Used in safety stock calculations to account for supply uncertainty.' ;
    rdfs:domain ind:ReplenishmentRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockRuleId rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Rule Id' ;
    rdfs:comment 'Unique identifier for the safety stock rule record. Primary key.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageDailyDemand rdf:type rdf:Property ;
    rdfs:label 'Average Daily Demand' ;
    rdfs:comment 'The mean daily sales rate or demand for this SKU at this warehouse node, used as baseline for safety stock calculation.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Average Lead Time Days' ;
    rdfs:comment 'The mean supplier or replenishment lead time in days for this SKU at this location.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationFrequency rdf:type rdf:Property ;
    rdfs:label 'Calculation Frequency' ;
    rdfs:comment 'How often the safety stock quantity is automatically recalculated to reflect changing demand patterns and supply conditions.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'The methodology used to calculate safety stock quantity: statistical (based on demand variability), fixed (constant buffer), seasonal (adjusted for seasonality), dynamic (real-time optimization), min-max (reorder point logic), or service level (target fill rate).' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandForecastHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Demand Forecast Horizon Days' ;
    rdfs:comment 'The number of days into the future for which demand forecasts are considered in safety stock calculation.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isPromotionalProduct rdf:type rdf:Property ;
    rdfs:label 'Is Promotional Product' ;
    rdfs:comment 'Boolean flag indicating whether this SKU is frequently subject to promotional campaigns that create demand spikes.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSeasonalProduct rdf:type rdf:Property ;
    rdfs:label 'Is Seasonal Product' ;
    rdfs:comment 'Boolean flag indicating whether this SKU exhibits seasonal demand patterns requiring adjusted safety stock strategies.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCalculationDate rdf:type rdf:Property ;
    rdfs:label 'Last Calculation Date' ;
    rdfs:comment 'The most recent date on which the safety stock quantity was recalculated based on updated demand and lead time data.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModifiedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Code' ;
    rdfs:comment 'Identifier of the user or system process that most recently updated this safety stock rule record.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeVariabilityDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Variability Days' ;
    rdfs:comment 'The standard deviation or variance in supplier lead time measured in days, capturing supply uncertainty for safety stock calculation.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Free-text explanation when safety stock levels are manually overridden from system-calculated values, documenting business justification.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityClassification rdf:type rdf:Property ;
    rdfs:label 'Priority Classification' ;
    rdfs:comment 'Business priority level assigned to this SKU for safety stock management, influencing service level targets and buffer sizing.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Review Period Days' ;
    rdfs:comment 'The frequency in days at which inventory levels are reviewed and replenishment decisions are made for this SKU.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the safety stock rule indicating whether it is actively applied in inventory planning.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockDaysOfCover rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Days Of Cover' ;
    rdfs:comment 'The number of days of average demand that the safety stock quantity represents, providing a time-based buffer metric.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierReliabilityScore rdf:type rdf:Property ;
    rdfs:label 'Supplier Reliability Score' ;
    rdfs:comment 'Quantitative score (0-100) measuring supplier on-time delivery performance and quality, influencing safety stock buffer requirements.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zScore rdf:type rdf:Property ;
    rdfs:label 'Z Score' ;
    rdfs:comment 'The standard normal distribution z-score corresponding to the service level target, used in statistical safety stock formulas.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:skuVelocityId rdf:type rdf:Property ;
    rdfs:label 'Sku Velocity Id' ;
    rdfs:comment 'Unique surrogate primary key for the SKU velocity record. Identifies a single master record tracking daily sales rate and velocity classification for a SKU at a warehouse node.' ;
    rdfs:domain ind:SkuVelocity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activePromotionFlag rdf:type rdf:Property ;
    rdfs:label 'Active Promotion Flag' ;
    rdfs:comment 'Boolean flag indicating whether this SKU is currently under an active promotional campaign that may be influencing its DSR. When true, velocity metrics may be temporarily elevated and should be interpreted with caution for baseline replenishment planning.' ;
    rdfs:domain ind:SkuVelocity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bsrCategory rdf:type rdf:Property ;
    rdfs:label 'Bsr Category' ;
    rdfs:comment 'Product category within which the BSR rank is computed (e.g., \'Electronics\', \'Apparel\'). BSR is category-relative; this field provides the denominator context for rank interpretation.' ;
    rdfs:domain ind:SkuVelocity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bsrRank rdf:type rdf:Property ;
    rdfs:label 'Bsr Rank' ;
    rdfs:comment 'Best Seller Rank (BSR) of this SKU within its product category at the time of the last velocity recalculation. Lower rank indicates higher sales velocity. Used as a co-input with DSR for velocity tier classification.' ;
    rdfs:domain ind:SkuVelocity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Data Window Start Date' ;
    rdfs:comment 'Start date of the data window used in the most recent velocity recalculation. Defines the earliest transaction date included in DSR computations. Important for understanding the representativeness of velocity metrics for newly launched or recently reactivated SKUs.' ;
    rdfs:domain ind:SkuVelocity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysOfSupply rdf:type rdf:Property ;
    rdfs:label 'Days Of Supply' ;
    rdfs:comment 'Estimated number of days the current on-hand inventory will last at the current 30-day DSR before reaching zero. Key Out-of-Stock (OOS) risk indicator used in replenishment prioritization.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dsr30d rdf:type rdf:Property ;
    rdfs:label 'Dsr 30d' ;
    rdfs:comment 'Rolling 30-day average Daily Sales Rate (DSR) expressed as units sold per day. Medium-term velocity indicator used for standard replenishment planning and safety stock calculations.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dsr7d rdf:type rdf:Property ;
    rdfs:label 'Dsr 7d' ;
    rdfs:comment 'Rolling 7-day average Daily Sales Rate (DSR) expressed as units sold per day. Short-term velocity indicator used for immediate replenishment triggers and safety stock adjustments.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dsr90d rdf:type rdf:Property ;
    rdfs:label 'Dsr 90d' ;
    rdfs:comment 'Rolling 90-day average Daily Sales Rate (DSR) expressed as units sold per day. Long-term velocity baseline used for seasonal trend analysis, safety stock floor calculations, and velocity tier classification.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentModel rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Model' ;
    rdfs:comment 'Fulfillment model under which this SKU is stocked and shipped at this node. FBA = Fulfillment By Amazon-style (platform-fulfilled); FBM = Fulfilled by Merchant; 3PL = Third-Party Logistics; DTC = Direct to Consumer; BOPIS = Buy Online Pick Up In Store. Velocity benchmarks and slotting rules differ by fulfillment model.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSeasonalSku rdf:type rdf:Property ;
    rdfs:label 'Is Seasonal Sku' ;
    rdfs:comment 'Boolean flag indicating whether this SKU exhibits significant seasonal demand patterns. When true, the seasonal velocity index is weighted more heavily in safety stock and replenishment calculations.' ;
    rdfs:domain ind:SkuVelocity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netDsr30d rdf:type rdf:Property ;
    rdfs:label 'Net Dsr 30d' ;
    rdfs:comment 'Net 30-day Daily Sales Rate (DSR) adjusted for returns: gross units sold minus units returned, divided by 30 days. Provides a more accurate velocity signal for replenishment planning than gross DSR when return rates are material.' ;
    rdfs:domain ind:SkuVelocity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oosRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Oos Risk Flag' ;
    rdfs:comment 'Boolean flag indicating whether this SKU at this node is at imminent risk of an Out-of-Stock (OOS) event, defined as days_of_supply falling below the replenishment lead time. Triggers priority replenishment workflows.' ;
    rdfs:domain ind:SkuVelocity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:peakDsr rdf:type rdf:Property ;
    rdfs:label 'Peak Dsr' ;
    rdfs:comment 'Maximum observed Daily Sales Rate (DSR) for this SKU at this node within the trailing 365-day window. Used to size safety stock buffers for peak demand events such as promotions or seasonal spikes.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakDsrDate rdf:type rdf:Property ;
    rdfs:label 'Peak Dsr Date' ;
    rdfs:comment 'Calendar date on which the peak DSR was recorded. Provides temporal context for peak demand analysis and seasonal pattern identification.' ;
    rdfs:domain ind:SkuVelocity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorVelocityTier rdf:type rdf:Property ;
    rdfs:label 'Prior Velocity Tier' ;
    rdfs:comment 'Velocity tier assigned to this SKU-node combination in the previous recalculation cycle. Retained alongside the current tier to support tier-change analysis, slotting review workflows, and audit trails.' ;
    rdfs:domain ind:SkuVelocity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionVelocityUplift rdf:type rdf:Property ;
    rdfs:label 'Promotion Velocity Uplift' ;
    rdfs:comment 'Multiplier representing the observed or forecasted increase in DSR during active promotional periods for this SKU. A value of 1.5 indicates a 50% uplift over baseline DSR during promotions. Used to pre-position inventory ahead of planned promotions.' ;
    rdfs:domain ind:SkuVelocity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recalculationFrequencyHours rdf:type rdf:Property ;
    rdfs:label 'Recalculation Frequency Hours' ;
    rdfs:comment 'Configured frequency in hours at which the velocity metrics for this SKU-node record are recalculated. Tier-A SKUs may recalculate every 4 hours; Tier-D SKUs may recalculate daily. Drives scheduling of the velocity computation job.' ;
    rdfs:domain ind:SkuVelocity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reorderPointQty rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Qty' ;
    rdfs:comment 'Inventory level at which a replenishment order should be triggered for this SKU at this node. Computed from DSR, replenishment lead time, and safety stock. When on-hand quantity falls to or below this level, a replenishment signal is generated.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replenishmentFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Replenishment Frequency Days' ;
    rdfs:comment 'Recommended replenishment cycle in days derived from the SKU velocity tier and DSR. Tier-A SKUs may have a 0.5-day (twice daily) replenishment cycle; Tier-D SKUs may be replenished every 30 days. Feeds the Warehouse Management System replenishment scheduler.' ;
    rdfs:domain ind:SkuVelocity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnRate30d rdf:type rdf:Property ;
    rdfs:label 'Return Rate 30d' ;
    rdfs:comment 'Ratio of units returned to units sold for this SKU at this node over the trailing 30-day window. Expressed as a decimal (e.g., 0.05 = 5% return rate). High return rates may inflate gross DSR; net velocity should account for returns in replenishment planning.' ;
    rdfs:domain ind:SkuVelocity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockQty rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Qty' ;
    rdfs:comment 'Recommended safety stock quantity for this SKU at this node, calculated from DSR, lead time variability, and seasonal velocity index. Represents the buffer inventory held to prevent Out-of-Stock (OOS) events during demand spikes or supply delays.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonCode rdf:type rdf:Property ;
    rdfs:label 'Season Code' ;
    rdfs:comment 'Primary selling season associated with this SKU. Used to contextualize the seasonal velocity index and align replenishment planning with seasonal demand cycles. \'YEAR_ROUND\' indicates no dominant season.' ;
    rdfs:domain ind:SkuVelocity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalVelocityIndex rdf:type rdf:Property ;
    rdfs:label 'Seasonal Velocity Index' ;
    rdfs:comment 'Dimensionless multiplier representing the ratio of current period DSR to the annual average DSR for this SKU at this node. Values above 1.0 indicate above-average seasonal demand; below 1.0 indicate below-average. Used to adjust safety stock and replenishment quantities for seasonal fluctuations.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slottingZone rdf:type rdf:Property ;
    rdfs:label 'Slotting Zone' ;
    rdfs:comment 'Warehouse slotting zone recommended or assigned to this SKU based on its velocity tier. \'prime\' = highest-pick-frequency zone closest to packing; \'forward\' = forward pick area; \'reserve\' = reserve storage; \'bulk\' = bulk pallet storage; \'overflow\' = overflow/offsite storage. Drives pick path optimization and labor efficiency.' ;
    rdfs:domain ind:SkuVelocity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Tier Change Flag' ;
    rdfs:comment 'Boolean flag indicating whether the velocity tier changed during the most recent recalculation cycle. When true, triggers a slotting review workflow to evaluate whether physical relocation of the SKU within the warehouse is warranted.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierChangedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tier Changed Timestamp' ;
    rdfs:comment 'Timestamp when the velocity tier last changed for this SKU-node combination. Used to measure tier stability, assess slotting decision lag, and support historical velocity analysis.' ;
    rdfs:domain ind:SkuVelocity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:unitsSold30d rdf:type rdf:Property ;
    rdfs:label 'Units Sold 30d' ;
    rdfs:comment 'Total units of this SKU sold from this warehouse node in the trailing 30-day window. Raw sales volume input used to compute the 30-day DSR and velocity tier assignment.' ;
    rdfs:domain ind:SkuVelocity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsSold7d rdf:type rdf:Property ;
    rdfs:label 'Units Sold 7d' ;
    rdfs:comment 'Total units of this SKU sold from this warehouse node in the trailing 7-day window. Raw sales volume input used to compute the 7-day DSR.' ;
    rdfs:domain ind:SkuVelocity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitsSold90d rdf:type rdf:Property ;
    rdfs:label 'Units Sold 90d' ;
    rdfs:comment 'Total units of this SKU sold from this warehouse node in the trailing 90-day window. Raw sales volume input used to compute the 90-day DSR and long-term velocity baseline.' ;
    rdfs:domain ind:SkuVelocity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:velocityRecalculatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Velocity Recalculated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent velocity recalculation job that updated DSR values, velocity tier, and seasonal index for this SKU-node combination. Used to assess data freshness and trigger stale-data alerts.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:velocityStatus rdf:type rdf:Property ;
    rdfs:label 'Velocity Status' ;
    rdfs:comment 'Lifecycle status of this SKU velocity record. \'active\' = currently used for slotting and replenishment decisions; \'inactive\' = SKU no longer stocked at this node; \'suspended\' = temporarily excluded from velocity-driven decisions (e.g., during a product recall); \'pending_review\' = awaiting manual validation after anomaly detection.' ;
    rdfs:domain ind:SkuVelocity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:velocityTier rdf:type rdf:Property ;
    rdfs:label 'Velocity Tier' ;
    rdfs:comment 'ABC/D velocity tier assigned to the SKU at this warehouse node based on Best Seller Rank (BSR) and sales volume. A = fastest moving (top ~20%), B = moderate, C = slow, D = dead/near-zero movement. Drives slotting zone assignment and replenishment frequency.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:velocityTrend rdf:type rdf:Property ;
    rdfs:label 'Velocity Trend' ;
    rdfs:comment 'Directional trend of SKU velocity based on comparison of 7-day DSR to 90-day DSR. \'accelerating\' = 7d DSR significantly above 90d DSR; \'stable\' = within normal variance band; \'decelerating\' = 7d DSR significantly below 90d DSR; \'volatile\' = high variance with no clear direction. Used for proactive inventory positioning.' ;
    rdfs:domain ind:SkuVelocity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damagedQuantity rdf:type rdf:Property ;
    rdfs:label 'Damaged Quantity' ;
    rdfs:comment 'The quantity of the SKU identified as damaged or defective at the time of the snapshot. Typically marked for return to supplier or disposal.' ;
    rdfs:domain ind:Snapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysOfCover rdf:type rdf:Property ;
    rdfs:label 'Days Of Cover' ;
    rdfs:comment 'The number of days the current on-hand inventory can support expected demand, calculated as on-hand quantity divided by daily sales rate (DSR). Used for inventory health monitoring.' ;
    rdfs:domain ind:Snapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fifoCostLayerReference rdf:type rdf:Property ;
    rdfs:label 'Fifo Cost Layer Reference' ;
    rdfs:comment 'Identifier linking this snapshot to a specific FIFO cost layer for inventory valuation and cost of goods sold reconciliation under FIFO accounting method.' ;
    rdfs:domain ind:Snapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inTransitQuantity rdf:type rdf:Property ;
    rdfs:label 'In Transit Quantity' ;
    rdfs:comment 'The quantity of the SKU currently in transit to this warehouse node from suppliers or other distribution centers, expected to arrive and increase on-hand stock.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'The overall status classification of this inventory position, indicating whether the stock is available for sale, held for specific purposes, or flagged for special handling. [ENUM-REF-CANDIDATE: available|reserved|quarantine|damaged|in_transit|expired|obsolete — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onHandQuantity rdf:type rdf:Property ;
    rdfs:label 'On Hand Quantity' ;
    rdfs:comment 'The physical quantity of the SKU available in the warehouse at the time of the snapshot. Represents actual stock on shelves or in bins.' ;
    rdfs:domain ind:Snapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oosFlag rdf:type rdf:Property ;
    rdfs:label 'Oos Flag' ;
    rdfs:comment 'Boolean indicator that is true when the available quantity for this SKU at this warehouse node is zero or below safety stock, signaling a stockout condition.' ;
    rdfs:domain ind:Snapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reorderPointQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Quantity' ;
    rdfs:comment 'The inventory level at which a replenishment order should be triggered for this SKU at this warehouse node to maintain optimal stock levels.' ;
    rdfs:domain ind:Snapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:comment 'The quantity of the SKU that is allocated to pending orders or fulfillment processes but not yet shipped. Reduces available-to-promise inventory.' ;
    rdfs:domain ind:Snapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:snapshotType rdf:type rdf:Property ;
    rdfs:label 'Snapshot Type' ;
    rdfs:comment 'Classification of the snapshot based on the reporting period it represents, such as daily, weekly, monthly, quarterly, yearly, or ad-hoc snapshots for special reconciliation needs.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalInventoryValue rdf:type rdf:Property ;
    rdfs:label 'Total Inventory Value' ;
    rdfs:comment 'The total monetary value of the on-hand inventory for this SKU at this warehouse node, calculated as on-hand quantity multiplied by unit cost. Used for financial reporting and SOX compliance.' ;
    rdfs:domain ind:Snapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockAllocationId rdf:type rdf:Property ;
    rdfs:label 'Stock Allocation Id' ;
    rdfs:comment 'Unique identifier for the stock allocation record. Primary key.' ;
    rdfs:domain ind:StockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineId rdf:type rdf:Property ;
    rdfs:label 'Line Id' ;
    rdfs:comment 'Reference to the specific order line item that this allocation fulfills. Enables line-level allocation tracking.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:transferOrderId rdf:type rdf:Property ;
    rdfs:label 'Transfer Order Id' ;
    rdfs:comment 'Reference to an inter-warehouse transfer order if this allocation is for inventory movement between facilities.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransferOrder .

ind:allocationNotes rdf:type rdf:Property ;
    rdfs:label 'Allocation Notes' ;
    rdfs:comment 'Free-text notes or special instructions related to this allocation. Captures operational context and exceptions.' ;
    rdfs:domain ind:StockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Allocation Reason Code' ;
    rdfs:comment 'Coded reason for the allocation or any special handling requirements. Examples: STANDARD, EXPEDITED, REPLACEMENT, SAMPLE.' ;
    rdfs:domain ind:StockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationSource rdf:type rdf:Property ;
    rdfs:label 'Allocation Source' ;
    rdfs:comment 'The system or process that originated this allocation. Distinguishes automated allocations from manual interventions.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current lifecycle state of the allocation. Tracks progression from reservation through fulfillment or cancellation. [ENUM-REF-CANDIDATE: pending|confirmed|picked|packed|shipped|cancelled|expired|released — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocation Timestamp' ;
    rdfs:comment 'The date and time when the inventory was allocated to this demand. Represents the business event time of reservation.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Classification of the allocation commitment. Hard allocation is firm and reduces ATP; soft allocation is tentative and may be released; pre-allocation reserves inventory before order confirmation; reservation holds inventory for future demand.' ;
    rdfs:domain ind:StockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdFlag rdf:type rdf:Property ;
    rdfs:label 'Hold Flag' ;
    rdfs:comment 'Indicates whether this allocation is on hold and cannot proceed to fulfillment. True if held, False otherwise.' ;
    rdfs:domain ind:StockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryCondition rdf:type rdf:Property ;
    rdfs:label 'Inventory Condition' ;
    rdfs:comment 'Physical condition of the allocated inventory. Supports allocation rules that prioritize new stock over returned or refurbished items.' ;
    rdfs:domain ind:StockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Packed Timestamp' ;
    rdfs:comment 'The date and time when the picked inventory was packed for shipment. Tracks fulfillment milestone.' ;
    rdfs:domain ind:StockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Picked Timestamp' ;
    rdfs:comment 'The date and time when the allocated inventory was picked. Marks transition from allocated to in-fulfillment state.' ;
    rdfs:domain ind:StockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:releasedQuantity rdf:type rdf:Property ;
    rdfs:label 'Released Quantity' ;
    rdfs:comment 'The quantity of inventory released from this allocation back to ATP. May differ from allocated quantity if partial fulfillment occurred.' ;
    rdfs:domain ind:StockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releasedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Released Timestamp' ;
    rdfs:comment 'The date and time when the allocation was released back to ATP. Null if allocation is still active.' ;
    rdfs:domain ind:StockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:warehouseLocationCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location Code' ;
    rdfs:comment 'Specific bin, aisle, or zone within the warehouse where the allocated inventory resides. Supports pick-path optimization.' ;
    rdfs:domain ind:StockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockMovementId rdf:type rdf:Property ;
    rdfs:label 'Stock Movement Id' ;
    rdfs:comment 'Unique identifier for the stock movement transaction. Primary key for the stock movement audit trail.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationLocationWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Warehouse Location Id' ;
    rdfs:comment 'Identifier of the warehouse location, bin, or virtual location to which inventory is being moved. Null for issue transactions leaving the warehouse network or write-off transactions.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:primaryStockWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Warehouse Location Id' ;
    rdfs:comment 'Identifier of the warehouse location, bin, or virtual location from which inventory is being moved. Null for receipt transactions originating outside the warehouse network.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:routeId rdf:type rdf:Property ;
    rdfs:label 'Route Id' ;
    rdfs:comment 'Foreign key linking to logistics.route. Business justification: Inter-warehouse stock movements are executed via transport routes; linking enables route efficiency reporting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Route .

ind:adjustmentReasonNotes rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason Notes' ;
    rdfs:comment 'Free-text explanation for manual adjustments, write-offs, or variance corrections. Required for audit trail completeness and regulatory compliance. Captures business context not conveyed by reason code alone.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Erp Document Number' ;
    rdfs:comment 'Material document or goods movement document number generated by the ERP system (e.g., SAP material document). Used for cross-system reconciliation and audit trail.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFinancialImpact rdf:type rdf:Property ;
    rdfs:label 'Is Financial Impact' ;
    rdfs:comment 'Flag indicating whether this movement has financial impact requiring general ledger posting (True) or is a non-financial movement such as location transfer within the same warehouse (False). Critical for financial reconciliation and month-end close.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSystemInitiated rdf:type rdf:Property ;
    rdfs:label 'Is System Initiated' ;
    rdfs:comment 'Flag indicating whether the movement was automatically triggered by system logic (True) or manually initiated by a user (False). Used to distinguish automated replenishment, allocation, and reservation movements from manual transactions.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:movementNumber rdf:type rdf:Property ;
    rdfs:label 'Movement Number' ;
    rdfs:comment 'Business-facing unique identifier for the stock movement transaction. Human-readable reference number used in operational systems and audit reports.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementStatus rdf:type rdf:Property ;
    rdfs:label 'Movement Status' ;
    rdfs:comment 'Current lifecycle state of the stock movement transaction. Pending = awaiting execution; In Transit = movement initiated but not yet received; Completed = movement finalized and inventory updated; Cancelled = movement voided before completion; Failed = movement attempted but rejected by system validation.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Movement Timestamp' ;
    rdfs:comment 'Date and time when the physical inventory movement occurred or was recorded in the system. This is the business event timestamp used for inventory valuation and audit trail sequencing.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'Classification of the inventory movement transaction. Receipt = inbound from supplier or production; Issue = outbound to fulfillment or consumption; Transfer = inter-location movement; Adjustment = manual correction; Return = customer or supplier return; Write-off = inventory removal due to damage, expiry, or shrinkage.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Status' ;
    rdfs:comment 'Quality control status of the inventory at the time of movement. Approved = passed quality inspection and available for use; Quarantine = held for inspection or investigation; Rejected = failed quality standards; Inspection Pending = awaiting quality review. Critical for regulated industries and quality-sensitive products.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalValue rdf:type rdf:Property ;
    rdfs:label 'Total Value' ;
    rdfs:comment 'Total financial value of the inventory movement (quantity × unit cost). Used for general ledger posting, inventory asset reconciliation, and SOX-compliant financial reporting. Positive for receipts; negative for issues and write-offs.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmsTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Wms Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier from the source Warehouse Management System. Enables reconciliation between WMS and ERP inventory records and supports end-to-end audit trail.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockPositionId rdf:type rdf:Property ;
    rdfs:label 'Stock Position Id' ;
    rdfs:comment 'Unique surrogate identifier for the stock position record representing a SKU at a specific warehouse node or virtual location. Primary key of this entity.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockPosition .

ind:atpQty rdf:type rdf:Property ;
    rdfs:label 'Atp Qty' ;
    rdfs:comment 'Net units available for new order commitments, calculated as on_hand_qty minus reserved_qty minus quarantined_qty. The ATP quantity is the real-time sellable inventory figure exposed to the storefront and OMS for order promising.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:binLocationCode rdf:type rdf:Property ;
    rdfs:label 'Bin Location Code' ;
    rdfs:comment 'WMS bin, slot, or storage location code within the warehouse node where this SKU is primarily slotted (e.g., A-01-03-B). Used for pick path optimization, slotting analysis, and physical inventory audits.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountVarianceQty rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Variance Qty' ;
    rdfs:comment 'Difference between the system-recorded on-hand quantity and the physically counted quantity at the last cycle count (counted minus system). Positive = overage, negative = shrinkage. Used for inventory accuracy KPI reporting and shrinkage investigation.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:damagedQty rdf:type rdf:Property ;
    rdfs:label 'Damaged Qty' ;
    rdfs:comment 'Units at the node that have been identified as damaged and are unsellable in their current condition. May be eligible for liquidation, refurbishment, or disposal. Tracked for shrinkage reporting and insurance claims.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inTransitQty rdf:type rdf:Property ;
    rdfs:label 'In Transit Qty' ;
    rdfs:comment 'Units of the SKU currently in transit to this warehouse node from a supplier, another node, or a returns processing center. Included in future ATP projections but not in current on-hand. Tracked via Transportation Management System (TMS) shipment records.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryOwnershipType rdf:type rdf:Property ;
    rdfs:label 'Inventory Ownership Type' ;
    rdfs:comment 'Classifies who owns the inventory: first_party (platform-owned), third_party_fba (Fulfillment By Amazon-style seller inventory held at platform warehouse), consignment, dropship (never physically held), or vendor_managed inventory (VMI). Drives cost accounting and liability treatment.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHazmat rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat' ;
    rdfs:comment 'Indicates whether this SKU is classified as a hazardous material requiring special storage, handling, or shipping restrictions at this node. Drives WMS storage zone assignment, carrier eligibility filtering in TMS, and regulatory compliance checks.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOos rdf:type rdf:Property ;
    rdfs:label 'Is Oos' ;
    rdfs:comment 'Indicates whether the SKU is currently out of stock (OOS) at this node, meaning ATP quantity is zero or below safety stock threshold. Drives storefront availability suppression, OOS alerts, and replenishment escalation. Key KPI for inventory health reporting.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSerialized rdf:type rdf:Property ;
    rdfs:label 'Is Serialized' ;
    rdfs:comment 'Indicates whether individual units of this SKU are tracked by unique serial number at this node. When true, each unit has a distinct serial number record in the WMS. Relevant for high-value electronics, regulated goods, and warranty management.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Cycle Count Date' ;
    rdfs:comment 'Date of the most recent physical cycle count performed for this SKU at this warehouse node. Cycle counting is the primary mechanism for validating perpetual inventory accuracy. Frequency is driven by velocity tier (A-items counted more frequently).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMovementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Movement Timestamp' ;
    rdfs:comment 'Timestamp of the most recent inventory movement transaction (receipt, pick, transfer, adjustment) for this SKU at this node. Used to identify dormant stock, trigger dead-stock reviews, and validate real-time inventory visibility.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Last Received Date' ;
    rdfs:comment 'Date of the most recent inbound goods receipt (GR) posted for this SKU at this warehouse node. Used to assess inventory freshness, identify slow-moving stock, and validate replenishment cycle adherence.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lotTrackingMethod rdf:type rdf:Property ;
    rdfs:label 'Lot Tracking Method' ;
    rdfs:comment 'Inventory costing and lot rotation method applied to this SKU at this node: FIFO (First In First Out), LIFO (Last In First Out), FEFO (First Expired First Out for perishables), or none (no lot tracking). Governs pick sequencing in WMS and cost-of-goods-sold (COGS) calculation in ERP.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxStockQty rdf:type rdf:Property ;
    rdfs:label 'Max Stock Qty' ;
    rdfs:comment 'Upper bound on inventory units to hold at this node for this SKU, constrained by bin capacity, working capital policy, or perishability. Replenishment orders are sized to not exceed this level. Used in min-max replenishment planning.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onHandQty rdf:type rdf:Property ;
    rdfs:label 'On Hand Qty' ;
    rdfs:comment 'Total physical units of the SKU currently present at the warehouse node, regardless of reservation or allocation status. Includes allocated, quarantined, and damaged units. Source of truth from WMS cycle count or perpetual inventory.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oosSinceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Oos Since Timestamp' ;
    rdfs:comment 'Timestamp when the SKU first became out of stock at this node in the current OOS episode. Used to calculate OOS duration for SLA compliance, lost sales estimation, and seller performance monitoring. Null when is_oos is false.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quarantinedQty rdf:type rdf:Property ;
    rdfs:label 'Quarantined Qty' ;
    rdfs:comment 'Units physically present at the node but held in quarantine pending quality inspection, regulatory hold, or recall investigation. Not available for sale or fulfillment. Tracked separately for compliance and quality management reporting.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replenishmentLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Replenishment Lead Time Days' ;
    rdfs:comment 'Expected number of calendar days from purchase order (PO) placement to receipt of goods at this warehouse node for this SKU. Used in reorder point and safety stock calculations. Sourced from supplier SLA agreements.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reservedQty rdf:type rdf:Property ;
    rdfs:label 'Reserved Qty' ;
    rdfs:comment 'Units of the SKU that have been soft-allocated to open orders or reservations but not yet physically picked. Reduces available-to-promise (ATP) quantity. Managed by the Order Management System (OMS) allocation engine.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stockCondition rdf:type rdf:Property ;
    rdfs:label 'Stock Condition' ;
    rdfs:comment 'Physical or logical state of the stock at this node: on_hand (available in bin), allocated (reserved for an order), quarantined (held for QC), damaged (unsellable), in_transit (moving between nodes). Drives WMS pick eligibility and ATP calculations.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockValuationId rdf:type rdf:Property ;
    rdfs:label 'Stock Valuation Id' ;
    rdfs:comment 'Unique identifier for the stock valuation record. Primary key for this entity.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentNotes rdf:type rdf:Property ;
    rdfs:label 'Adjustment Notes' ;
    rdfs:comment 'Free-text notes providing additional context for cost layer adjustments or valuation changes.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason Code' ;
    rdfs:comment 'Code indicating the reason for any cost layer adjustment, such as cycle count variance, damage, obsolescence, or revaluation.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Unique identifier linking this valuation record to the audit trail for compliance and traceability purposes.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cogsAllocated rdf:type rdf:Property ;
    rdfs:label 'Cogs Allocated' ;
    rdfs:comment 'Total cost of goods sold amount allocated from this cost layer to revenue transactions, feeding COGS calculation for financial reporting.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumedQuantity rdf:type rdf:Property ;
    rdfs:label 'Consumed Quantity' ;
    rdfs:comment 'Quantity from this cost layer that has been consumed through sales, transfers, or adjustments, reducing the available layer quantity.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costLayerSequence rdf:type rdf:Property ;
    rdfs:label 'Cost Layer Sequence' ;
    rdfs:comment 'Sequential order of this cost layer within the SKU-warehouse-lot combination, used for FIFO/LIFO consumption ordering.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costVariance rdf:type rdf:Property ;
    rdfs:label 'Cost Variance' ;
    rdfs:comment 'Difference between actual unit cost and standard cost, used for cost variance reporting and analysis.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costingMethod rdf:type rdf:Property ;
    rdfs:label 'Costing Method' ;
    rdfs:comment 'Inventory valuation method applied to this cost layer: First In First Out (FIFO), Last In First Out (LIFO), weighted average, standard cost, or moving average.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyCost rdf:type rdf:Property ;
    rdfs:label 'Duty Cost' ;
    rdfs:comment 'Allocated customs duty and tariff cost component included in the unit cost for this inventory layer.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handlingCost rdf:type rdf:Property ;
    rdfs:label 'Handling Cost' ;
    rdfs:comment 'Allocated handling and processing cost component included in the unit cost for this inventory layer.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:landedCostIncluded rdf:type rdf:Property ;
    rdfs:label 'Landed Cost Included' ;
    rdfs:comment 'Indicates whether the unit cost includes landed cost components such as freight, duties, and handling charges.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:layerQuantity rdf:type rdf:Property ;
    rdfs:label 'Layer Quantity' ;
    rdfs:comment 'Total quantity of inventory units in this cost layer available for valuation.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:layerValue rdf:type rdf:Property ;
    rdfs:label 'Layer Value' ;
    rdfs:comment 'Total monetary value of this cost layer, calculated as unit cost multiplied by layer quantity.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'Date when the inventory lot was received into the warehouse, establishing the cost layer entry point for FIFO/LIFO.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remainingQuantity rdf:type rdf:Property ;
    rdfs:label 'Remaining Quantity' ;
    rdfs:comment 'Quantity remaining in this cost layer available for future consumption, calculated as layer quantity minus consumed quantity.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revaluationDate rdf:type rdf:Property ;
    rdfs:label 'Revaluation Date' ;
    rdfs:comment 'Date on which the cost layer revaluation was performed, if applicable.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revaluationFlag rdf:type rdf:Property ;
    rdfs:label 'Revaluation Flag' ;
    rdfs:comment 'Indicates whether this cost layer has undergone a revaluation adjustment due to market price changes or accounting policy updates.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Compliant Flag' ;
    rdfs:comment 'Indicates whether this cost layer valuation record meets SOX internal control requirements for financial reporting accuracy and auditability.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardCost rdf:type rdf:Property ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'Predetermined standard cost per unit for this SKU, used for variance analysis when standard costing method is applied.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationDate rdf:type rdf:Property ;
    rdfs:label 'Valuation Date' ;
    rdfs:comment 'Business date on which this inventory cost layer valuation is effective, used for financial period alignment.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valuationStatus rdf:type rdf:Property ;
    rdfs:label 'Valuation Status' ;
    rdfs:comment 'Lifecycle status of this cost layer valuation record, indicating whether it is active, fully consumed, or adjusted.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Valuation Timestamp' ;
    rdfs:comment 'Precise timestamp when this cost layer valuation was calculated or recorded in the system.' ;
    rdfs:domain ind:StockValuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destinationWarehouseWarehouseNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Warehouse Warehouse Node Id' ;
    rdfs:comment 'Identifier of the warehouse or fulfillment center to which inventory is being transferred.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseNode .

ind:primaryTransferWarehouseNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Transfer Warehouse Node Id' ;
    rdfs:comment 'Identifier of the warehouse or fulfillment center from which inventory is being transferred.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseNode .

ind:cancelledByUserCode rdf:type rdf:Property ;
    rdfs:label 'Cancelled By User Code' ;
    rdfs:comment 'Identifier of the user who cancelled the transfer order. Nullable for non-cancelled orders. Used for exception tracking and audit.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationLocationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Location Code' ;
    rdfs:comment 'Specific bin, aisle, or zone location within the destination warehouse where inventory will be stored. Used for putaway planning.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'Estimated date when the transfer shipment will arrive at the destination warehouse. Used for receiving planning and inventory availability forecasting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isCrossDock rdf:type rdf:Property ;
    rdfs:label 'Is Cross Dock' ;
    rdfs:comment 'Flag indicating whether this transfer bypasses storage and goes directly to outbound shipping. Used for fast-moving inventory optimization.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickedDate rdf:type rdf:Property ;
    rdfs:label 'Picked Date' ;
    rdfs:comment 'Date when inventory was picked from source warehouse location. Nullable until picking is completed.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedDate rdf:type rdf:Property ;
    rdfs:label 'Requested Date' ;
    rdfs:comment 'Date by which the transfer is requested to be completed. Used for replenishment planning and fulfillment network optimization.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippedDate rdf:type rdf:Property ;
    rdfs:label 'Shipped Date' ;
    rdfs:comment 'Date when the transfer shipment departed the source warehouse. Used for in-transit inventory tracking and SLA monitoring.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceLocationCode rdf:type rdf:Property ;
    rdfs:label 'Source Location Code' ;
    rdfs:comment 'Specific bin, aisle, or zone location within the source warehouse from which inventory is picked. Enables precise inventory tracking.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled' ;
    rdfs:comment 'Flag indicating whether the transfer requires temperature-controlled transportation. Used for cold chain compliance and carrier selection.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Order Number' ;
    rdfs:comment 'Externally-visible business identifier for the transfer order. Human-readable reference number used in warehouse operations and tracking systems.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferQuantity rdf:type rdf:Property ;
    rdfs:label 'Transfer Quantity' ;
    rdfs:comment 'Quantity of units being transferred from source to destination warehouse. Measured in the SKU\'s base unit of measure.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle status of the transfer order. Tracks the order through warehouse operations from creation to completion. [ENUM-REF-CANDIDATE: created|approved|picked|packed|shipped|in_transit|received|closed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the transfer order purpose. Indicates the business reason for the inter-warehouse movement.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessibilityType rdf:type rdf:Property ;
    rdfs:label 'Accessibility Type' ;
    rdfs:comment 'Equipment or method required to access this storage location. Determines which picking and putaway resources the WMS can assign to tasks involving this location. Automated locations are served by Automated Storage and Retrieval Systems (AS/RS).' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aisleCode rdf:type rdf:Property ;
    rdfs:label 'Aisle Code' ;
    rdfs:comment 'Identifier for the aisle within the warehouse zone where this location is physically situated. Used by WMS for pick-path optimization and travel-time minimization in fulfillment operations.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcode rdf:type rdf:Property ;
    rdfs:label 'Barcode' ;
    rdfs:comment 'Barcode value printed on the physical label affixed to this storage location. Scanned by warehouse operatives using handheld devices or fixed scanners during pick, putaway, and cycle count operations to confirm location identity.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binCode rdf:type rdf:Property ;
    rdfs:label 'Bin Code' ;
    rdfs:comment 'Identifier for the individual bin or slot within the shelf. The most granular physical unit of the warehouse location hierarchy. Directly maps to a scannable barcode label affixed to the physical bin in the warehouse.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUom rdf:type rdf:Property ;
    rdfs:label 'Capacity Uom' ;
    rdfs:comment 'Unit of measure in which the capacity of this storage location is expressed. Aligns with the WMS capacity management configuration for the warehouse node (e.g., \'pallets\' for bulk storage, \'units\' for pick-face bins, \'kg\' for weight-constrained locations).' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency Days' ;
    rdfs:comment 'Target number of days between cycle counts for this location. Drives the WMS cycle count scheduling engine. High-velocity or high-value locations typically have shorter intervals (e.g., 7 days) while low-velocity locations may be counted quarterly (e.g., 90 days).' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dedicatedSku rdf:type rdf:Property ;
    rdfs:label 'Dedicated Sku' ;
    rdfs:comment 'Stock Keeping Unit (SKU) code of the product permanently assigned to this location under a fixed slotting strategy. Null for floating or multi-SKU locations. Used by WMS to enforce single-SKU integrity and prevent mixed-SKU putaway errors.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBulkStorage rdf:type rdf:Property ;
    rdfs:label 'Is Bulk Storage' ;
    rdfs:comment 'Indicates whether this location is designated as a bulk or reserve storage position. Bulk locations hold overstock inventory that replenishes pick face locations. Used in WMS replenishment trigger logic.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazmatApproved rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat Approved' ;
    rdfs:comment 'Indicates whether this storage location has been certified and approved for storing hazardous materials. Drives WMS slotting rules to prevent non-approved locations from receiving hazmat inventory.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPickFace rdf:type rdf:Property ;
    rdfs:label 'Is Pick Face' ;
    rdfs:comment 'Indicates whether this location is designated as an active pick face — a forward-pick position from which pickers directly fulfil customer orders. Pick face locations are replenished from bulk storage and are optimized for pick speed and ergonomics.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isQuarantine rdf:type rdf:Property ;
    rdfs:label 'Is Quarantine' ;
    rdfs:comment 'Indicates whether this location is designated as a quarantine hold area. Inventory placed in quarantine locations is blocked from pick and shipment pending quality inspection, regulatory hold, or Return Merchandise Authorization (RMA) processing.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVirtual rdf:type rdf:Property ;
    rdfs:label 'Is Virtual' ;
    rdfs:comment 'Indicates whether this is a virtual (system-only) storage location with no physical counterpart in the warehouse. Virtual locations are used for in-transit inventory, damaged goods holding, or system adjustment buckets in the WMS.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:levelNumber rdf:type rdf:Property ;
    rdfs:label 'Level Number' ;
    rdfs:comment 'Numeric vertical level of the storage location within the rack structure (e.g., 1 = ground level, 2 = second level). Used for ergonomic slotting rules, forklift accessibility constraints, and pick-path optimization in the WMS.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current operational lifecycle state of the storage location. Controls whether the WMS can allocate inventory to or pick from this location. \'blocked\' indicates a temporary hold (e.g., quality inspection); \'under_maintenance\' indicates physical inaccessibility.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Capacity' ;
    rdfs:comment 'Maximum storage capacity of this location expressed in the unit defined by capacity_uom. Used by WMS to enforce inventory allocation limits and prevent overstocking. Critical for slotting optimization and replenishment planning.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxFillLevel rdf:type rdf:Property ;
    rdfs:label 'Max Fill Level' ;
    rdfs:comment 'Maximum inventory quantity (in capacity_uom) that should be stocked at this location. Used by the WMS to cap replenishment quantities and prevent overfilling. Typically set equal to or less than max_capacity to allow for operational buffer.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minFillLevel rdf:type rdf:Property ;
    rdfs:label 'Min Fill Level' ;
    rdfs:comment 'Minimum inventory quantity (in capacity_uom) that should be maintained at this location before a replenishment task is triggered. Used by the WMS replenishment engine to prevent Out of Stock (OOS) conditions at pick face locations.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mixedSkuAllowed rdf:type rdf:Property ;
    rdfs:label 'Mixed Sku Allowed' ;
    rdfs:comment 'Indicates whether multiple distinct Stock Keeping Units (SKUs) may be co-located in this storage position simultaneously. When false, the WMS enforces single-SKU integrity. Mixed-SKU locations are common in bulk storage but typically prohibited at pick faces to prevent picking errors.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickSequence rdf:type rdf:Property ;
    rdfs:label 'Pick Sequence' ;
    rdfs:comment 'Numeric sequence number used by the WMS to order this location within a pick path or wave. Lower numbers are visited first. Optimized to minimize picker travel distance and maximize throughput in fulfillment operations.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:putawayStrategy rdf:type rdf:Property ;
    rdfs:label 'Putaway Strategy' ;
    rdfs:comment 'Strategy used by the WMS to direct incoming inventory to this location during receiving and putaway operations. Fixed: always assigned to specific Stock Keeping Units (SKUs); floating: any compatible SKU; directed: WMS algorithm assigns; nearest_empty: proximity-based assignment.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rackCode rdf:type rdf:Property ;
    rdfs:label 'Rack Code' ;
    rdfs:comment 'Identifier for the rack or bay within the aisle where this location is physically situated. Part of the hierarchical location address used by WMS for precise inventory positioning.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentStrategy rdf:type rdf:Property ;
    rdfs:label 'Replenishment Strategy' ;
    rdfs:comment 'Inventory rotation and replenishment strategy applied to this location. Governs the order in which stock is consumed and replenished: First In First Out (FIFO), Last In First Out (LIFO), First Expired First Out (FEFO) for perishables, manual (operator-directed), or none (no automated replenishment).' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTag rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag' ;
    rdfs:comment 'RFID tag identifier associated with this storage location for automated inventory tracking and real-time location visibility. Null if the location is not RFID-enabled. Supports real-time inventory visibility in RFID-equipped warehouse nodes.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfCode rdf:type rdf:Property ;
    rdfs:label 'Shelf Code' ;
    rdfs:comment 'Identifier for the shelf level within the rack where this location is physically situated. Shelf codes are used for vertical positioning in WMS pick-path logic and ergonomic slotting (e.g., golden zone placement for high-velocity Stock Keeping Units (SKUs)).' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slottingVelocityClass rdf:type rdf:Property ;
    rdfs:label 'Slotting Velocity Class' ;
    rdfs:comment 'ABC/D velocity classification assigned to this location based on the throughput of Stock Keeping Units (SKUs) slotted here. Class A: highest-velocity (golden zone, ergonomic height); Class B: medium-velocity; Class C: low-velocity; Class D: very slow-moving or seasonal. Drives slotting optimization decisions.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneCode rdf:type rdf:Property ;
    rdfs:label 'Zone Code' ;
    rdfs:comment 'Identifier for the warehouse zone in which this location resides. Zones group locations by operational function, temperature requirement, or product category (e.g., DRY, COLD, HAZMAT, RETURNS). Used for slotting optimization and pick-path routing.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address line of the warehouse node facility. Used for carrier pickup scheduling, regulatory filings, and geographic routing in the TMS.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address line for the warehouse node (suite, dock number, building identifier). Supplements address_line1 for precise carrier and logistics routing.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacitySqft rdf:type rdf:Property ;
    rdfs:label 'Capacity Sqft' ;
    rdfs:comment 'Total usable floor area of the warehouse node in square feet. Principal capacity measurement used for space utilization reporting, lease management, and network capacity planning.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierCodes rdf:type rdf:Property ;
    rdfs:label 'Carrier Codes' ;
    rdfs:comment 'Comma-separated list of carrier codes (e.g., \'UPS,FEDEX,USPS,DHL\') representing the shipping carriers that service this warehouse node. Used by the TMS for carrier selection and rate shopping during order fulfillment.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionedDate rdf:type rdf:Property ;
    rdfs:label 'Commissioned Date' ;
    rdfs:comment 'Date on which the warehouse node was officially commissioned and became operational in the fulfillment network. Used for asset lifecycle tracking, depreciation calculations, and network history reporting.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decommissionedDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioned Date' ;
    rdfs:comment 'Date on which the warehouse node was decommissioned and removed from the active fulfillment network. Null for active nodes. Used for network topology history and asset lifecycle reporting.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dockDoorsInbound rdf:type rdf:Property ;
    rdfs:label 'Dock Doors Inbound' ;
    rdfs:comment 'Number of inbound receiving dock doors at the warehouse node. Determines inbound throughput capacity for purchase order receiving, supplier deliveries, and FTL/LTL carrier appointments.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dockDoorsOutbound rdf:type rdf:Property ;
    rdfs:label 'Dock Doors Outbound' ;
    rdfs:comment 'Number of outbound shipping dock doors at the warehouse node. Determines outbound throughput capacity for order fulfillment, carrier pickups, and cross-dock operations.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glCostCenterCode rdf:type rdf:Property ;
    rdfs:label 'Gl Cost Center Code' ;
    rdfs:comment 'SAP S/4HANA General Ledger cost center code associated with this warehouse node for financial reporting, operational cost allocation, and SOX-compliant expense tracking.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gln rdf:type rdf:Property ;
    rdfs:label 'Gln' ;
    rdfs:comment 'GS1 Global Location Number (GLN) — a 13-digit internationally standardized identifier for this warehouse node. Used in EDI transactions, supply chain partner communications, and global trade compliance.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:is24hrOperation rdf:type rdf:Property ;
    rdfs:label 'Is 24hr Operation' ;
    rdfs:comment 'Indicates whether the warehouse node operates on a 24-hour, continuous basis. When true, overrides operating_hours_start and operating_hours_end for SLA and routing calculations.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:is3pl rdf:type rdf:Property ;
    rdfs:label 'Is 3pl' ;
    rdfs:comment 'Indicates whether this warehouse node is operated by a third-party logistics (3PL) provider rather than owned/operated by the business. Drives cost allocation, SLA contract management, and operational reporting.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isColdStorage rdf:type rdf:Property ;
    rdfs:label 'Is Cold Storage' ;
    rdfs:comment 'Indicates whether the warehouse node has temperature-controlled cold storage capability. Used to route perishable or temperature-sensitive SKUs to eligible nodes during inventory allocation.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazmatCertified rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat Certified' ;
    rdfs:comment 'Indicates whether the warehouse node holds the required certifications to store and handle hazardous materials (hazmat). Drives SKU-level inventory routing and CPSC compliance checks.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReturnsEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Returns Enabled' ;
    rdfs:comment 'Indicates whether this warehouse node is authorized to receive and process customer returns and RMA (Return Merchandise Authorization) shipments. Controls return routing logic in the OMS.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiry Date' ;
    rdfs:comment 'Date on which the facility lease for this warehouse node expires. Used for network planning, lease renewal management, and long-term capacity forecasting. Applicable to leased facilities only.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxWeightCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Max Weight Capacity Kg' ;
    rdfs:comment 'Maximum total weight capacity of the warehouse node in kilograms. Used for structural load compliance, inventory planning, and safety management per facility engineering specifications.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkTier rdf:type rdf:Property ;
    rdfs:label 'Network Tier' ;
    rdfs:comment 'Hierarchical tier classification of the warehouse node within the fulfillment network topology. Hub nodes serve as primary distribution points; spoke nodes serve last-mile delivery zones. Drives inventory positioning and replenishment flow.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeCode rdf:type rdf:Property ;
    rdfs:label 'Node Code' ;
    rdfs:comment 'Externally-known, human-readable alphanumeric code uniquely identifying the warehouse node across all operational systems (WMS, TMS, OMS). Used as the business key in EDI, carrier integrations, and fulfillment routing logic.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeName rdf:type rdf:Property ;
    rdfs:label 'Node Name' ;
    rdfs:comment 'Full descriptive name of the warehouse node as used in operational communications, reporting dashboards, and carrier documentation (e.g., \'Dallas Fulfillment Center - North\').' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeStatus rdf:type rdf:Property ;
    rdfs:label 'Node Status' ;
    rdfs:comment 'Current operational lifecycle status of the warehouse node. Controls whether the node is eligible to receive inventory allocations, fulfill orders, or participate in replenishment planning.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeType rdf:type rdf:Property ;
    rdfs:label 'Node Type' ;
    rdfs:comment 'Classification of the warehouse node by its operational role in the fulfillment network. Drives routing logic, SLA assignment, and capacity planning. [ENUM-REF-CANDIDATE: fulfillment_center|distribution_center|dark_store|3pl_facility|drop_ship_node|returns_center — promote to reference product]' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingDays rdf:type rdf:Property ;
    rdfs:label 'Operating Days' ;
    rdfs:comment 'Comma-separated list of operating days of the week for the warehouse node (e.g., \'MON,TUE,WED,THU,FRI\'). Used for SLA cutoff scheduling, carrier appointment booking, and fulfillment routing logic.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Operating Hours End' ;
    rdfs:comment 'Standard daily operating end time for the warehouse node in HH:MM (24-hour) format. Used to determine carrier pickup cutoff windows, SLA calculation, and order routing eligibility.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursStart rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Start' ;
    rdfs:comment 'Standard daily operating start time for the warehouse node in HH:MM (24-hour) format. Used to determine carrier pickup cutoff windows, SLA calculation, and order routing eligibility.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletPositions rdf:type rdf:Property ;
    rdfs:label 'Pallet Positions' ;
    rdfs:comment 'Total number of standard pallet positions available in the warehouse node. Used for inventory capacity planning, MOQ compliance, and replenishment scheduling in the WMS.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tmsLocationCode rdf:type rdf:Property ;
    rdfs:label 'Tms Location Code' ;
    rdfs:comment 'Location code assigned by the Transportation Management System (TMS) for this warehouse node. Used for carrier pickup scheduling, route optimization, and shipment origin identification.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsFacilityReference rdf:type rdf:Property ;
    rdfs:label 'Wms Facility Reference' ;
    rdfs:comment 'Native facility identifier assigned by the Warehouse Management System (WMS) for this warehouse node. Used for system integration, EDI message routing, and reconciliation between the WMS and the lakehouse SSOT.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityTons rdf:type rdf:Property ;
    rdfs:label 'Capacity Tons' ;
    rdfs:comment 'Maximum weight capacity the carrier can transport per shipment.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierStatus rdf:type rdf:Property ;
    rdfs:label 'Carrier Status' ;
    rdfs:comment 'Current lifecycle status of the carrier (e.g., active, inactive, suspended, pending onboarding).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierTier rdf:type rdf:Property ;
    rdfs:label 'Carrier Tier' ;
    rdfs:comment 'Internal tier used to prioritize carriers based on performance, volume, and strategic importance.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierType rdf:type rdf:Property ;
    rdfs:label 'Carrier Type' ;
    rdfs:comment 'Primary service category the carrier provides (e.g., Full-Truck-Load, Less-Truck-Load, parcel, last-mile, cross-border).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCtpat rdf:type rdf:Property ;
    rdfs:label 'Compliance Ctpat' ;
    rdfs:comment 'Indicates whether the carrier holds a valid C-TPAT certification.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceIata rdf:type rdf:Property ;
    rdfs:label 'Compliance Iata' ;
    rdfs:comment 'Indicates whether the carrier is certified by IATA for air freight operations.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceWto rdf:type rdf:Property ;
    rdfs:label 'Compliance Wto' ;
    rdfs:comment 'Indicates whether the carrier complies with WTO trade regulations for cross-border shipments.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'Name of the primary business contact for the carrier.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:country rdf:type rdf:Property ;
    rdfs:label 'Country' ;
    rdfs:comment 'Three-letter ISO country code where the carrier is headquartered.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Number' ;
    rdfs:comment 'Seven-digit identifier assigned by the U.S. Department of Transportation to the carrier.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ediIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Edi Integration Status' ;
    rdfs:comment 'Current status of Electronic Data Interchange integration with the carrier.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiry Date' ;
    rdfs:comment 'Date when the carrier\'s insurance coverage expires.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Max Weight Lbs' ;
    rdfs:comment 'Maximum weight in pounds the carrier can handle for a single shipment.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingScore rdf:type rdf:Property ;
    rdfs:label 'Rating Score' ;
    rdfs:comment 'Aggregated performance rating (0-5) based on on-time delivery, damage rate, and service quality.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scacCode rdf:type rdf:Property ;
    rdfs:label 'Scac Code' ;
    rdfs:comment 'Four-character alphanumeric code that uniquely identifies the carrier in industry systems.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCapabilities rdf:type rdf:Property ;
    rdfs:label 'Service Capabilities' ;
    rdfs:comment 'Free-text description of the carrier\'s capabilities (e.g., temperature-controlled, hazardous-material, LTL consolidation).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDeliveryTimeActual rdf:type rdf:Property ;
    rdfs:label 'Sla Delivery Time Actual' ;
    rdfs:comment 'Actual delivery time in minutes recorded for the carrier.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaDeliveryTimeTarget rdf:type rdf:Property ;
    rdfs:label 'Sla Delivery Time Target' ;
    rdfs:comment 'Target delivery time in minutes defined in the carrier SLA.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:state rdf:type rdf:Property ;
    rdfs:label 'State' ;
    rdfs:comment 'State or province component of the carrier\'s primary address.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Public website address of the carrier.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierContractId rdf:type rdf:Property ;
    rdfs:label 'Carrier Contract Id' ;
    rdfs:comment 'System-generated unique identifier for each carrier contract record.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amendmentDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Date' ;
    rdfs:comment 'Date when the latest amendment was executed.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentDescription rdf:type rdf:Property ;
    rdfs:label 'Amendment Description' ;
    rdfs:comment 'Summary of changes introduced by the latest amendment.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Sequential number of the most recent amendment to the contract.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the contract automatically renews at expiry.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierContractStatus rdf:type rdf:Property ;
    rdfs:label 'Carrier Contract Status' ;
    rdfs:comment 'Current lifecycle state of the contract.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Flag' ;
    rdfs:comment 'Marks the contract as confidential for internal handling.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

