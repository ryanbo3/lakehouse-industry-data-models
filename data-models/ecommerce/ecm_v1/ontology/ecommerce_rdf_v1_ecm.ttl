    rdfs:range xsd:string .

ind:indexName rdf:type rdf:Property ;
    rdfs:label 'Index Name' ;
    rdfs:comment 'Human-readable name of the index used in UI and reporting.' ;
    rdfs:domain ind:Index ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexType rdf:type rdf:Property ;
    rdfs:label 'Index Type' ;
    rdfs:comment 'Category of assets the index serves (e.g., product catalog, content pages, seller profiles, or category taxonomy).' ;
    rdfs:domain ind:Index ;
    rdf:type owl:DatatypeProperty ;
