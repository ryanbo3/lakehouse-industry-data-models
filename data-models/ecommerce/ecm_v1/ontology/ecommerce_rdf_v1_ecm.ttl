    rdfs:comment 'Total number of visual components (charts, tables, maps) in the dashboard.' ;
    rdfs:domain ind:DashboardDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dashboardWidgetId rdf:type rdf:Property ;
    rdfs:label 'Dashboard Widget Id' ;
    rdfs:comment 'Unique identifier for the dashboard widget.' ;
    rdfs:domain ind:DashboardWidget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownerAgentId rdf:type rdf:Property ;
    rdfs:label 'Owner Agent Id' ;
    rdfs:comment 'Foreign key linking to service.agent. Business justification: Widgets may be customized by individual agents; linking owner_agent_id to agent.agent_id tracks widget ownership and change history.' ;
    rdfs:domain ind:Ecommerce ;
