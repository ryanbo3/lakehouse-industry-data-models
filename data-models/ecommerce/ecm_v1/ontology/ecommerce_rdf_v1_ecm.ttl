ind:supplierInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Supplier Invoice Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier_invoice. Business justification: Finance reconciliation of transport cost requires a direct FK to the Supplier Invoice that records the freight charge.' ;
    rdfs:domain ind:Ecommerce ;
