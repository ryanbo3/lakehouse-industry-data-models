    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryHealthScore rdf:type rdf:Property ;
    rdfs:label 'Inventory Health Score' ;
    rdfs:comment 'Composite score reflecting inventory availability and turnover for the seller.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastTierChangeDate rdf:type rdf:Property ;
    rdfs:label 'Last Tier Change Date' ;
    rdfs:comment 'Date when the seller most recently moved to a new performance tier.' ;
