    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Template .

ind:aBTestVariantName rdf:type rdf:Property ;
    rdfs:label 'A B Test Variant Name' ;
    rdfs:comment 'Identifier for the specific A/B test variant applied to the slot.' ;
