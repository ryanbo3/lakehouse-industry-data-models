    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:npsContributionScore rdf:type rdf:Property ;
    rdfs:label 'Nps Contribution Score' ;
    rdfs:comment 'Seller\'s contribution to the Net Promoter Score based on customer feedback.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderDefectRate rdf:type rdf:Property ;
    rdfs:label 'Order Defect Rate' ;
    rdfs:comment 'Proportion of orders with defects (e.g., cancellations, returns) expressed as a decimal fraction.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceTierRating rdf:type rdf:Property ;
    rdfs:label 'Performance Tier Rating' ;
    rdfs:comment 'Current tier assigned to the seller based on overall performance.' ;
    rdfs:domain ind:Scorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyViolationCount rdf:type rdf:Property ;
    rdfs:label 'Policy Violation Count' ;
