    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bsr rdf:type rdf:Property ;
    rdfs:label 'Bsr' ;
    rdfs:comment 'Seller\'s rank within its product category based on sales performance.' ;
