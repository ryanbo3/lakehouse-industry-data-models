    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalCode rdf:type rdf:Property ;
    rdfs:label 'Promotional Code' ;
    rdfs:comment 'Optional code that provides a discount or special terms for the plan.' ;
