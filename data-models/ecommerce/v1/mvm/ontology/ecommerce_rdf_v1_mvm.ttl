ind:trackingEventId rdf:type rdf:Property ;
    rdfs:label 'Tracking Event Id' ;
    rdfs:comment 'Globally unique surrogate key for each shipment tracking event.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierFacilityCode rdf:type rdf:Property ;
