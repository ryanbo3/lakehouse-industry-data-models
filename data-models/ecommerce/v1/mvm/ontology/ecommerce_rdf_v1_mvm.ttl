ind:surchargeResidential rdf:type rdf:Property ;
    rdfs:label 'Surcharge Residential' ;
    rdfs:comment 'Indicates whether a residential-delivery surcharge applies to this zone.' ;
    rdfs:domain ind:DeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:zoneName rdf:type rdf:Property ;
    rdfs:label 'Zone Name' ;
    rdfs:comment 'Human-readable name of the delivery zone.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneTier rdf:type rdf:Property ;
    rdfs:label 'Zone Tier' ;
    rdfs:comment 'Tier classification used for pricing and service level differentiation.' ;
    rdfs:domain ind:DeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Date' ;
    rdfs:comment 'Date when the latest amendment was executed.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentDescription rdf:type rdf:Property ;
    rdfs:label 'Amendment Description' ;
    rdfs:comment 'Summary of changes introduced by the latest amendment.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Sequential number of the most recent amendment to the contract.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierContractStatus rdf:type rdf:Property ;
    rdfs:label 'Carrier Contract Status' ;
    rdfs:comment 'Current lifecycle state of the contract.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Flag' ;
    rdfs:comment 'Marks the contract as confidential for internal handling.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractCategory rdf:type rdf:Property ;
    rdfs:label 'Contract Category' ;
    rdfs:comment 'Indicates whether the contract applies to domestic or international shipments.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Contract Document Url' ;
    rdfs:comment 'Link to the stored electronic copy of the signed contract.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Contract Manager Email' ;
    rdfs:comment 'Email address of the contract manager.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractManagerName rdf:type rdf:Property ;
    rdfs:label 'Contract Manager Name' ;
    rdfs:comment 'Name of the person managing day-to-day contract activities.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractManagerPhone rdf:type rdf:Property ;
    rdfs:label 'Contract Manager Phone' ;
    rdfs:comment 'Phone number of the contract manager.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractOwner rdf:type rdf:Property ;
    rdfs:label 'Contract Owner' ;
    rdfs:comment 'Internal stakeholder responsible for the contract\'s overall performance.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractRegion rdf:type rdf:Property ;
    rdfs:label 'Contract Region' ;
    rdfs:comment 'Geographic region covered by the contract.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractSignedDate rdf:type rdf:Property ;
    rdfs:label 'Contract Signed Date' ;
    rdfs:comment 'Date when the contract was formally signed by both parties.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStatusChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Contract Status Change Timestamp' ;
    rdfs:comment 'Timestamp when the contract status last changed.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contractStatusReason rdf:type rdf:Property ;
    rdfs:label 'Contract Status Reason' ;
    rdfs:comment 'Reason or narrative explaining the most recent status change.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedVolume rdf:type rdf:Property ;
    rdfs:label 'Contracted Volume' ;
    rdfs:comment 'Total volume of freight (e.g., tons) the carrier commits to transport under the contract.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPreferred rdf:type rdf:Property ;
    rdfs:label 'Is Preferred' ;
    rdfs:comment 'Marks the carrier as a preferred partner for routing decisions.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Monetary penalty applied for SLA breaches or contract violations.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyCurrency rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency' ;
    rdfs:comment 'Currency of the penalty amount.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardReference rdf:type rdf:Property ;
    rdfs:label 'Rate Card Reference' ;
    rdfs:comment 'Identifier linking to the carrier\'s rate card that defines pricing structures.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Months' ;
    rdfs:comment 'Number of months for each renewal period when auto-renewal is enabled.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaDeliveryTimeActualHours rdf:type rdf:Property ;
    rdfs:label 'Sla Delivery Time Actual Hours' ;
    rdfs:comment 'Actual delivery time recorded for the contract period.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaDeliveryTimeTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Delivery Time Target Hours' ;
    rdfs:comment 'Targeted delivery time in hours as defined in the SLA.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Period Days' ;
    rdfs:comment 'Required notice period in days before contract termination.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Unit' ;
    rdfs:comment 'Unit of measure for the contracted volume.' ;
    rdfs:domain ind:CarrierContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayId rdf:type rdf:Property ;
    rdfs:label 'Gateway Id' ;
    rdfs:comment 'Foreign key linking to payment.gateway. Business justification: Every payment transaction is processed through a specific payment gateway. payment_transaction currently captures gateway_response_code and gateway_response_message as string fields but has no FK to t' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Gateway .

ind:merchantAccountId rdf:type rdf:Property ;
    rdfs:label 'Merchant Account Id' ;
    rdfs:comment 'Identifier of the merchant receiving the payment.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchantAccount .

ind:reconciliationId rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Id' ;
    rdfs:comment 'Foreign key linking to payment.reconciliation. Business justification: Transactions are part of a reconciliation run; linking via reconciliation_id enables auditability and variance analysis.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Reconciliation .

ind:tokenId rdf:type rdf:Property ;
    rdfs:label 'Token Id' ;
    rdfs:comment 'Foreign key linking to payment.token. Business justification: Payment transactions processed with tokenized card data reference a specific PCI DSS token in the token registry. payment_transaction currently has card_last4, card_brand, card_expiry_month, card_expi' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Token .

ind:tokenizedPaymentMethodId rdf:type rdf:Property ;
    rdfs:label 'Tokenized Payment Method Id' ;
    rdfs:comment 'PCI-DSS compliant token representing the stored payment method.' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Method .

ind:walletId rdf:type rdf:Property ;
    rdfs:label 'Wallet Id' ;
    rdfs:comment 'Foreign key linking to payment.wallet. Business justification: Payment transactions can be funded from a customer digital wallet. payment_transaction currently has no FK to the wallet table, despite wallet being a first-class payment instrument in the domain. Add' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wallet .

ind:amountFee rdf:type rdf:Property ;
    rdfs:label 'Amount Fee' ;
    rdfs:comment 'Processing fee charged by the payment gateway.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountGross rdf:type rdf:Property ;
    rdfs:label 'Amount Gross' ;
    rdfs:comment 'Total amount authorized before fees or taxes.' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountNet rdf:type rdf:Property ;
    rdfs:label 'Amount Net' ;
    rdfs:comment 'Final amount settled to the merchant after fees and taxes.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountTax rdf:type rdf:Property ;
    rdfs:label 'Amount Tax' ;
    rdfs:comment 'Tax component applied to the transaction.' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'Code returned by the issuing bank authorizing the transaction.' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardBrand rdf:type rdf:Property ;
    rdfs:label 'Card Brand' ;
    rdfs:comment 'Brand of the payment card when card-based method is used.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardExpiryMonth rdf:type rdf:Property ;
    rdfs:label 'Card Expiry Month' ;
    rdfs:comment 'Expiration month of the payment card.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardExpiryYear rdf:type rdf:Property ;
    rdfs:label 'Card Expiry Year' ;
    rdfs:comment 'Expiration year of the payment card.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardLast4 rdf:type rdf:Property ;
    rdfs:label 'Card Last4' ;
    rdfs:comment 'Last four digits of the card number for display and reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackFlag rdf:type rdf:Property ;
    rdfs:label 'Chargeback Flag' ;
    rdfs:comment 'Indicates whether the transaction resulted in a chargeback.' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceFlags rdf:type rdf:Property ;
    rdfs:label 'Compliance Flags' ;
    rdfs:comment 'Comma-separated list of compliance regimes applicable to the transaction.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceFingerprint rdf:type rdf:Property ;
    rdfs:label 'Device Fingerprint' ;
    rdfs:comment 'Identifier of the device used to capture the payment.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayResponseCode rdf:type rdf:Property ;
    rdfs:label 'Gateway Response Code' ;
    rdfs:comment 'Standardized response code from the payment gateway.' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayResponseMessage rdf:type rdf:Property ;
    rdfs:label 'Gateway Response Message' ;
    rdfs:comment 'Human-readable message accompanying the gateway response code.' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifier rdf:type rdf:Property ;
    rdfs:label 'Identifier' ;
    rdfs:comment 'External identifier assigned by the payment gateway for this transaction.' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Merchant Category Code' ;
    rdfs:comment 'Four-digit code classifying the merchant\'s industry.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTransactionDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Transaction Description' ;
    rdfs:comment 'Free-form description or memo for the transaction.' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTransactionStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Transaction Status' ;
    rdfs:comment 'Current lifecycle state of the transaction.' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurringCycle rdf:type rdf:Property ;
    rdfs:label 'Recurring Cycle' ;
    rdfs:comment 'Frequency of the recurring payment.' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurringEndDate rdf:type rdf:Property ;
    rdfs:label 'Recurring End Date' ;
    rdfs:comment 'Date when the recurring payment schedule terminates.' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskAssessment rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment' ;
    rdfs:comment 'Overall risk classification derived from fraud score and other signals.' ;
    rdfs:domain ind:PaymentTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'Date on which funds were settled to the merchant account.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Status' ;
    rdfs:comment 'Current status of the settlement process.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodId rdf:type rdf:Property ;
    rdfs:label 'Method Id' ;
    rdfs:comment 'Primary key for method' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Method .

ind:billingCustomerAddressId rdf:type rdf:Property ;
    rdfs:label 'Billing Customer Address Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_address. Business justification: Address verification and 3NF normalization: payment method billing address is denormalized across five columns. Linking to customer_address enables AVS (Address Verification Service) checks, address c' ;
    rdfs:domain ind:Method ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAddress .

ind:cardNetwork rdf:type rdf:Property ;
    rdfs:label 'Card Network' ;
    rdfs:comment 'Card scheme or network for card-based methods.' ;
    rdfs:domain ind:Method ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderEmail rdf:type rdf:Property ;
    rdfs:label 'Cardholder Email' ;
    rdfs:comment 'Email address associated with the cardholder.' ;
    rdfs:domain ind:Method ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderName rdf:type rdf:Property ;
    rdfs:label 'Cardholder Name' ;
    rdfs:comment 'Legal name of the cardholder as it appears on the card.' ;
    rdfs:domain ind:Method ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderPhone rdf:type rdf:Property ;
    rdfs:label 'Cardholder Phone' ;
    rdfs:comment 'Phone number associated with the cardholder.' ;
    rdfs:domain ind:Method ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Timestamp' ;
    rdfs:comment 'Timestamp of the most recent compliance verification.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current compliance posture of the payment method with regulatory standards.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Daily Limit Amount' ;
    rdfs:comment 'Maximum cumulative amount allowed per day.' ;
    rdfs:domain ind:Method ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expiryMonth rdf:type rdf:Property ;
    rdfs:label 'Expiry Month' ;
    rdfs:comment 'Expiration month of the card (1-12).' ;
    rdfs:domain ind:Method ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expiryYear rdf:type rdf:Property ;
    rdfs:label 'Expiry Year' ;
    rdfs:comment 'Expiration year of the card (four-digit).' ;
    rdfs:domain ind:Method ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isInternationalAllowed rdf:type rdf:Property ;
    rdfs:label 'Is International Allowed' ;
    rdfs:comment 'Indicates if the payment method supports cross-border transactions.' ;
    rdfs:domain ind:Method ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOneTimeAllowed rdf:type rdf:Property ;
    rdfs:label 'Is One Time Allowed' ;
    rdfs:comment 'Indicates if the payment method can be used for one-off transactions.' ;
    rdfs:domain ind:Method ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecurringAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Recurring Allowed' ;
    rdfs:comment 'Indicates if the payment method can be used for recurring billing.' ;
    rdfs:domain ind:Method ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingBank rdf:type rdf:Property ;
    rdfs:label 'Issuing Bank' ;
    rdfs:comment 'Name of the financial institution that issued the card or account.' ;
    rdfs:domain ind:Method ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastFour rdf:type rdf:Property ;
    rdfs:label 'Last Four' ;
    rdfs:comment 'Last four digits of the card number (masked).' ;
    rdfs:domain ind:Method ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUsedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Used Timestamp' ;
    rdfs:comment 'Timestamp when the payment method was last used in a transaction.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:methodDescription rdf:type rdf:Property ;
    rdfs:label 'Method Description' ;
    rdfs:comment 'Optional free-text description of the payment method.' ;
    rdfs:domain ind:Method ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodStatus rdf:type rdf:Property ;
    rdfs:label 'Method Status' ;
    rdfs:comment 'Current lifecycle status of the payment method.' ;
    rdfs:domain ind:Method ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodType rdf:type rdf:Property ;
    rdfs:label 'Method Type' ;
    rdfs:comment 'Category of the payment instrument.' ;
    rdfs:domain ind:Method ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Limit Amount' ;
    rdfs:comment 'Maximum cumulative amount allowed per calendar month.' ;
    rdfs:domain ind:Method ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethodName rdf:type rdf:Property ;
    rdfs:label 'Payment Method Name' ;
    rdfs:comment 'User-defined nickname for the payment method.' ;
    rdfs:domain ind:Method ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceRank rdf:type rdf:Property ;
    rdfs:label 'Preference Rank' ;
    rdfs:comment 'User-defined ranking indicating preferred payment method order.' ;
    rdfs:domain ind:Method ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Overall risk classification for the payment method.' ;
    rdfs:domain ind:Method ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaEnrolled rdf:type rdf:Property ;
    rdfs:label 'Sca Enrolled' ;
    rdfs:comment 'Indicates whether the payment method is enrolled for SCA (e.g., 3-DS).' ;
    rdfs:domain ind:Method ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tokenReference rdf:type rdf:Property ;
    rdfs:label 'Token Reference' ;
    rdfs:comment 'PCI-DSS token that represents the underlying card or bank account.' ;
    rdfs:domain ind:Method ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenizationProvider rdf:type rdf:Property ;
    rdfs:label 'Tokenization Provider' ;
    rdfs:comment 'Vendor or service that performed tokenization of the payment instrument.' ;
    rdfs:domain ind:Method ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Limit Amount' ;
    rdfs:comment 'Maximum amount allowed per individual transaction.' ;
    rdfs:domain ind:Method ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizationId rdf:type rdf:Property ;
    rdfs:label 'Authorization Id' ;
    rdfs:comment 'System-generated unique identifier for the payment authorization record.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Authorization .

ind:authAmount rdf:type rdf:Property ;
    rdfs:label 'Auth Amount' ;
    rdfs:comment 'Monetary amount requested for authorization, expressed in the transaction currency.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authCode rdf:type rdf:Property ;
    rdfs:label 'Auth Code' ;
    rdfs:comment 'Issuer-provided code confirming successful authorization.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Authorization Status' ;
    rdfs:comment 'Current lifecycle state of the authorization (e.g., authorized, declined, voided).' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avsResult rdf:type rdf:Property ;
    rdfs:label 'Avs Result' ;
    rdfs:comment 'Result of the AVS check comparing billing address to card records.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'Three-letter country code of the billing address.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:challengeStatus rdf:type rdf:Property ;
    rdfs:label 'Challenge Status' ;
    rdfs:comment 'Status of any 3-DS challenge presented to the cardholder.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cvvResult rdf:type rdf:Property ;
    rdfs:label 'Cvv Result' ;
    rdfs:comment 'Result of the CVV check for the card.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declineReason rdf:type rdf:Property ;
    rdfs:label 'Decline Reason' ;
    rdfs:comment 'Issuer-provided textual reason for a declined authorization.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Expiry Timestamp' ;
    rdfs:comment 'Time when the authorization hold is scheduled to expire if not captured.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isCaptured rdf:type rdf:Property ;
    rdfs:label 'Is Captured' ;
    rdfs:comment 'True if the authorized amount has been captured.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPartialCaptureAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Partial Capture Allowed' ;
    rdfs:comment 'Indicates whether the authorized amount can be captured in parts.' ;
    rdfs:domain ind:Authorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRefunded rdf:type rdf:Property ;
    rdfs:label 'Is Refunded' ;
    rdfs:comment 'True if the captured amount has been fully refunded.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTestTransaction rdf:type rdf:Property ;
    rdfs:label 'Is Test Transaction' ;
    rdfs:comment 'True if the authorization was generated in a test or sandbox environment.' ;
