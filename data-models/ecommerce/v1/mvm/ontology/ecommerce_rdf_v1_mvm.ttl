    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listingCategoryDescription rdf:type rdf:Property ;
    rdfs:label 'Listing Category Description' ;
    rdfs:comment 'Full textual description of the category purpose and scope.' ;
    rdfs:domain ind:ListingCategory ;
