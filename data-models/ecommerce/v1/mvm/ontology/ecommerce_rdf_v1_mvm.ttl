    rdfs:comment 'Role of the user who performed the last audit action (e.g., pricing_manager).' ;
    rdfs:domain ind:PriceListItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleComponentSkus rdf:type rdf:Property ;
