ind:dailyVolumeLimit rdf:type rdf:Property ;
    rdfs:label 'Daily Volume Limit' ;
    rdfs:comment 'Maximum total transaction amount per day.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isMultiCurrency rdf:type rdf:Property ;
    rdfs:label 'Is Multi Currency' ;
    rdfs:comment 'Indicates if the account supports multiple currencies.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTestAccount rdf:type rdf:Property ;
    rdfs:label 'Is Test Account' ;
    rdfs:comment 'Indicates if this is a test or sandbox merchant account.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Last Settlement Date' ;
    rdfs:comment 'Date of the most recent settlement for this account.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:merchantAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Merchant Account Number' ;
    rdfs:comment 'Unique account number assigned by acquiring bank.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Merchant Account Status' ;
    rdfs:comment 'Current status of the merchant account.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyTransactionLimit rdf:type rdf:Property ;
    rdfs:label 'Monthly Transaction Limit' ;
    rdfs:comment 'Maximum number of transactions allowed per month.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monthlyVolumeLimit rdf:type rdf:Property ;
    rdfs:label 'Monthly Volume Limit' ;
    rdfs:comment 'Maximum total transaction amount per month.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentNetwork rdf:type rdf:Property ;
    rdfs:label 'Payment Network' ;
    rdfs:comment 'Payment card network associated with the merchant account.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Pci Compliance Status' ;
    rdfs:comment 'PCI DSS compliance status.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingCurrency rdf:type rdf:Property ;
    rdfs:label 'Processing Currency' ;
    rdfs:comment 'Currency in which transactions are processed.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingFeeFixed rdf:type rdf:Property ;
    rdfs:label 'Processing Fee Fixed' ;
    rdfs:comment 'Fixed fee per transaction.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'Indicates if the account is subject to special regulatory reporting.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementBankAccount rdf:type rdf:Property ;
    rdfs:label 'Settlement Bank Account' ;
    rdfs:comment 'Bank account number where settlements are deposited.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementBankName rdf:type rdf:Property ;
    rdfs:label 'Settlement Bank Name' ;
    rdfs:comment 'Name of the bank where settlements are deposited.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementBankSwiftCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Bank Swift Code' ;
    rdfs:comment 'SWIFT/BIC code of the settlement bank.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenizationEnabled rdf:type rdf:Property ;
    rdfs:label 'Tokenization Enabled' ;
    rdfs:comment 'Indicates if card data tokenization is used.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tokenizationMethod rdf:type rdf:Property ;
    rdfs:label 'Tokenization Method' ;
    rdfs:comment 'Method of tokenization applied.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedLineCount rdf:type rdf:Property ;
    rdfs:label 'Matched Line Count' ;
    rdfs:comment 'Number of line items where internal transaction matched the external statement.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'End date of the financial period covered by this reconciliation.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'Start date of the financial period covered by this reconciliation.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationNumber rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Number' ;
    rdfs:comment 'Business-visible identifier for the reconciliation run, often used in reporting and audit trails.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runTimestamp rdf:type rdf:Property ;
    rdfs:label 'Run Timestamp' ;
    rdfs:comment 'Exact time when the reconciliation process was executed.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Classification of the reconciliation run frequency or trigger.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalExternalAmount rdf:type rdf:Property ;
    rdfs:label 'Total External Amount' ;
    rdfs:comment 'Aggregate monetary value of external bank/gateway statement records for the period.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalInternalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Internal Amount' ;
    rdfs:comment 'Aggregate monetary value of internal transaction records for the period.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unmatchedLineCount rdf:type rdf:Property ;
    rdfs:label 'Unmatched Line Count' ;
    rdfs:comment 'Number of line items that did not find a matching counterpart.' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'Difference between total internal and external amounts (internal - external).' ;
    rdfs:domain ind:Reconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balance rdf:type rdf:Property ;
    rdfs:label 'Balance' ;
    rdfs:comment 'Current available balance in the wallet, expressed in the wallet\'s currency.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceToken rdf:type rdf:Property ;
    rdfs:label 'Compliance Token' ;
    rdfs:comment 'PCI-DSS-compliant token representing the underlying payment instrument used for funding; stored instead of raw card data.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultWallet rdf:type rdf:Property ;
    rdfs:label 'Is Default Wallet' ;
    rdfs:comment 'Indicates whether this wallet is the default payment source for the owner customer.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTopupAmount rdf:type rdf:Property ;
    rdfs:label 'Last Topup Amount' ;
    rdfs:comment 'Amount of the most recent top-up (funding) transaction.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastTransactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Timestamp' ;
    rdfs:comment 'Timestamp of the most recent balance-affecting transaction recorded for the wallet.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastWithdrawalAmount rdf:type rdf:Property ;
    rdfs:label 'Last Withdrawal Amount' ;
    rdfs:comment 'Amount of the most recent withdrawal or redemption transaction.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pendingBalance rdf:type rdf:Property ;
    rdfs:label 'Pending Balance' ;
    rdfs:comment 'Balance amount that is pending settlement (e.g., authorizations awaiting capture).' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCredits rdf:type rdf:Property ;
    rdfs:label 'Total Credits' ;
    rdfs:comment 'Cumulative sum of all credit-type movements (top-ups, refunds, promotions) to the wallet.' ;
