    rdfs:comment 'Historical elasticity metric used for dynamic pricing decisions.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceListCode rdf:type rdf:Property ;
    rdfs:label 'Price List Code' ;
    rdfs:comment 'Unique business code used to reference the price list in external systems and contracts.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListDescription rdf:type rdf:Property ;
    rdfs:label 'Price List Description' ;
    rdfs:comment 'Free-form description providing context, purpose, and any special rules for the price list.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListStatus rdf:type rdf:Property ;
    rdfs:label 'Price List Status' ;
    rdfs:comment 'Current lifecycle state of the price list.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePrecision rdf:type rdf:Property ;
