    rdfs:comment 'Human-readable description of the event type.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionReasonCode rdf:type rdf:Property ;
