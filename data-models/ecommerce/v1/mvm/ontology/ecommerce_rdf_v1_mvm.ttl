    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDebits rdf:type rdf:Property ;
    rdfs:label 'Total Debits' ;
    rdfs:comment 'Cumulative sum of all debit-type movements (purchases, withdrawals, redemptions) from the wallet.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:walletName rdf:type rdf:Property ;
    rdfs:label 'Wallet Name' ;
    rdfs:comment 'Descriptive name for the wallet (e.g., "My Store Credit").' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:walletNumber rdf:type rdf:Property ;
    rdfs:label 'Wallet Number' ;
    rdfs:comment 'Human-readable unique wallet number assigned to the account.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:walletStatus rdf:type rdf:Property ;
    rdfs:label 'Wallet Status' ;
    rdfs:comment 'Current operational state of the wallet.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:walletType rdf:type rdf:Property ;
    rdfs:label 'Wallet Type' ;
    rdfs:comment 'Category of wallet indicating its purpose and rules (store credit, loyalty points, prepaid balance, gift, promotional).' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditLogReference rdf:type rdf:Property ;
    rdfs:label 'Audit Log Reference' ;
    rdfs:comment 'Reference to the audit log entry that records token lifecycle events.' ;
    rdfs:domain ind:Token ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:encryptionKeyReference rdf:type rdf:Property ;
    rdfs:label 'Encryption Key Reference' ;
    rdfs:comment 'Identifier of the cryptographic key used to encrypt the token.' ;
    rdfs:domain ind:Token ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:format rdf:type rdf:Property ;
    rdfs:label 'Format' ;
    rdfs:comment 'Technical format of the token (e.g., alphanumeric, numeric).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hashAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Hash Algorithm' ;
    rdfs:comment 'Hash algorithm applied to the token for integrity verification.' ;
    rdfs:domain ind:Token ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issued Timestamp' ;
    rdfs:comment 'Date-time when the token was created.' ;
    rdfs:domain ind:Token ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:length rdf:type rdf:Property ;
    rdfs:label 'Length' ;
    rdfs:comment 'Number of characters in the token.' ;
    rdfs:domain ind:Token ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:method rdf:type rdf:Property ;
    rdfs:label 'Method' ;
    rdfs:comment 'Process used to generate the token.' ;
    rdfs:domain ind:Token ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provider rdf:type rdf:Property ;
    rdfs:label 'Provider' ;
    rdfs:comment 'Entity that issued or generated the token.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secureValue rdf:type rdf:Property ;
    rdfs:label 'Secure Value' ;
    rdfs:comment 'PCI-compliant token that replaces the original PAN for transaction processing.' ;
    rdfs:domain ind:Token ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tokenStatus rdf:type rdf:Property ;
    rdfs:label 'Token Status' ;
    rdfs:comment 'Current lifecycle status of the token.' ;
    rdfs:domain ind:Token ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenType rdf:type rdf:Property ;
    rdfs:label 'Token Type' ;
    rdfs:comment 'Indicates whether the token is a network-issued token or a platform-generated token.' ;
    rdfs:domain ind:Token ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cartId rdf:type rdf:Property ;
    rdfs:label 'Cart Id' ;
    rdfs:comment 'Unique identifier for the cart (primary key).' ;
    rdfs:domain ind:Order ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cart .

ind:shippingCustomerAddressId rdf:type rdf:Property ;
    rdfs:label 'Shipping Customer Address Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_address. Business justification: Cart currently stores shipping address as denormalized plain columns violating 3NF. Linking to customer_address enables address pre-fill from saved addresses, address validation during checkout, and c' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAddress .

ind:abandonmentEmailSentFlag rdf:type rdf:Property ;
    rdfs:label 'Abandonment Email Sent Flag' ;
    rdfs:comment 'Indicates whether a cart abandonment email has been sent.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:abandonmentReason rdf:type rdf:Property ;
    rdfs:label 'Abandonment Reason' ;
    rdfs:comment 'Free-text reason captured (if any) for why the cart was abandoned.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cartNumber rdf:type rdf:Property ;
    rdfs:label 'Cart Number' ;
    rdfs:comment 'Business-facing cart identifier shown to customers and used in support.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cartSource rdf:type rdf:Property ;
    rdfs:label 'Cart Source' ;
    rdfs:comment 'System or integration source that created the cart.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cartStatus rdf:type rdf:Property ;
    rdfs:label 'Cart Status' ;
    rdfs:comment 'Current lifecycle status of the cart.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Coupon Discount Amount' ;
    rdfs:comment 'Monetary value of the coupon discount.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'Type of device used to create the cart.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Total Amount' ;
    rdfs:comment 'Aggregate discount amount from coupons, promotions, and cart-level discounts.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastActivityTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Activity Timestamp' ;
    rdfs:comment 'Timestamp of the most recent interaction with the cart.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loyaltyPointsApplied rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Applied' ;
    rdfs:comment 'Number of loyalty points redeemed against the cart.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when the cart record was first persisted in the data lake (audit).' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the cart record (audit).' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:savedForLaterFlag rdf:type rdf:Property ;
    rdfs:label 'Saved For Later Flag' ;
    rdfs:comment 'Indicates if the cart is marked as saved for later purchase.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shippingFeeEstimatedAmount rdf:type rdf:Property ;
    rdfs:label 'Shipping Fee Estimated Amount' ;
    rdfs:comment 'Estimated shipping cost for the cart.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Sum of line-item prices before discounts, taxes, and shipping.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxEstimatedAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Estimated Amount' ;
    rdfs:comment 'Estimated tax calculated for the cart based on jurisdiction.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalEstimatedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Estimated Amount' ;
    rdfs:comment 'Final estimated amount payable after discounts, tax, and shipping.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Quantity' ;
    rdfs:comment 'Sum of quantities across all cart items.' ;
    rdfs:domain ind:Cart ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeCm3 rdf:type rdf:Property ;
    rdfs:label 'Total Volume Cm3' ;
    rdfs:comment 'Aggregate volume of all items, used for logistics planning.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cartItemId rdf:type rdf:Property ;
    rdfs:label 'Cart Item Id' ;
    rdfs:comment 'Unique identifier for the cart line item.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCartSkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Cart Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Required for real-time inventory, pricing and fulfillment; cart item must map to the definitive SKU record used in downstream order processing.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:addedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Added Timestamp' ;
    rdfs:comment 'Date and time when the item was added to the cart.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:backorderEstimateDate rdf:type rdf:Property ;
    rdfs:label 'Backorder Estimate Date' ;
    rdfs:comment 'Estimated date when the back-ordered item will be available.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:couponApplied rdf:type rdf:Property ;
    rdfs:label 'Coupon Applied' ;
    rdfs:comment 'True if a coupon was applied to this line.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBackorder rdf:type rdf:Property ;
    rdfs:label 'Is Backorder' ;
    rdfs:comment 'True if the item is currently back-ordered.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBundle rdf:type rdf:Property ;
    rdfs:label 'Is Bundle' ;
    rdfs:comment 'True if the item is part of a product bundle.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPreorder rdf:type rdf:Property ;
    rdfs:label 'Is Preorder' ;
    rdfs:comment 'True if the item is a preorder.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemStatus rdf:type rdf:Property ;
    rdfs:label 'Item Status' ;
    rdfs:comment 'Current lifecycle status of the cart line.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineTotal rdf:type rdf:Property ;
    rdfs:label 'Line Total' ;
    rdfs:comment 'Final net amount for the line after discounts and tax.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preorderReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Preorder Release Date' ;
    rdfs:comment 'Release date when the preorder item becomes available.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceAfterDiscount rdf:type rdf:Property ;
    rdfs:label 'Price After Discount' ;
    rdfs:comment 'Price after discount but before tax.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceBeforeDiscount rdf:type rdf:Property ;
    rdfs:label 'Price Before Discount' ;
    rdfs:comment 'Original list price of the line before any promotional discounts.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referralSource rdf:type rdf:Property ;
    rdfs:label 'Referral Source' ;
    rdfs:comment 'Marketing source that drove the user to add the item.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingEstimateDate rdf:type rdf:Property ;
    rdfs:label 'Shipping Estimate Date' ;
    rdfs:comment 'Projected date the item will be shipped to the customer.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxExemptionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Code' ;
    rdfs:comment 'Code representing the reason for tax exemption.' ;
    rdfs:domain ind:CartItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressOrderAddressId rdf:type rdf:Property ;
    rdfs:label 'Billing Address Order Address Id' ;
    rdfs:comment 'Reference to the address used for billing purposes.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderAddress .

ind:headerOrderAddressId rdf:type rdf:Property ;
    rdfs:label 'Header Order Address Id' ;
    rdfs:comment 'Reference to the address where the order will be shipped.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderAddress .

ind:paymentGatewayId rdf:type rdf:Property ;
    rdfs:label 'Payment Gateway Id' ;
    rdfs:comment 'Foreign key linking to payment.gateway. Business justification: REQUIRED: Operational dashboards track which payment gateway handled each order for SLA monitoring and compliance; a FK from order_header to gateway provides this linkage.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Gateway .

ind:deliveryActualDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Actual Date' ;
    rdfs:comment 'Date the order was actually delivered to the customer.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryEstimatedDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Estimated Date' ;
    rdfs:comment 'Projected date for order delivery based on SLA.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isExpedited rdf:type rdf:Property ;
    rdfs:label 'Is Expedited' ;
    rdfs:comment 'Indicates whether the order requires expedited handling.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSplitShipment rdf:type rdf:Property ;
    rdfs:label 'Is Split Shipment' ;
    rdfs:comment 'True if the order will be fulfilled in multiple shipments.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderComments rdf:type rdf:Property ;
    rdfs:label 'Order Comments' ;
    rdfs:comment 'Free-form comments entered by the customer or support staff.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Human-readable order identifier used in customer communications and external systems.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderPlacedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Placed Timestamp' ;
    rdfs:comment 'Exact moment the order was submitted by the customer.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderPriority rdf:type rdf:Property ;
    rdfs:label 'Order Priority' ;
    rdfs:comment 'Priority level used for fulfillment sequencing.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle state of the order.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current processing state of the payment.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoCode rdf:type rdf:Property ;
    rdfs:label 'Promo Code' ;
    rdfs:comment 'Code of any promotion applied to the order.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'Indicates whether the order is exempt from tax.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxExemptReason rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Reason' ;
    rdfs:comment 'Reason code for tax exemption, if applicable.' ;
    rdfs:domain ind:Header ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPercent rdf:type rdf:Property ;
    rdfs:label 'Discount Percent' ;
    rdfs:comment 'Percentage discount applied to this line.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Current status of the fulfillment process for this line.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBackordered rdf:type rdf:Property ;
    rdfs:label 'Is Backordered' ;
    rdfs:comment 'True if the line is currently on backorder.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityFulfilled rdf:type rdf:Property ;
    rdfs:label 'Quantity Fulfilled' ;
    rdfs:comment 'Number of units actually shipped to the customer.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restrictedItemFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Item Flag' ;
    rdfs:comment 'True if the product is subject to sales restrictions.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction' ;
    rdfs:comment 'ISO-3166-1 alpha-3 country code indicating the tax authority for this line.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalGross rdf:type rdf:Property ;
    rdfs:label 'Total Gross' ;
    rdfs:comment 'Total amount before tax and after discounts (quantity × unit_price – discount).' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNet rdf:type rdf:Property ;
    rdfs:label 'Total Net' ;
    rdfs:comment 'Final amount after tax (gross total + tax_amount).' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Status History Id' ;
    rdfs:comment 'Unique surrogate identifier for each status transition record.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actorType rdf:type rdf:Property ;
    rdfs:label 'Actor Type' ;
    rdfs:comment 'Category of the entity that triggered the status change.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comment rdf:type rdf:Property ;
    rdfs:label 'Comment' ;
    rdfs:comment 'Free-form text providing additional context for the status change.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSystemGenerated rdf:type rdf:Property ;
    rdfs:label 'Is System Generated' ;
    rdfs:comment 'Indicates whether the transition was automatically generated by the system (true) or manually entered (false).' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaActualSeconds rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Seconds' ;
    rdfs:comment 'Actual elapsed time between the previous status and this transition, in seconds.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaTargetSeconds rdf:type rdf:Property ;
    rdfs:label 'Sla Target Seconds' ;
    rdfs:comment 'Configured service-level-agreement target time for this status transition, expressed in seconds.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:statusFrom rdf:type rdf:Property ;
    rdfs:label 'Status From' ;
    rdfs:comment 'The order status before the transition occurred.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusTo rdf:type rdf:Property ;
    rdfs:label 'Status To' ;
    rdfs:comment 'The order status after the transition occurred.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transition Timestamp' ;
    rdfs:comment 'Exact date-time when the status change was recorded.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderAddressId rdf:type rdf:Property ;
    rdfs:label 'Order Address Id' ;
    rdfs:comment 'Unique surrogate key for the order address record.' ;
    rdfs:domain ind:OrderAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierPreference rdf:type rdf:Property ;
    rdfs:label 'Carrier Preference' ;
    rdfs:comment 'Preferred shipping speed or carrier service level.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAddressReference rdf:type rdf:Property ;
    rdfs:label 'External Address Reference' ;
    rdfs:comment 'Identifier assigned by an external address verification or logistics provider.' ;
    rdfs:domain ind:OrderAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodeAccuracy rdf:type rdf:Property ;
    rdfs:label 'Geocode Accuracy' ;
    rdfs:comment 'Indicates the confidence level of the geocoding result.' ;
    rdfs:domain ind:OrderAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isResidential rdf:type rdf:Property ;
    rdfs:label 'Is Residential' ;
    rdfs:comment 'True if the address is a residential location; false otherwise.' ;
    rdfs:domain ind:OrderAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:label rdf:type rdf:Property ;
    rdfs:label 'Label' ;
    rdfs:comment 'Human-readable label for the address (e.g., Home, Office).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line1' ;
    rdfs:comment 'First line of the street address.' ;
    rdfs:domain ind:OrderAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line2' ;
    rdfs:comment 'Second line of the street address (optional).' ;
    rdfs:domain ind:OrderAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderAddressStatus rdf:type rdf:Property ;
    rdfs:label 'Order Address Status' ;
    rdfs:comment 'Current lifecycle status of the address record.' ;
    rdfs:domain ind:OrderAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'Date and time when the address was last validated.' ;
    rdfs:domain ind:OrderAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderPaymentId rdf:type rdf:Property ;
    rdfs:label 'Order Payment Id' ;
    rdfs:comment 'Surrogate primary key for the order payment allocation record.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gmvSettlementId rdf:type rdf:Property ;
    rdfs:label 'Gmv Settlement Id' ;
    rdfs:comment 'Foreign key linking to seller.gmv_settlement. Business justification: Finance reconciliation requires knowing which GMV settlement period each order payment was included in. This FK enables payment-to-settlement traceability for audit, dispute resolution, and regulatory' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GmvSettlement .

ind:primaryPaymentTransactionId rdf:type rdf:Property ;
    rdfs:label 'Primary Payment Transaction Id' ;
    rdfs:comment 'Identifier of the payment transaction from the payment gateway.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentTransaction .

ind:auditTrail rdf:type rdf:Property ;
    rdfs:label 'Audit Trail' ;
    rdfs:comment 'JSON string capturing audit events for this payment allocation.' ;
    rdfs:domain ind:Order ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authorization Timestamp' ;
    rdfs:comment 'Timestamp when the payment was authorized.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:captureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Capture Timestamp' ;
    rdfs:comment 'Timestamp when the payment was captured.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isGiftCard rdf:type rdf:Property ;
    rdfs:label 'Is Gift Card' ;
    rdfs:comment 'True if part of the payment was made using a gift card.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRefund rdf:type rdf:Property ;
    rdfs:label 'Is Refund' ;
    rdfs:comment 'Indicates if this record represents a refund transaction.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSplitPayment rdf:type rdf:Property ;
    rdfs:label 'Is Split Payment' ;
    rdfs:comment 'Indicates if the order payment is part of a split payment across multiple methods.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStoreCredit rdf:type rdf:Property ;
    rdfs:label 'Is Store Credit' ;
    rdfs:comment 'True if part of the payment was made using store credit.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineQuantity rdf:type rdf:Property ;
    rdfs:label 'Line Quantity' ;
    rdfs:comment 'Number of payment units allocated (typically 1).' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:note rdf:type rdf:Property ;
    rdfs:label 'Note' ;
    rdfs:comment 'Additional notes or remarks about the payment.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDescription rdf:type rdf:Property ;
    rdfs:label 'Payment Description' ;
    rdfs:comment 'Optional free-text description of the payment allocation.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundedAmount rdf:type rdf:Property ;
    rdfs:label 'Refunded Amount' ;
    rdfs:comment 'Amount refunded for this payment allocation, if any.' ;
    rdfs:domain ind:OrderPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderPromotionId rdf:type rdf:Property ;
    rdfs:label 'Order Promotion Id' ;
    rdfs:comment 'Unique identifier for the order promotion record.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliedBy rdf:type rdf:Property ;
    rdfs:label 'Applied By' ;
    rdfs:comment 'Mechanism that applied the promotion: system, customer service agent, or automated rule.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountCurrency rdf:type rdf:Property ;
    rdfs:label 'Discount Currency' ;
    rdfs:comment 'Three-letter ISO 4217 code of the currency in which discount_amount is expressed.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityMessage rdf:type rdf:Property ;
    rdfs:label 'Eligibility Message' ;
    rdfs:comment 'Human-readable explanation when eligibility_status is ineligible or pending.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Eligibility Status' ;
    rdfs:comment 'Result of promotion eligibility validation for this order.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCombinationAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Combination Allowed' ;
    rdfs:comment 'Indicates if this promotion may be combined with other promotions beyond stacking_rule logic.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxUsesPerCustomer rdf:type rdf:Property ;
    rdfs:label 'Max Uses Per Customer' ;
    rdfs:comment 'Maximum total number of times a single customer may use this promotion.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxUsesPerOrder rdf:type rdf:Property ;
    rdfs:label 'Max Uses Per Order' ;
    rdfs:comment 'Maximum number of times this promotion can be applied within a single order.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Net Discount Amount' ;
    rdfs:comment 'Discount amount after tax adjustments, if applicable.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderPromotionDescription rdf:type rdf:Property ;
    rdfs:label 'Order Promotion Description' ;
    rdfs:comment 'Human-readable description of the promotion\'s purpose and mechanics.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionCategory rdf:type rdf:Property ;
    rdfs:label 'Promotion Category' ;
    rdfs:comment 'High-level classification of the promotion for reporting.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionSource rdf:type rdf:Property ;
    rdfs:label 'Promotion Source' ;
    rdfs:comment 'Origin of the promotion – marketing campaign, loyalty program, seller-funded, or system generated.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityApplied rdf:type rdf:Property ;
    rdfs:label 'Quantity Applied' ;
    rdfs:comment 'Number of discount units applied (e.g., number of items covered by a BOGO).' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stackingRule rdf:type rdf:Property ;
    rdfs:label 'Stacking Rule' ;
    rdfs:comment 'Rule that defines whether this promotion can be combined with other promotions.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExempt rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt' ;
    rdfs:comment 'Indicates whether the discount amount is exempt from sales tax.' ;
    rdfs:domain ind:OrderPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxId rdf:type rdf:Property ;
    rdfs:label 'Tax Id' ;
    rdfs:comment 'Unique surrogate key for each tax line applied to an order.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation Timestamp' ;
    rdfs:comment 'Exact time when the tax engine performed the calculation.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:engineReference rdf:type rdf:Property ;
    rdfs:label 'Engine Reference' ;
    rdfs:comment 'Opaque identifier returned by the tax calculation engine for audit and traceability.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptFlag rdf:type rdf:Property ;
    rdfs:label 'Exempt Flag' ;
    rdfs:comment 'Indicates whether the tax was exempted for this order line (true = exempt, false = taxable).' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptionReason rdf:type rdf:Property ;
    rdfs:label 'Exemption Reason' ;
    rdfs:comment 'Reason code or description for tax exemption, if applicable.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'Code representing the tax jurisdiction (state, province, country) that governs the tax calculation.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nexusCountry rdf:type rdf:Property ;
    rdfs:label 'Nexus Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where tax nexus exists.' ;
    rdfs:domain ind:Tax ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nexusState rdf:type rdf:Property ;
