ind:reviewText rdf:type rdf:Property ;
    rdfs:label 'Review Text' ;
    rdfs:comment 'Free-form textual feedback provided by the buyer.' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerResponseDate rdf:type rdf:Property ;
    rdfs:label 'Seller Response Date' ;
    rdfs:comment 'Timestamp when the seller posted a response to the review.' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sellerResponseText rdf:type rdf:Property ;
    rdfs:label 'Seller Response Text' ;
    rdfs:comment 'Text of the seller’s response to the buyer’s review, if any.' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unhelpfulVotes rdf:type rdf:Property ;
    rdfs:label 'Unhelpful Votes' ;
    rdfs:comment 'Number of other buyers who marked the review as unhelpful.' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verifiedPurchase rdf:type rdf:Property ;
    rdfs:label 'Verified Purchase' ;
    rdfs:comment 'Indicates whether the rating is tied to a completed purchase (True) or not (False).' ;
    rdfs:domain ind:Rating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:violationId rdf:type rdf:Property ;
    rdfs:label 'Violation Id' ;
    rdfs:comment 'Primary key for violation' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originatingCaseServiceSupportCaseId rdf:type rdf:Property ;
    rdfs:label 'Originating Case Service Support Case Id' ;
    rdfs:comment 'Foreign key linking to service.service_support_case. Business justification: Compliance audit and violation investigation workflows require tracing each seller violation back to the originating support case (e.g., buyer complaint triggering a policy breach investigation). Regu' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupportCase .

ind:appealDeadline rdf:type rdf:Property ;
    rdfs:label 'Appeal Deadline' ;
    rdfs:comment 'Last date by which the seller can submit an appeal.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealEligibility rdf:type rdf:Property ;
    rdfs:label 'Appeal Eligibility' ;
    rdfs:comment 'Indicates whether the seller may appeal the enforcement action.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealOutcome rdf:type rdf:Property ;
    rdfs:label 'Appeal Outcome' ;
    rdfs:comment 'Result of the seller\'s appeal, if filed.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRegion rdf:type rdf:Property ;
    rdfs:label 'Compliance Region' ;
    rdfs:comment 'Geographic region (ISO 3166-1 alpha-3) governing the applicable regulations.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'How the violation was identified: automated rule, manual review, buyer report, or regulatory notice.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Reference' ;
    rdfs:comment 'Link (URL or internal ID) to supporting evidence such as screenshots, logs, or documents.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReinstatementDate rdf:type rdf:Property ;
    rdfs:label 'Expected Reinstatement Date' ;
    rdfs:comment 'Planned date for lifting the suspension, if applicable.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fineAmount rdf:type rdf:Property ;
    rdfs:label 'Fine Amount' ;
    rdfs:comment 'Monetary penalty assessed for the violation, if any.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current state of the investigation workflow.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyDescription rdf:type rdf:Property ;
    rdfs:label 'Policy Description' ;
    rdfs:comment 'Human-readable description of the violated policy.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'Regulatory authority whose rules are implicated by the violation.' ;
