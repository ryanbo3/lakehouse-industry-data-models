    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerGmvAtViolation rdf:type rdf:Property ;
    rdfs:label 'Seller Gmv At Violation' ;
    rdfs:comment 'Total GMV generated by the seller at the time the violation was recorded.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Business impact rating of the violation, ranging from warning to critical.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Effective Date' ;
    rdfs:comment 'Date when the seller\'s account suspension becomes active.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:violationNumber rdf:type rdf:Property ;
    rdfs:label 'Violation Number' ;
    rdfs:comment 'Human-readable reference number for the violation, used in communications and reporting.' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationType rdf:type rdf:Property ;
    rdfs:label 'Violation Type' ;
    rdfs:comment 'Category of policy breach (e.g., counterfeit, prohibited item, pricing manipulation, review fraud, IP infringement, data misuse).' ;
    rdfs:domain ind:Violation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dedicatedAccountManagerAgentId rdf:type rdf:Property ;
    rdfs:label 'Dedicated Account Manager Agent Id' ;
    rdfs:comment 'Foreign key linking to service.agent. Business justification: Required for Tier Management: each seller tier assigns a dedicated account manager (service.agent) to support sellers; reports on manager performance per tier depend on this link.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:apiRatePriority rdf:type rdf:Property ;
    rdfs:label 'Api Rate Priority' ;
    rdfs:comment 'Flag indicating priority access to API rate limits.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:badgeDisplayEligible rdf:type rdf:Property ;
