ind:transactionFeePercent rdf:type rdf:Property ;
    rdfs:label 'Transaction Fee Percent' ;
    rdfs:comment 'Variable fee percentage applied to each transaction processed through the gateway.' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquiringBankName rdf:type rdf:Property ;
    rdfs:label 'Acquiring Bank Name' ;
    rdfs:comment 'Name of the bank that acquires transactions for the merchant.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackFeeFixed rdf:type rdf:Property ;
    rdfs:label 'Chargeback Fee Fixed' ;
    rdfs:comment 'Fixed fee per chargeback transaction.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargebackFeeRate rdf:type rdf:Property ;
    rdfs:label 'Chargeback Fee Rate' ;
    rdfs:comment 'Fee rate applied to chargeback transactions.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceAuditDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Audit Date' ;
    rdfs:comment 'Date of the most recent compliance audit.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceAuditStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Audit Status' ;
    rdfs:comment 'Result of the most recent compliance audit.' ;
    rdfs:domain ind:MerchantAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyTransactionLimit rdf:type rdf:Property ;
    rdfs:label 'Daily Transaction Limit' ;
    rdfs:comment 'Maximum number of transactions allowed per day.' ;
