    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shipmentPackageStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Package Status' ;
    rdfs:comment 'Current lifecycle status of the package.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingUrl rdf:type rdf:Property ;
    rdfs:label 'Tracking Url' ;
