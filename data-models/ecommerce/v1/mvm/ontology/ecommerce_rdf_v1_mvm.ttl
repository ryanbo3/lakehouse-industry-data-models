    rdfs:range xsd:string .

ind:declaredValueUsd rdf:type rdf:Property ;
    rdfs:label 'Declared Value Usd' ;
    rdfs:comment 'Monetary value declared for customs and insurance purposes, expressed in US dollars.' ;
