    rdfs:range xsd:decimal .

ind:proofOfDeliveryPhotoUrl rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Photo Url' ;
    rdfs:comment 'Link to the delivery confirmation photo.' ;
    rdfs:domain ind:TrackingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfDeliveryRecipientName rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Recipient Name' ;
    rdfs:comment 'Name of the person who received the shipment.' ;
