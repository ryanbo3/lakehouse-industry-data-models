    rdfs:label 'Seller Bank Account Id' ;
    rdfs:comment 'Foreign key linking to seller.seller_bank_account. Business justification: Each GMV settlement results in a payout disbursed to a specific seller bank account. Linking gmv_settlement.seller_bank_account_id → seller_bank_account.seller_bank_account_id captures exactly which v' ;
    rdfs:domain ind:Seller ;
