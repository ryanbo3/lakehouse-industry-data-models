ind:marketplaceSellerSettlementId rdf:type rdf:Property ;
    rdfs:label 'Marketplace Seller Settlement Id' ;
    rdfs:comment 'Foreign key linking to marketplace.seller_settlement. Business justification: Finance reconciliation requires matching seller-domain GMV settlement records to marketplace-domain disbursement records. These represent the same business event from two ledger perspectives; without ' ;
    rdfs:domain ind:GmvSettlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SellerSettlement .

