ind:listingCategoryName rdf:type rdf:Property ;
    rdfs:label 'Listing Category Name' ;
    rdfs:comment 'Human-readable name of the category used in UI and reports.' ;
    rdfs:domain ind:ListingCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listingCategoryStatus rdf:type rdf:Property ;
    rdfs:label 'Listing Category Status' ;
    rdfs:comment 'Current lifecycle status of the category.' ;
    rdfs:domain ind:ListingCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalEligible rdf:type rdf:Property ;
    rdfs:label 'Promotional Eligible' ;
    rdfs:comment 'Indicates whether the category can participate in platform promotions or discounts.' ;
