ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'Service level agreement target duration (in hours) for dispute resolution.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Total Refund Amount' ;
    rdfs:comment 'Aggregate amount refunded to the buyer as a result of the dispute.' ;
