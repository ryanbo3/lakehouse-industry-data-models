    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demotionGracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Demotion Grace Period Days' ;
    rdfs:comment 'Number of days after a downgrade trigger before the tier is actually changed.' ;
