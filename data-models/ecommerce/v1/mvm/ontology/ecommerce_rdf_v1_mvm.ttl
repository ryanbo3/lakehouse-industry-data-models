    rdfs:range xsd:string .

ind:supportedPaymentMethods rdf:type rdf:Property ;
    rdfs:label 'Supported Payment Methods' ;
    rdfs:comment 'Comma-separated list of payment methods (e.g., credit_card, debit_card, paypal, apple_pay) the gateway can process.' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsChargebacks rdf:type rdf:Property ;
    rdfs:label 'Supports Chargebacks' ;
    rdfs:comment 'Indicates whether the gateway provides chargeback handling capabilities.' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsPartialRefunds rdf:type rdf:Property ;
    rdfs:label 'Supports Partial Refunds' ;
    rdfs:comment 'Indicates whether the gateway allows partial refunds.' ;
