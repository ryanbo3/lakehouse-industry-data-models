    rdfs:comment 'Monetary amount of insurance coverage for the package, in US dollars.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Flag' ;
    rdfs:comment 'True if the package is insured for loss or damage.' ;
    rdfs:domain ind:ShipmentPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReturn rdf:type rdf:Property ;
    rdfs:label 'Is Return' ;
    rdfs:comment 'Indicates whether the package is part of a return shipment.' ;
