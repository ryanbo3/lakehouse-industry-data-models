    rdfs:range xsd:string .

ind:disputeSource rdf:type rdf:Property ;
    rdfs:label 'Dispute Source' ;
    rdfs:comment 'Origin of the dispute creation.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeType rdf:type rdf:Property ;
    rdfs:label 'Dispute Type' ;
    rdfs:comment 'Category of the dispute indicating the underlying issue.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementAction rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action' ;
    rdfs:comment 'Any punitive action taken against the offending party.' ;
