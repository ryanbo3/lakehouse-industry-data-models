    rdfs:range xsd:boolean .

ind:lastEventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Event Timestamp' ;
    rdfs:comment 'Timestamp of the most recent status change or activity on the dispute.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:marketplaceFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Marketplace Fee Amount' ;
    rdfs:comment 'Fee retained by the marketplace platform for handling the transaction.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'External reference number assigned to the dispute for tracking and communication with parties.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'Result of the dispute after investigation.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaAchievedHours rdf:type rdf:Property ;
    rdfs:label 'Sla Achieved Hours' ;
    rdfs:comment 'Actual time taken (in hours) to resolve the dispute.' ;
