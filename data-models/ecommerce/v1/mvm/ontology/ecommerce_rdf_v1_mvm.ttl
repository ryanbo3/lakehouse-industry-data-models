    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCategory rdf:type rdf:Property ;
    rdfs:label 'Service Category' ;
    rdfs:comment 'Broad classification of the service based on geographic scope.' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCode rdf:type rdf:Property ;
    rdfs:label 'Service Code' ;
    rdfs:comment 'Carrier-assigned alphanumeric code that uniquely identifies the service.' ;
    rdfs:domain ind:CarrierService ;
