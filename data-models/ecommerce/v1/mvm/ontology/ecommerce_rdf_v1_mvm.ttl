ind:maxQuantity rdf:type rdf:Property ;
    rdfs:label 'Max Quantity' ;
    rdfs:comment 'Maximum quantity for which the price is valid; null for no upper bound.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minPrice rdf:type rdf:Property ;
    rdfs:label 'Min Price' ;
    rdfs:comment 'Floor price for the list; used to enforce pricing floors.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
