    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:catalogCategoryId rdf:type rdf:Property ;
    rdfs:label 'Catalog Category Id' ;
    rdfs:comment 'Foreign key linking to product.category. Business justification: Marketplace listing taxonomy must map to product catalog taxonomy for cross-channel category reporting, commission inheritance, and compliance rule propagation. Role-prefix \'catalog_\' distinguishes th' ;
    rdfs:domain ind:ListingCategory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:parentCategoryListingCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Category Listing Category Id' ;
    rdfs:comment 'Reference to the immediate parent category in the hierarchy.' ;
    rdfs:domain ind:ListingCategory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ListingCategory .

ind:categoryImageUrl rdf:type rdf:Property ;
    rdfs:label 'Category Image Url' ;
    rdfs:comment 'Link to the representative image for the category.' ;
