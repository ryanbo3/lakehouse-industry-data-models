ind:totalCommissionAmount rdf:type rdf:Property ;
    rdfs:label 'Total Commission Amount' ;
    rdfs:comment 'Sum of marketplace commissions deducted from the seller\'s gross sales.' ;
    rdfs:domain ind:SellerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:communicationChannel rdf:type rdf:Property ;
    rdfs:label 'Communication Channel' ;
    rdfs:comment 'Preferred channel used for communications related to the dispute.' ;
    rdfs:domain ind:Dispute ;
