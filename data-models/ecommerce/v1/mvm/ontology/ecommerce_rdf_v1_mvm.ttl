    rdfs:comment 'Business identifier or code for the segment, unique within the marketing domain.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceSegmentDescription rdf:type rdf:Property ;
    rdfs:label 'Audience Segment Description' ;
    rdfs:comment 'Free-form description of the segment purpose, business rationale, and target audience.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceSegmentName rdf:type rdf:Property ;
    rdfs:label 'Audience Segment Name' ;
    rdfs:comment 'Human-readable name of the segment used for reporting and UI display.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceSegmentStatus rdf:type rdf:Property ;
    rdfs:label 'Audience Segment Status' ;
    rdfs:comment 'Current lifecycle status of the segment.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceSegmentType rdf:type rdf:Property ;
    rdfs:label 'Audience Segment Type' ;
    rdfs:comment 'Classification of the segment based on its creation logic (e.g., demographic, behavioral, predictive).' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationMethod rdf:type rdf:Property ;
    rdfs:label 'Creation Method' ;
    rdfs:comment 'Indicates whether the segment was created manually by a marketer or generated automatically by a model.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:definitionLogic rdf:type rdf:Property ;
    rdfs:label 'Definition Logic' ;
    rdfs:comment 'Serialized logic (e.g., JSON, SQL, rule engine syntax) that defines inclusion criteria for the segment.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionCriteria rdf:type rdf:Property ;
    rdfs:label 'Exclusion Criteria' ;
    rdfs:comment 'Human-readable summary of rules that exclude customers from the segment.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inclusionCriteria rdf:type rdf:Property ;
    rdfs:label 'Inclusion Criteria' ;
    rdfs:comment 'Human-readable summary of rules that include customers in the segment.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDynamic rdf:type rdf:Property ;
    rdfs:label 'Is Dynamic' ;
    rdfs:comment 'True if the segment membership updates continuously; false if static snapshot.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownerName rdf:type rdf:Property ;
    rdfs:label 'Owner Name' ;
    rdfs:comment 'Display name of the segment owner.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerUserReference rdf:type rdf:Property ;
    rdfs:label 'Owner User Reference' ;
    rdfs:comment 'Identifier of the marketing user or team that owns the segment.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:purpose rdf:type rdf:Property ;
    rdfs:label 'Purpose' ;
    rdfs:comment 'Business objective of the segment (e.g., acquisition, retention, upsell, testing).' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeAssetId rdf:type rdf:Property ;
    rdfs:label 'Creative Asset Id' ;
    rdfs:comment 'Primary key for creative_asset' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CreativeAsset .

ind:bodyContent rdf:type rdf:Property ;
    rdfs:label 'Body Content' ;
    rdfs:comment 'Main body copy or description of the creative asset.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCanSpam rdf:type rdf:Property ;
    rdfs:label 'Compliance Can Spam' ;
    rdfs:comment 'Indicates whether the asset complies with CAN-SPAM regulations.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentBlockRefs rdf:type rdf:Property ;
    rdfs:label 'Content Block Refs' ;
    rdfs:comment 'Comma-separated list of content block identifiers used within the asset.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeAssetName rdf:type rdf:Property ;
    rdfs:label 'Creative Asset Name' ;
    rdfs:comment 'Human-readable name of the creative asset.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeAssetStatus rdf:type rdf:Property ;
    rdfs:label 'Creative Asset Status' ;
    rdfs:comment 'Current lifecycle state of the asset.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationUrl rdf:type rdf:Property ;
    rdfs:label 'Destination Url' ;
    rdfs:comment 'Target URL where the user is directed after clicking the creative.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayUrl rdf:type rdf:Property ;
    rdfs:label 'Display Url' ;
    rdfs:comment 'URL shown to users in the creative (e.g., in email footer).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Size of the asset file in bytes.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headline rdf:type rdf:Property ;
    rdfs:label 'Headline' ;
    rdfs:comment 'Primary headline text for ad creatives.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageLocale rdf:type rdf:Property ;
    rdfs:label 'Language Locale' ;
    rdfs:comment 'Locale code (e.g., en_US, fr_FR) indicating the language of the asset.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaUrl rdf:type rdf:Property ;
    rdfs:label 'Media Url' ;
    rdfs:comment 'URL to the image, video, or other media file associated with the asset.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationTokens rdf:type rdf:Property ;
    rdfs:label 'Personalization Tokens' ;
    rdfs:comment 'Tokens/placeholders for dynamic personalization (e.g., {{first_name}}).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformCode rdf:type rdf:Property ;
    rdfs:label 'Platform Code' ;
    rdfs:comment 'Identifier assigned by the target marketing platform (e.g., SFMC, Google Ads).' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectLine rdf:type rdf:Property ;
    rdfs:label 'Subject Line' ;
    rdfs:comment 'Subject line used when the asset is an email template.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateVersion rdf:type rdf:Property ;
    rdfs:label 'Template Version' ;
    rdfs:comment 'Version string of the creative template.' ;
    rdfs:domain ind:CreativeAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailEventId rdf:type rdf:Property ;
    rdfs:label 'Email Event Id' ;
    rdfs:comment 'Unique identifier for the email interaction event.' ;
    rdfs:domain ind:EmailEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bounceCategory rdf:type rdf:Property ;
    rdfs:label 'Bounce Category' ;
    rdfs:comment 'Classification of bounce when event_type is bounced.' ;
    rdfs:domain ind:EmailEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailClient rdf:type rdf:Property ;
    rdfs:label 'Email Client' ;
    rdfs:comment 'Email client or application used to open the email.' ;
    rdfs:domain ind:EmailEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailSubject rdf:type rdf:Property ;
    rdfs:label 'Email Subject' ;
    rdfs:comment 'Subject line of the email message.' ;
    rdfs:domain ind:EmailEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventOutcome rdf:type rdf:Property ;
    rdfs:label 'Event Outcome' ;
    rdfs:comment 'Overall outcome of the event (e.g., success for delivered/opened, failure for bounce).' ;
    rdfs:domain ind:EmailEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkUrl rdf:type rdf:Property ;
    rdfs:label 'Link Url' ;
    rdfs:comment 'Destination URL that was clicked in the email (populated for click events).' ;
    rdfs:domain ind:EmailEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Location Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 country code inferred from the IP address.' ;
    rdfs:domain ind:EmailEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing Timestamp' ;
    rdfs:comment 'Timestamp when the event record was ingested into the lakehouse.' ;
    rdfs:domain ind:EmailEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:attributionTouchpointId rdf:type rdf:Property ;
    rdfs:label 'Attribution Touchpoint Id' ;
    rdfs:comment 'Unique identifier for the marketing touchpoint record.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adGroupId rdf:type rdf:Property ;
    rdfs:label 'Ad Group Id' ;
    rdfs:comment 'Identifier of the ad group within the campaign.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdGroup .

ind:convertedHeaderId rdf:type rdf:Property ;
    rdfs:label 'Converted Header Id' ;
    rdfs:comment 'Foreign key linking to order.header. Business justification: Conversion attribution requires linking each touchpoint to the order it converted — the foundational marketing attribution join in e-commerce. Role-prefix \'converted_\' distinguishes this as the result' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Header .

ind:attributionScore rdf:type rdf:Property ;
    rdfs:label 'Attribution Score' ;
    rdfs:comment 'Numeric score representing the weight of this touchpoint in the chosen attribution model.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:browser rdf:type rdf:Property ;
    rdfs:label 'Browser' ;
    rdfs:comment 'Name of the web browser used (e.g., Chrome, Safari).' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Conversion Timestamp' ;
    rdfs:comment 'Timestamp of the conversion event linked to this touchpoint, if any.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:costAttributed rdf:type rdf:Property ;
    rdfs:label 'Cost Attributed' ;
    rdfs:comment 'Marketing cost associated with this touchpoint.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAttributed rdf:type rdf:Property ;
    rdfs:label 'Is Attributed' ;
    rdfs:comment 'Indicates whether the touchpoint contributed to a conversion.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConverted rdf:type rdf:Property ;
    rdfs:label 'Is Converted' ;
    rdfs:comment 'Indicates whether the touchpoint ultimately led to a conversion.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyword rdf:type rdf:Property ;
    rdfs:label 'Keyword' ;
    rdfs:comment 'Search keyword or term that triggered the ad (if applicable).' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landingPageUrl rdf:type rdf:Property ;
    rdfs:label 'Landing Page Url' ;
    rdfs:comment 'URL of the landing page associated with the touchpoint.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingSystem rdf:type rdf:Property ;
    rdfs:label 'Operating System' ;
    rdfs:comment 'Operating system of the device (e.g., iOS, Android, Windows).' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageUrl rdf:type rdf:Property ;
    rdfs:label 'Page Url' ;
    rdfs:comment 'URL of the page where the interaction occurred.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referrerUrl rdf:type rdf:Property ;
    rdfs:label 'Referrer Url' ;
    rdfs:comment 'URL of the page that referred the customer to the touchpoint.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenResolution rdf:type rdf:Property ;
    rdfs:label 'Screen Resolution' ;
    rdfs:comment 'Screen resolution of the device (e.g., 1920x1080).' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session End Timestamp' ;
    rdfs:comment 'Timestamp when the user session ended.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session Start Timestamp' ;
    rdfs:comment 'Timestamp when the user session began.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:touchpointPosition rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Position' ;
    rdfs:comment 'Position of the touchpoint within the customer\'s conversion journey.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:touchpointTimestamp rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Timestamp' ;
    rdfs:comment 'Exact date and time when the marketing touchpoint was recorded.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:utmContent rdf:type rdf:Property ;
    rdfs:label 'Utm Content' ;
    rdfs:comment 'UTM content parameter used to differentiate ads or links.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmTerm rdf:type rdf:Property ;
    rdfs:label 'Utm Term' ;
    rdfs:comment 'UTM term parameter for paid search keywords.' ;
    rdfs:domain ind:AttributionTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralId rdf:type rdf:Property ;
    rdfs:label 'Referral Id' ;
    rdfs:comment 'Unique system-generated identifier for the referral record.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referralCustomerProfileId rdf:type rdf:Property ;
    rdfs:label 'Referral Customer Profile Id' ;
    rdfs:comment 'Identifier of the existing customer who made the referral.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerProfile .

ind:referralRefereeCustomerProfileId rdf:type rdf:Property ;
    rdfs:label 'Referral Referee Customer Profile Id' ;
    rdfs:comment 'Identifier of the prospect who was referred (may be null until conversion).' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerProfile .

ind:incentiveAmount rdf:type rdf:Property ;
    rdfs:label 'Incentive Amount' ;
    rdfs:comment 'Monetary value of the incentive provided to the referee.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveCurrency rdf:type rdf:Property ;
    rdfs:label 'Incentive Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the referee incentive amount.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveType rdf:type rdf:Property ;
    rdfs:label 'Incentive Type' ;
    rdfs:comment 'Type of incentive offered to the referred prospect (e.g., discount, credit, gift card, cash, loyalty points).' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralDate rdf:type rdf:Property ;
    rdfs:label 'Referral Date' ;
    rdfs:comment 'Timestamp when the referral was created or sent to the prospect.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:referralStatus rdf:type rdf:Property ;
    rdfs:label 'Referral Status' ;
    rdfs:comment 'Current lifecycle status of the referral.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardAmount rdf:type rdf:Property ;
    rdfs:label 'Reward Amount' ;
    rdfs:comment 'Monetary value of the reward given to the referrer.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rewardCurrency rdf:type rdf:Property ;
    rdfs:label 'Reward Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the referrer reward amount.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardType rdf:type rdf:Property ;
    rdfs:label 'Reward Type' ;
    rdfs:comment 'Type of incentive granted to the referrer (e.g., discount, store credit, gift card, cash, loyalty points).' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerTierId rdf:type rdf:Property ;
    rdfs:label 'Seller Tier Id' ;
    rdfs:comment 'Foreign key linking to seller.tier. Business justification: Seller tier classification is defined in the tier reference table; replacing the string tier attribute with a foreign key enforces referential integrity and supports tier-based analytics.' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tier .

ind:businessType rdf:type rdf:Property ;
    rdfs:label 'Business Type' ;
    rdfs:comment 'Classification of the seller based on size and structure.' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmvAttribution rdf:type rdf:Property ;
    rdfs:label 'Gmv Attribution' ;
    rdfs:comment 'Total GMV generated by the seller that is attributed to the marketplace.' ;
    rdfs:domain ind:Seller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incorporationCountry rdf:type rdf:Property ;
    rdfs:label 'Incorporation Country' ;
    rdfs:comment 'Three-letter ISO country code where the seller is legally incorporated.' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Completed Date' ;
    rdfs:comment 'Date when KYC verification was successfully completed.' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Status' ;
    rdfs:comment 'Current status of Know-Your-Customer / Know-Your-Business verification.' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationPreferences rdf:type rdf:Property ;
    rdfs:label 'Notification Preferences' ;
    rdfs:comment 'Serialized preferences indicating which notification channels the seller opts into (e.g., email, SMS, in-app).' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceScoreBsr rdf:type rdf:Property ;
    rdfs:label 'Performance Score Bsr' ;
    rdfs:comment 'Numeric score derived from the seller\'s Best Seller Rank performance.' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceScoreDsr rdf:type rdf:Property ;
    rdfs:label 'Performance Score Dsr' ;
    rdfs:comment 'Numeric score reflecting the seller\'s daily sales rate performance.' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platformJoinDate rdf:type rdf:Property ;
    rdfs:label 'Platform Join Date' ;
    rdfs:comment 'Date the seller first joined the marketplace platform.' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryCategory rdf:type rdf:Property ;
    rdfs:label 'Primary Category' ;
    rdfs:comment 'Top-level product category the seller primarily operates in.' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingName rdf:type rdf:Property ;
    rdfs:label 'Trading Name' ;
    rdfs:comment 'Public-facing name used by the seller on the marketplace.' ;
    rdfs:domain ind:SellerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationId rdf:type rdf:Property ;
    rdfs:label 'Verification Id' ;
    rdfs:comment 'Primary key for verification' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onboardingId rdf:type rdf:Property ;
    rdfs:label 'Onboarding Id' ;
    rdfs:comment 'Foreign key linking to seller.onboarding. Business justification: KYC/KYB verification workflows are initiated as part of the seller onboarding process. Linking verification.onboarding_id → onboarding.onboarding_id captures which onboarding workflow triggered each v' ;
    rdfs:domain ind:Seller ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Onboarding .

ind:auditTrailNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Notes' ;
    rdfs:comment 'Additional audit information captured during verification lifecycle.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Document Expiry Timestamp' ;
    rdfs:comment 'Date and time when the document expires or becomes invalid.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:documentName rdf:type rdf:Property ;
    rdfs:label 'Document Name' ;
    rdfs:comment 'Original file name of the uploaded document.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentUploadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Document Upload Timestamp' ;
    rdfs:comment 'Date and time the document was uploaded to the system.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:documentUri rdf:type rdf:Property ;
    rdfs:label 'Document Uri' ;
    rdfs:comment 'S3 or blob storage reference where the document is stored.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Document Verification Status' ;
    rdfs:comment 'Result of the document verification process.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPlatformIssued rdf:type rdf:Property ;
    rdfs:label 'Is Platform Issued' ;
    rdfs:comment 'Indicates whether the document was supplied by the platform rather than the seller.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Entity that issued the document (e.g., government agency, bank).' ;
    rdfs:domain ind:Verification ;
