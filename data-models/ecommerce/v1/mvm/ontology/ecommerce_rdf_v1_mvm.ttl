ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Categorization of the service offering (e.g., standard ground, express, LTL, FTL).' ;
    rdfs:domain ind:CarrierService ;
    rdf:type owl:DatatypeProperty ;
