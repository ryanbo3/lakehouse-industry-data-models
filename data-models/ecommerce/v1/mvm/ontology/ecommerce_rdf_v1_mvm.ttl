    rdfs:comment 'Rounding behavior applied to calculated prices.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceSource rdf:type rdf:Property ;
    rdfs:label 'Price Source' ;
    rdfs:comment 'Origin of the price data (e.g., manually entered, system-generated, partner feed).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceTier rdf:type rdf:Property ;
    rdfs:label 'Price Tier' ;
    rdfs:comment 'Logical tier or band within the price list (e.g., "Gold", "Silver").' ;
    rdfs:domain ind:PriceList ;
