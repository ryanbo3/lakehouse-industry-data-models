    rdfs:range xsd:string .

ind:ediIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Edi Integration Status' ;
    rdfs:comment 'Current status of Electronic Data Interchange integration with the carrier.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Amount' ;
    rdfs:comment 'Total monetary value of the carrier\'s liability insurance coverage.' ;
