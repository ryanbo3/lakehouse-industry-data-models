    rdfs:domain ind:CampaignBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetName rdf:type rdf:Property ;
    rdfs:label 'Budget Name' ;
    rdfs:comment 'Human-readable name for the budget allocation.' ;
    rdfs:domain ind:CampaignBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the budget cadence or scope (e.g., daily, lifetime).' ;
    rdfs:domain ind:CampaignBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignBudgetStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Budget Status' ;
    rdfs:comment 'Current lifecycle status of the budget record.' ;
    rdfs:domain ind:CampaignBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerAcquisitionActual rdf:type rdf:Property ;
    rdfs:label 'Cost Per Acquisition Actual' ;
    rdfs:comment 'Realized cost per acquisition calculated from spend and conversions.' ;
    rdfs:domain ind:CampaignBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerAcquisitionTarget rdf:type rdf:Property ;
    rdfs:label 'Cost Per Acquisition Target' ;
    rdfs:comment 'Planned maximum cost per new customer acquisition for this budget.' ;
    rdfs:domain ind:CampaignBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Amount' ;
    rdfs:comment 'Allocated amount minus spent amount; represents funds still available.' ;
    rdfs:domain ind:CampaignBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Incremental version number for changes to the budget record.' ;
    rdfs:domain ind:CampaignBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spentAmount rdf:type rdf:Property ;
    rdfs:label 'Spent Amount' ;
    rdfs:comment 'Cumulative amount actually spent against the allocated budget.' ;
    rdfs:domain ind:CampaignBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wishlistItemId rdf:type rdf:Property ;
    rdfs:label 'Wishlist Item Id' ;
    rdfs:comment 'Primary key for the wishlist_item association' ;
    rdfs:domain ind:WishlistItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentAdGroupId rdf:type rdf:Property ;
    rdfs:label 'Parent Ad Group Id' ;
    rdfs:comment 'Self-referencing FK on ad_group (parent_ad_group_id)' ;
    rdfs:domain ind:AdGroup ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdGroup .

ind:adGroupName rdf:type rdf:Property ;
    rdfs:label 'Ad Group Name' ;
    rdfs:comment 'Human-readable name of the ad group used in reporting and UI.' ;
    rdfs:domain ind:AdGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adGroupSource rdf:type rdf:Property ;
    rdfs:label 'Ad Group Source' ;
    rdfs:comment 'Originating advertising platform for the ad group.' ;
    rdfs:domain ind:AdGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adGroupStatus rdf:type rdf:Property ;
    rdfs:label 'Ad Group Status' ;
    rdfs:comment 'Current lifecycle status of the ad group.' ;
    rdfs:domain ind:AdGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adGroupType rdf:type rdf:Property ;
    rdfs:label 'Ad Group Type' ;
    rdfs:comment 'Category of ad group based on the ad format or channel.' ;
    rdfs:domain ind:AdGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adRotationMode rdf:type rdf:Property ;
    rdfs:label 'Ad Rotation Mode' ;
    rdfs:comment 'How ads within the group are rotated during delivery.' ;
    rdfs:domain ind:AdGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidStrategy rdf:type rdf:Property ;
    rdfs:label 'Bid Strategy' ;
    rdfs:comment 'Algorithm used to set bids for the ad group.' ;
    rdfs:domain ind:AdGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyCapWindow rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Window' ;
    rdfs:comment 'Number of days over which the frequency cap applies.' ;
    rdfs:domain ind:AdGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isExperiment rdf:type rdf:Property ;
    rdfs:label 'Is Experiment' ;
    rdfs:comment 'Indicates whether the ad group is part of an A/B test or experiment.' ;
    rdfs:domain ind:AdGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optimizationGoal rdf:type rdf:Property ;
    rdfs:label 'Optimization Goal' ;
    rdfs:comment 'Primary performance metric the ad group is optimized for.' ;
    rdfs:domain ind:AdGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetingCriteria rdf:type rdf:Property ;
    rdfs:label 'Targeting Criteria' ;
    rdfs:comment 'JSON-encoded rules defining audience, geography, device, and other targeting parameters.' ;
    rdfs:domain ind:AdGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentMarketplaceId rdf:type rdf:Property ;
    rdfs:label 'Parent Marketplace Id' ;
    rdfs:comment 'Self-referencing FK on marketplace (parent_marketplace_id)' ;
    rdfs:domain ind:Marketplace ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Marketplace .

ind:averageOrderValue rdf:type rdf:Property ;
    rdfs:label 'Average Order Value' ;
    rdfs:comment 'Mean monetary value of orders processed on the marketplace.' ;
    rdfs:domain ind:Marketplace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buyerCount rdf:type rdf:Property ;
    rdfs:label 'Buyer Count' ;
    rdfs:comment 'Count of distinct buyer accounts that have placed at least one order.' ;
    rdfs:domain ind:Marketplace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataClassification rdf:type rdf:Property ;
    rdfs:label 'Data Classification' ;
    rdfs:comment 'Classification level applied to data originating from this marketplace.' ;
    rdfs:domain ind:Marketplace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmvAnnual rdf:type rdf:Property ;
    rdfs:label 'Gmv Annual' ;
    rdfs:comment 'Total value of goods and services transacted on the marketplace in the most recent fiscal year.' ;
    rdfs:domain ind:Marketplace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFtcCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Ftc Compliant' ;
    rdfs:comment 'True if the marketplace meets FTC advertising disclosure requirements.' ;
    rdfs:domain ind:Marketplace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSpamProtected rdf:type rdf:Property ;
    rdfs:label 'Is Spam Protected' ;
    rdfs:comment 'True if the marketplace employs anti-spam measures for listings and communications.' ;
    rdfs:domain ind:Marketplace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketplaceCode rdf:type rdf:Property ;
    rdfs:label 'Marketplace Code' ;
    rdfs:comment 'External business code used to reference the marketplace in contracts and reporting.' ;
    rdfs:domain ind:Marketplace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketplaceDescription rdf:type rdf:Property ;
    rdfs:label 'Marketplace Description' ;
    rdfs:comment 'Free-form text describing the marketplace\'s purpose, target audience, and unique features.' ;
    rdfs:domain ind:Marketplace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketplaceName rdf:type rdf:Property ;
    rdfs:label 'Marketplace Name' ;
    rdfs:comment 'Human-readable name of the marketplace (e.g., US Marketplace, EU Marketplace).' ;
    rdfs:domain ind:Marketplace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketplaceStatus rdf:type rdf:Property ;
    rdfs:label 'Marketplace Status' ;
    rdfs:comment 'Current operational status of the marketplace.' ;
    rdfs:domain ind:Marketplace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketplaceType rdf:type rdf:Property ;
    rdfs:label 'Marketplace Type' ;
    rdfs:comment 'Category of marketplace based on scope and product focus.' ;
    rdfs:domain ind:Marketplace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'Name of the internal business unit or legal entity that owns the marketplace.' ;
    rdfs:domain ind:Marketplace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerCount rdf:type rdf:Property ;
    rdfs:label 'Seller Count' ;
    rdfs:comment 'Count of distinct seller accounts actively listing on the marketplace.' ;
    rdfs:domain ind:Marketplace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:termsOfServiceUrl rdf:type rdf:Property ;
    rdfs:label 'Terms Of Service Url' ;
    rdfs:comment 'Web address of the marketplace\'s terms of service document.' ;
    rdfs:domain ind:Marketplace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignCreativeAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Campaign Creative Assignment Id' ;
    rdfs:comment 'Primary key for the campaign_creative_assignment association' ;
    rdfs:domain ind:CampaignCreativeAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:abTestVariant rdf:type rdf:Property ;
    rdfs:label 'Ab Test Variant' ;
    rdfs:comment 'Identifies which A/B or multivariate test arm this creative asset represents within the campaign. The same asset may be the control in one campaign and a variant in another, so this designation belongs to the assignment record.' ;
    rdfs:domain ind:CampaignCreativeAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryCreative rdf:type rdf:Property ;
    rdfs:label 'Is Primary Creative' ;
    rdfs:comment 'Indicates whether this creative asset is the designated hero or primary creative for the campaign. A campaign may have one primary creative and multiple supporting or variant creatives. Belongs to the assignment, not to the asset or campaign independently.' ;
    rdfs:domain ind:CampaignCreativeAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placementType rdf:type rdf:Property ;
    rdfs:label 'Placement Type' ;
    rdfs:comment 'The specific ad slot, channel placement, or content zone this creative asset occupies within the campaign. Belongs to the assignment because the same asset may serve different placement roles across different campaigns.' ;
    rdfs:domain ind:CampaignCreativeAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageEndDate rdf:type rdf:Property ;
    rdfs:label 'Usage End Date' ;
    rdfs:comment 'The date on which this creative asset was retired or replaced within this campaign assignment. Enables historical tracking of which assets were active during which periods of a campaign.' ;
    rdfs:domain ind:CampaignCreativeAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:usageStartDate rdf:type rdf:Property ;
    rdfs:label 'Usage Start Date' ;
    rdfs:comment 'The date on which this creative asset became active for this specific campaign assignment. Distinct from the campaign flight start date — an asset may be introduced mid-campaign or rotated in during optimization.' ;
    rdfs:domain ind:CampaignCreativeAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:categoryAttributeScopeId rdf:type rdf:Property ;
    rdfs:label 'Category Attribute Scope Id' ;
    rdfs:comment 'Primary key for the category_attribute_scope association' ;
    rdfs:domain ind:CategoryAttributeScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableCategoryScope rdf:type rdf:Property ;
    rdfs:label 'Applicable Category Scope' ;
    rdfs:comment 'Comma-separated list of product category codes or taxonomy nodes to which this attribute applies. Defines the scope of attribute applicability across the catalog. [Moved from attribute_definition: This denormalized STRING field stores a comma-separated list of category codes representing the M:N relationship. It must be removed from attribute_definition and replaced by proper FK records in this association table, enabling per-category overrides, efficient querying, and lifecycle management.]' ;
    rdfs:domain ind:CategoryAttributeScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionCategoryEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Promotion Category Enrollment Id' ;
    rdfs:comment 'Primary key for the promotion_category_enrollment association' ;
    rdfs:domain ind:PromotionCategoryEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enrollmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment End Date' ;
    rdfs:comment 'Date when the enrollment window closes for the promotion. [Moved from marketplace_promotion: Same reasoning as enrollment_start_date — the enrollment window close date is specific to each category-promotion pairing, not a single value on the promotion master record.]' ;
    rdfs:domain ind:PromotionCategoryEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentSource rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source' ;
    rdfs:comment 'Origin of the enrollment request for a listing. [Moved from marketplace_promotion: The origin of the enrollment request (e.g., seller-initiated, platform-initiated, bulk upload) is specific to each category-promotion enrollment event, not a property of the promotion itself.]' ;
    rdfs:domain ind:PromotionCategoryEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Start Date' ;
    rdfs:comment 'Date when the enrollment window opens for the promotion. [Moved from marketplace_promotion: This date governs the enrollment window for a specific category within a promotion, not the promotion as a whole. When a promotion covers multiple categories, each category may have a different enrollment window. It belongs to the association, not to marketplace_promotion.]' ;
    rdfs:domain ind:PromotionCategoryEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionCategoryEnrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Promotion Category Enrollment Status' ;
    rdfs:comment 'Current lifecycle state of this category\'s enrollment in the promotion. Sourced from enrollment_status identified in detection phase.' ;
    rdfs:domain ind:PromotionCategoryEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .
