    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentPackageId rdf:type rdf:Property ;
    rdfs:label 'Shipment Package Id' ;
    rdfs:comment 'Unique identifier for the shipment package record.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShipmentPackage .

ind:barcodeImageUrl rdf:type rdf:Property ;
    rdfs:label 'Barcode Image Url' ;
    rdfs:comment 'Link to the barcode image used on the package label.' ;
