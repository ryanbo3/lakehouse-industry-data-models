    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryPath rdf:type rdf:Property ;
    rdfs:label 'Category Path' ;
    rdfs:comment 'Full hierarchical path (e.g., "Electronics > Computers > Laptops").' ;
    rdfs:domain ind:ListingCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRate rdf:type rdf:Property ;
    rdfs:label 'Commission Rate' ;
    rdfs:comment 'Default commission percentage applied to sales in this category (e.g., 0.1500 = 15%).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpscComplianceRequired rdf:type rdf:Property ;
