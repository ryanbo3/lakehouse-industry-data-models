    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionFeeFixed rdf:type rdf:Property ;
    rdfs:label 'Transaction Fee Fixed' ;
    rdfs:comment 'Fixed monetary fee (in the settlement currency) applied per transaction.' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:DatatypeProperty ;
