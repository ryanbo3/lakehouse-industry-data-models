    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'Identifier used by external catalog or ERP systems.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRestricted rdf:type rdf:Property ;
    rdfs:label 'Is Restricted' ;
    rdfs:comment 'Indicates whether the category is restricted by policy or regulation.' ;
    rdfs:domain ind:ListingCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSponsoredAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Sponsored Allowed' ;
    rdfs:comment 'True if sellers may purchase sponsored placements within this category.' ;
    rdfs:domain ind:ListingCategory ;
    rdf:type owl:DatatypeProperty ;
