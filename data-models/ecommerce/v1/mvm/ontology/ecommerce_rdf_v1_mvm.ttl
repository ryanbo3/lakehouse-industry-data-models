    rdfs:comment 'Entity responsible for financing the promotion.' ;
    rdfs:domain ind:MarketplacePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScopeType rdf:type rdf:Property ;
