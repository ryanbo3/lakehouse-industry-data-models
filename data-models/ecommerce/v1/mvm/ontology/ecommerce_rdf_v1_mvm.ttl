# RDFS Schema for Business: Ecommerce

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/ecommerce#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Ecommerce ---
ind:Ecommerce rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Ecommerce' ;
    rdfs:comment 'E-Commerce is a rapidly growing digital industry operating online marketplaces, fulfillment networks, and technology platforms that connect millions of buyers and sellers with fast delivery, personalized recommendations, and seamless transactions.' .

# --- Domain Classes ---
ind:Customer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Customer' ;
    rdfs:comment 'Single source of truth for customer identity, profiles, accounts, segments, preferences, and behavioral data across B2C, B2B, and C2C customer types. Manages unified customer views, household relationships, loyalty programs, CLTV scoring, and NPS measurement. Owns consent and preference management under GDPR and CCPA. Integrates with Customer Data Platform for unified profile orchestration.' .

ind:Product rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Product' ;
    rdfs:comment 'Authoritative source for the entire product catalog, SKU master data, product attributes, digital assets, taxonomy, and product lifecycle management. Manages UPC, EAN, ASIN identifiers, PDP and PLP content, product enrichment, variants, cross-sell/upsell relationships, and CPSC compliance metadata. Integrates with PIM systems for catalog governance.' .

ind:Order rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Order' ;
    rdfs:comment 'Core transactional domain managing the full order lifecycle from cart submission through confirmed delivery. Owns order capture, OMS orchestration, order status tracking, cancellations, delivery confirmation, and order-level SLA management across B2C, B2B, and marketplace channels. Tracks AOV, CVR, and GMV at the order level.' .

ind:Inventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Inventory' ;
    rdfs:comment 'SSOT for stock positions across all warehouse nodes and virtual locations. Manages SKU-level inventory records, stock allocation, replenishment planning, safety stock, OOS tracking, FIFO/LIFO lot tracking, cycle counting, MOQ rules, DSR metrics, and real-time inventory visibility. Integrates with WMS for inventory control.' .

ind:Payment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Payment' ;
    rdfs:comment 'Authoritative source for all monetary transactions on the platform. Owns payment gateway authorization, settlement, refund processing, chargebacks, fraud detection, PCI DSS-compliant card data tokenization, multi-currency transaction records, payment method management, and payment reconciliation. Tracks transaction success rates and processing fees.' .

ind:Seller rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Seller' ;
    rdfs:comment 'SSOT for marketplace seller and third-party merchant entities. Owns seller onboarding, KYC/KYB verification, seller profiles, performance scorecards (BSR, DSR), commission structures, GMV attribution, seller tier management, seller agreements, seller ratings, and policy compliance monitoring via the Seller Management Portal.' .

ind:Fulfillment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Fulfillment' ;
    rdfs:comment 'Manages pick-pack-ship operations, warehouse workflows, order allocation, packing slips, shipping labels, and fulfillment SLA tracking. Supports FBA-style fulfillment center operations, 3PL partner coordination, BOPIS orchestration, and proof-of-delivery records. Integrates with WMS and TMS for end-to-end fulfillment execution.' .

ind:Logistics rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Logistics' ;
    rdfs:comment 'Owns transportation planning and carrier execution across the supply chain. Manages last-mile delivery, carrier selection, route optimization, FTL/LTL shipment planning, shipment tracking, delivery confirmation, EDI carrier integrations, cross-border WTO-compliant customs documentation, and transportation cost management. Integrates with TMS for real-time tracking.' .

ind:Pricing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Pricing' ;
    rdfs:comment 'SSOT for all pricing rules, promotional mechanics, and discount structures. Owns base price lists, dynamic pricing algorithms, markdown schedules, coupon and voucher management, promotional campaign pricing, competitive price intelligence, and A/B testing for pricing experiments. Tracks ASP, price elasticity, and GMV optimization.' .

ind:Marketing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Marketing' ;
    rdfs:comment 'Owns customer acquisition and retention campaign execution. Manages CRM-driven campaign management via Salesforce Marketing Cloud, customer segmentation, email marketing, personalization, attribution modeling, SEM/SEO performance, and A/B testing results. Tracks CAC, ROAS, CTR, CPM, CPC, RPM, and campaign ROI across DTC and B2B channels.' .

ind:Finance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Finance' ;
    rdfs:comment 'SSOT for enterprise financial records and reporting. Owns general ledger, accounts payable, accounts receivable, cost center management, budget tracking, GMV-to-revenue reconciliation, and regulatory financial reporting. Integrates with SAP S/4HANA for financial consolidation. Ensures SOX compliance for financial controls and audit trails. Tracks MRR, ARR, and revenue recognition.' .

ind:Procurement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Procurement' ;
    rdfs:comment 'Manages supplier relationships, purchase orders, vendor contracts, procurement workflows, and supplier performance monitoring. Tracks MOQ, lead times, and procurement costs. Integrates with ERP for procure-to-pay processes, supplier onboarding, and vendor compliance management.' .

ind:Service rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Service' ;
    rdfs:comment 'Manages customer support cases, RMA processing, returns and refunds workflows, customer inquiries, and service tickets. Tracks NPS, CSAT, resolution time, and support SLA compliance. Integrates with CRM for unified customer service experience and case management.' .

ind:Marketplace rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ecommerce ;
    rdfs:label 'Marketplace' ;
    rdfs:comment 'Owns the multi-sided marketplace platform connecting buyers and sellers. Manages marketplace catalog listings, C2C and B2C transaction facilitation, GMV reporting, buy-box eligibility rules, seller-buyer dispute resolution, sponsored listing management, and FTC-compliant advertising disclosure for the marketplace ecosystem.' .

# --- Data Product Classes (Tables) ---
ind:GeneralLedger rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'General Ledger' ;
    rdfs:comment 'SSOT for the enterprise chart of accounts and GL account master data. Defines account codes, account types (asset, liability, equity, revenue, expense), account hierarchies, and natural account groupings. Serves as the structural backbone for all financial postings, trial balance generation, and financial statement preparation. Integrates with SAP S/4HANA GL for multi-company-code chart of accounts and supports SOX-compliant period-end close.' .

ind:JournalEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry' ;
    rdfs:comment 'Authoritative record of all double-entry accounting transactions posted to the general ledger, including both header-level metadata and line-level debit/credit detail. Header captures posting dates, fiscal periods, document types, reference documents (order IDs, payment IDs, invoice numbers), reversal indicators, and SAP document numbers. Each line item captures GL account, cost center, profit center, amount in transaction and local currency, tax code, business area, and trading partner. Supports SOX audit trails, automated period-end close postings (accruals, depreciation, revaluations), and granular reconciliation workflows. Every entry must balance (total debits = total credits).' .

ind:JournalEntryLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry Line' ;
    rdfs:comment 'Individual debit or credit line items within a journal entry. Captures GL account, cost center, profit center, amount, currency, tax code, and business area for each posting line. Enables granular financial analysis at the line-item level and supports reconciliation workflows in SAP S/4HANA.' .

ind:CostCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Master data for organizational cost centers and profit centers used to track, allocate, and report on operational expenses and internal profitability across business units, departments, and functions. Owns cost/profit center hierarchy, center type (cost-only or profit-tracking), responsible managers, budget allocation codes, and validity periods. Supports GMV-to-revenue reconciliation at the segment level and P&L reporting by business unit (marketplace, DTC, B2B). Integrates with SAP S/4HANA CO module for internal cost controlling and EC-PCA for profitability analysis.' .

ind:ProfitCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'Master data for profit centers representing autonomous business segments for internal profitability reporting. Tracks revenue, costs, and margins by business unit (e.g., marketplace, DTC, B2B). Supports GMV-to-revenue reconciliation and segment-level P&L reporting in SAP S/4HANA EC-PCA module.' .

ind:AccountsPayable rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Accounts Payable' ;
    rdfs:comment 'SSOT for vendor and supplier payable obligations and AP subledger management. Tracks AP invoices, credit memos, payment terms, due dates, payment status, aging buckets, three-way match results, and payment batch execution. Covers 3PL carrier invoices, marketplace seller disbursement obligations, SaaS vendor subscriptions, and supplier PO settlements. Integrates with SAP S/4HANA FI-AP for automated payment runs and vendor account reconciliation.' .

ind:AccountsReceivable rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Accounts Receivable' ;
    rdfs:comment 'SSOT for customer and platform receivable balances and AR subledger management. Tracks AR invoices, credit memos, customer payment terms, collection workflows, dunning levels, aging analysis, cash application, and write-off processing. Covers B2B customer invoicing, marketplace seller fee receivables, advertising revenue receivables, and subscription billing. Integrates with SAP S/4HANA FI-AR for automated dunning and payment matching.' .

ind:RevenueRecognition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Revenue Recognition' ;
    rdfs:comment 'Tracks revenue recognition events and schedules per ASC 606 / IFRS 15 standards. Captures performance obligation identification, transaction price allocation, recognition trigger events, recognized amounts, and deferred revenue balances. Covers GMV-to-net-revenue waterfall, marketplace commission recognition, subscription MRR/ARR recognition, and promotional discount adjustments.' .

ind:TaxRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Tax Record' ;
    rdfs:comment 'SSOT for all tax obligations, filings, and tax line-item records across transactions. Captures tax type (VAT, GST, sales tax, withholding tax), tax jurisdiction, tax rate applied, taxable amount, tax amount, tax period, and filing status. Supports compliance with FTC, GDPR, and international tax regulations. Integrates with SAP S/4HANA tax determination.' .

ind:FinanceBankAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Finance Bank Account' ;
    rdfs:comment 'Master data and complete transaction history for all corporate bank accounts used in treasury operations. Tracks bank name, account identifiers (masked account number, IBAN/SWIFT), currency, account type (operating, payroll, escrow, concentration), account status, and owning legal entity. Includes electronic bank statement records with statement dates, opening/closing balances, individual transaction lines (credits and debits), value dates, and reconciliation status. Supports automated bank reconciliation, daily cash position reporting, cash flow management, and liquidity forecasting in SAP S/4HANA treasury.' .

ind:LegalEntity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Legal Entity' ;
    rdfs:comment 'Master data for all legal entities within the Ecommerce corporate group. Tracks entity name, registration number, jurisdiction, country of incorporation, functional currency, tax identification number, and consolidation group membership. Serves as the organizational anchor for intercompany transactions, regulatory filings, and consolidated financial reporting.' .

ind:Supplier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Supplier' ;
    rdfs:comment 'Master record for all suppliers and vendors in the e-commerce procurement network. Captures supplier identity, classification, contact details (including multiple contact persons with roles and communication preferences), tax identifiers, payment terms, currency, country of origin, supplier tier (strategic/preferred/approved/transactional), onboarding status, compliance certifications (ISO/PCI/GDPR/CPSC with expiry tracking), lead time parameters per SKU-warehouse combination, and risk assessment scores. SSOT for supplier identity and supplier-level attributes across the procurement domain. Integrates with SAP S/4HANA vendor master.' .

ind:PurchaseOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Purchase Order' ;
    rdfs:comment 'Core transactional record representing a formal procurement commitment issued to a supplier. Captures PO number, PO type (standard/blanket/consignment/drop-ship), supplier reference, buyer, requested delivery date, ship-to warehouse, total PO value, currency, payment terms, incoterms, approval status, and PO lifecycle state (draft/approved/sent/acknowledged/partially_received/closed/cancelled). Integrates with SAP S/4HANA ME21N/ME22N and WMS receiving workflows.' .

ind:PoLineItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Po Line Item' ;
    rdfs:comment 'Individual line-level detail within a purchase order. Captures line number, SKU/material number, ordered quantity, unit of measure, agreed unit price, line total, MOQ compliance flag, requested delivery date per line, confirmed delivery date, goods receipt quantity, invoice quantity, and line status. Enables granular tracking of multi-SKU POs and partial fulfillment scenarios common in e-commerce replenishment.' .

ind:VendorContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Vendor Contract' ;
    rdfs:comment 'Master procurement contract governing the commercial relationship with a supplier, including full amendment and change order lifecycle. Captures contract type (framework/blanket/spot/consignment), contract number, effective and expiry dates, total contract value, currency, auto-renewal flag, payment terms, SLA commitments, penalty clauses, exclusivity terms, amendment history (change reason, effective date, revised terms, approver), and contract status (draft/active/amended/expired/terminated). Serves as the authoritative agreement record for procure-to-pay processes in SAP S/4HANA.' .

ind:GoodsReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Goods Receipt' ;
    rdfs:comment 'Transactional record capturing the full inbound lifecycle from supplier dispatch through physical receipt at a warehouse. Records ASN (Advance Shipment Notice) number, carrier, tracking number, origin location, destination warehouse, shipped and received quantities per SKU, unit of measure, batch/lot number, estimated and actual arrival dates, quality inspection status, discrepancy quantity, over/under delivery flag, freight cost, shipment status (in_transit/arrived/receiving_in_progress/completed/exception), and GR posting status. SSOT boundary: procurement owns inbound shipment tracking and GR posting; inventory domain owns post-receipt stock position updates. Triggers three-way match in accounts payable and inventory update in WMS.' .

ind:SupplierInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Supplier Invoice' ;
    rdfs:comment 'Supplier-submitted invoice record for goods or services delivered, owned by procurement for three-way match validation (PO/GR/invoice) and discrepancy resolution. Captures invoice number, invoice date, supplier reference, PO reference, invoiced amount, tax amount, currency, payment due date, three-way match status, discrepancy reason, approval status, and payment block flag. SSOT boundary: procurement owns invoice receipt, validation, and match status; finance domain owns payment posting, GL entry, and cash disbursement. Integrates with SAP S/4HANA MIRO for AP invoice verification.' .

ind:SupplierPerformance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Supplier Performance' ;
    rdfs:comment 'Periodic supplier performance scorecard capturing operational KPIs per supplier per evaluation period (monthly/quarterly/annual). Tracks on-time delivery rate, fill rate, defect rate (DPPM), invoice accuracy rate, lead time adherence, return rate, SLA breach count, NPS from procurement team, overall weighted performance score, and performance tier classification (gold/silver/bronze/probation). Drives supplier development programs, contract renewal decisions, and automated supplier tier reclassification. SSOT for supplier operational performance metrics; does not own financial credit risk scores (finance domain).' .

ind:SupplierPriceList rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Supplier Price List' ;
    rdfs:comment 'Agreed pricing catalog between the e-commerce platform and a supplier for specific SKUs, maintained under a contract or as a standalone purchasing info record. Captures supplier, SKU, price list version, unit price, currency, quantity break tiers (volume discount schedules), discount percentage, effective date, expiry date, and price list status (active/expired/superseded). SSOT for supplier-agreed pricing used in automated PO price validation, cost-of-goods calculations, and price comparison during requisition-to-PO conversion. Does not own dynamic selling prices (pricing domain) or actual invoice amounts (supplier_invoice).' .

ind:StockPosition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Position' ;
    rdfs:comment 'Core master record and SSOT representing the current stock position and velocity profile for a SKU at a specific warehouse node or virtual location. Tracks on-hand quantity, reserved quantity, available-to-promise (ATP) quantity, in-transit quantity, and physical/logical inventory states (on-hand, allocated, quarantined, damaged). Includes comprehensive velocity metrics: rolling daily sales rate (DSR) at 7/30/90-day windows, velocity tier classification (A/B/C/D based on BSR and sales volume), average units sold per day, peak DSR, seasonal velocity index, and last velocity recalculation timestamp. Velocity data drives slotting decisions, replenishment frequency, and safety stock calculations. No separate velocity entity exists — stock_position is the SSOT for both inventory quantities and SKU velocity at the node level. Integrates with WMS for real-time inventory visibility across all fulfillment nodes.' .

ind:WarehouseLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Warehouse Location' ;
    rdfs:comment 'Master record for physical and virtual storage locations within a warehouse node, including bin, shelf, aisle, zone, and rack identifiers. Defines location type (pick face, bulk storage, receiving dock, returns area, virtual), capacity constraints, temperature zone, and hazmat classification. Used by WMS for slotting optimization and inventory allocation to specific storage positions.' .

ind:StockMovement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Movement' ;
    rdfs:comment 'Transactional record and sole audit trail capturing every inventory movement and adjustment event including receipts, issues, transfers, manual corrections, cycle count variances, returns, write-offs, and system-initiated adjustments. Records movement type, source and destination location, quantity moved, unit of measure, movement reason code (shrinkage, damage, count variance, system error, expiry write-off, recount adjustment), reference document (PO, RMA, transfer order, cycle count, investigation), operator ID, authorizing user for adjustments, adjusted quantity (positive or negative), adjusted value for financial reconciliation, and financial impact. Serves as the SSOT for all inventory change audit trails including both automated movements and manual corrections requiring authorization. Feeds replenishment triggers, DSR calculations, inventory write-off reconciliation, and SOX-compliant financial reporting.' .

ind:StockAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Stock Allocation' ;
    rdfs:comment 'Transactional record linking a specific quantity of inventory to a fulfillment demand (order line, reservation, or pre-allocation). Tracks allocated SKU, warehouse location, lot, allocated quantity, allocation type (hard/soft), allocation status, expiry timestamp, and the originating order or transfer reference. Ensures ATP accuracy and prevents overselling by managing the reserved inventory pool.' .

ind:Adjustment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Adjustment' ;
    rdfs:comment 'Transactional record documenting a manual or system-initiated correction to stock quantity or value at a specific location and lot. Captures adjustment reason (shrinkage, damage, count variance, system error, expiry write-off), adjusted quantity (positive or negative), adjusted value, authorizing user, and reference to the originating cycle count or investigation. Provides the financial reconciliation trail for inventory write-offs.' .

ind:TransferOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Transfer Order' ;
    rdfs:comment 'Transactional record managing the inter-warehouse or inter-location movement of inventory. Captures source warehouse, destination warehouse, SKU, lot, transfer quantity, transfer type (replenishment, rebalancing, returns processing), requested date, confirmed ship date, in-transit quantity, and transfer status (created, picked, shipped, received, closed). Supports multi-node inventory rebalancing and fulfillment network optimization.' .

ind:SafetyStockRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Safety Stock Rule' ;
    rdfs:comment 'Master record defining safety stock parameters for a SKU at a warehouse node, calculated to buffer against demand variability and supply uncertainty. Captures safety stock quantity, safety stock days of cover, calculation method (statistical, fixed, seasonal), demand variability coefficient, supplier lead time variability, service level target percentage, and last recalculation date. Supports dynamic safety stock optimization.' .

ind:WarehouseNode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Warehouse Node' ;
    rdfs:comment 'Master record for a physical or virtual warehouse node in the fulfillment network, including distribution centers, fulfillment centers, dark stores, 3PL facilities, and virtual drop-ship nodes. Captures node code, node type, address, geographic coordinates, capacity (sqft and pallet positions), operating hours, supported fulfillment types (FBA-style, BOPIS, DTC), and active status. SSOT for warehouse network topology.' .

ind:SupportCase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Support Case' ;
    rdfs:comment 'Core master entity representing a customer support case or service ticket. Tracks the full lifecycle from creation through resolution including case type (billing, shipping, product defect, account access, returns, marketplace dispute referral), priority level (P1-P4), originating channel (phone, email, chat, social, self-service), assigned agent, current queue, escalation status, SLA policy reference, customer entitlement tier, first response timestamp, resolution timestamp, CSAT score, NPS score, and outcome disposition (resolved, unresolved, duplicate, transferred). Serves as the central operational record linking all service interactions, escalations, RMAs, refunds, and feedback for a single customer issue.' .

ind:CaseInteraction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Case Interaction' ;
    rdfs:comment 'Transactional record capturing every individual interaction or communication event within a support case lifecycle. Tracks inbound and outbound messages, call logs, chat transcripts, email threads, internal notes, and agent responses. Stores interaction channel, direction (inbound/outbound), agent ID, timestamp, content summary, attachment references, and interaction outcome. Enables full audit trail of case communications and supports agent performance measurement.' .

ind:Rma rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Rma' ;
    rdfs:comment 'Return Merchandise Authorization master record managing the end-to-end RMA lifecycle for e-commerce returns. Captures RMA number, originating order reference, return reason code, return type (refund, exchange, store credit), customer-declared condition, carrier return label details, expected return window, actual receipt date, inspection status, disposition decision (restock, liquidate, destroy), and financial settlement status. SSOT for all return authorization records across the platform.' .

ind:RmaLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Rma Line' ;
    rdfs:comment 'Line-item detail record for each SKU included in an RMA. Captures the specific product SKU, quantity requested for return, quantity actually received, unit return reason, item condition on receipt, restocking eligibility flag, refund amount per line, exchange SKU if applicable, and inspection notes. Supports multi-item returns under a single RMA authorization and enables SKU-level return analytics and inventory disposition.' .

ind:ServiceRefund rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Service Refund' ;
    rdfs:comment 'Transactional record representing all customer remediation, refunds, and compensation issued through the service domain. Covers full refunds, partial refunds, store credits, gift cards, coupon codes, free shipping vouchers, loyalty point grants, and goodwill compensation for service failures or proactive retention gestures. Tracks remediation type (refund, exchange credit, compensation, goodwill gesture, retention offer), amount/value, currency, method (original payment method, store credit, gift card), status lifecycle (pending, approved, processing, completed, failed, redeemed, expired), initiating RMA or case reference, approval workflow with authorization thresholds by amount tier, issuing agent, manager override flag, redemption status, expiry date, compensation reason category, and settlement confirmation reference. Owns the service-side authorization decision while payment domain owns financial execution. SSOT for all service-originated customer remediation and compensation records.' .

ind:Agent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Agent' ;
    rdfs:comment 'Master record for customer service agents and support staff operating within the service domain. Captures agent name, employee ID reference, team assignment, skill set tags (returns, billing, technical, escalations), supported channels, language proficiencies, current availability status, shift schedule reference, performance tier, and active/inactive status. Serves as the SSOT for agent identity within the service domain and supports case routing, workload balancing, and performance measurement.' .

ind:Team rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Team' ;
    rdfs:comment 'Master record defining customer service teams and organizational groupings within the support operation. Captures team name, team type (tier-1 frontline, tier-2 escalation, specialist, back-office), supported contact channels, operating hours, geographic coverage, team lead reference, SLA tier assignment, and capacity targets. Enables hierarchical case routing, team-level SLA tracking, and workforce planning for the service organization.' .

ind:SlaPolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Sla Policy' ;
    rdfs:comment 'Reference master defining SLA (Service Level Agreement) policies governing response and resolution time targets for customer support cases. Captures SLA policy name, applicable case type and priority matrix, first response time target (hours), resolution time target (hours), escalation trigger thresholds, business hours vs. calendar hours flag, breach penalty rules, and effective date range. Provides the authoritative SLA configuration used to evaluate case compliance and drive automated escalations.' .

ind:Escalation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Escalation' ;
    rdfs:comment 'Transactional record tracking case escalation events within the support workflow. Captures the originating case reference, escalation trigger reason (SLA breach, customer demand, complexity, VIP customer), escalation tier (tier-1 to tier-2, tier-2 to specialist, agent to supervisor), escalating agent, receiving agent or team, escalation timestamp, resolution at escalated tier flag, and time-to-resolution post-escalation. Supports escalation pattern analysis and service quality improvement.' .

ind:FeedbackResponse rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Feedback Response' ;
    rdfs:comment 'Transactional record capturing all customer feedback survey responses tied to service interactions. Covers CSAT (1-5 satisfaction rating for specific interactions), NPS (0-10 loyalty score with promoter/passive/detractor classification), and CES (Customer Effort Score) surveys. Stores survey type, numeric score, classification category, verbatim feedback text, survey trigger event (post-case closure, post-delivery, periodic relationship survey), delivery channel (email, SMS, in-app), response timestamp, associated case and agent references, customer segment, and follow-up action flag. SSOT for all service-domain customer feedback and satisfaction measurement data.' .

ind:KnowledgeArticle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Knowledge Article' ;
    rdfs:comment 'Master record for knowledge base articles supporting agent-assisted resolution and customer self-service deflection. Captures article title, rich content body, article type (FAQ, troubleshooting guide, policy document, how-to, known issue), applicable product categories and issue taxonomy tags, authoring agent, review/approval workflow status, publish date, expiry/review-by date, version history, locale/language, view count, helpfulness rating (thumbs up/down), linked case types, and case deflection attribution metrics. Enables measurement of self-service effectiveness, agent knowledge utilization, and content gap identification.' .

ind:CatalogItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Catalog Item' ;
    rdfs:comment 'Core master entity representing a sellable product in the e-commerce catalog. Serves as the authoritative SKU master record, capturing product identity, UPC/EAN/ASIN identifiers, brand, manufacturer, model number, product type, lifecycle status (active, discontinued, draft, archived), launch date, end-of-life date, and PIM system source reference. This is the SSOT for all product identity data across the platform.' .

ind:Sku rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Stock Keeping Unit record representing a specific, orderable variant of a catalog item. Captures the unique SKU code, variant dimensions (size, color, material, style), sellable unit of measure, weight, dimensions (length, width, height), packaging type, hazmat flag, age restriction flag, country of origin, and fulfillment eligibility flags (FBA-eligible, BOPIS-eligible, DTC-eligible). Each SKU maps to exactly one catalog item and is the atomic unit tracked by inventory and order systems.' .

ind:Category rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Category' ;
    rdfs:comment 'Hierarchical taxonomy node defining the classification structure for the product catalog. Stores category name, category code, parent category reference (for tree traversal), depth level, full path string, display order, SEO slug, meta title, meta description, is_leaf flag, and active status. Supports multi-level category trees (e.g., Electronics > Smartphones > Android Phones) used for PLP navigation, search faceting, and catalog governance.' .

ind:AttributeDefinition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Attribute Definition' ;
    rdfs:comment 'Master definition of a product attribute within the PIM system, forming the schema for dynamic product data. Captures attribute name, attribute code, data type (string, numeric, boolean, enum, multi-select, date, rich_text), unit of measure, validation rules (min/max values, regex pattern, allowed values list), is_required flag, is_searchable flag, is_filterable flag, is_comparable flag, display group, display order, display label, help text, and applicable product category scope. Drives dynamic attribute rendering on PDP and PLP pages, powers faceted search configuration, and governs catalog enrichment completeness scoring.' .

ind:AttributeValue rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Attribute Value' ;
    rdfs:comment 'Stores the actual attribute values assigned to a specific SKU or catalog item as managed in the PIM system. Captures the SKU or catalog item reference, attribute definition reference, raw value (string), typed value (numeric, boolean, date as applicable), unit of measure, locale/language code for localized values, source system, enrichment status, and last enrichment timestamp. Enables faceted search, product comparison, and PDP attribute display.' .

ind:DigitalAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Digital Asset' ;
    rdfs:comment 'Unified content and media asset entity serving as the single source of truth for ALL product presentation content on PDP and PLP pages. Manages both digital media (hero images, lifestyle images, videos, 360-degree spins, AR/3D models, size charts, PDFs) and all textual marketing content (product titles, short descriptions, long descriptions with HTML/rich text, bullet points, SEO meta titles, SEO meta descriptions, SEO canonical URLs, SEO keywords, structured data markup/JSON-LD). Captures asset type, content type, file/CDN URL, resolution, alt text, locale/language code, content status (draft, approved, published, archived), sort order, is_primary flag, rights/license metadata, content author, publishing timestamps, and enrichment completeness score. Supports multi-locale content for international catalog syndication. Governed by PIM/DAM systems for enrichment quality and brand consistency. This is the SSOT for all product content — no other entity in this domain stores product titles, descriptions, or SEO metadata.' .

ind:Bundle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Bundle' ;
    rdfs:comment 'Defines product bundles and kits offered as a single sellable unit composed of multiple SKUs. Captures bundle code, bundle name, bundle type (fixed bundle, configurable bundle, gift set, kit), bundle description, bundle status, pricing strategy (fixed price, sum-of-parts, discounted), bundle price, minimum quantity, maximum quantity, is_virtual flag, and effective date range. Enables cross-sell and upsell mechanics, promotional bundling, and FBA-style fulfillment of multi-item packages.' .

ind:BundleComponent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Bundle Component' ;
    rdfs:comment 'Association entity defining the individual SKU components that make up a product bundle. Captures bundle reference, component SKU reference, component quantity, component role (primary, accessory, optional), is_substitutable flag, substitution group code, display order, and component-level pricing override. Supports bundle assembly in fulfillment, component-level inventory reservation, and bundle configurator UI logic.' .

ind:Relation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Relation' ;
    rdfs:comment 'Defines curated product-to-product relationships between catalog items to power recommendation widgets, accessory suggestions, and replacement/spare part lookups on PDP and cart pages. Stores source catalog item reference, target catalog item reference, relation type (cross_sell, upsell, frequently_bought_together, accessory, replacement, spare_part, compatible_with), relation strength score, display position, effective date range, is_active flag, and relation source (manual_curation, algorithmic, seller_submitted). Integrates with the recommendation engine for personalized suggestions and supports merchandising team curation workflows.' .

ind:Brand rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Brand' ;
    rdfs:comment 'Master record for product brands represented in the catalog. Captures brand name, brand code, brand logo URL, brand description, brand website URL, brand country of origin, brand tier (luxury, premium, standard, private_label), is_verified flag, is_exclusive flag, brand owner type (manufacturer, distributor, marketplace_seller, private_label), brand status, and brand registration date. Serves as the SSOT for brand identity referenced by catalog items and used in brand-filtered search and PLP brand pages.' .

ind:ProductListing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Product Listing' ;
    rdfs:comment 'Represents a marketplace or channel-specific product listing that maps a SKU to a specific sales channel (website, mobile app, marketplace, B2B portal, BOPIS). Captures SKU reference, channel code, channel-specific listing ID (e.g., ASIN for Amazon-style marketplace), listing status (active, suppressed, pending, inactive), listing title override, listing description override, listing price, buy box eligibility flag, listing quality score, suppression reason, and listing created/updated timestamps. Distinct from catalog_item as it models channel-specific presentation and eligibility.' .

ind:CustomerProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Customer Profile' ;
    rdfs:comment 'Unified master record for every customer identity across B2C, B2B, and C2C customer types. Serves as the single source of truth for customer identity data sourced from the Customer Data Platform. Stores full name, email, phone, date of birth, gender, preferred language, preferred currency, account status, customer type (individual/business/marketplace), acquisition channel, acquisition date, first purchase date, last active date, and CDP profile ID. Owns KYC/identity verification records: verification type (email, phone, government ID, business registration), verification status, provider, verification date, expiry date, document type, risk level, and failure reason. This is the anchor entity for the entire customer domain — all other customer products reference back to profile.' .

ind:Account rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Account' ;
    rdfs:comment 'Customer account record representing the commercial relationship between a customer and the Ecommerce platform. Tracks account type (B2C personal, B2B corporate, C2C marketplace), account tier, account status (active, suspended, closed, pending), account open date, account close date, credit limit, default payment method reference, default shipping address reference, loyalty program enrollment status, marketplace seller flag, B2B company name, tax ID, VAT number, and account manager assignment. One profile may have one or more accounts (e.g., personal + business). Owns the immutable account status change audit trail: each transition records previous status, new status, change reason code, change initiated by (customer, agent, automated rule, fraud system), change timestamp, effective date, reversal flag, and associated case reference. Provides full account lifecycle audit for compliance, dispute resolution, and customer service operations.' .

ind:CustomerAddress rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Customer Address' ;
    rdfs:comment 'Physical and virtual address records associated with a customer profile. Stores address type (shipping, billing, registered, pickup), address line 1 and 2, city, state/province, postal code, country ISO code, address validation status, geocoded latitude/longitude, is_default_shipping flag, is_default_billing flag, residential vs commercial classification, BOPIS-eligible flag, and address verification source. Supports multi-address customers and international address formats per ISO 3166.' .

ind:Contact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Contact' ;
    rdfs:comment 'Individual contact person associated with a customer account, primarily used for B2B accounts with multiple authorized contacts (procurement officers, finance contacts, shipping coordinators). Stores contact first name, last name, job title, department, email address, phone number, contact type (primary, billing, shipping, technical), is_primary flag, communication opt-in status, authorization level, and contact status. Enables multi-contact B2B account management, purchase approval routing, and targeted communication delivery to the correct role within an enterprise account.' .

ind:LoyaltyProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Loyalty Program' ;
    rdfs:comment 'Master definition of loyalty programs offered on the Ecommerce platform. Stores program name, program type (points-based, tier-based, cashback, subscription), program status, enrollment eligibility rules, points-to-currency conversion rate, tier thresholds, program start date, program end date, sponsoring brand or seller reference, terms and conditions URL, and applicable customer segments. This is the catalog-level definition of loyalty programs, distinct from individual customer enrollment records.' .

ind:LoyaltyEnrollment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Loyalty Enrollment' ;
    rdfs:comment 'Customer enrollment and ongoing loyalty standing for a specific loyalty program. Tracks enrollment date, current tier (Bronze, Silver, Gold, Platinum), tier qualification date, tier expiry date, current points balance, lifetime points earned, lifetime points redeemed, points expiry date, enrollment channel, enrollment status (active, suspended, expired), and next tier threshold gap. Also owns the complete loyalty point transaction history: each transaction records type (earn, redeem, expire, adjust, transfer), points amount, transaction date, triggering order reference, triggering promotion reference, balance before, balance after, expiry date of earned points, transaction status, and reversal reference. Serves as the SSOT for a customer\'s loyalty standing, points balance, and full transaction audit trail supporting dispute resolution and financial reconciliation of loyalty currency.' .

ind:Segment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Segmentation entity defining named customer segments and managing complete membership lifecycle. Stores segment definition: name, type (behavioral, demographic, RFM-based, CLTV-based, lifecycle stage), rule expression or ML model reference, segment size, creation date, last refresh date, owning team, status, and applicable channels. Owns membership records: each membership links a profile to a segment with temporal window (start/end dates), status (active, expired), assignment method (rule-based, manual, ML-model), confidence score for ML assignments, and segment version at assignment time. Segments are managed by the Customer Data Platform and consumed by Marketing Automation. Supports point-in-time membership queries, A/B testing audience construction, segment overlap analysis, and version tracking.' .

ind:Preference rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Preference' ;
    rdfs:comment 'Customer preference and communication opt-in/opt-out record capturing explicit customer choices for personalization, notifications, and marketing communications. Stores preference category (email marketing, SMS, push notification, personalized recommendations, third-party data sharing, cookie consent), preference value (opted-in, opted-out, not-set), channel, preference source (customer self-service, agent-set, import), effective date, expiry date, and last updated timestamp. GDPR and CCPA compliance anchor — this is the SSOT for consent and preference management.' .

ind:ConsentEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Consent Event' ;
    rdfs:comment 'Immutable audit log of every consent change event for a customer, required for GDPR Article 7 and CCPA compliance. Stores event type (consent-given, consent-withdrawn, consent-updated, data-deletion-requested, data-portability-requested), consent category, prior value, new value, event timestamp, collection method (web form, mobile app, call center, email link), IP address at time of consent, user agent string, legal basis (legitimate interest, contract, consent), and processing purpose. This is the regulatory evidence trail for consent lifecycle.' .

ind:Wishlist rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Wishlist' ;
    rdfs:comment 'Customer wishlist representing products explicitly saved for future consideration. Stores wishlist header: name, type (personal, gift-registry, shared), visibility setting, creation date, sharing URL, expiry date for gift registries. Owns individual line items: each item records SKU reference, product name at save time, price at save time, current price, price change indicator, availability status, priority rank, customer notes, date added, date removed, and notification preferences for price drops and back-in-stock alerts. Supports personalization, re-engagement campaigns, and gift registry workflows. Distinct from cart (active purchase intent) — wishlist represents longer-term interest signals and demand forecasting inputs.' .

ind:Center rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Center' ;
    rdfs:comment 'Master record for each physical fulfillment center (FC) or warehouse node in the fulfillment network. Captures FC identity, type (FBA-style, 3PL, BOPIS hub, dark store), geographic location, operational capacity, supported fulfillment methods, WMS integration identifiers, and SLA tier assignments. SSOT for all warehouse facility master data within the fulfillment domain.' .

ind:FulfillmentOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Fulfillment Order' ;
    rdfs:comment 'Core operational record representing a fulfillment instruction issued to a warehouse or 3PL partner for a specific customer order or sub-order. Tracks fulfillment order status (received, allocated, picking, packed, shipped, delivered, cancelled), assigned fulfillment center, fulfillment method (standard, expedited, BOPIS, FBA-style, 3PL), promised SLA window, actual pick/pack/ship timestamps, and WMS/OMS reference identifiers. Central entity for pick-pack-ship orchestration.' .

ind:OrderLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Order Line' ;
    rdfs:comment 'Line-level detail for each SKU within a fulfillment order, serving as the unified pick-and-allocate record. Captures SKU identifier, ordered/allocated/picked/packed quantities, unit of measure, bin/slot location at time of pick, substitution flags, line-level fulfillment status, assigned picker (associate ID or robot unit), pick zone, pick method (single-order, batch, zone, wave), pick start/completion timestamps, pick exceptions (short pick, mispick), and confirmation status. SSOT for SKU-level fulfillment execution including pick task assignment and completion within the WMS workflow.' .

ind:PackingSlip rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Packing Slip' ;
    rdfs:comment 'Consolidated operational record and SSOT for the full packing lifecycle of a fulfillment order — from pack station assignment and carton selection through QC verification and packing slip document generation. Stores pack station ID, packer associate, carton/box type, dimensional and actual weight, packing materials, QC scan results, packed SKUs with quantities, special handling instructions, gift message and branded insert flags, pack start/end timestamps, and generation timestamp. Serves as both the operational pack execution record (replacing standalone pack task) and the customer-facing documentation reference for shipment contents and returns processing.' .

ind:ShippingLabel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Shipping Label' ;
    rdfs:comment 'Master record and SSOT for each shipping label generated for an outbound shipment, incorporating the full carrier selection, rate-shopping, and label generation lifecycle. Stores carrier SCAC code, tracking number, label format (ZPL, PDF), service level (ground, 2-day, overnight, same-day), origin and destination address snapshots, label generation timestamp, carrier rate quoted, rate basis (weight, dimensional weight, zone), carrier selection method (cheapest, fastest, preferred, TMS-optimized), manual override flag, selection timestamp, label void status, and TMS reference identifier. Unified record for carrier assignment decision and physical label artifact; integrates with TMS for carrier selection and rate shopping.' .

ind:FulfillmentShipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Fulfillment Shipment' ;
    rdfs:comment 'Core transactional record representing a physical outbound shipment dispatched from a fulfillment center to a customer or intermediate hub. Tracks shipment status (manifested, in-transit, out-for-delivery, delivered, exception, returned), carrier, tracking number, ship date, estimated delivery date, actual delivery date, shipment weight, dimensions, declared value, and proof-of-delivery reference. Bridges fulfillment execution and last-mile logistics; integrates with TMS for carrier tracking events.' .

ind:ShipmentEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Shipment Event' ;
    rdfs:comment 'Immutable event log capturing carrier-reported and internal tracking milestones for a shipment throughout its transit lifecycle. Each record represents a discrete tracking event: event type (picked up, in-transit, out-for-delivery, delivered, exception, attempted delivery), event timestamp, event location (city, state, country), carrier event code, raw carrier scan message, and data source (carrier API, TMS webhook, EDI 214). Enables SLA breach detection and customer-facing tracking updates.' .

ind:ProofOfDelivery rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Proof Of Delivery' ;
    rdfs:comment 'Transactional record capturing confirmed delivery evidence for a shipment. Stores confirmation type (signature, photo, GPS, OTP), recipient name, delivery timestamp, location coordinates, photo/signature asset references, carrier confirmation code, and exception notes. Critical for dispute resolution, chargeback defense, RMA initiation, and last-mile SLA compliance.' .

ind:BinLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Bin Location' ;
    rdfs:comment 'Master record for each physical storage location (bin, slot, shelf, pallet position) within a fulfillment center. Captures location code, zone classification (pick, bulk, staging, returns, hazmat, cold chain), aisle/bay/level/position coordinates, location type, capacity constraints (units, weight, volume), temperature zone, hazmat flag, and active status. SSOT for warehouse slotting and zone-based pick path optimization.' .

ind:Sla rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fulfillment ;
    rdfs:label 'Sla' ;
    rdfs:comment 'Reference record defining SLA commitments by fulfillment method, carrier service level, customer segment, and fulfillment center. Captures promised pick/pack/ship SLA windows (hours), delivery window (days), same-day cutoff time, breach thresholds, and effective date range. Drives SLA compliance monitoring, fulfillment_exception breach detection, and carrier selection logic.' .

ind:MarketplaceListing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketplace ;
    rdfs:label 'Marketplace Listing' ;
    rdfs:comment 'Core master entity representing a seller\'s product offering on the marketplace platform. Captures the full lifecycle of a marketplace listing including listing status (active, inactive, suspended, pending review), listing type (B2C, C2C, auction, fixed-price), buy-box eligibility status, featured listing flag, listing creation and expiry dates, listing title, description, condition (new, used, refurbished), category path, brand, ASIN/UPC/EAN identifiers, seller SKU, marketplace-assigned listing ID, fulfillment type (FBA-style, seller-fulfilled, dropship), listing visibility flags, and FTC-compliant advertising disclosure indicators. SSOT for marketplace catalog listings distinct from the product domain\'s master catalog.' .

ind:ListingOffer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketplace ;
    rdfs:label 'Listing Offer' ;
    rdfs:comment 'Represents a specific seller\'s price offer on a marketplace listing at a point in time. A single listing may have multiple competing offers from different sellers. Captures offer price, shipping cost, condition, seller fulfillment method, offer rank, buy-box winner flag, offer start and end dates, quantity available, handling time SLA, and offer suppression reason. Drives buy-box eligibility determination and competitive pricing intelligence on the marketplace.' .

ind:MarketplaceTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketplace ;
    rdfs:label 'Marketplace Transaction' ;
    rdfs:comment 'Core transactional record capturing each completed C2C or B2C transaction facilitated through the marketplace platform. Records transaction date and time, buyer and seller identifiers, listing and offer references, transaction amount (GMV contribution), marketplace commission amount, commission rate, payment method, transaction currency, transaction status (pending, completed, cancelled, disputed, refunded), fulfillment type, and applicable tax amounts. SSOT for GMV reporting and marketplace revenue recognition distinct from the order domain\'s OMS records.' .

ind:CommissionSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketplace ;
    rdfs:label 'Commission Schedule' ;
    rdfs:comment 'Reference master defining the commission rate structures applied to marketplace transactions by seller tier, product category, fulfillment type, and promotional period. Captures commission schedule name, applicable seller tier, product category path, base commission rate percentage, variable fee structure, minimum and maximum fee caps, effective date range, currency, and schedule status. Drives automated commission calculation on marketplace transactions and seller settlement processing.' .

ind:SellerSettlement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketplace ;
    rdfs:label 'Seller Settlement' ;
    rdfs:comment 'Transactional record capturing the periodic financial settlement disbursed to marketplace sellers. Tracks settlement period start and end dates, seller identifier, gross sales amount, total commissions deducted, refund deductions, promotional funding credits, net disbursement amount, settlement currency, disbursement status (pending, processing, disbursed, on-hold), bank transfer reference, and settlement generation timestamp. Supports seller financial reconciliation and SOX-compliant revenue reporting.' .

ind:Dispute rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketplace ;
    rdfs:label 'Dispute' ;
    rdfs:comment 'Master entity managing the full lifecycle of seller-buyer dispute cases on the marketplace platform, including granular event audit trail. Captures dispute details (reference number, type, initiating party, status, resolution outcome, enforcement actions) and all lifecycle events (status changes with timestamps, evidence submissions, escalations, agent assignments, decisions, appeals, communications). Supports dispute types including item-not-received, item-not-as-described, unauthorized transactions, return disputes, and listing policy violations. Each event records actor type (buyer, seller, marketplace agent, automated system), event notes, attached evidence references, and resulting status. Provides complete audit trail for FTC consumer protection compliance, RMA workflows, SLA tracking, and regulatory reporting.' .

ind:ListingCategory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketplace ;
    rdfs:label 'Listing Category' ;
    rdfs:comment 'Reference hierarchy defining the marketplace-specific product category taxonomy used for listing classification, commission schedule mapping, buy-box rule application, and search relevance. Captures category node identifier, category name, parent category reference (supporting multi-level hierarchy), category path string, category depth level, applicable commission rate reference, restricted category flag, age-restricted flag, hazmat flag, category status, and CPSC compliance requirement indicator. Distinct from the product domain\'s catalog taxonomy as it governs marketplace-specific rules.' .

ind:MarketplacePromotion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketplace ;
    rdfs:label 'Marketplace Promotion' ;
    rdfs:comment 'Master entity representing marketplace-level promotional campaigns, deal events, and their enrolled listing associations. Captures promotion lifecycle (name, type, status, date range, discount mechanics, funding source, budget cap, FTC disclosure requirements) and listing enrollment details as child records (enrolled listing references, promotional pricing, quantity limits, seller acceptance status, enrollment source, enrollment date, eligibility score at enrollment, enrollment status). Supports lightning deals, deal-of-the-day, coupons, bundle deals, and seasonal events. Manages the many-to-many relationship between promotions and marketplace listings including enrollment workflows and seller opt-in tracking.' .

ind:PriceList rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Price List' ;
    rdfs:comment 'Master record defining a named price list (e.g., MSRP, wholesale, member, regional) with effective date ranges, currency, applicable customer segments, and channel scope. Serves as the authoritative base price catalog from which all pricing rules derive. Owned by the Pricing domain as the SSOT for base price structures.' .

ind:PriceListItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Price List Item' ;
    rdfs:comment 'Line-level entry within a price list associating a specific SKU or product variant to its base unit price, minimum order quantity (MOQ), unit of measure, and pricing structure type (flat, tiered, volume-based, bundle). For tiered/volume pricing, captures quantity thresholds and per-tier unit prices. For bundle pricing, captures constituent SKUs and bundle discount. Serves as the authoritative base price per SKU per price list supporting all pricing structure variants.' .

ind:DynamicPriceRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Dynamic Price Rule' ;
    rdfs:comment 'Defines algorithmic or rules-based dynamic pricing logic applied to SKUs, categories, or seller listings across platform-owned and marketplace channels. Includes trigger conditions (demand signals, inventory levels, competitor price thresholds, MAP violations, seller compliance triggers), adjustment type (percentage, fixed, floor/ceiling), rule scope (platform-wide, seller-specific, category-level, brand-level), priority rank, activation schedule, and enforcement actions. For marketplace-scoped rules: MAP enforcement thresholds, maximum price caps, commission-adjusted floor prices, seller-specific pricing agreements, and brand protection policies. Powers real-time price optimization, surge/markdown automation, MAP enforcement, marketplace pricing integrity, and seller pricing governance.' .

ind:MarkdownSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Markdown Schedule' ;
    rdfs:comment 'Planned markdown calendar for SKUs or product categories, specifying markdown percentage or absolute reduction, start and end dates, markdown reason (end-of-season, clearance, overstock), and approval status. Supports seasonal clearance cycles and inventory liquidation workflows.' .

ind:PromotionalCampaign rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Promotional Campaign' ;
    rdfs:comment 'Master record for a pricing-driven promotional campaign (e.g., flash sale, seasonal event, loyalty reward event), capturing campaign name, type, budget cap, GMV target, start/end timestamps, eligibility rules, and owning business unit. Acts as the parent entity for all promotional mechanics and discount structures within a campaign.' .

ind:PromotionRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Promotion Rule' ;
    rdfs:comment 'Defines the specific discount mechanics within a promotional campaign, including rule type (BOGO, percentage off, fixed amount off, free shipping, bundle deal), qualifying conditions (minimum cart value, eligible SKUs, customer segment, channel), discount value, stacking priority, and maximum redemption limits.' .

ind:Coupon rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Coupon' ;
    rdfs:comment 'Master record for all discount code instruments including public promotional coupons, customer-specific vouchers, batch-issued codes, and gift card discount codes. Captures code identifier, code type (public coupon, targeted voucher, batch-issued, gift card), discount type (percentage, fixed amount, free shipping), discount value, minimum order threshold, maximum discount cap, eligible product/category scope, customer segment eligibility, distribution method, usage limit per customer, total redemption cap, expiry date, issuance channel, and linked campaign. For voucher-type codes: tracks individual issuance records with customer assignment, face value, issuance date, redemption status, and linked loyalty program. Serves as the SSOT for all discount code lifecycle management across all code types.' .

ind:CouponRedemption rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Coupon Redemption' ;
    rdfs:comment 'Transactional record capturing each coupon or voucher redemption event, including the redeemed code, order reference, customer reference, discount amount applied, redemption timestamp, channel, and redemption outcome (success, failure, partial). Provides the audit trail for all discount code usage and supports fraud detection and budget tracking.' .

ind:PriceOverride rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Price Override' ;
    rdfs:comment 'Transactional record of a manual or system-initiated price override applied to a specific order line or SKU, capturing the original price, overridden price, override reason code, approving user, approval timestamp, and override scope (order-level, line-level, customer-specific). Supports exception pricing workflows and audit compliance.' .

ind:PriceHistory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Price History' ;
    rdfs:comment 'Immutable append-only log of all price changes for each SKU across all price lists, capturing previous price, new price, effective timestamp, change source (dynamic rule, manual override, markdown, promotion, experiment adoption), triggering entity reference, and the user or system that initiated the change. Supports price elasticity computation, regulatory compliance (price display laws, consumer protection), competitive analysis, rollback capability, and historical price auditing for dispute resolution.' .

ind:Carrier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Carrier' ;
    rdfs:comment 'Master record for all transportation carriers (FTL, LTL, parcel, last-mile, cross-border) contracted by Ecommerce. Captures carrier identity (SCAC, DOT number), service capabilities, EDI integration status, compliance certifications (C-TPAT, IATA, WTO), carrier tier classification, performance SLA thresholds, and active contract references. SSOT for carrier identity across TMS and logistics operations.' .

ind:CarrierService rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Carrier Service' ;
    rdfs:comment 'Defines the specific service offerings provided by each carrier — e.g., standard ground, express, overnight, same-day, LTL freight, FTL, cross-border. Captures service code, transit time SLA, weight/dimension limits, supported origin-destination lanes, surcharge eligibility, and carrier-assigned service level identifiers. Enables carrier selection logic in TMS route optimization.' .

ind:LogisticsShipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Logistics Shipment' ;
    rdfs:comment 'Core transactional entity representing a physical shipment dispatched from a fulfillment node to a destination. Captures shipment reference number, origin/destination addresses, carrier assignment, service level, tracking number, weight, dimensions, declared value, shipment status (derived from tracking_event stream), estimated and actual ship/delivery dates, FTL/LTL indicator, and TMS shipment ID. Central logistics record linking orders to physical movement. SSOT for shipment identity and carrier assignment. Status is derived from tracking_event — this entity owns the shipment header, not the event history.' .

ind:ShipmentPackage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Shipment Package' ;
    rdfs:comment 'Individual physical packages within a shipment. A single shipment may contain multiple packages (cartons, pallets, parcels, envelopes). Captures package sequence number, dimensions (L×W×H), weight, package type, tracking barcode, carrier label format and file reference URL, label generation timestamp, seal number, hazmat flag, and package-level status. Subsumes shipping label data — label attributes are properties of the package, not a separate entity. Enables parcel-level tracking, carrier billing reconciliation, and manifest generation.' .

ind:ShipmentItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Shipment Item' ;
    rdfs:comment 'Line-level detail of SKUs included within a shipment package. Captures SKU reference, quantity shipped, unit of measure, item description, HS tariff code for customs, country of origin, declared unit value, and hazmat classification. Supports customs documentation, carrier manifests, and shipment-to-order reconciliation.' .

ind:TrackingEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Tracking Event' ;
    rdfs:comment 'Unified event stream recording all shipment lifecycle events from carrier integrations (EDI 214, carrier APIs). Event types include: pickup scan, in-transit scan, out-for-delivery, delivery attempt (with attempt sequence, outcome, and reattempt scheduling), exception (address correction, customs hold, damage, carrier delay — with exception reason code, responsible party, resolution action, and resolution timestamp), and proof-of-delivery confirmation (recipient name, signature capture, delivery photo URL, GPS coordinates). Captures event timestamp, event type code, scan location, carrier facility code, GPS coordinates, and raw carrier event description. SSOT for ALL shipment status derivation, last-mile visibility, exception management, delivery confirmation, and SLA compliance monitoring. No other entity in this domain records shipment events or delivery outcomes.' .

ind:CarrierRateCard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Carrier Rate Card' ;
    rdfs:comment 'Contracted rate structures negotiated with carriers for specific lanes, service levels, and weight breaks. Captures rate card version, effective/expiry dates, origin-destination lane, service level code, weight tier, base rate, fuel surcharge percentage, accessorial rate schedule, currency, and negotiation reference. SSOT for freight cost estimation and carrier selection optimization in TMS.' .

ind:DeliveryZone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Delivery Zone' ;
    rdfs:comment 'Geographic delivery zone definitions used for carrier assignment, rate calculation, and SLA determination. Captures zone code, zone name, country/region/state coverage, postal code ranges, carrier-specific zone mapping, delivery day SLA, surcharge applicability (remote area, residential), and zone tier classification. Reference entity supporting route optimization and last-mile planning.' .

ind:CarrierContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Logistics ;
    rdfs:label 'Carrier Contract' ;
    rdfs:comment 'Master records of commercial contracts with transportation carriers. Captures contract number, carrier reference, contract type (master, spot, dedicated), effective and expiry dates, contracted volume commitments, rate card references, SLA terms, penalty clauses, auto-renewal flag, and contract status. Distinct from carrier_rate_card which holds rate structures — this entity holds the legal and commercial agreement metadata.' .

ind:PaymentTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Payment Transaction' ;
    rdfs:comment 'Core authoritative record of every monetary transaction processed on the platform, including the immutable event log of all state transitions (authorized, captured, settled, voided, failed) and gateway webhook callbacks. Captures payment amount, currency, exchange rate applied, processing status, gateway response codes, authorization codes, timestamps, retry history, and event-driven lifecycle audit trail. Each transaction references a payment method, may have one or more authorizations, and flows through to settlement. Supports PCI DSS audit requirements and PSD2 Strong Customer Authentication (SCA) compliance evidence. SSOT for all payment transaction records, their lifecycle events, and state transition history.' .

ind:Method rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Method' ;
    rdfs:comment 'Master record of all payment instruments registered by customers on the platform, including credit/debit cards (PCI DSS-tokenized), digital wallets (Apple Pay, Google Pay, PayPal), bank accounts (ACH/SEPA), buy-now-pay-later instruments, gift cards, and marketplace credits. Stores tokenized card data reference, billing address, expiry, card network (Visa/MC/Amex/Discover), issuing bank, method lifecycle status (active/expired/suspended/deleted), customer preference ranking, and SCA enrollment status. SSOT for payment instrument definitions referenced by transactions, authorizations, and tokens.' .

ind:Authorization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Authorization' ;
    rdfs:comment 'Captures the real-time authorization request and response lifecycle for each payment attempt against the issuing bank via the payment gateway. Records authorization code, AVS/CVV result, issuer response, decline reason, authorization amount, hold expiry, 3DS/SCA authentication result and challenge status, and gateway latency. An authorization may be voided, partially captured, retried, or expire without settlement — distinct from the final captured transaction. Supports PSD2 Strong Customer Authentication compliance tracking.' .

ind:Settlement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Settlement' ;
    rdfs:comment 'Records settlement batches and individual settlement entries submitted to acquiring banks and payment networks for fund transfer, including all associated processing fees at transaction level. Settlement attributes: settlement date, amount, currency, acquiring bank, merchant account, status (pending/settled/failed). Fee attributes: fee type (interchange, assessment, gateway fee, cross-border fee, currency conversion fee), fee amount, fee rate, fee currency. SSOT for settlement records and their associated processing fees. Supports daily reconciliation, financial close, cost-of-payment analysis, and fee reconciliation against gateway invoices.' .

ind:PaymentRefund rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Payment Refund' ;
    rdfs:comment 'Tracks all refund transactions initiated against original payment transactions, including full and partial refunds. Records refund amount, refund reason code, originating transaction reference, refund method (original payment method or store credit), processing status, and gateway refund confirmation. Supports RMA-driven refund workflows and customer service-initiated refunds.' .

ind:Chargeback rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Chargeback' ;
    rdfs:comment 'Manages the full lifecycle of payment disputes and chargebacks initiated by cardholders through their issuing bank. Tracks chargeback reason code (per Visa/MC/Amex dispute categories), dispute amount, dispute date, response deadline, evidence submission status, chargeback outcome (won/lost/accepted), and associated financial liability. Critical for fraud management and financial reconciliation.' .

ind:FraudCase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Fraud Case' ;
    rdfs:comment 'Operational record of confirmed or suspected fraudulent payment activity requiring investigation and action, plus the authoritative registry of fraud detection rules and velocity checks that drive automated prevention. Case attributes: fraud type (CNP, account takeover, friendly fraud, synthetic identity), detection source, fraud amount, case status, investigator assignment, resolution outcome, recovery amount. Rule attributes: rule logic (e.g., max transaction amount per hour, BIN country mismatch, device fingerprint anomaly), rule priority, action (block/review/allow), activation status, performance thresholds. SSOT for both fraud investigation cases and the fraud prevention ruleset. Supports real-time fraud blocking, post-transaction investigation, rule tuning, and regulatory SAR (Suspicious Activity Report) filing.' .

ind:Gateway rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Gateway' ;
    rdfs:comment 'Master reference for all payment gateway integrations and acquiring bank connections configured on the platform. Records gateway provider (Stripe, Adyen, Braintree, etc.), supported payment methods, supported currencies, processing region, gateway endpoint configuration, failover priority, and SLA parameters. Enables multi-gateway routing and fallback logic for transaction processing.' .

ind:MerchantAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Merchant Account' ;
    rdfs:comment 'Master record of merchant accounts established with acquiring banks and payment processors for fund collection. Tracks merchant account number, acquiring bank, payment network agreements, processing currency, settlement currency, merchant category code (MCC), account status, and associated processing fees. Supports multi-merchant-account routing for marketplace and DTC channels.' .

ind:Reconciliation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Reconciliation' ;
    rdfs:comment 'Tracks the daily and periodic reconciliation process between internal transaction records and external bank/gateway statements, at both run-level summary and individual line-item detail. Run attributes: reconciliation period, matched/unmatched counts, variance totals, status (open/reconciled/exception). Line-item attributes: internal transaction reference, external statement reference, match status, variance amount, exception reason code. SSOT for all reconciliation runs and their constituent line items. Supports financial close, SOX-compliant payment reconciliation, and drill-down investigation of discrepancies.' .

ind:Wallet rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Wallet' ;
    rdfs:comment 'Master record of customer digital wallet accounts on the platform with complete transactional ledger of all balance movements. Wallet attributes: balance, currency, type (store credit, loyalty points, prepaid balance), funding sources, status. Transaction attributes: movement type (top-up, refund credit, promotional credit, loyalty redemption, purchase payment, withdrawal, expiry), amount, balance before/after, reference order or promotion, timestamp. SSOT for wallet accounts and their full transaction history. Provides complete audit trail for wallet balance integrity. Distinct from third-party digital wallets (Apple Pay, PayPal) which are captured as payment_method records.' .

ind:Token rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Payment ;
    rdfs:label 'Token' ;
    rdfs:comment 'PCI DSS-compliant tokenization registry mapping sensitive payment card data (PAN) to platform-generated tokens used in transaction processing. Stores token value, token type (network token vs. platform token), associated payment method reference, tokenization provider (Visa Token Service, Mastercard MDES, internal vault), token status, and expiry. Ensures raw card data never persists in application systems.' .

ind:Cart rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Cart' ;
    rdfs:comment 'Represents a customers active shopping cart prior to order submission. Captures session context, channel origin (B2C, B2B, marketplace, mobile app), cart creation and expiry timestamps, applied coupon codes, estimated totals, saved-for-later flag, and cart abandonment signals (last activity timestamp, abandonment email trigger status). Serves as the SSOT for pre-purchase intent and cart-to-order conversion tracking. This is the entry point of the order lifecycle — cart submission triggers order_header creation. Line-item details are held in the related cart_item product.' .

ind:CartItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Cart Item' ;
    rdfs:comment 'Individual line-level SKU entries within a shopping cart. Tracks SKU identifier, quantity requested, unit price at time of add-to-cart, seller ID for marketplace items, product variant details, and item-level promotional flags. Supports cart-to-order conversion analysis and CVR optimization.' .

ind:Header rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Header' ;
    rdfs:comment 'The authoritative master record for a confirmed customer order within the OMS. Captures the full order header including order number, channel (B2C, B2B, marketplace, BOPIS, DTC), order placement timestamp, customer reference, billing address, total GMV, AOV contribution, tax amount, discount amount, currency, order status, SLA tier, and payment reference. This is the SSOT for order-level identity and lifecycle management across all channels.' .

ind:Line rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Line' ;
    rdfs:comment 'Individual SKU-level line items within a confirmed order. Captures SKU/ASIN/UPC, product name, quantity ordered/fulfilled, unit selling price, line-level discount, line total, seller ID for marketplace orders, fulfillment node assignment, line status, promised delivery date, and line-level tax details (jurisdiction, rate, amount, exemption status). Supports GMV decomposition, line-level fulfillment tracking, returns attribution, and tax compliance reporting.' .

ind:StatusHistory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Status History' ;
    rdfs:comment 'Immutable audit log of all order lifecycle state transitions for a sales order. Records each status change event (e.g., PLACED → CONFIRMED → ALLOCATED → SHIPPED → DELIVERED → CANCELLED), the timestamp of transition, the actor or system that triggered the change, and any associated reason codes. Enables SLA breach detection, order lifecycle analytics, and OMS orchestration tracing.' .

ind:OrderAddress rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Order Address' ;
    rdfs:comment 'Shipping and billing address records associated with a sales order. Stores address type (shipping/billing/pickup), recipient name, address lines, city, state/province, postal code, country, geolocation coordinates, address validation status, and residential vs. commercial flag. Supports last-mile delivery routing, tax jurisdiction determination, and fraud screening.' .

ind:OrderPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Order Payment' ;
    rdfs:comment 'Order-level payment allocation records linking a sales order to one or more payment transactions. Captures payment method type, payment reference from the payment gateway, amount allocated to this order, currency, payment status (authorized, captured, failed, refunded), split-payment flags, and gift card or store credit redemption amounts. This is the order domains local reference to payment events — it does NOT own gateway integration, PCI-scoped card data, or settlement processing (those belong to the payment domain). Enables order-level payment reconciliation, refund eligibility checks, and revenue recognition without crossing domain boundaries.' .

ind:OrderPromotion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Order Promotion' ;
    rdfs:comment 'Records of promotions, discount codes, and coupons applied at the order or line level. Captures promotion code, promotion type (percentage discount, fixed amount, BOGO, free shipping), discount amount applied, promotion source (marketing campaign, loyalty program, seller-funded), eligibility validation status, and stacking rules applied. Supports GMV-net-of-discount reporting and ROAS attribution.' .

ind:Tax rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Tax' ;
    rdfs:comment 'Tax calculation and jurisdiction records applied to a sales order. Captures tax jurisdiction code, tax type (sales tax, VAT, GST, customs duty), taxable amount, tax rate applied, tax amount, tax exemption status, nexus state/country, and the tax engine calculation reference. Supports SOX-compliant tax reporting, GDPR-aligned data residency, and cross-border e-commerce compliance.' .

ind:Cancellation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Cancellation' ;
    rdfs:comment 'Records of order or order-line cancellation events initiated by customers, sellers, or the OMS. Captures cancellation request timestamp, reason code (customer-initiated, out-of-stock, fraud hold, seller cancellation, payment failure), status workflow (requested → approved/rejected → completed), refund eligibility, cancellation actor, and partial vs. full cancellation scope. Supports cancellation rate KPI tracking, GMV leakage analysis, and refund workflow triggering.' .

ind:DeliveryConfirmation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Delivery Confirmation' ;
    rdfs:comment 'Final delivery confirmation records for fulfilled orders. Captures actual delivery timestamp, delivery location type (door, locker, neighbor, pickup point), proof-of-delivery reference (signature, photo, OTP), carrier scan event reference, delivery attempt number, and delivery exception codes (failed attempt, returned to sender). This is the SSOT for confirmed delivery events within the order domain, distinct from logistics shipment tracking.' .

ind:FulfillmentAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Order ;
    rdfs:label 'Fulfillment Allocation' ;
    rdfs:comment 'Records the assignment of order lines to specific fulfillment nodes (warehouses, 3PL centers, FBA-style nodes, seller locations, dark stores). Captures the fulfillment node ID, allocation timestamp, allocation method (nearest node, lowest cost, seller-fulfilled, zone-skipping), allocated quantity, allocation status (pending, confirmed, picked, cancelled), split-shipment flag, and estimated ship date. This is the order domains handoff point to the fulfillment domain — it owns the allocation decision, not the pick-pack-ship execution.' .

ind:Campaign rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Campaign' ;
    rdfs:comment 'Master record for all marketing campaigns across owned (email, push, SMS), paid (SEM, display, social, shopping, video), and earned (referral, affiliate, organic social) channels. Captures campaign identity, type, channel, objective (acquisition, retention, upsell, brand awareness), budget allocation, flight dates, target audience segment, campaign owner, status lifecycle, UTM parameters, bidding strategy, daily/lifetime budget caps, target geography, platform-specific IDs, ad group hierarchy (as nested structure for paid media), ad format, and associated brand or product line. SSOT for all campaign definitions — performance, attribution, budget, and creative records reference this master. For paid media campaigns, includes ad group-level detail (keyword themes, audience targeting, bid amounts, group status) as child records within the campaign structure.' .

ind:CampaignPerformance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Campaign Performance' ;
    rdfs:comment 'Operational record capturing each campaign deployment event and its resulting performance metrics. Combines execution metadata (send date/time, channel, audience size, delivery status, bounce count, batch ID, platform job reference) with engagement metrics (impressions, clicks, CTR, conversions, CVR, spend, revenue attributed, ROAS, CPC, CPM, RPM, CAC, AOV). One record per campaign activation per reporting period. Supports real-time campaign monitoring, ROI analysis, and budget optimization. Subsumes former campaign_execution concept.' .

ind:AudienceSegment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Audience Segment' ;
    rdfs:comment 'Master record for reusable customer audience segments including membership composition. Captures segment definition (name, type, logic, refresh frequency, owner, status) and per-member association records (customer ID, membership dates, inclusion reason, membership status). Enables historical tracking of segment composition changes, CLTV-based cohort analysis, and real-time personalization decisioning. SSOT for marketing audience definitions and their evaluated membership.' .

ind:CreativeAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Creative Asset' ;
    rdfs:comment 'Master record for all marketing creative assets across email templates, ad creatives (text, image, video, carousel, responsive), push notification content, and SMS templates. Captures asset name, format type (email_template, ad_text, ad_image, ad_video, ad_carousel, push, sms), subject line/headline, body content/description, display URL, destination URL, media references (image/video URLs), content block references, personalization tokens, language/locale, compliance flags (CAN-SPAM, GDPR), approval status, platform-specific IDs, template version, and active status. SSOT for all creative content deployed in campaign execution across owned and paid channels. Supports creative performance comparison and A/B test variant tracking.' .

ind:EmailEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Email Event' ;
    rdfs:comment 'Transactional record capturing individual email interaction events at the recipient level. Tracks event type (sent, delivered, opened, clicked, bounced, unsubscribed, spam complaint), event timestamp, recipient customer ID, campaign execution ID, email message ID, link URL clicked, device type, email client, IP address, and bounce category. Sourced from Salesforce Marketing Cloud tracking extracts. Enables deliverability monitoring and engagement analysis.' .

ind:AttributionTouchpoint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Attribution Touchpoint' ;
    rdfs:comment 'Transactional record capturing each marketing touchpoint in a customer\'s pre-conversion journey. Tracks customer ID, session ID, touchpoint timestamp, channel (paid search, organic, email, display, affiliate, social, direct), campaign ID, ad group, keyword, UTM source/medium/campaign/content/term, device type, and touchpoint position (first, middle, last). Feeds multi-touch attribution models (linear, time-decay, data-driven) for ROAS and CAC calculation.' .

ind:Referral rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Referral' ;
    rdfs:comment 'Master record for customer referral program instances where an existing customer refers a new prospect. Captures referrer customer ID, referred prospect identifier, referral code, referral channel (email, social share, link), referral date, referral status (pending, converted, expired, rewarded), conversion order ID, referrer reward type and amount, and referee incentive type and amount. Supports referral program ROI measurement and viral acquisition tracking.' .

ind:SellerProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Seller ;
    rdfs:label 'Seller Profile' ;
    rdfs:comment 'Master record for every third-party merchant and marketplace seller entity on the platform. Stores legal business name, trading name, registration number, business type (individual/SMB/enterprise), incorporation country, tax identification numbers (VAT/EIN/GST), primary and secondary contact details (owner name, email, phone, role, notification preferences), primary category, current seller tier reference, onboarding status, account status (active/suspended/terminated), platform join date, and preferred communication language. This is the SSOT for seller identity and contact information — all other seller domain entities reference this record. Sourced from the Seller Management Portal.' .

ind:Verification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Seller ;
    rdfs:label 'Verification' ;
    rdfs:comment 'Tracks Know Your Customer / Know Your Business (KYC/KYB) identity verification workflows and serves as the authoritative document repository for all seller-submitted compliance materials. Captures verification type (identity/business/bank/tax), verification provider, submission date, workflow status (pending/in_review/approved/rejected/expired), rejection reason codes, risk classification, and compliance officer notes. Stores associated documents: document type (passport/business_license/utility_bill/tax_certificate/insurance_certificate/bank_statement/product_certification), document name, file reference (S3/blob URI), upload date, expiry date, issuing authority, document verification status (unverified/verified/expired/rejected), and whether document is seller-submitted or platform-issued. Each seller may have multiple verification records with multiple associated documents across lifecycle events. Supports regulatory obligations under FTC, GDPR, AML/CFT, CPSC, and EU DAC7 frameworks. Single point of response for regulatory document requests and KYC audit inquiries.' .

ind:Onboarding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Seller ;
    rdfs:label 'Onboarding' ;
    rdfs:comment 'Captures the end-to-end seller onboarding workflow record initiated when a merchant applies to join the marketplace. Tracks application submission date, onboarding stage (applied/document_review/kyc_check/category_approval/agreement_signed/live), assigned reviewer, category requested, business model (B2C/B2B/C2C), fulfillment model (FBA-style/self-fulfilled/3PL), estimated GMV, rejection reasons, escalation flags, and go-live date. Sourced from the Seller Management Portal onboarding module.' .

ind:Agreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Seller ;
    rdfs:label 'Agreement' ;
    rdfs:comment 'Stores the contractual agreement records between the marketplace platform and each seller. Captures agreement type (standard/enterprise/category-specific), effective date, expiration date, governing jurisdiction, commission rate schedule reference, return policy terms, SLA commitments, prohibited category clauses, intellectual property terms, agreement version, digital signature timestamp, and termination conditions. Tracks amendments and renewals as versioned records. Supports SOX and FTC compliance for marketplace contracts.' .

ind:Commission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Seller ;
    rdfs:label 'Commission' ;
    rdfs:comment 'Defines the commission and fee schedule applicable to a seller or seller tier. Captures commission rate by product category, referral fee percentage, variable closing fee, subscription fee tier, FBA-style fulfillment fee rates, promotional co-op fee, minimum commission floor, effective date range, and whether the structure is negotiated (enterprise) or standard. Supports GMV-based tiered commission models and category-specific rate overrides. Referenced by payment settlement and GMV attribution processes.' .

ind:Scorecard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Seller ;
    rdfs:label 'Scorecard' ;
    rdfs:comment 'Periodic performance scorecard record for each seller capturing key operational and commercial KPIs used for tier management and enforcement decisions. Stores scorecard period (daily/weekly/monthly), DSR (Daily Sales Rate), BSR (Best Seller Rank) within category, order defect rate (ODR), late shipment rate, cancellation rate, return rate, NPS contribution score, customer complaint count, policy violation count, GMV for period, AOV (Average Order Value), conversion rate on seller listings, inventory health score, and overall performance tier rating. Used for automated tier promotion/demotion triggers, suspension threshold monitoring, and incentive program eligibility. Sourced from Seller Management Portal performance monitoring module.' .

ind:GmvSettlement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Seller ;
    rdfs:label 'Gmv Settlement' ;
    rdfs:comment 'Transactional record attributing Gross Merchandise Value (GMV) to individual sellers for each settlement period. Captures gross sales amount, returns and refunds deducted, net GMV, platform commission charged, promotional subsidy applied, tax collected on behalf of seller, currency, exchange rate, attribution period start/end dates, and GMV source channel (web/mobile/API). Supports financial reporting, seller tier evaluation, and marketplace revenue recognition. Links to order and payment domains for reconciliation.' .

ind:Rating rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Seller ;
    rdfs:label 'Rating' ;
    rdfs:comment 'Stores buyer-submitted ratings and reviews for individual sellers. Captures rating score (1-5), review text, review date, order reference, verified purchase flag, rating dimensions (communication/shipping_speed/item_as_described/packaging), seller response text, seller response date, moderation status (pending/approved/removed), removal reason, and helpfulness votes. Aggregated ratings feed into seller scorecard and tier management. Supports NPS and CSAT tracking at the seller level.' .

ind:Violation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Seller ;
    rdfs:label 'Violation' ;
    rdfs:comment 'Records policy breaches, enforcement actions, and account suspension/reinstatement events for sellers who violate marketplace policies, regulatory requirements, or platform terms of service. Captures violation type (counterfeit/prohibited_item/pricing_manipulation/review_fraud/IP_infringement/data_misuse), detection method (automated_rule/manual_review/buyer_report/regulatory_notice), severity level (warning/minor/major/critical), detection date, evidence references, assigned investigator, investigation status (open/under_review/upheld/dismissed/appealed), enforcement action taken (warning_issued/listing_removed/account_suspended/account_terminated/probation_applied), suspension effective date, expected reinstatement date, appeal eligibility and deadline, appeal outcome, and reinstatement conditions. Provides complete enforcement lifecycle from detection through resolution including suspension/reinstatement audit trail. Supports FTC, CPSC, and platform trust & safety compliance.' .

ind:Tier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Seller ;
    rdfs:label 'Tier' ;
    rdfs:comment 'Reference master defining the marketplace seller tier classification hierarchy. Captures tier name (Bronze/Silver/Gold/Platinum/Enterprise), qualification thresholds (minimum GMV, minimum scorecard rating, minimum tenure), benefits granted (commission rate discount percentage, premium feature access flags, dedicated account manager eligibility, API rate priority, enhanced analytics access), badge display eligibility, tier review cadence (monthly/quarterly), demotion grace period rules, and tier-specific SLA commitments. Provides the authoritative classification framework referenced by profile for current tier assignment, by scorecard for promotion/demotion evaluation, and by commission for rate resolution.' .

ind:SellerBankAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Seller ;
    rdfs:label 'Seller Bank Account' ;
    rdfs:comment 'Stores verified bank account and payment disbursement method records for each seller. Captures account holder name, bank name, account type (checking/savings/business), account number (tokenized/masked per PCI DSS), routing number, IBAN, SWIFT/BIC code, currency, country, verification status (pending/verified/failed), primary payout flag, and date verified. A seller may have multiple bank accounts across currencies. Directly referenced by seller_payout for disbursement routing. PCI DSS-compliant storage with tokenization.' .

ind:ApprovedVendorList rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Approved Vendor List' ;
    rdfs:comment 'Master list of pre-qualified and approved vendors eligible for purchase order issuance, capturing approval status, qualification criteria met, and expiration dates.' .

ind:PriceZone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pricing ;
    rdfs:label 'Price Zone' ;
    rdfs:comment 'Geographic or customer-segment-based pricing zone definitions that determine which price list applies to a given buyer. Captures zone code, zone name, geographic boundaries, customer segment criteria, and effective date ranges.' .

ind:Channel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Master record defining marketing channels and their configurations (email, SMS, push notification, social media, display advertising, affiliate). Captures channel type, platform integration details, cost model, and performance benchmarks.' .

ind:CampaignBudget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Campaign Budget' ;
    rdfs:comment 'Transactional record tracking marketing campaign-level budget allocations, spend tracking, and ROI calculations. Captures allocated amount, spent amount, remaining budget, cost-per-acquisition targets, and budget period.' .

ind:WishlistItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Wishlist Item' ;
    rdfs:comment 'This association product represents the relationship between a customer wishlist and a catalog item. It captures when an item was added to a wishlist, the desired quantity, priority ranking, and any user notes. Each record links one wishlist to one catalog item and stores data that belongs only to the association.. Existence Justification: Customers actively create and manage wishlists, adding multiple catalog items to each wishlist. Each catalog item can appear in many different customers\' wishlists. The platform records attributes such as when an item was added, desired quantity, priority, and user notes, making the association a managed business entity.' .

ind:AdGroup rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Ad Group' ;
    rdfs:comment 'Master reference table for ad_group. Referenced by ad_group_id.' .

ind:Marketplace rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketplace ;
    rdfs:label 'Marketplace' ;
    rdfs:comment 'Master reference table for marketplace. Referenced by marketplace_id.' .

ind:CampaignCreativeAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Campaign Creative Assignment' ;
    rdfs:comment 'This association product represents the Assignment (Role) between campaign and creative_asset. It captures the operational record of a specific creative asset being deployed within a specific campaign, including placement context, active date range, primary/variant designation, and A/B test role. Each record links one campaign to one creative_asset with attributes that exist only in the context of this assignment — a creative asset may be assigned to many campaigns, and a campaign may deploy many creative assets, each assignment carrying its own placement and variant metadata.. Existence Justification: In e-commerce marketing operations, creative assets are reusable brand assets managed in a DAM system and deliberately assigned to multiple campaigns (e.g., a hero banner image used across a summer sale campaign AND a retargeting campaign simultaneously). Conversely, a single campaign deploys multiple creative assets (e.g., A/B test variants, different ad formats for different placements). The business actively manages these assignments through a creative assignment workflow, tracking placement type, date ranges, and variant roles — this is not derivable from transactional data but is an operational record humans create and update.' .

ind:CategoryAttributeScope rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Product ;
    rdfs:label 'Category Attribute Scope' ;
    rdfs:comment 'This association product represents the schema governance contract between attribute_definition and category in the PIM system. It captures which attributes are assigned to which categories, along with per-scope overrides for requiredness, display ordering, and lifecycle dates. Each record defines one attribute\'s applicability to one category, enabling merchandising teams to manage catalog completeness rules at the category level. Replaces the denormalized applicable_category_scope STRING field on attribute_definition.. Existence Justification: In PIM systems, merchandising and catalog governance teams explicitly manage which attributes apply to which categories — this is a core operational function called \'attribute scope assignment\' or \'category attribute schema\'. An attribute_definition (e.g., \'Screen Size\') applies to multiple categories (e.g., Smartphones, Tablets, Monitors), and a category (e.g., Electronics > Smartphones) requires many attribute definitions (Screen Size, Battery Life, OS, RAM). This is not derivable from transactional data — it is a schema governance record that humans actively create, update, and retire.' .

ind:PromotionCategoryEnrollment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketplace ;
    rdfs:label 'Promotion Category Enrollment' ;
    rdfs:comment 'This association product represents the Enrollment event between marketplace_promotion and listing_category. It captures the operational record of a specific product category being enrolled in a specific promotional campaign, including the enrollment lifecycle, applicable discount terms for that category within the promotion, and the date window during which the enrollment is active. Each record links one marketplace_promotion to one listing_category with attributes that exist only in the context of this category-level promotional participation.. Existence Justification: In marketplace operations, promotional campaigns are explicitly scoped to specific product categories — a Deal of the Day or Lightning Deal targets Electronics, Apparel, or other category nodes with distinct discount rules and enrollment windows. One promotion covers many categories simultaneously, and one category participates in many promotions over time (seasonal events, flash sales, coupon campaigns). The business actively manages this as \'promotion_category_enrollment\' — a named operational concept with its own lifecycle, dates, status, and discount terms that belong neither to the promotion nor the category alone.' .

# --- Attribute Properties ---
ind:generalLedgerId rdf:type rdf:Property ;
    rdfs:label 'General Ledger Id' ;
    rdfs:comment 'Primary key for general_ledger' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneralLedger .

ind:legalEntityId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: GL accounts belong to a specific legal entity\'s chart of accounts. general_ledger.company_code is a denormalized code; adding legal_entity_id provides a proper FK to the legal_entity master, enabling ' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:accountBalanceGc rdf:type rdf:Property ;
    rdfs:label 'Account Balance Gc' ;
    rdfs:comment 'Current cumulative balance of the GL account in the group/consolidation currency. Used for multi-entity financial consolidation, group-level reporting, and GMV-to-revenue reconciliation across all company codes. Supports MRR and ARR tracking at the enterprise level.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountBalanceLc rdf:type rdf:Property ;
    rdfs:label 'Account Balance Lc' ;
    rdfs:comment 'Current cumulative balance of the GL account in the company code local currency. Represents the net of all debit and credit postings to this account for the current fiscal period. Used for trial balance generation, financial statement preparation, and period-end close reporting.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountCategory rdf:type rdf:Property ;
    rdfs:label 'Account Category' ;
    rdfs:comment 'Secondary classification grouping GL accounts into functional categories such as cash and equivalents, accounts receivable, inventory, fixed assets, accounts payable, accrued liabilities, deferred revenue, cost of goods sold, operating expenses, etc. Supports financial statement line-item grouping and management reporting. [ENUM-REF-CANDIDATE: cash_and_equivalents|accounts_receivable|inventory|fixed_assets|accounts_payable|accrued_liabilities|deferred_revenue|cost_of_goods_sold|operating_expenses|other — promote to reference product]' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountDescription rdf:type rdf:Property ;
    rdfs:label 'Account Description' ;
    rdfs:comment 'Detailed narrative description of the GL account\'s business purpose, the types of transactions it records, and any special posting rules or restrictions. Used for financial governance documentation, new employee training, and SOX control documentation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountEffectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Account Effective From' ;
    rdfs:comment 'The date from which this GL account became active and available for financial postings. Used for account lifecycle management, historical reporting, and SOX audit trails. Postings with a document date before this date are not permitted.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountEffectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Account Effective Until' ;
    rdfs:comment 'The date after which this GL account is no longer available for financial postings. Null for accounts with no planned end date. Used for account decommissioning, chart of accounts rationalization, and SOX-compliant account lifecycle management.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'Organizational grouping of GL accounts within the chart of accounts that controls the number range and field selection for account master data maintenance. Corresponds to SAP S/4HANA account group (KTOKS). Examples include balance sheet accounts, P&L accounts, cost accounts.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountLongName rdf:type rdf:Property ;
    rdfs:label 'Account Long Name' ;
    rdfs:comment 'Full descriptive name of the GL account providing complete context for financial reporting and audit purposes. Corresponds to the SAP S/4HANA GL account long text (TXT50). Used in detailed financial statements and regulatory filings.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'Short descriptive name of the GL account as displayed in financial reports, trial balances, and the chart of accounts. Corresponds to the SAP S/4HANA GL account short text (TXT20).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'The externally-known, human-readable GL account number as defined in the chart of accounts. Used in all financial postings, journal entries, and financial statement line items. Corresponds to the SAP S/4HANA GL account key (SAKNR).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the GL account master record. Active accounts accept financial postings; blocked accounts are temporarily restricted from new postings; marked_for_deletion accounts are pending archival after period-end close. Corresponds to SAP S/4HANA account blocking indicators.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Fundamental financial classification of the GL account per the accounting equation. Determines how the account appears on financial statements: asset and liability/equity accounts appear on the balance sheet; revenue and expense accounts appear on the income statement. Corresponds to SAP S/4HANA account type (KTOKS).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Alternative Account Number' ;
    rdfs:comment 'Alternative or country-specific account number used for local statutory reporting requirements. Enables mapping between the operational chart of accounts and country-specific or group chart of accounts. Supports multi-GAAP reporting and local statutory compliance.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccountsCode rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Code' ;
    rdfs:comment 'Identifier for the chart of accounts grouping to which this GL account belongs. In SAP S/4HANA, a chart of accounts is a classified directory of all GL accounts used by one or more company codes. Enables multi-COA structures for operational and group reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'SAP S/4HANA company code representing the legal entity or organizational unit for which the GL account is defined. Supports multi-company-code chart of accounts and financial consolidation across the enterprise.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'SAP S/4HANA cost center code linked to this GL account for cost center accounting. Enables expense tracking and allocation by organizational unit, department, or function. Supports management reporting and budget variance analysis.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'Indicates whether this GL account is also defined as a cost element in SAP Controlling (CO) module. Primary cost elements correspond to GL expense/revenue accounts; secondary cost elements are used for internal cost allocations and have no corresponding GL account. Drives cost center accounting and profitability analysis.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'SAP S/4HANA user ID of the person who created this GL account master record. Required for SOX-compliant audit trails, segregation of duties controls, and financial governance. Corresponds to SAP S/4HANA ERNAM field.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when this GL account master record was first created in the system. Provides the audit trail creation point for SOX compliance and data lineage tracking. Corresponds to SAP S/4HANA creation date and time fields.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the account currency. When set, all postings to this account must be in this currency. If null, the account accepts postings in any currency and balances are maintained in the company code currency. Critical for multi-currency financial reporting and foreign exchange management.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldStatusGroup rdf:type rdf:Property ;
    rdfs:label 'Field Status Group' ;
    rdfs:comment 'SAP S/4HANA field status group code assigned to this GL account that controls which fields are required, optional, or suppressed during document entry for postings to this account. Ensures data completeness and consistency for financial postings.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementSection rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Section' ;
    rdfs:comment 'Identifies which primary financial statement this GL account contributes to. Drives automated financial statement preparation and regulatory reporting. Critical for SOX-compliant period-end close and IFRS/GAAP financial reporting.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal period (accounting period) within the fiscal year to which the current account balance applies. Typically 1-12 for monthly periods, with additional special periods (13-16) for year-end adjustments. Corresponds to SAP S/4HANA posting period (MONAT).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year to which the current account balance and period-end close data applies. Supports multi-year financial reporting, year-over-year comparisons, and SOX-compliant audit trails. Corresponds to SAP S/4HANA fiscal year (GJAHR).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'SAP S/4HANA fiscal year variant code that defines the fiscal year structure (calendar year, non-calendar year, or shortened fiscal year) and the number of posting periods. Determines how fiscal periods map to calendar months for financial reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'SAP S/4HANA functional area classification that categorizes GL accounts by business function (e.g., sales, marketing, production, administration, research and development). Enables cost-of-sales accounting and functional income statement reporting per IFRS IAS 1.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric level of this GL account within the account hierarchy tree, where level 1 represents the top-most grouping (e.g., total assets) and higher numbers represent more granular accounts. Used for financial statement rollup logic and management reporting drill-down.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBalanceSheetRelevant rdf:type rdf:Property ;
    rdfs:label 'Is Balance Sheet Relevant' ;
    rdfs:comment 'Indicates whether this GL account carries a balance that is reported on the balance sheet. Balance sheet accounts (assets, liabilities, equity) carry forward their balances at year-end; P&L accounts are reset to zero. Drives automated year-end closing and balance carryforward processes.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPostingAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Posting Allowed' ;
    rdfs:comment 'Indicates whether direct financial postings are permitted to this GL account. When false, the account is a summary/header account used only for hierarchical reporting and cannot receive direct journal entry postings. Corresponds to SAP S/4HANA posting block indicator.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReconciliationAccount rdf:type rdf:Property ;
    rdfs:label 'Is Reconciliation Account' ;
    rdfs:comment 'Indicates whether this GL account is a reconciliation account that is automatically updated when postings are made to subledger accounts (accounts receivable, accounts payable, asset accounting). Reconciliation accounts cannot receive direct manual postings. Critical for AR/AP subledger-to-GL reconciliation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPostingDate rdf:type rdf:Property ;
    rdfs:label 'Last Posting Date' ;
    rdfs:comment 'The date of the most recent financial posting made to this GL account. Used for account activity monitoring, dormant account identification, and chart of accounts maintenance. Supports period-end close validation and SOX control testing.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineItemDisplay rdf:type rdf:Property ;
    rdfs:label 'Line Item Display' ;
    rdfs:comment 'Indicates whether individual line items posted to this GL account are stored and displayable for audit and analysis purposes. When true, each posting line is retained for drill-down reporting. Required for SOX audit trails and financial investigation. Corresponds to SAP S/4HANA line item display indicator (XKRES).' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:normalBalance rdf:type rdf:Property ;
    rdfs:label 'Normal Balance' ;
    rdfs:comment 'Indicates whether the GL account normally carries a debit or credit balance per double-entry bookkeeping rules. Assets and expenses normally carry debit balances; liabilities, equity, and revenue normally carry credit balances. Used for trial balance validation and automated posting rules.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openItemManagement rdf:type rdf:Property ;
    rdfs:label 'Open Item Management' ;
    rdfs:comment 'Indicates whether open item management is activated for this GL account. When true, individual line items remain open until they are cleared against offsetting entries (e.g., payment clearing for bank accounts, GR/IR clearing accounts). Essential for bank reconciliation and clearing account management.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Parent Account Number' ;
    rdfs:comment 'Account number of the parent GL account in the account hierarchy. Enables multi-level account hierarchies for financial reporting rollups, management reporting, and financial consolidation. Null for top-level accounts in the hierarchy.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'SAP S/4HANA profit center code associated with this GL account for profitability analysis and segment reporting. Enables revenue and cost attribution to business segments, product lines, or geographic regions. Supports IFRS 8 operating segment disclosures.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationAccountType rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Type' ;
    rdfs:comment 'Specifies the subledger type this reconciliation account is linked to. Determines which subledger transactions automatically update this GL account. Null or \'none\' for non-reconciliation accounts. Corresponds to SAP S/4HANA reconciliation account type (MITKZ).' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Business segment identifier associated with this GL account for segment reporting. Supports IFRS 8 and US GAAP ASC 280 operating segment disclosures. Enables financial reporting by business segment such as marketplace, fulfillment, advertising, or subscription services.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'SAP S/4HANA sort key code that determines which field is used to populate the allocation field in line items posted to this account. Controls how line items are sorted and displayed in account statements. Examples: 001 (posting date), 003 (document number), 031 (order number).' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'Specifies the tax treatment applicable to postings on this GL account. Controls whether tax codes are required, optional, or not applicable for journal entries. Relevant for VAT/GST compliance, sales tax reporting, and indirect tax management. Corresponds to SAP S/4HANA tax category (MWSKZ). [ENUM-REF-CANDIDATE: input_tax|output_tax|not_relevant|all_tax_codes|minus_sign — promote to reference product]' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceGroup rdf:type rdf:Property ;
    rdfs:label 'Tolerance Group' ;
    rdfs:comment 'SAP S/4HANA tolerance group assigned to this GL account that defines the permitted payment differences and rounding tolerances for clearing transactions. Controls automatic write-off of small differences during payment processing and bank reconciliation. Supports SOX controls over financial accuracy.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'SAP S/4HANA user ID of the person who last modified this GL account master record. Required for SOX-compliant audit trails, change management controls, and financial governance. Corresponds to SAP S/4HANA AENAM field.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this GL account master record. Tracks changes to account attributes for SOX-compliant audit trails and data lineage. Essential for change management controls and period-end close integrity.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Unique surrogate identifier for each journal entry record in the general ledger. Serves as the primary key for the journal_entry data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:accountsPayableId rdf:type rdf:Property ;
    rdfs:label 'Accounts Payable Id' ;
    rdfs:comment 'Foreign key linking to finance.accounts_payable. Business justification: Journal entries are generated from AP invoice postings and payment events. Linking journal_entry to accounts_payable enables AP-to-GL drill-through for three-way match reconciliation and audit trails.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountsPayable .

ind:accountsReceivableId rdf:type rdf:Property ;
    rdfs:label 'Accounts Receivable Id' ;
    rdfs:comment 'Foreign key linking to finance.accounts_receivable. Business justification: Journal entries are generated from AR invoice postings, cash application, and write-off events. Linking journal_entry to accounts_receivable enables AR-to-GL drill-through for subledger reconciliation' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountsReceivable .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Reference to the cost center responsible for the expenditure or revenue captured in this journal entry. Enables cost allocation, departmental P&L reporting, and budget variance analysis.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:financeBankAccountId rdf:type rdf:Property ;
    rdfs:label 'Finance Bank Account Id' ;
    rdfs:comment 'Foreign key linking to finance.finance_bank_account. Business justification: Bank-related journal entries (bank receipts, payments, reconciliation postings) reference specific bank accounts. Linking journal_entry to finance_bank_account enables bank-to-GL reconciliation and tr' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceBankAccount .

ind:lineId rdf:type rdf:Property ;
    rdfs:label 'Line Id' ;
    rdfs:comment 'Foreign key linking to order.order_line. Business justification: Journal entries for COGS, revenue, and line-level tax are posted at the order line level. Finance teams need drill-down from GL journal entries to source order lines for transaction-level audit, COGS ' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:primaryJournalGeneralLedgerId rdf:type rdf:Property ;
    rdfs:label 'Primary Journal General Ledger Id' ;
    rdfs:comment 'Reference to the General Ledger (GL) account to which this journal entry header is primarily associated. The GL account determines the financial statement line item and chart of accounts classification.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneralLedger .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Reference to the profit center associated with this journal entry. Supports segment-level profitability reporting, GMV-to-revenue reconciliation, and management accounting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:settlementId rdf:type rdf:Property ;
    rdfs:label 'Settlement Id' ;
    rdfs:comment 'Foreign key linking to payment.settlement. Business justification: Journal entries for settlement cash postings reference the settlement batch. Finance GL posting process for cash receipts from payment settlements requires tracing journal entries back to the settleme' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Settlement .

ind:supplierId rdf:type rdf:Property ;
    rdfs:label 'Supplier Id' ;
    rdfs:comment 'Reference to the intercompany trading partner entity involved in this journal entry. Required for intercompany elimination during financial consolidation and statutory group reporting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:taxRecordId rdf:type rdf:Property ;
    rdfs:label 'Tax Record Id' ;
    rdfs:comment 'Foreign key linking to finance.tax_record. Business justification: Journal entries are generated from tax posting events (tax accruals, remittances, adjustments). Linking journal_entry to tax_record enables tax-to-GL reconciliation and SOX-compliant audit trails for ' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxRecord .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'A free-form alphanumeric field used to group or sort journal entry line items for reconciliation and reporting purposes (e.g., payment run ID, clearing document number, batch reference). Supports open item management and account clearing workflows.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'SAP business area code representing a distinct operational segment of the enterprise (e.g., marketplace, fulfillment, advertising). Enables cross-company-code financial reporting by business segment.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'The date on which the open item represented by this journal entry line was cleared (offset by a payment or contra-entry). Used for aging analysis, DSO (Days Sales Outstanding) calculation, and AR/AP reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'The SAP document number of the clearing transaction that offset this open item (e.g., payment clearing an invoice). Populated when the journal entry line has been cleared. Supports accounts receivable and accounts payable reconciliation workflows.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'Indicates whether the journal entry line represents a debit (D) or credit (C) posting in double-entry accounting. Every journal entry must balance such that total debits equal total credits, enforcing the fundamental accounting equation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date of the original source document (invoice, receipt, contract) that triggered the journal entry. May differ from the posting date for accruals, reversals, or late-arriving documents.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'SAP document type code classifying the nature of the journal entry (e.g., SA=General Ledger, KR=Vendor Invoice, DR=Customer Invoice, AB=Accounting Document, ZP=Payment Posting, AA=Asset Posting). Drives posting rules and account determination. [ENUM-REF-CANDIDATE: SA|KR|DR|AB|ZP|AA|RE|RV|WA|WE — promote to reference product]' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entry Timestamp' ;
    rdfs:comment 'The precise date and time when the journal entry record was first created and captured in the system. Used for SOX audit trails, data lineage, and period-end close monitoring.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:entryType rdf:type rdf:Property ;
    rdfs:label 'Entry Type' ;
    rdfs:comment 'Business classification of the journal entry indicating its accounting purpose: original posting, reversal of a prior entry, period-end accrual, asset depreciation run, currency revaluation, or intercompany elimination.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The foreign currency exchange rate applied to convert the transaction currency amount to the local currency at the time of posting. Critical for multi-currency reconciliation, currency revaluation, and GAAP/IFRS IAS 21 compliance.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupAmount rdf:type rdf:Property ;
    rdfs:label 'Group Amount' ;
    rdfs:comment 'The monetary amount of the journal entry converted to the group (consolidation) currency. Used for consolidated financial statements, MRR/ARR tracking, and enterprise-level GMV-to-revenue reconciliation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupCurrency rdf:type rdf:Property ;
    rdfs:label 'Group Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the enterprise group\'s reporting currency (e.g., USD). Used for consolidated financial statements and cross-entity comparisons.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headerText rdf:type rdf:Property ;
    rdfs:label 'Header Text' ;
    rdfs:comment 'Free-text description at the journal entry header level explaining the business purpose or context of the posting (e.g., \'Q4 Accrual - Marketplace Seller Commissions\', \'Monthly Depreciation Run\'). Used for audit review and financial close documentation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isIntercompany rdf:type rdf:Property ;
    rdfs:label 'Is Intercompany' ;
    rdfs:comment 'Flag indicating whether this journal entry represents an intercompany transaction between two legal entities within the same corporate group (True) or an external third-party transaction (False). Intercompany entries require elimination during group financial consolidation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStatistical rdf:type rdf:Property ;
    rdfs:label 'Is Statistical' ;
    rdfs:comment 'Flag indicating whether this journal entry is a statistical (non-real) posting used for management reporting and cost allocation purposes only (True), as opposed to a real posting that updates actual financial balances (False). Statistical postings do not affect the balance sheet.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'The date and time when the journal entry record was last modified. Supports change tracking, audit trails, and incremental data pipeline processing in the Databricks Silver Layer.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Line Item Number' ;
    rdfs:comment 'Sequential line number within the journal entry document identifying the position of each debit or credit line. Used to uniquely reference individual line items within a multi-line journal entry for reconciliation and audit purposes.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineItemText rdf:type rdf:Property ;
    rdfs:label 'Line Item Text' ;
    rdfs:comment 'Free-text description at the individual line item level providing additional context for the specific debit or credit posting (e.g., \'Accrued seller commission - Nov 2024\', \'Revenue recognition - Order #ORD-98765\'). Supports granular audit trails and reconciliation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localAmount rdf:type rdf:Property ;
    rdfs:label 'Local Amount' ;
    rdfs:comment 'The monetary amount of the journal entry converted to the local (company code) currency. Used for statutory financial reporting and local GAAP compliance in the jurisdiction of the legal entity.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localCurrency rdf:type rdf:Property ;
    rdfs:label 'Local Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the company code\'s local (functional) currency (e.g., USD for US entities, EUR for EU entities). Used for local statutory reporting and tax filings.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The principal real-world accounting date on which the journal entry is posted to the general ledger. Determines the fiscal period assignment and is the primary date used for period-end close, financial reporting, and regulatory submissions.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'SAP two-digit posting key that determines the account type, debit/credit assignment, and field selection for the journal entry line (e.g., 40=GL Debit, 50=GL Credit, 01=Customer Invoice, 31=Vendor Invoice). Drives account determination and field status.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current lifecycle state of the journal entry in the general ledger workflow. Draft entries are pending approval; posted entries are final; reversed entries have been offset by a counter-entry; parked entries await completion; held entries are saved but not yet posted; error entries failed validation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'The type of source business document that originated this journal entry (e.g., order, payment, invoice, purchase_order, return, shipment). Enables traceability from the GL back to the originating operational transaction.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The date on which the reversal of this journal entry is scheduled or was executed. Used for automated period-end accrual reversals and audit trail completeness.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this journal entry is a reversal of a previously posted entry (True) or an original posting (False). Reversal entries offset prior postings and are critical for period-end close accuracy and SOX audit trails.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The SAP document number of the original journal entry that this entry reverses. Populated only when reversal_indicator is True. Enables audit trail linkage between original and reversal postings.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'The externally-known accounting document number assigned by SAP S/4HANA upon posting. This is the primary business identifier used by finance teams to reference a journal entry across systems, audit trails, and reconciliation workflows.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Identifies the operational system of record that originated this journal entry (e.g., SAP_S4HANA for ERP-generated entries, OMS for order management system auto-postings, PAYMENT_GATEWAY for payment settlement entries, WMS for inventory adjustments, MANUAL for manually entered entries). Supports data lineage and audit trail requirements.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'The calculated tax amount (VAT, GST, or sales tax) associated with this journal entry in the transaction currency. Used for tax liability reporting, tax reconciliation, and regulatory filings.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'SAP tax code identifying the applicable tax rate and tax category (e.g., VAT, GST, sales tax) for the journal entry line. Drives automatic tax calculation and tax reporting to regulatory authorities.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'The gross monetary amount of the journal entry in the transaction currency (the currency of the originating business event). Used as the base amount before currency conversion for multi-currency reconciliation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the originating transaction (e.g., USD, EUR, GBP). Represents the currency in which the business event was denominated before conversion to local or group currency.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual debit or credit line item within a journal entry. Serves as the primary key for this entity in the Databricks Silver Layer.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The monetary amount of this journal entry line in the transaction currency. Always stored as a positive value; the debit_credit_indicator determines the sign direction. Satisfies TRANSACTION_LINE LINE_VALUE_OR_RESULT category. Corresponds to WRBTR in SAP S/4HANA.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountGroupCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Group Currency' ;
    rdfs:comment 'The monetary amount of this line item translated into the group (consolidation) currency for enterprise-wide financial consolidation and consolidated financial statement preparation. Corresponds to KZBTR in SAP S/4HANA.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Local Currency' ;
    rdfs:comment 'The monetary amount of this line item translated into the company code local currency (functional currency). Used for statutory financial reporting in the entity\'s home jurisdiction. Corresponds to DMBTR in SAP S/4HANA.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'The calculated due date for payment of this line item based on the document date and payment terms. Used for cash flow forecasting, payment run scheduling, and overdue item identification. Corresponds to FAEDT in SAP S/4HANA.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isCleared rdf:type rdf:Property ;
    rdfs:label 'Is Cleared' ;
    rdfs:comment 'Boolean flag indicating whether this open item has been cleared (True) or remains open (False) in the subledger. Drives open item management reporting for AR and AP aging analysis.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number within the parent journal entry, used to order and uniquely identify each posting line within a document. Satisfies TRANSACTION_LINE LINE_SEQUENCE category. Corresponds to BUZEI in SAP S/4HANA ACDOCA.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the company code local (functional) currency. Enables reconciliation between transaction currency and statutory reporting currency. Corresponds to HWAER in SAP S/4HANA.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Payment terms key applicable to this line item, defining the due date calculation and any early payment discount conditions (e.g., NET30, 2/10NET30). Relevant for vendor invoice and customer invoice line items. Corresponds to ZTERM in SAP S/4HANA.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterPartner rdf:type rdf:Property ;
    rdfs:label 'Profit Center Partner' ;
    rdfs:comment 'The partner profit center for intercompany or intra-company eliminations in profit center accounting. Used to eliminate internal transactions during segment and consolidated financial reporting. Corresponds to PRCTR_PARTNER in SAP S/4HANA.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference number from the originating source document (e.g., vendor invoice number, purchase order number, payment reference). Enables traceability from the GL posting back to the originating business transaction. Corresponds to XBLNR in SAP S/4HANA.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Code identifying the business reason for reversing this journal entry line (e.g., incorrect account, wrong period, duplicate posting, accrual reversal). Supports audit trail documentation and SOX compliance. Corresponds to STGRD in SAP S/4HANA.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segment rdf:type rdf:Property ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Financial reporting segment assigned to this line item for segment-level P&L reporting under IFRS 8 or ASC 280. Represents a distinct business unit such as B2C marketplace, B2B wholesale, or third-party logistics. Corresponds to SEGMENT in SAP S/4HANA.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceLedger rdf:type rdf:Property ;
    rdfs:label 'Source Ledger' ;
    rdfs:comment 'The SAP ledger from which this journal entry line originates (e.g., 0L=Leading Ledger GAAP, 1L=Local GAAP extension ledger, 2L=IFRS extension ledger). Supports parallel accounting under multiple accounting standards. Corresponds to RLDNR in SAP S/4HANA.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialGlIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Gl Indicator' ;
    rdfs:comment 'SAP special GL indicator used to classify non-standard postings such as down payments, guarantees, bills of exchange, or statistical postings. Enables separate reporting of these items from standard AR/AP balances. Corresponds to UMSKZ in SAP S/4HANA.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartner rdf:type rdf:Property ;
    rdfs:label 'Trading Partner' ;
    rdfs:comment 'Company code of the intercompany trading partner for intercompany transaction identification and elimination during group financial consolidation. Corresponds to VBUND in SAP S/4HANA.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'The date on which the financial value of this posting becomes effective for cash flow and liquidity management purposes. Particularly relevant for bank postings and payment transactions. Corresponds to VALUT in SAP S/4HANA.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'SAP user ID of the person or system process that created this journal entry line. Essential for SOX audit trail, segregation of duties compliance, and financial control monitoring. Corresponds to USNAM in SAP S/4HANA.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityTypeCode rdf:type rdf:Property ;
    rdfs:label 'Activity Type Code' ;
    rdfs:comment 'SAP CO activity type code associated with this cost center for activity-based costing. Activity types define the unit of output (e.g., machine hours, labor hours, API calls) used to allocate costs to cost objects such as orders or projects.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualPostingAllowed rdf:type rdf:Property ;
    rdfs:label 'Actual Posting Allowed' ;
    rdfs:comment 'Indicates whether actual cost postings (from FI, MM, HR, etc.) are permitted to this cost center. Controls financial transaction authorization at the cost center level in SAP CO.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:annualBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Amount' ;
    rdfs:comment 'Total approved annual budget allocated to this cost center in the controlling currency. Represents the planned expenditure ceiling for the fiscal year. Used for budget vs. actual variance analysis and financial planning.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAllocationCode rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Code' ;
    rdfs:comment 'Code that links this cost center to its approved budget allocation in the annual planning cycle. Used to match actual expenditures against planned budgets in SAP CO-PA and for variance analysis in financial reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'Top-level business unit to which this cost center belongs. Supports P&L reporting segmented by Marketplace, Direct-to-Consumer (DTC), Business-to-Business (B2B), Fulfillment, Technology, and Corporate functions. Enables GMV-to-revenue reconciliation at the segment level.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:centerType rdf:type rdf:Property ;
    rdfs:label 'Center Type' ;
    rdfs:comment 'Classifies whether the center tracks costs only (cost center), revenues and costs for P&L (profit center), capital investment accountability (investment center), or revenue generation only (revenue center). Drives how SAP EC-PCA profitability analysis is applied.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentPostingAllowed rdf:type rdf:Property ;
    rdfs:label 'Commitment Posting Allowed' ;
    rdfs:comment 'Indicates whether commitment postings (purchase orders, purchase requisitions) are permitted to this cost center. Enables funds management and purchase order commitment tracking against the cost center budget.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'SAP CO controlling area code that defines the organizational unit within which cost accounting is performed. All cost centers belong to exactly one controlling area, which determines the currency and fiscal year variant for internal reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Method' ;
    rdfs:comment 'Method used to allocate or distribute costs from this cost center to other cost objects. Direct allocation posts costs directly; assessment uses statistical keys; distribution reallocates primary costs; activity-based costing uses activity types. Configured in SAP CO-OM cycle definitions.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'SAP CO cost center category code (e.g., E for administration, F for production, H for auxiliary) that classifies the functional nature of the cost center for internal cost allocation and reporting. [ENUM-REF-CANDIDATE: administration|production|auxiliary|sales|marketing|logistics|technology|finance — promote to reference product]' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Detailed narrative description of the cost center\'s business purpose, scope of operations, and the types of expenses it tracks. Supports financial governance and audit documentation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'Human-readable name of the cost center as defined in the SAP CO module. Used in financial reports, P&L statements, and budget dashboards to identify the organizational unit.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. Active centers accept postings; locked centers are frozen for new transactions; archived centers are closed and retained for historical reporting only. Aligns with SAP CO activation status.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where this cost center operates. Used for statutory reporting, tax jurisdiction assignment, and GDPR/CCPA data residency compliance.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Functional department within the business unit that owns this cost center (e.g., Engineering, Finance, Marketing, Operations, Logistics). Used for departmental budget tracking and headcount cost allocation.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'SAP FI functional area code assigned to this cost center, used to classify costs by business function (e.g., Sales, Administration, Production, R&D) for cost-of-sales accounting and segment reporting under GAAP and IFRS.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprRelevant rdf:type rdf:Property ;
    rdfs:label 'Gdpr Relevant' ;
    rdfs:comment 'Indicates whether this cost center processes or is associated with personal data subject to GDPR obligations. Used for data protection impact assessments and privacy-by-design compliance tracking.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Geographic region or country code (ISO 3166-1 alpha-3) associated with this cost center. Used for regional P&L reporting, transfer pricing compliance, and multi-currency consolidation in international operations.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyNodeCode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Node Code' ;
    rdfs:comment 'Code of the parent node in the standard cost center hierarchy (SAP CO standard hierarchy). Enables roll-up reporting from individual cost centers to department, business unit, and enterprise levels for consolidated financial reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOrderCode rdf:type rdf:Property ;
    rdfs:label 'Internal Order Code' ;
    rdfs:comment 'SAP CO internal order code linked to this cost center for project-based or campaign-based cost tracking. Internal orders provide a more granular cost collection object within the cost center for specific initiatives (e.g., a marketing campaign or technology project).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this cost center master data record in the source system. Used for change detection in ETL pipelines, audit trails, and SOX compliance evidence of record changes.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lockIndicator rdf:type rdf:Property ;
    rdfs:label 'Lock Indicator' ;
    rdfs:comment 'Indicates whether the cost center is locked for new financial postings. When True, no new actual or plan postings are permitted. Used during period-end close, audits, or organizational restructuring to prevent unauthorized transactions.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mrrTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Mrr Tracking Enabled' ;
    rdfs:comment 'Indicates whether this cost center is configured to track Monthly Recurring Revenue (MRR) contributions for subscription-based revenue recognition. Relevant for B2B and marketplace seller subscription fee revenue streams.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentCostCenterCode rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Center Code' ;
    rdfs:comment 'Code of the parent cost center in a self-referencing hierarchy, enabling recursive organizational roll-up for management reporting. Null for top-level cost centers.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planPostingAllowed rdf:type rdf:Property ;
    rdfs:label 'Plan Posting Allowed' ;
    rdfs:comment 'Indicates whether planning postings (budget and forecast entries) are permitted to this cost center. Controls whether the cost center participates in the annual planning and rolling forecast cycles in SAP CO-OM.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleManagerName rdf:type rdf:Property ;
    rdfs:label 'Responsible Manager Name' ;
    rdfs:comment 'Full name of the manager responsible for this cost center. Stored as a denormalized display field for financial reports and budget dashboards without requiring a join to the HR system.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxRelevant rdf:type rdf:Property ;
    rdfs:label 'Sox Relevant' ;
    rdfs:comment 'Indicates whether this cost center is in scope for Sarbanes-Oxley (SOX) internal controls over financial reporting. SOX-relevant cost centers require documented control procedures, segregation of duties, and periodic audit evidence.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Tax jurisdiction code assigned to this cost center for indirect tax (VAT/GST/sales tax) determination and reporting. Used in SAP FI-TX for tax calculation on cost center-related procurement and expense transactions.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Code' ;
    rdfs:comment 'SAP PS Work Breakdown Structure (WBS) element code associated with this cost center for project cost tracking. Enables project-level cost reporting and capital expenditure (CapEx) vs. operating expenditure (OpEx) classification.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFrom rdf:type rdf:Property ;
    rdfs:label 'Valid From' ;
    rdfs:comment 'The date from which this cost center is active and can accept financial postings. Corresponds to the SAP CO validity period start date. Cost center records are time-sliced; this field defines the start of the current validity interval.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validTo rdf:type rdf:Property ;
    rdfs:label 'Valid To' ;
    rdfs:comment 'The date until which this cost center is active and can accept financial postings. Corresponds to the SAP CO validity period end date. A null or far-future date (e.g., 9999-12-31) indicates an open-ended validity period.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Method used to allocate shared costs and overhead to this profit center in SAP CO. \'direct\' = costs posted directly; \'assessment\' = allocated via assessment cycles; \'distribution\' = allocated via distribution cycles; \'settlement\' = settled from internal orders or projects.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualCostBudget rdf:type rdf:Property ;
    rdfs:label 'Annual Cost Budget' ;
    rdfs:comment 'Planned annual operating cost allocation for this profit center in the profit center\'s primary currency. Supports cost center management, overhead allocation, and budget adherence tracking.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualRevenueBudget rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Budget' ;
    rdfs:comment 'Planned annual revenue target for this profit center in the profit center\'s primary currency. Used for budget vs. actuals variance analysis and segment-level P&L reporting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetFiscalYear rdf:type rdf:Property ;
    rdfs:label 'Budget Fiscal Year' ;
    rdfs:comment 'The fiscal year for which the current budget allocation is defined for this profit center. Used to align budget tracking with the enterprise fiscal calendar in SAP S/4HANA.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Business justification or reason code for the most recent change to this profit center\'s master data (e.g., \'Organizational restructuring\', \'New business segment launch\', \'Merger integration\'). Required for SOX audit trail documentation.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyClassification rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Classification' ;
    rdfs:comment 'Data classification level assigned to financial data associated with this profit center per enterprise data governance policy. Drives access control, data masking, and retention policies in the lakehouse.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'The date on which this profit center was deactivated or archived. Null if the profit center is currently active. Used for historical reporting, audit trails, and ensuring no new postings are made to deactivated profit centers.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Organizational department code associated with this profit center. Links the profit center to the enterprise organizational structure for headcount allocation and overhead cost distribution.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpProfitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Erp Profit Center Code' ;
    rdfs:comment 'Native profit center identifier as stored in the source ERP system (SAP S/4HANA). Enables traceability and reconciliation between the lakehouse silver layer and the operational SAP system of record.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmvToRevenueRatio rdf:type rdf:Property ;
    rdfs:label 'Gmv To Revenue Ratio' ;
    rdfs:comment 'The standard ratio used to convert Gross Merchandise Value (GMV) to recognized net revenue for this profit center. For marketplace segments, this reflects the take rate (commission percentage). Critical for GMV-to-revenue reconciliation in financial reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupCode rdf:type rdf:Property ;
    rdfs:label 'Group Code' ;
    rdfs:comment 'Code of the profit center group (node in the standard hierarchy) to which this profit center belongs. Profit center groups enable aggregated reporting across multiple profit centers in SAP EC-PCA.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyTradingPartner rdf:type rdf:Property ;
    rdfs:label 'Intercompany Trading Partner' ;
    rdfs:comment 'SAP trading partner code identifying the affiliated company for intercompany transactions originating from this profit center. Required for intercompany elimination during financial consolidation. Corresponds to the VBUND field in SAP.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDummy rdf:type rdf:Property ;
    rdfs:label 'Is Dummy' ;
    rdfs:comment 'Indicates whether this is the dummy profit center used to capture postings that cannot be assigned to a real profit center. Each controlling area has exactly one dummy profit center. Corresponds to the DUMMY field in SAP EC-PCA.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mrrApplicable rdf:type rdf:Property ;
    rdfs:label 'Mrr Applicable' ;
    rdfs:comment 'Indicates whether this profit center tracks Monthly Recurring Revenue (MRR) as a primary financial metric. Applicable to subscription-based or SaaS business segments. Drives MRR and ARR reporting in financial dashboards.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentProfitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Parent Profit Center Code' ;
    rdfs:comment 'Business code of the parent profit center in the organizational hierarchy. Enables hierarchical roll-up of P&L data for consolidated segment reporting. Self-referencing relationship within the profit center hierarchy.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Profit Center Category' ;
    rdfs:comment 'Functional classification of the profit center indicating whether it is primarily a revenue-generating, cost-bearing, or investment unit. Used for internal profitability analysis and capital allocation decisions.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Profit Center Description' ;
    rdfs:comment 'Detailed narrative description of the profit center\'s business scope, revenue streams, and cost responsibilities. Provides context for financial analysts and auditors.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'Human-readable business name of the profit center (e.g., \'Marketplace - North America\', \'DTC - Apparel\', \'B2B - Enterprise\'). Used in P&L reports and management dashboards.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current lifecycle status of the profit center in SAP EC-PCA. \'active\' = operational and accepting postings; \'inactive\' = temporarily suspended; \'locked\' = blocked for new postings (SOX control); \'pending_activation\' = created but not yet approved; \'archived\' = historical, no longer in use.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleManager rdf:type rdf:Property ;
    rdfs:label 'Responsible Manager' ;
    rdfs:comment 'Name or employee ID of the business manager accountable for the profit center\'s financial performance, budget adherence, and P&L outcomes. Used for management reporting and SOX accountability assignments.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Method' ;
    rdfs:comment 'Accounting method applied for revenue recognition within this profit center. Determines how GMV converts to recognized revenue. \'point_in_time\' for standard product sales; \'over_time\' for subscription/SaaS; \'percentage_completion\' for long-term contracts; \'milestone\' for project-based billing.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the profit center by primary business model or channel. Drives segment-level P&L reporting and GMV-to-revenue reconciliation. Values: marketplace (third-party seller platform), dtc (Direct to Consumer), b2b (Business to Business), b2c (Business to Consumer), c2c (Consumer to Consumer), fulfillment (logistics/fulfillment services), advertising (ad revenue segment). [ENUM-REF-CANDIDATE: marketplace|dtc|b2b|b2c|c2c|fulfillment|advertising — promote to reference product]' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated display name for the profit center used in condensed financial reports, dashboards, and column headers where space is limited. Corresponds to the KTEXT field in SAP EC-PCA.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlRelevant rdf:type rdf:Property ;
    rdfs:label 'Sox Control Relevant' ;
    rdfs:comment 'Indicates whether this profit center is subject to Sarbanes-Oxley (SOX) internal control requirements. SOX-relevant profit centers require enhanced audit trails, segregation of duties, and periodic management sign-off on financial balances.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:takeRatePct rdf:type rdf:Property ;
    rdfs:label 'Take Rate Pct' ;
    rdfs:comment 'The commission percentage charged to marketplace sellers on each transaction, representing the portion of GMV retained as revenue by the platform. Applicable to marketplace and seller-facing profit centers. Used in GMV-to-revenue reconciliation.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMarginPct rdf:type rdf:Property ;
    rdfs:label 'Target Margin Pct' ;
    rdfs:comment 'Planned profit margin percentage target for this profit center, expressed as a percentage of revenue. Used as a KPI benchmark for segment-level profitability reporting and management performance evaluation.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'The date from which this profit center becomes effective and can receive financial postings. Defines the start of the profit center\'s validity period in SAP EC-PCA. Corresponds to the DATAB field in SAP.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'The date until which this profit center remains valid for financial postings. Null or 9999-12-31 indicates an open-ended validity period. Corresponds to the DATBI field in SAP EC-PCA.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Reference to the originating purchase order that generated this payable obligation. Used for three-way match (PO, goods receipt, invoice) validation and PO settlement tracking.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:supplierInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Supplier Invoice Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier_invoice. Business justification: Three-way match (PO→GR→Invoice) is the core AP process. AP records originate from supplier invoices; this FK enables invoice verification, dispute resolution, and audit trail reporting. Every e-commer' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierInvoice .

ind:vendorContractId rdf:type rdf:Property ;
    rdfs:label 'Vendor Contract Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor_contract. Business justification: AP invoices are processed against governing vendor contracts for contract compliance monitoring, spend-against-contract reporting, and payment terms validation. E-commerce finance teams link payables ' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorContract .

ind:agingBucket rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket' ;
    rdfs:comment 'Aging classification of the outstanding payable based on the number of days past the invoice date or due date. Used for AP aging reports, cash flow forecasting, vendor relationship management, and SOX financial disclosure. Recalculated daily during Silver layer processing.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apStatus rdf:type rdf:Property ;
    rdfs:label 'Ap Status' ;
    rdfs:comment 'Current lifecycle status of the AP record within the payment workflow. Drives aging analysis, payment run eligibility, and cash flow forecasting. [ENUM-REF-CANDIDATE: open|pending_approval|approved|scheduled|paid|disputed|cancelled — promote to reference product]' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'The current approval workflow status of the invoice within the AP approval chain. Invoices must be approved before payment release. Supports segregation of duties controls required for SOX compliance.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'The username or employee ID of the individual who approved the invoice for payment. Required for SOX segregation of duties audit trail and internal controls documentation.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'The date and time when the invoice was approved for payment processing. Part of the SOX-required audit trail for AP internal controls. Distinct from posting date and payment date.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:baseCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Base Currency Amount' ;
    rdfs:comment 'The net payable amount converted to the company code base currency (typically USD) using the exchange rate at posting date. Required for consolidated financial reporting, GL posting, and multi-currency AP subledger reconciliation. Corresponds to DMBTR in SAP FI-AP.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysPastDue rdf:type rdf:Property ;
    rdfs:label 'Days Past Due' ;
    rdfs:comment 'Number of calendar days the invoice has exceeded its payment due date. Negative values indicate days until due. Zero indicates due today. Used for AP aging analysis, vendor penalty calculations, and cash flow management. Recalculated daily.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'The cash discount amount available if payment is made within the early payment discount window defined in the payment terms (e.g., 2/10 net 30). Supports working capital optimization and dynamic discounting programs.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountDueDate rdf:type rdf:Property ;
    rdfs:label 'Discount Due Date' ;
    rdfs:comment 'The last date by which payment must be made to qualify for the early payment discount. Calculated from invoice date plus discount period days in the payment terms. Drives dynamic discounting and working capital optimization decisions.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'The reason code for placing an invoice in disputed status. Populated when ap_status is \'disputed\'. Drives dispute resolution workflows, vendor communication, and root cause analysis for AP exception management.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'The total gross amount of the vendor invoice before any deductions, discounts, or adjustments. Represents the full obligation as stated on the vendor invoice. Used for GMV-to-revenue reconciliation and AP aging analysis.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date printed on the vendor invoice document. Serves as the principal business event date for the payable obligation and is the baseline for payment term calculations and aging bucket assignment.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the AP document type. Standard invoices represent normal vendor payables; credit memos reduce outstanding balances; debit memos increase obligations; recurring invoices are for subscription/SaaS vendors; prepayments are advance payments; intercompany invoices are for internal entity transactions. Corresponds to BLART in SAP FI-AP.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Indicates whether this invoice is part of a recurring payment schedule (e.g., SaaS subscriptions, lease payments, maintenance contracts). Recurring invoices are auto-generated by SAP recurring entry programs. Used for MRR/ARR tracking and cash flow forecasting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'The net amount payable to the vendor after deducting applicable discounts, credits, and adjustments from the gross invoice amount. Represents the actual cash outflow obligation. Used for payment run execution and cash flow forecasting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockCode rdf:type rdf:Property ;
    rdfs:label 'Payment Block Code' ;
    rdfs:comment 'SAP FI-AP payment block indicator that prevents automatic payment processing when set. Common values: R (manual review), A (disputed), B (blocked by purchasing), V (verified pending). Empty string indicates no block. Corresponds to ZLSPR in SAP FI-AP.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The actual date on which payment was executed and disbursed to the vendor. Populated upon successful payment run completion. Used for cash flow reporting, bank reconciliation, and vendor account statement generation.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The method by which payment will be or was made to the vendor (e.g., ACH, wire transfer, check, virtual card, EFT, SEPA). Corresponds to ZLSCH in SAP FI-AP. Used for payment run configuration and bank reconciliation.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'The bank or payment gateway reference number assigned when payment was executed. Used for bank statement reconciliation, payment confirmation, and vendor remittance advice. Corresponds to AUGBL in SAP FI-AP.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'The vendor-agreed payment terms code defining the payment schedule, discount periods, and due date calculation rules (e.g., NET30, 2/10NET30, NET60). Corresponds to ZTERM in SAP FI-AP. Drives automated due date and discount date calculation.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Result of the three-way match validation comparing the purchase order, goods receipt (GR), and vendor invoice. A matched status is required before invoice approval and payment release. Exceptions trigger manual review workflows. Critical for AP internal controls and SOX compliance.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorInvoiceReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Receipt Date' ;
    rdfs:comment 'The date on which the vendor invoice was physically or electronically received by the AP department. Distinct from invoice date (vendor-stamped) and posting date (system-stamped). Used for SLA compliance tracking and payment term baseline calculations where terms start from receipt date.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorType rdf:type rdf:Property ;
    rdfs:label 'Vendor Type' ;
    rdfs:comment 'Classification of the vendor category for this payable. Distinguishes between product suppliers, 3PL carrier invoices, marketplace seller disbursement obligations, SaaS vendor subscriptions, intercompany entities, and utility providers. Drives routing rules, approval workflows, and reporting segmentation.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'The withholding tax amount deducted from the vendor payment at source, as required by applicable tax regulations (e.g., 1099 reporting in the US, WHT for cross-border payments). Corresponds to QSSHB in SAP FI-AP. Required for tax compliance reporting.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: B2B e-commerce credit management requires AR records linked to the customer account for credit limit enforcement, outstanding balance reconciliation, and account-level dunning. customer.account carrie' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:collectionAgentId rdf:type rdf:Property ;
    rdfs:label 'Collection Agent Id' ;
    rdfs:comment 'Reference to the internal collections agent or team assigned to manage the recovery of this overdue AR balance. Used for workload distribution, collector performance reporting, and escalation tracking in the collections workflow.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:customerProfileId rdf:type rdf:Property ;
    rdfs:label 'Customer Profile Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_profile. Business justification: AR aging reports, dunning workflows, and collections management require direct customer identity on each receivable. E-commerce finance teams run customer-level credit exposure reports and collections' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerProfile .

ind:headerId rdf:type rdf:Property ;
    rdfs:label 'Header Id' ;
    rdfs:comment 'Reference to the originating order that generated this AR invoice. Links the receivable to the Order Management System (OMS) for order-to-cash reconciliation and GMV-to-revenue tracing.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Header .

ind:amountPaid rdf:type rdf:Property ;
    rdfs:label 'Amount Paid' ;
    rdfs:comment 'Cumulative amount of payments applied to this AR invoice to date. Supports partial payment tracking and open_amount calculation. Updated each time a payment is matched via cash application.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arStatus rdf:type rdf:Property ;
    rdfs:label 'Ar Status' ;
    rdfs:comment 'Current lifecycle state of the AR record within the collection and settlement workflow. Drives dunning automation, aging bucket classification, and cash application processes in SAP FI-AR. Transitions: open → partially_paid → paid; open → overdue → written_off; open → disputed.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arType rdf:type rdf:Property ;
    rdfs:label 'Ar Type' ;
    rdfs:comment 'Classification of the AR record by the nature of the receivable. Distinguishes B2B customer invoicing, marketplace seller fee receivables, advertising revenue receivables, and subscription billing per the product scope. Drives subledger routing and revenue recognition treatment.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Billing Document Number' ;
    rdfs:comment 'The source billing document number from the Order Management System or SAP SD (Sales and Distribution) that triggered the creation of this AR invoice. Enables order-to-cash traceability and billing dispute resolution.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashApplicationDate rdf:type rdf:Property ;
    rdfs:label 'Cash Application Date' ;
    rdfs:comment 'The date on which incoming payment was matched and applied to this AR invoice in the cash application process. Null if no payment has been applied. Used for DSO calculation, bank reconciliation, and revenue recognition confirmation.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditMemoAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Amount' ;
    rdfs:comment 'The monetary value of the credit memo applied against this AR invoice. Reduces the net receivable balance. Null if no credit memo has been applied. Used in AR reconciliation and revenue adjustment reporting.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Number' ;
    rdfs:comment 'Reference number of the credit memo issued against this AR invoice, if applicable. Used for returns, billing adjustments, and dispute resolutions. Links to the credit memo document in SAP FI-AR for offset processing.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current status of any billing dispute raised by the customer against this AR invoice. Drives dunning_block activation, collection hold, and dispute resolution workflow routing. Integrates with the Customer Data Platform for dispute case management.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningBlock rdf:type rdf:Property ;
    rdfs:label 'Dunning Block' ;
    rdfs:comment 'Flag indicating whether automated dunning is blocked for this AR record (e.g., due to active dispute, customer agreement, or manual hold). When True, the dunning run in SAP FI-AR will skip this record. Corresponds to SAP MANSP field.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunningDate rdf:type rdf:Property ;
    rdfs:label 'Dunning Date' ;
    rdfs:comment 'The date on which the most recent dunning notice was issued to the customer for this AR record. Used to enforce minimum dunning intervals and track collection activity history. Corresponds to SAP FI-AR MAHND field.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current dunning escalation level for overdue AR, ranging from 0 (no dunning) to 4 (final notice / legal escalation). Incremented by the automated dunning run in SAP FI-AR. Drives collection workflow routing and customer communication templates. Corresponds to SAP MAHNS field.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'The General Ledger (GL) account code to which this AR transaction is posted in SAP S/4HANA FI. Used for financial consolidation, trial balance, and regulatory financial reporting. Corresponds to SAP HKONT (GL Account) field.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Externally-visible, human-readable invoice reference number assigned to the AR document. Used in customer-facing communications, remittance matching, and audit trails. Corresponds to the SAP FI-AR BELNR (Accounting Document Number) field.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openAmount rdf:type rdf:Property ;
    rdfs:label 'Open Amount' ;
    rdfs:comment 'The current outstanding balance remaining on the AR invoice after partial payments, credit memo applications, and cash applications. Equals net_amount minus total payments applied. Drives collection prioritization and DSO calculation.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlock rdf:type rdf:Property ;
    rdfs:label 'Payment Block' ;
    rdfs:comment 'Flag indicating whether this AR invoice has been blocked from automated payment clearing (e.g., pending dispute resolution, credit hold, or manual review). When True, the automatic payment program in SAP FI-AR will not clear this item. Corresponds to SAP ZLSPR field.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'The number of days from invoice date within which payment is due, as defined by the payment terms code. Stored explicitly for aging bucket calculation and DSO (Days Sales Outstanding) analytics without requiring a join to payment terms reference data.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promisedPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Promised Payment Date' ;
    rdfs:comment 'The date on which the customer has committed to making payment, as captured during a collection contact or payment arrangement. Used to track promise-to-pay (PTP) agreements and measure collection effectiveness.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'The date on which revenue associated with this AR invoice is recognized per ASC 606 / IFRS 15 five-step model. May differ from invoice_date for subscription billing, milestone-based contracts, or deferred revenue scenarios.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'The amount of the AR balance that has been written off as uncollectible bad debt. Populated when ar_status transitions to written_off. Used for bad debt expense reporting, allowance for doubtful accounts, and SOX-controlled write-off approval workflows.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'The date on which the AR balance was formally written off as uncollectible. Required for bad debt expense period recognition, tax deduction timing, and SOX audit trail. Null if no write-off has occurred.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffReason rdf:type rdf:Property ;
    rdfs:label 'Write Off Reason' ;
    rdfs:comment 'Standardized reason code explaining why the AR balance was written off. Required for SOX-controlled write-off approval documentation and bad debt analytics.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionId rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Id' ;
    rdfs:comment 'Unique surrogate identifier for each revenue recognition event or schedule record in the enterprise financial system. Primary key for this table.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognition .

ind:agreementId rdf:type rdf:Property ;
    rdfs:label 'Agreement Id' ;
    rdfs:comment 'Foreign key linking to seller.seller_agreement. Business justification: Under ASC 606/IFRS 15, revenue recognition is triggered by performance obligations defined in seller agreements. Finance teams require contract-level revenue recognition reporting and external audit t' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:commissionId rdf:type rdf:Property ;
    rdfs:label 'Commission Id' ;
    rdfs:comment 'Foreign key linking to seller.commission. Business justification: Revenue recognition records contain denormalized commission_amount and commission_rate from seller.commission. ASC 606/IFRS 15 revenue recognition requires tracing recognized amounts to the commission' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Commission .

ind:paymentTransactionId rdf:type rdf:Property ;
    rdfs:label 'Payment Transaction Id' ;
    rdfs:comment 'Foreign key linking to payment.payment_transaction. Business justification: ASC 606/IFRS 15 revenue recognition is triggered by payment receipt for cash-basis recognition methods. Revenue recognition records must reference the payment transaction that triggered the recognitio' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentTransaction .

ind:sellerProfileId rdf:type rdf:Property ;
    rdfs:label 'Seller Profile Id' ;
    rdfs:comment 'Reference to the marketplace seller whose transaction generated this revenue recognition event. Relevant for marketplace commission recognition. Sourced from the Seller Management Portal.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SellerProfile .

ind:allocatedTransactionPrice rdf:type rdf:Property ;
    rdfs:label 'Allocated Transaction Price' ;
    rdfs:comment 'The portion of the total contract transaction price allocated to this specific performance obligation, based on relative standalone selling prices per ASC 606 Step 4. May differ from transaction_price when a contract has multiple performance obligations.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:constraintApplied rdf:type rdf:Property ;
    rdfs:label 'Constraint Applied' ;
    rdfs:comment 'Indicates whether the variable consideration constraint was applied to limit the recognized amount, preventing a significant revenue reversal per ASC 606. True = constraint applied; False = full variable consideration included.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractModificationFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Modification Flag' ;
    rdfs:comment 'Indicates whether this revenue recognition event was triggered or affected by a contract modification (e.g., order amendment, subscription upgrade/downgrade, price renegotiation). True = contract modification involved; False = original contract terms.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deferredAmount rdf:type rdf:Property ;
    rdfs:label 'Deferred Amount' ;
    rdfs:comment 'The portion of the transaction price that has been received or billed but not yet recognized as revenue, deferred to future accounting periods. Represents the deferred revenue liability balance for this obligation.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'The precise date and time at which the revenue recognition trigger event occurred (e.g., delivery confirmed timestamp, subscription period end timestamp). This is the principal real-world business event time, distinct from record audit timestamps.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter code for the entity\'s functional currency used for financial consolidation in SAP S/4HANA. Amounts may be converted from transaction currency to functional currency for GL posting.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fxRate rdf:type rdf:Property ;
    rdfs:label 'Fx Rate' ;
    rdfs:comment 'The exchange rate applied to convert transaction currency amounts to the functional currency at the time of recognition. Sourced from SAP S/4HANA currency tables. Relevant for cross-border marketplace transactions.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmvAmount rdf:type rdf:Property ;
    rdfs:label 'Gmv Amount' ;
    rdfs:comment 'The total Gross Merchandise Value (GMV) of the transaction before any deductions. Starting point of the GMV-to-net-revenue waterfall. Represents the full face value of goods/services transacted on the platform.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRecognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Net Recognized Amount' ;
    rdfs:comment 'The net revenue amount recognized after applying promotional discounts, refund adjustments, and other variable consideration adjustments. Equals recognized_amount minus promotional_discount_amount minus refund_adjustment_amount. Bottom line of the GMV-to-net-revenue waterfall.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text notes or comments entered by the finance team regarding this revenue recognition event. Used to document manual overrides, contract modification rationale, or audit observations.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:percentageComplete rdf:type rdf:Property ;
    rdfs:label 'Percentage Complete' ;
    rdfs:comment 'The estimated percentage of the performance obligation that has been satisfied as of the recognition event date. Used for over-time revenue recognition to calculate the recognized amount. Range: 0.00 to 100.00.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceObligationDescription rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Description' ;
    rdfs:comment 'Human-readable description of the distinct performance obligation being satisfied in this recognition event (e.g., \'Delivery of physical goods\', \'Monthly SaaS subscription access\', \'Marketplace listing service\').' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalAgentIndicator rdf:type rdf:Property ;
    rdfs:label 'Principal Agent Indicator' ;
    rdfs:comment 'Indicates whether the entity is acting as principal (recognizes gross revenue) or agent (recognizes net commission) for this transaction. Critical for marketplace revenue recognition and GMV-to-net-revenue waterfall. Determined per ASC 606 B34-B38.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Promotional Discount Amount' ;
    rdfs:comment 'The value of promotional discounts, coupons, or price reductions applied to this transaction that reduce the recognized revenue amount. Part of the GMV-to-net-revenue waterfall adjustment. Sourced from Pricing and Promotions Management.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recognitionEventNumber rdf:type rdf:Property ;
    rdfs:label 'Recognition Event Number' ;
    rdfs:comment 'Externally referenceable business identifier for this revenue recognition event, used in financial reporting, audit correspondence, and reconciliation with SAP S/4HANA journal entries.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Recognition Method' ;
    rdfs:comment 'The accounting method used to measure progress toward complete satisfaction of the performance obligation for over-time recognition. Output methods measure results achieved; input methods measure effort expended. [ENUM-REF-CANDIDATE: output_method|input_method|straight_line|usage_based|milestone_based|residual_approach — promote to reference product]' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Period End Date' ;
    rdfs:comment 'End date of the accounting period over which revenue is recognized. For point-in-time recognition, this equals the event date. For over-time recognition (e.g., subscription ARR), this is the end of the service period.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Period Start Date' ;
    rdfs:comment 'Start date of the accounting period over which revenue is recognized. For point-in-time recognition, this equals the event date. For over-time recognition (e.g., subscription MRR), this is the start of the service period.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Recognition Status' ;
    rdfs:comment 'Current lifecycle state of the revenue recognition event. \'pending\' = awaiting trigger; \'recognized\' = revenue fully recognized; \'deferred\' = revenue deferred to future period; \'partially_recognized\' = portion recognized; \'reversed\' = recognition reversed; \'cancelled\' = event voided.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionTrigger rdf:type rdf:Property ;
    rdfs:label 'Recognition Trigger' ;
    rdfs:comment 'The business event that triggered this revenue recognition. Examples: delivery confirmation from TMS/WMS, subscription billing period elapsed, customer acceptance, refund/return window expiry, or manual finance override. [ENUM-REF-CANDIDATE: delivery_confirmed|subscription_period_elapsed|milestone_achieved|customer_acceptance|refund_period_expired|manual_override|partial_shipment|contract_modification — promote to reference product]' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionType rdf:type rdf:Property ;
    rdfs:label 'Recognition Type' ;
    rdfs:comment 'Indicates whether revenue is recognized at a single point in time (e.g., product delivery) or over time (e.g., subscription MRR/ARR, service contracts), per ASC 606 / IFRS 15 criteria.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Recognized Amount' ;
    rdfs:comment 'The gross revenue amount recognized in this event or for this period. For partial recognition, this is the portion recognized in the current period. Core field in the GMV-to-net-revenue waterfall.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Adjustment Amount' ;
    rdfs:comment 'The amount of revenue reversed or adjusted due to customer returns, refunds, or Return Merchandise Authorization (RMA) events. Reduces recognized revenue in the GMV-to-net-revenue waterfall. Negative values indicate revenue reduction.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Category' ;
    rdfs:comment 'Business classification of the revenue stream being recognized. Covers GMV-to-net-revenue waterfall components: direct product sales, marketplace seller commissions, subscription MRR/ARR, advertising revenue, fulfillment fees, and other. [ENUM-REF-CANDIDATE: product_sale|marketplace_commission|subscription|advertising|fulfillment_fee|data_licensing|other — promote to reference product]' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Source Transaction Reference' ;
    rdfs:comment 'The native transaction identifier from the originating source system (e.g., OMS order number, payment gateway transaction ID, SAP document number). Enables end-to-end reconciliation and audit trail across systems.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Flag' ;
    rdfs:comment 'Indicates whether this revenue recognition record is subject to SOX internal control review and audit. True = SOX-controlled record requiring documented approval and audit trail; False = non-SOX-controlled record.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standaloneSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Standalone Selling Price' ;
    rdfs:comment 'The price at which the entity would sell this performance obligation separately to a customer. Used as the basis for allocating the transaction price across multiple performance obligations per ASC 606 Step 4.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subscriptionMrrAmount rdf:type rdf:Property ;
    rdfs:label 'Subscription Mrr Amount' ;
    rdfs:comment 'The Monthly Recurring Revenue (MRR) amount recognized for subscription-based services in this period. Applicable when revenue_category = \'subscription\'. Used for MRR/ARR tracking and SaaS revenue reporting.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionPrice rdf:type rdf:Property ;
    rdfs:label 'Transaction Price' ;
    rdfs:comment 'The total transaction price allocated to this performance obligation per ASC 606 Step 4. Represents the amount of consideration the business expects to receive in exchange for satisfying this performance obligation, before adjustments.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variableConsiderationEstimate rdf:type rdf:Property ;
    rdfs:label 'Variable Consideration Estimate' ;
    rdfs:comment 'The estimated amount of variable consideration (e.g., volume discounts, rebates, returns allowance, performance bonuses) included in the transaction price per ASC 606 Step 3. Subject to the constraint that a significant revenue reversal is not probable.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exemptionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Exemption Certificate Number' ;
    rdfs:comment 'Reference number of the tax exemption certificate provided by the buyer or seller to justify a zero or reduced tax rate. Required for audit substantiation when is_tax_exempt is True. Confidential business document reference.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'The date on which the tax return or remittance was filed with the relevant tax authority. Null if not yet filed. Used to track compliance with filing deadlines and SLA obligations.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current lifecycle status of the tax record within the filing workflow. Tracks progression from pending obligation through filed, accepted by authority, rejected, amended, or voided. Drives compliance monitoring and SOX audit controls.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMarketplaceFacilitator rdf:type rdf:Property ;
    rdfs:label 'Is Marketplace Facilitator' ;
    rdfs:comment 'Indicates whether the tax was collected and remitted by the e-commerce platform acting as a marketplace facilitator (True) rather than by the individual seller (False). Relevant for US marketplace facilitator tax laws and similar international regulations.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxExempt rdf:type rdf:Property ;
    rdfs:label 'Is Tax Exempt' ;
    rdfs:comment 'Indicates whether the transaction or customer is tax-exempt (True), resulting in a zero tax amount. Requires a valid exemption certificate on file. Used for B2B tax exemption processing and audit compliance.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remittanceDate rdf:type rdf:Property ;
    rdfs:label 'Remittance Date' ;
    rdfs:comment 'The actual date on which the tax amount was remitted (paid) to the tax authority. Null if not yet remitted. Used to confirm payment completion and calculate late payment penalties.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxAmountLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Tax Amount Local Currency' ;
    rdfs:comment 'Tax amount converted to the local reporting currency of the legal entity, using the exchange rate at the time of the taxable event. Required for statutory financial reporting, SOX compliance, and SAP S/4HANA parallel ledger reconciliation.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Name' ;
    rdfs:comment 'Name of the government tax authority to which the tax is owed or has been filed (e.g., \'IRS\', \'HMRC\', \'EU VAT Authority\', \'California CDTFA\'). Used for filing routing and regulatory correspondence.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Document Number' ;
    rdfs:comment 'Externally-known tax document reference number assigned by SAP S/4HANA FI-TX module or the tax authority. Used for audit trails, tax filings, and cross-referencing with regulatory submissions. Serves as the BUSINESS_IDENTIFIER for this transaction.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxEventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tax Event Timestamp' ;
    rdfs:comment 'The principal real-world timestamp when the taxable event occurred (e.g., point of sale, invoice issuance, payment settlement). Distinct from record audit timestamps. Determines the applicable tax period and rate under tax authority rules.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxJurisdictionLevel rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Level' ;
    rdfs:comment 'Hierarchical level of the tax jurisdiction at which the tax is levied. Supports multi-level tax stacking (e.g., federal + state + county + city sales tax in the US) and jurisdiction hierarchy reporting.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionName rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Name' ;
    rdfs:comment 'Human-readable name of the tax jurisdiction (e.g., \'California\', \'United Kingdom\', \'European Union VAT Area\'). Complements the jurisdiction code for reporting and business user readability.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Tax Period End Date' ;
    rdfs:comment 'End date of the tax reporting period to which this tax record belongs. Together with tax_period_start_date, defines the fiscal period boundary for tax filing and financial consolidation.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Tax Period Start Date' ;
    rdfs:comment 'Start date of the tax reporting period (month, quarter, or year) to which this tax record belongs. Determines the filing period for tax authority submissions and financial period-end close.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'The applicable tax rate expressed as a decimal fraction (e.g., 0.085000 for 8.5%). Sourced from SAP S/4HANA tax condition records for the applicable jurisdiction and tax type at the time of the taxable event.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Registration Number' ;
    rdfs:comment 'The company\'s tax registration or identification number with the relevant tax authority (e.g., VAT registration number, EIN, GST registration). Required for tax invoice compliance and regulatory filings. Confidential business identifier.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxTreatment rdf:type rdf:Property ;
    rdfs:label 'Tax Treatment' ;
    rdfs:comment 'The VAT/GST tax treatment applied to the transaction line, determining how the tax is calculated and reported. Drives tax return categorization and compliance with EU VAT Directive and OECD guidelines.' ;
    rdfs:domain ind:TaxRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'Classification of the tax obligation by tax regime type. Determines the applicable regulatory framework, filing requirements, and remittance rules. [ENUM-REF-CANDIDATE: VAT|GST|sales_tax|withholding_tax|customs_duty|excise_tax|use_tax|digital_services_tax — promote to reference product]' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableAmount rdf:type rdf:Property ;
    rdfs:label 'Taxable Amount' ;
    rdfs:comment 'The gross base amount subject to taxation before tax is applied, expressed in the transaction currency. Forms the basis for tax calculation: tax_amount = taxable_amount × tax_rate. Core component of the MONETARY_TRIPLET.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Classification of the underlying business transaction that generated the tax record. Determines the direction of tax flow (payable vs. receivable) and applicable reporting treatment.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumberMasked rdf:type rdf:Property ;
    rdfs:label 'Account Number Masked' ;
    rdfs:comment 'Masked representation of the bank account number showing only the last 4 digits (e.g., XXXXXXXX1234). Full account number is stored in a separate secrets vault per PCI DSS requirements. Used for display, reconciliation matching, and audit trail.' ;
    rdfs:domain ind:FinanceBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountPurpose rdf:type rdf:Property ;
    rdfs:label 'Account Purpose' ;
    rdfs:comment 'Free-text description of the specific business purpose of this account (e.g., \'Marketplace seller escrow disbursements - APAC region\', \'US payroll funding account\'). Provides operational context beyond the account_type classification.' ;
    rdfs:domain ind:FinanceBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankBranchAddress rdf:type rdf:Property ;
    rdfs:label 'Bank Branch Address' ;
    rdfs:comment 'Full street address of the bank branch. Used for payment instructions, correspondence, and regulatory filings. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:FinanceBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankBranchName rdf:type rdf:Property ;
    rdfs:label 'Bank Branch Name' ;
    rdfs:comment 'Name of the specific bank branch where the account is held (e.g., \'New York Midtown Branch\'). Used for correspondence, wire transfer instructions, and bank relationship management.' ;
    rdfs:domain ind:FinanceBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankContactEmail rdf:type rdf:Property ;
    rdfs:label 'Bank Contact Email' ;
    rdfs:comment 'Email address of the primary bank relationship manager or contact for this account. Used for electronic correspondence, statement delivery notifications, and escalation. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:FinanceBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankContactName rdf:type rdf:Property ;
    rdfs:label 'Bank Contact Name' ;
    rdfs:comment 'Name of the primary relationship manager or contact person at the bank for this account. Used for escalation, issue resolution, and bank relationship management.' ;
    rdfs:domain ind:FinanceBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankCountryCode rdf:type rdf:Property ;
    rdfs:label 'Bank Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the bank branch is domiciled (e.g., USA, GBR, DEU). Drives currency controls, regulatory reporting jurisdiction, and cross-border payment rules.' ;
    rdfs:domain ind:FinanceBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'Full legal name of the financial institution holding this account (e.g., JPMorgan Chase Bank, N.A.). Used for treasury reporting, bank relationship management, and counterparty risk assessment.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookBalance rdf:type rdf:Property ;
    rdfs:label 'Book Balance' ;
    rdfs:comment 'Internal GL book balance for this bank account as recorded in SAP S/4HANA general ledger, in the account\'s base currency. Compared against current_balance during bank reconciliation to identify timing differences and unrecorded items.' ;
    rdfs:domain ind:FinanceBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingDate rdf:type rdf:Property ;
    rdfs:label 'Closing Date' ;
    rdfs:comment 'Date on which the bank account was officially closed. Null for active accounts. Used for account lifecycle management, historical reporting, and SOX audit trail.' ;
    rdfs:domain ind:FinanceBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentBalance rdf:type rdf:Property ;
    rdfs:label 'Current Balance' ;
    rdfs:comment 'Most recent confirmed closing balance of the bank account as reported on the latest electronic bank statement, in the account\'s base currency. Used for daily cash position reporting and liquidity forecasting.' ;
    rdfs:domain ind:FinanceBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dualControlRequired rdf:type rdf:Property ;
    rdfs:label 'Dual Control Required' ;
    rdfs:comment 'Indicates whether this bank account requires dual authorization (two-person rule) for payment initiation per treasury policy and SOX segregation of duties controls. True: dual approval mandatory. False: single authorization permitted.' ;
    rdfs:domain ind:FinanceBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:houseBankCode rdf:type rdf:Property ;
    rdfs:label 'House Bank Code' ;
    rdfs:comment 'SAP S/4HANA house bank identifier that groups bank accounts under a single banking relationship. Used for payment program configuration, bank statement import, and electronic bank reconciliation in SAP FI-BL.' ;
    rdfs:domain ind:FinanceBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'International Bank Account Number (IBAN) assigned to this account per ISO 13616 standard. Used for cross-border payment instructions, SEPA transactions, and international treasury operations. Nullable for non-IBAN jurisdictions.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRate rdf:type rdf:Property ;
    rdfs:label 'Interest Rate' ;
    rdfs:comment 'Annual interest rate (as a decimal percentage, e.g., 0.0425 = 4.25%) applicable to this bank account for credit balances or overdraft facilities. Used in treasury yield analysis and cost-of-funds reporting.' ;
    rdfs:domain ind:FinanceBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPoolingHeader rdf:type rdf:Property ;
    rdfs:label 'Is Pooling Header' ;
    rdfs:comment 'Indicates whether this account serves as the header/master account in a cash concentration or notional pooling structure. True: this is the concentration account that receives sweeps from subsidiary accounts. False: standard account.' ;
    rdfs:domain ind:FinanceBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReconciledDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciled Date' ;
    rdfs:comment 'Date on which the most recent successful automated bank reconciliation was completed for this account in SAP S/4HANA. Used for cash position accuracy monitoring and SOX reconciliation controls.' ;
    rdfs:domain ind:FinanceBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastStatementDate rdf:type rdf:Property ;
    rdfs:label 'Last Statement Date' ;
    rdfs:comment 'Date of the most recently received and processed electronic bank statement (EBS) for this account. Used to monitor statement receipt timeliness and identify gaps in automated bank reconciliation.' ;
    rdfs:domain ind:FinanceBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openingDate rdf:type rdf:Property ;
    rdfs:label 'Opening Date' ;
    rdfs:comment 'Date on which the bank account was officially opened and activated by the financial institution. Used for account tenure analysis, regulatory reporting, and audit trail.' ;
    rdfs:domain ind:FinanceBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overdraftLimit rdf:type rdf:Property ;
    rdfs:label 'Overdraft Limit' ;
    rdfs:comment 'Maximum overdraft facility amount authorized by the bank for this account, in the account\'s base currency. Used in daily cash position reporting and liquidity forecasting to determine available credit headroom.' ;
    rdfs:domain ind:FinanceBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentLimit rdf:type rdf:Property ;
    rdfs:label 'Payment Limit' ;
    rdfs:comment 'Maximum amount in the account\'s base currency that can be authorized for a single payment transaction from this account without escalated approval. Enforces treasury payment controls and SOX segregation of duties.' ;
    rdfs:domain ind:FinanceBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethodCodes rdf:type rdf:Property ;
    rdfs:label 'Payment Method Codes' ;
    rdfs:comment 'Comma-separated list of SAP payment method codes authorized for use with this bank account (e.g., \'T,U,C\' for wire transfer, ACH, check). Controls which payment programs can use this account in SAP automatic payment runs.' ;
    rdfs:domain ind:FinanceBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Current reconciliation status of the bank account as of the last statement processing cycle. Reconciled: all items matched. Unreconciled: outstanding items exist. In_progress: reconciliation run is active. Exception: unresolvable discrepancies requiring manual review.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'ABA routing transit number (9-digit) identifying the US financial institution for domestic ACH and wire transfers. Used in payment processing and settlement runs. Applicable for US-domiciled accounts only.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryNames rdf:type rdf:Property ;
    rdfs:label 'Signatory Names' ;
    rdfs:comment 'Comma-separated list of names of individuals authorized to sign on this bank account per the bank mandate. Used for treasury governance, audit, and SOX segregation of duties controls.' ;
    rdfs:domain ind:FinanceBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Statement Delivery Method' ;
    rdfs:comment 'Method by which electronic bank statements are delivered from the bank to the ERP system. SWIFT: via SWIFT network. SFTP: secure file transfer. API: direct bank API integration. Email: email attachment. Manual: manual upload.' ;
    rdfs:domain ind:FinanceBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementFormat rdf:type rdf:Property ;
    rdfs:label 'Statement Format' ;
    rdfs:comment 'Format of the electronic bank statement (EBS) received from the bank for automated import into SAP S/4HANA. MT940: SWIFT legacy format. CAMT053: ISO 20022 XML format. BAI2: US cash management format. OFX: Open Financial Exchange. CSV: flat file.' ;
    rdfs:domain ind:FinanceBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftBic rdf:type rdf:Property ;
    rdfs:label 'Swift Bic' ;
    rdfs:comment 'SWIFT/BIC code identifying the bank and branch for international wire transfers and correspondent banking. Conforms to ISO 9362 standard. Required for cross-border payment routing in the Transportation Management System and ERP payment runs.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetBalance rdf:type rdf:Property ;
    rdfs:label 'Target Balance' ;
    rdfs:comment 'Desired minimum or target cash balance for this account as set by treasury policy. Used in cash concentration/sweeping rules and liquidity forecasting to trigger inter-account transfers.' ;
    rdfs:domain ind:FinanceBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentEntityLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Parent Entity Legal Entity Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediate parent legal entity in the corporate ownership hierarchy. Null for the ultimate holding company.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:accountingStandard rdf:type rdf:Property ;
    rdfs:label 'Accounting Standard' ;
    rdfs:comment 'Financial reporting standard under which this legal entity prepares its statutory financial statements (IFRS, US GAAP, or local GAAP). Determines accounting policies, disclosure requirements, and consolidation adjustments.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessActivityDescription rdf:type rdf:Property ;
    rdfs:label 'Business Activity Description' ;
    rdfs:comment 'Narrative description of the primary business activities conducted by this legal entity (e.g., marketplace operations, fulfillment services, technology platform, financial services). Used for regulatory filings and transfer pricing documentation.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationMethod rdf:type rdf:Property ;
    rdfs:label 'Consolidation Method' ;
    rdfs:comment 'Accounting method applied when consolidating this entity into the group financial statements. Drives intercompany elimination logic and ownership percentage calculations.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'Date on which the legal entity was formally dissolved, wound up, or deregistered with the relevant government authority. Null for active entities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date from which this legal entity record is considered active and valid for financial transactions, intercompany postings, and regulatory filings within the Ecommerce corporate group.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date on which this legal entity record ceases to be valid for new transactions. Null for currently active entities. Populated upon dissolution, merger, or deregistration.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entityName rdf:type rdf:Property ;
    rdfs:label 'Entity Name' ;
    rdfs:comment 'Full registered legal name of the entity as recorded with the relevant government or regulatory authority in the jurisdiction of incorporation.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityStatus rdf:type rdf:Property ;
    rdfs:label 'Entity Status' ;
    rdfs:comment 'Current lifecycle status of the legal entity. Drives inclusion or exclusion in consolidation runs, intercompany transaction eligibility, and regulatory filing requirements.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Classification of the legal entity by its structural role within the corporate group. [ENUM-REF-CANDIDATE: holding_company|operating_company|subsidiary|joint_venture|branch|partnership|special_purpose_vehicle|associate — promote to reference product]' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Functional Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the primary currency of the economic environment in which the entity operates. Used for local financial statement preparation and SAP S/4HANA company code currency assignment.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprApplicable rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicable' ;
    rdfs:comment 'Indicates whether this legal entity is subject to GDPR data privacy obligations, either as a data controller or data processor. True for entities operating in or processing data of EU residents.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incorporationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Incorporation Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the country in which the legal entity was incorporated or registered.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'Date on which the legal entity was formally incorporated or registered with the relevant government authority. Used for entity age calculations and regulatory filing timelines.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:industryClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Industry Classification Code' ;
    rdfs:comment 'Standard industry classification code (NAICS or SIC) assigned to this legal entity based on its primary business activity. Used for regulatory reporting, benchmarking, and transfer pricing comparability analysis.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyTradingPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Intercompany Trading Partner Code' ;
    rdfs:comment 'SAP S/4HANA trading partner code assigned to this legal entity for intercompany transaction identification and elimination during group consolidation. Enables automated intercompany reconciliation.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Specific legal jurisdiction (state, province, or territory) within the country of incorporation where the entity is registered. Relevant for sub-national regulatory compliance (e.g., Delaware, California, Ontario).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalForm rdf:type rdf:Property ;
    rdfs:label 'Legal Form' ;
    rdfs:comment 'Legal structure or form of the entity as defined by the jurisdiction of incorporation (e.g., LLC, PLC, GmbH, S.A., Pvt Ltd, Corp). Determines governance, liability, and reporting obligations.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leiCode rdf:type rdf:Property ;
    rdfs:label 'Lei Code' ;
    rdfs:comment '20-character alphanumeric Legal Entity Identifier (LEI) code assigned by a Local Operating Unit (LOU) accredited by the Global LEI Foundation (GLEIF). Used for regulatory reporting and counterparty identification in financial transactions.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Operating Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the primary country where the entity conducts its business operations. May differ from the country of incorporation for tax-optimized structures.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipPct rdf:type rdf:Property ;
    rdfs:label 'Ownership Pct' ;
    rdfs:comment 'Percentage of the legal entity owned by the immediate parent entity in the corporate hierarchy. Used to determine consolidation scope and minority interest calculations. Value between 0.00 and 100.00.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pciDssApplicable rdf:type rdf:Property ;
    rdfs:label 'Pci Dss Applicable' ;
    rdfs:comment 'Indicates whether this legal entity is subject to PCI DSS compliance requirements due to processing, storing, or transmitting payment card data. Drives scope of PCI DSS audit and certification.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registeredAddressCity rdf:type rdf:Property ;
    rdfs:label 'Registered Address City' ;
    rdfs:comment 'City of the official registered address of the legal entity. Used for regulatory filings, tax jurisdiction determination, and legal correspondence.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressCountryCode rdf:type rdf:Property ;
    rdfs:label 'Registered Address Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the country of the entity\'s registered address. May differ from the country of incorporation for branch offices.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line1' ;
    rdfs:comment 'First line of the official registered address of the legal entity as recorded with the government authority. Used for regulatory correspondence, tax filings, and legal notices.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressPostalCode rdf:type rdf:Property ;
    rdfs:label 'Registered Address Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the official registered address. Used for tax jurisdiction mapping, regulatory filings, and last-mile logistics planning for entity-level shipments.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Official company registration number assigned by the government authority in the jurisdiction of incorporation (e.g., Companies House number in the UK, EIN in the US).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrency rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code used for presenting the entity\'s financial statements in consolidated group reporting. Typically the group\'s presentation currency (e.g., USD for a US-listed parent).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionStandard rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Standard' ;
    rdfs:comment 'Accounting standard applied for revenue recognition by this legal entity. Determines how and when revenue from e-commerce transactions, marketplace fees, and fulfillment services is recognized.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxInScope rdf:type rdf:Property ;
    rdfs:label 'Sox In Scope' ;
    rdfs:comment 'Indicates whether this legal entity is within the scope of Sarbanes-Oxley (SOX) internal controls assessment and financial reporting requirements. True for entities that are material to the consolidated group\'s financial statements.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxIdNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Id Number' ;
    rdfs:comment 'Government-issued Tax Identification Number (TIN) or Employer Identification Number (EIN) used for tax filings, regulatory reporting, and financial settlements. Classified as restricted due to sensitivity of tax data.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'Value Added Tax (VAT) or Goods and Services Tax (GST) registration number issued by the tax authority in the entity\'s operating jurisdiction. Required for cross-border e-commerce tax compliance.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:votingRightsPct rdf:type rdf:Property ;
    rdfs:label 'Voting Rights Pct' ;
    rdfs:comment 'Percentage of voting rights held by the parent entity in this legal entity. May differ from ownership percentage in dual-class share structures. Determines control assessment under IFRS 10.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryCategoryId rdf:type rdf:Property ;
    rdfs:label 'Primary Category Id' ;
    rdfs:comment 'Foreign key linking to product.category. Business justification: Suppliers in e-commerce are onboarded and managed by primary product category specialization (electronics supplier, apparel supplier). Category managers use this to identify category-specialized suppl' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:bankAccountName rdf:type rdf:Property ;
    rdfs:label 'Bank Account Name' ;
    rdfs:comment 'Name of the bank account holder as registered for supplier payment remittance. Used in AP payment processing to validate beneficiary identity and prevent payment fraud. Subject to PCI DSS and SOX financial controls.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'Supplier\'s bank account number for payment remittance. Stored in encrypted/tokenized form per PCI DSS requirements. Used exclusively by the AP payment processing module in SAP S/4HANA for wire transfers and ACH payments.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankRoutingCode rdf:type rdf:Property ;
    rdfs:label 'Bank Routing Code' ;
    rdfs:comment 'Bank routing identifier for payment processing — either SWIFT/BIC code for international wire transfers or ABA routing number for US domestic ACH payments. Required for accurate payment routing in the AP settlement process.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'First line of the supplier\'s registered billing address. Used for invoice processing, payment remittance, and accounts payable (AP) in SAP S/4HANA. Required for PCI DSS-compliant payment processing and SOX financial controls.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City component of the supplier\'s registered billing address. Used in conjunction with billing_address_line1 for complete address resolution in AP payment processing and tax jurisdiction determination.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountry rdf:type rdf:Property ;
    rdfs:label 'Billing Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the supplier\'s billing address country. Drives tax jurisdiction rules, currency defaults, and cross-border trade compliance in the ERP procure-to-pay process.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the supplier\'s billing address. Used for tax jurisdiction mapping, carrier rate determination, and address validation in the procure-to-pay workflow.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Expiry date of the current master vendor agreement or supplier contract. Triggers contract renewal workflows and procurement alerts when approaching expiry. Nullable for open-ended evergreen contracts.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Effective start date of the current master vendor agreement or supplier contract. Defines the period during which negotiated pricing, payment terms, and SLAs are binding. Used in SAP S/4HANA outline agreements and procurement scheduling.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the country where the supplier is legally registered and primarily operates. Used for import/export compliance, tariff classification, and WTO trade regulation adherence.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpscCertificationExpiry rdf:type rdf:Property ;
    rdfs:label 'Cpsc Certification Expiry' ;
    rdfs:comment 'Expiry date of the supplier\'s CPSC product safety certification. Used to enforce product safety compliance gating in the Product Information Management System (PIM) catalog onboarding workflow.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cpscCompliant rdf:type rdf:Property ;
    rdfs:label 'Cpsc Compliant' ;
    rdfs:comment 'Indicates whether the supplier\'s products meet Consumer Product Safety Commission (CPSC) safety standards. Required for suppliers providing consumer goods sold on the e-commerce marketplace. Non-compliant suppliers are blocked from product catalog onboarding.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Default Lead Time Days' ;
    rdfs:comment 'Standard supplier lead time in calendar days from Purchase Order (PO) placement to goods receipt at the warehouse. Used as the default for inventory replenishment planning and MOQ calculations when no SKU-specific lead time is defined. Feeds into the WMS receiving schedule and ERP supply chain planning.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdprCompliant rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant' ;
    rdfs:comment 'Indicates whether the supplier has signed a Data Processing Agreement (DPA) and is confirmed GDPR compliant for handling EU personal data. Mandatory for suppliers processing customer data on behalf of the e-commerce platform under GDPR Article 28.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'International Commercial Terms (Incoterms 2020) code defining the division of costs, risks, and responsibilities between the buyer and supplier for goods delivery. Drives logistics cost allocation, insurance requirements, and customs documentation in the TMS and ERP. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDiversitySupplier rdf:type rdf:Property ;
    rdfs:label 'Is Diversity Supplier' ;
    rdfs:comment 'Indicates whether the supplier holds a recognized diversity certification (e.g., minority-owned, women-owned, veteran-owned, small business). Tracked for supplier diversity program reporting, ESG compliance, and government contract requirements.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPreferredVendor rdf:type rdf:Property ;
    rdfs:label 'Is Preferred Vendor' ;
    rdfs:comment 'Indicates whether this supplier is designated as a preferred vendor in the approved vendor list (AVL). Preferred vendors receive priority in automated PO sourcing and are eligible for blanket purchase agreements. Managed in SAP S/4HANA vendor evaluation.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoCertificationExpiry rdf:type rdf:Property ;
    rdfs:label 'Iso Certification Expiry' ;
    rdfs:comment 'Expiry date of the supplier\'s ISO certification. Procurement compliance workflows use this date to trigger re-certification reminders and to flag suppliers with lapsed certifications for suspension review.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isoCertified rdf:type rdf:Property ;
    rdfs:label 'Iso Certified' ;
    rdfs:comment 'Indicates whether the supplier holds a valid ISO certification (e.g., ISO 9001 Quality Management, ISO 27001 Information Security, ISO 14001 Environmental Management). Drives compliance gating in the supplier onboarding workflow.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full registered legal name of the supplier entity as recorded in official business registration documents. Used for contract execution, tax filings, and regulatory compliance. Must match the name on vendor contracts and invoices.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moq rdf:type rdf:Property ;
    rdfs:label 'Moq' ;
    rdfs:comment 'Minimum Order Quantity (MOQ) — the minimum number of units the supplier requires per purchase order line. Enforced during PO creation in the ERP to prevent under-minimum orders. Critical for inventory planning and procurement cost optimization.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date on which the supplier was formally approved and activated in the procurement system following completion of the onboarding workflow (KYC, compliance checks, contract execution). Marks the start of the active vendor relationship.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingStatus rdf:type rdf:Property ;
    rdfs:label 'Onboarding Status' ;
    rdfs:comment 'Current lifecycle state of the supplier in the procurement onboarding and vendor management workflow. Pending: application submitted. Under Review: compliance and due diligence in progress. Approved: cleared for procurement. Active: currently transacting. Suspended: temporarily blocked. Terminated: relationship ended.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentCurrency rdf:type rdf:Property ;
    rdfs:label 'Payment Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the supplier invoices and is paid (e.g., USD, EUR, GBP). Drives FX conversion in SAP S/4HANA AP and financial settlement. Essential for multi-currency procurement operations.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciDssCompliant rdf:type rdf:Property ;
    rdfs:label 'Pci Dss Compliant' ;
    rdfs:comment 'Indicates whether the supplier is currently PCI DSS compliant, relevant for suppliers handling payment card data or integrated into the payment processing ecosystem. Required for suppliers in the Payment Gateway and Processing Platform integration.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pciDssExpiry rdf:type rdf:Property ;
    rdfs:label 'Pci Dss Expiry' ;
    rdfs:comment 'Expiry date of the supplier\'s PCI DSS compliance certification. Annual re-assessment is required per PCI SSC standards. Used to trigger compliance renewal workflows and to block non-compliant suppliers from payment data integrations.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Business email address of the primary contact person at the supplier. Used for PO transmission, invoice correspondence, and procurement workflow notifications. Subject to GDPR legitimate interest basis for B2B processing.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary business contact person at the supplier organization. Used for procurement communications, PO acknowledgments, and relationship management. Not a personal consumer — represents a B2B contact.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Business phone number of the primary contact at the supplier organization. Used for urgent procurement escalations, delivery coordination, and supplier relationship management. Stored in E.164 international format.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactRole rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Role' ;
    rdfs:comment 'Business role or function of the primary contact person at the supplier. Determines routing of procurement communications (e.g., POs to account manager, invoices to finance contact, shipment queries to logistics coordinator).' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'Categorical risk classification derived from the supplier risk assessment process. Low: minimal supply chain risk. Medium: moderate risk requiring monitoring. High: significant risk requiring mitigation plans. Critical: immediate action required. Used to trigger procurement escalation workflows.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Composite risk assessment score for the supplier on a 0.00–100.00 scale, where higher values indicate greater risk. Incorporates financial stability, geopolitical exposure, compliance history, and delivery performance. Used by procurement to prioritize supplier audits and diversification strategies.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Code' ;
    rdfs:comment 'Externally-known alphanumeric code assigned to the supplier for cross-system identification. Used in Purchase Orders (POs), EDI transactions, and ERP integrations. Maps to the SAP S/4HANA vendor account number.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierTier rdf:type rdf:Property ;
    rdfs:label 'Supplier Tier' ;
    rdfs:comment 'Procurement tier classification indicating the strategic importance and relationship depth with the supplier. Strategic: top-tier partners with deep integration and long-term contracts. Preferred: vetted suppliers with negotiated terms. Approved: qualified suppliers on the approved vendor list. Transactional: one-off or spot-buy suppliers.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierType rdf:type rdf:Property ;
    rdfs:label 'Supplier Type' ;
    rdfs:comment 'Classification of the supplier by their role in the supply chain. Manufacturer: produces goods directly. Distributor: resells from manufacturers. Wholesaler: bulk reseller. 3PL (Third-Party Logistics): logistics provider. Dropshipper: ships directly to end customer. Marketplace Seller: sells via the e-commerce marketplace platform.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Government-issued tax identification number for the supplier, such as EIN (Employer Identification Number) in the US, VAT number in the EU, or GST number in other jurisdictions. Required for tax reporting, invoice validation, and SOX-compliant financial controls.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Operating or trade name (Doing Business As) of the supplier, which may differ from the legal name. Used in day-to-day procurement communications, catalog displays, and seller portal references.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Number' ;
    rdfs:comment 'VAT registration number for suppliers operating in VAT-applicable jurisdictions (primarily EU). Distinct from the general tax_id as it specifically governs VAT reclaim and cross-border EU trade compliance. Required for EU Electronic Commerce Directive compliance.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blanketPoPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Blanket Po Purchase Order Id' ;
    rdfs:comment 'Reference to the parent blanket purchase order when this PO is a release against an open blanket agreement. Enables aggregation of spend and quantity consumed against the blanket PO ceiling.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:buyerAccountId rdf:type rdf:Property ;
    rdfs:label 'Buyer Account Id' ;
    rdfs:comment 'Foreign key linking to customer.account. Business justification: Associates drop-ship or direct-to-customer purchase orders with the buying customer.account for fulfillment and revenue reporting.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:buyerContactId rdf:type rdf:Property ;
    rdfs:label 'Buyer Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: B2B e-commerce PO approval workflows and audit trails require knowing which buyer-side contact (procurement officer, category manager) raised or approved the purchase order. purchase_order has buyer_a' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:priceListId rdf:type rdf:Property ;
    rdfs:label 'Price List Id' ;
    rdfs:comment 'Foreign key linking to pricing.price_list. Business justification: Required for PO pricing reports: each purchase order is priced using a specific price list to compute expected cost and margin.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceList .

ind:promotionalCampaignId rdf:type rdf:Property ;
    rdfs:label 'Promotional Campaign Id' ;
    rdfs:comment 'Foreign key linking to pricing.promotional_campaign. Business justification: E-commerce procurement teams raise POs specifically to stock inventory for promotional campaigns (flash sales, seasonal events). Linking PO to promotional_campaign enables promotional inventory planni' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromotionalCampaign .

ind:warehouseNodeId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Node Id' ;
    rdfs:comment 'Reference to the destination warehouse or fulfillment center where goods are to be received. Drives WMS receiving workflow initiation, inventory allocation, and inbound logistics planning.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseNode .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'The date goods were physically received at the ship-to warehouse as recorded by the WMS goods receipt process. Used to calculate supplier on-time delivery performance and lead time actuals.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'The delivery date confirmed by the supplier upon order acknowledgement. Compared against requested_delivery_date to measure supplier on-time commitment accuracy and to trigger alerts for potential stockouts.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsReceiptStatus rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Status' ;
    rdfs:comment 'Current status of goods receipt against this purchase order as recorded in the WMS and SAP S/4HANA MIGO. Tracks whether no goods have been received, some lines/quantities are received, or all ordered quantities have been fully received.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'International Commercial Terms (Incoterms 2020) defining the transfer of risk, cost responsibility, and delivery obligations between buyer and supplier. Determines who bears freight, insurance, and customs costs. Critical for landed cost calculation and logistics planning. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'The named place or port associated with the Incoterms condition (e.g., \'FOB Shanghai\', \'DAP Los Angeles\'). Specifies the exact point of risk transfer and cost responsibility as required by ICC Incoterms 2020.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Status of supplier invoice matching against this purchase order in the SAP S/4HANA three-way match process (PO, goods receipt, invoice). Tracks whether invoices have been received, partially matched, fully matched, or are under dispute.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDropShip rdf:type rdf:Property ;
    rdfs:label 'Is Drop Ship' ;
    rdfs:comment 'Indicates whether this purchase order is a drop-ship arrangement where the supplier ships goods directly to the end customer rather than to a company warehouse. Triggers different fulfillment workflows in the OMS and WMS.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUrgent rdf:type rdf:Property ;
    rdfs:label 'Is Urgent' ;
    rdfs:comment 'Indicates whether this purchase order has been flagged as urgent, requiring expedited processing, prioritized supplier communication, and accelerated receiving. Typically set when inventory levels are critically low (OOS risk) or to fulfill a high-priority customer order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'Agreed or estimated number of calendar days from PO issuance to expected goods receipt at the destination warehouse. Used for inventory replenishment planning, safety stock calculations, and supplier performance benchmarking.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current state of the purchase order within the procure-to-pay lifecycle. Draft = created but not yet approved; Approved = internally authorized; Sent = transmitted to supplier; Acknowledged = supplier confirmed receipt; Partially_received = some line items received in WMS; Closed = fully received and matched; Cancelled = voided before completion. [ENUM-REF-CANDIDATE: draft|approved|sent|acknowledged|partially_received|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'The business date on which the purchase order was formally issued and transmitted to the supplier. Represents the principal real-world event time for this procurement transaction. Used as the baseline for lead time calculations and payment term due date computation.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Externally visible, human-readable purchase order number assigned by SAP S/4HANA ME21N at PO creation. Used in all supplier communications, EDI transactions, and receiving workflows. Globally unique within the enterprise.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order by procurement strategy. Standard = one-time discrete order; Blanket = open quantity/value agreement with releases; Consignment = supplier-owned stock held at warehouse; Drop-ship = supplier ships directly to customer; Service = non-goods procurement.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingGroup rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group' ;
    rdfs:comment 'SAP S/4HANA purchasing group code identifying the buyer team or commodity group responsible for this PO. Used for spend analytics, category management, and buyer performance reporting.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrg rdf:type rdf:Property ;
    rdfs:label 'Purchasing Org' ;
    rdfs:comment 'SAP S/4HANA purchasing organization code responsible for negotiating and issuing this purchase order. Determines the legal entity, currency, and terms applicable to the procurement transaction. Aligns with organizational hierarchy for spend reporting.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'The date by which the buyer requires the goods or services to be delivered to the ship-to location. Used for supplier SLA tracking, lead time analysis, and inventory replenishment planning. Distinct from the confirmed delivery date provided by the supplier.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'The purchase requisition number from SAP S/4HANA ME51N that originated this purchase order. Provides the audit trail from business need (requisition) to formal commitment (PO) for SOX compliance and spend authorization tracking.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sent Timestamp' ;
    rdfs:comment 'Timestamp when the purchase order was electronically transmitted to the supplier via EDI, email, or supplier portal. Marks the start of the supplier lead time clock and is used for SLA and communication audit purposes.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shipToAddress rdf:type rdf:Property ;
    rdfs:label 'Ship To Address' ;
    rdfs:comment 'Full delivery address for the purchase order, including street, city, state/province, postal code, and country. Used for carrier routing, customs documentation, and inbound logistics coordination. May differ from the warehouse address for drop-ship or direct-to-store orders.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Reference Number' ;
    rdfs:comment 'The supplier\'s own order confirmation or reference number provided upon acknowledgement of the purchase order. Used for cross-referencing in supplier communications, EDI transactions, and invoice matching.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLineCount rdf:type rdf:Property ;
    rdfs:label 'Total Line Count' ;
    rdfs:comment 'Total number of line items included in this purchase order. Used for PO complexity analysis, receiving workflow planning, and supplier performance metrics. Not a calculated aggregate — captured at PO creation from the source system.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:poLineItemId rdf:type rdf:Property ;
    rdfs:label 'Po Line Item Id' ;
    rdfs:comment 'Unique surrogate identifier for each purchase order line item record in the Silver Layer lakehouse. Serves as the primary key for this entity. Entity role: TRANSACTION_LINE.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoLineItem .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: E-commerce media buying and promotional material procurement raises PO line items against specific campaigns for granular cost allocation. Linking po_line_item to campaign enables campaign-level actua' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:priceListItemId rdf:type rdf:Property ;
    rdfs:label 'Price List Item Id' ;
    rdfs:comment 'Foreign key linking to pricing.price_list_item. Business justification: Needed for line-item cost analysis: each PO line item references the exact price-list item that supplied its unit price.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceListItem .

ind:skuId rdf:type rdf:Property ;
    rdfs:label 'Sku Id' ;
    rdfs:comment 'Reference to the product/material master record for the item being procured on this line. Links to the Product Information Management System for catalog enrichment and attribute management. Aligns with TRANSACTION_LINE role category: RESOURCE_REFERENCE.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:supplierPriceListId rdf:type rdf:Property ;
    rdfs:label 'Supplier Price List Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier_price_list. Business justification: A PO line item is priced based on the agreed supplier price list for that SKU. Linking po_line_item to supplier_price_list enables price variance analysis (po_line_item.price_variance_amount can be co' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierPriceList .

ind:warehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.warehouse_location. Business justification: PO line items specify a target storage location for putaway. storage_location_code is a denormalized reference to warehouse_location. Linking enables WMS-driven putaway routing and bin-level capacity ' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:accountAssignmentCategory rdf:type rdf:Property ;
    rdfs:label 'Account Assignment Category' ;
    rdfs:comment 'ERP account assignment category determining how the PO line item cost is posted in the general ledger (e.g., K=Cost Center, F=Order, P=Project, A=Asset, C=Sales Order, U=Unknown). Required for financial posting and SOX compliance.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLeadTimeVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Lead Time Variance Days' ;
    rdfs:comment 'Difference in calendar days between the confirmed delivery date and the actual delivery date for this line item. Positive value indicates late delivery; negative indicates early delivery. Key supplier on-time delivery (OTD) performance metric.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Percentage discount negotiated with the supplier for this line item, applied to the gross unit price to arrive at the net unit price. Supports procurement cost analysis and vendor contract compliance monitoring.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalDeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Final Delivery Flag' ;
    rdfs:comment 'Indicates whether the supplier has confirmed this as the final delivery for this PO line item, closing it against further goods receipts. True = final delivery confirmed; False = further deliveries expected. Used to close open PO lines.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptAmount rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Amount' ;
    rdfs:comment 'Total monetary value of goods received against this PO line (goods_receipt_quantity × unit_price). Used for inventory valuation, accrual accounting, and accounts payable liability recognition.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptBlockedFlag rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Blocked Flag' ;
    rdfs:comment 'Indicates whether goods receipt posting is blocked for this PO line item (e.g., due to quality inspection hold, price discrepancy, or compliance issue). True = GR blocked; False = GR allowed. Used in WMS receiving workflows.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptQuantity rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Quantity' ;
    rdfs:comment 'Total quantity of this line item received into the warehouse against this PO line. Populated from WMS goods receipt transactions. Used for partial fulfillment tracking, open quantity calculation, and 3-way invoice matching.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceVerificationFlag rdf:type rdf:Property ;
    rdfs:label 'Invoice Verification Flag' ;
    rdfs:comment 'Indicates whether invoice verification (3-way match: PO vs. GR vs. invoice) has been completed for this line item. True = verified; False = pending verification. Used for accounts payable processing and payment release.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoicedAmount rdf:type rdf:Property ;
    rdfs:label 'Invoiced Amount' ;
    rdfs:comment 'Total monetary value invoiced by the supplier for this PO line. Used for 3-way match variance analysis, accounts payable processing, and financial accrual reconciliation.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoicedQuantity rdf:type rdf:Property ;
    rdfs:label 'Invoiced Quantity' ;
    rdfs:comment 'Total quantity of this line item for which a supplier invoice has been received and matched. Used for 3-way match (PO quantity vs. GR quantity vs. invoice quantity), accounts payable processing, and payment settlement.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itemDescription rdf:type rdf:Property ;
    rdfs:label 'Item Description' ;
    rdfs:comment 'Short description of the product or material being procured on this line, as captured at the time of PO creation. May differ from the current PIM catalog description if the product was updated after PO issuance.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current workflow status of this purchase order line item. Tracks the lifecycle from open order through goods receipt, invoicing, and closure. Enables partial fulfillment monitoring and open PO reporting. [ENUM-REF-CANDIDATE: open|partially_received|fully_received|invoiced|closed|cancelled — promote to reference product if additional statuses are needed]' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Line Total Amount' ;
    rdfs:comment 'Total monetary value of this line item (ordered_quantity × unit_price). Used for PO value tracking, budget commitment, accounts payable accruals, and financial reporting. Aligns with TRANSACTION_LINE role category: LINE_VALUE_OR_RESULT.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moqComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Moq Compliance Flag' ;
    rdfs:comment 'Indicates whether the ordered quantity on this line meets or exceeds the supplier\'s Minimum Order Quantity (MOQ) requirement. True = MOQ compliant; False = below MOQ threshold. Critical for supplier contract compliance and procurement workflow validation.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openQuantity rdf:type rdf:Property ;
    rdfs:label 'Open Quantity' ;
    rdfs:comment 'Remaining quantity yet to be received against this PO line (ordered_quantity minus goods_receipt_quantity). Supports open PO reporting, inventory replenishment monitoring, and supplier follow-up workflows.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'Quantity of the SKU ordered on this line item as agreed with the supplier. Used for MOQ compliance validation, inventory replenishment planning, and partial fulfillment tracking. Aligns with TRANSACTION_LINE role category: LINE_QUANTITY.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'ERP plant or fulfillment center code to which this PO line item is being delivered. Identifies the receiving warehouse or distribution center in the fulfillment network. Used for inventory planning and logistics routing.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Price Variance Amount' ;
    rdfs:comment 'Monetary difference between the PO agreed unit price and the actual invoiced price for this line item. A key procurement KPI used for cost control, supplier negotiation analysis, and financial reporting under SOX.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason a PO line item was rejected, cancelled, or blocked (e.g., quality failure, price discrepancy, supplier non-compliance). Used for procurement analytics and supplier performance management.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Identifier of the operational source system from which this PO line item record was ingested (e.g., SAP_S4HANA_PROD, ERP_EU, ERP_US). Supports data lineage tracking, multi-system reconciliation, and Silver Layer provenance.' ;
    rdfs:domain ind:PoLineItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Standard unit of measure for the ordered quantity on this line (e.g., EA=Each, CS=Case, PK=Pack, KG=Kilogram, PAL=Pallet). Sourced from the ERP material master and used for WMS receiving and inventory allocation. [ENUM-REF-CANDIDATE: EA|CS|PK|KG|LB|L|M|M2|M3|PAL|BOX|ROLL|SET|DOZ — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Negotiated unit price for the SKU as agreed with the supplier on this PO line. Used for line total calculation, invoice matching (3-way match), and procurement cost analysis. Expressed in the PO currency.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approverAgentId rdf:type rdf:Property ;
    rdfs:label 'Approver Agent Id' ;
    rdfs:comment 'Reference to the employee who provided final authorization and approval for this contract or its most recent amendment. Supports SOX audit trail requirements for procurement authorization controls.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:categoryId rdf:type rdf:Property ;
    rdfs:label 'Category Id' ;
    rdfs:comment 'Foreign key linking to product.category. Business justification: Vendor contracts in e-commerce procurement are scoped to product categories (e.g., electronics, apparel). Category managers need to identify active contracts governing their category for sourcing deci' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:marketplaceId rdf:type rdf:Property ;
    rdfs:label 'Marketplace Id' ;
    rdfs:comment 'Foreign key linking to marketplace.marketplace. Business justification: In multi-marketplace e-commerce platforms, vendor contracts are scoped to a specific marketplace (e.g., supplier contracted for US marketplace but not EU). This FK enables marketplace-specific contrac' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Marketplace .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Total number of formal amendments (change orders) that have been executed against this contract since its original execution. Provides a quick indicator of contract stability and negotiation history. Incremented each time a change order is approved.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the contract is configured to automatically renew upon reaching its expiry date without requiring a new negotiation cycle. True = auto-renews; False = requires explicit renewal action. Critical for contract lifecycle management and budget planning.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Data classification level assigned to this contract document indicating the sensitivity of its commercial terms and conditions. Restricted: highly sensitive strategic terms. Confidential: standard commercial terms not for external disclosure. Internal: accessible to all internal staff. Public: terms disclosed publicly (rare for vendor contracts).' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known, human-readable unique identifier for the vendor contract as assigned by the procurement or ERP system (e.g., SAP scheduling agreement or outline agreement number). Used in all vendor communications, purchase orders, and audit trails.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle state of the vendor contract governing its operational validity. Draft: under internal review and not yet binding. Active: fully executed and in force. Amended: modified via change order but still active. Suspended: temporarily halted pending resolution. Expired: reached end date without renewal. Terminated: ended before expiry by either party.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractTitle rdf:type rdf:Property ;
    rdfs:label 'Contract Title' ;
    rdfs:comment 'Descriptive human-readable title or short name of the vendor contract (e.g., \'Annual Packaging Materials Supply Agreement FY2025\'). Used for display in procurement dashboards and contract registers.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the procurement contract by commercial structure. Framework agreements establish terms for future orders; blanket purchase orders cover recurring purchases up to a ceiling value; spot contracts are one-time buys; consignment contracts allow inventory held at buyer premises billed on consumption; scheduled agreements define delivery schedules. [ENUM-REF-CANDIDATE: framework|blanket|spot|consignment|scheduled — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocationCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Code' ;
    rdfs:comment 'Code identifying the designated delivery destination (warehouse, fulfillment center, or plant) where the vendor must deliver goods under this contract. Maps to the WMS facility or SAP S/4HANA plant/storage location.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'The contractually agreed mechanism for resolving commercial disputes between the buyer and vendor (e.g., binding arbitration, mediation, or court litigation). Determines the legal process to follow in case of contract breach or disagreement.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The date on which the vendor contract becomes legally binding and commercially effective. Marks the start of the contract period for SLA enforcement, payment terms, and procurement eligibility.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether this contract grants the vendor exclusive supply rights for the specified goods or services category, preventing the buyer from sourcing from competing vendors during the contract term. True = exclusive; False = non-exclusive.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityScope rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Scope' ;
    rdfs:comment 'Free-text description of the scope of exclusivity when the exclusivity flag is True. Defines the product categories, geographic regions, or channels covered by the exclusive arrangement (e.g., \'Exclusive supplier of private-label packaging materials for APAC fulfillment centers\').' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'The date on which the vendor contract is scheduled to expire and cease to be binding, unless renewed or extended. Nullable for open-ended evergreen contracts. Used to trigger renewal workflows and compliance alerts.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprDpaFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Dpa Flag' ;
    rdfs:comment 'Indicates whether a GDPR-compliant Data Processing Agreement (DPA) has been executed with this vendor, required when the vendor processes personal data on behalf of the company. True = DPA in place; False = DPA not required or not yet executed. Mandatory for GDPR Article 28 compliance.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingLawCountry rdf:type rdf:Property ;
    rdfs:label 'Governing Law Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code identifying the jurisdiction whose laws govern the interpretation and enforcement of this contract (e.g., USA, GBR, DEU). Critical for cross-border procurement and dispute resolution.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'The date on which the most recent formal amendment or change order to this contract was executed and became effective. Null for contracts that have never been amended. Used to track contract evolution and trigger re-approval workflows.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastAmendmentReason rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Reason' ;
    rdfs:comment 'Free-text description of the business reason for the most recent contract amendment (e.g., \'Price adjustment due to raw material cost increase Q3 2025\', \'Extended term by 12 months following supplier performance review\'). Supports audit trail and change management documentation.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderQty rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Qty' ;
    rdfs:comment 'The minimum quantity per purchase order that the vendor requires under this contract, as negotiated in the commercial terms. MOQ is a standard e-commerce and supply chain procurement metric used for inventory planning and replenishment decisions.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moqUnit rdf:type rdf:Property ;
    rdfs:label 'Moq Unit' ;
    rdfs:comment 'Unit of measure applicable to the minimum order quantity (e.g., EA for each, CS for case, KG for kilogram, PAL for pallet). Follows ISO 80000 / UN/CEFACT unit codes as used in SAP S/4HANA.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndaFlag rdf:type rdf:Property ;
    rdfs:label 'Nda Flag' ;
    rdfs:comment 'Indicates whether a Non-Disclosure Agreement (NDA) is in place with this vendor as part of or alongside this contract. True = NDA executed; False = no NDA. Relevant for IP protection, proprietary pricing, and technology sharing arrangements.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyCapAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Cap Amount' ;
    rdfs:comment 'The maximum cumulative financial penalty amount (in contract currency) that can be levied against the vendor under this contract over its full term. Caps total liability exposure for both parties. Null when no penalty cap is defined.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Flag' ;
    rdfs:comment 'Indicates whether this contract contains financial penalty clauses for SLA breaches, late delivery, or quality failures. True = penalty clauses exist; False = no financial penalties defined. Drives penalty calculation workflows in accounts payable.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyRatePct rdf:type rdf:Property ;
    rdfs:label 'Penalty Rate Pct' ;
    rdfs:comment 'The contractually defined financial penalty rate expressed as a percentage of the affected order value or invoice amount, applied when the vendor breaches SLA commitments. Null when penalty_clause_flag is False.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of calendar days before the contract expiry date by which either party must provide written notice of intent to renew or terminate. Used to trigger automated procurement alerts and prevent unintended auto-renewals.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'The date on which the contract was formally executed (signed) by all authorized parties. May differ from the effective date when contracts are backdated or post-dated. Critical for legal enforceability and audit.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaDefectRatePct rdf:type rdf:Property ;
    rdfs:label 'Sla Defect Rate Pct' ;
    rdfs:comment 'Contractually agreed maximum acceptable defect/rejection rate (as a percentage) for goods delivered under this contract. Exceeding this threshold constitutes an SLA breach and may trigger return merchandise authorization (RMA) processes and financial penalties.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaFillRatePct rdf:type rdf:Property ;
    rdfs:label 'Sla Fill Rate Pct' ;
    rdfs:comment 'Contractually committed minimum order fill rate (as a percentage) representing the proportion of ordered quantity that the vendor must fulfill completely per shipment. A fill rate below this threshold triggers SLA breach notifications and potential penalties.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaOnTimeDeliveryPct rdf:type rdf:Property ;
    rdfs:label 'Sla On Time Delivery Pct' ;
    rdfs:comment 'Contractually committed minimum on-time delivery rate (as a percentage) that the vendor must achieve. Measured as the percentage of purchase orders delivered on or before the agreed delivery date. Used for vendor performance scorecards and penalty clause triggers.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'The actual date on which the contract was terminated early, if applicable. Null for contracts that expired naturally or are still active. Distinct from expiry_date which is the scheduled end; this captures unplanned or negotiated early termination.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Coded reason for early contract termination. Mutual agreement: both parties agreed to end early. Vendor breach: vendor failed to meet contractual obligations. Buyer breach: buyer defaulted. Force majeure: unforeseeable external event. Regulatory: compliance or legal requirement. Convenience: buyer exercised termination for convenience clause.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalContractValue rdf:type rdf:Property ;
    rdfs:label 'Total Contract Value' ;
    rdfs:comment 'The total maximum committed monetary value of the vendor contract over its full term, expressed in the contract currency. For blanket/framework agreements this is the ceiling value; for spot contracts it is the fixed order value. Used for spend analytics, budget commitment tracking, and SOX financial controls.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Unique surrogate identifier for the goods receipt record in the procurement domain. Primary key for this transactional entity. Entity Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'Foreign key linking to logistics.carrier. Business justification: In e-commerce warehouse receiving, the carrier delivering supplier goods must be formally tracked for carrier performance scoring, freight claims, SLA compliance reporting, and dock scheduling. The ex' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:stockPositionId rdf:type rdf:Property ;
    rdfs:label 'Stock Position Id' ;
    rdfs:comment 'Foreign key linking to inventory.stock_position. Business justification: Goods receipt directly updates a specific stock position (SKU+warehouse+lot). Inventory receiving workflow and on-hand quantity reconciliation require tracing which stock_position was incremented by e' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StockPosition .

ind:actualArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Date' ;
    rdfs:comment 'Date the shipment physically arrived at the destination warehouse dock. Compared against estimated arrival date to calculate supplier on-time delivery performance (OTD KPI).' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:asnNumber rdf:type rdf:Property ;
    rdfs:label 'Asn Number' ;
    rdfs:comment 'Advance Shipment Notice number provided by the supplier prior to dispatch. Used to pre-receive inventory in WMS, schedule dock appointments, and validate shipment contents against the PO. Format: ASN- followed by 10 digits.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchLotNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Lot Number' ;
    rdfs:comment 'Supplier-assigned batch or lot number for the received goods. Critical for traceability, recall management, FIFO inventory management, and quality inspection correlation. Mandatory for perishable, regulated, or serialized products.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsDeclarationNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Number' ;
    rdfs:comment 'Customs entry or import declaration number assigned by customs authorities for cross-border shipments. Required for import duty reconciliation, trade compliance audit, and WTO regulatory reporting.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'Supplier-issued delivery note or packing slip number accompanying the physical shipment. Used for receiving verification, three-way match, and dispute resolution with the supplier.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyQuantity rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Quantity' ;
    rdfs:comment 'Net difference between quantity shipped (per ASN) and quantity received (physically counted). Positive value indicates shortage; negative value indicates overage. Used for supplier dispute resolution and accounts payable adjustment.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Date' ;
    rdfs:comment 'Expected date of shipment arrival at the destination warehouse as communicated by the supplier or carrier via ASN. Used for dock scheduling, labor planning, and lead time performance measurement.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightCost rdf:type rdf:Property ;
    rdfs:label 'Freight Cost' ;
    rdfs:comment 'Total freight cost associated with the inbound shipment as invoiced by the carrier or allocated from the purchase order freight terms. Used for landed cost calculation, freight accrual in accounts payable, and procurement cost analysis.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the freight cost is denominated (e.g., USD, EUR, GBP). Required for multi-currency freight reconciliation and FX conversion in SAP S/4HANA.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grNotes rdf:type rdf:Property ;
    rdfs:label 'Gr Notes' ;
    rdfs:comment 'Free-text notes recorded by the warehouse receiving team during the goods receipt process. Captures observations about shipment condition, packaging damage, partial delivery reasons, or special handling instructions not captured in structured fields.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grNumber rdf:type rdf:Property ;
    rdfs:label 'Gr Number' ;
    rdfs:comment 'Externally-known business identifier for the goods receipt document, used in supplier communications, three-way match, and ERP posting. Corresponds to the Material Document number in SAP S/4HANA MM (MIGO). Format: GR- followed by 10 digits.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gr Posting Date' ;
    rdfs:comment 'Accounting date on which the goods receipt is posted to the general ledger in SAP S/4HANA. Determines the financial period for inventory valuation and accounts payable accrual. Critical for period-end close and SOX compliance.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grPostingStatus rdf:type rdf:Property ;
    rdfs:label 'Gr Posting Status' ;
    rdfs:comment 'ERP posting status of the goods receipt document in SAP S/4HANA. Indicates whether the GR has been financially posted to the general ledger, is pending, has been reversed, or is blocked pending quality inspection clearance. Triggers three-way match in accounts payable upon \'posted\' status.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHazardousMaterial rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous Material' ;
    rdfs:comment 'Indicates whether the received goods are classified as hazardous materials (HazMat) requiring special handling, storage, and transportation compliance. Triggers HazMat receiving protocols in WMS and regulatory reporting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOverDelivery rdf:type rdf:Property ;
    rdfs:label 'Is Over Delivery' ;
    rdfs:comment 'Indicates whether the quantity received exceeds the quantity ordered on the purchase order, beyond the configured over-delivery tolerance. Triggers procurement workflow for approval or return-to-supplier action.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnderDelivery rdf:type rdf:Property ;
    rdfs:label 'Is Under Delivery' ;
    rdfs:comment 'Indicates whether the quantity received falls below the quantity ordered on the purchase order, beyond the configured under-delivery tolerance. May trigger a follow-up delivery or partial invoice processing in accounts payable.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originCountryCode rdf:type rdf:Property ;
    rdfs:label 'Origin Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the shipment origin. Required for customs declarations, import duty calculations, and trade compliance reporting under WTO regulations.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originLocation rdf:type rdf:Property ;
    rdfs:label 'Origin Location' ;
    rdfs:comment 'Supplier dispatch location or origin facility from which the shipment was sent. May be a supplier warehouse address, factory location, or 3PL origin hub. Used for logistics planning, lead time analysis, and customs documentation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Status of the quality inspection performed upon receipt of goods. Determines whether inventory can be released to available stock in WMS. \'conditionally_accepted\' indicates partial acceptance with documented deviations. [ENUM-REF-CANDIDATE: not_required|pending|in_progress|passed|failed|conditionally_accepted — promote to reference product]' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'Quantity of the SKU originally ordered on the purchase order line. Baseline for over/under delivery calculation and three-way match validation in accounts payable.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityReceived rdf:type rdf:Property ;
    rdfs:label 'Quantity Received' ;
    rdfs:comment 'Actual quantity of the SKU physically counted and accepted at the destination warehouse during the receiving process. Posted to WMS inventory and used for GR document creation in SAP S/4HANA.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRejected rdf:type rdf:Property ;
    rdfs:label 'Quantity Rejected' ;
    rdfs:comment 'Quantity of the SKU rejected during quality inspection due to damage, non-conformance, or specification failure. Drives Return Merchandise Authorization (RMA) creation and supplier debit note processing.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityShipped rdf:type rdf:Property ;
    rdfs:label 'Quantity Shipped' ;
    rdfs:comment 'Quantity of the SKU declared by the supplier on the Advance Shipment Notice (ASN) as dispatched. Used to identify pre-receipt discrepancies between ordered and shipped quantities.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingCompleteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receiving Complete Timestamp' ;
    rdfs:comment 'Date and time when the physical receiving process was completed and the GR document was confirmed in WMS. Used to calculate dock-to-stock cycle time and warehouse throughput metrics.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receivingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receiving Start Timestamp' ;
    rdfs:comment 'Date and time when the physical receiving process was initiated at the warehouse dock. Used to measure receiving cycle time, dock-to-stock time KPI, and WMS labor productivity.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle state of the inbound shipment from supplier dispatch through GR completion. Drives operational workflows in WMS and TMS. Values: in_transit (carrier has picked up), arrived (at dock), receiving_in_progress (WMS receiving active), completed (GR posted), exception (discrepancy or damage identified).' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierInvoiceReference rdf:type rdf:Property ;
    rdfs:label 'Supplier Invoice Reference' ;
    rdfs:comment 'Supplier-provided invoice number associated with this goods receipt, used to link the GR to the corresponding accounts payable invoice for three-way match processing and payment settlement.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Carrier-assigned tracking number for the inbound shipment. Used to monitor shipment progress in TMS and correlate with carrier proof-of-delivery documentation.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountReference rdf:type rdf:Property ;
    rdfs:label 'Bank Account Reference' ;
    rdfs:comment 'Masked or tokenized reference to the supplier\'s bank account designated for payment of this invoice. Stored as a reference token rather than raw account number to comply with PCI DSS. Full banking details are maintained in the secure vendor master.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyAmount rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Amount' ;
    rdfs:comment 'Monetary value of the discrepancy between the invoiced amount and the expected amount based on PO and GR. Quantifies the financial exposure of the mismatch for prioritization of resolution and escalation decisions.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discrepancyReason rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Reason' ;
    rdfs:comment 'Free-text description of the specific discrepancy identified during three-way match validation or manual review. Provides context for resolution workflow, supplier dispute management, and audit trail. Populated when three_way_match_status is FAILED or PARTIAL_MATCH.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyType rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Type' ;
    rdfs:comment 'Classification of the discrepancy identified during three-way match validation. PRICE_VARIANCE: invoiced unit price differs from PO price beyond tolerance; QUANTITY_VARIANCE: invoiced quantity exceeds GR quantity; MISSING_GR: no goods receipt found; DUPLICATE_INVOICE: invoice number already processed; INCORRECT_PO: PO reference invalid or mismatched; TAX_MISMATCH: tax amount inconsistency.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'Gross invoice amount converted to the company\'s functional (local) currency using the exchange_rate at posting time. Used for GL posting, financial reporting, and SOX-compliant AP ledger entries in the finance domain.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceCategory rdf:type rdf:Property ;
    rdfs:label 'Invoice Category' ;
    rdfs:comment 'Business category of the goods or services being invoiced. GOODS: physical merchandise; SERVICES: professional or managed services; FREIGHT: logistics and shipping charges; UTILITIES: energy, water, telecom; CAPEX: capital expenditure items; INTERCOMPANY: invoices between related entities. Used for spend analytics and GL account determination.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlockFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Block Flag' ;
    rdfs:comment 'Indicates whether the invoice has been blocked from payment processing. True when a payment block is active due to discrepancy, pending approval, compliance hold, or manual block. Maps to SAP S/4HANA payment block indicator (ZLSPR) on the AP document. Finance domain uses this flag to exclude the invoice from payment run.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'The date by which payment must be made to the supplier to comply with agreed payment terms and avoid late payment penalties. Derived from invoice date and supplier payment terms but stored explicitly for operational payment scheduling and cash flow planning.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'The date the invoice was physically or electronically received by the procurement team. Used to calculate payment due dates based on payment terms and to measure invoice processing cycle time. Maps to MIRO BUDAT (posting date) in SAP S/4HANA.' ;
    rdfs:domain ind:SupplierInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Free-text explanation provided by the approver when the invoice is rejected. Used for supplier communication, dispute resolution, and process improvement analytics. Populated only when approval_status is REJECTED.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Supplier Performance Id' ;
    rdfs:comment 'Unique surrogate identifier for each supplier performance scorecard record. Primary key for the supplier_performance data product in the procurement domain.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:avgActualLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Avg Actual Lead Time Days' ;
    rdfs:comment 'Average number of calendar days between purchase order placement and goods receipt for all POs evaluated during the period. Compared against contracted lead time to compute lead_time_adherence_rate and inform replenishment planning.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractRenewalRecommendation rdf:type rdf:Property ;
    rdfs:label 'Contract Renewal Recommendation' ;
    rdfs:comment 'Procurement team\'s formal recommendation for the supplier\'s contract renewal based on this evaluation period\'s performance scorecard. Drives contract lifecycle management decisions in SAP S/4HANA. Classified as confidential due to commercial sensitivity.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Contracted Lead Time Days' ;
    rdfs:comment 'The agreed-upon lead time in calendar days as specified in the supplier\'s active vendor contract or purchase agreement. Serves as the benchmark for lead_time_adherence_rate calculation and SLA compliance assessment.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctiveActionCount rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Count' ;
    rdfs:comment 'Number of formal corrective action requests (CARs) issued to the supplier during the evaluation period due to quality, delivery, or compliance failures. High counts indicate systemic supplier issues requiring escalation or probation review.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:criticalSlaBreachCount rdf:type rdf:Property ;
    rdfs:label 'Critical Sla Breach Count' ;
    rdfs:comment 'Number of high-severity SLA breaches that caused material business impact (e.g., stockouts, production stoppages, customer order cancellations) during the evaluation period. Subset of sla_breach_count; used for escalation and probation decisions.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Identifies the operational system of record from which the KPI data for this scorecard was primarily sourced. SAP_S4HANA for ERP-driven metrics; WMS for warehouse receiving data; TMS for delivery performance; SELLER_PORTAL for supplier self-reported data; MANUAL for procurement team input.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectRateDppm rdf:type rdf:Property ;
    rdfs:label 'Defect Rate Dppm' ;
    rdfs:comment 'Number of defective units received per one million units delivered by the supplier during the evaluation period. Industry-standard quality metric (DPPM - Defective Parts Per Million) used to assess product quality compliance and drive supplier quality improvement programs.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:developmentProgramEnrolledFlag rdf:type rdf:Property ;
    rdfs:label 'Development Program Enrolled Flag' ;
    rdfs:comment 'Indicates whether the supplier has been enrolled in a formal supplier development program as a result of this evaluation period\'s performance. Typically triggered by bronze tier or probation classification.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeCount rdf:type rdf:Property ;
    rdfs:label 'Dispute Count' ;
    rdfs:comment 'Number of formal disputes raised by either Ecommerce or the supplier regarding PO terms, invoice discrepancies, or delivery claims during the evaluation period. Sourced from SAP S/4HANA dispute management module.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentationComplianceRate rdf:type rdf:Property ;
    rdfs:label 'Documentation Compliance Rate' ;
    rdfs:comment 'Percentage of shipments accompanied by complete and accurate documentation (packing lists, certificates of conformance, customs documents, safety data sheets) as required by contract and regulatory standards during the evaluation period.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationNotes rdf:type rdf:Property ;
    rdfs:label 'Evaluation Notes' ;
    rdfs:comment 'Free-text field for the procurement evaluator to capture qualitative observations, context, or exceptions that are not reflected in the quantitative KPI scores (e.g., force majeure events, supply chain disruptions, extraordinary performance).' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'The last calendar date of the performance evaluation window. Paired with evaluation_period_start_date to define the full measurement interval for all KPIs.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'The first calendar date of the performance evaluation window. Used to define the measurement boundary for all KPIs captured in this scorecard.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodType rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Type' ;
    rdfs:comment 'Granularity of the performance evaluation cycle: monthly for operational monitoring, quarterly for strategic reviews, and annual for contract renewal decisions.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillRate rdf:type rdf:Property ;
    rdfs:label 'Fill Rate' ;
    rdfs:comment 'Percentage of ordered quantity actually fulfilled and shipped by the supplier during the evaluation period. Calculated as (units shipped / units ordered) × 100. Measures supplier\'s ability to meet demand without shortfalls, critical for inventory replenishment planning.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceAccuracyRate rdf:type rdf:Property ;
    rdfs:label 'Invoice Accuracy Rate' ;
    rdfs:comment 'Percentage of supplier invoices that matched the corresponding purchase order without discrepancies (price, quantity, or terms) during the evaluation period. Calculated as (accurate invoices / total invoices) × 100. Impacts accounts payable efficiency and procure-to-pay cycle time in SAP S/4HANA.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadTimeAdherenceRate rdf:type rdf:Property ;
    rdfs:label 'Lead Time Adherence Rate' ;
    rdfs:comment 'Percentage of purchase orders where the supplier\'s actual lead time met or was within the contracted lead time during the evaluation period. Calculated as (orders within lead time / total orders) × 100. Critical for inventory replenishment planning and MOQ (Minimum Order Quantity) management.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moqComplianceRate rdf:type rdf:Property ;
    rdfs:label 'Moq Compliance Rate' ;
    rdfs:comment 'Percentage of purchase orders where the supplier honored the contracted MOQ (Minimum Order Quantity) terms during the evaluation period. Non-compliance may indicate supply constraints or contract violations requiring procurement intervention.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTimeDeliveryRate rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate' ;
    rdfs:comment 'Percentage of purchase orders delivered by the supplier on or before the confirmed delivery date during the evaluation period. Calculated as (on-time deliveries / total deliveries) × 100. Key operational KPI for SLA compliance monitoring.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openCorrectiveActionCount rdf:type rdf:Property ;
    rdfs:label 'Open Corrective Action Count' ;
    rdfs:comment 'Number of corrective action requests (CARs) issued to the supplier that remain unresolved as of the scorecard evaluation date. Unresolved CARs beyond SLA timelines may trigger escalation to probation tier.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Overall Performance Score' ;
    rdfs:comment 'Composite weighted performance score (0–100) aggregating all KPI dimensions (on-time delivery, fill rate, defect rate, invoice accuracy, lead time adherence, return rate, SLA compliance, NPS) per the procurement scoring model. Primary driver for performance tier classification and contract renewal decisions.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'Classified performance tier assigned to the supplier based on the weighted overall performance score for the evaluation period. Gold = top-tier preferred supplier; Silver = satisfactory; Bronze = needs improvement; Probation = at risk of contract termination. Drives supplier development programs and contract renewal decisions.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousPerformanceTier rdf:type rdf:Property ;
    rdfs:label 'Previous Performance Tier' ;
    rdfs:comment 'The supplier\'s performance tier from the immediately preceding evaluation period. Used to detect tier reclassification events and trigger automated supplier development workflows.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementCostVariancePct rdf:type rdf:Property ;
    rdfs:label 'Procurement Cost Variance Pct' ;
    rdfs:comment 'Percentage variance between the contracted unit price and the actual invoiced price across all POs in the evaluation period. Positive value indicates supplier overcharged vs. contract; negative indicates undercharge. Flags pricing compliance issues for AP reconciliation in SAP S/4HANA.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementNpsScore rdf:type rdf:Property ;
    rdfs:label 'Procurement Nps Score' ;
    rdfs:comment 'Net Promoter Score (NPS) provided by the internal procurement team rating the supplier\'s responsiveness, communication quality, and overall partnership experience during the evaluation period. Scale: -100 to +100. Captures qualitative relationship health not reflected in operational KPIs.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnRate rdf:type rdf:Property ;
    rdfs:label 'Return Rate' ;
    rdfs:comment 'Percentage of received units returned to the supplier due to defects, non-conformance, or incorrect shipments during the evaluation period. Calculated as (units returned / units received) × 100. Feeds into RMA (Return Merchandise Authorization) processing and supplier quality programs.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scorecardPublishedDate rdf:type rdf:Property ;
    rdfs:label 'Scorecard Published Date' ;
    rdfs:comment 'The date on which the finalized supplier performance scorecard was formally published and shared with the supplier. Marks the start of the supplier\'s response and dispute window.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scorecardReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Scorecard Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this supplier performance scorecard record, used in procurement communications, supplier development meetings, and audit trails. Format: SPC-YYYY-MM-SUPPID.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardStatus rdf:type rdf:Property ;
    rdfs:label 'Scorecard Status' ;
    rdfs:comment 'Current lifecycle state of the supplier performance scorecard. Draft indicates data collection in progress; pending_review awaits procurement manager sign-off; approved is finalized; published is shared with supplier; disputed is under supplier challenge; closed is archived.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachCount rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Count' ;
    rdfs:comment 'Total number of SLA (Service Level Agreement) violations recorded against the supplier during the evaluation period. Includes delivery, quality, and communication SLA breaches as defined in the vendor contract. Triggers penalty clauses and escalation workflows.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierAcknowledgedFlag rdf:type rdf:Property ;
    rdfs:label 'Supplier Acknowledged Flag' ;
    rdfs:comment 'Indicates whether the supplier has formally acknowledged receipt and review of the published performance scorecard via the Seller Management Portal. Required for audit trail and dispute resolution process initiation.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Supplier Acknowledgement Date' ;
    rdfs:comment 'The date on which the supplier formally acknowledged the performance scorecard in the Seller Management Portal. Null if supplier_acknowledged_flag is False. Used to track response timeliness.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sustainabilityComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Sustainability Compliance Score' ;
    rdfs:comment 'Score (0–100) reflecting the supplier\'s adherence to environmental, social, and governance (ESG) standards and Ecommerce\'s supplier code of conduct during the evaluation period. Assessed via audits, certifications, and self-reported data. Increasingly required for regulatory and investor reporting.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierReclassificationFlag rdf:type rdf:Property ;
    rdfs:label 'Tier Reclassification Flag' ;
    rdfs:comment 'Indicates whether the supplier\'s performance tier changed between the previous and current evaluation period. True triggers automated supplier development program enrollment or contract review workflows in the ERP.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalPosEvaluated rdf:type rdf:Property ;
    rdfs:label 'Total Pos Evaluated' ;
    rdfs:comment 'Total number of purchase orders (POs) included in the performance evaluation for this period. Provides the denominator context for rate-based KPIs and ensures statistical significance of the scorecard.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalUnitsReceived rdf:type rdf:Property ;
    rdfs:label 'Total Units Received' ;
    rdfs:comment 'Total quantity of units received from the supplier across all purchase orders during the evaluation period. Used as the volume denominator for defect rate, return rate, and fill rate calculations. Sourced from WMS (Warehouse Management System) receiving records.' ;
    rdfs:domain ind:SupplierPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketplaceListingId rdf:type rdf:Property ;
    rdfs:label 'Marketplace Listing Id' ;
    rdfs:comment 'Foreign key linking to marketplace.marketplace_listing. Business justification: Supplier price lists define the buy-side cost for products listed on the marketplace. Linking supplier_price_list to marketplace_listing enables real-time gross margin calculation (listing price minus' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketplaceListing .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.segment. Business justification: Enables segment-specific pricing; the pricing engine selects a price list based on the customer.segment of the buyer.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:supersededBySupplierPriceListId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Supplier Price List Id' ;
    rdfs:comment 'Reference to the newer supplier_price_list record that replaced this one when status is \'superseded\'. Enables version chain traversal for price history analysis and audit. Null if this is the current active version.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplierPriceList .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'The date on which this price list was formally approved by the authorized procurement officer. Required for SOX compliance audit trails and procurement governance reporting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:autoPoPricingEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Po Pricing Enabled' ;
    rdfs:comment 'Indicates whether this price list is enabled for automatic price determination during purchase order creation in the ERP system. When True, the system automatically applies this price list during PO generation without manual price entry.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:erpInfoRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Erp Info Record Number' ;
    rdfs:comment 'The SAP S/4HANA Purchasing Info Record (PIR) number corresponding to this price list entry. Enables direct traceability between the Silver layer data product and the ERP system of record for procurement price determination.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightIncluded rdf:type rdf:Property ;
    rdfs:label 'Freight Included' ;
    rdfs:comment 'Indicates whether freight/shipping costs are included in the quoted unit price. When True, no separate freight charge is added during PO creation. When False, freight is billed separately or calculated via the TMS.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasVolumeTiers rdf:type rdf:Property ;
    rdfs:label 'Has Volume Tiers' ;
    rdfs:comment 'Indicates whether this price list includes a volume discount schedule (quantity break tiers) in addition to the base unit price. When True, the associated supplier_price_list_tier records define the tiered pricing structure.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermCode rdf:type rdf:Property ;
    rdfs:label 'Incoterm Code' ;
    rdfs:comment 'The International Commercial Terms (Incoterms) code defining the delivery obligations, risk transfer point, and cost responsibilities between the supplier and the e-commerce platform for shipments under this price list (e.g., FOB, DDP, EXW). [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterm Location' ;
    rdfs:comment 'The named place or port associated with the Incoterms code (e.g., \'Port of Shanghai\' for FOB, \'Buyer Warehouse\' for DDP). Required to fully specify the delivery terms per ICC Incoterms 2020 rules.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceBasis rdf:type rdf:Property ;
    rdfs:label 'Price Basis' ;
    rdfs:comment 'Indicates whether the unit price represents the gross list price (before discounts), the net agreed price (after discounts), or the landed cost (inclusive of freight, duties, and insurance). Critical for correct COGS calculation and PO price validation.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListCategory rdf:type rdf:Property ;
    rdfs:label 'Price List Category' ;
    rdfs:comment 'Business category of the price list indicating its commercial purpose. \'standard\' = regular agreed pricing; \'promotional\' = time-limited promotional pricing; \'seasonal\' = seasonal pricing adjustment; \'clearance\' = end-of-life or excess inventory pricing; \'emergency\' = expedited sourcing price.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListName rdf:type rdf:Property ;
    rdfs:label 'Price List Name' ;
    rdfs:comment 'Human-readable name or description of the price list, such as \'Q1 2025 Electronics Pricing\' or \'Annual Volume Agreement - Supplier XYZ\'. Used for display and search in procurement portals.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListNumber rdf:type rdf:Property ;
    rdfs:label 'Price List Number' ;
    rdfs:comment 'Externally-known business identifier for this price list, used in supplier communications, purchase order references, and ERP purchasing info records. Follows the format PL-{alphanumeric code}.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListType rdf:type rdf:Property ;
    rdfs:label 'Price List Type' ;
    rdfs:comment 'Classification of the price list by its commercial basis. \'contract_based\' = tied to a formal vendor contract; \'standalone_pir\' = standalone Purchasing Info Record (PIR) in ERP; \'spot_quote\' = one-time quoted price; \'catalog\' = supplier-published catalog price; \'blanket_order\' = price under a blanket purchase order.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListVersion rdf:type rdf:Property ;
    rdfs:label 'Price List Version' ;
    rdfs:comment 'Version number of this price list, enabling tracking of successive revisions for the same supplier-SKU combination. Incremented each time the supplier submits a revised pricing schedule.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceTolerancePercentage rdf:type rdf:Property ;
    rdfs:label 'Price Tolerance Percentage' ;
    rdfs:comment 'The maximum allowable percentage deviation between the price list unit price and the actual invoice price before a three-way match exception is raised. Used in automated invoice verification to flag price discrepancies requiring manual review.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceUnitQuantity rdf:type rdf:Property ;
    rdfs:label 'Price Unit Quantity' ;
    rdfs:comment 'The quantity basis for which the unit price is quoted (e.g., price per 1 unit, per 100 units, per 1000 units). Used to correctly compute per-unit cost when the supplier quotes prices in bulk multiples. Corresponds to the SAP Purchasing Info Record \'Price Unit\' field.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalReminderDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Reminder Days' ;
    rdfs:comment 'The number of days before the expiry date at which a renewal reminder notification should be triggered to the procurement team. Supports proactive price list renewal management and prevents procurement disruption due to expired pricing.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Source Document Reference' ;
    rdfs:comment 'The reference number of the source document from which this price list was derived, such as a supplier quotation number, RFQ response number, or EDI catalog transmission ID. Provides traceability back to the originating supplier communication.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierPriceListStatus rdf:type rdf:Property ;
    rdfs:label 'Supplier Price List Status' ;
    rdfs:comment 'Current lifecycle state of the price list. \'active\' = currently valid for PO pricing; \'expired\' = past expiry date; \'superseded\' = replaced by a newer version; \'draft\' = under preparation; \'pending_approval\' = awaiting procurement approval; \'suspended\' = temporarily deactivated.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierSkuCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Sku Code' ;
    rdfs:comment 'The supplier\'s own part number or item code for this SKU, as used in the supplier\'s catalog and order acknowledgements. Required for EDI purchase order transmission and supplier invoice matching. Distinct from the internal SKU identifier.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierSkuDescription rdf:type rdf:Property ;
    rdfs:label 'Supplier Sku Description' ;
    rdfs:comment 'The supplier\'s description of the SKU as it appears in their catalog or price list document. Used for three-way matching during invoice verification and for resolving discrepancies between internal and supplier item descriptions.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Tax Classification Code' ;
    rdfs:comment 'The tax classification code assigned to this SKU-supplier combination for VAT/GST determination during purchase order processing. Maps to the tax condition type in the ERP pricing procedure.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierCount rdf:type rdf:Property ;
    rdfs:label 'Tier Count' ;
    rdfs:comment 'The number of quantity break tiers defined in the volume discount schedule for this price list. Zero if has_volume_tiers is False. Provides a quick summary of pricing complexity without joining to tier detail records.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uomCode rdf:type rdf:Property ;
    rdfs:label 'Uom Code' ;
    rdfs:comment 'The unit of measure in which the SKU is priced and ordered (e.g., EA for each, CS for case, KG for kilogram, L for litre). Aligns with the UOM defined in the product master and used in purchase order line items.' ;
    rdfs:domain ind:SupplierPriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atpQty rdf:type rdf:Property ;
    rdfs:label 'Atp Qty' ;
    rdfs:comment 'Net units available for new order commitments, calculated as on_hand_qty minus reserved_qty minus quarantined_qty. The ATP quantity is the real-time sellable inventory figure exposed to the storefront and OMS for order promising.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cycleCountVarianceQty rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Variance Qty' ;
    rdfs:comment 'Difference between the system-recorded on-hand quantity and the physically counted quantity at the last cycle count (counted minus system). Positive = overage, negative = shrinkage. Used for inventory accuracy KPI reporting and shrinkage investigation.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:damagedQty rdf:type rdf:Property ;
    rdfs:label 'Damaged Qty' ;
    rdfs:comment 'Units at the node that have been identified as damaged and are unsellable in their current condition. May be eligible for liquidation, refurbishment, or disposal. Tracked for shrinkage reporting and insurance claims.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysOfSupply rdf:type rdf:Property ;
    rdfs:label 'Days Of Supply' ;
    rdfs:comment 'Estimated number of days the current ATP quantity will last at the current 30-day DSR before reaching zero stock. Calculated as atp_qty divided by dsr_30d. Key operational metric for replenishment urgency triage and OOS risk scoring.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dsr30d rdf:type rdf:Property ;
    rdfs:label 'Dsr 30d' ;
    rdfs:comment 'Average units sold per day for this SKU at this node over the trailing 30-day window. Medium-term velocity metric used for safety stock calculation, reorder point setting, and monthly replenishment planning.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dsr7d rdf:type rdf:Property ;
    rdfs:label 'Dsr 7d' ;
    rdfs:comment 'Average units sold per day for this SKU at this node over the trailing 7-day window. Short-term velocity metric used for immediate replenishment decisions and flash sale impact assessment. Recalculated nightly from order fulfillment data.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dsr90d rdf:type rdf:Property ;
    rdfs:label 'Dsr 90d' ;
    rdfs:comment 'Average units sold per day for this SKU at this node over the trailing 90-day window. Long-term velocity baseline used for seasonal trend analysis, annual replenishment planning, and velocity tier classification.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inTransitQty rdf:type rdf:Property ;
    rdfs:label 'In Transit Qty' ;
    rdfs:comment 'Units of the SKU currently in transit to this warehouse node from a supplier, another node, or a returns processing center. Included in future ATP projections but not in current on-hand. Tracked via Transportation Management System (TMS) shipment records.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryOwnershipType rdf:type rdf:Property ;
    rdfs:label 'Inventory Ownership Type' ;
    rdfs:comment 'Classifies who owns the inventory: first_party (platform-owned), third_party_fba (Fulfillment By Amazon-style seller inventory held at platform warehouse), consignment, dropship (never physically held), or vendor_managed inventory (VMI). Drives cost accounting and liability treatment.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'Current lifecycle status of this stock position record. Active = normal operations; quarantined = held pending quality inspection; suspended = temporarily blocked from sale; archived = historical record no longer in active use.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHazmat rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat' ;
    rdfs:comment 'Indicates whether this SKU is classified as a hazardous material requiring special storage, handling, or shipping restrictions at this node. Drives WMS storage zone assignment, carrier eligibility filtering in TMS, and regulatory compliance checks.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOos rdf:type rdf:Property ;
    rdfs:label 'Is Oos' ;
    rdfs:comment 'Indicates whether the SKU is currently out of stock (OOS) at this node, meaning ATP quantity is zero or below safety stock threshold. Drives storefront availability suppression, OOS alerts, and replenishment escalation. Key KPI for inventory health reporting.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSerialized rdf:type rdf:Property ;
    rdfs:label 'Is Serialized' ;
    rdfs:comment 'Indicates whether individual units of this SKU are tracked by unique serial number at this node. When true, each unit has a distinct serial number record in the WMS. Relevant for high-value electronics, regulated goods, and warranty management.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Cycle Count Date' ;
    rdfs:comment 'Date of the most recent physical cycle count performed for this SKU at this warehouse node. Cycle counting is the primary mechanism for validating perpetual inventory accuracy. Frequency is driven by velocity tier (A-items counted more frequently).' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMovementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Movement Timestamp' ;
    rdfs:comment 'Timestamp of the most recent inventory movement transaction (receipt, pick, transfer, adjustment) for this SKU at this node. Used to identify dormant stock, trigger dead-stock reviews, and validate real-time inventory visibility.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Last Received Date' ;
    rdfs:comment 'Date of the most recent inbound goods receipt (GR) posted for this SKU at this warehouse node. Used to assess inventory freshness, identify slow-moving stock, and validate replenishment cycle adherence.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classifies the nature of the storage location: physical_warehouse (owned/leased FC), virtual_location (logical inventory bucket), dropship_node (supplier ships direct), store_backroom (BOPIS-enabled store), or 3pl_facility (Third-Party Logistics partner site).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Supplier or internal lot/batch identifier for the current stock at this node. Enables traceability for product recalls, quality investigations, and FEFO rotation. Null when lot_tracking_method is \'none\'.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotTrackingMethod rdf:type rdf:Property ;
    rdfs:label 'Lot Tracking Method' ;
    rdfs:comment 'Inventory costing and lot rotation method applied to this SKU at this node: FIFO (First In First Out), LIFO (Last In First Out), FEFO (First Expired First Out for perishables), or none (no lot tracking). Governs pick sequencing in WMS and cost-of-goods-sold (COGS) calculation in ERP.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxStockQty rdf:type rdf:Property ;
    rdfs:label 'Max Stock Qty' ;
    rdfs:comment 'Upper bound on inventory units to hold at this node for this SKU, constrained by bin capacity, working capital policy, or perishability. Replenishment orders are sized to not exceed this level. Used in min-max replenishment planning.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onHandQty rdf:type rdf:Property ;
    rdfs:label 'On Hand Qty' ;
    rdfs:comment 'Total physical units of the SKU currently present at the warehouse node, regardless of reservation or allocation status. Includes allocated, quarantined, and damaged units. Source of truth from WMS cycle count or perpetual inventory.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oosSinceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Oos Since Timestamp' ;
    rdfs:comment 'Timestamp when the SKU first became out of stock at this node in the current OOS episode. Used to calculate OOS duration for SLA compliance, lost sales estimation, and seller performance monitoring. Null when is_oos is false.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:peakDsr rdf:type rdf:Property ;
    rdfs:label 'Peak Dsr' ;
    rdfs:comment 'Highest single-day sales rate observed for this SKU at this node within the trailing 90-day window. Used to size safety stock for peak demand scenarios (e.g., flash sales, holiday events) and to stress-test replenishment plans.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quarantinedQty rdf:type rdf:Property ;
    rdfs:label 'Quarantined Qty' ;
    rdfs:comment 'Units physically present at the node but held in quarantine pending quality inspection, regulatory hold, or recall investigation. Not available for sale or fulfillment. Tracked separately for compliance and quality management reporting.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reorderPointQty rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Qty' ;
    rdfs:comment 'Inventory level at which a replenishment purchase order (PO) should be triggered for this SKU at this node. Calculated as safety_stock_qty plus demand during replenishment lead time. Drives automated replenishment in the ERP/WMS.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replenishmentLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Replenishment Lead Time Days' ;
    rdfs:comment 'Expected number of calendar days from purchase order (PO) placement to receipt of goods at this warehouse node for this SKU. Used in reorder point and safety stock calculations. Sourced from supplier SLA agreements.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reservedQty rdf:type rdf:Property ;
    rdfs:label 'Reserved Qty' ;
    rdfs:comment 'Units of the SKU that have been soft-allocated to open orders or reservations but not yet physically picked. Reduces available-to-promise (ATP) quantity. Managed by the Order Management System (OMS) allocation engine.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyStockQty rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Qty' ;
    rdfs:comment 'Minimum buffer stock level maintained at the node to protect against demand variability and supply lead time uncertainty. When ATP quantity falls below safety stock, a replenishment alert is triggered. Calculated from DSR metrics and lead time data.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonalVelocityIndex rdf:type rdf:Property ;
    rdfs:label 'Seasonal Velocity Index' ;
    rdfs:comment 'Multiplicative seasonal adjustment factor applied to the baseline DSR to account for predictable seasonal demand patterns (e.g., 1.5 = 50% above baseline in peak season, 0.7 = 30% below in off-season). Used in demand forecasting and safety stock uplift calculations.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockCondition rdf:type rdf:Property ;
    rdfs:label 'Stock Condition' ;
    rdfs:comment 'Physical or logical state of the stock at this node: on_hand (available in bin), allocated (reserved for an order), quarantined (held for QC), damaged (unsellable), in_transit (moving between nodes). Drives WMS pick eligibility and ATP calculations.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:velocityRecalculatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Velocity Recalculated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent recalculation of DSR metrics and velocity tier for this stock position record. Indicates data freshness for downstream consumers (replenishment engine, slotting optimizer, search ranking). Recalculated nightly or on-demand.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:velocityTier rdf:type rdf:Property ;
    rdfs:label 'Velocity Tier' ;
    rdfs:comment 'ABC/D velocity tier assigned to this SKU at this node based on Best Seller Rank (BSR) and sales volume: A = fast-moving (top ~20% by volume), B = medium-moving, C = slow-moving, D = dead stock / near-zero velocity. Drives slotting decisions, replenishment frequency, and pick path optimization in WMS.' ;
    rdfs:domain ind:StockPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dedicatedSkuId rdf:type rdf:Property ;
    rdfs:label 'Dedicated Sku Id' ;
    rdfs:comment 'Foreign key linking to product.sku. Business justification: Warehouse slotting operations assign fixed locations to specific SKUs (fixed-slot putaway strategy). The existing plain-text \'dedicated_sku\' column is a denormalized SKU reference; replacing it with a' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:accessibilityType rdf:type rdf:Property ;
    rdfs:label 'Accessibility Type' ;
    rdfs:comment 'Equipment or method required to access this storage location. Determines which picking and putaway resources the WMS can assign to tasks involving this location. Automated locations are served by Automated Storage and Retrieval Systems (AS/RS).' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aisleCode rdf:type rdf:Property ;
    rdfs:label 'Aisle Code' ;
    rdfs:comment 'Identifier for the aisle within the warehouse zone where this location is physically situated. Used by WMS for pick-path optimization and travel-time minimization in fulfillment operations.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcode rdf:type rdf:Property ;
    rdfs:label 'Barcode' ;
    rdfs:comment 'Barcode value printed on the physical label affixed to this storage location. Scanned by warehouse operatives using handheld devices or fixed scanners during pick, putaway, and cycle count operations to confirm location identity.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binCode rdf:type rdf:Property ;
    rdfs:label 'Bin Code' ;
    rdfs:comment 'Identifier for the individual bin or slot within the shelf. The most granular physical unit of the warehouse location hierarchy. Directly maps to a scannable barcode label affixed to the physical bin in the warehouse.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUom rdf:type rdf:Property ;
    rdfs:label 'Capacity Uom' ;
    rdfs:comment 'Unit of measure in which the capacity of this storage location is expressed. Aligns with the WMS capacity management configuration for the warehouse node (e.g., \'pallets\' for bulk storage, \'units\' for pick-face bins, \'kg\' for weight-constrained locations).' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency Days' ;
    rdfs:comment 'Target number of days between cycle counts for this location. Drives the WMS cycle count scheduling engine. High-velocity or high-value locations typically have shorter intervals (e.g., 7 days) while low-velocity locations may be counted quarterly (e.g., 90 days).' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'Date from which this storage location record became operationally active and available for inventory allocation in the WMS. Supports bi-temporal data management and warehouse expansion tracking.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'Date on which this storage location record ceases to be operationally active. Null for currently active locations. Used to manage decommissioned or seasonally inactive locations without hard-deleting master records.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hazmatClass rdf:type rdf:Property ;
    rdfs:label 'Hazmat Class' ;
    rdfs:comment 'Hazardous materials classification code assigned to this location, indicating the category of dangerous goods that may be stored here (e.g., Class 3 Flammable Liquids, Class 8 Corrosives). Null for non-hazmat locations. Governs WMS slotting restrictions and regulatory compliance for storage. [ENUM-REF-CANDIDATE: class_1_explosives|class_2_gases|class_3_flammable|class_4_flammable_solids|class_5_oxidizers|class_6_toxic|class_7_radioactive|class_8_corrosives|class_9_misc|none — promote to reference product]' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightCm rdf:type rdf:Property ;
    rdfs:label 'Height Cm' ;
    rdfs:comment 'Physical height dimension of the storage location in centimetres. Used for vertical clearance validation during slotting and for determining forklift or reach-truck accessibility requirements.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBulkStorage rdf:type rdf:Property ;
    rdfs:label 'Is Bulk Storage' ;
    rdfs:comment 'Indicates whether this location is designated as a bulk or reserve storage position. Bulk locations hold overstock inventory that replenishes pick face locations. Used in WMS replenishment trigger logic.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazmatApproved rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat Approved' ;
    rdfs:comment 'Indicates whether this storage location has been certified and approved for storing hazardous materials. Drives WMS slotting rules to prevent non-approved locations from receiving hazmat inventory.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPickFace rdf:type rdf:Property ;
    rdfs:label 'Is Pick Face' ;
    rdfs:comment 'Indicates whether this location is designated as an active pick face — a forward-pick position from which pickers directly fulfil customer orders. Pick face locations are replenished from bulk storage and are optimized for pick speed and ergonomics.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isQuarantine rdf:type rdf:Property ;
    rdfs:label 'Is Quarantine' ;
    rdfs:comment 'Indicates whether this location is designated as a quarantine hold area. Inventory placed in quarantine locations is blocked from pick and shipment pending quality inspection, regulatory hold, or Return Merchandise Authorization (RMA) processing.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVirtual rdf:type rdf:Property ;
    rdfs:label 'Is Virtual' ;
    rdfs:comment 'Indicates whether this is a virtual (system-only) storage location with no physical counterpart in the warehouse. Virtual locations are used for in-transit inventory, damaged goods holding, or system adjustment buckets in the WMS.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lengthCm rdf:type rdf:Property ;
    rdfs:label 'Length Cm' ;
    rdfs:comment 'Physical length dimension of the storage location in centimetres. Used in WMS slotting optimization to match product dimensions to available location space and to calculate volumetric utilization.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:levelNumber rdf:type rdf:Property ;
    rdfs:label 'Level Number' ;
    rdfs:comment 'Numeric vertical level of the storage location within the rack structure (e.g., 1 = ground level, 2 = second level). Used for ergonomic slotting rules, forklift accessibility constraints, and pick-path optimization in the WMS.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this storage location within the warehouse. Used by WMS for pick-pack-ship operations, barcode scanning, and slotting optimization. Typically formatted as ZONE-AISLE-RACK-SHELF-BIN (e.g., A-01-03-02-05).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable descriptive name for the storage location, used in WMS user interfaces, slotting reports, and operational dashboards (e.g., \'Aisle 3 Rack B Shelf 2 Bin 5\').' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current operational lifecycle state of the storage location. Controls whether the WMS can allocate inventory to or pick from this location. \'blocked\' indicates a temporary hold (e.g., quality inspection); \'under_maintenance\' indicates physical inaccessibility.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotTrackingRequired rdf:type rdf:Property ;
    rdfs:label 'Lot Tracking Required' ;
    rdfs:comment 'Indicates whether inventory stored at this location must be tracked at the lot or batch level. Required for locations holding perishables, pharmaceuticals, or regulated goods where First In First Out (FIFO) / First Expired First Out (FEFO) lot traceability is mandated.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Capacity' ;
    rdfs:comment 'Maximum storage capacity of this location expressed in the unit defined by capacity_uom. Used by WMS to enforce inventory allocation limits and prevent overstocking. Critical for slotting optimization and replenishment planning.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxFillLevel rdf:type rdf:Property ;
    rdfs:label 'Max Fill Level' ;
    rdfs:comment 'Maximum inventory quantity (in capacity_uom) that should be stocked at this location. Used by the WMS to cap replenishment quantities and prevent overfilling. Typically set equal to or less than max_capacity to allow for operational buffer.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Weight Kg' ;
    rdfs:comment 'Maximum allowable weight in kilograms that this storage location can safely bear. Enforced by WMS during inventory allocation to prevent structural overloading. Particularly relevant for high-density racking and mezzanine-level locations.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minFillLevel rdf:type rdf:Property ;
    rdfs:label 'Min Fill Level' ;
    rdfs:comment 'Minimum inventory quantity (in capacity_uom) that should be maintained at this location before a replenishment task is triggered. Used by the WMS replenishment engine to prevent Out of Stock (OOS) conditions at pick face locations.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mixedSkuAllowed rdf:type rdf:Property ;
    rdfs:label 'Mixed Sku Allowed' ;
    rdfs:comment 'Indicates whether multiple distinct Stock Keeping Units (SKUs) may be co-located in this storage position simultaneously. When false, the WMS enforces single-SKU integrity. Mixed-SKU locations are common in bulk storage but typically prohibited at pick faces to prevent picking errors.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickSequence rdf:type rdf:Property ;
    rdfs:label 'Pick Sequence' ;
    rdfs:comment 'Numeric sequence number used by the WMS to order this location within a pick path or wave. Lower numbers are visited first. Optimized to minimize picker travel distance and maximize throughput in fulfillment operations.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:putawayStrategy rdf:type rdf:Property ;
    rdfs:label 'Putaway Strategy' ;
    rdfs:comment 'Strategy used by the WMS to direct incoming inventory to this location during receiving and putaway operations. Fixed: always assigned to specific Stock Keeping Units (SKUs); floating: any compatible SKU; directed: WMS algorithm assigns; nearest_empty: proximity-based assignment.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rackCode rdf:type rdf:Property ;
    rdfs:label 'Rack Code' ;
    rdfs:comment 'Identifier for the rack or bay within the aisle where this location is physically situated. Part of the hierarchical location address used by WMS for precise inventory positioning.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentStrategy rdf:type rdf:Property ;
    rdfs:label 'Replenishment Strategy' ;
    rdfs:comment 'Inventory rotation and replenishment strategy applied to this location. Governs the order in which stock is consumed and replenished: First In First Out (FIFO), Last In First Out (LIFO), First Expired First Out (FEFO) for perishables, manual (operator-directed), or none (no automated replenishment).' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTag rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag' ;
    rdfs:comment 'RFID tag identifier associated with this storage location for automated inventory tracking and real-time location visibility. Null if the location is not RFID-enabled. Supports real-time inventory visibility in RFID-equipped warehouse nodes.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfCode rdf:type rdf:Property ;
    rdfs:label 'Shelf Code' ;
    rdfs:comment 'Identifier for the shelf level within the rack where this location is physically situated. Shelf codes are used for vertical positioning in WMS pick-path logic and ergonomic slotting (e.g., golden zone placement for high-velocity Stock Keeping Units (SKUs)).' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slottingVelocityClass rdf:type rdf:Property ;
    rdfs:label 'Slotting Velocity Class' ;
    rdfs:comment 'ABC/D velocity classification assigned to this location based on the throughput of Stock Keeping Units (SKUs) slotted here. Class A: highest-velocity (golden zone, ergonomic height); Class B: medium-velocity; Class C: low-velocity; Class D: very slow-moving or seasonal. Drives slotting optimization decisions.' ;
    rdfs:domain ind:WarehouseLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureZone rdf:type rdf:Property ;
    rdfs:label 'Temperature Zone' ;
    rdfs:comment 'Temperature classification of the storage location, defining the environmental condition maintained at this position. Drives product-to-location compatibility rules in WMS slotting: ambient (room temperature), chilled (2–8°C), frozen (below -18°C), controlled (specific regulated range for pharmaceuticals or electronics).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthCm rdf:type rdf:Property ;
    rdfs:label 'Width Cm' ;
    rdfs:comment 'Physical width dimension of the storage location in centimetres. Used alongside length_cm and height_cm for volumetric capacity calculations and product-to-location fit validation in WMS slotting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneCode rdf:type rdf:Property ;
    rdfs:label 'Zone Code' ;
    rdfs:comment 'Identifier for the warehouse zone in which this location resides. Zones group locations by operational function, temperature requirement, or product category (e.g., DRY, COLD, HAZMAT, RETURNS). Used for slotting optimization and pick-path routing.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockMovementId rdf:type rdf:Property ;
    rdfs:label 'Stock Movement Id' ;
    rdfs:comment 'Unique identifier for the stock movement transaction. Primary key for the stock movement audit trail.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Id' ;
    rdfs:comment 'Foreign key linking to inventory.adjustment. Business justification: When an inventory adjustment is processed, a corresponding stock movement record is created as the audit trail of the quantity change. Linking stock_movement to adjustment enables direct traceability ' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Adjustment .

ind:carrierServiceId rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Id' ;
    rdfs:comment 'Foreign key linking to logistics.carrier_service. Business justification: Carrier performance reporting and freight cost allocation: stock movements (inbound receipts, outbound transfers) use specific carrier service levels. Existing FK covers carrier but not service. Opera' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierService .

ind:destinationLocationWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Destination Location Warehouse Location Id' ;
    rdfs:comment 'Identifier of the warehouse location, bin, or virtual location to which inventory is being moved. Null for issue transactions leaving the warehouse network or write-off transactions.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:logisticsShipmentId rdf:type rdf:Property ;
    rdfs:label 'Logistics Shipment Id' ;
    rdfs:comment 'Foreign key linking to logistics.logistics_shipment. Business justification: Inbound goods receipt reconciliation: stock movements for inbound receipts must be traceable to the logistics shipment that delivered the goods. Warehouse operations and finance teams use this link to' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LogisticsShipment .

ind:orderLineId rdf:type rdf:Property ;
    rdfs:label 'Order Line Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.fulfillment_order_line. Business justification: In e-commerce WMS operations, pick and pack stock movements are line-level events tied to a specific fulfillment_order_line. Line-level pick confirmation, short-pick exception handling, and inventory ' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderLine .

ind:paymentRefundId rdf:type rdf:Property ;
    rdfs:label 'Payment Refund Id' ;
    rdfs:comment 'Foreign key linking to payment.payment_refund. Business justification: Returns reconciliation process: when a customer return is received at the warehouse, a stock movement (inbound return) is recorded alongside a payment refund. This FK enables direct tracing of physica' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentRefund .

ind:primaryStockWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Stock Warehouse Location Id' ;
    rdfs:comment 'Identifier of the warehouse location, bin, or virtual location from which inventory is being moved. Null for receipt transactions originating outside the warehouse network.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:rmaId rdf:type rdf:Property ;
    rdfs:label 'Rma Id' ;
    rdfs:comment 'Foreign key linking to service.rma. Business justification: Return-type stock movements are directly caused by RMA processing. Linking stock_movement.rma_id → rma.rma_id enables reverse logistics reporting, financial reconciliation of returned goods, and audit' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rma .

ind:transferOrderId rdf:type rdf:Property ;
    rdfs:label 'Transfer Order Id' ;
    rdfs:comment 'Foreign key linking to inventory.transfer_order. Business justification: A transfer order (inter-warehouse or inter-location movement) generates stock movement records — an outbound movement from the source and an inbound movement at the destination. Linking stock_movement' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransferOrder .

ind:adjustmentReasonNotes rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason Notes' ;
    rdfs:comment 'Free-text explanation for manual adjustments, write-offs, or variance corrections. Required for audit trail completeness and regulatory compliance. Captures business context not conveyed by reason code alone.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Erp Document Number' ;
    rdfs:comment 'Material document or goods movement document number generated by the ERP system (e.g., SAP material document). Used for cross-system reconciliation and audit trail.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'Accounting period date when the inventory movement value was posted to the general ledger. May differ from movement_timestamp due to period close timing. Null for non-financial movements.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isFinancialImpact rdf:type rdf:Property ;
    rdfs:label 'Is Financial Impact' ;
    rdfs:comment 'Flag indicating whether this movement has financial impact requiring general ledger posting (True) or is a non-financial movement such as location transfer within the same warehouse (False). Critical for financial reconciliation and month-end close.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSystemInitiated rdf:type rdf:Property ;
    rdfs:label 'Is System Initiated' ;
    rdfs:comment 'Flag indicating whether the movement was automatically triggered by system logic (True) or manually initiated by a user (False). Used to distinguish automated replenishment, allocation, and reservation movements from manual transactions.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:movementNumber rdf:type rdf:Property ;
    rdfs:label 'Movement Number' ;
    rdfs:comment 'Business-facing unique identifier for the stock movement transaction. Human-readable reference number used in operational systems and audit reports.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementStatus rdf:type rdf:Property ;
    rdfs:label 'Movement Status' ;
    rdfs:comment 'Current lifecycle state of the stock movement transaction. Pending = awaiting execution; In Transit = movement initiated but not yet received; Completed = movement finalized and inventory updated; Cancelled = movement voided before completion; Failed = movement attempted but rejected by system validation.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Movement Timestamp' ;
    rdfs:comment 'Date and time when the physical inventory movement occurred or was recorded in the system. This is the business event timestamp used for inventory valuation and audit trail sequencing.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'Classification of the inventory movement transaction. Receipt = inbound from supplier or production; Issue = outbound to fulfillment or consumption; Transfer = inter-location movement; Adjustment = manual correction; Return = customer or supplier return; Write-off = inventory removal due to damage, expiry, or shrinkage.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Status' ;
    rdfs:comment 'Quality control status of the inventory at the time of movement. Approved = passed quality inspection and available for use; Quarantine = held for inspection or investigation; Rejected = failed quality standards; Inspection Pending = awaiting quality review. Critical for regulated industries and quality-sensitive products.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Quantity of inventory units moved in this transaction. Positive for receipts and returns; negative for issues and write-offs. Supports fractional quantities for items sold by weight or volume.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized code explaining the business reason for the inventory movement. Critical for root cause analysis of inventory variances, write-offs, and adjustments. Shrinkage = theft or loss; Damage = physical damage; Count Variance = cycle count discrepancy; System Error = ERP correction; Expiry = expired product removal; Recount = audit adjustment; Returns = RMA processing; Production Scrap = manufacturing waste. [ENUM-REF-CANDIDATE: shrinkage|damage|count_variance|system_error|expiry|recount|customer_return|supplier_return|production_scrap — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Unique serial number for serialized inventory items requiring unit-level tracking (electronics, high-value goods, regulated products). Null for non-serialized items.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalValue rdf:type rdf:Property ;
    rdfs:label 'Total Value' ;
    rdfs:comment 'Total financial value of the inventory movement (quantity × unit cost). Used for general ledger posting, inventory asset reconciliation, and SOX-compliant financial reporting. Positive for receipts; negative for issues and write-offs.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Per-unit inventory cost at the time of movement, used for inventory valuation and financial reconciliation. Reflects weighted average cost, FIFO cost, or standard cost depending on accounting policy.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wmsTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Wms Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier from the source Warehouse Management System. Enables reconciliation between WMS and ERP inventory records and supports end-to-end audit trail.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockAllocationId rdf:type rdf:Property ;
    rdfs:label 'Stock Allocation Id' ;
    rdfs:comment 'Unique identifier for the stock allocation record. Primary key.' ;
    rdfs:domain ind:StockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fulfillmentOrderId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Order Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.fulfillment_order. Business justification: Required for the Fulfillment Order creation process that reserves inventory for each order line, enabling real-time allocation tracking.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentOrder .

ind:fulfillmentShipmentId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Shipment Id' ;
    rdfs:comment 'Reference to the shipment that will fulfill this allocation. Links allocation to outbound logistics.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentShipment .

ind:allocatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocated Quantity' ;
    rdfs:comment 'The quantity of inventory reserved for this allocation. Reduces Available-to-Promise (ATP) and prevents overselling.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationNotes rdf:type rdf:Property ;
    rdfs:label 'Allocation Notes' ;
    rdfs:comment 'Free-text notes or special instructions related to this allocation. Captures operational context and exceptions.' ;
    rdfs:domain ind:StockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Allocation Reason Code' ;
    rdfs:comment 'Coded reason for the allocation or any special handling requirements. Examples: STANDARD, EXPEDITED, REPLACEMENT, SAMPLE.' ;
    rdfs:domain ind:StockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationSource rdf:type rdf:Property ;
    rdfs:label 'Allocation Source' ;
    rdfs:comment 'The system or process that originated this allocation. Distinguishes automated allocations from manual interventions.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current lifecycle state of the allocation. Tracks progression from reservation through fulfillment or cancellation. [ENUM-REF-CANDIDATE: pending|confirmed|picked|packed|shipped|cancelled|expired|released — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocation Timestamp' ;
    rdfs:comment 'The date and time when the inventory was allocated to this demand. Represents the business event time of reservation.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Classification of the allocation commitment. Hard allocation is firm and reduces ATP; soft allocation is tentative and may be released; pre-allocation reserves inventory before order confirmation; reservation holds inventory for future demand.' ;
    rdfs:domain ind:StockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Explanation for why the allocation was cancelled. Examples: customer cancellation, inventory unavailable, order modification, fraud.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'The date and time when the allocation was cancelled. Null if allocation was not cancelled.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiry Timestamp' ;
    rdfs:comment 'The date and time when this allocation expires if not fulfilled. After expiry, the allocation may be automatically released back to ATP.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdFlag rdf:type rdf:Property ;
    rdfs:label 'Hold Flag' ;
    rdfs:comment 'Indicates whether this allocation is on hold and cannot proceed to fulfillment. True if held, False otherwise.' ;
    rdfs:domain ind:StockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdReason rdf:type rdf:Property ;
    rdfs:label 'Hold Reason' ;
    rdfs:comment 'Explanation for why the allocation is on hold. Examples: payment pending, fraud review, inventory quality check, customer request.' ;
    rdfs:domain ind:StockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryCondition rdf:type rdf:Property ;
    rdfs:label 'Inventory Condition' ;
    rdfs:comment 'Physical condition of the allocated inventory. Supports allocation rules that prioritize new stock over returned or refurbished items.' ;
    rdfs:domain ind:StockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Packed Timestamp' ;
    rdfs:comment 'The date and time when the picked inventory was packed for shipment. Tracks fulfillment milestone.' ;
    rdfs:domain ind:StockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickedQuantity rdf:type rdf:Property ;
    rdfs:label 'Picked Quantity' ;
    rdfs:comment 'The quantity that has been physically picked from the warehouse location. Tracks fulfillment progress.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Picked Timestamp' ;
    rdfs:comment 'The date and time when the allocated inventory was picked. Marks transition from allocated to in-fulfillment state.' ;
    rdfs:domain ind:StockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Numeric priority ranking for this allocation. Higher priority allocations are fulfilled first. Supports SLA-based fulfillment sequencing.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releasedQuantity rdf:type rdf:Property ;
    rdfs:label 'Released Quantity' ;
    rdfs:comment 'The quantity of inventory released from this allocation back to ATP. May differ from allocated quantity if partial fulfillment occurred.' ;
    rdfs:domain ind:StockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releasedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Released Timestamp' ;
    rdfs:comment 'The date and time when the allocation was released back to ATP. Null if allocation is still active.' ;
    rdfs:domain ind:StockAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shippedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shipped Timestamp' ;
    rdfs:comment 'The date and time when the allocation was shipped to the customer. Marks completion of the allocation lifecycle.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originalAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Original Adjustment Id' ;
    rdfs:comment 'Reference to the original adjustment transaction being reversed, if this record is a reversal. Maintains audit trail for corrections.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Adjustment .

ind:rmaLineId rdf:type rdf:Property ;
    rdfs:label 'Rma Line Id' ;
    rdfs:comment 'Foreign key linking to service.rma_line. Business justification: Inventory adjustments for scrap, write-off, or restocking are triggered by specific RMA line dispositions. adjustment has external_reference_number (denormalized reference) but no FK to rma_line. Retu' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RmaLine .

ind:adjustedQuantity rdf:type rdf:Property ;
    rdfs:label 'Adjusted Quantity' ;
    rdfs:comment 'The net quantity change applied to inventory. Positive values indicate additions to stock; negative values indicate reductions. Measured in the SKU\'s unit of measure (UOM).' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustedValue rdf:type rdf:Property ;
    rdfs:label 'Adjusted Value' ;
    rdfs:comment 'The total financial value of the adjustment, calculated as adjusted_quantity × unit_cost. Represents the General Ledger (GL) impact for inventory write-offs or additions.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Number' ;
    rdfs:comment 'Human-readable business identifier for the adjustment transaction, typically formatted as ADJ-YYYYMMDD-NNNN for external reference and audit trail.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current lifecycle state of the adjustment transaction. Controls whether the adjustment has been applied to inventory balances and financial ledgers.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjustment Timestamp' ;
    rdfs:comment 'The date and time when the physical or system adjustment event occurred. Distinct from record creation timestamp; represents the real-world business event time.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Classification of the adjustment reason. Determines financial treatment and operational follow-up actions. [ENUM-REF-CANDIDATE: shrinkage|damage|count_variance|system_error|expiry_write_off|return_to_stock|transfer_correction|theft|obsolescence — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'The date and time when the adjustment was formally approved by an authorized user. Marks the transition to posted status.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:authorizedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Authorized By User Code' ;
    rdfs:comment 'Identifier of the user who approved and authorized the adjustment. Required for segregation of duties and audit compliance.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByUserCode rdf:type rdf:Property ;
    rdfs:label 'Created By User Code' ;
    rdfs:comment 'Identifier of the user who initiated or recorded the adjustment transaction in the system.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'External Reference Number' ;
    rdfs:comment 'Optional reference to an external document or transaction ID, such as a Return Merchandise Authorization (RMA) number, supplier claim, or insurance case number.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedToGlFlag rdf:type rdf:Property ;
    rdfs:label 'Posted To Gl Flag' ;
    rdfs:comment 'Indicates whether the adjustment has been posted to the financial General Ledger. True when the financial impact has been recorded in the ERP system.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityAfterAdjustment rdf:type rdf:Property ;
    rdfs:label 'Quantity After Adjustment' ;
    rdfs:comment 'The resulting on-hand inventory quantity after the adjustment is applied. Calculated as quantity_before_adjustment + adjusted_quantity.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityBeforeAdjustment rdf:type rdf:Property ;
    rdfs:label 'Quantity Before Adjustment' ;
    rdfs:comment 'The on-hand inventory quantity recorded in the system immediately prior to the adjustment. Provides audit trail for variance analysis.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this adjustment is a reversal of a previously posted adjustment. True when correcting an erroneous prior adjustment.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierRateCardId rdf:type rdf:Property ;
    rdfs:label 'Carrier Rate Card Id' ;
    rdfs:comment 'Foreign key linking to logistics.carrier_rate_card. Business justification: Freight cost audit and financial reconciliation: transfer orders carry a freight_cost field that must be auditable against the rate card applied. Finance and procurement teams require this link to val' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierRateCard .

ind:destinationWarehouseWarehouseNodeId rdf:type rdf:Property ;
    rdfs:label 'Destination Warehouse Warehouse Node Id' ;
    rdfs:comment 'Identifier of the warehouse or fulfillment center to which inventory is being transferred.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseNode .

ind:primaryTransferWarehouseNodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Transfer Warehouse Node Id' ;
    rdfs:comment 'Identifier of the warehouse or fulfillment center from which inventory is being transferred.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseNode .

ind:sourceWarehouseLocationId rdf:type rdf:Property ;
    rdfs:label 'Source Warehouse Location Id' ;
    rdfs:comment 'Foreign key linking to inventory.warehouse_location. Business justification: A transfer order moves inventory FROM a specific source warehouse location (bin/shelf). The existing source_location_code (STRING) on transfer_order is a denormalized reference to warehouse_location.l' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WarehouseLocation .

ind:approvedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Approved By User Code' ;
    rdfs:comment 'Identifier of the user who approved the transfer order. Nullable until approval is granted. Used for authorization audit trail.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date when the transfer order was approved by inventory management or warehouse operations. Nullable for orders not yet approved.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancelledByUserCode rdf:type rdf:Property ;
    rdfs:label 'Cancelled By User Code' ;
    rdfs:comment 'Identifier of the user who cancelled the transfer order. Nullable for non-cancelled orders. Used for exception tracking and audit.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Date and time when the transfer order was closed after successful receipt and reconciliation. Nullable until order is closed. Used for cycle time analysis.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destinationLocationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Location Code' ;
    rdfs:comment 'Specific bin, aisle, or zone location within the destination warehouse where inventory will be stored. Used for putaway planning.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'Estimated date when the transfer shipment will arrive at the destination warehouse. Used for receiving planning and inventory availability forecasting.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inTransitQuantity rdf:type rdf:Property ;
    rdfs:label 'In Transit Quantity' ;
    rdfs:comment 'Quantity currently in transit between warehouses. Used for real-time inventory visibility and available-to-promise calculations.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCrossDock rdf:type rdf:Property ;
    rdfs:label 'Is Cross Dock' ;
    rdfs:comment 'Flag indicating whether this transfer bypasses storage and goes directly to outbound shipping. Used for fast-moving inventory optimization.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Date and time when the transfer order record was last modified. Used for change tracking and data quality monitoring.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickedDate rdf:type rdf:Property ;
    rdfs:label 'Picked Date' ;
    rdfs:comment 'Date when inventory was picked from source warehouse location. Nullable until picking is completed.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date when inventory was received and checked in at the destination warehouse. Nullable until receipt is completed.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'Actual quantity received at destination warehouse. May differ from transfer quantity due to damage, loss, or discrepancies.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedDate rdf:type rdf:Property ;
    rdfs:label 'Requested Date' ;
    rdfs:comment 'Date by which the transfer is requested to be completed. Used for replenishment planning and fulfillment network optimization.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentMethod rdf:type rdf:Property ;
    rdfs:label 'Shipment Method' ;
    rdfs:comment 'Transportation mode used for the transfer. Determines transit time and cost for network optimization.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippedDate rdf:type rdf:Property ;
    rdfs:label 'Shipped Date' ;
    rdfs:comment 'Date when the transfer shipment departed the source warehouse. Used for in-transit inventory tracking and SLA monitoring.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:temperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled' ;
    rdfs:comment 'Flag indicating whether the transfer requires temperature-controlled transportation. Used for cold chain compliance and carrier selection.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Order Number' ;
    rdfs:comment 'Externally-visible business identifier for the transfer order. Human-readable reference number used in warehouse operations and tracking systems.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferQuantity rdf:type rdf:Property ;
    rdfs:label 'Transfer Quantity' ;
    rdfs:comment 'Quantity of units being transferred from source to destination warehouse. Measured in the SKU\'s base unit of measure.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle status of the transfer order. Tracks the order through warehouse operations from creation to completion. [ENUM-REF-CANDIDATE: created|approved|picked|packed|shipped|in_transit|received|closed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the transfer order purpose. Indicates the business reason for the inter-warehouse movement.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'Difference between transfer quantity and received quantity. Positive indicates overage, negative indicates shortage. Used for inventory reconciliation.' ;
    rdfs:domain ind:TransferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockRuleId rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Rule Id' ;
    rdfs:comment 'Unique identifier for the safety stock rule record. Primary key.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaId rdf:type rdf:Property ;
    rdfs:label 'Sla Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.fulfillment_sla. Business justification: In e-commerce replenishment planning, safety stock targets are calibrated per SLA tier — same-day SLA demands higher safety stock than standard. Planners explicitly align safety_stock_rule parameters ' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sla .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'Inventory classification based on value and volume: A (high value, tight control), B (moderate), C (low value, loose control).' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageDailyDemand rdf:type rdf:Property ;
    rdfs:label 'Average Daily Demand' ;
    rdfs:comment 'The mean daily sales rate or demand for this SKU at this warehouse node, used as baseline for safety stock calculation.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Average Lead Time Days' ;
    rdfs:comment 'The mean supplier or replenishment lead time in days for this SKU at this location.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationFrequency rdf:type rdf:Property ;
    rdfs:label 'Calculation Frequency' ;
    rdfs:comment 'How often the safety stock quantity is automatically recalculated to reflect changing demand patterns and supply conditions.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'The methodology used to calculate safety stock quantity: statistical (based on demand variability), fixed (constant buffer), seasonal (adjusted for seasonality), dynamic (real-time optimization), min-max (reorder point logic), or service level (target fill rate).' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demandForecastHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Demand Forecast Horizon Days' ;
    rdfs:comment 'The number of days into the future for which demand forecasts are considered in safety stock calculation.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:demandVariabilityCoefficient rdf:type rdf:Property ;
    rdfs:label 'Demand Variability Coefficient' ;
    rdfs:comment 'Statistical measure of demand volatility (standard deviation or coefficient of variation) used in safety stock calculation to account for demand uncertainty.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'The date on which this safety stock rule expires or is superseded by a new rule. Null indicates an open-ended rule.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'The date from which this safety stock rule becomes active and is applied in inventory calculations.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdingCostPerUnitPerDay rdf:type rdf:Property ;
    rdfs:label 'Holding Cost Per Unit Per Day' ;
    rdfs:comment 'The daily cost of carrying one unit of inventory, including warehousing, insurance, obsolescence, and capital cost.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPromotionalProduct rdf:type rdf:Property ;
    rdfs:label 'Is Promotional Product' ;
    rdfs:comment 'Boolean flag indicating whether this SKU is frequently subject to promotional campaigns that create demand spikes.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSeasonalProduct rdf:type rdf:Property ;
    rdfs:label 'Is Seasonal Product' ;
    rdfs:comment 'Boolean flag indicating whether this SKU exhibits seasonal demand patterns requiring adjusted safety stock strategies.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCalculationDate rdf:type rdf:Property ;
    rdfs:label 'Last Calculation Date' ;
    rdfs:comment 'The most recent date on which the safety stock quantity was recalculated based on updated demand and lead time data.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModifiedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Code' ;
    rdfs:comment 'Identifier of the user or system process that most recently updated this safety stock rule record.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeVariabilityDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Variability Days' ;
    rdfs:comment 'The standard deviation or variance in supplier lead time measured in days, capturing supply uncertainty for safety stock calculation.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level' ;
    rdfs:comment 'The upper inventory threshold for this SKU at this location, used in min-max inventory control systems.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'The minimum quantity that must be ordered from the supplier, which may influence safety stock levels and reorder point calculations.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'The scheduled date for the next review and potential recalculation of this safety stock rule.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Free-text explanation when safety stock levels are manually overridden from system-calculated values, documenting business justification.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityClassification rdf:type rdf:Property ;
    rdfs:label 'Priority Classification' ;
    rdfs:comment 'Business priority level assigned to this SKU for safety stock management, influencing service level targets and buffer sizing.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'The inventory level at which a replenishment order should be triggered, calculated as lead time demand plus safety stock.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Review Period Days' ;
    rdfs:comment 'The frequency in days at which inventory levels are reviewed and replenishment decisions are made for this SKU.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name or label for this safety stock rule configuration.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the safety stock rule indicating whether it is actively applied in inventory planning.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockDaysOfCover rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Days Of Cover' ;
    rdfs:comment 'The number of days of average demand that the safety stock quantity represents, providing a time-based buffer metric.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'The calculated safety stock quantity in units that should be maintained as buffer inventory to protect against stockouts.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonalityFactor rdf:type rdf:Property ;
    rdfs:label 'Seasonality Factor' ;
    rdfs:comment 'Multiplier applied to safety stock during seasonal demand periods to adjust buffer levels for predictable demand fluctuations.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLevelTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Service Level Target Percentage' ;
    rdfs:comment 'The target in-stock probability or fill rate percentage (e.g., 95.00, 99.00) that this safety stock rule is designed to achieve.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockoutCostPerUnit rdf:type rdf:Property ;
    rdfs:label 'Stockout Cost Per Unit' ;
    rdfs:comment 'The estimated business cost incurred per unit when a stockout occurs, including lost sales, expedited shipping, and customer dissatisfaction.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zScore rdf:type rdf:Property ;
    rdfs:label 'Z Score' ;
    rdfs:comment 'The standard normal distribution z-score corresponding to the service level target, used in statistical safety stock formulas.' ;
    rdfs:domain ind:SafetyStockRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierContractId rdf:type rdf:Property ;
    rdfs:label 'Carrier Contract Id' ;
    rdfs:comment 'Foreign key linking to logistics.carrier_contract. Business justification: Carrier contract management: e-commerce fulfillment centers operate under specific carrier contracts governing outbound rates and SLAs. Network operations teams must know which carrier contract applie' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarrierContract .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address line of the warehouse node facility. Used for carrier pickup scheduling, regulatory filings, and geographic routing in the TMS.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address line for the warehouse node (suite, dock number, building identifier). Supplements address_line1 for precise carrier and logistics routing.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacitySqft rdf:type rdf:Property ;
    rdfs:label 'Capacity Sqft' ;
    rdfs:comment 'Total usable floor area of the warehouse node in square feet. Principal capacity measurement used for space utilization reporting, lease management, and network capacity planning.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierCodes rdf:type rdf:Property ;
    rdfs:label 'Carrier Codes' ;
    rdfs:comment 'Comma-separated list of carrier codes (e.g., \'UPS,FEDEX,USPS,DHL\') representing the shipping carriers that service this warehouse node. Used by the TMS for carrier selection and rate shopping during order fulfillment.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City in which the warehouse node is physically located. Used for geographic clustering, last-mile delivery zone assignment, and regulatory jurisdiction determination.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionedDate rdf:type rdf:Property ;
    rdfs:label 'Commissioned Date' ;
    rdfs:comment 'Date on which the warehouse node was officially commissioned and became operational in the fulfillment network. Used for asset lifecycle tracking, depreciation calculations, and network history reporting.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decommissionedDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioned Date' ;
    rdfs:comment 'Date on which the warehouse node was decommissioned and removed from the active fulfillment network. Null for active nodes. Used for network topology history and asset lifecycle reporting.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dockDoorsInbound rdf:type rdf:Property ;
    rdfs:label 'Dock Doors Inbound' ;
    rdfs:comment 'Number of inbound receiving dock doors at the warehouse node. Determines inbound throughput capacity for purchase order receiving, supplier deliveries, and FTL/LTL carrier appointments.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dockDoorsOutbound rdf:type rdf:Property ;
    rdfs:label 'Dock Doors Outbound' ;
    rdfs:comment 'Number of outbound shipping dock doors at the warehouse node. Determines outbound throughput capacity for order fulfillment, carrier pickups, and cross-dock operations.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fulfillmentModel rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Model' ;
    rdfs:comment 'Primary fulfillment model supported by this node. Determines order routing eligibility and SLA commitments. FBA-style nodes handle seller-stocked inventory; BOPIS nodes support Buy Online Pick Up In Store; DTC nodes serve direct-to-consumer shipments. [ENUM-REF-CANDIDATE: fba_style|bopis|dtc|b2b|omnichannel|cross_dock — promote to reference product]' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gln rdf:type rdf:Property ;
    rdfs:label 'Gln' ;
    rdfs:comment 'GS1 Global Location Number (GLN) — a 13-digit internationally standardized identifier for this warehouse node. Used in EDI transactions, supply chain partner communications, and global trade compliance.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:is24hrOperation rdf:type rdf:Property ;
    rdfs:label 'Is 24hr Operation' ;
    rdfs:comment 'Indicates whether the warehouse node operates on a 24-hour, continuous basis. When true, overrides operating_hours_start and operating_hours_end for SLA and routing calculations.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:is3pl rdf:type rdf:Property ;
    rdfs:label 'Is 3pl' ;
    rdfs:comment 'Indicates whether this warehouse node is operated by a third-party logistics (3PL) provider rather than owned/operated by the business. Drives cost allocation, SLA contract management, and operational reporting.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isColdStorage rdf:type rdf:Property ;
    rdfs:label 'Is Cold Storage' ;
    rdfs:comment 'Indicates whether the warehouse node has temperature-controlled cold storage capability. Used to route perishable or temperature-sensitive SKUs to eligible nodes during inventory allocation.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazmatCertified rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat Certified' ;
    rdfs:comment 'Indicates whether the warehouse node holds the required certifications to store and handle hazardous materials (hazmat). Drives SKU-level inventory routing and CPSC compliance checks.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReturnsEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Returns Enabled' ;
    rdfs:comment 'Indicates whether this warehouse node is authorized to receive and process customer returns and RMA (Return Merchandise Authorization) shipments. Controls return routing logic in the OMS.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the warehouse node in decimal degrees (WGS 84). Used by the TMS for route optimization, delivery radius calculations, and geospatial analytics.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiry Date' ;
    rdfs:comment 'Date on which the facility lease for this warehouse node expires. Used for network planning, lease renewal management, and long-term capacity forecasting. Applicable to leased facilities only.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the warehouse node in decimal degrees (WGS 84). Used by the TMS for route optimization, delivery radius calculations, and geospatial analytics.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxWeightCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Max Weight Capacity Kg' ;
    rdfs:comment 'Maximum total weight capacity of the warehouse node in kilograms. Used for structural load compliance, inventory planning, and safety management per facility engineering specifications.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkTier rdf:type rdf:Property ;
    rdfs:label 'Network Tier' ;
    rdfs:comment 'Hierarchical tier classification of the warehouse node within the fulfillment network topology. Hub nodes serve as primary distribution points; spoke nodes serve last-mile delivery zones. Drives inventory positioning and replenishment flow.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeCode rdf:type rdf:Property ;
    rdfs:label 'Node Code' ;
    rdfs:comment 'Externally-known, human-readable alphanumeric code uniquely identifying the warehouse node across all operational systems (WMS, TMS, OMS). Used as the business key in EDI, carrier integrations, and fulfillment routing logic.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeName rdf:type rdf:Property ;
    rdfs:label 'Node Name' ;
    rdfs:comment 'Full descriptive name of the warehouse node as used in operational communications, reporting dashboards, and carrier documentation (e.g., \'Dallas Fulfillment Center - North\').' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeStatus rdf:type rdf:Property ;
    rdfs:label 'Node Status' ;
    rdfs:comment 'Current operational lifecycle status of the warehouse node. Controls whether the node is eligible to receive inventory allocations, fulfill orders, or participate in replenishment planning.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nodeType rdf:type rdf:Property ;
    rdfs:label 'Node Type' ;
    rdfs:comment 'Classification of the warehouse node by its operational role in the fulfillment network. Drives routing logic, SLA assignment, and capacity planning. [ENUM-REF-CANDIDATE: fulfillment_center|distribution_center|dark_store|3pl_facility|drop_ship_node|returns_center — promote to reference product]' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingDays rdf:type rdf:Property ;
    rdfs:label 'Operating Days' ;
    rdfs:comment 'Comma-separated list of operating days of the week for the warehouse node (e.g., \'MON,TUE,WED,THU,FRI\'). Used for SLA cutoff scheduling, carrier appointment booking, and fulfillment routing logic.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Operating Hours End' ;
    rdfs:comment 'Standard daily operating end time for the warehouse node in HH:MM (24-hour) format. Used to determine carrier pickup cutoff windows, SLA calculation, and order routing eligibility.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursStart rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Start' ;
    rdfs:comment 'Standard daily operating start time for the warehouse node in HH:MM (24-hour) format. Used to determine carrier pickup cutoff windows, SLA calculation, and order routing eligibility.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:palletPositions rdf:type rdf:Property ;
    rdfs:label 'Pallet Positions' ;
    rdfs:comment 'Total number of standard pallet positions available in the warehouse node. Used for inventory capacity planning, MOQ compliance, and replenishment scheduling in the WMS.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the warehouse node facility. Used for carrier zone mapping, last-mile delivery cost calculation, and geographic analytics.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Internal geographic region code grouping warehouse nodes for network planning, carrier contract management, and regional fulfillment analytics (e.g., \'US-WEST\', \'EU-CENTRAL\').' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State or province code where the warehouse node is located. Used for tax nexus determination, labor law compliance, and regional fulfillment routing. Follows ISO 3166-2 subdivision codes.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Temperature Max C' ;
    rdfs:comment 'Maximum maintained temperature in degrees Celsius for the warehouse node\'s temperature-controlled storage areas. Applicable only when is_cold_storage is true. Used for SKU eligibility routing and compliance audits.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Temperature Min C' ;
    rdfs:comment 'Minimum maintained temperature in degrees Celsius for the warehouse node\'s temperature-controlled storage areas. Applicable only when is_cold_storage is true. Used for SKU eligibility routing and compliance audits.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA timezone identifier for the warehouse node location (e.g., \'America/Chicago\'). Used to correctly interpret operating hours, SLA cutoff times, and carrier pickup windows across distributed fulfillment networks.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmsLocationCode rdf:type rdf:Property ;
    rdfs:label 'Tms Location Code' ;
    rdfs:comment 'Location code assigned by the Transportation Management System (TMS) for this warehouse node. Used for carrier pickup scheduling, route optimization, and shipment origin identification.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsFacilityReference rdf:type rdf:Property ;
    rdfs:label 'Wms Facility Reference' ;
    rdfs:comment 'Native facility identifier assigned by the Warehouse Management System (WMS) for this warehouse node. Used for system integration, EDI message routing, and reconciliation between the WMS and the lakehouse SSOT.' ;
    rdfs:domain ind:WarehouseNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportCaseId rdf:type rdf:Property ;
    rdfs:label 'Support Case Id' ;
    rdfs:comment 'Unique identifier for the customer support case or service ticket. Primary key for the service support case entity.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupportCase .

ind:assignedAgentId rdf:type rdf:Property ;
    rdfs:label 'Assigned Agent Id' ;
    rdfs:comment 'Reference to the customer service agent currently assigned to work on this case. May be null if case is unassigned or in queue.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:assignedTeamId rdf:type rdf:Property ;
    rdfs:label 'Assigned Team Id' ;
    rdfs:comment 'Foreign key linking to service.team. Business justification: service_support_case currently stores assigned_queue as a denormalized STRING representing the team or queue a case is routed to. Adding assigned_team_id → service.team.team_id normalizes this relatio' ;
    rdfs:domain ind:SupportCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:bundleId rdf:type rdf:Property ;
    rdfs:label 'Bundle Id' ;
    rdfs:comment 'Foreign key linking to product.bundle. Business justification: Support cases are raised for bundle-specific issues (missing component, bundle pricing dispute, partial return eligibility). Agents need to identify the bundle to apply correct return policy and calcu' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bundle .

ind:catalogItemId rdf:type rdf:Property ;
    rdfs:label 'Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Product quality reporting, CPSC compliance tracking, and recall management require grouping all support cases by catalog item across all SKUs. Agents investigating product-level defects need this link' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:centerId rdf:type rdf:Property ;
    rdfs:label 'Center Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.center. Business justification: Support cases often arise from issues at a specific fulfillment center (e.g., inventory or pickup problems); linking enables Center-Level case reporting and SLA tracking.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Center .

ind:channelId rdf:type rdf:Property ;
    rdfs:label 'Channel Id' ;
    rdfs:comment 'Foreign key linking to marketing.channel. Business justification: Omnichannel support routing and channel-level SLA assignment require linking each case to its originating marketing channel. E-commerce operations report CSAT and resolution time by channel; `originat' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: In B2B e-commerce, support cases are raised by a specific contact (buyer persona within an account). Contact-level case tracking drives SLA reporting per contact, escalation routing, and communication' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:couponRedemptionId rdf:type rdf:Property ;
    rdfs:label 'Coupon Redemption Id' ;
    rdfs:comment 'Foreign key linking to pricing.coupon_redemption. Business justification: Coupon failure and misapplication are among the top support case drivers in e-commerce. Linking the case directly to the coupon_redemption record allows agents to inspect redemption status, fraud flag' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CouponRedemption .

ind:knowledgeArticleId rdf:type rdf:Property ;
    rdfs:label 'Knowledge Article Id' ;
    rdfs:comment 'Reference to the knowledge base article used to resolve this case. Links case resolution to documented solutions for knowledge management and self-service improvement.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KnowledgeArticle .

ind:loyaltyEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Enrollment Id' ;
    rdfs:comment 'Foreign key linking to customer.loyalty_enrollment. Business justification: customer_entitlement_tier on service_support_case requires real-time loyalty tier validation for SLA routing and VIP case handling. Direct FK to loyalty_enrollment enables tier-based case prioritizati' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyEnrollment .

ind:marketplacePromotionId rdf:type rdf:Property ;
    rdfs:label 'Marketplace Promotion Id' ;
    rdfs:comment 'Foreign key linking to marketplace.marketplace_promotion. Business justification: Support cases frequently arise from marketplace promotion disputes (promotional price not honored, eligibility errors). Direct FK to marketplace_promotion enables promotion-specific case routing, FTC ' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketplacePromotion .

ind:marketplaceTransactionId rdf:type rdf:Property ;
    rdfs:label 'Marketplace Transaction Id' ;
    rdfs:comment 'Foreign key linking to marketplace.marketplace_transaction. Business justification: Required for support case reporting: each case must reference the specific marketplace transaction that triggered the issue, enabling accurate SLA tracking and root-cause analysis.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketplaceTransaction .

ind:parentCaseServiceSupportCaseId rdf:type rdf:Property ;
    rdfs:label 'Parent Case Service Support Case Id' ;
    rdfs:comment 'Reference to a parent case if this case is a child or follow-up case. Used for linking related cases and tracking case hierarchies (e.g., original case and subsequent escalation or related inquiry).' ;
    rdfs:domain ind:SupportCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupportCase .

ind:priceOverrideId rdf:type rdf:Property ;
    rdfs:label 'Price Override Id' ;
    rdfs:comment 'Foreign key linking to pricing.price_override. Business justification: Pricing dispute cases — where customers question why they were charged a non-standard price — require agents to directly inspect the price_override record. This is one of the most common case types in' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceOverride .

ind:productListingId rdf:type rdf:Property ;
    rdfs:label 'Product Listing Id' ;
    rdfs:comment 'Foreign key linking to product.product_listing. Business justification: Cases originating from listing-level issues (incorrect price displayed, suppressed listing, wrong description) require direct listing linkage for listing quality reporting, suppression root-cause anal' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductListing .

ind:proofOfDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.proof_of_delivery. Business justification: Delivery dispute resolution is a named e-commerce support process: when a customer claims non-delivery, the agent must access the POD record (photo, GPS, signature) directly from the case. No existing' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProofOfDelivery .

ind:slaPolicyId rdf:type rdf:Property ;
    rdfs:label 'Sla Policy Id' ;
    rdfs:comment 'Foreign key linking to service.sla_policy. Business justification: service_support_case currently stores sla_policy_code as a denormalized STRING reference to the governing SLA policy. Adding a proper FK sla_policy_id → service.sla_policy.sla_policy_id normalizes thi' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaPolicy .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Externally visible unique case identifier displayed to customers and agents. Typically follows a format like CS-12345678 or CASE-0001234567.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the support case by the nature of the customer issue: billing inquiry, shipping problem, product defect, account access issue, returns processing, refund request, marketplace dispute, or general inquiry. [ENUM-REF-CANDIDATE: billing|shipping|product_defect|account_access|returns|refund|marketplace_dispute|general_inquiry — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationAmount rdf:type rdf:Property ;
    rdfs:label 'Compensation Amount' ;
    rdfs:comment 'Monetary compensation or goodwill credit provided to the customer as part of case resolution (e.g., account credit, discount voucher, refund). Null if no compensation was provided.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contactAttempts rdf:type rdf:Property ;
    rdfs:label 'Contact Attempts' ;
    rdfs:comment 'Number of times the support team attempted to contact the customer regarding this case. Used for tracking customer responsiveness and case aging.' ;
    rdfs:domain ind:SupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:csatScore rdf:type rdf:Property ;
    rdfs:label 'Csat Score' ;
    rdfs:comment 'Customer satisfaction score collected after case resolution, typically on a scale of 1.00 to 5.00. Measures customer satisfaction with the support experience and resolution quality.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerEntitlementTier rdf:type rdf:Property ;
    rdfs:label 'Customer Entitlement Tier' ;
    rdfs:comment 'The service entitlement level of the customer at the time the case was created: standard (basic support), premium (priority support), VIP (dedicated support), enterprise (white-glove service). Influences SLA targets and routing.' ;
    rdfs:domain ind:SupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationStatus rdf:type rdf:Property ;
    rdfs:label 'Escalation Status' ;
    rdfs:comment 'Indicates whether and to what level the case has been escalated: not_escalated (standard handling), tier2 (specialist support), tier3 (expert/engineering), management (supervisor review), executive (C-level attention).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackComments rdf:type rdf:Property ;
    rdfs:label 'Feedback Comments' ;
    rdfs:comment 'Free-text feedback comments provided by the customer in post-case surveys. Captures qualitative insights about the support experience, agent performance, and areas for improvement.' ;
    rdfs:domain ind:SupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Response Timestamp' ;
    rdfs:comment 'Date and time when the first substantive response was provided to the customer by an agent. Key SLA metric for measuring initial response time.' ;
    rdfs:domain ind:SupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interactionCount rdf:type rdf:Property ;
    rdfs:label 'Interaction Count' ;
    rdfs:comment 'Total number of customer-agent interactions (calls, emails, chats) associated with this case. Indicates case complexity and effort required for resolution.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isVipCase rdf:type rdf:Property ;
    rdfs:label 'Is Vip Case' ;
    rdfs:comment 'Boolean flag indicating whether this case involves a VIP or high-value customer requiring special handling, expedited service, or executive attention. True for VIP cases, False otherwise.' ;
    rdfs:domain ind:SupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the language in which the case was handled (e.g., en for English, es for Spanish, fr for French).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'Net Promoter Score collected from the customer after case resolution, on a scale of 0 to 10. Measures customer loyalty and likelihood to recommend the company based on the support experience.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outcomeDisposition rdf:type rdf:Property ;
    rdfs:label 'Outcome Disposition' ;
    rdfs:comment 'Final disposition of the case: resolved (issue successfully addressed), unresolved (could not be resolved), duplicate (merged with another case), transferred (moved to another system or team), withdrawn (customer cancelled request).' ;
    rdfs:domain ind:SupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reopenedCount rdf:type rdf:Property ;
    rdfs:label 'Reopened Count' ;
    rdfs:comment 'Number of times this case has been reopened after being marked as resolved or closed. Indicates resolution quality issues or recurring customer problems.' ;
    rdfs:domain ind:SupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Detailed notes documenting the resolution provided to the customer, actions taken, root cause identified, and any follow-up required. Populated when case is resolved or closed.' ;
    rdfs:domain ind:SupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Date and time when the case was marked as resolved, indicating that a solution was provided to the customer. Key SLA metric for measuring time-to-resolution.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'Classification of the underlying root cause identified during case resolution (e.g., system_error, process_gap, product_defect, user_error, policy_exception, carrier_issue). Used for trend analysis and continuous improvement. [ENUM-REF-CANDIDATE: system_error|process_gap|product_defect|user_error|policy_exception|carrier_issue|payment_failure|inventory_issue|data_quality — promote to reference product]' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentimentScore rdf:type rdf:Property ;
    rdfs:label 'Sentiment Score' ;
    rdfs:comment 'Automated sentiment analysis score derived from customer communications (emails, chat transcripts) during the case lifecycle. Scale typically -1.00 (very negative) to +1.00 (very positive).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceSupportCaseDescription rdf:type rdf:Property ;
    rdfs:label 'Service Support Case Description' ;
    rdfs:comment 'Detailed description of the customer issue, inquiry, or request as captured during case creation. May include customer-provided details, agent notes, and initial diagnostic information.' ;
    rdfs:domain ind:SupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceSupportCaseStatus rdf:type rdf:Property ;
    rdfs:label 'Service Support Case Status' ;
    rdfs:comment 'Current lifecycle status of the support case: new (just created), open (assigned), pending_customer (awaiting customer response), pending_internal (awaiting internal action), in_progress (actively being worked), escalated (moved to higher tier), resolved (solution provided), closed (finalized), cancelled (withdrawn). [ENUM-REF-CANDIDATE: new|open|pending_customer|pending_internal|in_progress|escalated|resolved|closed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SupportCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Boolean indicator of whether this case breached its SLA targets for first response time or resolution time. True indicates SLA was breached, False indicates SLA was met.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Brief summary or subject line describing the customer issue or inquiry. Typically 100-200 characters.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseInteractionId rdf:type rdf:Property ;
    rdfs:label 'Case Interaction Id' ;
    rdfs:comment 'Unique identifier for the case interaction record. Primary key.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryCaseAgentId rdf:type rdf:Property ;
    rdfs:label 'Primary Case Agent Id' ;
    rdfs:comment 'Identifier of the customer service agent who handled this interaction. Links to employee or agent entity.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:attachmentCount rdf:type rdf:Property ;
    rdfs:label 'Attachment Count' ;
    rdfs:comment 'Number of file attachments associated with this interaction (screenshots, documents, logs).' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attachmentReferences rdf:type rdf:Property ;
    rdfs:label 'Attachment References' ;
    rdfs:comment 'Comma-separated list of attachment identifiers or URIs pointing to files stored in external document management system.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactMethod rdf:type rdf:Property ;
    rdfs:label 'Contact Method' ;
    rdfs:comment 'The specific contact method used for this interaction (phone number, email address, chat handle, social media handle).' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentSummary rdf:type rdf:Property ;
    rdfs:label 'Content Summary' ;
    rdfs:comment 'Summarized content or transcript of the interaction, capturing key points discussed without full verbatim text.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Direction of the interaction: inbound (customer-initiated) or outbound (agent-initiated).' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Total duration of the interaction in seconds, applicable for calls and chat sessions.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Boolean flag indicating whether this interaction resulted in an escalation to a higher support tier or management (True/False).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Reason or justification for escalating the interaction, if escalation occurred.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalInteractionReference rdf:type rdf:Property ;
    rdfs:label 'External Interaction Reference' ;
    rdfs:comment 'Unique identifier for this interaction in the external source system, used for cross-system reconciliation and traceability.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedbackComment rdf:type rdf:Property ;
    rdfs:label 'Feedback Comment' ;
    rdfs:comment 'Free-text feedback or comment provided by the customer about this interaction.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullTranscriptReference rdf:type rdf:Property ;
    rdfs:label 'Full Transcript Reference' ;
    rdfs:comment 'Reference pointer or URI to the full transcript or recording stored in external system (e.g., CDN (Content Delivery Network), document management system).' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionNumber rdf:type rdf:Property ;
    rdfs:label 'Interaction Number' ;
    rdfs:comment 'Human-readable business identifier for the interaction, typically formatted as INT- followed by numeric sequence.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionSequence rdf:type rdf:Property ;
    rdfs:label 'Interaction Sequence' ;
    rdfs:comment 'Sequential ordering of this interaction within the parent case lifecycle, starting from 1.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interactionStatus rdf:type rdf:Property ;
    rdfs:label 'Interaction Status' ;
    rdfs:comment 'Current status of the interaction: completed, pending follow-up, escalated to higher tier, abandoned by customer, or transferred to another agent.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Interaction Timestamp' ;
    rdfs:comment 'The exact date and time when the interaction event occurred in the format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'The type or category of interaction event: call, email, chat, SMS, social media, or web form submission.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Internal notes or comments added by the agent for internal reference, not visible to the customer.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'The outcome or result of the interaction: resolved, unresolved, escalated, referred to another department, information provided, or callback scheduled.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Priority level assigned to this interaction: low, medium, high, or critical.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Resolution Provided Flag' ;
    rdfs:comment 'Boolean flag indicating whether a resolution or answer was provided during this interaction (True/False).' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Response Time Seconds' ;
    rdfs:comment 'Time in seconds taken by the agent to provide the first substantive response after interaction initiation.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaBreachReason rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Reason' ;
    rdfs:comment 'Reason or explanation for SLA (Service Level Agreement) breach, if the interaction did not meet SLA targets.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether this interaction met the defined SLA (Service Level Agreement) targets for response and resolution time (True/False).' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tags rdf:type rdf:Property ;
    rdfs:label 'Tags' ;
    rdfs:comment 'Comma-separated list of tags or labels applied to categorize or classify the interaction (e.g., billing, technical, complaint, refund).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferFlag rdf:type rdf:Property ;
    rdfs:label 'Transfer Flag' ;
    rdfs:comment 'Boolean flag indicating whether the interaction was transferred to another agent or department (True/False).' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waitTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Wait Time Seconds' ;
    rdfs:comment 'Time in seconds the customer waited before the interaction was answered or acknowledged by an agent.' ;
    rdfs:domain ind:CaseInteraction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryConfirmationId rdf:type rdf:Property ;
    rdfs:label 'Delivery Confirmation Id' ;
    rdfs:comment 'Foreign key linking to order.delivery_confirmation. Business justification: RMA return window eligibility is calculated from confirmed delivery date; linking RMA to delivery_confirmation enables automated return eligibility validation, proof-of-delivery dispute resolution, an' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryConfirmation .

ind:returnFromCustomerAddressId rdf:type rdf:Property ;
    rdfs:label 'Return From Customer Address Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_address. Business justification: Return label generation and carrier pickup scheduling require the customer\'s return-from address. The rma table has no address FK currently. Role-prefixed return_from_ distinguishes pickup address fro' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAddress .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Flag indicating whether this RMA requires manual approval by customer service or management. Triggered by policy exceptions or high-value returns.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date when the RMA case was fully closed and all associated workflows completed. Marks the end of the return lifecycle for reporting purposes.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerDeclaredCondition rdf:type rdf:Property ;
    rdfs:label 'Customer Declared Condition' ;
    rdfs:comment 'Condition of the returned item as declared by the customer at the time of RMA request. Used for initial eligibility assessment and compared against inspection findings.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerServiceNotes rdf:type rdf:Property ;
    rdfs:label 'Customer Service Notes' ;
    rdfs:comment 'Free-text notes entered by customer service representatives regarding the RMA case. Captures context, customer interactions, and special handling instructions.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDecision rdf:type rdf:Property ;
    rdfs:label 'Disposition Decision' ;
    rdfs:comment 'Final decision on how the returned item will be handled post-inspection. Drives inventory allocation, financial write-offs, and reverse logistics.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReturnDate rdf:type rdf:Property ;
    rdfs:label 'Expected Return Date' ;
    rdfs:comment 'Estimated date by which the returned item is expected to arrive at the warehouse. Used for receiving planning and exception alerts.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectedCondition rdf:type rdf:Property ;
    rdfs:label 'Inspected Condition' ;
    rdfs:comment 'Actual condition of the returned item as determined by warehouse inspection team. Used to validate customer declaration and determine disposition.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Completed Date' ;
    rdfs:comment 'Date when the warehouse inspection of the returned item was completed. Triggers disposition decision and refund processing.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Inspection Notes' ;
    rdfs:comment 'Free-text notes entered by warehouse inspection team regarding the physical condition and findings of the returned item.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current status of the physical inspection process for the returned item. Tracks warehouse receiving and quality control workflow.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isWithinPolicy rdf:type rdf:Property ;
    rdfs:label 'Is Within Policy' ;
    rdfs:comment 'Flag indicating whether the RMA request complies with the applicable return policy rules. Used for auto-approval workflows and exception handling.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Label Issued Date' ;
    rdfs:comment 'Date when the return shipping label was generated and provided to the customer. Used for tracking customer action and carrier pickup scheduling.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labelPaidBy rdf:type rdf:Property ;
    rdfs:label 'Label Paid By' ;
    rdfs:comment 'Party responsible for paying the return shipping cost. Determines financial settlement and customer experience.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Total monetary amount to be refunded to the customer in the transaction currency. May differ from original order amount due to restocking fees or partial returns.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundMethod rdf:type rdf:Property ;
    rdfs:label 'Refund Method' ;
    rdfs:comment 'Method by which the refund will be issued to the customer. Drives payment processing workflow and customer communication.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundProcessedDate rdf:type rdf:Property ;
    rdfs:label 'Refund Processed Date' ;
    rdfs:comment 'Date when the refund transaction was successfully processed and funds were released to the customer. Used for financial reconciliation and customer satisfaction tracking.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refundStatus rdf:type rdf:Property ;
    rdfs:label 'Refund Status' ;
    rdfs:comment 'Current status of the refund transaction. Tracks financial settlement workflow and customer notification triggers.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restockingFee rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee' ;
    rdfs:comment 'Fee charged to the customer for processing the return, deducted from the refund amount. Applied per return policy and product category.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnLabelCost rdf:type rdf:Property ;
    rdfs:label 'Return Label Cost' ;
    rdfs:comment 'Cost of the return shipping label in the transaction currency. Used for return cost analysis and customer charge-back decisions.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason for the return. Used for root cause analysis, product quality tracking, and return rate analytics. [ENUM-REF-CANDIDATE: defective|wrong_item|not_as_described|damaged_in_transit|no_longer_needed|size_fit_issue|buyer_remorse|duplicate_order|late_delivery|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Return Tracking Number' ;
    rdfs:comment 'Carrier-provided tracking number for the return shipment. Enables real-time visibility into return transit status.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnType rdf:type rdf:Property ;
    rdfs:label 'Return Type' ;
    rdfs:comment 'Classification of the return resolution method requested by the customer or determined by policy. Drives downstream financial and fulfillment workflows.' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnWindowDays rdf:type rdf:Property ;
    rdfs:label 'Return Window Days' ;
    rdfs:comment 'Number of days from original order delivery date within which the return must be initiated per policy. Used for eligibility validation.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rmaStatus rdf:type rdf:Property ;
    rdfs:label 'Rma Status' ;
    rdfs:comment 'Current lifecycle status of the RMA. Tracks the return authorization workflow from initial request through final disposition. [ENUM-REF-CANDIDATE: pending_approval|approved|rejected|label_issued|in_transit|received|inspecting|completed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rma ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionCode rdf:type rdf:Property ;
    rdfs:label 'Disposition Code' ;
    rdfs:comment 'The final disposition decision for the returned item. Determines how the item will be handled after inspection and processing.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Exchange Requested Flag' ;
    rdfs:comment 'Indicates whether the customer has requested an exchange rather than a refund for this item. True if exchange requested, false if refund only.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exchangeSku rdf:type rdf:Property ;
    rdfs:label 'Exchange Sku' ;
    rdfs:comment 'The SKU of the replacement product requested by the customer if this is an exchange. Null if this is a refund-only return.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Inspected By User Code' ;
    rdfs:comment 'Reference to the warehouse staff member who performed the inspection of this returned item. Supports quality control and accountability.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectedDate rdf:type rdf:Property ;
    rdfs:label 'Inspected Date' ;
    rdfs:comment 'The date the returned item completed quality inspection. Marks the completion of the inspection process and readiness for disposition.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:itemConditionCode rdf:type rdf:Property ;
    rdfs:label 'Item Condition Code' ;
    rdfs:comment 'Standardized assessment of the physical condition of the returned item upon receipt at the warehouse. Determines restocking eligibility and disposition.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineSubtotal rdf:type rdf:Property ;
    rdfs:label 'Line Subtotal' ;
    rdfs:comment 'The total amount for this line before taxes and fees, calculated as unit price multiplied by quantity approved. Represents the base refund amount.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Line Tax Amount' ;
    rdfs:comment 'The tax amount to be refunded for this line item. Calculated based on the approved quantity and applicable tax rates.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityApproved rdf:type rdf:Property ;
    rdfs:label 'Quantity Approved' ;
    rdfs:comment 'The number of units approved for refund or exchange after inspection. May be less than quantity received if some units fail inspection criteria.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'The number of units the customer has requested to return for this SKU. Represents the customer\'s initial return request quantity.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restockingEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Restocking Eligible Flag' ;
    rdfs:comment 'Indicates whether the returned item is in suitable condition to be restocked and resold as new inventory. True if eligible for resale, false if must be liquidated or disposed.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restockingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee Amount' ;
    rdfs:comment 'The restocking fee charged to the customer for this line item, if applicable. Typically applied for non-defective returns or opened items per return policy.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Return Reason Description' ;
    rdfs:comment 'Detailed free-text explanation provided by the customer or service agent describing the specific reason for returning this item.' ;
    rdfs:domain ind:RmaLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceRefundId rdf:type rdf:Property ;
    rdfs:label 'Service Refund Id' ;
    rdfs:comment 'Unique identifier for the service refund record. Primary key for the service refund entity.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceRefund .

ind:paymentMethodId rdf:type rdf:Property ;
    rdfs:label 'Payment Method Id' ;
    rdfs:comment 'Foreign key linking to payment.payment_method. Business justification: Enables audit of refunds by payment method, supporting compliance reports and method-level performance metrics.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Method .

ind:primaryServiceIssuingAgentId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Issuing Agent Id' ;
    rdfs:comment 'Reference to the customer service agent who initiated the refund request. Links to the employee or agent record.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:sellerSettlementId rdf:type rdf:Property ;
    rdfs:label 'Seller Settlement Id' ;
    rdfs:comment 'Foreign key linking to marketplace.seller_settlement. Business justification: Refunds issued on marketplace transactions must be deducted from the seller\'s settlement disbursement. Finance and marketplace ops require this link for seller payout reconciliation, net disbursement ' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SellerSettlement .

ind:approvalTier rdf:type rdf:Property ;
    rdfs:label 'Approval Tier' ;
    rdfs:comment 'Authorization level required for this refund based on amount thresholds. Defines the approval hierarchy tier.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'Date and time when the refund was successfully settled and funds were returned to the customer. Marks the end of the refund lifecycle.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerSatisfactionImpact rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Impact' ;
    rdfs:comment 'Assessed impact of the refund on customer satisfaction based on follow-up surveys or agent assessment. Used for service quality tracking.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGoodwillGesture rdf:type rdf:Property ;
    rdfs:label 'Is Goodwill Gesture' ;
    rdfs:comment 'Indicates whether the refund was issued as a proactive goodwill gesture rather than in response to a specific complaint or return. True for retention offers.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRetentionOffer rdf:type rdf:Property ;
    rdfs:label 'Is Retention Offer' ;
    rdfs:comment 'Indicates whether the compensation was issued as part of a customer retention strategy to prevent churn. True for proactive retention gestures.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyPointsGranted rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Granted' ;
    rdfs:comment 'Number of loyalty program points awarded as compensation. Zero if compensation was not in the form of loyalty points.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managerOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Manager Override Flag' ;
    rdfs:comment 'Indicates whether the refund required manager override of standard policy or amount thresholds. True if exception was granted.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netRefundCost rdf:type rdf:Property ;
    rdfs:label 'Net Refund Cost' ;
    rdfs:comment 'Total cost to the business including refund amount and processing fees. Used for financial impact analysis and reporting.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npsSurveyResponse rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Response' ;
    rdfs:comment 'Customer NPS score (0-10) collected after refund resolution. Null if no survey response was received. Used for service quality measurement.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalPaymentMethodType rdf:type rdf:Property ;
    rdfs:label 'Original Payment Method Type' ;
    rdfs:comment 'Type of payment method used in the original order. Used to determine refund routing and processing requirements. [ENUM-REF-CANDIDATE: credit_card|debit_card|paypal|bank_transfer|gift_card|store_credit|cash_on_delivery|buy_now_pay_later — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideJustification rdf:type rdf:Property ;
    rdfs:label 'Override Justification' ;
    rdfs:comment 'Explanation provided by the approving manager for policy override or exception. Required when manager_override_flag is true.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processed Timestamp' ;
    rdfs:comment 'Date and time when the refund was submitted to the payment system for execution. Marks handoff from service to payment domain.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processingFee rdf:type rdf:Property ;
    rdfs:label 'Processing Fee' ;
    rdfs:comment 'Fee charged by payment processor or financial institution for processing the refund transaction. Represents cost to business.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonCategory rdf:type rdf:Property ;
    rdfs:label 'Reason Category' ;
    rdfs:comment 'High-level categorization of why the refund or compensation was issued. Used for root cause analysis and service improvement. [ENUM-REF-CANDIDATE: defective_product|wrong_item_shipped|damaged_in_transit|late_delivery|service_failure|customer_dissatisfaction|pricing_error|goodwill_gesture|retention_offer|policy_exception — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDetail rdf:type rdf:Property ;
    rdfs:label 'Reason Detail' ;
    rdfs:comment 'Detailed explanation of the specific reason for issuing the refund or compensation. Free-text field for agent notes.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionCode rdf:type rdf:Property ;
    rdfs:label 'Redemption Code' ;
    rdfs:comment 'Unique code issued for store credit, gift card, or coupon compensation. Used by customer to claim the value. Confidential business data.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Redemption Status' ;
    rdfs:comment 'Tracks whether non-monetary compensation (store credit, gift card, coupon) has been used by the customer. Not applicable for direct refunds.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionValueRemaining rdf:type rdf:Property ;
    rdfs:label 'Redemption Value Remaining' ;
    rdfs:comment 'Remaining unredeemed value for partial-use compensation instruments like store credit or gift cards. Null for one-time refunds.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundNumber rdf:type rdf:Property ;
    rdfs:label 'Refund Number' ;
    rdfs:comment 'Externally visible unique business identifier for the refund. Used in customer communications and tracking.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationType rdf:type rdf:Property ;
    rdfs:label 'Remediation Type' ;
    rdfs:comment 'Category of customer remediation issued. Defines the form of compensation provided to the customer. [ENUM-REF-CANDIDATE: full_refund|partial_refund|store_credit|gift_card|coupon_code|free_shipping_voucher|loyalty_points|goodwill_compensation — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Requested Timestamp' ;
    rdfs:comment 'Date and time when the refund was initially requested by the customer or initiated by the service agent. Marks the start of the refund lifecycle.' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceRefundStatus rdf:type rdf:Property ;
    rdfs:label 'Service Refund Status' ;
    rdfs:comment 'Current lifecycle state of the refund. Tracks the refund through authorization, processing, and completion stages. [ENUM-REF-CANDIDATE: pending|approved|processing|completed|failed|redeemed|expired|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentId rdf:type rdf:Property ;
    rdfs:label 'Agent Id' ;
    rdfs:comment 'Unique identifier for the customer service agent. Primary key for the agent entity.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:supervisorAgentId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Agent Id' ;
    rdfs:comment 'FK to service.agent' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:activeStatus rdf:type rdf:Property ;
    rdfs:label 'Active Status' ;
    rdfs:comment 'Current employment and operational status of the agent. Determines whether the agent is eligible for case assignment.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Availability Status' ;
    rdfs:comment 'Current real-time availability status of the agent. Used by the case routing engine to determine if the agent can accept new cases.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageHandleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Handle Time Minutes' ;
    rdfs:comment 'Rolling average time in minutes the agent takes to resolve a case from assignment to closure. Key performance indicator for agent efficiency.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date when the agents current service certification expires and requires renewal. Null if certification does not expire.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Score' ;
    rdfs:comment 'Average customer satisfaction score for cases handled by this agent, typically on a 1-5 scale. Derived from post-interaction surveys.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Corporate email address for the agent. Used for internal communication and system notifications.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCode rdf:type rdf:Property ;
    rdfs:label 'Employee Code' ;
    rdfs:comment 'External employee identifier from the HR system. Links the agent to their employee record in the Enterprise Resource Planning (ERP) system.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRate rdf:type rdf:Property ;
    rdfs:label 'Escalation Rate' ;
    rdfs:comment 'Percentage of cases handled by the agent that required escalation to a supervisor or specialist. Lower rates indicate higher agent competency.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstContactResolutionRate rdf:type rdf:Property ;
    rdfs:label 'First Contact Resolution Rate' ;
    rdfs:comment 'Percentage of cases resolved by the agent on first contact without escalation or follow-up. Key quality metric for agent performance.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Full legal name of the customer service agent as recorded in the HR system.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date the agent was hired into the customer service organization. Used for tenure analysis and performance benchmarking.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:languageProficiencies rdf:type rdf:Property ;
    rdfs:label 'Language Proficiencies' ;
    rdfs:comment 'Comma-separated list of languages the agent can support with proficiency level (e.g., EN-native, ES-fluent, FR-conversational). Enables multilingual customer support routing.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastLoginTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Login Timestamp' ;
    rdfs:comment 'Timestamp of the agents most recent login to the customer service platform. Used for activity monitoring and availability tracking.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxConcurrentCases rdf:type rdf:Property ;
    rdfs:label 'Max Concurrent Cases' ;
    rdfs:comment 'Maximum number of cases the agent can handle simultaneously. Used by the workload balancing engine to prevent agent overload.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netPromoterScore rdf:type rdf:Property ;
    rdfs:label 'Net Promoter Score' ;
    rdfs:comment 'Average Net Promoter Score (NPS) for interactions handled by this agent. Measures customer loyalty and likelihood to recommend based on agent service.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phoneExtension rdf:type rdf:Property ;
    rdfs:label 'Phone Extension' ;
    rdfs:comment 'Internal phone extension number for the agent within the contact center phone system.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAssuranceScore rdf:type rdf:Property ;
    rdfs:label 'Quality Assurance Score' ;
    rdfs:comment 'Average quality assurance audit score for the agent based on case review and compliance checks. Typically scored 0-100 by QA team.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftScheduleReference rdf:type rdf:Property ;
    rdfs:label 'Shift Schedule Reference' ;
    rdfs:comment 'Reference identifier to the agents current shift schedule or roster. Links to workforce management system for capacity planning.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillSetTags rdf:type rdf:Property ;
    rdfs:label 'Skill Set Tags' ;
    rdfs:comment 'Comma-separated list of agent competencies and specializations (e.g., returns, billing, technical, escalations, fraud, international). Used for intelligent case routing and workload balancing.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaComplianceRate rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Rate' ;
    rdfs:comment 'Percentage of cases where the agent met or exceeded the defined Service Level Agreement (SLA) response and resolution time targets.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportedChannels rdf:type rdf:Property ;
    rdfs:label 'Supported Channels' ;
    rdfs:comment 'Comma-separated list of customer service channels the agent is trained and authorized to handle (e.g., phone, email, chat, social media, SMS).' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamAssignment rdf:type rdf:Property ;
    rdfs:label 'Team Assignment' ;
    rdfs:comment 'Name or identifier of the service team to which the agent is assigned (e.g., Returns Team, Billing Support, Technical Support, Escalations).' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCasesHandled rdf:type rdf:Property ;
    rdfs:label 'Total Cases Handled' ;
    rdfs:comment 'Cumulative count of all cases assigned to and handled by the agent since hire date. Used for productivity and experience analysis.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'Date the agent completed initial onboarding and training program and was certified to handle customer cases independently.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:teamId rdf:type rdf:Property ;
    rdfs:label 'Team Id' ;
    rdfs:comment 'Unique identifier for the customer service team. Primary key.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentTeamId rdf:type rdf:Property ;
    rdfs:label 'Parent Team Id' ;
    rdfs:comment 'Reference to the parent team in a hierarchical team structure. Null for top-level teams. Enables organizational hierarchy and escalation path modeling.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:primaryEscalationTeamId rdf:type rdf:Property ;
    rdfs:label 'Primary Escalation Team Id' ;
    rdfs:comment 'Reference to the team to which cases are escalated when this team cannot resolve them. Null if this is the highest escalation tier. Enables escalation path configuration.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:capacityFte rdf:type rdf:Property ;
    rdfs:label 'Capacity Fte' ;
    rdfs:comment 'Total team capacity expressed in Full-Time Equivalent (FTE) headcount. Used for workforce planning, capacity forecasting, and case load balancing.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:csatTarget rdf:type rdf:Property ;
    rdfs:label 'Csat Target' ;
    rdfs:comment 'Target Customer Satisfaction (CSAT) score for the team, expressed as a percentage (0-100). Key performance indicator (KPI) for customer experience quality.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Geographic region or market this team serves, using 3-letter ISO country codes or region identifiers (e.g., USA, CAN, GBR, EUR, APAC, GLOBAL). Supports geo-based routing and regional SLA (Service Level Agreement) management.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRemote rdf:type rdf:Property ;
    rdfs:label 'Is Remote' ;
    rdfs:comment 'Indicates whether the team operates remotely (distributed workforce) or from a centralized physical location. True if remote, False if on-site.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageSupport rdf:type rdf:Property ;
    rdfs:label 'Language Support' ;
    rdfs:comment 'Comma-separated list of languages the team can support using ISO 639-1 two-letter codes (e.g., en, es, fr, de, zh, ja). Enables language-based case routing.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsTarget rdf:type rdf:Property ;
    rdfs:label 'Nps Target' ;
    rdfs:comment 'Target Net Promoter Score (NPS) for the team, ranging from -100 to +100. Measures customer loyalty and likelihood to recommend based on team interactions.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatesHolidays rdf:type rdf:Property ;
    rdfs:label 'Operates Holidays' ;
    rdfs:comment 'Indicates whether the team operates on public holidays. True if holiday coverage is provided, False if holidays are non-operational.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatesWeekends rdf:type rdf:Property ;
    rdfs:label 'Operates Weekends' ;
    rdfs:comment 'Indicates whether the team operates on weekends (Saturday and Sunday). True if weekend coverage is provided, False if weekends are non-operational.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary phone number for the team, used for internal escalations and coordination. Organizational contact data, classified as confidential.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalLocation rdf:type rdf:Property ;
    rdfs:label 'Physical Location' ;
    rdfs:comment 'Physical office or site location where the team is based (e.g., New York HQ, Manila Contact Center, Remote). Used for workforce planning and facility management.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryFunction rdf:type rdf:Property ;
    rdfs:label 'Primary Function' ;
    rdfs:comment 'Brief description of the team\'s primary business function and scope of responsibility (e.g., Order inquiries and tracking, Returns and refunds processing, Account and billing support, Technical troubleshooting).' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityScoreTarget rdf:type rdf:Property ;
    rdfs:label 'Quality Score Target' ;
    rdfs:comment 'Target quality assurance score for the team, expressed as a percentage (0-100). Represents the expected standard for case handling quality, monitored through QA audits.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTier rdf:type rdf:Property ;
    rdfs:label 'Sla Tier' ;
    rdfs:comment 'The SLA tier this team is assigned to deliver: standard (baseline service levels), priority (faster response for high-value segments), premium (enhanced service commitments), vip (white-glove service for top customers). Drives case routing and performance targets.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specializationTags rdf:type rdf:Property ;
    rdfs:label 'Specialization Tags' ;
    rdfs:comment 'Comma-separated list of specialization keywords or skill tags that describe the team\'s expertise (e.g., rma, fraud_detection, vip_service, technical_support, billing_disputes). Used for intelligent case routing based on issue type.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetFirstResponseMinutes rdf:type rdf:Property ;
    rdfs:label 'Target First Response Minutes' ;
    rdfs:comment 'Target time in minutes for the team to provide the first response to a customer inquiry, as defined by the team\'s SLA tier. Key performance indicator (KPI) for responsiveness.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetResolutionHours rdf:type rdf:Property ;
    rdfs:label 'Target Resolution Hours' ;
    rdfs:comment 'Target time in hours for the team to resolve a case, as defined by the team\'s SLA tier. Key performance indicator (KPI) for case closure efficiency.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teamCode rdf:type rdf:Property ;
    rdfs:label 'Team Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the team for operational systems and reporting (e.g., T1-FRONT, T2-ESC, RMA-SPEC).' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamName rdf:type rdf:Property ;
    rdfs:label 'Team Name' ;
    rdfs:comment 'Human-readable name of the customer service team (e.g., Tier-1 Frontline Support, Returns Specialist Team, VIP Customer Care).' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamStatus rdf:type rdf:Property ;
    rdfs:label 'Team Status' ;
    rdfs:comment 'Current operational status of the team: active (currently operational and accepting cases), inactive (temporarily not operational), suspended (on hold pending review), dissolved (permanently closed).' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamType rdf:type rdf:Property ;
    rdfs:label 'Team Type' ;
    rdfs:comment 'Classification of the team based on its role in the service organization: tier_1_frontline (first contact resolution), tier_2_escalation (complex issue handling), specialist (domain-specific expertise such as RMA or fraud), back_office (non-customer-facing support), quality_assurance (monitoring and coaching), training (onboarding and skill development).' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByPolicySlaPolicyId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Policy Sla Policy Id' ;
    rdfs:comment 'Reference to the newer SLA policy that replaces this one. Nullable for current active policies. Creates version chain for policy evolution tracking.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaPolicy .

ind:autoEscalationEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Escalation Enabled' ;
    rdfs:comment 'Boolean flag indicating whether automatic escalation is enabled when escalation_threshold_hours is reached. True enables automated escalation workflow, False requires manual escalation.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breachPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Breach Penalty Amount' ;
    rdfs:comment 'Monetary amount of penalty or credit applied when SLA is breached. Applicable when breach_penalty_type is financial or credit. Stored in base currency.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachPenaltyCurrency rdf:type rdf:Property ;
    rdfs:label 'Breach Penalty Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the breach penalty amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachPenaltyType rdf:type rdf:Property ;
    rdfs:label 'Breach Penalty Type' ;
    rdfs:comment 'Type of penalty or action triggered when SLA is breached. Options include no penalty, financial penalty, customer credit, automatic escalation, or notification to management.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessDays rdf:type rdf:Property ;
    rdfs:label 'Business Days' ;
    rdfs:comment 'Comma-separated list of business days when SLA is active (e.g., \'Monday,Tuesday,Wednesday,Thursday,Friday\'). Used when time_calculation_method is business_hours to exclude weekends or specific days.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Business Hours End' ;
    rdfs:comment 'End time of business hours in HH:MM format (24-hour clock) when time_calculation_method is business_hours. Used to calculate SLA compliance during operational hours only.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessHoursStart rdf:type rdf:Property ;
    rdfs:label 'Business Hours Start' ;
    rdfs:comment 'Start time of business hours in HH:MM format (24-hour clock) when time_calculation_method is business_hours. Used to calculate SLA compliance during operational hours only.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casePriority rdf:type rdf:Property ;
    rdfs:label 'Case Priority' ;
    rdfs:comment 'Priority level of cases this SLA policy applies to. Used in conjunction with case_type to form the SLA matrix (e.g., High priority order inquiries have different SLA targets than Low priority inquiries).' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Required' ;
    rdfs:comment 'Boolean flag indicating whether this SLA policy is driven by regulatory compliance requirements (e.g., GDPR data subject request response times, financial services complaint handling). True indicates regulatory mandate.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Numeric escalation tier this SLA policy triggers (e.g., 1 = supervisor, 2 = manager, 3 = director). Defines the organizational level to which cases are escalated when thresholds are breached.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Hours' ;
    rdfs:comment 'Time threshold in hours that triggers automatic escalation if the case is not resolved. Typically set before the resolution target to allow time for escalated handling.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusions rdf:type rdf:Property ;
    rdfs:label 'Exclusions' ;
    rdfs:comment 'Description of cases or conditions excluded from this SLA policy (e.g., \'Excludes cases opened during system maintenance windows\', \'Does not apply to third-party vendor issues\'). Defines policy boundaries.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstResponseTargetHours rdf:type rdf:Property ;
    rdfs:label 'First Response Target Hours' ;
    rdfs:comment 'Target time in hours for the first response to a customer case under this SLA policy. Represents the maximum time allowed before initial acknowledgment or response to the customer.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDefaultPolicy rdf:type rdf:Property ;
    rdfs:label 'Is Default Policy' ;
    rdfs:comment 'Boolean flag indicating whether this is the default SLA policy applied when no specific policy matches a case. Only one policy per case_type should be marked as default.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Notification Enabled' ;
    rdfs:comment 'Boolean flag indicating whether automated notifications are sent when SLA thresholds are approaching or breached. True enables notification workflow.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Notification Threshold Percent' ;
    rdfs:comment 'Percentage of SLA target time elapsed that triggers a warning notification (e.g., 80 means notify when 80% of resolution_target_hours has passed). Used for proactive SLA management.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownerUserCode rdf:type rdf:Property ;
    rdfs:label 'Owner User Code' ;
    rdfs:comment 'Identifier of the business user or manager responsible for defining and maintaining this SLA policy. Typically a customer service director or operations manager.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:policyCode rdf:type rdf:Property ;
    rdfs:label 'Policy Code' ;
    rdfs:comment 'Unique business identifier code for the SLA policy used in operational systems and reporting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Human-readable name of the SLA policy (e.g., \'Premium Support SLA\', \'Standard Response Policy\').' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Classification of the SLA policy indicating the service area it governs (customer support, technical support, returns processing, escalation handling, VIP service, standard service).' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Name of the regulatory framework or law that mandates this SLA policy (e.g., \'GDPR\', \'CCPA\', \'FTC Consumer Protection\', \'PCI DSS\'). Populated when compliance_required is True.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTargetHours rdf:type rdf:Property ;
    rdfs:label 'Resolution Target Hours' ;
    rdfs:comment 'Target time in hours for full resolution of a customer case under this SLA policy. Represents the maximum time allowed to completely resolve and close the case.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaPolicyDescription rdf:type rdf:Property ;
    rdfs:label 'Sla Policy Description' ;
    rdfs:comment 'Detailed description of the SLA policy including its purpose, scope, and any special conditions or exceptions. Provides context for policy application and interpretation.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaPolicyStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Policy Status' ;
    rdfs:comment 'Current lifecycle status of the SLA policy indicating whether it is actively enforced, inactive, in draft state, archived, or temporarily suspended.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Time Calculation Method' ;
    rdfs:comment 'Method used to calculate SLA time targets. Business hours counts only operational hours (e.g., 9am-5pm weekdays), while calendar hours counts all hours including nights and weekends.' ;
    rdfs:domain ind:SlaPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Version number of this SLA policy. Incremented when policy terms are updated. Supports policy change tracking and historical analysis.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationId rdf:type rdf:Property ;
    rdfs:label 'Escalation Id' ;
    rdfs:comment 'Unique identifier for the escalation event. Primary key.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeId rdf:type rdf:Property ;
    rdfs:label 'Dispute Id' ;
    rdfs:comment 'Foreign key linking to marketplace.dispute. Business justification: Marketplace disputes that exceed standard resolution thresholds trigger service escalations. Escalation management and SLA compliance reporting require direct traceability from the escalation record t' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dispute .

ind:escalationEscalatingAgentId rdf:type rdf:Property ;
    rdfs:label 'Escalation Escalating Agent Id' ;
    rdfs:comment 'Reference to the support agent who initiated or triggered the escalation.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:receivingAgentId rdf:type rdf:Property ;
    rdfs:label 'Receiving Agent Id' ;
    rdfs:comment 'Reference to the support agent who received and accepted the escalated case.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:receivingTeamId rdf:type rdf:Property ;
    rdfs:label 'Receiving Team Id' ;
    rdfs:comment 'Reference to the support team or queue to which the case was escalated.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:compensationIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Compensation Issued Flag' ;
    rdfs:comment 'Boolean indicator of whether customer compensation (refund, credit, discount, gift) was issued as part of escalation resolution (True) or not (False).' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compensationType rdf:type rdf:Property ;
    rdfs:label 'Compensation Type' ;
    rdfs:comment 'The type of compensation provided to the customer (e.g., refund, account credit, discount code, gift card, free shipping, product replacement).' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cost rdf:type rdf:Property ;
    rdfs:label 'Cost' ;
    rdfs:comment 'Estimated or actual cost associated with handling the escalation, including labor, compensation, and operational overhead.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationNumber rdf:type rdf:Property ;
    rdfs:label 'Escalation Number' ;
    rdfs:comment 'Human-readable business identifier for the escalation event, formatted as ESC-NNNNNNNN.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'The date and time when the escalation event occurred, formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:escalationType rdf:type rdf:Property ;
    rdfs:label 'Escalation Type' ;
    rdfs:comment 'Classification of the escalation mechanism: functional (to specialist team), hierarchical (to supervisor/manager), automatic (system-triggered), or manual (agent-initiated).' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'The trigger or reason that caused the case to be escalated. Common reasons include SLA (Service Level Agreement) breach, customer demand, case complexity, VIP customer status, regulatory concern, or repeat issue.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionAtEscalatedTierFlag rdf:type rdf:Property ;
    rdfs:label 'Resolution At Escalated Tier Flag' ;
    rdfs:comment 'Boolean indicator of whether the case was successfully resolved at the escalated tier (True) or required further escalation (False).' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionCode rdf:type rdf:Property ;
    rdfs:label 'Resolution Code' ;
    rdfs:comment 'Standardized code indicating how the escalated case was resolved (e.g., refund issued, replacement shipped, technical fix applied).' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetResolutionMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Resolution Minutes' ;
    rdfs:comment 'The target resolution time in minutes as defined by the applicable SLA for the escalated case.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceTier rdf:type rdf:Property ;
    rdfs:label 'Source Tier' ;
    rdfs:comment 'The support tier or level from which the case was escalated.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTier rdf:type rdf:Property ;
    rdfs:label 'Target Tier' ;
    rdfs:comment 'The support tier or level to which the case was escalated.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeToResolutionMinutes rdf:type rdf:Property ;
    rdfs:label 'Time To Resolution Minutes' ;
    rdfs:comment 'The elapsed time in minutes from escalation timestamp to resolution timestamp, used for performance analysis and SLA compliance tracking.' ;
    rdfs:domain ind:Escalation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feedbackResponseId rdf:type rdf:Property ;
    rdfs:label 'Feedback Response Id' ;
    rdfs:comment 'Primary key for feedback_response' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryFeedbackAgentId rdf:type rdf:Property ;
    rdfs:label 'Primary Feedback Agent Id' ;
    rdfs:comment 'Reference to the customer service agent who handled the case being evaluated. Used for agent performance tracking and coaching.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:caseCategory rdf:type rdf:Property ;
    rdfs:label 'Case Category' ;
    rdfs:comment 'The category of the service case that triggered this feedback (e.g., order_inquiry, return_request, product_defect, delivery_issue, account_management, technical_support). Used to analyze satisfaction by case type and identify problem areas.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseResolutionTimeHours rdf:type rdf:Property ;
    rdfs:label 'Case Resolution Time Hours' ;
    rdfs:comment 'The total time in hours from case creation to case closure for the service case being evaluated. Captured at the time of survey to enable correlation analysis between resolution speed and customer satisfaction.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:channelOfService rdf:type rdf:Property ;
    rdfs:label 'Channel Of Service' ;
    rdfs:comment 'The channel through which the customer received service for the case being evaluated. Used to analyze satisfaction by service channel and optimize channel strategy. [ENUM-REF-CANDIDATE: phone|email|chat|social_media|in-app|self-service|store — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationCategory rdf:type rdf:Property ;
    rdfs:label 'Classification Category' ;
    rdfs:comment 'The categorical classification derived from the numeric score. For NPS: promoter (9-10), passive (7-8), detractor (0-6). For CSAT: satisfied (4-5), neutral (3), dissatisfied (1-2). For CES: low_effort (6-7), high_effort (1-3). Used for segmentation and aggregate metrics calculation. [ENUM-REF-CANDIDATE: promoter|passive|detractor|satisfied|neutral|dissatisfied|low_effort|high_effort — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactReason rdf:type rdf:Property ;
    rdfs:label 'Contact Reason' ;
    rdfs:comment 'The specific reason the customer contacted support, as classified by the service team. More granular than case_category, capturing the detailed nature of the inquiry or issue (e.g., damaged_item, late_delivery, wrong_item_shipped, refund_status, promo_code_issue).' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalSurveyReference rdf:type rdf:Property ;
    rdfs:label 'External Survey Reference' ;
    rdfs:comment 'The unique identifier for this survey response in the external survey platform or CRM system. Used for cross-system reconciliation and to link back to the source system for detailed survey metadata.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstContactResolutionFlag rdf:type rdf:Property ;
    rdfs:label 'First Contact Resolution Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer\'s issue was resolved on the first contact without requiring follow-up interactions. Key performance indicator (KPI) for service efficiency and a strong predictor of customer satisfaction.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpActionFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action Flag' ;
    rdfs:comment 'Boolean flag indicating whether this feedback response requires follow-up action from the service team. Typically set to true for detractor responses, low CSAT scores, or when verbatim feedback indicates unresolved issues. Triggers service recovery workflows.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Completed Flag' ;
    rdfs:comment 'Boolean flag indicating whether the required follow-up action has been completed. Used to track closure of service recovery loops and ensure no customer feedback is left unaddressed.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Follow Up Completed Timestamp' ;
    rdfs:comment 'The date and time when the follow-up action was completed. Used to measure time-to-resolution for service recovery and closed-loop feedback processes.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:incentiveOfferedFlag rdf:type rdf:Property ;
    rdfs:label 'Incentive Offered Flag' ;
    rdfs:comment 'Boolean flag indicating whether an incentive (discount, reward points, gift card) was offered to encourage survey completion. Used to analyze response bias and response rate impact of incentives.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numericScore rdf:type rdf:Property ;
    rdfs:label 'Numeric Score' ;
    rdfs:comment 'The numeric rating provided by the customer. For CSAT surveys this is typically 1-5 (1=very dissatisfied, 5=very satisfied). For NPS surveys this is 0-10 (0=not at all likely to recommend, 10=extremely likely). For CES surveys this is typically 1-7 (1=very difficult, 7=very easy).' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryFeedbackTheme rdf:type rdf:Property ;
    rdfs:label 'Primary Feedback Theme' ;
    rdfs:comment 'The main topic or theme identified in the verbatim feedback through text analytics or manual coding. Examples include product_quality, delivery_speed, agent_professionalism, resolution_time, website_usability, pricing, return_process. Used for root cause analysis and improvement prioritization.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDeviceType rdf:type rdf:Property ;
    rdfs:label 'Response Device Type' ;
    rdfs:comment 'Type of device used by the customer to submit the feedback response. Used to analyze response patterns by device and optimize survey design for different form factors.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseLanguage rdf:type rdf:Property ;
    rdfs:label 'Response Language' ;
    rdfs:comment 'ISO 639-1 two-letter language code indicating the language in which the customer provided their feedback. Used for multilingual sentiment analysis and to route feedback to appropriate language-capable service teams.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseStatus rdf:type rdf:Property ;
    rdfs:label 'Response Status' ;
    rdfs:comment 'Status of the survey response. Completed indicates all required questions were answered, partial indicates the survey was started but not finished, abandoned indicates the customer left mid-survey, expired indicates the survey link expired before response, bounced indicates the survey invitation was undeliverable.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'The date and time when the customer submitted their feedback response. Used to calculate response time from survey delivery and to track feedback recency.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sentimentClassification rdf:type rdf:Property ;
    rdfs:label 'Sentiment Classification' ;
    rdfs:comment 'Categorical sentiment classification derived from sentiment score and verbatim text analysis. Positive indicates favorable feedback, negative indicates unfavorable feedback, neutral indicates balanced or no strong sentiment, mixed indicates conflicting sentiments within the same response.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Met Flag' ;
    rdfs:comment 'Boolean flag indicating whether the service case was resolved within the committed SLA timeframe. Used to correlate SLA compliance with customer satisfaction and identify the impact of SLA breaches on customer experience.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surveySentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Survey Sent Timestamp' ;
    rdfs:comment 'The date and time when the survey invitation was sent to the customer. Used to calculate response lag and survey completion rates.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:surveyTriggerEvent rdf:type rdf:Property ;
    rdfs:label 'Survey Trigger Event' ;
    rdfs:comment 'The specific business event that triggered the delivery of this feedback survey. Identifies the touchpoint in the customer journey being measured.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyType rdf:type rdf:Property ;
    rdfs:label 'Survey Type' ;
    rdfs:comment 'Type of customer feedback survey administered. CSAT measures satisfaction with specific interactions (1-5 scale), NPS measures customer loyalty and likelihood to recommend (0-10 scale), CES measures ease of interaction (effort score). Post-Delivery surveys capture feedback after order fulfillment, Relationship surveys are periodic assessments, Post-Case surveys follow service case closure.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyVersion rdf:type rdf:Property ;
    rdfs:label 'Survey Version' ;
    rdfs:comment 'Version identifier of the survey template used. Enables tracking of survey design changes over time and ensures consistent analysis when survey questions or scales are modified.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verbatimFeedbackText rdf:type rdf:Property ;
    rdfs:label 'Verbatim Feedback Text' ;
    rdfs:comment 'Free-form text comments provided by the customer explaining their rating. This qualitative feedback provides context for the numeric score and is used for sentiment analysis, theme extraction, and identifying specific improvement opportunities. Classified as confidential due to potential inclusion of customer-specific details.' ;
    rdfs:domain ind:FeedbackResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listingCategoryId rdf:type rdf:Property ;
    rdfs:label 'Listing Category Id' ;
    rdfs:comment 'Foreign key linking to marketplace.listing_category. Business justification: Knowledge articles are scoped to marketplace listing categories (e.g., hazmat return policies, age-restricted item handling, CPSC compliance guides). Support agents need category-specific articles sur' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ListingCategory .

ind:primaryKnowledgeAuthorAgentId rdf:type rdf:Property ;
    rdfs:label 'Primary Knowledge Author Agent Id' ;
    rdfs:comment 'Identifier of the customer service agent or knowledge manager who authored the article.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:reviewerAgentId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Agent Id' ;
    rdfs:comment 'Identifier of the agent or manager who reviewed and approved the article for publication.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:agentUsageCount rdf:type rdf:Property ;
    rdfs:label 'Agent Usage Count' ;
    rdfs:comment 'Number of times agents have referenced or attached this article during case resolution. Indicates agent knowledge utilization.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:articleNumber rdf:type rdf:Property ;
    rdfs:label 'Article Number' ;
    rdfs:comment 'Externally-visible unique article number used for reference and citation in support interactions. Format: KA-XXXXXXXX.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:articleType rdf:type rdf:Property ;
    rdfs:label 'Article Type' ;
    rdfs:comment 'Classification of the article content type. Determines presentation format and usage context.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attachmentUrls rdf:type rdf:Property ;
    rdfs:label 'Attachment Urls' ;
    rdfs:comment 'Comma-separated list of URLs pointing to supplementary attachments such as PDFs, videos, screenshots, or downloadable resources stored in Content Delivery Network (CDN).' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseDeflectionCount rdf:type rdf:Property ;
    rdfs:label 'Case Deflection Count' ;
    rdfs:comment 'Number of support cases attributed as deflected by this article through self-service resolution. Measured via customer journey tracking.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:caseTypeTags rdf:type rdf:Property ;
    rdfs:label 'Case Type Tags' ;
    rdfs:comment 'Comma-separated list of case types this article is designed to resolve. Links article to specific support case categories.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentBody rdf:type rdf:Property ;
    rdfs:label 'Content Body' ;
    rdfs:comment 'Rich text content body of the article containing the full resolution steps, policy details, or instructional content. May include HTML formatting, images, and embedded media.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:helpfulVotes rdf:type rdf:Property ;
    rdfs:label 'Helpful Votes' ;
    rdfs:comment 'Count of positive helpfulness ratings (thumbs up) received from users who viewed the article.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:helpfulnessScore rdf:type rdf:Property ;
    rdfs:label 'Helpfulness Score' ;
    rdfs:comment 'Calculated helpfulness percentage based on ratio of helpful to total votes. Range 0.00 to 100.00. Used to identify high-quality and low-quality content.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issueTaxonomyTags rdf:type rdf:Property ;
    rdfs:label 'Issue Taxonomy Tags' ;
    rdfs:comment 'Comma-separated list of issue taxonomy tags for categorization and search optimization. Examples: shipping_delay, payment_failure, account_access, product_defect.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knowledgeArticleStatus rdf:type rdf:Property ;
    rdfs:label 'Knowledge Article Status' ;
    rdfs:comment 'Current lifecycle status of the article in the approval and publication workflow.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Updated Date' ;
    rdfs:comment 'Date when the article content was last modified and republished.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locale rdf:type rdf:Property ;
    rdfs:label 'Locale' ;
    rdfs:comment 'Language and region locale code for the article content. Format: ISO 639-1 language code underscore ISO 3166-1 country code (e.g., en_US, es_MX, fr_FR).' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notHelpfulVotes rdf:type rdf:Property ;
    rdfs:label 'Not Helpful Votes' ;
    rdfs:comment 'Count of negative helpfulness ratings (thumbs down) received from users who viewed the article.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publishDate rdf:type rdf:Property ;
    rdfs:label 'Publish Date' ;
    rdfs:comment 'Date when the article was first published and made available to agents or customers.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewByDate rdf:type rdf:Property ;
    rdfs:label 'Review By Date' ;
    rdfs:comment 'Target date by which the article should be reviewed for accuracy and relevance. Used to trigger periodic content audits.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:searchKeywords rdf:type rdf:Property ;
    rdfs:label 'Search Keywords' ;
    rdfs:comment 'Comma-separated list of keywords and phrases optimized for internal search engine indexing and article discovery.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Human-readable title of the knowledge article displayed in search results and article headers.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewCount rdf:type rdf:Property ;
    rdfs:label 'View Count' ;
    rdfs:comment 'Total number of times the article has been viewed by agents or customers. Used to measure article popularity and relevance.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visibilityScope rdf:type rdf:Property ;
    rdfs:label 'Visibility Scope' ;
    rdfs:comment 'Defines the audience scope for article visibility. Determines which user groups can access the article.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandId rdf:type rdf:Property ;
    rdfs:label 'Brand Id' ;
    rdfs:comment 'FK to product.brand' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:primarySellerProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Seller Profile Id' ;
    rdfs:comment 'Foreign key linking to seller.seller_profile. Business justification: REQUIRED: Default Seller Assignment for catalog items, needed for pricing, fulfillment routing and sales reporting; obvious to marketplace operators.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SellerProfile .

ind:asin rdf:type rdf:Property ;
    rdfs:label 'Asin' ;
    rdfs:comment '10-character alphanumeric unique identifier used for product catalog management in Amazon-style marketplaces.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:color rdf:type rdf:Property ;
    rdfs:label 'Color' ;
    rdfs:comment 'Primary color or color variant of the product, used for product differentiation, filtering, and variant management.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpscComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Cpsc Compliance Status' ;
    rdfs:comment 'Indicates whether the product meets CPSC safety standards and regulations, critical for product safety compliance and recall management.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ean rdf:type rdf:Property ;
    rdfs:label 'Ean' ;
    rdfs:comment '13-digit international product identifier used globally for retail scanning and supply chain tracking.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endOfLifeDate rdf:type rdf:Property ;
    rdfs:label 'End Of Life Date' ;
    rdfs:comment 'The date when the product will be or was discontinued and removed from active catalog, used for inventory planning and clearance strategies.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hsCode rdf:type rdf:Property ;
    rdfs:label 'Hs Code' ;
    rdfs:comment 'International standardized system of names and numbers for classifying traded products, used for customs clearance, tariff calculation, and international trade compliance.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAgeRestricted rdf:type rdf:Property ;
    rdfs:label 'Is Age Restricted' ;
    rdfs:comment 'Indicates whether the product has age restrictions for purchase (e.g., alcohol, tobacco, mature content), requiring age verification at checkout.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReturnable rdf:type rdf:Property ;
    rdfs:label 'Is Returnable' ;
    rdfs:comment 'Indicates whether the product is eligible for return under the standard Return Merchandise Authorization (RMA) policy.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxable rdf:type rdf:Property ;
    rdfs:label 'Is Taxable' ;
    rdfs:comment 'Indicates whether the product is subject to sales tax, VAT, or other consumption taxes in applicable jurisdictions.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'The date when the product was first made available for sale on the platform, used for new product performance tracking and lifecycle analytics.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'The legal name of the company that manufactures the product, used for supplier management and compliance tracking.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'The unique part number assigned by the manufacturer, used for warranty claims, technical support, and supplier coordination.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialComposition rdf:type rdf:Property ;
    rdfs:label 'Material Composition' ;
    rdfs:comment 'Description of the materials used in the product construction (e.g., 100% Cotton, Stainless Steel), used for product specifications and compliance labeling.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumAgeRequirement rdf:type rdf:Property ;
    rdfs:label 'Minimum Age Requirement' ;
    rdfs:comment 'The minimum age in years required to purchase this product, enforced during checkout for age-restricted items.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'The specific model identifier assigned by the manufacturer, used for product differentiation and technical specifications lookup.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pimSourceCode rdf:type rdf:Property ;
    rdfs:label 'Pim Source Code' ;
    rdfs:comment 'Unique identifier of this product in the source PIM system, used for data lineage and system integration reconciliation.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pimSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Pim Source System' ;
    rdfs:comment 'Name of the Product Information Management system that is the authoritative source for this catalog item master data.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'The primary display name of the product shown on Product Detail Pages (PDP) and Product Listing Pages (PLP). Used for customer-facing search and discovery.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productSubcategory rdf:type rdf:Property ;
    rdfs:label 'Product Subcategory' ;
    rdfs:comment 'Granular subcategory classification within the product taxonomy, enabling precise product discovery and merchandising strategies.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productTitle rdf:type rdf:Property ;
    rdfs:label 'Product Title' ;
    rdfs:comment 'Extended product title optimized for Search Engine Optimization (SEO) and Search Engine Marketing (SEM), including key attributes and brand information.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'High-level classification of the product category (e.g., Electronics, Apparel, Home & Garden), used for catalog organization and merchandising.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:comment 'Size designation of the product (e.g., Small, Medium, Large, or numeric sizes), used for apparel, footwear, and size-variant products.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sku rdf:type rdf:Property ;
    rdfs:label 'Sku' ;
    rdfs:comment 'Unique alphanumeric identifier for the product used across inventory, order management, and fulfillment systems. The authoritative SKU master identifier.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upc rdf:type rdf:Property ;
    rdfs:label 'Upc' ;
    rdfs:comment '12-digit barcode identifier used for retail scanning and inventory tracking in North America.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Duration Months' ;
    rdfs:comment 'Duration of the manufacturer or seller warranty in months, used for warranty claim validation and customer service.' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyType rdf:type rdf:Property ;
    rdfs:label 'Warranty Type' ;
    rdfs:comment 'Type of warranty coverage provided with the product (manufacturer warranty, seller warranty, extended warranty, or no warranty).' ;
    rdfs:domain ind:CatalogItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightKg rdf:type rdf:Property ;
    rdfs:label 'Weight Kg' ;
    rdfs:comment 'Product weight in kilograms, used for shipping cost calculation, carrier selection, and warehouse capacity planning.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryGeneralLedgerId rdf:type rdf:Property ;
    rdfs:label 'Inventory General Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.general_ledger. Business justification: Needed for inventory valuation accounting; each SKU posts inventory movements to its specific GL account for COGS and stock balance.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneralLedger .

ind:ownerSellerProfileId rdf:type rdf:Property ;
    rdfs:label 'Owner Seller Profile Id' ;
    rdfs:comment 'Foreign key linking to seller.seller_profile. Business justification: REQUIRED: Seller SKU Ownership links each SKU to its owning seller for inventory, compliance and fulfillment decisions; standard in multi-seller marketplaces.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SellerProfile .

ind:ageRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Age Restriction Flag' ;
    rdfs:comment 'Indicates whether this SKU has age verification requirements (e.g., alcohol, tobacco, adult content).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bopisEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Bopis Eligible Flag' ;
    rdfs:comment 'Indicates whether this SKU is eligible for buy online, pick up in store fulfillment.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cpscCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Cpsc Compliant Flag' ;
    rdfs:comment 'Indicates whether this SKU meets CPSC product safety standards and testing requirements.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cpscTrackingLabel rdf:type rdf:Property ;
    rdfs:label 'Cpsc Tracking Label' ;
    rdfs:comment 'CPSC-required tracking label containing manufacturer, production date, batch, and cohort information for children\'s products.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date when this SKU was discontinued and removed from active catalog. Null for active SKUs.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dtcEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Dtc Eligible Flag' ;
    rdfs:comment 'Indicates whether this SKU is eligible for direct-to-consumer shipping from distribution centers.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fbaEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Fba Eligible Flag' ;
    rdfs:comment 'Indicates whether this SKU is eligible for FBA-style fulfillment services (stored in marketplace fulfillment centers).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Indicates whether this SKU is classified as hazardous material requiring special handling and shipping restrictions.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Lot Controlled Flag' ;
    rdfs:comment 'Indicates whether this SKU is tracked by lot or batch number for quality control and traceability.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumAgeYears rdf:type rdf:Property ;
    rdfs:label 'Minimum Age Years' ;
    rdfs:comment 'Minimum age in years required to purchase this SKU. Null if no age restriction applies.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packagingType rdf:type rdf:Property ;
    rdfs:label 'Packaging Type' ;
    rdfs:comment 'Type of packaging required for this SKU (e.g., standard, fragile, oversized, gift wrap, bulk, refrigerated).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perishableFlag rdf:type rdf:Property ;
    rdfs:label 'Perishable Flag' ;
    rdfs:comment 'Indicates whether this SKU is perishable and requires temperature-controlled storage and expedited fulfillment.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serializedFlag rdf:type rdf:Property ;
    rdfs:label 'Serialized Flag' ;
    rdfs:comment 'Indicates whether each unit of this SKU is tracked by unique serial number for warranty, recall, or anti-counterfeiting purposes.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Number of days this SKU remains sellable from receipt date. Null for non-perishable items.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skuCode rdf:type rdf:Property ;
    rdfs:label 'Sku Code' ;
    rdfs:comment 'Unique alphanumeric code identifying this specific sellable variant. The atomic unit tracked by inventory and order systems.' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuStatus rdf:type rdf:Property ;
    rdfs:label 'Sku Status' ;
    rdfs:comment 'Current lifecycle status of the SKU (active, inactive, discontinued, pending approval, blocked, seasonal).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantColor rdf:type rdf:Property ;
    rdfs:label 'Variant Color' ;
    rdfs:comment 'Color dimension of the variant (e.g., Blue, Red, Black, Navy).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantMaterial rdf:type rdf:Property ;
    rdfs:label 'Variant Material' ;
    rdfs:comment 'Material composition of the variant (e.g., Cotton, Polyester, Leather, Stainless Steel).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantName rdf:type rdf:Property ;
    rdfs:label 'Variant Name' ;
    rdfs:comment 'Human-readable name describing this specific variant (e.g., \'Blue Cotton T-Shirt - Size M\').' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantSize rdf:type rdf:Property ;
    rdfs:label 'Variant Size' ;
    rdfs:comment 'Size dimension of the variant (e.g., S, M, L, XL, 32x34, 10.5).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantStyle rdf:type rdf:Property ;
    rdfs:label 'Variant Style' ;
    rdfs:comment 'Style or design dimension of the variant (e.g., Crew Neck, V-Neck, Slim Fit, Classic).' ;
    rdfs:domain ind:Sku ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Category Id' ;
    rdfs:comment 'Reference to the parent category node in the hierarchy. Null for root-level categories. Enables tree traversal and multi-level category structures.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:revenueGeneralLedgerId rdf:type rdf:Property ;
    rdfs:label 'Revenue General Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.general_ledger. Business justification: Category-level revenue GL mapping: e-commerce finance teams post category revenue to specific GL accounts for financial statement segmentation (electronics vs. apparel vs. consumables). Category P&L r' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneralLedger .

ind:averageMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Average Margin Percent' ;
    rdfs:comment 'Average gross margin percentage for products in this category. Used for pricing strategy, promotional planning, and financial forecasting. Business-confidential metric.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Unique alphanumeric business identifier for the category. Used for system integration, API (Application Programming Interface) calls, and internal catalog management.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryDescription rdf:type rdf:Property ;
    rdfs:label 'Category Description' ;
    rdfs:comment 'Detailed textual description of the category displayed on PLP (Product Listing Page) headers. Provides context and improves SEO (Search Engine Optimization) content richness.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Human-readable name of the product category displayed on Product Listing Pages (PLP) and navigation menus. Used for customer-facing catalog browsing.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Percent' ;
    rdfs:comment 'Default commission rate percentage applied to marketplace seller transactions for products in this category. Used for GMV (Gross Merchandise Value) and seller disbursement calculations.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultShippingClass rdf:type rdf:Property ;
    rdfs:label 'Default Shipping Class' ;
    rdfs:comment 'Default shipping class for products in this category. Used for carrier selection, rate calculation, and SLA (Service Level Agreement) determination in TMS (Transportation Management System).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depthLevel rdf:type rdf:Property ;
    rdfs:label 'Depth Level' ;
    rdfs:comment 'Numeric depth of the category node in the hierarchy tree. Root categories are level 0 or 1. Used for tree traversal algorithms and display logic.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:displayOrder rdf:type rdf:Property ;
    rdfs:label 'Display Order' ;
    rdfs:comment 'Numeric sequence controlling the sort order of categories within the same parent level. Lower values appear first in navigation menus and PLP (Product Listing Page).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalCode rdf:type rdf:Property ;
    rdfs:label 'External Code' ;
    rdfs:comment 'Identifier from the source Product Information Management (PIM) system or ERP (Enterprise Resource Planning) system. Used for data integration and reconciliation.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullPath rdf:type rdf:Property ;
    rdfs:label 'Full Path' ;
    rdfs:comment 'Complete hierarchical path from root to current node, typically slash-delimited (e.g., Electronics/Smartphones/Android Phones). Used for breadcrumb navigation and SEO (Search Engine Optimization).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatClassification rdf:type rdf:Property ;
    rdfs:label 'Hazmat Classification' ;
    rdfs:comment 'Hazardous material classification for products in this category. Used for shipping restrictions, carrier selection in TMS (Transportation Management System), and warehouse handling in WMS (Warehouse Management System).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iconUrl rdf:type rdf:Property ;
    rdfs:label 'Icon Url' ;
    rdfs:comment 'URL to the category icon or glyph stored in CDN (Content Delivery Network). Used for compact navigation menus and mobile interfaces.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imageUrl rdf:type rdf:Property ;
    rdfs:label 'Image Url' ;
    rdfs:comment 'URL to the category thumbnail or banner image stored in CDN (Content Delivery Network). Used for visual navigation tiles and PLP (Product Listing Page) headers.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Boolean flag indicating whether the category is currently active and visible to customers. Inactive categories are hidden from navigation and search but retained for historical data.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFeatured rdf:type rdf:Property ;
    rdfs:label 'Is Featured' ;
    rdfs:comment 'Boolean flag indicating whether this category is promoted as a featured category on the homepage or main navigation. Used for merchandising campaigns.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeaf rdf:type rdf:Property ;
    rdfs:label 'Is Leaf' ;
    rdfs:comment 'Boolean flag indicating whether this category is a terminal node (leaf) with no child categories. Leaf categories typically contain SKU (Stock Keeping Unit) assignments.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNavigable rdf:type rdf:Property ;
    rdfs:label 'Is Navigable' ;
    rdfs:comment 'Boolean flag indicating whether this category appears in customer-facing navigation menus. Hidden categories may exist for internal classification only.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSearchable rdf:type rdf:Property ;
    rdfs:label 'Is Searchable' ;
    rdfs:comment 'Boolean flag indicating whether this category is included in site search indexing and autocomplete suggestions. Used to control search faceting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:metaDescription rdf:type rdf:Property ;
    rdfs:label 'Meta Description' ;
    rdfs:comment 'HTML meta description tag content for the category page. Displayed in search engine results snippets to improve CTR (Click-Through Rate).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metaKeywords rdf:type rdf:Property ;
    rdfs:label 'Meta Keywords' ;
    rdfs:comment 'Comma-separated list of keywords associated with the category for search engine indexing and internal search relevance tuning.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metaTitle rdf:type rdf:Property ;
    rdfs:label 'Meta Title' ;
    rdfs:comment 'HTML meta title tag content for the category page. Optimized for search engine ranking and displayed in browser tabs and search results.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCount rdf:type rdf:Property ;
    rdfs:label 'Product Count' ;
    rdfs:comment 'Total number of active SKU (Stock Keeping Unit) products currently assigned to this category. Used for merchandising analytics and empty category detection.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresAgeVerification rdf:type rdf:Property ;
    rdfs:label 'Requires Age Verification' ;
    rdfs:comment 'Boolean flag indicating whether products in this category require age verification at checkout (e.g., alcohol, tobacco). Used for compliance with FTC (Federal Trade Commission) and state regulations.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresCpscCompliance rdf:type rdf:Property ;
    rdfs:label 'Requires Cpsc Compliance' ;
    rdfs:comment 'Boolean flag indicating whether products in this category must comply with CPSC (Consumer Product Safety Commission) safety standards. Used for product onboarding validation.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seoSlug rdf:type rdf:Property ;
    rdfs:label 'Seo Slug' ;
    rdfs:comment 'URL-friendly lowercase hyphenated string used in category page URLs for SEO (Search Engine Optimization) and clean URL structure (e.g., electronics-smartphones).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyStandard rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Standard' ;
    rdfs:comment 'Industry classification standard used for this category (e.g., GS1 Global Product Classification, UNSPSC, eCl@ss). Supports multi-taxonomy mapping for B2B (Business to Business) and marketplace integration.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Updated By User Code' ;
    rdfs:comment 'Identifier of the user or system account that last modified the category record. Used for audit trail and change management.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributeDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Attribute Definition Id' ;
    rdfs:comment 'Unique identifier for the attribute definition within the Product Information Management (PIM) system. Primary key.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AttributeDefinition .

ind:allowedValuesList rdf:type rdf:Property ;
    rdfs:label 'Allowed Values List' ;
    rdfs:comment 'Comma-separated or JSON list of allowed values for enum and multi-select attributes. Defines the controlled vocabulary for categorical attributes.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributeCode rdf:type rdf:Property ;
    rdfs:label 'Attribute Code' ;
    rdfs:comment 'Machine-readable unique code for the attribute, used as the technical identifier in API calls and data integrations. Typically snake_case format.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributeGroup rdf:type rdf:Property ;
    rdfs:label 'Attribute Group' ;
    rdfs:comment 'High-level classification of the attribute for PIM governance (e.g., Core, Marketing, Technical, Compliance, Digital Asset). Used for attribute set management.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributeName rdf:type rdf:Property ;
    rdfs:label 'Attribute Name' ;
    rdfs:comment 'Human-readable name of the attribute displayed in the PIM system and administrative interfaces.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributeStatus rdf:type rdf:Property ;
    rdfs:label 'Attribute Status' ;
    rdfs:comment 'Current lifecycle status of the attribute definition. Active attributes are available for product enrichment; deprecated attributes are phased out; draft attributes are under review; archived attributes are retained for historical data.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether this attribute is required for regulatory compliance (e.g., Consumer Product Safety Commission (CPSC) metadata, General Data Protection Regulation (GDPR) consent tracking).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStandard rdf:type rdf:Property ;
    rdfs:label 'Compliance Standard' ;
    rdfs:comment 'Name of the regulatory standard or governing body that mandates this attribute (e.g., CPSC, GDPR, ISO 27001, PCI DSS). Null for non-compliance attributes.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataType rdf:type rdf:Property ;
    rdfs:label 'Data Type' ;
    rdfs:comment 'The data type that defines the structure and validation rules for attribute values. Determines how the attribute is stored, validated, and rendered on Product Detail Page (PDP) and Product Listing Page (PLP). [ENUM-REF-CANDIDATE: string|numeric|boolean|enum|multi_select|date|rich_text — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultValue rdf:type rdf:Property ;
    rdfs:label 'Default Value' ;
    rdfs:comment 'Default value automatically populated for this attribute when a new product is created in the PIM system. Null if no default is defined.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:displayGroup rdf:type rdf:Property ;
    rdfs:label 'Display Group' ;
    rdfs:comment 'Logical grouping of attributes for organized presentation on PDP and PLP (e.g., Technical Specifications, Dimensions, Compliance). Used to structure attribute rendering.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayLabel rdf:type rdf:Property ;
    rdfs:label 'Display Label' ;
    rdfs:comment 'Customer-facing label for the attribute displayed on PDP and PLP. May differ from the internal attribute name for better user experience.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAttributeCode rdf:type rdf:Property ;
    rdfs:label 'External Attribute Code' ;
    rdfs:comment 'Identifier for this attribute in external systems or third-party integrations (e.g., vendor PIM, industry standard attribute codes). Used for cross-system mapping.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facetDisplayType rdf:type rdf:Property ;
    rdfs:label 'Facet Display Type' ;
    rdfs:comment 'UI component type used to render this attribute as a filter facet on PLP (e.g., checkbox for multi-select, slider for numeric ranges, swatch for colors).' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:helpText rdf:type rdf:Property ;
    rdfs:label 'Help Text' ;
    rdfs:comment 'Instructional text or tooltip displayed to catalog managers during product enrichment to guide accurate data entry.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isComparable rdf:type rdf:Property ;
    rdfs:label 'Is Comparable' ;
    rdfs:comment 'Indicates whether this attribute is displayed in side-by-side product comparison views to help customers evaluate alternatives.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFilterable rdf:type rdf:Property ;
    rdfs:label 'Is Filterable' ;
    rdfs:comment 'Indicates whether this attribute can be used as a facet filter on Product Listing Page (PLP) to narrow search results.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLocalizable rdf:type rdf:Property ;
    rdfs:label 'Is Localizable' ;
    rdfs:comment 'Indicates whether this attribute supports multi-language or region-specific values for international catalog management.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRequired rdf:type rdf:Property ;
    rdfs:label 'Is Required' ;
    rdfs:comment 'Indicates whether this attribute must be populated for a product to be considered complete and publishable. Drives catalog enrichment completeness scoring.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSystemAttribute rdf:type rdf:Property ;
    rdfs:label 'Is System Attribute' ;
    rdfs:comment 'Indicates whether this attribute is a core system attribute managed by the PIM platform (e.g., SKU, UPC, ASIN) versus a custom business attribute.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnique rdf:type rdf:Property ;
    rdfs:label 'Is Unique' ;
    rdfs:comment 'Indicates whether attribute values must be unique across all products (e.g., UPC, EAN, ASIN identifiers). Enforces uniqueness constraints during catalog enrichment.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVisibleOnPdp rdf:type rdf:Property ;
    rdfs:label 'Is Visible On Pdp' ;
    rdfs:comment 'Indicates whether this attribute is displayed on the Product Detail Page (PDP) for customer viewing.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'Username or user identifier of the PIM administrator who last modified this attribute definition.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searchWeight rdf:type rdf:Property ;
    rdfs:label 'Search Weight' ;
    rdfs:comment 'Numeric weight assigned to this attribute for search relevance ranking. Higher weights increase the attributes influence on search result ordering.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationMaxValue rdf:type rdf:Property ;
    rdfs:label 'Validation Max Value' ;
    rdfs:comment 'Maximum allowed value for numeric attributes. Used to enforce data quality rules during catalog enrichment.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationMinValue rdf:type rdf:Property ;
    rdfs:label 'Validation Min Value' ;
    rdfs:comment 'Minimum allowed value for numeric attributes. Used to enforce data quality rules during catalog enrichment.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validationRegexPattern rdf:type rdf:Property ;
    rdfs:label 'Validation Regex Pattern' ;
    rdfs:comment 'Regular expression pattern used to validate string attribute values. Enforces format rules such as SKU patterns, UPC format, or custom identifiers.' ;
    rdfs:domain ind:AttributeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributeValueId rdf:type rdf:Property ;
    rdfs:label 'Attribute Value Id' ;
    rdfs:comment 'Unique identifier for the product attribute value record. Primary key.' ;
    rdfs:domain ind:AttributeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Additional notes or documentation related to compliance status, including references to certifications, test results, or regulatory submissions.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'A numeric score (0-100) representing the completeness and accuracy of the attribute value. Used to prioritize enrichment efforts and ensure high-quality Product Detail Page (PDP) content.' ;
    rdfs:domain ind:AttributeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrichmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrichment Status' ;
    rdfs:comment 'The current status of the attribute value in the enrichment workflow. Tracks whether the value has been validated, enriched, or requires further action.' ;
    rdfs:domain ind:AttributeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrichmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Enrichment Timestamp' ;
    rdfs:comment 'The date and time when the attribute value was last enriched or validated in the PIM system.' ;
    rdfs:domain ind:AttributeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isVariantDefining rdf:type rdf:Property ;
    rdfs:label 'Is Variant Defining' ;
    rdfs:comment 'Indicates whether this attribute value defines a product variant (e.g., size, color) that creates a distinct SKU within a product family.' ;
    rdfs:domain ind:AttributeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localeCode rdf:type rdf:Property ;
    rdfs:label 'Locale Code' ;
    rdfs:comment 'The locale or language code for localized attribute values, following ISO 639-1 language and ISO 3166-1 country format (e.g., en_US, fr_FR, de_DE). Supports multi-language Product Detail Page (PDP) and Product Listing Page (PLP) content.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rawValue rdf:type rdf:Property ;
    rdfs:label 'Raw Value' ;
    rdfs:comment 'The raw string representation of the attribute value as captured from the source system or enrichment process.' ;
    rdfs:domain ind:AttributeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typedValueBoolean rdf:type rdf:Property ;
    rdfs:label 'Typed Value Boolean' ;
    rdfs:comment 'The attribute value when the attribute type is boolean. Used for yes/no or true/false product characteristics.' ;
    rdfs:domain ind:AttributeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:typedValueDate rdf:type rdf:Property ;
    rdfs:label 'Typed Value Date' ;
    rdfs:comment 'The attribute value when the attribute type is date. Used for time-based product attributes such as release date or expiration date.' ;
    rdfs:domain ind:AttributeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:typedValueNumeric rdf:type rdf:Property ;
    rdfs:label 'Typed Value Numeric' ;
    rdfs:comment 'The attribute value when the attribute type is numeric. Enables range filtering and comparison operations.' ;
    rdfs:domain ind:AttributeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typedValueString rdf:type rdf:Property ;
    rdfs:label 'Typed Value String' ;
    rdfs:comment 'The attribute value when the attribute type is string or text. Used for faceted search and filtering.' ;
    rdfs:domain ind:AttributeValue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalAssetId rdf:type rdf:Property ;
    rdfs:label 'Digital Asset Id' ;
    rdfs:comment 'Unique identifier for the product digital asset record. Primary key for this entity.' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessibilityComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Accessibility Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether the asset meets WCAG accessibility standards (alt text, captions, transcripts). Required for regulatory compliance.' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Classification of the digital asset media type. Determines rendering and display logic on PDP and PLP pages.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentType rdf:type rdf:Property ;
    rdfs:label 'Content Type' ;
    rdfs:comment 'Specific content classification within the asset type. Distinguishes between hero images, lifestyle images, product titles, SEO metadata, and other content elements for PDP/PLP presentation. [ENUM-REF-CANDIDATE: hero_image|lifestyle_image|thumbnail|product_video|size_chart|instruction_manual|warranty_document|product_title|short_description|long_description|bullet_points|seo_meta_title|seo_meta_description|seo_canonical_url|seo_keywords|structured_data_markup — 16 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrichmentCompletenessScore rdf:type rdf:Property ;
    rdfs:label 'Enrichment Completeness Score' ;
    rdfs:comment 'Percentage score (0-100) measuring content enrichment quality and completeness. Calculated based on presence of required attributes, SEO metadata, and multi-locale coverage.' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalAssetCode rdf:type rdf:Property ;
    rdfs:label 'External Asset Code' ;
    rdfs:comment 'Unique identifier from the source system or external DAM platform. Enables cross-system reconciliation and integration.' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagsMetadata rdf:type rdf:Property ;
    rdfs:label 'Tags Metadata' ;
    rdfs:comment 'Comma-separated list of descriptive tags for asset categorization and search. Supports content discovery and filtering in DAM systems.' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRightsNotes rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Notes' ;
    rdfs:comment 'Free-text notes describing usage restrictions, attribution requirements, or special licensing terms. Supports legal compliance and rights management.' ;
    rdfs:domain ind:DigitalAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleCode rdf:type rdf:Property ;
    rdfs:label 'Bundle Code' ;
    rdfs:comment 'Externally-known unique business identifier for the bundle, used in catalog systems, order management, and fulfillment. Typically alphanumeric SKU-style code.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleDescription rdf:type rdf:Property ;
    rdfs:label 'Bundle Description' ;
    rdfs:comment 'Detailed marketing description of the bundle, including value proposition, contents summary, and usage scenarios. Displayed on PDP for customer decision-making.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleName rdf:type rdf:Property ;
    rdfs:label 'Bundle Name' ;
    rdfs:comment 'Human-readable name of the bundle displayed on Product Detail Pages (PDP) and Product Listing Pages (PLP).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleStatus rdf:type rdf:Property ;
    rdfs:label 'Bundle Status' ;
    rdfs:comment 'Current lifecycle status of the bundle in the catalog. Controls visibility and sellability across channels.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleType rdf:type rdf:Property ;
    rdfs:label 'Bundle Type' ;
    rdfs:comment 'Classification of the bundle structure: fixed bundle (pre-defined items), configurable bundle (customer selects components), gift set (curated collection), kit (assembly required), promotional bundle (limited-time offer), subscription box (recurring delivery).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertifications rdf:type rdf:Property ;
    rdfs:label 'Compliance Certifications' ;
    rdfs:comment 'Comma-separated list of regulatory certifications and compliance standards the bundle meets (e.g., Consumer Product Safety Commission (CPSC), CE, RoHS, FDA). Required for cross-border trade and marketplace listing approval.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentCount rdf:type rdf:Property ;
    rdfs:label 'Component Count' ;
    rdfs:comment 'Total number of distinct Stock Keeping Units (SKUs) included in the bundle. Used for fulfillment complexity scoring and customer messaging.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crossSellBundleIds rdf:type rdf:Property ;
    rdfs:label 'Cross Sell Bundle Ids' ;
    rdfs:comment 'Comma-separated list of bundle IDs recommended for cross-sell on PDP. Supports recommendation engine and Average Order Value (AOV) optimization.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Discontinued Timestamp' ;
    rdfs:comment 'Timestamp when the bundle was marked as discontinued. Used for product lifecycle reporting and inventory liquidation planning.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:harmonizedTariffCode rdf:type rdf:Property ;
    rdfs:label 'Harmonized Tariff Code' ;
    rdfs:comment 'International trade classification code for customs and duty calculation. Required for cross-border e-commerce and Electronic Data Interchange (EDI) with customs authorities.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConfigurable rdf:type rdf:Property ;
    rdfs:label 'Is Configurable' ;
    rdfs:comment 'Indicates whether customers can customize bundle components (select variants, add-ons, or substitutions) at purchase time.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSubscriptionEligible rdf:type rdf:Property ;
    rdfs:label 'Is Subscription Eligible' ;
    rdfs:comment 'Indicates whether the bundle can be purchased as a recurring subscription with automated replenishment.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:listPrice rdf:type rdf:Property ;
    rdfs:label 'List Price' ;
    rdfs:comment 'Manufacturer\'s suggested retail price (MSRP) or original price before discounts. Used to calculate savings and display strikethrough pricing.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Quantity' ;
    rdfs:comment 'Maximum number of bundle units a customer can purchase in a single order. Used to prevent inventory depletion and manage promotional limits.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Quantity' ;
    rdfs:comment 'Minimum number of bundle units a customer must purchase in a single order. Supports bulk-buy and wholesale scenarios.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modifiedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Modified By User Code' ;
    rdfs:comment 'Reference to the user or system account that last modified the bundle record. Supports change management and SOX compliance.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageDimensionsCm rdf:type rdf:Property ;
    rdfs:label 'Package Dimensions Cm' ;
    rdfs:comment 'Physical dimensions of the bundle package in LxWxH format (centimeters). Used for warehouse slotting, cartonization, and Less Than Truck Load (LTL) / Full Truck Load (FTL) planning.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:price rdf:type rdf:Property ;
    rdfs:label 'Price' ;
    rdfs:comment 'Selling price of the bundle in the base currency. For sum-of-parts strategy, this may be calculated; for fixed price, this is the set amount.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingStrategy rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy' ;
    rdfs:comment 'Method used to calculate bundle price: fixed price (single price regardless of components), sum-of-parts (total of individual SKU prices), discounted (percentage off sum-of-parts), tiered (price varies by quantity), dynamic (algorithmic pricing).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingClass rdf:type rdf:Property ;
    rdfs:label 'Shipping Class' ;
    rdfs:comment 'Shipping method classification for the bundle. Determines carrier eligibility, Service Level Agreement (SLA) targets, and last-mile delivery options.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Concise summary of the bundle for display on PLP, search results, and mobile views. Typically 150-200 characters.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Kg' ;
    rdfs:comment 'Combined shipping weight of all bundle components in kilograms. Used for carrier selection, freight cost calculation, and Transportation Management System (TMS) route optimization.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upsellBundleIds rdf:type rdf:Property ;
    rdfs:label 'Upsell Bundle Ids' ;
    rdfs:comment 'Comma-separated list of higher-value bundle IDs recommended for upsell. Supports Gross Merchandise Value (GMV) growth and Customer Acquisition Cost (CAC) recovery.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleComponentId rdf:type rdf:Property ;
    rdfs:label 'Bundle Component Id' ;
    rdfs:comment 'Unique identifier for the bundle component association record. Primary key.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentGeneralLedgerId rdf:type rdf:Property ;
    rdfs:label 'Component General Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.general_ledger. Business justification: Component-level COGS posting: e-commerce bundle profitability analysis requires each component\'s cost to post to a specific GL account (raw material vs. packaging vs. labor). Finance teams run bundle ' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneralLedger .

ind:primaryBundleSkuId rdf:type rdf:Property ;
    rdfs:label 'Primary Bundle Sku Id' ;
    rdfs:comment 'Reference to the parent bundle product SKU that contains this component.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:assemblyInstructionText rdf:type rdf:Property ;
    rdfs:label 'Assembly Instruction Text' ;
    rdfs:comment 'Textual instructions for warehouse staff on how to assemble or package this component within the bundle. Used during pick-pack-ship operations.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentPriceOverride rdf:type rdf:Property ;
    rdfs:label 'Component Price Override' ;
    rdfs:comment 'Optional component-level pricing override for this SKU within the bundle context. Used when the component has a different price when sold as part of the bundle versus standalone. Null if standard component pricing applies.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentQuantity rdf:type rdf:Property ;
    rdfs:label 'Component Quantity' ;
    rdfs:comment 'The quantity of this component SKU required in the bundle. Supports fractional quantities for items sold by weight or volume.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentRole rdf:type rdf:Property ;
    rdfs:label 'Component Role' ;
    rdfs:comment 'The functional role of this component within the bundle (e.g., primary product, accessory, optional add-on, complementary item, replacement part, or sample).' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentStatus rdf:type rdf:Property ;
    rdfs:label 'Component Status' ;
    rdfs:comment 'Current lifecycle status of this component within the bundle. Active components are available for sale, inactive are temporarily unavailable, discontinued are permanently removed, and pending are awaiting approval.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Component Volume M3' ;
    rdfs:comment 'The volume of this component in cubic meters. Used for calculating total bundle volume for warehouse space planning and shipping container optimization.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentWeightKg rdf:type rdf:Property ;
    rdfs:label 'Component Weight Kg' ;
    rdfs:comment 'The weight of this component in kilograms. Used for calculating total bundle weight for shipping cost estimation and carrier selection.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpscComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Cpsc Compliance Flag' ;
    rdfs:comment 'Indicates whether this component meets Consumer Product Safety Commission (CPSC) safety standards and compliance requirements. True if compliant, False otherwise.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displaySequence rdf:type rdf:Property ;
    rdfs:label 'Display Sequence' ;
    rdfs:comment 'The order in which this component should be displayed in the bundle configurator UI, Product Detail Page (PDP), and fulfillment documentation. Lower numbers appear first.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryReservationPriority rdf:type rdf:Property ;
    rdfs:label 'Inventory Reservation Priority' ;
    rdfs:comment 'Priority level for reserving inventory for this component during bundle order processing. Lower numbers indicate higher priority. Used by Warehouse Management System (WMS) for allocation logic.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isSubstitutable rdf:type rdf:Property ;
    rdfs:label 'Is Substitutable' ;
    rdfs:comment 'Indicates whether this component can be substituted with an alternative SKU during fulfillment if out of stock. True if substitution is allowed, False otherwise.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVisibleToCustomer rdf:type rdf:Property ;
    rdfs:label 'Is Visible To Customer' ;
    rdfs:comment 'Indicates whether this component is visible to the customer on the Product Detail Page (PDP) and Product Listing Page (PLP). False for hidden components like packaging materials or promotional inserts.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'The username or identifier of the user who last modified this bundle component record. Used for audit trail and data governance.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionGroupCode rdf:type rdf:Property ;
    rdfs:label 'Substitution Group Code' ;
    rdfs:comment 'Code identifying the substitution group for this component. Components with the same substitution group code can be interchanged during fulfillment. Null if component is not substitutable.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationId rdf:type rdf:Property ;
    rdfs:label 'Relation Id' ;
    rdfs:comment 'Primary key for relation' ;
    rdfs:domain ind:Relation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSkuId rdf:type rdf:Property ;
    rdfs:label 'Source Sku Id' ;
    rdfs:comment 'Identifier of the source catalog item (SKU) from which the relationship originates. This is the product displayed on the PDP or cart page that triggers the recommendation.' ;
    rdfs:domain ind:Relation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:targetSkuId rdf:type rdf:Property ;
    rdfs:label 'Target Sku Id' ;
    rdfs:comment 'Identifier of the target catalog item (SKU) being recommended or related. This is the product suggested to the customer based on the source SKU.' ;
    rdfs:domain ind:Relation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sku .

ind:clickThroughRate rdf:type rdf:Property ;
    rdfs:label 'Click Through Rate' ;
    rdfs:comment 'Percentage of customers who clicked on the related product recommendation when displayed, calculated as clicks divided by impressions. Used to measure recommendation effectiveness and optimize display logic.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionRate rdf:type rdf:Property ;
    rdfs:label 'Conversion Rate' ;
    rdfs:comment 'Percentage of customers who purchased the related product after clicking the recommendation, calculated as purchases divided by clicks. Key performance indicator (KPI) for recommendation quality and revenue impact.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:displayPosition rdf:type rdf:Property ;
    rdfs:label 'Display Position' ;
    rdfs:comment 'Ordinal position in which the related product should appear in the recommendation widget on the Product Detail Page (PDP) or cart page. Lower numbers indicate higher priority placement.' ;
    rdfs:domain ind:Relation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastPerformanceUpdateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Performance Update Timestamp' ;
    rdfs:comment 'Date and time when the performance metrics (impressions, clicks, conversions, revenue) were last refreshed from the analytics pipeline. Supports data freshness monitoring and Extract Transform Load (ETL) orchestration.' ;
    rdfs:domain ind:Relation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:merchandisingNotes rdf:type rdf:Property ;
    rdfs:label 'Merchandising Notes' ;
    rdfs:comment 'Free-text notes from merchandising team explaining the rationale for the product relationship, special handling instructions, or campaign context. Supports manual curation workflows and knowledge transfer.' ;
    rdfs:domain ind:Relation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Business priority ranking assigned by merchandising team to override algorithmic display position. Lower numbers indicate higher priority. Used for strategic product placement and promotional campaigns.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relationSource rdf:type rdf:Property ;
    rdfs:label 'Relation Source' ;
    rdfs:comment 'Origin or method by which the product relationship was created. Indicates whether the relation was manually curated by merchandising team, generated algorithmically by recommendation engine, submitted by marketplace seller, or derived from specific ML techniques (collaborative filtering, content-based, hybrid).' ;
    rdfs:domain ind:Relation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationType rdf:type rdf:Property ;
    rdfs:label 'Relation Type' ;
    rdfs:comment 'Type of product-to-product relationship. Defines the nature of the recommendation: cross_sell (complementary product), upsell (higher-value alternative), frequently_bought_together (bundle suggestion), accessory (add-on item), replacement (substitute product), spare_part (component or part).' ;
    rdfs:domain ind:Relation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAttributed rdf:type rdf:Property ;
    rdfs:label 'Revenue Attributed' ;
    rdfs:comment 'Total revenue in base currency generated from purchases of the related product that were attributed to this recommendation relationship. Used to measure Return on Ad Spend (ROAS) and recommendation engine effectiveness.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strengthScore rdf:type rdf:Property ;
    rdfs:label 'Strength Score' ;
    rdfs:comment 'Numeric score representing the strength or confidence of the product relationship, typically ranging from 0.0000 to 1.0000. Higher scores indicate stronger associations and higher likelihood of conversion. Used by recommendation algorithms to rank suggestions.' ;
    rdfs:domain ind:Relation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalClicks rdf:type rdf:Property ;
    rdfs:label 'Total Clicks' ;
    rdfs:comment 'Cumulative count of times customers clicked on the related product recommendation. Used to calculate Click-Through Rate (CTR) and Conversion Rate (CVR).' ;
    rdfs:domain ind:Relation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalConversions rdf:type rdf:Property ;
    rdfs:label 'Total Conversions' ;
    rdfs:comment 'Cumulative count of times customers purchased the related product after clicking the recommendation. Used to calculate Conversion Rate (CVR) and measure revenue attribution.' ;
    rdfs:domain ind:Relation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalImpressions rdf:type rdf:Property ;
    rdfs:label 'Total Impressions' ;
    rdfs:comment 'Cumulative count of times the related product recommendation was displayed to customers. Used to calculate Click-Through Rate (CTR) and assess recommendation reach.' ;
    rdfs:domain ind:Relation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentBrandId rdf:type rdf:Property ;
    rdfs:label 'Parent Brand Id' ;
    rdfs:comment 'Foreign key reference to the parent brand if this brand is a sub-brand or brand extension. Null for top-level brands. Enables brand hierarchy modeling for conglomerates and brand families.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:averageRating rdf:type rdf:Property ;
    rdfs:label 'Average Rating' ;
    rdfs:comment 'Aggregated average customer rating for all products under this brand, on a scale of 0.00 to 5.00. Calculated from product reviews. Used for brand reputation scoring and search ranking.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandCode rdf:type rdf:Property ;
    rdfs:label 'Brand Code' ;
    rdfs:comment 'Short alphanumeric code used as a business identifier for the brand in internal systems, reporting, and integrations. Typically 2-20 uppercase characters.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandDescription rdf:type rdf:Property ;
    rdfs:label 'Brand Description' ;
    rdfs:comment 'Marketing description of the brand, including brand story, heritage, and value proposition. Used for brand pages and Search Engine Optimization (SEO).' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'The official registered name of the brand as it appears in the catalog and on Product Detail Pages (PDP) and Product Listing Pages (PLP).' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandStatus rdf:type rdf:Property ;
    rdfs:label 'Brand Status' ;
    rdfs:comment 'Current lifecycle status of the brand in the catalog. Active brands are visible in search and Product Listing Pages (PLP). Inactive and discontinued brands are hidden. Pending approval brands are under review. Suspended brands are temporarily blocked.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertification rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification' ;
    rdfs:comment 'Comma-separated list of compliance certifications held by the brand (e.g., ISO 9001, Fair Trade, Organic, GOTS, B-Corp). Used for compliance filtering and regulatory reporting.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featuredRank rdf:type rdf:Property ;
    rdfs:label 'Featured Rank' ;
    rdfs:comment 'Merchandising rank used to determine the display order of brands on featured brand pages and promotional campaigns. Lower numbers indicate higher priority. Null if not featured.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Exclusive' ;
    rdfs:comment 'Boolean flag indicating whether the brand is sold exclusively on this e-commerce platform. Exclusive brands are featured in marketing campaigns and receive preferential merchandising.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVerified rdf:type rdf:Property ;
    rdfs:label 'Is Verified' ;
    rdfs:comment 'Boolean flag indicating whether the brand has been verified by the platform as an authentic, authorized brand. Verified brands receive trust badges on Product Detail Pages (PDP) and higher search ranking.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturerCountry rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the primary country where products under this brand are manufactured. Used for tariff classification and World Trade Organization (WTO) compliance.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerType rdf:type rdf:Property ;
    rdfs:label 'Owner Type' ;
    rdfs:comment 'Classification of the entity that owns and controls the brand. Values: manufacturer (brand owned by product manufacturer), distributor (brand owned by distribution partner), marketplace_seller (brand owned by third-party seller), private_label (brand owned by the e-commerce platform).' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'The date when the brand was first registered in the Product Information Management (PIM) system and made available for catalog association. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sustainabilityScore rdf:type rdf:Property ;
    rdfs:label 'Sustainability Score' ;
    rdfs:comment 'Numeric sustainability rating for the brand on a scale of 0.00 to 5.00, based on environmental and social governance criteria. Used for eco-conscious customer filtering and Environmental, Social, and Governance (ESG) reporting.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier rdf:type rdf:Property ;
    rdfs:label 'Tier' ;
    rdfs:comment 'Market positioning tier of the brand. Used for pricing strategy, merchandising, and customer segmentation. Values: luxury (high-end designer), premium (aspirational quality), standard (mainstream), value (budget-friendly), private_label (retailer-owned).' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalReviews rdf:type rdf:Property ;
    rdfs:label 'Total Reviews' ;
    rdfs:comment 'Total count of customer reviews submitted for all products under this brand. Used for brand trust signals and Net Promoter Score (NPS) analysis.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSkus rdf:type rdf:Property ;
    rdfs:label 'Total Skus' ;
    rdfs:comment 'Total count of active Stock Keeping Units (SKU) associated with this brand in the catalog. Used for brand breadth analysis and merchandising planning.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trademarkCountry rdf:type rdf:Property ;
    rdfs:label 'Trademark Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the jurisdiction where the trademark is registered. Format: ISO 3166-1 alpha-3.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trademarkNumber rdf:type rdf:Property ;
    rdfs:label 'Trademark Number' ;
    rdfs:comment 'Official trademark registration number issued by the national trademark office. Used for intellectual property verification and counterfeit prevention.' ;
    rdfs:domain ind:Brand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'User identifier or system account that last modified the brand record. Used for audit trail and accountability in compliance with Sarbanes-Oxley Act (SOX) and General Data Protection Regulation (GDPR).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Official website URL of the brand. Used for external brand reference links and customer research.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryZoneId rdf:type rdf:Property ;
    rdfs:label 'Delivery Zone Id' ;
    rdfs:comment 'Foreign key linking to logistics.delivery_zone. Business justification: In e-commerce, a product listing\'s shipping eligibility, SLA promise, and surcharge applicability are determined by its assigned delivery zone. Zone-based listing management drives buy-box eligibility' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryZone .

ind:ageRestriction rdf:type rdf:Property ;
    rdfs:label 'Age Restriction' ;
    rdfs:comment 'The minimum age required to purchase this product, if applicable. Common values: 18 (alcohol, tobacco), 21 (certain regulated products), 13 (COPPA compliance for digital products). Null indicates no age restriction.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buyBoxEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Buy Box Eligible Flag' ;
    rdfs:comment 'Indicates whether this listing is eligible to compete for the buy box on marketplace channels. The buy box is the prominent \'Add to Cart\' section on a product page. Eligibility is determined by factors such as price competitiveness, fulfillment method, seller performance metrics, and inventory availability.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'The sales channel where this product listing is published. Examples: WEB (website), MOBILE (mobile app), MARKETPLACE (third-party marketplace), B2B (business-to-business portal), BOPIS (Buy Online Pick Up In Store), SOCIAL (social commerce platform).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelListingCode rdf:type rdf:Property ;
    rdfs:label 'Channel Listing Code' ;
    rdfs:comment 'The unique identifier assigned by the sales channel for this listing. For Amazon-style marketplaces, this would be the ASIN (Amazon Standard Identification Number). For other channels, this is the channel\'s native product identifier.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compareAtPrice rdf:type rdf:Property ;
    rdfs:label 'Compare At Price' ;
    rdfs:comment 'The original or suggested retail price shown for comparison purposes to highlight discounts. Used to calculate savings percentage displayed on PDP and Product Listing Page (PLP). Null if no comparison pricing is used.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conditionType rdf:type rdf:Property ;
    rdfs:label 'Condition Type' ;
    rdfs:comment 'The physical condition of the product being sold through this listing. New: brand new in original packaging; Refurbished: restored to working condition; Used: previously owned; Open Box: new but packaging opened; Damaged: functional but with cosmetic or minor defects.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eanCode rdf:type rdf:Property ;
    rdfs:label 'Ean Code' ;
    rdfs:comment 'The 13-digit European Article Number barcode identifier for the product. Commonly used in international markets. Equivalent to UPC but with an additional digit for country code.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'The date when this listing will be or was deactivated and removed from the channel. Null indicates no planned end date. Used for seasonal products, limited-time offers, or product lifecycle management.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:featuredFlag rdf:type rdf:Property ;
    rdfs:label 'Featured Flag' ;
    rdfs:comment 'Indicates whether this listing is featured or promoted on the channel\'s homepage, category pages, or marketing campaigns. Featured listings receive higher visibility and priority in search and recommendation algorithms.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fulfillmentMethod rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Method' ;
    rdfs:comment 'The fulfillment strategy for orders placed through this listing. FBM: Fulfilled By Merchant (seller ships); FBA: Fulfillment By Amazon-style (marketplace fulfillment center ships); 3PL: Third-Party Logistics provider; DROPSHIP: direct from manufacturer; BOPIS: Buy Online Pick Up In Store.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryQuantity rdf:type rdf:Property ;
    rdfs:label 'Inventory Quantity' ;
    rdfs:comment 'The current available inventory quantity allocated to this listing on the channel. This may be a subset of total warehouse inventory based on channel allocation rules and safety stock policies. Used to determine Out of Stock (OOS) status and listing suppression.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastSoldTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Sold Timestamp' ;
    rdfs:comment 'The timestamp of the most recent order placed for this listing. Used to identify slow-moving inventory, calculate Daily Sales Rate (DSR), and trigger automated repricing or suppression rules.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:listingStatus rdf:type rdf:Property ;
    rdfs:label 'Listing Status' ;
    rdfs:comment 'Current operational status of the product listing on the channel. Active: live and purchasable; Suppressed: hidden due to quality or compliance issues; Pending: awaiting approval or activation; Inactive: manually disabled; Suspended: temporarily blocked; Archived: permanently removed.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'The maximum number of units a customer can purchase in a single order for this listing. Used to prevent overselling, manage high-demand products, or enforce promotional limits. Null indicates no maximum limit.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionalBadge rdf:type rdf:Property ;
    rdfs:label 'Promotional Badge' ;
    rdfs:comment 'A marketing badge or label displayed on the listing to highlight special offers or features. Examples: \'Best Seller\', \'Limited Time Offer\', \'Free Shipping\', \'New Arrival\', \'Exclusive\'. Used to increase Click-Through Rate (CTR) and Conversion Rate (CVR).' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'A calculated score (0-100) representing the overall quality of the listing based on factors such as content completeness, image quality, keyword optimization, customer reviews, conversion rate (CVR), and compliance with channel guidelines. Higher scores improve search ranking and buy box eligibility.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewCount rdf:type rdf:Property ;
    rdfs:label 'Review Count' ;
    rdfs:comment 'The total number of customer reviews submitted for this listing. Higher review counts increase customer trust and improve search ranking. Used in conjunction with average rating for social proof.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shippingDimensions rdf:type rdf:Property ;
    rdfs:label 'Shipping Dimensions' ;
    rdfs:comment 'The package dimensions in format \'Length x Width x Height\' with unit (e.g., \'30x20x10 cm\'). Used for shipping cost calculation, warehouse space planning, and carrier compatibility checks.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingWeightKg rdf:type rdf:Property ;
    rdfs:label 'Shipping Weight Kg' ;
    rdfs:comment 'The total weight of the product including packaging, measured in kilograms. Used for shipping cost calculation, carrier selection, and logistics planning by the Transportation Management System (TMS).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'The date when this listing was first activated and made available for purchase on the channel. Used for lifecycle tracking and performance analysis.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suppressionReason rdf:type rdf:Property ;
    rdfs:label 'Suppression Reason' ;
    rdfs:comment 'Explanation for why the listing status is \'suppressed\'. Common reasons include: missing required attributes, policy violations, quality issues, pricing errors, inventory unavailability, restricted product category, or failed compliance checks (e.g., CPSC safety standards, PCI DSS for payment-related products).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalUnitsSold rdf:type rdf:Property ;
    rdfs:label 'Total Units Sold' ;
    rdfs:comment 'The cumulative number of units sold through this listing since activation. Used for Best Seller Rank (BSR) calculation, inventory forecasting, and performance reporting.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upcCode rdf:type rdf:Property ;
    rdfs:label 'Upc Code' ;
    rdfs:comment 'The 12-digit Universal Product Code barcode identifier for the product. Required for many retail and marketplace channels. Used for inventory tracking, point-of-sale scanning, and catalog integration.' ;
    rdfs:domain ind:ProductListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountClosedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Account Closed Timestamp' ;
    rdfs:comment 'Timestamp when the customer account was permanently closed or deactivated. Null for active accounts. Used for churn analysis and GDPR right-to-erasure compliance.' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:accountCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Account Created Timestamp' ;
    rdfs:comment 'Timestamp when the customer profile record was first created in the system. Used for audit trails and account age calculations.' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:accountUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Account Updated Timestamp' ;
    rdfs:comment 'Timestamp when the customer profile record was last modified. Used for change tracking and data freshness monitoring.' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:acquisitionChannel rdf:type rdf:Property ;
    rdfs:label 'Acquisition Channel' ;
    rdfs:comment 'Marketing channel through which the customer was originally acquired. Used for CAC (Customer Acquisition Cost) analysis and ROAS (Return on Ad Spend) measurement. [ENUM-REF-CANDIDATE: organic_search|paid_search|social_media|email|affiliate|direct|referral|mobile_app|marketplace|offline — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date when the customer first registered or created an account. Used for cohort analysis and CLTV (Customer Lifetime Value) calculation.' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cdpProfileCode rdf:type rdf:Property ;
    rdfs:label 'Cdp Profile Code' ;
    rdfs:comment 'External identifier from the Customer Data Platform system. Used for unified profile orchestration and cross-system reconciliation.' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'Timestamp when the customer provided or last updated their marketing consent preferences. Required for GDPR consent audit trails.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerType rdf:type rdf:Property ;
    rdfs:label 'Customer Type' ;
    rdfs:comment 'Classification of customer type: B2C (Business to Consumer individual shopper), B2B (Business to Business corporate buyer), C2C (Consumer to Consumer marketplace participant), marketplace_seller (third-party seller), or guest (one-time purchaser without account).' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProcessingConsent rdf:type rdf:Property ;
    rdfs:label 'Data Processing Consent' ;
    rdfs:comment 'Indicates whether the customer has consented to data processing for analytics, personalization, and AI/ML model training. Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Date of birth of the customer. Used for age verification, compliance with age-restricted product regulations, and lifecycle marketing segmentation.' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary email address for customer communication, order confirmations, marketing campaigns, and account recovery. Serves as the primary digital contact channel.' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Email Verified Flag' ;
    rdfs:comment 'Indicates whether the customers email address has been verified through a confirmation link or OTP (One-Time Password). True if verified, False if pending verification.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given name of the customer. Used for personalized communication and segmentation.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'First Purchase Date' ;
    rdfs:comment 'Date of the customers first completed order. Used to measure conversion from registration to first purchase and calculate time-to-first-purchase metrics.' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'Self-identified gender of the customer. Used for personalization and demographic segmentation. Optional field respecting customer privacy preferences.' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycDocumentType rdf:type rdf:Property ;
    rdfs:label 'Kyc Document Type' ;
    rdfs:comment 'Type of identity document submitted for KYC verification. Used for compliance reporting and document expiry tracking. [ENUM-REF-CANDIDATE: passport|drivers_license|national_id|business_license|tax_id|bank_statement|utility_bill — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Expiry Date' ;
    rdfs:comment 'Date when the KYC verification expires and re-verification is required. Typically set based on regulatory requirements or risk assessment policies.' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycFailureReason rdf:type rdf:Property ;
    rdfs:label 'Kyc Failure Reason' ;
    rdfs:comment 'Reason for KYC verification failure if status is failed. Examples: document expired, document unreadable, name mismatch, address mismatch, watchlist match. Used for customer support and fraud investigation.' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Kyc Risk Level' ;
    rdfs:comment 'Risk assessment level assigned to the customer based on KYC verification results, transaction patterns, and fraud signals. Used for enhanced due diligence and transaction monitoring.' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Date' ;
    rdfs:comment 'Date when the KYC identity verification was successfully completed. Used for compliance audit trails and re-verification scheduling.' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycVerificationProvider rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Provider' ;
    rdfs:comment 'Name of the third-party identity verification service provider used for KYC checks (e.g., Jumio, Onfido, Trulioo). Used for audit trails and provider performance analysis.' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Status' ;
    rdfs:comment 'Status of the KYC identity verification process. Required for high-value transactions, B2B accounts, and marketplace sellers to comply with anti-fraud and regulatory requirements.' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycVerificationType rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Type' ;
    rdfs:comment 'Type of identity verification method used for KYC compliance. Government ID includes passport, drivers license, national ID; business registration for B2B customers.' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActiveDate rdf:type rdf:Property ;
    rdfs:label 'Last Active Date' ;
    rdfs:comment 'Date of the customers most recent interaction with any platform touchpoint (login, browse, cart activity, customer service contact). Used for engagement scoring and dormancy detection.' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family name or surname of the customer. Used for identity verification and customer matching.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Date' ;
    rdfs:comment 'Date of the customers most recent completed order. Used for recency scoring in RFM (Recency, Frequency, Monetary) analysis and churn prediction.' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loyaltyPointsBalance rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Balance' ;
    rdfs:comment 'Current balance of loyalty reward points available for redemption. Points are earned through purchases, referrals, reviews, and promotional activities.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyTier rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier' ;
    rdfs:comment 'Current tier level in the customer loyalty program. Determines benefits such as free shipping, exclusive discounts, early access to sales, and priority customer service.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingOptInEmail rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In Email' ;
    rdfs:comment 'Indicates whether the customer has consented to receive marketing emails. True if opted in, False if opted out. Required for GDPR and CAN-SPAM compliance.' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingOptInPush rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In Push' ;
    rdfs:comment 'Indicates whether the customer has consented to receive push notifications through the mobile app. True if opted in, False if opted out.' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingOptInSms rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In Sms' ;
    rdfs:comment 'Indicates whether the customer has consented to receive marketing SMS messages. True if opted in, False if opted out. Required for TCPA compliance.' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Date' ;
    rdfs:comment 'Date when the most recent NPS survey response was collected. Used for tracking sentiment trends over time.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary contact phone number for customer service, delivery coordination, and two-factor authentication. Includes country code and area code.' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Phone Verified Flag' ;
    rdfs:comment 'Indicates whether the customers phone number has been verified through SMS OTP or voice call verification. True if verified, False if pending verification.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredCurrency rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code representing the customers preferred currency for pricing display and transactions.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'ISO 639-2 three-letter language code representing the customers preferred language for communication, user interface, and content delivery.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartySharingConsent rdf:type rdf:Property ;
    rdfs:label 'Third Party Sharing Consent' ;
    rdfs:comment 'Indicates whether the customer has consented to sharing their data with third-party partners for marketing or analytics purposes. Required for CCPA compliance.' ;
    rdfs:domain ind:CustomerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountCustomerAddressId rdf:type rdf:Property ;
    rdfs:label 'Account Customer Address Id' ;
    rdfs:comment 'Reference to the customer\'s preferred shipping address for this account. Pre-populated at checkout for faster order placement.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAddress .

ind:accountDefaultBillingAddressCustomerAddressId rdf:type rdf:Property ;
    rdfs:label 'Account Default Billing Address Customer Address Id' ;
    rdfs:comment 'Reference to the customer\'s preferred billing address for invoices and payment processing. May differ from shipping address for B2B accounts.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAddress .

ind:defaultPaymentMethodId rdf:type rdf:Property ;
    rdfs:label 'Default Payment Method Id' ;
    rdfs:comment 'Reference to the customer\'s preferred payment method for this account. Used for one-click checkout and subscription billing.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Method .

ind:defaultWalletId rdf:type rdf:Property ;
    rdfs:label 'Default Wallet Id' ;
    rdfs:comment 'Foreign key linking to payment.wallet. Business justification: Checkout wallet selection: e-commerce accounts need a designated default digital wallet for one-click checkout and balance-based payments. This FK supports wallet balance display at checkout, auto-deb' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wallet .

ind:accountSource rdf:type rdf:Property ;
    rdfs:label 'Account Source' ;
    rdfs:comment 'Channel through which the account was originally created. Used for Customer Acquisition Cost (CAC) analysis and channel attribution.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Service tier or membership level of the account determining benefits, pricing, and service levels. Standard for basic accounts, Premium for paid memberships, VIP for high-value customers, Enterprise for B2B corporate accounts.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:b2bCompanyName rdf:type rdf:Property ;
    rdfs:label 'B2b Company Name' ;
    rdfs:comment 'Legal company name for B2B corporate accounts. Null for B2C personal accounts. Used for invoicing, tax reporting, and corporate account management.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'Date when the account was permanently closed. Null for active and suspended accounts. Used for churn analysis and retention reporting.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cltvLastCalculatedDate rdf:type rdf:Property ;
    rdfs:label 'Cltv Last Calculated Date' ;
    rdfs:comment 'Date when the CLTV score was last recalculated. CLTV is typically refreshed monthly or quarterly based on updated transaction data.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum credit amount extended to the account for B2B corporate accounts or premium consumer accounts. Null for standard pay-per-order accounts. Used for order approval and risk management.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimitCurrency rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the credit limit amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerLifetimeValue rdf:type rdf:Property ;
    rdfs:label 'Customer Lifetime Value' ;
    rdfs:comment 'Predicted total revenue expected from this account over its lifetime. Calculated by analytics models based on purchase history, frequency, and retention probability. Used for segmentation and marketing investment decisions.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataProcessingConsentDate rdf:type rdf:Property ;
    rdfs:label 'Data Processing Consent Date' ;
    rdfs:comment 'Timestamp when the customer provided data processing consent. Required for GDPR compliance audit trails. Null if data_processing_consent is False.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Order Date' ;
    rdfs:comment 'Date of the most recent order placed by this account. Used for recency-frequency-monetary (RFM) analysis and churn prediction. Null if no orders have been placed.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loyaltyProgramEnrolled rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Enrolled' ;
    rdfs:comment 'Indicates whether the account is enrolled in the company\'s loyalty or rewards program. True if enrolled, False otherwise.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In' ;
    rdfs:comment 'Indicates whether the account holder has consented to receive marketing communications (emails, SMS, push notifications). Managed under GDPR and CCPA consent requirements.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingOptInDate rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In Date' ;
    rdfs:comment 'Timestamp when the customer provided marketing consent. Required for GDPR and CCPA compliance audit trails. Null if marketing_opt_in is False.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:marketplaceSellerFlag rdf:type rdf:Property ;
    rdfs:label 'Marketplace Seller Flag' ;
    rdfs:comment 'Indicates whether this account is also registered as a marketplace seller (C2C model). True if the account holder sells products on the platform, False for buyer-only accounts.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'Date when the account was first opened and activated. Used for calculating account tenure and Customer Lifetime Value (CLTV).' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Current outstanding balance owed by the account holder for credit-based accounts. Represents unpaid invoices and charges. Zero for prepaid accounts.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referralCode rdf:type rdf:Property ;
    rdfs:label 'Referral Code' ;
    rdfs:comment 'Referral or promotional code used during account registration. Used for tracking referral program effectiveness and attributing customer acquisition.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScoreLastUpdated rdf:type rdf:Property ;
    rdfs:label 'Risk Score Last Updated' ;
    rdfs:comment 'Timestamp when the fraud risk score was last recalculated. Risk scores are updated in real-time or near-real-time based on transaction patterns and fraud signals.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalOrderCount rdf:type rdf:Property ;
    rdfs:label 'Total Order Count' ;
    rdfs:comment 'Lifetime count of orders placed by this account. Used for customer segmentation and loyalty tier calculation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerAddressId rdf:type rdf:Property ;
    rdfs:label 'Customer Address Id' ;
    rdfs:comment 'Unique identifier for the address record. Primary key.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAddress .

ind:priceZoneId rdf:type rdf:Property ;
    rdfs:label 'Price Zone Id' ;
    rdfs:comment 'Foreign key linking to pricing.price_zone. Business justification: Customer addresses determine applicable price zones for geographic pricing, regional tax rates, and delivery surcharges. E-commerce pricing engines resolve the correct price list by mapping a customer' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceZone .

ind:addressStatus rdf:type rdf:Property ;
    rdfs:label 'Address Status' ;
    rdfs:comment 'Current lifecycle status of the address record. Active = currently usable, inactive = temporarily disabled, archived = historical record, flagged = requires review due to delivery failures or fraud indicators.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classification of address purpose: shipping (delivery destination), billing (invoice address), registered (legal/account address), pickup (BOPIS location), return (RMA destination).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentMarketingFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Marketing Flag' ;
    rdfs:comment 'Boolean flag indicating whether the customer has consented to receive marketing communications at this address. Required for GDPR and CCPA compliance. Used by Marketing Automation Platform for campaign targeting.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryInstructions rdf:type rdf:Property ;
    rdfs:label 'Delivery Instructions' ;
    rdfs:comment 'Special delivery instructions provided by the customer for this address (e.g., gate code, leave at door, ring bell, call upon arrival). Used by last-mile delivery carriers and 3PL (Third-Party Logistics) providers.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failedDeliveryCount rdf:type rdf:Property ;
    rdfs:label 'Failed Delivery Count' ;
    rdfs:comment 'Number of failed delivery attempts to this address. Used for address quality scoring and to flag problematic addresses. High count triggers address verification workflow.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstUsedDate rdf:type rdf:Property ;
    rdfs:label 'First Used Date' ;
    rdfs:comment 'Date when this address was first used for an order or transaction. Used for address age analysis and Customer Lifetime Value (CLTV) modeling.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geocodingAccuracy rdf:type rdf:Property ;
    rdfs:label 'Geocoding Accuracy' ;
    rdfs:comment 'Precision level of the geocoded coordinates. Rooftop = exact building location, range_interpolated = estimated within address range, geometric_center = center of postal code area, approximate = city/region level. Impacts delivery time estimation accuracy.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBopisEligible rdf:type rdf:Property ;
    rdfs:label 'Is Bopis Eligible' ;
    rdfs:comment 'Boolean flag indicating whether this address is eligible for BOPIS (Buy Online Pick Up In Store) fulfillment. True if address is within serviceable radius of a store or pickup location with inventory availability.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultBilling rdf:type rdf:Property ;
    rdfs:label 'Is Default Billing' ;
    rdfs:comment 'Boolean flag indicating whether this is the customers preferred default billing address. Used for payment processing, invoice generation, and tax calculation. Only one address per customer should have this flag set to true.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultShipping rdf:type rdf:Property ;
    rdfs:label 'Is Default Shipping' ;
    rdfs:comment 'Boolean flag indicating whether this is the customers preferred default shipping address. Used for checkout pre-population and Order Management System (OMS) fulfillment routing. Only one address per customer should have this flag set to true.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMilitaryAddress rdf:type rdf:Property ;
    rdfs:label 'Is Military Address' ;
    rdfs:comment 'Boolean flag indicating whether this is a military address (APO, FPO, DPO). Military addresses have special handling requirements, customs exemptions, and carrier restrictions. Used for fulfillment routing and compliance.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPoBox rdf:type rdf:Property ;
    rdfs:label 'Is Po Box' ;
    rdfs:comment 'Boolean flag indicating whether this is a PO Box address. Some carriers and products cannot deliver to PO Boxes. Used for fulfillment eligibility checks and carrier selection.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVerifiedByCustomer rdf:type rdf:Property ;
    rdfs:label 'Is Verified By Customer' ;
    rdfs:comment 'Boolean flag indicating whether the customer has explicitly confirmed this address is correct. Used to reduce failed deliveries and Return Merchandise Authorization (RMA) costs. Set to true after successful delivery or customer confirmation.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'Date when this address was most recently used for an order or transaction. Used for address recency analysis and inactive address cleanup.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line 1' ;
    rdfs:comment 'Primary street address line including street number, street name, and unit/apartment/suite number. First line of physical or mailing address.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line 2' ;
    rdfs:comment 'Secondary address line for additional location details such as building name, floor, department, or c/o information. Optional supplementary address information.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nickname rdf:type rdf:Property ;
    rdfs:label 'Nickname' ;
    rdfs:comment 'Customer-defined friendly name for the address (e.g., Home, Office, Moms House, Vacation Home). Used for easy address selection during checkout in Customer Relationship Management (CRM) and e-commerce platforms.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residentialCommercialFlag rdf:type rdf:Property ;
    rdfs:label 'Residential Commercial Flag' ;
    rdfs:comment 'Classification of address as residential (home delivery) or commercial (business delivery). Impacts carrier selection, delivery time windows, signature requirements, and shipping costs. Commercial addresses may have different Service Level Agreement (SLA) options.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceableByCarrier rdf:type rdf:Property ;
    rdfs:label 'Serviceable By Carrier' ;
    rdfs:comment 'Comma-separated list of carrier codes that can service this address (e.g., UPS, FEDEX, USPS, DHL). Determined by Transportation Management System (TMS) based on carrier coverage maps and Service Level Agreement (SLA) capabilities. Used for carrier selection during fulfillment.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Total number of times this address has been used across all orders and transactions. Used for address preference analysis and fraud detection (unusually high usage may indicate drop-shipping or fraud).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validationSource rdf:type rdf:Property ;
    rdfs:label 'Validation Source' ;
    rdfs:comment 'Name of the address verification service or postal authority used to validate the address (e.g., USPS, Google Maps API, Loqate, Melissa Data, Canada Post). Null if unvalidated.' ;
    rdfs:domain ind:CustomerAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Status of address verification against postal authority databases. Validated = confirmed deliverable, unvalidated = not yet checked, failed = undeliverable, corrected = standardized by validation service, partial = some components verified.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportsToContactId rdf:type rdf:Property ;
    rdfs:label 'Reports To Contact Id' ;
    rdfs:comment 'Reference to the contact_id of the person this contact reports to within the customer organization. Enables organizational hierarchy mapping and approval escalation workflows.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:approvalLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Approval Limit Amount' ;
    rdfs:comment 'Maximum monetary amount (in account base currency) that this contact is authorized to approve for purchase orders without escalation. Used in B2B purchase approval workflows.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assistantEmail rdf:type rdf:Property ;
    rdfs:label 'Assistant Email' ;
    rdfs:comment 'Email address of the contact\'s executive assistant. Used for meeting scheduling and communication coordination in high-value B2B accounts.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assistantName rdf:type rdf:Property ;
    rdfs:label 'Assistant Name' ;
    rdfs:comment 'Name of the contact\'s executive assistant or administrative support person. Used for scheduling and communication routing in enterprise B2B accounts.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assistantPhone rdf:type rdf:Property ;
    rdfs:label 'Assistant Phone' ;
    rdfs:comment 'Phone number of the contact\'s executive assistant. Used for urgent communication routing and meeting coordination.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationLevel rdf:type rdf:Property ;
    rdfs:label 'Authorization Level' ;
    rdfs:comment 'Level of authorization and permissions granted to the contact within the customer account. Determines purchase approval limits, account management capabilities, and data access rights.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact record. Active contacts can receive communications and perform authorized actions; inactive contacts are retained for historical reference but cannot transact.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classification of the contact role within the account structure. Determines routing of specific communication types and approval workflows. [ENUM-REF-CANDIDATE: primary|billing|shipping|technical|procurement|finance|legal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deactivated Timestamp' ;
    rdfs:comment 'Timestamp when the contact was deactivated or marked inactive. Null for active contacts. Used for contact lifecycle analysis and retention reporting.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deactivationReason rdf:type rdf:Property ;
    rdfs:label 'Deactivation Reason' ;
    rdfs:comment 'Free-text explanation of why the contact was deactivated (e.g., left company, role change, duplicate record, customer request). Used for contact churn analysis and data quality improvement.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailOptIn rdf:type rdf:Property ;
    rdfs:label 'Email Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the contact has opted in to receive marketing and promotional email communications. Managed under GDPR consent requirements and CAN-SPAM Act compliance.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalContactCode rdf:type rdf:Property ;
    rdfs:label 'External Contact Code' ;
    rdfs:comment 'Contact identifier from the source system or external CRM platform. Used for cross-system reconciliation and integration mapping.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Boolean flag indicating whether this contact is the primary point of contact for the customer account. Primary contacts receive all general account communications and have highest authorization level.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Job title or role of the contact within their organization (e.g., Procurement Manager, Finance Director, Shipping Coordinator). Used for routing communications and approvals to the appropriate role.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedinProfileUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Profile Url' ;
    rdfs:comment 'URL to the contact\'s LinkedIn professional profile. Used for B2B relationship management, account intelligence, and professional network mapping.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'Mobile phone number for the contact. Used for SMS notifications, two-factor authentication, and mobile-first communication channels.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneOptIn rdf:type rdf:Property ;
    rdfs:label 'Phone Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the contact has opted in to receive phone call communications for marketing purposes. Managed under TCPA compliance and do-not-call registry requirements.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'Contact\'s preferred method of communication for non-urgent account matters. Used to optimize communication delivery and improve contact engagement rates.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsOptIn rdf:type rdf:Property ;
    rdfs:label 'Sms Opt In' ;
    rdfs:comment 'Boolean flag indicating whether the contact has opted in to receive SMS text message communications. Managed under TCPA compliance and GDPR consent requirements.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the contact\'s location (e.g., America/New_York, Europe/London). Used for scheduling communications and calls during appropriate business hours.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyProgramId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Id' ;
    rdfs:comment 'Unique identifier for the loyalty program. Primary key.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyProgram .

ind:scopedCategoryId rdf:type rdf:Property ;
    rdfs:label 'Scoped Category Id' ;
    rdfs:comment 'Foreign key linking to product.category. Business justification: Category-scoped loyalty programs (e.g., double points on Electronics) are a standard e-commerce promotional mechanic. Program managers configure which product category earns bonus points. A domain exp' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:sponsoringBrandId rdf:type rdf:Property ;
    rdfs:label 'Sponsoring Brand Id' ;
    rdfs:comment 'Reference to the brand entity that sponsors or owns this loyalty program. Nullable for platform-wide programs.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:applicableCustomerSegments rdf:type rdf:Property ;
    rdfs:label 'Applicable Customer Segments' ;
    rdfs:comment 'Comma-separated list or description of customer segments eligible for this loyalty program (e.g., B2C, B2B, premium customers, geographic regions).' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoEnrollmentFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Enrollment Flag' ;
    rdfs:comment 'Indicates whether customers are automatically enrolled in this loyalty program upon account creation (True) or must opt-in manually (False).' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cashbackPercentage rdf:type rdf:Property ;
    rdfs:label 'Cashback Percentage' ;
    rdfs:comment 'Percentage of purchase amount returned as cashback to the customer. Applicable for cashback and hybrid programs.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentEnrollmentCount rdf:type rdf:Property ;
    rdfs:label 'Current Enrollment Count' ;
    rdfs:comment 'Current number of customers actively enrolled in this loyalty program.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earnRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Earn Rate Multiplier' ;
    rdfs:comment 'Multiplier applied to base earning rate for this program (e.g., 2.0 means customers earn points at twice the standard rate).' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentEligibilityRules rdf:type rdf:Property ;
    rdfs:label 'Enrollment Eligibility Rules' ;
    rdfs:comment 'Business rules defining which customer segments or criteria qualify for enrollment in this loyalty program (e.g., geographic restrictions, customer type requirements, minimum purchase thresholds).' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'Username or identifier of the user who last modified this loyalty program record.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxEnrollmentCount rdf:type rdf:Property ;
    rdfs:label 'Max Enrollment Count' ;
    rdfs:comment 'Maximum number of customers allowed to enroll in this loyalty program. Null indicates no enrollment cap.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerCoalitionFlag rdf:type rdf:Property ;
    rdfs:label 'Partner Coalition Flag' ;
    rdfs:comment 'Indicates whether this loyalty program is part of a coalition with external partner brands (True) or is a standalone program (False).' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pointsCurrencyConversionRate rdf:type rdf:Property ;
    rdfs:label 'Points Currency Conversion Rate' ;
    rdfs:comment 'The conversion rate from loyalty points to base currency (e.g., 100 points = 1 USD). Applicable for points-based and hybrid programs.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsExpirationPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Points Expiration Period Days' ;
    rdfs:comment 'Number of days after which earned loyalty points expire if not redeemed. Null indicates points do not expire.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:privacyPolicyUrl rdf:type rdf:Property ;
    rdfs:label 'Privacy Policy Url' ;
    rdfs:comment 'URL link to the privacy policy explaining how customer data is collected, used, and protected within the loyalty program.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Unique business identifier code for the loyalty program, used for external references and integrations.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDescription rdf:type rdf:Property ;
    rdfs:label 'Program Description' ;
    rdfs:comment 'Detailed description of the loyalty program benefits, features, and value proposition for marketing and customer communication.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Program Manager Email' ;
    rdfs:comment 'Email address of the program manager for internal contact and escalation purposes.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programManagerName rdf:type rdf:Property ;
    rdfs:label 'Program Manager Name' ;
    rdfs:comment 'Name of the business owner or manager responsible for this loyalty program.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'The marketing name of the loyalty program displayed to customers.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle status of the loyalty program: active (accepting enrollments and accruals), inactive (not accepting new enrollments), suspended (temporarily paused), draft (under development), or archived (historical record).' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the loyalty program structure: points-based (earn and redeem points), tier-based (status levels with benefits), cashback (percentage return), subscription (paid membership), hybrid (combination), or coalition (multi-brand partnership).' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionMinimumPoints rdf:type rdf:Property ;
    rdfs:label 'Redemption Minimum Points' ;
    rdfs:comment 'Minimum number of points required before a customer can redeem rewards. Applicable for points-based programs.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subscriptionBillingFrequency rdf:type rdf:Property ;
    rdfs:label 'Subscription Billing Frequency' ;
    rdfs:comment 'Frequency at which subscription fees are charged: monthly, quarterly, annual, or one-time.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Subscription Fee Amount' ;
    rdfs:comment 'Recurring fee amount charged for subscription-based loyalty programs (e.g., annual membership fee).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:termsConditionsUrl rdf:type rdf:Property ;
    rdfs:label 'Terms Conditions Url' ;
    rdfs:comment 'URL link to the full terms and conditions document governing the loyalty program, required for regulatory compliance and customer transparency.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierThresholdBronze rdf:type rdf:Property ;
    rdfs:label 'Tier Threshold Bronze' ;
    rdfs:comment 'Minimum points or spend required to achieve bronze tier status. Applicable for tier-based programs.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierThresholdGold rdf:type rdf:Property ;
    rdfs:label 'Tier Threshold Gold' ;
    rdfs:comment 'Minimum points or spend required to achieve gold tier status. Applicable for tier-based programs.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierThresholdPlatinum rdf:type rdf:Property ;
    rdfs:label 'Tier Threshold Platinum' ;
    rdfs:comment 'Minimum points or spend required to achieve platinum tier status. Applicable for tier-based programs.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierThresholdSilver rdf:type rdf:Property ;
    rdfs:label 'Tier Threshold Silver' ;
    rdfs:comment 'Minimum points or spend required to achieve silver tier status. Applicable for tier-based programs.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentChannelId rdf:type rdf:Property ;
    rdfs:label 'Enrollment Channel Id' ;
    rdfs:comment 'Foreign key linking to marketing.channel. Business justification: Channel performance analysis for loyalty acquisition: which marketing channels (email, push, social, in-app) drive loyalty enrollments is a standard e-commerce KPI. Replaces denormalized string \'enrol' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:primaryLoyaltyCustomerProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Loyalty Customer Profile Id' ;
    rdfs:comment 'Unique identifier of the customer enrolled in the loyalty program. Links to the customer master record.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerProfile .

ind:sourceCampaignId rdf:type rdf:Property ;
    rdfs:label 'Source Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: Loyalty acquisition attribution: linking enrollment to the originating campaign enables campaign ROI measurement (cost-per-enrollment, LTV of campaign-acquired loyalty members). E-commerce marketers r' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Indicates whether the loyalty membership is set to automatically renew at the end of the term. Applicable for paid or subscription-based loyalty programs.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'Date when the loyalty enrollment was cancelled. Null if enrollment has never been cancelled.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentPointsBalance rdf:type rdf:Property ;
    rdfs:label 'Current Points Balance' ;
    rdfs:comment 'Current available points balance that the customer can redeem. Represents the net of all earned, redeemed, expired, and adjusted points. This is the real-time spendable loyalty currency balance.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentTier rdf:type rdf:Property ;
    rdfs:label 'Current Tier' ;
    rdfs:comment 'Current tier or level of the customer within the loyalty program hierarchy. Determines benefits, earning rates, and redemption privileges. Common tiers include Bronze, Silver, Gold, Platinum, Diamond, and VIP.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date when the customer enrolled in the loyalty program. Marks the beginning of the customer\'s loyalty relationship.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Human-readable unique enrollment number or membership number assigned to the customer for this loyalty program. Used for customer service and member identification.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of the loyalty enrollment. Active indicates the member can earn and redeem points; suspended indicates temporary hold; expired indicates membership lapsed; cancelled indicates voluntary or involuntary termination; pending indicates enrollment awaiting activation.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent loyalty activity (earn, redeem, or adjustment). Used for inactivity detection and dormancy rules.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastEarnDate rdf:type rdf:Property ;
    rdfs:label 'Last Earn Date' ;
    rdfs:comment 'Date when the customer last earned loyalty points. Used for engagement scoring, churn prediction, and reactivation campaigns.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRedeemDate rdf:type rdf:Property ;
    rdfs:label 'Last Redeem Date' ;
    rdfs:comment 'Date when the customer last redeemed loyalty points. Used for engagement analysis and redemption behavior modeling.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimePointsEarned rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Earned' ;
    rdfs:comment 'Cumulative total of all points earned by the customer since enrollment. Used for tier qualification, lifetime value analysis, and member recognition. This is a monotonically increasing counter.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimePointsExpired rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Expired' ;
    rdfs:comment 'Cumulative total of all points that have expired due to inactivity or program rules since enrollment. Used for breakage analysis and financial reconciliation.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimePointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Redeemed' ;
    rdfs:comment 'Cumulative total of all points redeemed by the customer since enrollment. Used for engagement analysis and redemption behavior modeling.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:membershipFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Membership Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the membership fee. Used for multi-currency loyalty programs.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipFeePaid rdf:type rdf:Property ;
    rdfs:label 'Membership Fee Paid' ;
    rdfs:comment 'Total membership fee paid by the customer for enrollment or renewal in the loyalty program. Zero for free programs.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextTierGap rdf:type rdf:Property ;
    rdfs:label 'Next Tier Gap' ;
    rdfs:comment 'Remaining points or spend needed to reach the next tier. Calculated as next_tier_threshold minus current qualifying activity. Used for personalized tier progression campaigns.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextTierThreshold rdf:type rdf:Property ;
    rdfs:label 'Next Tier Threshold' ;
    rdfs:comment 'Points or spend threshold required to qualify for the next loyalty tier. Used for gamification and tier progression messaging. Null if customer is already at the highest tier.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optInEmail rdf:type rdf:Property ;
    rdfs:label 'Opt In Email' ;
    rdfs:comment 'Indicates whether the customer has opted in to receive loyalty program communications via email.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInMarketing rdf:type rdf:Property ;
    rdfs:label 'Opt In Marketing' ;
    rdfs:comment 'Indicates whether the customer has opted in to receive marketing communications related to the loyalty program. Supports GDPR and CCPA consent management.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInPushNotification rdf:type rdf:Property ;
    rdfs:label 'Opt In Push Notification' ;
    rdfs:comment 'Indicates whether the customer has opted in to receive loyalty program push notifications via mobile app.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInSms rdf:type rdf:Property ;
    rdfs:label 'Opt In Sms' ;
    rdfs:comment 'Indicates whether the customer has opted in to receive loyalty program communications via SMS text messages.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pointsExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Points Expiry Date' ;
    rdfs:comment 'Date when the next batch of points is scheduled to expire. Used for customer communication and expiry alerts. Null if no points are scheduled to expire or program has no expiration policy.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reactivationDate rdf:type rdf:Property ;
    rdfs:label 'Reactivation Date' ;
    rdfs:comment 'Date when a previously suspended or expired enrollment was reactivated. Used for win-back campaign analysis.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'Date when the loyalty enrollment was suspended. Null if enrollment has never been suspended.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Reason for suspension of the loyalty enrollment, if status is suspended. Examples include fraud investigation, terms violation, payment failure, or customer request.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Tier Expiry Date' ;
    rdfs:comment 'Date when the current tier status expires and the customer must re-qualify or be downgraded. Null for lifetime tiers or programs without tier expiration.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierQualificationDate rdf:type rdf:Property ;
    rdfs:label 'Tier Qualification Date' ;
    rdfs:comment 'Date when the customer qualified for their current loyalty tier. Used to track tier tenure and calculate tier anniversary dates.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierQualifyingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Tier Qualifying Period End' ;
    rdfs:comment 'End date of the current tier qualification period. After this date, tier status is re-evaluated based on qualifying activity.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierQualifyingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Tier Qualifying Period Start' ;
    rdfs:comment 'Start date of the current tier qualification period. Used to calculate rolling qualification windows and reset tier progress.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierQualifyingSpend rdf:type rdf:Property ;
    rdfs:label 'Tier Qualifying Spend' ;
    rdfs:comment 'Total spend amount that counts toward tier qualification in the current qualification period. Used when tier status is based on spend rather than points earned.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetProductCategoryId rdf:type rdf:Property ;
    rdfs:label 'Target Product Category Id' ;
    rdfs:comment 'Foreign key linking to product.product_category. Business justification: Needed for segment-to-category targeting: segments are defined by the product categories they are intended to reach in marketing reports.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:activatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activated Timestamp' ;
    rdfs:comment 'Timestamp when the segment was first activated and made available for campaign targeting and personalization. Null if segment has never been activated.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:applicableChannels rdf:type rdf:Property ;
    rdfs:label 'Applicable Channels' ;
    rdfs:comment 'Comma-separated list of marketing and engagement channels where this segment is intended to be used (e.g., email, SMS, push notification, display ads, social media, in-app messaging). [ENUM-REF-CANDIDATE: email|sms|push|display|social|in_app|direct_mail|call_center|web_personalization|mobile_app — promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assignment Method' ;
    rdfs:comment 'Method used to assign customers to this segment: rule_based (criteria-driven), ml_model (machine learning prediction), manual (curated list), hybrid (combination of methods).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineMetricValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Metric Value' ;
    rdfs:comment 'Baseline or benchmark value for the performance_metric_kpi, used to measure segment lift and incremental impact. Established at segment creation or from control group analysis.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessOwner rdf:type rdf:Property ;
    rdfs:label 'Business Owner' ;
    rdfs:comment 'Name or identifier of the individual business owner accountable for segment strategy, performance, and compliance.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Compliant Flag' ;
    rdfs:comment 'Indicates whether this segment definition and processing logic comply with CCPA requirements for consumer rights, opt-out mechanisms, and data sale restrictions (True) or require review (False).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentPurpose rdf:type rdf:Property ;
    rdfs:label 'Consent Purpose' ;
    rdfs:comment 'Specific consent purpose or legal basis for processing customer data in this segment (e.g., marketing communications, personalized recommendations, analytics). Required when consent_required_flag is True.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Required Flag' ;
    rdfs:comment 'Indicates whether explicit customer consent is required for inclusion in this segment under GDPR, CCPA, or other privacy regulations (True) or if legitimate interest applies (False).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusionRules rdf:type rdf:Property ;
    rdfs:label 'Exclusion Rules' ;
    rdfs:comment 'Logical expression defining criteria for excluding customers from this segment (e.g., opted out of marketing, fraudulent account, employee account, test account).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant Flag' ;
    rdfs:comment 'Indicates whether this segment definition and processing logic comply with GDPR requirements for lawful processing, data minimization, and purpose limitation (True) or require review (False).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Timestamp' ;
    rdfs:comment 'Timestamp of the most recent segment membership recalculation and update. Used to track data freshness and SLA compliance.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:memberCount rdf:type rdf:Property ;
    rdfs:label 'Member Count' ;
    rdfs:comment 'Current number of active customer profiles assigned to this segment. Updated with each segment refresh.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mlModelReference rdf:type rdf:Property ;
    rdfs:label 'Ml Model Reference' ;
    rdfs:comment 'Reference identifier or URI to the ML model used for predictive or propensity-based segment assignment (e.g., churn prediction model, next-best-offer model). Null for rule-based segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User identifier or email of the person who last modified the segment definition. Used for audit trail and change tracking.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Refresh Timestamp' ;
    rdfs:comment 'Timestamp of the next scheduled segment membership recalculation. Null for on-demand or real-time segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:overlapAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Overlap Allowed Flag' ;
    rdfs:comment 'Indicates whether customers can be members of this segment and other segments simultaneously (True) or if this segment enforces mutual exclusivity (False).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:owningTeam rdf:type rdf:Property ;
    rdfs:label 'Owning Team' ;
    rdfs:comment 'Business team or department responsible for defining, maintaining, and governing this segment (e.g., Marketing, CRM, Analytics, Retention).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceMetricKpi rdf:type rdf:Property ;
    rdfs:label 'Performance Metric Kpi' ;
    rdfs:comment 'Primary KPI used to measure segment performance and business impact (e.g., CVR, ROAS, CLTV, NPS, churn rate, AOV). Used for segment effectiveness tracking and optimization.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency' ;
    rdfs:comment 'Cadence at which segment membership is recalculated and updated: real_time (streaming), hourly, daily, weekly, monthly, on_demand (manual trigger).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Retention Period Days' ;
    rdfs:comment 'Number of days that segment membership records are retained for compliance, audit, and historical analysis purposes before archival or deletion.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ruleExpression rdf:type rdf:Property ;
    rdfs:label 'Rule Expression' ;
    rdfs:comment 'Logical expression or SQL-like query defining the segment membership criteria for rule-based segments (e.g., AOV > 200 AND purchase_count >= 3 AND last_purchase_days <= 90). Null for ML-model-based segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed business description of the segment purpose, target audience characteristics, and intended use cases (e.g., marketing campaigns, personalization, retention programs).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable name of the customer segment (e.g., High-Value Shoppers, Cart Abandoners, Loyal Customers).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle status of the segment: active (in use), inactive (paused), draft (under development), archived (historical reference), deprecated (replaced by newer version).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSize rdf:type rdf:Property ;
    rdfs:label 'Target Size' ;
    rdfs:comment 'Intended or target number of members for this segment, used for capacity planning and campaign sizing. Null if no target is defined.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:useCase rdf:type rdf:Property ;
    rdfs:label 'Use Case' ;
    rdfs:comment 'Primary business use case or campaign objective for this segment (e.g., acquisition, retention, cross-sell, upsell, win-back, personalization, A/B testing, churn prevention).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version identifier for the segment definition, enabling tracking of rule changes, A/B testing variants, and historical comparison (e.g., v1.0, v2.3, 2024-Q1).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceId rdf:type rdf:Property ;
    rdfs:label 'Preference Id' ;
    rdfs:comment 'Unique identifier for the customer preference record. Primary key.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketingCampaignId rdf:type rdf:Property ;
    rdfs:label 'Marketing Campaign Id' ;
    rdfs:comment 'Identifier of the marketing campaign that triggered or is associated with this preference capture. Nullable if the preference was not captured in the context of a specific campaign. Links to campaign performance analysis.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:parentPreferenceId rdf:type rdf:Property ;
    rdfs:label 'Parent Preference Id' ;
    rdfs:comment 'Identifier of the parent preference record if this preference is a channel-specific override of a global preference. Nullable for top-level global preferences. Enables hierarchical preference inheritance.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Preference .

ind:preferredBrandId rdf:type rdf:Property ;
    rdfs:label 'Preferred Brand Id' ;
    rdfs:comment 'Foreign key linking to product.brand. Business justification: Brand preferences drive personalized homepage recommendations, email campaigns, and search ranking in e-commerce. Distinct from item-level preference (preferred_catalog_item_id already exists). A pers' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Brand .

ind:preferredCatalogItemId rdf:type rdf:Property ;
    rdfs:label 'Preferred Catalog Item Id' ;
    rdfs:comment 'Foreign key linking to product.catalog_item. Business justification: Supports personalized recommendation engine: captures a customer\'s explicit preference for a specific catalog item.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CatalogItem .

ind:preferredCategoryId rdf:type rdf:Property ;
    rdfs:label 'Preferred Category Id' ;
    rdfs:comment 'Foreign key linking to product.category. Business justification: Category preferences (e.g., \'prefers Electronics, Sports\') are a foundational personalization signal used in recommendation engines, browse personalization, and targeted email campaigns. Distinct from' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The channel through which this preference applies or was captured. Enables channel-specific preference management and omnichannel consent orchestration.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentText rdf:type rdf:Property ;
    rdfs:label 'Consent Text' ;
    rdfs:comment 'The full text of the consent statement or privacy notice that was presented to the customer at the time of preference capture. Stored for regulatory audit and proof of consent.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Version' ;
    rdfs:comment 'The version identifier of the consent text or privacy policy that the customer agreed to when setting this preference. Enables audit trail of consent changes over time.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Period Days' ;
    rdfs:comment 'Number of days this preference record and associated consent data must be retained for regulatory compliance and audit purposes. Used to enforce data retention policies and right to erasure.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceCode rdf:type rdf:Property ;
    rdfs:label 'Device Code' ;
    rdfs:comment 'Unique identifier of the device from which the preference was set. Used for device-level consent tracking and cross-device preference synchronization.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doubleOptInConfirmed rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Confirmed' ;
    rdfs:comment 'Boolean flag indicating whether the customer has confirmed their opt-in preference through a double opt-in process (e.g., email confirmation link). Required for certain marketing channels under GDPR.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doubleOptInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Timestamp' ;
    rdfs:comment 'The timestamp when the customer confirmed their opt-in preference through the double opt-in process. Nullable if double opt-in is not required or not yet completed.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:frequencyCap rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap' ;
    rdfs:comment 'Maximum number of communications allowed per time period for this preference category. Used to enforce customer-specified communication frequency limits and prevent over-messaging.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyPeriod rdf:type rdf:Property ;
    rdfs:label 'Frequency Period' ;
    rdfs:comment 'The time period over which the frequency cap applies. Defines the window for counting communications against the frequency cap.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hash rdf:type rdf:Property ;
    rdfs:label 'Hash' ;
    rdfs:comment 'Cryptographic hash of the preference record content. Used for tamper detection, data integrity verification, and proof of consent immutability for regulatory audit.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'The IP address from which the preference was set. Captured for fraud detection, audit trail, and proof of consent. May be considered PII under GDPR in certain jurisdictions.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGlobalPreference rdf:type rdf:Property ;
    rdfs:label 'Is Global Preference' ;
    rdfs:comment 'Boolean flag indicating whether this preference applies globally across all channels and touchpoints, or is specific to a single channel. Supports hierarchical preference management.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalBasis rdf:type rdf:Property ;
    rdfs:label 'Legal Basis' ;
    rdfs:comment 'The GDPR Article 6 legal basis under which this preference and associated data processing is justified. Critical for GDPR compliance and regulatory audit.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceCategory rdf:type rdf:Property ;
    rdfs:label 'Preference Category' ;
    rdfs:comment 'The category or type of preference being captured. Defines the communication channel or data usage purpose for which consent is being managed.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceSource rdf:type rdf:Property ;
    rdfs:label 'Preference Source' ;
    rdfs:comment 'The origin or method by which this preference was captured. Indicates whether the preference was set by the customer directly, by a customer service agent, imported from an external system, or defaulted by the system.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Preference Status' ;
    rdfs:comment 'Current lifecycle status of this preference record. Indicates whether the preference is currently in effect, has expired, been superseded by a newer preference, or revoked by the customer.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceValue rdf:type rdf:Property ;
    rdfs:label 'Preference Value' ;
    rdfs:comment 'The explicit choice made by the customer for this preference category. Indicates whether the customer has consented to or declined the specific communication or data usage.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rightToBeForgottenRequested rdf:type rdf:Property ;
    rdfs:label 'Right To Be Forgotten Requested' ;
    rdfs:comment 'Boolean flag indicating whether the customer has exercised their GDPR Article 17 right to erasure (right to be forgotten) for this preference and associated data. Triggers data deletion workflows.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rightToBeForgottenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Right To Be Forgotten Timestamp' ;
    rdfs:comment 'The timestamp when the customer requested their right to be forgotten. Nullable if no such request has been made. Used for compliance tracking and audit trail.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Calculated score representing the strength or confidence of this preference based on customer behavior, engagement history, and preference consistency. Used for predictive personalization and preference inference.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionCategory rdf:type rdf:Property ;
    rdfs:label 'Suppression Category' ;
    rdfs:comment 'Categorical classification of the suppression reason. Enables structured analysis of opt-out patterns and compliance reporting.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartySharingPartners rdf:type rdf:Property ;
    rdfs:label 'Third Party Sharing Partners' ;
    rdfs:comment 'Comma-separated list of third-party partner identifiers with whom the customer has consented to share their data. Used for granular third-party data sharing consent management under GDPR and CCPA.' ;
    rdfs:domain ind:Preference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userAgent rdf:type rdf:Property ;
    rdfs:label 'User Agent' ;
    rdfs:comment 'The user agent string of the browser or application from which the preference was set. Provides technical context for audit and troubleshooting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentEventId rdf:type rdf:Property ;
    rdfs:label 'Consent Event Id' ;
    rdfs:comment 'Unique identifier for each consent event record. Primary key for the consent event log.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentConsentEventId rdf:type rdf:Property ;
    rdfs:label 'Parent Consent Event Id' ;
    rdfs:comment 'Reference to a previous consent event that this event modifies or supersedes. Enables tracking of consent change chains and audit trail reconstruction.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsentEvent .

ind:collectionMethod rdf:type rdf:Property ;
    rdfs:label 'Collection Method' ;
    rdfs:comment 'Channel or interface through which the consent event was captured. Identifies the touchpoint where the customer interacted with consent management.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationLanguage rdf:type rdf:Property ;
    rdfs:label 'Communication Language' ;
    rdfs:comment 'Two-letter ISO 639-1 language code representing the language in which the consent was presented and captured. Ensures consent was obtained in the customer\'s preferred language.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentCategory rdf:type rdf:Property ;
    rdfs:label 'Consent Category' ;
    rdfs:comment 'Category of consent or preference being managed. Defines the specific processing purpose or communication channel covered by this consent event.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentScope rdf:type rdf:Property ;
    rdfs:label 'Consent Scope' ;
    rdfs:comment 'Geographic or operational scope to which this consent applies. Defines the boundaries of consent applicability across different jurisdictions or business units.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerEmail rdf:type rdf:Property ;
    rdfs:label 'Customer Email' ;
    rdfs:comment 'Email address of the customer at the time of the consent event. Captured for verification and communication purposes in consent lifecycle management.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Type of consent event that occurred. Categorizes the nature of the customer\'s action for regulatory reporting and lifecycle tracking.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date when this consent is set to expire and require renewal. Used for time-bound consent management and automated re-consent workflows.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geolocationCountry rdf:type rdf:Property ;
    rdfs:label 'Geolocation Country' ;
    rdfs:comment 'Three-letter ISO country code representing the geographic location from which the consent event originated. Used for jurisdiction-specific compliance reporting.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geolocationRegion rdf:type rdf:Property ;
    rdfs:label 'Geolocation Region' ;
    rdfs:comment 'State, province, or region from which the consent event originated. Provides additional geographic context for jurisdiction-specific privacy laws (e.g., CCPA for California).' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMinor rdf:type rdf:Property ;
    rdfs:label 'Is Minor' ;
    rdfs:comment 'Indicates whether the customer was identified as a minor (under age of consent) at the time of this event. Critical for GDPR Article 8 and COPPA compliance.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newValue rdf:type rdf:Property ;
    rdfs:label 'New Value' ;
    rdfs:comment 'The consent status after this event was applied. Represents the current state resulting from the customer\'s action.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optOutSaleFlag rdf:type rdf:Property ;
    rdfs:label 'Opt Out Sale Flag' ;
    rdfs:comment 'Indicates whether the customer has exercised their right to opt out of the sale of personal information under CCPA. Must be honored across all business processes.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalConsentRequired rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Required' ;
    rdfs:comment 'Indicates whether parental or guardian consent was required for this event due to the customer being a minor. Used for COPPA and GDPR Article 8 compliance tracking.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalConsentVerified rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Verified' ;
    rdfs:comment 'Indicates whether parental or guardian consent was successfully verified for this event. Critical for processing consent events for minors under COPPA and GDPR.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorValue rdf:type rdf:Property ;
    rdfs:label 'Prior Value' ;
    rdfs:comment 'The consent status before this event occurred. Captures the previous state to enable audit trail reconstruction and change tracking.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing Completed Timestamp' ;
    rdfs:comment 'Date and time when the consent event was fully processed and applied across all relevant systems. Used to measure compliance with GDPR\'s one-month response requirement.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processingPurpose rdf:type rdf:Property ;
    rdfs:label 'Processing Purpose' ;
    rdfs:comment 'Detailed description of the specific purpose for which personal data will be processed under this consent. Must be explicit and granular per GDPR requirements.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingStatus rdf:type rdf:Property ;
    rdfs:label 'Processing Status' ;
    rdfs:comment 'Current processing status of the consent event. Tracks whether the event has been successfully applied to downstream systems and customer profiles.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionCode rdf:type rdf:Property ;
    rdfs:label 'Session Code' ;
    rdfs:comment 'Unique identifier for the user session during which the consent event occurred. Enables correlation with other user actions in the same session for behavioral analysis.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartySharingAllowed rdf:type rdf:Property ;
    rdfs:label 'Third Party Sharing Allowed' ;
    rdfs:comment 'Indicates whether the customer has consented to sharing their personal data with third parties. Critical for CCPA \'Do Not Sell\' compliance and GDPR Article 6 lawful basis.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify the identity of the customer before processing the consent event. Critical for data deletion and portability requests to prevent fraud.' ;
    rdfs:domain ind:ConsentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status of identity verification for this consent event. Indicates whether the customer\'s identity was successfully confirmed before processing the request.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wishlistId rdf:type rdf:Property ;
    rdfs:label 'Wishlist Id' ;
    rdfs:comment 'Unique identifier for the wishlist. Primary key.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wishlist .

ind:archivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archived Timestamp' ;
    rdfs:comment 'Timestamp when the wishlist was archived by the customer or system. Null if never archived. Supports lifecycle reporting and data retention policies.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:conversionCount rdf:type rdf:Property ;
    rdfs:label 'Conversion Count' ;
    rdfs:comment 'Number of items from this wishlist that have been purchased by the owner or gift contributors. Measures wishlist effectiveness and purchase intent conversion.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deleted Timestamp' ;
    rdfs:comment 'Timestamp when the wishlist was soft-deleted. Null if active. Supports GDPR right-to-erasure and data retention compliance. Hard deletion occurs after retention period.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'Target date for gift registries (wedding date, baby due date, birthday). Used to trigger expiration logic and prioritize gift-giving urgency. Null for non-event wishlists.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isDefault rdf:type rdf:Property ;
    rdfs:label 'Is Default' ;
    rdfs:comment 'Indicates whether this is the customer\'s default wishlist. When a customer adds an item without specifying a wishlist, it goes to the default. Only one wishlist per customer can be default.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemCount rdf:type rdf:Property ;
    rdfs:label 'Item Count' ;
    rdfs:comment 'Total number of active line items currently in the wishlist. Excludes removed or purchased items. Updated in real-time as items are added or removed.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastViewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Viewed Timestamp' ;
    rdfs:comment 'Timestamp when the customer last opened or viewed this wishlist. Used for engagement scoring and re-engagement campaign targeting.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationBackInStockEnabled rdf:type rdf:Property ;
    rdfs:label 'Notification Back In Stock Enabled' ;
    rdfs:comment 'Customer preference flag indicating whether to send notifications when out-of-stock items in this wishlist become available again. Drives conversion from latent demand.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationEventReminderEnabled rdf:type rdf:Property ;
    rdfs:label 'Notification Event Reminder Enabled' ;
    rdfs:comment 'Customer preference flag for gift registries indicating whether to send reminders as the event date approaches. Helps drive gift purchases from registry contributors.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationPriceDropEnabled rdf:type rdf:Property ;
    rdfs:label 'Notification Price Drop Enabled' ;
    rdfs:comment 'Customer preference flag indicating whether to send notifications when any item in this wishlist experiences a price reduction. Supports re-engagement campaigns.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privacyConsentMarketing rdf:type rdf:Property ;
    rdfs:label 'Privacy Consent Marketing' ;
    rdfs:comment 'Customer consent flag indicating permission to use wishlist data for personalized marketing campaigns (price drop alerts, recommendations, promotions). Required under GDPR and CCPA.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privacyConsentSharing rdf:type rdf:Property ;
    rdfs:label 'Privacy Consent Sharing' ;
    rdfs:comment 'Customer consent flag indicating explicit permission to share wishlist data with third parties (e.g., gift registry partners, social media). Required under GDPR and CCPA.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registryCompletionPercentage rdf:type rdf:Property ;
    rdfs:label 'Registry Completion Percentage' ;
    rdfs:comment 'For gift registries, the percentage of items that have been purchased by contributors. Calculated as (purchased_items / total_items) * 100. Null for non-registry wishlists.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shareCount rdf:type rdf:Property ;
    rdfs:label 'Share Count' ;
    rdfs:comment 'Number of times the wishlist sharing URL has been generated or distributed. Tracks viral/social engagement for gift registries.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sharingToken rdf:type rdf:Property ;
    rdfs:label 'Sharing Token' ;
    rdfs:comment 'Secure token embedded in sharing URL for access control. Prevents unauthorized access to shared wishlists. Regenerated if sharing is disabled and re-enabled.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sharingUrl rdf:type rdf:Property ;
    rdfs:label 'Sharing Url' ;
    rdfs:comment 'Unique shareable URL for gift registries and shared wishlists. Enables customers to distribute wishlist access to friends and family without requiring account login.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'Channel through which the wishlist was originally created (web browser, mobile app, API integration, customer service agent). Used for channel attribution and UX optimization.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDeviceType rdf:type rdf:Property ;
    rdfs:label 'Source Device Type' ;
    rdfs:comment 'Device type used when the wishlist was created. Supports device-specific personalization and responsive design optimization.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCurrentValue rdf:type rdf:Property ;
    rdfs:label 'Total Current Value' ;
    rdfs:comment 'Sum of all item prices at current market rates. Recalculated nightly or on-demand. Enables price drop alerts and conversion optimization. Currency is USD unless otherwise specified.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalValueAtSave rdf:type rdf:Property ;
    rdfs:label 'Total Value At Save' ;
    rdfs:comment 'Sum of all item prices at the time they were added to the wishlist. Provides baseline for price change tracking and demand forecasting. Currency is USD unless otherwise specified.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viewCountByOthers rdf:type rdf:Property ;
    rdfs:label 'View Count By Others' ;
    rdfs:comment 'Number of times the wishlist has been viewed by users other than the owner (gift contributors, shared link recipients). Measures gift registry engagement.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visibility rdf:type rdf:Property ;
    rdfs:label 'Visibility' ;
    rdfs:comment 'Access control setting for the wishlist. Private: only owner can view; Public: discoverable by others; Shared Link: accessible via unique URL.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wishlistDescription rdf:type rdf:Property ;
    rdfs:label 'Wishlist Description' ;
    rdfs:comment 'Optional customer-provided description or notes about the wishlist purpose, occasion, or preferences. Supports gift registry messaging and personalization.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wishlistName rdf:type rdf:Property ;
    rdfs:label 'Wishlist Name' ;
    rdfs:comment 'Customer-defined name for the wishlist (e.g., \'Birthday Gifts\', \'Home Office Setup\', \'Wedding Registry\'). Enables customers to organize multiple wishlists by purpose.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wishlistStatus rdf:type rdf:Property ;
    rdfs:label 'Wishlist Status' ;
    rdfs:comment 'Current lifecycle state of the wishlist. Active: in use; Archived: preserved but inactive; Expired: past event date for registries; Deleted: soft-deleted pending purge.' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wishlistType rdf:type rdf:Property ;
    rdfs:label 'Wishlist Type' ;
    rdfs:comment 'Classification of the wishlist purpose. Personal wishlists are private shopping lists; gift registries are shared for events (weddings, baby showers); shared wishlists allow collaborative curation. [ENUM-REF-CANDIDATE: personal|gift_registry|shared|wedding_registry|baby_registry|holiday|wishlist — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Wishlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultCarrierId rdf:type rdf:Property ;
    rdfs:label 'Default Carrier Id' ;
    rdfs:comment 'Foreign key linking to logistics.carrier. Business justification: Default carrier per fulfillment center drives automated carrier selection in the \'Shipment Creation\' workflow.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:managerAgentId rdf:type rdf:Property ;
    rdfs:label 'Manager Agent Id' ;
    rdfs:comment 'Foreign key linking to service.agent. Business justification: Each fulfillment center is overseen by a manager agent responsible for operations; linking enables manager-level performance dashboards and incident escalation.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:operatorSupplierId rdf:type rdf:Property ;
    rdfs:label 'Operator Supplier Id' ;
    rdfs:comment 'Foreign key linking to procurement.supplier. Business justification: 3PL-operated fulfillment centers must be linked to their supplier record for contract management, performance scoring, and invoice reconciliation. partner_operator_name is a denormalized text field th' ;
    rdfs:domain ind:Center ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address line for the fulfillment center physical location, including street number and name.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address line for additional location details such as building, suite, or floor number.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'Degree of automation in fulfillment operations: manual (human-driven), semi-automated (mix of manual and automated processes), fully automated (end-to-end automation), or robotic (advanced robotics and AI).' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availableCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Available Capacity Units' ;
    rdfs:comment 'Current available storage capacity in the fulfillment center, representing unused storage units available for new inventory allocation.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit Of Measure' ;
    rdfs:comment 'Unit of measurement used to quantify storage capacity: pallets, bins, cubic feet, cubic meters, square feet, or square meters.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:centerCode rdf:type rdf:Property ;
    rdfs:label 'Center Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code for the fulfillment center, used in operational systems and partner integrations.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:centerName rdf:type rdf:Property ;
    rdfs:label 'Center Name' ;
    rdfs:comment 'Human-readable name of the fulfillment center, used for display and reporting purposes.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary contact email address for the fulfillment center operations team, used for internal coordination and partner communication.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary contact phone number for the fulfillment center operations team, used for internal coordination and partner communication.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cutoffTimeLocal rdf:type rdf:Property ;
    rdfs:label 'Cutoff Time Local' ;
    rdfs:comment 'Daily cutoff time in local time zone (HH:MM format) by which orders must be received to qualify for same-day processing and shipment.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyThroughputCapacity rdf:type rdf:Property ;
    rdfs:label 'Daily Throughput Capacity' ;
    rdfs:comment 'Maximum number of orders or units the fulfillment center can process per day under normal operating conditions, used for capacity planning and order allocation.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:erpSiteCode rdf:type rdf:Property ;
    rdfs:label 'Erp Site Code' ;
    rdfs:comment 'Site or plant code in the ERP system (e.g., SAP S/4HANA) that corresponds to this fulfillment center, used for financial and supply chain integration.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'Date when the fulfillment center commenced operations and began processing orders.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operates247 rdf:type rdf:Property ;
    rdfs:label 'Operates 24 7' ;
    rdfs:comment 'Boolean flag indicating whether the fulfillment center operates continuously (true) or has scheduled operating hours (false).' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Standard operating hours for the fulfillment center if not 24/7, formatted as day ranges and time ranges (e.g., Mon-Fri 08:00-18:00, Sat 09:00-15:00).' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational state of the fulfillment center in its lifecycle: active (fully operational), inactive (not processing orders), under construction (pre-launch), temporarily closed (planned downtime), decommissioned (permanently closed), or seasonal (operates during peak periods only).' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipModel rdf:type rdf:Property ;
    rdfs:label 'Ownership Model' ;
    rdfs:comment 'Ownership and operational model of the fulfillment center: owned (company-owned and operated), leased (company-operated but leased facility), third-party operated (3PL partner), or hybrid (shared operations).' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardProcessingTimeHours rdf:type rdf:Property ;
    rdfs:label 'Standard Processing Time Hours' ;
    rdfs:comment 'Standard time in hours from order receipt to shipment dispatch under normal operating conditions, used for SLA calculations and customer promise dates.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportedFulfillmentMethods rdf:type rdf:Property ;
    rdfs:label 'Supported Fulfillment Methods' ;
    rdfs:comment 'Comma-separated list of fulfillment methods supported by this center: standard_shipping, expedited_shipping, same_day_delivery, next_day_delivery, bopis, ship_from_store, white_glove, etc.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportsColdStorage rdf:type rdf:Property ;
    rdfs:label 'Supports Cold Storage' ;
    rdfs:comment 'Boolean flag indicating whether the fulfillment center has refrigerated or frozen storage capabilities for temperature-sensitive products.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsHazmat rdf:type rdf:Property ;
    rdfs:label 'Supports Hazmat' ;
    rdfs:comment 'Boolean flag indicating whether the fulfillment center is certified and equipped to handle hazardous materials shipments.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsReturnsProcessing rdf:type rdf:Property ;
    rdfs:label 'Supports Returns Processing' ;
    rdfs:comment 'Boolean flag indicating whether the fulfillment center is equipped to receive, inspect, and process customer returns and RMA (Return Merchandise Authorization) requests.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tmsIntegrationReference rdf:type rdf:Property ;
    rdfs:label 'Tms Integration Reference' ;
    rdfs:comment 'External system identifier used to integrate with the Transportation Management System (TMS) for carrier selection and shipment tracking.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCapacityUnits rdf:type rdf:Property ;
    rdfs:label 'Total Capacity Units' ;
    rdfs:comment 'Maximum storage capacity of the fulfillment center measured in storage units (pallets, bins, or cubic feet), representing the total inventory holding capacity.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wmsIntegrationReference rdf:type rdf:Property ;
    rdfs:label 'Wms Integration Reference' ;
    rdfs:comment 'External system identifier used to integrate with the WMS for real-time inventory synchronization and order orchestration.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wmsSystemName rdf:type rdf:Property ;
    rdfs:label 'Wms System Name' ;
    rdfs:comment 'Name of the Warehouse Management System (WMS) software deployed at this fulfillment center for inventory and operations management.' ;
    rdfs:domain ind:Center ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentCenterId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Center Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.center. Business justification: A fulfillment order is issued to a specific fulfillment center for execution. This is a core operational relationship — every fulfillment instruction must be assigned to a physical FC node. No center_' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Center .

ind:allocatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocated Timestamp' ;
    rdfs:comment 'The timestamp when inventory was successfully allocated to this fulfillment order in the WMS. Marks transition from received to allocated status.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivered Timestamp' ;
    rdfs:comment 'The timestamp when the package was successfully delivered to the customer destination address. Sourced from carrier proof-of-delivery records.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fulfillmentOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Order Number' ;
    rdfs:comment 'Human-readable business identifier for the fulfillment order, typically displayed on packing slips, shipping labels, and in Warehouse Management System (WMS) interfaces.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Order Status' ;
    rdfs:comment 'Current lifecycle status of the fulfillment order. Tracks progression through warehouse workflow stages from receipt to delivery. [ENUM-REF-CANDIDATE: received|allocated|picking|packed|shipped|delivered|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftMessage rdf:type rdf:Property ;
    rdfs:label 'Gift Message' ;
    rdfs:comment 'Optional personalized message to be included with gift orders. Printed on packing slip or gift card insert.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGift rdf:type rdf:Property ;
    rdfs:label 'Is Gift' ;
    rdfs:comment 'Boolean flag indicating whether this order is a gift. When true, pricing information is excluded from packing slip and gift wrapping may be applied.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the order based on business context. B2C = Business to Consumer, B2B = Business to Business. Determines packing requirements, documentation, and invoicing rules.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageCount rdf:type rdf:Property ;
    rdfs:label 'Package Count' ;
    rdfs:comment 'The number of individual packages or parcels created for this fulfillment order. Orders may be split into multiple packages based on size, weight, or inventory location.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packingCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Packing Completed Timestamp' ;
    rdfs:comment 'The timestamp when all items were packed, shipping label applied, and the package was ready for carrier pickup.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packingSlipUrl rdf:type rdf:Property ;
    rdfs:label 'Packing Slip Url' ;
    rdfs:comment 'URL to the generated packing slip document that accompanies the shipment. Contains itemized order details for customer reference.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Packing Started Timestamp' ;
    rdfs:comment 'The timestamp when packing operations began for this fulfillment order at the packing station.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickingCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Picking Completed Timestamp' ;
    rdfs:comment 'The timestamp when all items for this fulfillment order were successfully picked from warehouse locations.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickingStartedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Picking Started Timestamp' ;
    rdfs:comment 'The timestamp when warehouse personnel began picking items for this fulfillment order. Marks start of physical fulfillment execution.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:promisedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Promised Delivery Date' ;
    rdfs:comment 'The date by which the order is promised to be delivered to the customer. Used for SLA tracking and customer communication.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promisedShipDate rdf:type rdf:Property ;
    rdfs:label 'Promised Ship Date' ;
    rdfs:comment 'The date by which the fulfillment center committed to ship this order to meet customer Service Level Agreement (SLA) expectations.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'The timestamp when the fulfillment order was received by the Warehouse Management System (WMS) from the Order Management System (OMS).' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recipientName rdf:type rdf:Property ;
    rdfs:label 'Recipient Name' ;
    rdfs:comment 'The full name of the person or business receiving the shipment. Printed on shipping label for carrier delivery verification.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientPhone rdf:type rdf:Property ;
    rdfs:label 'Recipient Phone' ;
    rdfs:comment 'Contact phone number for the shipment recipient. Used by carriers for delivery coordination and customer notification.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Line1' ;
    rdfs:comment 'The primary street address line for the delivery destination. Contains street number, street name, and unit/apartment number if applicable.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Line2' ;
    rdfs:comment 'Secondary address line for additional delivery instructions, building name, or suite information.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCity rdf:type rdf:Property ;
    rdfs:label 'Shipping City' ;
    rdfs:comment 'The city or municipality name for the delivery destination address.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the delivery destination. Determines customs requirements and international shipping regulations.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingLabelUrl rdf:type rdf:Property ;
    rdfs:label 'Shipping Label Url' ;
    rdfs:comment 'URL to the generated shipping label document stored in the Content Delivery Network (CDN) or document management system.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Postal Code' ;
    rdfs:comment 'The postal code or ZIP code for the delivery destination address. Used for carrier routing and delivery zone determination.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Shipping State Province' ;
    rdfs:comment 'The state, province, or administrative region for the delivery destination address.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Free-text field for special handling requirements, delivery instructions, or customer notes. Examples: fragile, signature required, leave at door.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalItemQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Item Quantity' ;
    rdfs:comment 'The total number of individual units (across all Stock Keeping Units or SKUs) included in this fulfillment order.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Volume M3' ;
    rdfs:comment 'The total packed volume of the fulfillment order in cubic meters. Used for warehouse space planning and transportation optimization.' ;
    rdfs:domain ind:FulfillmentOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:binLocationId rdf:type rdf:Property ;
    rdfs:label 'Bin Location Id' ;
    rdfs:comment 'Foreign key linking to fulfillment.bin_location. Business justification: During the pick operation, each fulfillment order line is picked from a specific physical bin location within the fulfillment center. Linking fulfillment_order_line to bin_location enables pick-path o' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BinLocation .

ind:listingOfferId rdf:type rdf:Property ;
    rdfs:label 'Listing Offer Id' ;
    rdfs:comment 'Foreign key linking to marketplace.listing_offer. Business justification: Supports Offer Performance Analytics by linking each order line to the specific listing offer purchased, enabling pricing and conversion analysis.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ListingOffer .

ind:confirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Confirmation Status' ;
    rdfs:comment 'Status indicating whether the pick has been confirmed and validated. Used for quality control and accuracy verification.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftWrapFlag rdf:type rdf:Property ;
    rdfs:label 'Gift Wrap Flag' ;
    rdfs:comment 'Indicates whether gift wrapping service was requested for this line item. True if gift wrap required, false otherwise.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Timestamp' ;
    rdfs:comment 'Timestamp when this line item was packed into a shipping container. Indicates readiness for shipment.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packedQuantity rdf:type rdf:Property ;
    rdfs:label 'Packed Quantity' ;
    rdfs:comment 'Quantity successfully packed into shipping containers. Represents the final quantity being shipped to the customer.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pick Completion Timestamp' ;
    rdfs:comment 'Timestamp when the pick task for this line item was completed. Marks the end of the picking phase for this line.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pickExceptionCode rdf:type rdf:Property ;
    rdfs:label 'Pick Exception Code' ;
    rdfs:comment 'Code indicating any exception or issue encountered during the pick process. Used for root cause analysis and process improvement.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickExceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Pick Exception Notes' ;
    rdfs:comment 'Free-text notes providing additional context about pick exceptions or issues. Captured by warehouse associates for investigation.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickMethod rdf:type rdf:Property ;
    rdfs:label 'Pick Method' ;
    rdfs:comment 'The picking strategy used for this line item. Determines how the pick task was organized and executed within the WMS workflow.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pick Start Timestamp' ;
    rdfs:comment 'Timestamp when the pick task for this line item was initiated. Used for calculating pick duration and SLA compliance.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Return Eligible Flag' ;
    rdfs:comment 'Indicates whether this line item is eligible for return based on product category and business rules. True if returnable, false otherwise.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Any special handling requirements or instructions for this line item such as fragile, keep refrigerated, or this side up.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutedSku rdf:type rdf:Property ;
    rdfs:label 'Substituted Sku' ;
    rdfs:comment 'The SKU of the substitute product that was picked in place of the originally ordered SKU. Null if no substitution occurred.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Flag' ;
    rdfs:comment 'Indicates whether a product substitution was made for this line item due to stockout or customer preference. True if substituted, false otherwise.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Volume Cubic Meters' ;
    rdfs:comment 'Total volume of the picked quantity for this line item in cubic meters. Used for cartonization and space optimization.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packingSlipId rdf:type rdf:Property ;
    rdfs:label 'Packing Slip Id' ;
    rdfs:comment 'Unique identifier for the packing slip record. Primary key for the packing slip entity.' ;
    rdfs:domain ind:PackingSlip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualWeightKg rdf:type rdf:Property ;
    rdfs:label 'Actual Weight Kg' ;
    rdfs:comment 'Actual measured weight of the packed carton in kilograms, including all contents and packing materials. Captured at the pack station scale.' ;
    rdfs:domain ind:PackingSlip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandedInsertIncluded rdf:type rdf:Property ;
    rdfs:label 'Branded Insert Included' ;
    rdfs:comment 'Boolean flag indicating whether branded marketing inserts, promotional materials, or catalog cards were included in the shipment.' ;
    rdfs:domain ind:PackingSlip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cartonCode rdf:type rdf:Property ;
    rdfs:label 'Carton Code' ;
    rdfs:comment 'Unique identifier or barcode of the specific carton or container used for this shipment. Used for tracking and inventory management of packing materials.' ;
    rdfs:domain ind:PackingSlip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cartonType rdf:type rdf:Property ;
    rdfs:label 'Carton Type' ;
    rdfs:comment 'Type or size classification of the shipping carton or box used for packing. Examples include small box, medium box, large box, envelope, poly mailer.' ;
    rdfs:domain ind:PackingSlip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotes rdf:type rdf:Property ;
    rdfs:label 'Customer Notes' ;
    rdfs:comment 'Free-text field containing any customer-provided delivery instructions or notes that should be visible to the packer or carrier. Examples include gate codes, delivery preferences, or special requests.' ;
    rdfs:domain ind:PackingSlip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Dimensional Weight Kg' ;
    rdfs:comment 'Calculated dimensional weight of the packed carton in kilograms, based on carton dimensions. Used for carrier billing and rate calculation.' ;
    rdfs:domain ind:PackingSlip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentGenerationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Document Generation Timestamp' ;
    rdfs:comment 'Date and time when the packing slip document was generated and printed. Represents the official creation time of the customer-facing packing slip.' ;
    rdfs:domain ind:PackingSlip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:giftMessageIncluded rdf:type rdf:Property ;
    rdfs:label 'Gift Message Included' ;
    rdfs:comment 'Boolean flag indicating whether a gift message was included in the shipment. True if a gift message card or note was packed with the order.' ;
    rdfs:domain ind:PackingSlip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:giftWrapApplied rdf:type rdf:Property ;
    rdfs:label 'Gift Wrap Applied' ;
    rdfs:comment 'Boolean flag indicating whether gift wrapping was applied to the items in this shipment. True if gift wrap service was requested and applied.' ;
    rdfs:domain ind:PackingSlip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceIncluded rdf:type rdf:Property ;
    rdfs:label 'Invoice Included' ;
    rdfs:comment 'Boolean flag indicating whether a printed invoice or receipt was included in the shipment. Typically false for B2C gift orders, true for B2B orders.' ;
    rdfs:domain ind:PackingSlip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack End Timestamp' ;
    rdfs:comment 'Date and time when the packing operation was completed and the carton was sealed. Used for cycle time analysis and productivity tracking.' ;
    rdfs:domain ind:PackingSlip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pack Start Timestamp' ;
    rdfs:comment 'Date and time when the packing operation began at the pack station. Used for cycle time analysis and productivity tracking.' ;
    rdfs:domain ind:PackingSlip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packingExceptionCode rdf:type rdf:Property ;
    rdfs:label 'Packing Exception Code' ;
    rdfs:comment 'Code indicating any exception or issue encountered during the packing process, such as damaged item, missing item, substitution made, or oversized package. Null if no exceptions occurred.' ;
    rdfs:domain ind:PackingSlip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingExceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Packing Exception Notes' ;
    rdfs:comment 'Free-text description of any packing exceptions or issues, providing additional context beyond the exception code. Null if no exceptions occurred.' ;
    rdfs:domain ind:PackingSlip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingMaterialsUsed rdf:type rdf:Property ;
    rdfs:label 'Packing Materials Used' ;
    rdfs:comment 'Comma-separated list or description of packing materials used in the shipment, such as bubble wrap, air pillows, packing peanuts, paper fill, or dunnage. Used for cost tracking and sustainability reporting.' ;
    rdfs:domain ind:PackingSlip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingSlipNumber rdf:type rdf:Property ;
    rdfs:label 'Packing Slip Number' ;
    rdfs:comment 'Human-readable business identifier for the packing slip document. Printed on the physical packing slip and used for customer service reference.' ;
    rdfs:domain ind:PackingSlip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingSlipStatus rdf:type rdf:Property ;
    rdfs:label 'Packing Slip Status' ;
    rdfs:comment 'Current lifecycle status of the packing slip record. Tracks the progression from draft through completion and any subsequent actions like reprinting or voiding.' ;
    rdfs:domain ind:PackingSlip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcScanResult rdf:type rdf:Property ;
    rdfs:label 'Qc Scan Result' ;
    rdfs:comment 'Result of the quality control scan or verification performed during or after packing. Indicates whether the packed contents match the order requirements.' ;
    rdfs:domain ind:PackingSlip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qc Timestamp' ;
    rdfs:comment 'Date and time when the quality control scan or verification was completed. Null if QC was not performed.' ;
    rdfs:domain ind:PackingSlip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnLabelIncluded rdf:type rdf:Property ;
    rdfs:label 'Return Label Included' ;
    rdfs:comment 'Boolean flag indicating whether a prepaid return shipping label was included in the shipment for customer convenience.' ;
    rdfs:domain ind:PackingSlip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'Shipping service level or speed selected for this shipment. Examples include standard ground, two-day, next-day, same-day, or economy.' ;
    rdfs:domain ind:PackingSlip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingLabelPrinted rdf:type rdf:Property ;
    rdfs:label 'Shipping Label Printed' ;
    rdfs:comment 'Boolean flag indicating whether the shipping label has been printed for this packing slip. True once the label is generated and printed at the pack station.' ;
    rdfs:domain ind:PackingSlip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureRequired rdf:type rdf:Property ;
    rdfs:label 'Signature Required' ;
    rdfs:comment 'Boolean flag indicating whether a delivery signature is required for this shipment. True for high-value or restricted items.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalSkuCount rdf:type rdf:Property ;
    rdfs:label 'Total Sku Count' ;
    rdfs:comment 'Total count of distinct SKUs packed in this carton. Represents the variety of products in the shipment.' ;
    rdfs:domain ind:PackingSlip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shippingLabelId rdf:type rdf:Property ;
    rdfs:label 'Shipping Label Id' ;
    rdfs:comment 'Unique system-generated identifier for the shipping label record.' ;
    rdfs:domain ind:ShippingLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Any surcharge, discount, or fee applied to the base carrier rate.' ;
    rdfs:domain ind:ShippingLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierRateAmount rdf:type rdf:Property ;
    rdfs:label 'Carrier Rate Amount' ;
    rdfs:comment 'Base rate quoted by the carrier before adjustments.' ;
    rdfs:domain ind:ShippingLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsDeclarationFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Flag' ;
    rdfs:comment 'True if a customs declaration is required for the shipment.' ;
    rdfs:domain ind:ShippingLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customsValue rdf:type rdf:Property ;
    rdfs:label 'Customs Value' ;
    rdfs:comment 'Declared monetary value for customs purposes.' ;
    rdfs:domain ind:ShippingLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationAddressSnapshot rdf:type rdf:Property ;
    rdfs:label 'Destination Address Snapshot' ;
    rdfs:comment 'Serialized snapshot of the destination address at label generation time.' ;
    rdfs:domain ind:ShippingLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionsCm rdf:type rdf:Property ;
    rdfs:label 'Dimensions Cm' ;
    rdfs:comment 'Package dimensions formatted as LxWxH in centimeters.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Generated Timestamp' ;
    rdfs:comment 'Timestamp when the shipping label was generated.' ;
    rdfs:domain ind:ShippingLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:insuranceAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Amount' ;
    rdfs:comment 'Monetary value of the insurance coverage for the shipment.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Flag' ;
    rdfs:comment 'Indicates whether the shipment is insured.' ;
    rdfs:domain ind:Fulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelFormat rdf:type rdf:Property ;
    rdfs:label 'Label Format' ;
    rdfs:comment 'File format of the generated shipping label.' ;
    rdfs:domain ind:ShippingLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelNumber rdf:type rdf:Property ;
    rdfs:label 'Label Number' ;
    rdfs:comment 'Business identifier assigned to the shipping label, used for tracking and reference.' ;
    rdfs:domain ind:ShippingLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manualOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Manual Override Flag' ;
    rdfs:comment 'Indicates whether a user manually overrode the automated carrier selection.' ;
    rdfs:domain ind:ShippingLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originAddressSnapshot rdf:type rdf:Property ;
    rdfs:label 'Origin Address Snapshot' ;
    rdfs:comment 'Serialized snapshot of the origin address at label generation time.' ;
    rdfs:domain ind:ShippingLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'Physical packaging type used for the shipment.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateBasis rdf:type rdf:Property ;
    rdfs:label 'Rate Basis' ;
    rdfs:comment 'Basis used for carrier rate calculation (weight, dimensional weight, or zone).' ;
    rdfs:domain ind:ShippingLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCurrency rdf:type rdf:Property ;
    rdfs:label 'Rate Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the carrier rate.' ;
    rdfs:domain ind:ShippingLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectionMethod rdf:type rdf:Property ;
    rdfs:label 'Selection Method' ;
    rdfs:comment 'Algorithm or rule used to select the carrier for this label.' ;
    rdfs:domain ind:ShippingLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Selection Timestamp' ;
    rdfs:comment 'Timestamp when the carrier selection (automated or manual) occurred.' ;
    rdfs:domain ind:ShippingLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shippingLabelStatus rdf:type rdf:Property ;
    rdfs:label 'Shipping Label Status' ;
    rdfs:comment 'Current lifecycle state of the shipping label.' ;
    rdfs:domain ind:ShippingLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmsReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Tms Reference Code' ;
    rdfs:comment 'Identifier linking this label to the TMS transaction or batch.' ;
    rdfs:domain ind:ShippingLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Final cost of the shipping label after adjustments, in the specified currency.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidFlag rdf:type rdf:Property ;
    rdfs:label 'Void Flag' ;
    rdfs:comment 'True if the label has been voided or cancelled.' ;
    rdfs:domain ind:ShippingLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:voidTimestamp rdf:type rdf:Property ;
    rdfs:label 'Void Timestamp' ;
    rdfs:comment 'Timestamp when the label was voided, if applicable.' ;
    rdfs:domain ind:ShippingLabel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:carrierTrackingUrl rdf:type rdf:Property ;
    rdfs:label 'Carrier Tracking Url' ;
    rdfs:comment 'Web URL to the carrier\'s tracking page for this shipment.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValue rdf:type rdf:Property ;
    rdfs:label 'Declared Value' ;
    rdfs:comment 'Monetary value declared for customs and liability purposes.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declaredValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Declared Value Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the declared value.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAttempts rdf:type rdf:Property ;
    rdfs:label 'Delivery Attempts' ;
    rdfs:comment 'Number of delivery attempts made for this shipment.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryStatusDetail rdf:type rdf:Property ;
    rdfs:label 'Delivery Status Detail' ;
    rdfs:comment 'Additional detail about the delivery outcome (e.g., left with neighbor, held at depot).' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Destination Address Line1' ;
    rdfs:comment 'First line of the shipment destination address.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCity rdf:type rdf:Property ;
    rdfs:label 'Destination City' ;
    rdfs:comment 'City component of the destination address.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the destination.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPostalCode rdf:type rdf:Property ;
    rdfs:label 'Destination Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the destination address.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationState rdf:type rdf:Property ;
    rdfs:label 'Destination State' ;
    rdfs:comment 'State or province component of the destination address.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Date' ;
    rdfs:comment 'Projected date when the shipment is expected to be delivered.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightClass rdf:type rdf:Property ;
    rdfs:label 'Freight Class' ;
    rdfs:comment 'Classification of freight for pricing and handling (e.g., Class 70).' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightTerms rdf:type rdf:Property ;
    rdfs:label 'Freight Terms' ;
    rdfs:comment 'Terms of payment for freight charges.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentShipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the shipment.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Flag' ;
    rdfs:comment 'Indicates whether the shipment contains hazardous materials.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proofOfDeliveryReference rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Reference' ;
    rdfs:comment 'Reference to the proof-of-delivery document or image.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReason rdf:type rdf:Property ;
    rdfs:label 'Return Reason' ;
    rdfs:comment 'Reason provided for a returned shipment, if applicable.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ship Timestamp' ;
    rdfs:comment 'Timestamp when the shipment was dispatched from the fulfillment center.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'Business identifier assigned to the shipment for tracking and reference.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentType rdf:type rdf:Property ;
    rdfs:label 'Shipment Type' ;
    rdfs:comment 'Indicates whether the shipment is a normal outbound, a return, or an internal transfer.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Shipping Cost Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the shipping cost.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCostGross rdf:type rdf:Property ;
    rdfs:label 'Shipping Cost Gross' ;
    rdfs:comment 'Total shipping cost before taxes and adjustments.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippingCostNet rdf:type rdf:Property ;
    rdfs:label 'Shipping Cost Net' ;
    rdfs:comment 'Net shipping cost after tax adjustments.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippingCostTax rdf:type rdf:Property ;
    rdfs:label 'Shipping Cost Tax' ;
    rdfs:comment 'Tax component of the shipping cost.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippingPriority rdf:type rdf:Property ;
    rdfs:label 'Shipping Priority' ;
    rdfs:comment 'Priority level assigned to the shipment.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentEventId rdf:type rdf:Property ;
    rdfs:label 'Shipment Event Id' ;
    rdfs:comment 'Unique identifier for the shipment tracking event record. Primary key for the shipment event log.' ;
    rdfs:domain ind:ShipmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierEventCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Event Code' ;
    rdfs:comment 'The carrier-specific status code or event identifier from the carrier\'s tracking system. Raw code as provided by carrier API or EDI message.' ;
    rdfs:domain ind:ShipmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierEventDescription rdf:type rdf:Property ;
    rdfs:label 'Carrier Event Description' ;
    rdfs:comment 'The human-readable description of the tracking event as provided by the carrier. Raw scan message or status text from carrier system.' ;
    rdfs:domain ind:ShipmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocationType rdf:type rdf:Property ;
    rdfs:label 'Delivery Location Type' ;
    rdfs:comment 'The specific location where the package was left upon delivery. Applicable only to delivered events. Provides proof-of-delivery detail for customer service and claims. [ENUM-REF-CANDIDATE: front_door|back_door|side_door|mailroom|reception|neighbor|parcel_locker|carrier_facility — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventLocationCity rdf:type rdf:Property ;
    rdfs:label 'Event Location City' ;
    rdfs:comment 'The city where the tracking event was recorded by the carrier. May be null for certain event types that do not have precise location data.' ;
    rdfs:domain ind:ShipmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventLocationCountry rdf:type rdf:Property ;
    rdfs:label 'Event Location Country' ;
    rdfs:comment 'Three-letter ISO country code where the tracking event occurred (e.g., USA, CAN, MEX). Supports international shipment tracking.' ;
    rdfs:domain ind:ShipmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventLocationPostalCode rdf:type rdf:Property ;
    rdfs:label 'Event Location Postal Code' ;
    rdfs:comment 'The postal or ZIP code of the location where the tracking event was recorded. Enables geographic analysis of shipment flow.' ;
    rdfs:domain ind:ShipmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventLocationState rdf:type rdf:Property ;
    rdfs:label 'Event Location State' ;
    rdfs:comment 'The state or province where the tracking event occurred. Uses standard postal abbreviations (e.g., CA, NY, TX).' ;
    rdfs:domain ind:ShipmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSource rdf:type rdf:Property ;
    rdfs:label 'Event Source' ;
    rdfs:comment 'The system or channel through which the tracking event was received: carrier_api (direct carrier integration), tms_webhook (Transportation Management System callback), edi_214 (Electronic Data Interchange shipment status), manual_entry (operator input), wms_scan (Warehouse Management System scan).' ;
    rdfs:domain ind:ShipmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionReason rdf:type rdf:Property ;
    rdfs:label 'Exception Reason' ;
    rdfs:comment 'Detailed explanation of the exception condition if is_exception is True. Describes the nature of the delay, damage, or delivery issue. Null for non-exception events.' ;
    rdfs:domain ind:ShipmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingestion Timestamp' ;
    rdfs:comment 'The timestamp when this event record was ingested into the data platform. Distinct from event_timestamp (when the event actually occurred). Used for data lineage and latency monitoring.' ;
    rdfs:domain ind:ShipmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isCustomerVisible rdf:type rdf:Property ;
    rdfs:label 'Is Customer Visible' ;
    rdfs:comment 'Boolean flag indicating whether this event should be displayed to the customer in tracking interfaces. False for internal-only events (warehouse scans, carrier facility transfers).' ;
    rdfs:domain ind:ShipmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isException rdf:type rdf:Property ;
    rdfs:label 'Is Exception' ;
    rdfs:comment 'Boolean flag indicating whether this event represents an exception or problem condition (delay, damage, lost package, address issue, weather delay, etc.). True if exception, False for normal milestone events.' ;
    rdfs:domain ind:ShipmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSlaBreach rdf:type rdf:Property ;
    rdfs:label 'Is Sla Breach' ;
    rdfs:comment 'Boolean flag indicating whether this event represents or contributes to an SLA breach. True if the event timestamp exceeds the SLA target, False otherwise.' ;
    rdfs:domain ind:ShipmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rawPayload rdf:type rdf:Property ;
    rdfs:label 'Raw Payload' ;
    rdfs:comment 'The complete raw JSON or XML payload received from the carrier API, TMS webhook, or EDI message. Preserved for audit, troubleshooting, and reprocessing. May contain additional carrier-specific metadata.' ;
    rdfs:domain ind:ShipmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureName rdf:type rdf:Property ;
    rdfs:label 'Signature Name' ;
    rdfs:comment 'Name of the person who signed for the delivery. Captured for delivered events requiring proof of delivery. Null for events that do not involve signature capture.' ;
    rdfs:domain ind:ShipmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Target Delivery Timestamp' ;
    rdfs:comment 'The promised delivery date and time per the service level agreement. Used to detect SLA breaches by comparing against actual delivery timestamp.' ;
    rdfs:domain ind:ShipmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:temperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Celsius' ;
    rdfs:comment 'Ambient or package temperature in degrees Celsius recorded at the time of the event. Critical for cold-chain shipments (pharmaceuticals, perishables). Null for non-temperature-controlled shipments.' ;
    rdfs:domain ind:ShipmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightActualKg rdf:type rdf:Property ;
    rdfs:label 'Weight Actual Kg' ;
    rdfs:comment 'The actual measured weight of the shipment in kilograms as recorded during this event. May be captured at pickup, in-transit weighing, or delivery. Used for freight cost reconciliation.' ;
    rdfs:domain ind:ShipmentEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Code' ;
    rdfs:comment 'Identifier code of the carrier that performed the final delivery.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the delivery location. [ENUM-REF-CANDIDATE: USA|CAN|MEX|GBR|FRA|DEU|JPN|CHN|IND|BRA — promote to reference product]' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Mode of delivery used for the order.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'Timestamp when the delivery was confirmed (actual event time).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Flag' ;
    rdfs:comment 'Indicates whether an exception occurred during delivery (e.g., failed attempt, damage).' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Exception Notes' ;
    rdfs:comment 'Free-text notes describing any delivery exception details.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsAccuracyMeters rdf:type rdf:Property ;
    rdfs:label 'Gps Accuracy Meters' ;
    rdfs:comment 'Reported accuracy of the GPS coordinate in meters.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBopis rdf:type rdf:Property ;
    rdfs:label 'Is Bopis' ;
    rdfs:comment 'True if the delivery was part of a Buy-Online-Pick-Up-In-Store fulfillment.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:otpVerified rdf:type rdf:Property ;
    rdfs:label 'Otp Verified' ;
    rdfs:comment 'True if a one-time password was successfully verified at delivery.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photoCaptured rdf:type rdf:Property ;
    rdfs:label 'Photo Captured' ;
    rdfs:comment 'True if a photo of the delivered package was captured.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:podVersion rdf:type rdf:Property ;
    rdfs:label 'Pod Version' ;
    rdfs:comment 'Version identifier of the proof-of-delivery data format.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofAssetUrl rdf:type rdf:Property ;
    rdfs:label 'Proof Asset Url' ;
    rdfs:comment 'Link to the digital asset (image, signature file, etc.) that serves as proof.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfDeliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery Status' ;
    rdfs:comment 'Current lifecycle status of the delivery proof record.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofType rdf:type rdf:Property ;
    rdfs:label 'Proof Type' ;
    rdfs:comment 'Method used to capture delivery proof (e.g., signature, photo, GPS coordinate, one-time password).' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureCaptured rdf:type rdf:Property ;
    rdfs:label 'Signature Captured' ;
    rdfs:comment 'True if a handwritten signature was captured as proof.' ;
    rdfs:domain ind:ProofOfDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaActualMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Minutes' ;
    rdfs:comment 'Actual time in minutes taken to complete the delivery.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaCompliance rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance' ;
    rdfs:comment 'Result of SLA evaluation for this delivery.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Minutes' ;
    rdfs:comment 'Target service-level agreement time in minutes for delivery completion.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aisle rdf:type rdf:Property ;
    rdfs:label 'Aisle' ;
    rdfs:comment 'Alphanumeric identifier of the aisle containing the bin.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bay rdf:type rdf:Property ;
    rdfs:label 'Bay' ;
    rdfs:comment 'Alphanumeric identifier of the bay within the aisle.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binLocationLevel rdf:type rdf:Property ;
    rdfs:label 'Bin Location Level' ;
    rdfs:comment 'Vertical level or tier where the bin is located.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binLocationStatus rdf:type rdf:Property ;
    rdfs:label 'Bin Location Status' ;
    rdfs:comment 'Operational status of the bin (e.g., active, inactive, under maintenance).' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentUnits rdf:type rdf:Property ;
    rdfs:label 'Current Units' ;
    rdfs:comment 'Current count of units stored in the bin.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentVolumeCubicM rdf:type rdf:Property ;
    rdfs:label 'Current Volume Cubic M' ;
    rdfs:comment 'Current total volume of inventory in the bin.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentWeightKg rdf:type rdf:Property ;
    rdfs:label 'Current Weight Kg' ;
    rdfs:comment 'Current total weight of inventory in the bin.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAccessible rdf:type rdf:Property ;
    rdfs:label 'Is Accessible' ;
    rdfs:comment 'Indicates whether the bin is accessible to standard picking equipment (e.g., wheelchair-accessible).' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazmatAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat Allowed' ;
    rdfs:comment 'Indicates whether hazardous materials are permitted in this location.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTemperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Is Temperature Controlled' ;
    rdfs:comment 'True if the bin resides in a temperature-controlled environment.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastInventoryCheckDate rdf:type rdf:Property ;
    rdfs:label 'Last Inventory Check Date' ;
    rdfs:comment 'Date of the most recent physical inventory verification for this bin.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Free-form text describing special characteristics or notes about the bin.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxUnits rdf:type rdf:Property ;
    rdfs:label 'Max Units' ;
    rdfs:comment 'Maximum number of individual units the bin can hold.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxVolumeCubicM rdf:type rdf:Property ;
    rdfs:label 'Max Volume Cubic M' ;
    rdfs:comment 'Maximum volume in cubic meters that the bin can accommodate.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:position rdf:type rdf:Property ;
    rdfs:label 'Position' ;
    rdfs:comment 'Specific position index within the level (e.g., slot number).' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneType rdf:type rdf:Property ;
    rdfs:label 'Zone Type' ;
    rdfs:comment 'Classification of the zone where the bin resides, driving pick path and handling rules.' ;
    rdfs:domain ind:BinLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Breach Threshold Days' ;
    rdfs:comment 'Tolerance window in days for delivery-time breaches.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breachThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Breach Threshold Hours' ;
    rdfs:comment 'Tolerance window in hours beyond the target after which the SLA is considered breached.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryTimeTargetDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Time Target Days' ;
    rdfs:comment 'Maximum allowed days from shipment dispatch to customer receipt.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentSlaDescription rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Sla Description' ;
    rdfs:comment 'Free-form description of the SLA purpose and scope.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packTimeTargetHours rdf:type rdf:Property ;
    rdfs:label 'Pack Time Target Hours' ;
    rdfs:comment 'Maximum allowed time from pick completion to packing completion.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickTimeTargetHours rdf:type rdf:Property ;
    rdfs:label 'Pick Time Target Hours' ;
    rdfs:comment 'Maximum allowed time from order receipt to item pick completion.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sameDayCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Same Day Cutoff Time' ;
    rdfs:comment 'Latest order-placement time (HH:MM) for same-day fulfillment eligibility.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shipTimeTargetHours rdf:type rdf:Property ;
    rdfs:label 'Ship Time Target Hours' ;
    rdfs:comment 'Maximum allowed time from packing completion to shipment dispatch.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaCode rdf:type rdf:Property ;
    rdfs:label 'Sla Code' ;
    rdfs:comment 'Human-readable business code for the SLA, used in operational reporting and carrier selection.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaName rdf:type rdf:Property ;
    rdfs:label 'Sla Name' ;
    rdfs:comment 'Descriptive name of the SLA offering (e.g., "Prime Express SLA").' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Status' ;
    rdfs:comment 'Current lifecycle status of the SLA.' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaType rdf:type rdf:Property ;
    rdfs:label 'Sla Type' ;
    rdfs:comment 'Classification of the SLA (e.g., standard, premium, custom).' ;
    rdfs:domain ind:Sla ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Commission Schedule Id' ;
    rdfs:comment 'Foreign key linking to marketplace.commission_schedule. Business justification: marketplace_listing has commission_rate_percent: DECIMAL(5,2) which is a denormalized commission rate. The commission_schedule table is the authoritative reference for commission rate structures appli' ;
    rdfs:domain ind:Marketplace ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommissionSchedule .

ind:advertised rdf:type rdf:Property ;
    rdfs:label 'Advertised' ;
    rdfs:comment 'True when the listing includes FTC-compliant advertising disclosures.' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buyBoxEligible rdf:type rdf:Property ;
    rdfs:label 'Buy Box Eligible' ;
    rdfs:comment 'Indicates whether the listing qualifies for the marketplace buy-box algorithm.' ;
    rdfs:domain ind:Marketplace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:condition rdf:type rdf:Property ;
    rdfs:label 'Condition' ;
    rdfs:comment 'Physical state of the item being sold.' ;
    rdfs:domain ind:Marketplace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'Date-time when the listing expires or is deactivated.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:featured rdf:type rdf:Property ;
    rdfs:label 'Featured' ;
    rdfs:comment 'True if the seller has paid for promotional placement of the listing.' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ftcAdDisclosure rdf:type rdf:Property ;
    rdfs:label 'Ftc Ad Disclosure' ;
    rdfs:comment 'True when the listing includes required FTC advertising disclosure statements.' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fulfillmentType rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Type' ;
    rdfs:comment 'Method by which the product is delivered to the buyer.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isVisible rdf:type rdf:Property ;
    rdfs:label 'Is Visible' ;
    rdfs:comment 'Indicates whether the listing is visible to shoppers on the marketplace.' ;
    rdfs:domain ind:Marketplace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:listingSource rdf:type rdf:Property ;
    rdfs:label 'Listing Source' ;
    rdfs:comment 'Origin of the listing record (e.g., seller uploaded, system generated, bulk import).' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listingType rdf:type rdf:Property ;
    rdfs:label 'Listing Type' ;
    rdfs:comment 'Business model of the listing (B2C, C2C, auction, or fixed-price).' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketplaceListingDescription rdf:type rdf:Property ;
    rdfs:label 'Marketplace Listing Description' ;
    rdfs:comment 'Full textual description of the product, including features and specifications.' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketplaceListingStatus rdf:type rdf:Property ;
    rdfs:label 'Marketplace Listing Status' ;
    rdfs:comment 'Current operational state of the listing.' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingAverage rdf:type rdf:Property ;
    rdfs:label 'Rating Average' ;
    rdfs:comment 'Mean rating score from buyer reviews (scale 1-5).' ;
    rdfs:domain ind:MarketplaceListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'Date-time when the listing becomes active for purchase.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dynamicPriceRuleId rdf:type rdf:Property ;
    rdfs:label 'Dynamic Price Rule Id' ;
    rdfs:comment 'Foreign key linking to pricing.dynamic_price_rule. Business justification: A listing offer\'s price is often computed by a dynamic price rule. Price audit, compliance reporting, and buy-box strategy analysis require knowing which rule produced the current offer price. No exis' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DynamicPriceRule .

ind:buyBoxWinnerFlag rdf:type rdf:Property ;
    rdfs:label 'Buy Box Winner Flag' ;
    rdfs:comment 'True if the offer is the current buy-box winner for the listing.' ;
    rdfs:domain ind:Marketplace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buyerFeedbackScore rdf:type rdf:Property ;
    rdfs:label 'Buyer Feedback Score' ;
    rdfs:comment 'Aggregated rating given by buyers who purchased this specific offer.' ;
    rdfs:domain ind:ListingOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:giftWrapPrice rdf:type rdf:Property ;
    rdfs:label 'Gift Wrap Price' ;
    rdfs:comment 'Additional charge for gift-wrap when selected by the buyer.' ;
    rdfs:domain ind:ListingOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isGiftWrapAvailable rdf:type rdf:Property ;
    rdfs:label 'Is Gift Wrap Available' ;
    rdfs:comment 'True if the seller offers gift-wrap service for this offer.' ;
    rdfs:domain ind:ListingOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimeEligible rdf:type rdf:Property ;
    rdfs:label 'Is Prime Eligible' ;
    rdfs:comment 'True if the offer qualifies for accelerated shipping benefits.' ;
    rdfs:domain ind:ListingOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:listingOfferStatus rdf:type rdf:Property ;
    rdfs:label 'Listing Offer Status' ;
    rdfs:comment 'Operational state of the offer within its lifecycle.' ;
    rdfs:domain ind:ListingOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPrice rdf:type rdf:Property ;
    rdfs:label 'Net Price' ;
    rdfs:comment 'Final amount the seller receives after deductions.' ;
    rdfs:domain ind:ListingOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offerEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Offer End Timestamp' ;
    rdfs:comment 'Date and time when the offer is no longer eligible for purchase.' ;
    rdfs:domain ind:ListingOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:offerPrice rdf:type rdf:Property ;
    rdfs:label 'Offer Price' ;
    rdfs:comment 'Base price of the item as offered by the seller, expressed in the transaction currency.' ;
    rdfs:domain ind:ListingOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offerRank rdf:type rdf:Property ;
    rdfs:label 'Offer Rank' ;
    rdfs:comment 'Ordinal position of the offer in the ranking algorithm (1 = highest).' ;
    rdfs:domain ind:ListingOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offerSource rdf:type rdf:Property ;
    rdfs:label 'Offer Source' ;
    rdfs:comment 'Mechanism by which the offer was entered into the marketplace.' ;
    rdfs:domain ind:ListingOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Offer Start Timestamp' ;
    rdfs:comment 'Date and time when the offer starts being visible to buyers.' ;
    rdfs:domain ind:ListingOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priceEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Price Effective Date' ;
    rdfs:comment 'Calendar date from which the offer_price is valid.' ;
    rdfs:domain ind:ListingOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Price Expiration Date' ;
    rdfs:comment 'Calendar date after which the offer_price is no longer valid.' ;
    rdfs:domain ind:ListingOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'Indicates whether the price is a regular list price, sale price, or discounted price.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Flag' ;
    rdfs:comment 'True if the offer is tied to a marketplace promotion or discount campaign.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityAvailable rdf:type rdf:Property ;
    rdfs:label 'Quantity Available' ;
    rdfs:comment 'Number of units the seller can fulfill under this offer.' ;
    rdfs:domain ind:ListingOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sellerFulfillmentSlaMet rdf:type rdf:Property ;
    rdfs:label 'Seller Fulfillment Sla Met' ;
    rdfs:comment 'True if the seller consistently meets the handling time SLA for this offer.' ;
    rdfs:domain ind:ListingOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sellerRating rdf:type rdf:Property ;
    rdfs:label 'Seller Rating' ;
    rdfs:comment 'Aggregated rating score for the seller, on a 0-5 scale.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippingCost rdf:type rdf:Property ;
    rdfs:label 'Shipping Cost' ;
    rdfs:comment 'Shipping fee associated with the offer, expressed in the transaction currency.' ;
    rdfs:domain ind:ListingOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippingEstimateDays rdf:type rdf:Property ;
    rdfs:label 'Shipping Estimate Days' ;
    rdfs:comment 'Projected transit time from shipment to delivery.' ;
    rdfs:domain ind:ListingOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPrice rdf:type rdf:Property ;
    rdfs:label 'Total Price' ;
    rdfs:comment 'Combined price of the item and shipping, representing the amount the buyer would pay.' ;
    rdfs:domain ind:ListingOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sponsoredCampaignId rdf:type rdf:Property ;
    rdfs:label 'Sponsored Campaign Id' ;
    rdfs:comment 'Identifier of the sponsored advertising campaign if this transaction resulted from a sponsored listing.' ;
    rdfs:domain ind:MarketplaceTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:buyerIpAddress rdf:type rdf:Property ;
    rdfs:label 'Buyer Ip Address' ;
    rdfs:comment 'IP address of the buyer at the time of transaction, used for fraud detection and geographic analysis.' ;
    rdfs:domain ind:MarketplaceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeOpenedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispute Opened Timestamp' ;
    rdfs:comment 'Date and time when a dispute was opened for this transaction, if applicable.' ;
    rdfs:domain ind:MarketplaceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disputeResolvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolved Timestamp' ;
    rdfs:comment 'Date and time when the dispute was resolved, if applicable.' ;
    rdfs:domain ind:MarketplaceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fraudReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Fraud Review Status' ;
    rdfs:comment 'Status of fraud review process for this transaction.' ;
    rdfs:domain ind:MarketplaceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Score' ;
    rdfs:comment 'Risk score assigned by fraud detection system indicating the likelihood of fraudulent activity (0-100 scale).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSponsoredListing rdf:type rdf:Property ;
    rdfs:label 'Is Sponsored Listing' ;
    rdfs:comment 'Flag indicating whether this transaction resulted from a sponsored (paid advertising) listing, requiring FTC-compliant advertising disclosure.' ;
    rdfs:domain ind:MarketplaceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemSubtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Item Subtotal Amount' ;
    rdfs:comment 'Subtotal amount for the item(s) purchased, excluding shipping, taxes, and other fees.' ;
    rdfs:domain ind:MarketplaceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketplaceCommissionAmount rdf:type rdf:Property ;
    rdfs:label 'Marketplace Commission Amount' ;
    rdfs:comment 'Commission amount earned by the marketplace platform on this transaction. This is the marketplace revenue from facilitating the transaction.' ;
    rdfs:domain ind:MarketplaceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentChannel rdf:type rdf:Property ;
    rdfs:label 'Payment Channel' ;
    rdfs:comment 'Digital channel or interface through which the buyer completed the payment.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'Primary product category classification for the item sold in this transaction, used for GMV reporting by category.' ;
    rdfs:domain ind:MarketplaceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundReasonCode rdf:type rdf:Property ;
    rdfs:label 'Refund Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for the refund, used for return analytics and seller performance monitoring.' ;
    rdfs:domain ind:MarketplaceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Timestamp' ;
    rdfs:comment 'Date and time when the refund was processed, if applicable.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rmaNumber rdf:type rdf:Property ;
    rdfs:label 'Rma Number' ;
    rdfs:comment 'Return Merchandise Authorization number issued for product returns associated with this transaction.' ;
    rdfs:domain ind:MarketplaceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellerPayoutAmount rdf:type rdf:Property ;
    rdfs:label 'Seller Payout Amount' ;
    rdfs:comment 'Net amount to be paid to the seller after deducting marketplace commission and any other fees from the transaction amount.' ;
    rdfs:domain ind:MarketplaceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippingAmount rdf:type rdf:Property ;
    rdfs:label 'Shipping Amount' ;
    rdfs:comment 'Shipping and handling charges paid by the buyer for this transaction.' ;
    rdfs:domain ind:MarketplaceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Externally visible unique transaction number for customer and seller reference. Format: MKT-XXXXXXXXXX.' ;
    rdfs:domain ind:MarketplaceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle status of the marketplace transaction indicating its processing state and outcome.' ;
    rdfs:domain ind:MarketplaceTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'Date and time when the marketplace transaction was completed and recorded. Primary business event timestamp for GMV (Gross Merchandise Value) reporting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tierId rdf:type rdf:Property ;
    rdfs:label 'Tier Id' ;
    rdfs:comment 'Foreign key linking to seller.tier. Business justification: Commission schedules are tier-gated in e-commerce — the correct rate card is selected based on seller tier. seller_tier_code is a denormalized plain-text copy of seller.tier.tier_code; replacing it wi' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tier .

ind:baseCommissionRatePct rdf:type rdf:Property ;
    rdfs:label 'Base Commission Rate Pct' ;
    rdfs:comment 'Standard commission percentage applied before any variable adjustments.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capType rdf:type rdf:Property ;
    rdfs:label 'Cap Type' ;
    rdfs:comment 'Method used to cap commission (none, fixed amount, or percentage).' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capValue rdf:type rdf:Property ;
    rdfs:label 'Cap Value' ;
    rdfs:comment 'Numeric value of the commission cap, interpreted according to cap_type.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionScheduleDescription rdf:type rdf:Property ;
    rdfs:label 'Commission Schedule Description' ;
    rdfs:comment 'Free-form description providing additional context about the schedule.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Eligibility Criteria' ;
    rdfs:comment 'Business rules that determine which transactions qualify for this schedule.' ;
    rdfs:domain ind:Marketplace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxCommissionAmount rdf:type rdf:Property ;
    rdfs:label 'Max Commission Amount' ;
    rdfs:comment 'Ceiling amount for commission; calculated commission will not exceed this value.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minCommissionAmount rdf:type rdf:Property ;
    rdfs:label 'Min Commission Amount' ;
    rdfs:comment 'Floor amount for commission; if calculated commission falls below this, the minimum is applied.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Period Flag' ;
    rdfs:comment 'Indicates whether the schedule is tied to a promotional period.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Human-readable name of the commission schedule used for reporting and UI display.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the schedule.' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variableFeeStructure rdf:type rdf:Property ;
    rdfs:label 'Variable Fee Structure' ;
    rdfs:comment 'Textual definition of any variable fee components (e.g., tier-based bonuses, volume discounts).' ;
    rdfs:domain ind:CommissionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankTransferReference rdf:type rdf:Property ;
    rdfs:label 'Bank Transfer Reference' ;
    rdfs:comment 'Reference identifier provided by the banking institution for the settlement transfer.' ;
    rdfs:domain ind:SellerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementStatus rdf:type rdf:Property ;
    rdfs:label 'Disbursement Status' ;
    rdfs:comment 'Current processing state of the settlement payment.' ;
    rdfs:domain ind:SellerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeAdjustmentsAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Adjustments Amount' ;
    rdfs:comment 'Additional fee adjustments (e.g., chargebacks, penalties) applied to the settlement.' ;
    rdfs:domain ind:SellerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Sales Amount' ;
    rdfs:comment 'Total sales revenue generated by the seller during the settlement period before any deductions.' ;
    rdfs:domain ind:SellerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netDisbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Net Disbursement Amount' ;
    rdfs:comment 'Final amount transferred to the seller after all deductions and credits.' ;
    rdfs:domain ind:SellerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalCreditsAmount rdf:type rdf:Property ;
    rdfs:label 'Promotional Credits Amount' ;
    rdfs:comment 'Credits applied to the seller for promotional funding or marketing incentives.' ;
    rdfs:domain ind:SellerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordAuditCreated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Created' ;
    rdfs:comment 'Timestamp when the settlement record was first captured in the data lake.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordAuditUpdated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Updated' ;
    rdfs:comment 'Timestamp of the most recent update to the settlement record.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refundDeductionsAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Deductions Amount' ;
    rdfs:comment 'Total amount subtracted for buyer refunds processed during the period.' ;
    rdfs:domain ind:SellerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementCycle rdf:type rdf:Property ;
    rdfs:label 'Settlement Cycle' ;
    rdfs:comment 'Frequency of the settlement period such as weekly, monthly, or quarterly.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementEndDate rdf:type rdf:Property ;
    rdfs:label 'Settlement End Date' ;
    rdfs:comment 'Last calendar date of the settlement period.' ;
    rdfs:domain ind:SellerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementGeneratedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Settlement Generated Timestamp' ;
    rdfs:comment 'Exact time when the settlement record was created by the system.' ;
    rdfs:domain ind:SellerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:settlementNotes rdf:type rdf:Property ;
    rdfs:label 'Settlement Notes' ;
    rdfs:comment 'Free-form text for any additional information or remarks about the settlement.' ;
    rdfs:domain ind:SellerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementStartDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Start Date' ;
    rdfs:comment 'First calendar date of the settlement period.' ;
    rdfs:domain ind:SellerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementType rdf:type rdf:Property ;
    rdfs:label 'Settlement Type' ;
    rdfs:comment 'Indicates whether the settlement is periodic (e.g., weekly) or ad-hoc.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxWithheldAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Withheld Amount' ;
    rdfs:comment 'Amount of tax withheld from the seller\'s payout as required by jurisdictional regulations.' ;
