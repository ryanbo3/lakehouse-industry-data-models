    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsRefunds rdf:type rdf:Property ;
    rdfs:label 'Supports Refunds' ;
    rdfs:comment 'Indicates whether the gateway allows full refunds.' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testStatus rdf:type rdf:Property ;
    rdfs:label 'Test Status' ;
