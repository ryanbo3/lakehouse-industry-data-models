ind:eligibleProductScope rdf:type rdf:Property ;
    rdfs:label 'Eligible Product Scope' ;
    rdfs:comment 'Comma-separated list or pattern of product identifiers (SKU, ASIN, etc.) that the coupon can be applied to.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOneTimeUse rdf:type rdf:Property ;
    rdfs:label 'Is One Time Use' ;
    rdfs:comment 'True if the coupon may be redeemed only once across all customers.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuanceChannel rdf:type rdf:Property ;
    rdfs:label 'Issuance Channel' ;
    rdfs:comment 'System or process that generated the coupon (e.g., campaign engine, manual upload).' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Max Discount Amount' ;
    rdfs:comment 'Upper cap on the monetary value that can be deducted by the coupon.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Min Order Amount' ;
    rdfs:comment 'Minimum order subtotal required for the coupon to be applicable.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRedemptionCap rdf:type rdf:Property ;
    rdfs:label 'Total Redemption Cap' ;
    rdfs:comment 'Overall maximum number of redemptions allowed across all customers.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageLimitPerCustomer rdf:type rdf:Property ;
    rdfs:label 'Usage Limit Per Customer' ;
    rdfs:comment 'Maximum number of times a single customer may redeem this coupon.' ;
    rdfs:domain ind:Coupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliedQuantity rdf:type rdf:Property ;
    rdfs:label 'Applied Quantity' ;
    rdfs:comment 'Number of units of the SKU that the coupon discount covered.' ;
    rdfs:domain ind:CouponRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:couponRedemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Coupon Redemption Status' ;
    rdfs:comment 'Outcome of the redemption attempt: success, failure, or partial.' ;
    rdfs:domain ind:CouponRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Flag' ;
    rdfs:comment 'Indicates whether the redemption was flagged for potential fraud.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:redemptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Redemption Timestamp' ;
    rdfs:comment 'Exact date and time when the coupon was redeemed.' ;
    rdfs:domain ind:CouponRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:redemptionType rdf:type rdf:Property ;
    rdfs:label 'Redemption Type' ;
    rdfs:comment 'Classification of how the coupon can be used: single-use, multi-use, or auto-apply.' ;
    rdfs:domain ind:CouponRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Applied Timestamp' ;
    rdfs:comment 'Date and time when the price override took effect.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditNote rdf:type rdf:Property ;
    rdfs:label 'Audit Note' ;
    rdfs:comment 'Optional free-text note added during audit actions.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalPrice rdf:type rdf:Property ;
    rdfs:label 'Original Price' ;
    rdfs:comment 'The price of the SKU before the override was applied.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overriddenPrice rdf:type rdf:Property ;
    rdfs:label 'Overridden Price' ;
    rdfs:comment 'The new price after the override was applied.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideType rdf:type rdf:Property ;
    rdfs:label 'Override Type' ;
    rdfs:comment 'Indicates whether the price override was applied manually, by an automated system, or via a pricing rule.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceChangeAmount rdf:type rdf:Property ;
    rdfs:label 'Price Change Amount' ;
    rdfs:comment 'Absolute difference between overridden price and original price.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangePercentage rdf:type rdf:Property ;
    rdfs:label 'Price Change Percentage' ;
    rdfs:comment 'Percentage change represented by the price override.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceOverrideStatus rdf:type rdf:Property ;
    rdfs:label 'Price Override Status' ;
    rdfs:comment 'Current lifecycle status of the price override.' ;
    rdfs:domain ind:PriceOverride ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text description providing additional context for the override reason.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceHistoryId rdf:type rdf:Property ;
    rdfs:label 'Price History Id' ;
    rdfs:comment 'System-generated unique identifier for each price change event.' ;
    rdfs:domain ind:PriceHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Timestamp' ;
    rdfs:comment 'Exact moment when the new price became effective in the marketplace.' ;
    rdfs:domain ind:PriceHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:initiatedBySystem rdf:type rdf:Property ;
    rdfs:label 'Initiated By System' ;
    rdfs:comment 'Name of the automated system or service (e.g., pricing engine, rule engine) that generated the change.' ;
    rdfs:domain ind:PriceHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isManualOverride rdf:type rdf:Property ;
    rdfs:label 'Is Manual Override' ;
    rdfs:comment 'Indicates whether the price change was manually overridden (true) or system-driven (false).' ;
    rdfs:domain ind:PriceHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceAfter rdf:type rdf:Property ;
    rdfs:label 'Price After' ;
    rdfs:comment 'Price value after the change was applied.' ;
    rdfs:domain ind:PriceHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceBefore rdf:type rdf:Property ;
    rdfs:label 'Price Before' ;
    rdfs:comment 'Price value before the change was applied.' ;
    rdfs:domain ind:PriceHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangeType rdf:type rdf:Property ;
    rdfs:label 'Price Change Type' ;
    rdfs:comment 'Classification of the change mechanism that caused the price update.' ;
    rdfs:domain ind:PriceHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityTons rdf:type rdf:Property ;
    rdfs:label 'Capacity Tons' ;
    rdfs:comment 'Maximum weight capacity the carrier can transport per shipment.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Full legal name of the transportation carrier.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierStatus rdf:type rdf:Property ;
    rdfs:label 'Carrier Status' ;
    rdfs:comment 'Current lifecycle status of the carrier (e.g., active, inactive, suspended, pending onboarding).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierTier rdf:type rdf:Property ;
    rdfs:label 'Carrier Tier' ;
    rdfs:comment 'Internal tier used to prioritize carriers based on performance, volume, and strategic importance.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierType rdf:type rdf:Property ;
    rdfs:label 'Carrier Type' ;
    rdfs:comment 'Primary service category the carrier provides (e.g., Full-Truck-Load, Less-Truck-Load, parcel, last-mile, cross-border).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCtpat rdf:type rdf:Property ;
    rdfs:label 'Compliance Ctpat' ;
    rdfs:comment 'Indicates whether the carrier holds a valid C-TPAT certification.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceIata rdf:type rdf:Property ;
    rdfs:label 'Compliance Iata' ;
    rdfs:comment 'Indicates whether the carrier is certified by IATA for air freight operations.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceWto rdf:type rdf:Property ;
    rdfs:label 'Compliance Wto' ;
    rdfs:comment 'Indicates whether the carrier complies with WTO trade regulations for cross-border shipments.' ;
    rdfs:domain ind:Logistics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'Name of the primary business contact for the carrier.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:country rdf:type rdf:Property ;
    rdfs:label 'Country' ;
    rdfs:comment 'Three-letter ISO country code where the carrier is headquartered.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Number' ;
    rdfs:comment 'Seven-digit identifier assigned by the U.S. Department of Transportation to the carrier.' ;
    rdfs:domain ind:Carrier ;
