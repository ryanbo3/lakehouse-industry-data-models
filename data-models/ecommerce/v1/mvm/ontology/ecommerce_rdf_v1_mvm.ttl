ind:baseRate rdf:type rdf:Property ;
    rdfs:label 'Base Rate' ;
    rdfs:comment 'Fundamental freight charge per kilogram before surcharges, expressed in the specified currency.' ;
    rdfs:domain ind:CarrierRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierRateCardStatus rdf:type rdf:Property ;
    rdfs:label 'Carrier Rate Card Status' ;
    rdfs:comment 'Current lifecycle state of the rate card (e.g., active, inactive, expired, pending approval).' ;
    rdfs:domain ind:CarrierRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRegulation rdf:type rdf:Property ;
    rdfs:label 'Compliance Regulation' ;
    rdfs:comment 'Regulatory frameworks applicable to the rate card (e.g., WTO, ISO 27001, PCI DSS).' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargePct rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Pct' ;
    rdfs:comment 'Percentage applied to the base rate to account for fuel price volatility.' ;
    rdfs:domain ind:CarrierRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incoterm rdf:type rdf:Property ;
    rdfs:label 'Incoterm' ;
    rdfs:comment 'International Commercial Term governing responsibility and cost allocation (e.g., EXW, FCA, CPT, CIP, DAT, DAP, DDP). [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAT|DAP|DDP — promote to reference product]' ;
    rdfs:domain ind:CarrierRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAccessorialApplicable rdf:type rdf:Property ;
    rdfs:label 'Is Accessorial Applicable' ;
    rdfs:comment 'Indicates whether accessorial rates from the schedule are applicable for this lane.' ;
    rdfs:domain ind:CarrierRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFuelSurchargeApplicable rdf:type rdf:Property ;
    rdfs:label 'Is Fuel Surcharge Applicable' ;
    rdfs:comment 'Indicates whether the fuel surcharge percentage should be applied to shipments under this rate.' ;
    rdfs:domain ind:CarrierRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laneDestination rdf:type rdf:Property ;
    rdfs:label 'Lane Destination' ;
    rdfs:comment 'Standardized code (e.g., IATA, UN/LOCODE) representing the shipment destination point for the lane.' ;
    rdfs:domain ind:CarrierRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneOrigin rdf:type rdf:Property ;
    rdfs:label 'Lane Origin' ;
    rdfs:comment 'Standardized code (e.g., IATA, UN/LOCODE) representing the shipment origin point for the lane.' ;
    rdfs:domain ind:CarrierRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laneType rdf:type rdf:Property ;
    rdfs:label 'Lane Type' ;
    rdfs:comment 'Indicates whether the origin-destination lane is domestic or crosses international borders.' ;
    rdfs:domain ind:CarrierRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationReference rdf:type rdf:Property ;
    rdfs:label 'Negotiation Reference' ;
    rdfs:comment 'Internal reference or document ID linking the rate card to its contract negotiation record.' ;
    rdfs:domain ind:CarrierRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardCategory rdf:type rdf:Property ;
    rdfs:label 'Rate Card Category' ;
    rdfs:comment 'Logical grouping of the rate card such as lane-based, zone-based, or region-based.' ;
    rdfs:domain ind:CarrierRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardNumber rdf:type rdf:Property ;
    rdfs:label 'Rate Card Number' ;
    rdfs:comment 'External reference number assigned to the rate card by the carrier or logistics contract team.' ;
    rdfs:domain ind:CarrierRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Rate Card Source System' ;
    rdfs:comment 'System of record that originated the rate card (e.g., Transportation Management System, ERP).' ;
    rdfs:domain ind:CarrierRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightTierMaxKg rdf:type rdf:Property ;
    rdfs:label 'Weight Tier Max Kg' ;
    rdfs:comment 'Upper bound of the weight range (in kilograms) for which the base rate applies.' ;
    rdfs:domain ind:CarrierRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightTierMinKg rdf:type rdf:Property ;
    rdfs:label 'Weight Tier Min Kg' ;
    rdfs:comment 'Lower bound of the weight range (in kilograms) for which the base rate applies.' ;
    rdfs:domain ind:CarrierRateCard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierZoneMapping rdf:type rdf:Property ;
    rdfs:label 'Carrier Zone Mapping' ;
    rdfs:comment 'Mapping string that links carrier-specific zone identifiers to this internal zone.' ;
    rdfs:domain ind:DeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerShipment rdf:type rdf:Property ;
    rdfs:label 'Cost Per Shipment' ;
    rdfs:comment 'Standard base cost charged for a shipment to this zone before surcharges.' ;
    rdfs:domain ind:DeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliverySlaDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Sla Days' ;
    rdfs:comment 'Committed number of calendar days for delivery within this zone.' ;
    rdfs:domain ind:DeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryWindowEndTime rdf:type rdf:Property ;
    rdfs:label 'Delivery Window End Time' ;
    rdfs:comment 'Latest time of day (HH:MM) when delivery can be performed in this zone.' ;
    rdfs:domain ind:DeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryWindowStartTime rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Start Time' ;
    rdfs:comment 'Earliest time of day (HH:MM) when delivery can be performed in this zone.' ;
    rdfs:domain ind:DeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryZoneDescription rdf:type rdf:Property ;
    rdfs:label 'Delivery Zone Description' ;
    rdfs:comment 'Free-form description of the zone, including any special handling notes.' ;
    rdfs:domain ind:DeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryZoneStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Zone Status' ;
    rdfs:comment 'Current lifecycle status of the zone record.' ;
    rdfs:domain ind:DeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExpressAvailable rdf:type rdf:Property ;
    rdfs:label 'Is Express Available' ;
    rdfs:comment 'Indicates whether express (same-day/next-day) service is offered in this zone.' ;
    rdfs:domain ind:DeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postalCodeRange rdf:type rdf:Property ;
    rdfs:label 'Postal Code Range' ;
    rdfs:comment 'Range of postal codes (e.g., 10000-19999) included in the zone.' ;
    rdfs:domain ind:DeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresSignature rdf:type rdf:Property ;
    rdfs:label 'Requires Signature' ;
    rdfs:comment 'Indicates whether a recipient signature is required for deliveries in this zone.' ;
    rdfs:domain ind:DeliveryZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surchargeRemoteArea rdf:type rdf:Property ;
    rdfs:label 'Surcharge Remote Area' ;
    rdfs:comment 'Indicates whether a remote-area surcharge applies to shipments in this zone.' ;
    rdfs:domain ind:DeliveryZone ;
    rdf:type owl:DatatypeProperty ;
