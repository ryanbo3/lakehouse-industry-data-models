ind:promotionCode rdf:type rdf:Property ;
    rdfs:label 'Promotion Code' ;
    rdfs:comment 'External code used to reference the promotion in business processes and reporting.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionName rdf:type rdf:Property ;
    rdfs:label 'Promotion Name' ;
    rdfs:comment 'Descriptive name of the promotion shown to sellers and buyers.' ;
    rdfs:domain ind:MarketplacePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionType rdf:type rdf:Property ;
    rdfs:label 'Promotion Type' ;
    rdfs:comment 'Category of the promotion defining its business rules and display format.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalPrice rdf:type rdf:Property ;
    rdfs:label 'Promotional Price' ;
    rdfs:comment 'Fixed price applied to the listing when promotional_price_override is true.' ;
    rdfs:domain ind:MarketplacePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalPriceCurrency rdf:type rdf:Property ;
    rdfs:label 'Promotional Price Currency' ;
    rdfs:comment 'ISO 4217 currency code for the promotional price.' ;
    rdfs:domain ind:MarketplacePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalPriceOverride rdf:type rdf:Property ;
    rdfs:label 'Promotional Price Override' ;
    rdfs:comment 'If true, the promotion sets a specific price for the listing regardless of original price.' ;
