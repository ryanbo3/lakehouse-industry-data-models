    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsRecurring rdf:type rdf:Property ;
    rdfs:label 'Supports Recurring' ;
    rdfs:comment 'Indicates whether the gateway can process recurring subscription payments.' ;
