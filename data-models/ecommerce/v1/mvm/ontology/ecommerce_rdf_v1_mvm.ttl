ind:priceCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Price Calculation Method' ;
    rdfs:comment 'Method used to derive the prices in this list.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
