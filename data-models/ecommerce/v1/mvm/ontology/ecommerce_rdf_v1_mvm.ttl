ind:audienceSegmentId rdf:type rdf:Property ;
    rdfs:label 'Audience Segment Id' ;
    rdfs:comment 'Foreign key linking to marketing.audience_segment. Business justification: Marketplace promotions are targeted to defined audience segments (loyalty tiers, Prime members). Linking to audience_segment enforces referential integrity and enables segment-level promotion performa' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AudienceSegment .

ind:budgetCapAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Cap Amount' ;
    rdfs:comment 'Maximum total monetary value the promotion can consume across all enrollments.' ;
