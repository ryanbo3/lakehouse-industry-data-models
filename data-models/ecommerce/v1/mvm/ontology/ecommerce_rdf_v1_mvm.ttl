    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceCount rdf:type rdf:Property ;
    rdfs:label 'Evidence Count' ;
    rdfs:comment 'Number of evidence items (photos, documents, messages) attached to the dispute.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'Any fees, penalties, or processing charges applied to the dispute.' ;
    rdfs:domain ind:Ecommerce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Filed Timestamp' ;
    rdfs:comment 'Exact date and time when the dispute was initially filed by the initiating party.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ftcDisclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Ftc Disclosure Required' ;
    rdfs:comment 'Indicates whether FTC consumer-protection disclosure is required for this dispute.' ;
    rdfs:domain ind:Marketplace ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprDataSubjectConsent rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Subject Consent' ;
    rdfs:comment 'Flag indicating that the data subject (buyer/seller) has consented to processing of personal data for this dispute.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDuplicateDispute rdf:type rdf:Property ;
    rdfs:label 'Is Duplicate Dispute' ;
    rdfs:comment 'True if this dispute is identified as a duplicate of an existing case.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFraudFlag rdf:type rdf:Property ;
    rdfs:label 'Is Fraud Flag' ;
    rdfs:comment 'Indicates whether the dispute is suspected to involve fraudulent activity.' ;
