ind:lineValue rdf:type rdf:Property ;
    rdfs:label 'Line Value' ;
    rdfs:comment 'Total monetary value for the line (quantity × declared unit value).' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Flag' ;
    rdfs:comment 'True if the item is subject to export restrictions.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipmentItemStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Item Status' ;
    rdfs:comment 'Current processing status of the shipment line item.' ;
    rdfs:domain ind:ShipmentItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCbm rdf:type rdf:Property ;
    rdfs:label 'Volume Cbm' ;
