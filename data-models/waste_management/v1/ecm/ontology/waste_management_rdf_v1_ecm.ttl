ind:minimumBalanceThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Threshold' ;
    rdfs:comment 'Minimum outstanding account balance amount required to trigger this dunning sequence. Balances below this threshold are excluded from dunning.' ;
    rdfs:domain ind:DunningSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentPlanEligible rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Eligible' ;
    rdfs:comment 'Indicates whether customers in this dunning sequence are eligible to request payment plan arrangements to avoid further escalation.' ;
    rdfs:domain ind:DunningSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sequenceCode rdf:type rdf:Property ;
    rdfs:label 'Sequence Code' ;
    rdfs:comment 'Unique business identifier code for the dunning sequence used in billing and collections operations.' ;
    rdfs:domain ind:DunningSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceName rdf:type rdf:Property ;
    rdfs:label 'Sequence Name' ;
    rdfs:comment 'Human-readable name of the dunning sequence describing its purpose and escalation strategy.' ;
