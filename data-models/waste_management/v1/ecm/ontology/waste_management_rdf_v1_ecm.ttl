    rdfs:range xsd:string .

ind:voidedDate rdf:type rdf:Property ;
    rdfs:label 'Voided Date' ;
    rdfs:comment 'Date on which the credit memo was voided, if applicable. Nullable if not voided.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:availableForCommercial rdf:type rdf:Property ;
