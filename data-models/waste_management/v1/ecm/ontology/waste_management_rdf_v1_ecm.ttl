ind:appliedDate rdf:type rdf:Property ;
    rdfs:label 'Applied Date' ;
    rdfs:comment 'Date on which the credit memo was applied to the customer account or invoice. Nullable if not yet applied.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditMemoStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Status' ;
    rdfs:comment 'Current lifecycle status of the credit memo in the billing workflow.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditMemoType rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Type' ;
    rdfs:comment 'Classification of the credit memo based on the reason for issuance.' ;
