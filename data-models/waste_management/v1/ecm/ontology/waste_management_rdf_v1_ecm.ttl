ind:voidedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Voided By User Employee Id' ;
    rdfs:comment 'Reference to the user who voided the credit memo, if applicable. Nullable if not voided.' ;
    rdfs:domain ind:CreditMemo ;
