    rdfs:comment 'Typical number of business days required to process and settle a payment using this method.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processorMerchantCode rdf:type rdf:Property ;
