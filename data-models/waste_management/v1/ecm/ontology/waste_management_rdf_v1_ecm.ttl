    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceType rdf:type rdf:Property ;
    rdfs:label 'Sequence Type' ;
    rdfs:comment 'Classification of the dunning sequence based on customer segment or service type.' ;
    rdfs:domain ind:DunningSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxCompliant rdf:type rdf:Property ;
    rdfs:label 'Sox Compliant' ;
    rdfs:comment 'Indicates whether this dunning sequence meets Sarbanes-Oxley Act compliance requirements for revenue recognition and financial controls.' ;
    rdfs:domain ind:DunningSequence ;
