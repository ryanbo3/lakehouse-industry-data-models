    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresAuthorization rdf:type rdf:Property ;
    rdfs:label 'Requires Authorization' ;
    rdfs:comment 'Indicates whether this payment method requires real-time authorization before acceptance (e.g., credit card authorization).' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresBankAccount rdf:type rdf:Property ;
    rdfs:label 'Requires Bank Account' ;
    rdfs:comment 'Indicates whether this payment method requires customer bank account information (e.g., ACH, wire transfer).' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresCardDetails rdf:type rdf:Property ;
    rdfs:label 'Requires Card Details' ;
    rdfs:comment 'Indicates whether this payment method requires credit or debit card details.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsRecurring rdf:type rdf:Property ;
    rdfs:label 'Supports Recurring' ;
    rdfs:comment 'Indicates whether this payment method can be used for recurring subscription billing.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsRefund rdf:type rdf:Property ;
    rdfs:label 'Supports Refund' ;
    rdfs:comment 'Indicates whether this payment method supports refund transactions.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionFeeFlat rdf:type rdf:Property ;
    rdfs:label 'Transaction Fee Flat' ;
    rdfs:comment 'Fixed fee amount charged per transaction for this payment method, in USD.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionFeePercentage rdf:type rdf:Property ;
    rdfs:label 'Transaction Fee Percentage' ;
    rdfs:comment 'Percentage-based fee rate applied to transaction amount for this payment method (e.g., 0.0275 for 2.75%).' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalSampleId rdf:type rdf:Property ;
    rdfs:label 'Environmental Sample Id' ;
    rdfs:comment 'Primary key for environmental_sample' ;
    rdfs:domain ind:EnvironmentalSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnvironmentalSample .

ind:collectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Collector Employee Id' ;
    rdfs:comment 'Reference to the employee who physically collected the environmental sample.' ;
    rdfs:domain ind:EnvironmentalSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:laboratoryId rdf:type rdf:Property ;
    rdfs:label 'Laboratory Id' ;
    rdfs:comment 'Reference to the certified laboratory performing analysis on the sample.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Laboratory .

ind:samplingEventId rdf:type rdf:Property ;
    rdfs:label 'Sampling Event Id' ;
    rdfs:comment 'Reference to the broader sampling event or monitoring round of which this sample is a part.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SamplingEvent .

ind:analysisCompleteTimestamp rdf:type rdf:Property ;
    rdfs:label 'Analysis Complete Timestamp' ;
    rdfs:comment 'Date and time when laboratory analysis of the sample was completed.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:analysisCostUsd rdf:type rdf:Property ;
    rdfs:label 'Analysis Cost Usd' ;
    rdfs:comment 'Total cost of laboratory analysis for this sample, measured in US dollars.' ;
    rdfs:domain ind:EnvironmentalSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analysisStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Analysis Start Timestamp' ;
    rdfs:comment 'Date and time when laboratory analysis of the sample began.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:blankIndicator rdf:type rdf:Property ;
    rdfs:label 'Blank Indicator' ;
    rdfs:comment 'Flag indicating whether this sample is a field or trip blank used for quality control.' ;
    rdfs:domain ind:EnvironmentalSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compositeIndicator rdf:type rdf:Property ;
    rdfs:label 'Composite Indicator' ;
    rdfs:comment 'Flag indicating whether this sample is a composite of multiple sub-samples (true) or a discrete grab sample (false).' ;
    rdfs:domain ind:EnvironmentalSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:duplicateIndicator rdf:type rdf:Property ;
    rdfs:label 'Duplicate Indicator' ;
    rdfs:comment 'Flag indicating whether this sample is a quality control duplicate collected for quality assurance purposes.' ;
    rdfs:domain ind:EnvironmentalSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fieldObservations rdf:type rdf:Property ;
    rdfs:label 'Field Observations' ;
    rdfs:comment 'Free-text notes documenting field observations, anomalies, or conditions relevant to sample collection.' ;
    rdfs:domain ind:EnvironmentalSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdTimeExceededIndicator rdf:type rdf:Property ;
    rdfs:label 'Hold Time Exceeded Indicator' ;
    rdfs:comment 'Flag indicating whether the sample was analyzed after the maximum allowable hold time had expired.' ;
    rdfs:domain ind:EnvironmentalSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdTimeHours rdf:type rdf:Property ;
    rdfs:label 'Hold Time Hours' ;
    rdfs:comment 'Maximum allowable time between sample collection and analysis, measured in hours, as specified by the analytical method.' ;
    rdfs:domain ind:EnvironmentalSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phAtCollection rdf:type rdf:Property ;
    rdfs:label 'Ph At Collection' ;
    rdfs:comment 'pH measurement of the sample taken at the time of collection in the field.' ;
    rdfs:domain ind:EnvironmentalSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preservativeUsed rdf:type rdf:Property ;
    rdfs:label 'Preservative Used' ;
    rdfs:comment 'Chemical preservative added to the sample to maintain stability during transport and storage (e.g., HCl, H2SO4, HNO3).' ;
    rdfs:domain ind:EnvironmentalSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityIndicator rdf:type rdf:Property ;
    rdfs:label 'Priority Indicator' ;
    rdfs:comment 'Flag indicating whether this sample requires expedited or priority analysis due to regulatory deadlines or operational urgency.' ;
    rdfs:domain ind:EnvironmentalSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleDepthMeters rdf:type rdf:Property ;
    rdfs:label 'Sample Depth Meters' ;
    rdfs:comment 'Depth below surface at which the sample was collected, measured in meters. Applicable to groundwater, soil, and subsurface samples.' ;
    rdfs:domain ind:EnvironmentalSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleMatrix rdf:type rdf:Property ;
    rdfs:label 'Sample Matrix' ;
    rdfs:comment 'Detailed description of the sample matrix or substrate (e.g., sandy soil, clay, municipal solid waste leachate).' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleVolumeMl rdf:type rdf:Property ;
    rdfs:label 'Sample Volume Ml' ;
    rdfs:comment 'Volume of the environmental sample collected, measured in milliliters.' ;
    rdfs:domain ind:EnvironmentalSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureAtCollectionCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature At Collection Celsius' ;
    rdfs:comment 'Ambient or sample temperature at the time of collection, measured in degrees Celsius.' ;
    rdfs:domain ind:EnvironmentalSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidedReason rdf:type rdf:Property ;
    rdfs:label 'Voided Reason' ;
    rdfs:comment 'Explanation for why the sample was voided or invalidated (e.g., broken container, contamination, lost in transit).' ;
    rdfs:domain ind:EnvironmentalSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionLevel rdf:type rdf:Property ;
    rdfs:label 'Action Level' ;
    rdfs:comment 'Threshold value that triggers corrective action or enhanced monitoring when exceeded, typically set below the regulatory limit.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chainOfCustodyRequired rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Required' ;
    rdfs:comment 'Indicates whether formal chain of custody documentation is required for sample handling and transport.' ;
    rdfs:domain ind:MonitoringProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionPlanReference rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Reference' ;
    rdfs:comment 'Document reference or identifier for any corrective action plan associated with non-compliance or exceedances detected by this program.' ;
    rdfs:domain ind:MonitoringProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataManagementSystem rdf:type rdf:Property ;
    rdfs:label 'Data Management System' ;
    rdfs:comment 'Name of the software system or database used to store, manage, and report monitoring data (e.g., Enviance EHS, SAP EHS).' ;
    rdfs:domain ind:MonitoringProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataValidationLevel rdf:type rdf:Property ;
    rdfs:label 'Data Validation Level' ;
    rdfs:comment 'EPA data validation level applied to analytical results, indicating the rigor of quality assurance review.' ;
    rdfs:domain ind:MonitoringProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAnnualCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Cost' ;
    rdfs:comment 'Projected annual cost in USD for conducting this monitoring program, including sampling, analysis, reporting, and labor.' ;
    rdfs:domain ind:MonitoringProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iso45001Applicable rdf:type rdf:Property ;
    rdfs:label 'Iso 45001 Applicable' ;
    rdfs:comment 'Indicates whether this monitoring program supports ISO 45001 Occupational Health and Safety Management System requirements.' ;
    rdfs:domain ind:MonitoringProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monitoringLocationCount rdf:type rdf:Property ;
    rdfs:label 'Monitoring Location Count' ;
    rdfs:comment 'Total number of distinct sampling or monitoring locations included in this program.' ;
    rdfs:domain ind:MonitoringProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parameterMonitored rdf:type rdf:Property ;
    rdfs:label 'Parameter Monitored' ;
    rdfs:comment 'Specific environmental parameter, pollutant, or constituent being measured by this monitoring program (e.g., PM2.5, BOD, lead, methane).' ;
    rdfs:domain ind:MonitoringProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicDisclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Required' ;
    rdfs:comment 'Indicates whether monitoring results must be made available to the public through regulatory reporting portals or community right-to-know requirements.' ;
    rdfs:domain ind:MonitoringProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityAssurancePlanReference rdf:type rdf:Property ;
    rdfs:label 'Quality Assurance Plan Reference' ;
    rdfs:comment 'Document reference or identifier for the Quality Assurance Project Plan (QAPP) governing data quality objectives and procedures for this program.' ;
    rdfs:domain ind:MonitoringProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Collected By Employee Id' ;
    rdfs:comment 'Reference to the employee who physically collected the sample.' ;
    rdfs:domain ind:EnvironmentalSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:analysisCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Completed Date' ;
    rdfs:comment 'Date when laboratory analysis was completed.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analysisDueDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Due Date' ;
    rdfs:comment 'Date by which laboratory analysis must be completed to meet holding time requirements.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blankSampleFlag rdf:type rdf:Property ;
    rdfs:label 'Blank Sample Flag' ;
    rdfs:comment 'Indicates whether this is a quality control blank sample used to detect contamination.' ;
    rdfs:domain ind:EnvironmentalSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Collection Temperature Celsius' ;
    rdfs:comment 'Temperature of the sample at the time of collection.' ;
    rdfs:domain ind:EnvironmentalSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceExceedanceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Exceedance Flag' ;
    rdfs:comment 'Indicates whether any analyte in this sample exceeded regulatory limits.' ;
    rdfs:domain ind:EnvironmentalSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compositeSampleFlag rdf:type rdf:Property ;
    rdfs:label 'Composite Sample Flag' ;
    rdfs:comment 'Indicates whether this sample is a composite of multiple sub-samples collected over time or space.' ;
    rdfs:domain ind:EnvironmentalSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:duplicateSampleFlag rdf:type rdf:Property ;
    rdfs:label 'Duplicate Sample Flag' ;
    rdfs:comment 'Indicates whether this sample is a quality control duplicate of another sample.' ;
    rdfs:domain ind:EnvironmentalSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdingTimeHours rdf:type rdf:Property ;
    rdfs:label 'Holding Time Hours' ;
    rdfs:comment 'Maximum allowable time between sample collection and analysis completion, as specified by regulatory method.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preservationMethod rdf:type rdf:Property ;
    rdfs:label 'Preservation Method' ;
    rdfs:comment 'Technique used to preserve sample integrity during transport and storage.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleDescription rdf:type rdf:Property ;
    rdfs:label 'Sample Description' ;
    rdfs:comment 'Free-text description of the sample appearance, odor, or other observable characteristics at collection.' ;
    rdfs:domain ind:EnvironmentalSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleNotes rdf:type rdf:Property ;
    rdfs:label 'Sample Notes' ;
    rdfs:comment 'Additional notes or comments about the sample collection, handling, or analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleVolume rdf:type rdf:Property ;
    rdfs:label 'Sample Volume' ;
    rdfs:comment 'Quantity of sample collected, measured in the unit specified by volume_unit.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalComplianceTier rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Tier' ;
    rdfs:comment 'Classification tier indicating the level of environmental compliance requirements and reporting obligations for the municipality.' ;
    rdfs:domain ind:Municipality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fipsCode rdf:type rdf:Property ;
    rdfs:label 'Fips Code' ;
    rdfs:comment 'Five-digit FIPS code uniquely identifying the municipality for federal reporting and data integration.' ;
    rdfs:domain ind:Municipality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearEndMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End Month' ;
    rdfs:comment 'Month number (1-12) representing the end of the municipality\'s fiscal year, used for contract renewal and budget alignment.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:franchiseAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Franchise Agreement Flag' ;
    rdfs:comment 'Indicates whether the municipality operates under an exclusive franchise agreement with Waste Management.' ;
    rdfs:domain ind:Municipality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:municipalityType rdf:type rdf:Property ;
    rdfs:label 'Municipality Type' ;
    rdfs:comment 'Classification of the municipality based on its governmental structure and jurisdiction level.' ;
    rdfs:domain ind:Municipality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:population rdf:type rdf:Property ;
    rdfs:label 'Population' ;
    rdfs:comment 'Total population count of the municipality used for service capacity planning and pricing calculations.' ;
    rdfs:domain ind:Municipality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recyclingParticipationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Recycling Participation Rate Percent' ;
    rdfs:comment 'Percentage of households or businesses participating in recycling programs within the municipality.' ;
    rdfs:domain ind:Municipality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteGenerationRateTonsPerYear rdf:type rdf:Property ;
    rdfs:label 'Waste Generation Rate Tons Per Year' ;
    rdfs:comment 'Estimated annual waste generation volume in tons for the municipality, used for capacity planning and pricing.' ;
    rdfs:domain ind:Municipality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualResponseCount rdf:type rdf:Property ;
    rdfs:label 'Actual Response Count' ;
    rdfs:comment 'Current count of completed survey responses received. Updated as responses are submitted.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:anonymousFlag rdf:type rdf:Property ;
    rdfs:label 'Anonymous Flag' ;
    rdfs:comment 'Indicates whether respondent identity is captured (false) or kept anonymous (true). Anonymous surveys may improve response rates for sensitive topics.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Required Flag' ;
    rdfs:comment 'Indicates whether explicit consent must be obtained from respondents before they can participate in the survey, typically required for surveys collecting personal data.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataRetentionDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Days' ;
    rdfs:comment 'Number of days that survey response data will be retained before archival or deletion, in accordance with data governance and privacy policies.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'Primary channel through which the survey is distributed to respondents: email, SMS text message, customer web portal, mobile app, interactive voice response (IVR), paper mail, or in-person interview.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCompletionMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Completion Minutes' ;
    rdfs:comment 'Expected time in minutes for a respondent to complete the survey, used to set respondent expectations and improve response rates.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalSurveyCode rdf:type rdf:Property ;
    rdfs:label 'External Survey Code' ;
    rdfs:comment 'Unique identifier assigned to this survey by the external survey platform or vendor system. Used for integration and reconciliation.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveDescription rdf:type rdf:Property ;
    rdfs:label 'Incentive Description' ;
    rdfs:comment 'Description of the incentive offered to survey respondents (e.g., \'$10 account credit\', \'Entry into monthly prize draw\', \'10% discount on next service\'). Null if no incentive is offered.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveOfferedFlag rdf:type rdf:Property ;
    rdfs:label 'Incentive Offered Flag' ;
    rdfs:comment 'Indicates whether respondents are offered an incentive (e.g., discount, gift card, prize entry) for completing the survey.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invitationSentCount rdf:type rdf:Property ;
    rdfs:label 'Invitation Sent Count' ;
    rdfs:comment 'Total number of survey invitations distributed to potential respondents.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxReminderCount rdf:type rdf:Property ;
    rdfs:label 'Max Reminder Count' ;
    rdfs:comment 'Maximum number of reminder messages that will be sent to a non-respondent before ceasing outreach. Null if reminders are not enabled.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:privacyNoticeProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Privacy Notice Provided Flag' ;
    rdfs:comment 'Indicates whether respondents are presented with a privacy notice explaining how their survey data will be used, stored, and protected.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:questionCount rdf:type rdf:Property ;
    rdfs:label 'Question Count' ;
    rdfs:comment 'Total number of questions included in the survey instrument.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reminderEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Reminder Enabled Flag' ;
    rdfs:comment 'Indicates whether automated reminder messages are sent to non-respondents to encourage survey completion.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reminderFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Reminder Frequency Days' ;
    rdfs:comment 'Number of days between automated reminder messages sent to non-respondents. Null if reminders are not enabled.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseRatePercent rdf:type rdf:Property ;
    rdfs:label 'Response Rate Percent' ;
    rdfs:comment 'Percentage of survey invitations that resulted in completed responses, calculated as (actual_response_count / invitation_sent_count) * 100.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Response Required Flag' ;
    rdfs:comment 'Indicates whether all questions in the survey require a response (true) or if some questions are optional (false).' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surveyCategory rdf:type rdf:Property ;
    rdfs:label 'Survey Category' ;
    rdfs:comment 'Categorization of the survey by its timing and trigger: transactional (post-service), relationship (periodic customer health check), event-triggered (after specific incident), periodic (scheduled intervals), or ad-hoc (one-time special purpose).' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyCode rdf:type rdf:Property ;
    rdfs:label 'Survey Code' ;
    rdfs:comment 'Short alphanumeric code used to reference the survey in operational systems and reports (e.g., \'CSAT-Q1-2024\', \'NPS-ANN\').' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyName rdf:type rdf:Property ;
    rdfs:label 'Survey Name' ;
    rdfs:comment 'The business name or title of the survey (e.g., \'Q1 2024 Customer Satisfaction Survey\', \'Annual NPS Survey\').' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyOwner rdf:type rdf:Property ;
    rdfs:label 'Survey Owner' ;
    rdfs:comment 'Name or identifier of the business unit, department, or individual responsible for designing, deploying, and analyzing this survey (e.g., \'Customer Experience Team\', \'Operations Quality\', \'Regional Manager - Northeast\').' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyPlatform rdf:type rdf:Property ;
    rdfs:label 'Survey Platform' ;
    rdfs:comment 'Name of the technology platform or tool used to administer the survey (e.g., \'Qualtrics\', \'SurveyMonkey\', \'Medallia\', \'Salesforce Feedback Management\', \'Custom Portal\').' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyPurpose rdf:type rdf:Property ;
    rdfs:label 'Survey Purpose' ;
    rdfs:comment 'Detailed business purpose and objectives of the survey, explaining what insights or decisions it is intended to support.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyStatus rdf:type rdf:Property ;
    rdfs:label 'Survey Status' ;
    rdfs:comment 'Current lifecycle status of the survey: draft (being designed), active (accepting responses), paused (temporarily suspended), completed (closed to responses), archived (historical record), or cancelled (discontinued).' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyType rdf:type rdf:Property ;
    rdfs:label 'Survey Type' ;
    rdfs:comment 'Classification of the survey by its primary purpose: customer satisfaction (CSAT), net promoter score (NPS), service quality assessment, driver performance feedback, facility feedback, or complaint resolution follow-up.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyUrl rdf:type rdf:Property ;
    rdfs:label 'Survey Url' ;
    rdfs:comment 'Web address (URL) where respondents can access and complete the survey online.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'The intended respondent population for this survey: residential customers, commercial accounts, industrial clients, municipal contracts, all customer segments, or internal staff.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetResponseCount rdf:type rdf:Property ;
    rdfs:label 'Target Response Count' ;
    rdfs:comment 'Desired number of completed survey responses needed to achieve statistical significance or business objectives.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referralProgramId rdf:type rdf:Property ;
    rdfs:label 'Referral Program Id' ;
    rdfs:comment 'Primary key for referral_program' ;
    rdfs:domain ind:ReferralProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoApprovalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Approval Enabled' ;
    rdfs:comment 'Indicates whether referrals under this program are automatically approved when qualification criteria are met, or require manual review.' ;
    rdfs:domain ind:ReferralProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleRegions rdf:type rdf:Property ;
    rdfs:label 'Eligible Regions' ;
    rdfs:comment 'Comma-separated list of states, regions, or service areas where this referral program is active and customers can participate.' ;
    rdfs:domain ind:ReferralProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleServiceTypes rdf:type rdf:Property ;
    rdfs:label 'Eligible Service Types' ;
    rdfs:comment 'Comma-separated list of waste management service types eligible for this referral program, such as residential collection, commercial dumpster, recycling, or hazardous waste services.' ;
    rdfs:domain ind:ReferralProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isStackable rdf:type rdf:Property ;
    rdfs:label 'Is Stackable' ;
    rdfs:comment 'Indicates whether this referral program can be combined with other promotions, discounts, or referral programs.' ;
    rdfs:domain ind:ReferralProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingChannel rdf:type rdf:Property ;
    rdfs:label 'Marketing Channel' ;
    rdfs:comment 'Primary marketing channels used to promote this referral program, such as email, social media, customer portal, direct mail, or in-person.' ;
    rdfs:domain ind:ReferralProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumReferralsPerCustomer rdf:type rdf:Property ;
    rdfs:label 'Maximum Referrals Per Customer' ;
    rdfs:comment 'Maximum number of successful referrals a single customer can make within the program period. Null indicates no limit.' ;
    rdfs:domain ind:ReferralProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumServiceDurationDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Service Duration Days' ;
    rdfs:comment 'Number of days the referred customer must maintain active service before the referral qualifies for rewards.' ;
    rdfs:domain ind:ReferralProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Program Budget Amount' ;
    rdfs:comment 'Total allocated budget for the referral program including all rewards and administrative costs.' ;
    rdfs:domain ind:ReferralProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programBudgetCurrency rdf:type rdf:Property ;
    rdfs:label 'Program Budget Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the program budget amount.' ;
    rdfs:domain ind:ReferralProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programOwner rdf:type rdf:Property ;
    rdfs:label 'Program Owner' ;
    rdfs:comment 'Name or identifier of the business unit, department, or individual responsible for managing this referral program.' ;
    rdfs:domain ind:ReferralProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationCriteria rdf:type rdf:Property ;
    rdfs:label 'Qualification Criteria' ;
    rdfs:comment 'Business rules and conditions that must be met for a referral to qualify for rewards, such as minimum service duration, payment requirements, or service type restrictions.' ;
    rdfs:domain ind:ReferralProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refereeRewardAmount rdf:type rdf:Property ;
    rdfs:label 'Referee Reward Amount' ;
    rdfs:comment 'Monetary value or quantity of the reward provided to the referee upon successful enrollment and qualification.' ;
    rdfs:domain ind:ReferralProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refereeRewardCurrency rdf:type rdf:Property ;
    rdfs:label 'Referee Reward Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the referee reward amount. Waste Management primarily operates in USD.' ;
    rdfs:domain ind:ReferralProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refereeRewardType rdf:type rdf:Property ;
    rdfs:label 'Referee Reward Type' ;
    rdfs:comment 'Type of incentive or reward provided to the new customer who was referred (the referee).' ;
    rdfs:domain ind:ReferralProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referrerRewardAmount rdf:type rdf:Property ;
    rdfs:label 'Referrer Reward Amount' ;
    rdfs:comment 'Monetary value or quantity of the reward provided to the referrer upon successful referral completion.' ;
    rdfs:domain ind:ReferralProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referrerRewardCurrency rdf:type rdf:Property ;
    rdfs:label 'Referrer Reward Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the referrer reward amount. Waste Management primarily operates in USD.' ;
    rdfs:domain ind:ReferralProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referrerRewardType rdf:type rdf:Property ;
    rdfs:label 'Referrer Reward Type' ;
    rdfs:comment 'Type of incentive or reward provided to the customer who makes the referral (the referrer).' ;
    rdfs:domain ind:ReferralProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardFulfillmentMethod rdf:type rdf:Property ;
    rdfs:label 'Reward Fulfillment Method' ;
    rdfs:comment 'Method by which rewards are delivered to customers: automatically through billing system, manually by customer service, or via third-party vendor.' ;
    rdfs:domain ind:ReferralProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardFulfillmentTimingDays rdf:type rdf:Property ;
    rdfs:label 'Reward Fulfillment Timing Days' ;
    rdfs:comment 'Number of days after qualification that rewards are delivered to customers.' ;
    rdfs:domain ind:ReferralProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:termsAndConditionsUrl rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions Url' ;
    rdfs:comment 'Web address linking to the full legal terms and conditions document for the referral program.' ;
    rdfs:domain ind:ReferralProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingCodePrefix rdf:type rdf:Property ;
    rdfs:label 'Tracking Code Prefix' ;
    rdfs:comment 'Standardized prefix used in referral tracking codes to identify referrals associated with this program.' ;
    rdfs:domain ind:ReferralProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airPollutionControlDeviceType rdf:type rdf:Property ;
    rdfs:label 'Air Pollution Control Device Type' ;
    rdfs:comment 'Primary type of air pollution control equipment installed upstream of this stack to reduce emissions before discharge to atmosphere.' ;
    rdfs:domain ind:Stack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cemsCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Cems Certification Date' ;
    rdfs:comment 'Date when the CEMS was last certified or recertified by regulatory authorities, demonstrating compliance with accuracy and quality assurance requirements.' ;
    rdfs:domain ind:Stack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cemsNextRecertificationDate rdf:type rdf:Property ;
    rdfs:label 'Cems Next Recertification Date' ;
    rdfs:comment 'Scheduled date for the next required CEMS recertification to maintain regulatory compliance and measurement accuracy.' ;
    rdfs:domain ind:Stack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:continuousEmissionsMonitoringSystemInstalled rdf:type rdf:Property ;
    rdfs:label 'Continuous Emissions Monitoring System Installed' ;
    rdfs:comment 'Indicates whether a Continuous Emissions Monitoring System is installed on this stack for real-time pollutant measurement and regulatory reporting.' ;
    rdfs:domain ind:Stack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:designFlowRateCubicMetersPerHour rdf:type rdf:Property ;
    rdfs:label 'Design Flow Rate Cubic Meters Per Hour' ;
    rdfs:comment 'Maximum designed volumetric flow rate of exhaust gases through the stack, measured in cubic meters per hour at standard conditions. Used for capacity planning and permit limits.' ;
    rdfs:domain ind:Stack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionLimitCoPoundsPerHour rdf:type rdf:Property ;
    rdfs:label 'Emission Limit Co Pounds Per Hour' ;
    rdfs:comment 'Maximum permitted emission rate for carbon monoxide from this stack, measured in pounds per hour. Indicator of combustion efficiency and regulatory compliance.' ;
    rdfs:domain ind:Stack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionLimitDioxinFuranNanogramsPerCubicMeter rdf:type rdf:Property ;
    rdfs:label 'Emission Limit Dioxin Furan Nanograms Per Cubic Meter' ;
    rdfs:comment 'Maximum permitted emission concentration for dioxins and furans from this stack, measured in nanograms per dry standard cubic meter. Stringent limit for toxic organic compounds.' ;
    rdfs:domain ind:Stack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionLimitHclPoundsPerHour rdf:type rdf:Property ;
    rdfs:label 'Emission Limit Hcl Pounds Per Hour' ;
    rdfs:comment 'Maximum permitted emission rate for hydrogen chloride from this stack, measured in pounds per hour. Acid gas control requirement for waste combustion.' ;
    rdfs:domain ind:Stack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionLimitMercuryPoundsPerHour rdf:type rdf:Property ;
    rdfs:label 'Emission Limit Mercury Pounds Per Hour' ;
    rdfs:comment 'Maximum permitted emission rate for mercury from this stack, measured in pounds per hour. Hazardous air pollutant limit under Clean Air Act.' ;
    rdfs:domain ind:Stack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionLimitNoxPoundsPerHour rdf:type rdf:Property ;
    rdfs:label 'Emission Limit Nox Pounds Per Hour' ;
    rdfs:comment 'Maximum permitted emission rate for nitrogen oxides from this stack, measured in pounds per hour. Regulatory limit enforced under Clean Air Act.' ;
    rdfs:domain ind:Stack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionLimitParticulateMatterPoundsPerHour rdf:type rdf:Property ;
    rdfs:label 'Emission Limit Particulate Matter Pounds Per Hour' ;
    rdfs:comment 'Maximum permitted emission rate for particulate matter from this stack, measured in pounds per hour. Critical for air quality compliance.' ;
    rdfs:domain ind:Stack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionLimitSo2PoundsPerHour rdf:type rdf:Property ;
    rdfs:label 'Emission Limit So2 Pounds Per Hour' ;
    rdfs:comment 'Maximum permitted emission rate for sulfur dioxide from this stack, measured in pounds per hour. Regulatory limit enforced under Clean Air Act.' ;
    rdfs:domain ind:Stack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exitTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Exit Temperature Celsius' ;
    rdfs:comment 'Average temperature of exhaust gases at the stack exit point, measured in degrees Celsius. Critical for buoyancy calculations in dispersion modeling.' ;
    rdfs:domain ind:Stack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exitVelocityMetersPerSecond rdf:type rdf:Property ;
    rdfs:label 'Exit Velocity Meters Per Second' ;
    rdfs:comment 'Average velocity of exhaust gases exiting the stack, measured in meters per second. Key parameter for dispersion modeling and regulatory compliance calculations.' ;
    rdfs:domain ind:Stack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastStackTestDate rdf:type rdf:Property ;
    rdfs:label 'Last Stack Test Date' ;
    rdfs:comment 'Date when the most recent comprehensive stack emission test was conducted by certified third-party testing firm.' ;
    rdfs:domain ind:Stack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextStackTestDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Stack Test Due Date' ;
    rdfs:comment 'Scheduled date for the next required comprehensive stack emission test to maintain regulatory compliance.' ;
    rdfs:domain ind:Stack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:opacityLimitPercent rdf:type rdf:Property ;
    rdfs:label 'Opacity Limit Percent' ;
    rdfs:comment 'Maximum permitted visible opacity of stack emissions, measured as a percentage. Visual indicator of particulate emissions and combustion quality.' ;
    rdfs:domain ind:Stack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stackDiameterMeters rdf:type rdf:Property ;
    rdfs:label 'Stack Diameter Meters' ;
    rdfs:comment 'Internal diameter of the emission stack at the discharge point, measured in meters. Used for calculating exit velocity and dispersion characteristics.' ;
    rdfs:domain ind:Stack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stackHeightMeters rdf:type rdf:Property ;
    rdfs:label 'Stack Height Meters' ;
    rdfs:comment 'Physical height of the emission stack measured in meters from ground level to the top of the discharge point. Critical parameter for dispersion modeling and regulatory compliance.' ;
    rdfs:domain ind:Stack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stackName rdf:type rdf:Property ;
    rdfs:label 'Stack Name' ;
    rdfs:comment 'Human-readable name or designation for the emission stack, used for operational identification and communication.' ;
    rdfs:domain ind:Stack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackNumber rdf:type rdf:Property ;
    rdfs:label 'Stack Number' ;
    rdfs:comment 'Business identifier for the emission stack, typically assigned by facility operations or regulatory authorities. Used in operational documentation and compliance reporting.' ;
    rdfs:domain ind:Stack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stackTestingFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Stack Testing Frequency Months' ;
    rdfs:comment 'Required frequency for conducting comprehensive stack emission testing, measured in months between tests. Regulatory compliance requirement.' ;
    rdfs:domain ind:Stack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stackType rdf:type rdf:Property ;
    rdfs:label 'Stack Type' ;
    rdfs:comment 'Classification of the emission stack based on its primary function within the WTE facility operations.' ;
    rdfs:domain ind:Stack ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ashSampleId rdf:type rdf:Property ;
    rdfs:label 'Ash Sample Id' ;
    rdfs:comment 'Primary key for ash_sample' ;
    rdfs:domain ind:AshSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:archivedLocation rdf:type rdf:Property ;
    rdfs:label 'Archived Location' ;
    rdfs:comment 'Physical storage location identifier where the retained ash sample is archived for future reference or re-testing.' ;
    rdfs:domain ind:AshSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arsenicConcentrationMgPerL rdf:type rdf:Property ;
    rdfs:label 'Arsenic Concentration Mg Per L' ;
    rdfs:comment 'Concentration of arsenic detected in the ash sample leachate, measured in milligrams per liter.' ;
    rdfs:domain ind:AshSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beneficialReuseEligible rdf:type rdf:Property ;
    rdfs:label 'Beneficial Reuse Eligible' ;
    rdfs:comment 'Indicator of whether the ash sample meets quality criteria for beneficial reuse applications such as aggregate substitute, cement additive, or road base material.' ;
    rdfs:domain ind:AshSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cadmiumConcentrationMgPerL rdf:type rdf:Property ;
    rdfs:label 'Cadmium Concentration Mg Per L' ;
    rdfs:comment 'Concentration of cadmium detected in the ash sample leachate, measured in milligrams per liter.' ;
    rdfs:domain ind:AshSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonContentPercent rdf:type rdf:Property ;
    rdfs:label 'Carbon Content Percent' ;
    rdfs:comment 'Percentage of unburned carbon remaining in the ash sample, indicating combustion efficiency.' ;
    rdfs:domain ind:AshSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chlorideContentMgPerKg rdf:type rdf:Property ;
    rdfs:label 'Chloride Content Mg Per Kg' ;
    rdfs:comment 'Concentration of chloride ions in the ash sample, measured in milligrams per kilogram, relevant for corrosion assessment and beneficial reuse applications.' ;
    rdfs:domain ind:AshSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chromiumConcentrationMgPerL rdf:type rdf:Property ;
    rdfs:label 'Chromium Concentration Mg Per L' ;
    rdfs:comment 'Concentration of chromium detected in the ash sample leachate, measured in milligrams per liter.' ;
    rdfs:domain ind:AshSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectedBy rdf:type rdf:Property ;
    rdfs:label 'Collected By' ;
    rdfs:comment 'Name or identifier of the technician or operator who collected the ash sample.' ;
    rdfs:domain ind:AshSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionPoint rdf:type rdf:Property ;
    rdfs:label 'Collection Point' ;
    rdfs:comment 'Specific equipment location or system component where the ash sample was collected (e.g., Boiler 2 Bottom Hopper, ESP Unit 3, Baghouse Outlet).' ;
    rdfs:domain ind:AshSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryCode rdf:type rdf:Property ;
    rdfs:label 'Laboratory Code' ;
    rdfs:comment 'Reference to the laboratory facility responsible for analyzing this ash sample.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadConcentrationMgPerL rdf:type rdf:Property ;
    rdfs:label 'Lead Concentration Mg Per L' ;
    rdfs:comment 'Concentration of lead detected in the ash sample leachate, measured in milligrams per liter.' ;
    rdfs:domain ind:AshSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mercuryConcentrationMgPerL rdf:type rdf:Property ;
    rdfs:label 'Mercury Concentration Mg Per L' ;
    rdfs:comment 'Concentration of mercury detected in the ash sample leachate, measured in milligrams per liter.' ;
    rdfs:domain ind:AshSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityControlPassed rdf:type rdf:Property ;
    rdfs:label 'Quality Control Passed' ;
    rdfs:comment 'Indicator of whether the laboratory analysis passed internal quality control checks including blanks, duplicates, and spike recoveries.' ;
    rdfs:domain ind:AshSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedAtLabTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received At Lab Timestamp' ;
    rdfs:comment 'Date and time when the ash sample was received and logged into the laboratory information system.' ;
    rdfs:domain ind:AshSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:retentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiry Date' ;
    rdfs:comment 'Date when the archived ash sample may be disposed of per regulatory retention requirements.' ;
    rdfs:domain ind:AshSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleWeightKg rdf:type rdf:Property ;
    rdfs:label 'Sample Weight Kg' ;
    rdfs:comment 'Total weight of the ash sample collected, measured in kilograms.' ;
    rdfs:domain ind:AshSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sulfateContentMgPerKg rdf:type rdf:Property ;
    rdfs:label 'Sulfate Content Mg Per Kg' ;
    rdfs:comment 'Concentration of sulfate compounds in the ash sample, measured in milligrams per kilogram.' ;
    rdfs:domain ind:AshSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toxicityCharacteristic rdf:type rdf:Property ;
    rdfs:label 'Toxicity Characteristic' ;
    rdfs:comment 'Classification indicating whether the ash sample exhibits hazardous waste characteristics based on Toxicity Characteristic Leaching Procedure (TCLP) testing per RCRA regulations.' ;
    rdfs:domain ind:AshSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerGallonCng rdf:type rdf:Property ;
    rdfs:label 'Cost Per Gallon Cng' ;
    rdfs:comment 'Current negotiated or market cost per gallon equivalent for CNG fuel at this station.' ;
    rdfs:domain ind:FuelingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerGallonDiesel rdf:type rdf:Property ;
    rdfs:label 'Cost Per Gallon Diesel' ;
    rdfs:comment 'Current negotiated or market cost per gallon for diesel fuel at this station, used for fleet cost analysis.' ;
    rdfs:domain ind:FuelingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerKwhElectric rdf:type rdf:Property ;
    rdfs:label 'Cost Per Kwh Electric' ;
    rdfs:comment 'Current cost per kilowatt-hour for electric vehicle charging at this station.' ;
    rdfs:domain ind:FuelingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyThroughputCapacityGallons rdf:type rdf:Property ;
    rdfs:label 'Daily Throughput Capacity Gallons' ;
    rdfs:comment 'Maximum daily fuel dispensing capacity in gallons, used for fleet scheduling and station utilization analysis.' ;
    rdfs:domain ind:FuelingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decommissionedDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioned Date' ;
    rdfs:comment 'Date when the fueling station was permanently taken out of service, if applicable.' ;
    rdfs:domain ind:FuelingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:environmentalCertification rdf:type rdf:Property ;
    rdfs:label 'Environmental Certification' ;
    rdfs:comment 'Environmental certifications or compliance standards met by the fueling station (e.g., EPA Tier 3, CARB, LEED).' ;
    rdfs:domain ind:FuelingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelTypesAvailable rdf:type rdf:Property ;
    rdfs:label 'Fuel Types Available' ;
    rdfs:comment 'Comma-separated list of fuel types available at this station (e.g., diesel, CNG, RNG, gasoline, electric). [ENUM-REF-CANDIDATE: diesel|cng|rng|gasoline|electric|biodiesel|lng|hydrogen — promote to reference product]' ;
    rdfs:domain ind:FuelingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:is24HourAccess rdf:type rdf:Property ;
    rdfs:label 'Is 24 Hour Access' ;
    rdfs:comment 'Indicates whether the fueling station provides round-the-clock access for fleet vehicles.' ;
    rdfs:domain ind:FuelingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfCngDispensers rdf:type rdf:Property ;
    rdfs:label 'Number Of Cng Dispensers' ;
    rdfs:comment 'Count of CNG-specific dispensers at the station, critical for CNG fleet capacity planning.' ;
    rdfs:domain ind:FuelingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfElectricChargers rdf:type rdf:Property ;
    rdfs:label 'Number Of Electric Chargers' ;
    rdfs:comment 'Count of electric vehicle charging stations available for electric fleet vehicles.' ;
    rdfs:domain ind:FuelingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfPumps rdf:type rdf:Property ;
    rdfs:label 'Number Of Pumps' ;
    rdfs:comment 'Total count of fueling pumps or dispensers available at the station.' ;
    rdfs:domain ind:FuelingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryFuelType rdf:type rdf:Property ;
    rdfs:label 'Primary Fuel Type' ;
    rdfs:comment 'The predominant fuel type dispensed at this station, used for fleet routing and capacity planning.' ;
    rdfs:domain ind:FuelingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Safety Inspection Date' ;
    rdfs:comment 'Date of the most recent safety inspection for the fueling station, required for regulatory compliance.' ;
    rdfs:domain ind:FuelingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storageCapacityGallons rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Gallons' ;
    rdfs:comment 'Total fuel storage capacity at the station measured in gallons, used for inventory and supply chain planning.' ;
    rdfs:domain ind:FuelingStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Documentation Required Flag' ;
    rdfs:comment 'Indicates whether completion of this checklist requires formal documentation, sign-off, or record retention for compliance.' ;
    rdfs:domain ind:ServiceChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalTemplateReference rdf:type rdf:Property ;
    rdfs:label 'External Template Reference' ;
    rdfs:comment 'Identifier for this checklist template in the source system (e.g., Infor EAM template ID, SAP PM task list number) for integration and traceability.' ;
    rdfs:domain ind:ServiceChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsListRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Parts List Required Flag' ;
    rdfs:comment 'Indicates whether a bill of materials (BOM) or parts list is associated with this checklist for maintenance activities.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photoEvidenceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Photo Evidence Required Flag' ;
    rdfs:comment 'Indicates whether photographic evidence must be captured during checklist execution for audit or compliance purposes.' ;
    rdfs:domain ind:ServiceChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredSkillLevel rdf:type rdf:Property ;
    rdfs:label 'Required Skill Level' ;
    rdfs:comment 'Minimum technician skill or certification level required to perform this checklist.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateCode rdf:type rdf:Property ;
    rdfs:label 'Template Code' ;
    rdfs:comment 'Unique business identifier code for the checklist template used for external reference and system integration.' ;
    rdfs:domain ind:ServiceChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateName rdf:type rdf:Property ;
    rdfs:label 'Template Name' ;
    rdfs:comment 'Human-readable name of the service checklist template describing its purpose and scope.' ;
    rdfs:domain ind:ServiceChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalChecklistItems rdf:type rdf:Property ;
    rdfs:label 'Total Checklist Items' ;
    rdfs:comment 'Total number of inspection or verification items included in this checklist template.' ;
    rdfs:domain ind:ServiceChecklistTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertOnEntry rdf:type rdf:Property ;
    rdfs:label 'Alert On Entry' ;
    rdfs:comment 'Indicates whether an alert should be triggered when a vehicle enters this geofence zone.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alertOnExit rdf:type rdf:Property ;
    rdfs:label 'Alert On Exit' ;
    rdfs:comment 'Indicates whether an alert should be triggered when a vehicle exits this geofence zone.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allowedVehicleTypes rdf:type rdf:Property ;
    rdfs:label 'Allowed Vehicle Types' ;
    rdfs:comment 'Comma-separated list or description of vehicle types permitted to operate within this geofence zone (e.g., ASL, FEL, REL, roll-off, CNG, RNG).' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaSquareMeters rdf:type rdf:Property ;
    rdfs:label 'Area Square Meters' ;
    rdfs:comment 'Total area covered by the geofence zone in square meters, calculated from the defined geometry.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:boundaryCoordinates rdf:type rdf:Property ;
    rdfs:label 'Boundary Coordinates' ;
    rdfs:comment 'Serialized representation of the geofence boundary coordinates (e.g., WKT, GeoJSON string) defining the polygon or custom shape.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:centerLatitude rdf:type rdf:Property ;
    rdfs:label 'Center Latitude' ;
    rdfs:comment 'Latitude coordinate of the geofence zone center point in decimal degrees (WGS84).' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:centerLongitude rdf:type rdf:Property ;
    rdfs:label 'Center Longitude' ;
    rdfs:comment 'Longitude coordinate of the geofence zone center point in decimal degrees (WGS84).' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dotComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Dot Compliance Required' ;
    rdfs:comment 'Indicates whether operations within this geofence zone are subject to DOT/FMCSA compliance monitoring and reporting.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalZoneCode rdf:type rdf:Property ;
    rdfs:label 'External Zone Code' ;
    rdfs:comment 'Identifier for this geofence zone in the external telematics or fleet management system (e.g., Geotab zone ID).' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geometryType rdf:type rdf:Property ;
    rdfs:label 'Geometry Type' ;
    rdfs:comment 'The geometric shape type used to define the geofence zone boundaries (e.g., circle, polygon, rectangle, custom).' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatZone rdf:type rdf:Property ;
    rdfs:label 'Hazmat Zone' ;
    rdfs:comment 'Indicates whether this geofence zone is designated for hazardous waste handling and requires special compliance monitoring.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:idleTimeThresholdMinutes rdf:type rdf:Property ;
    rdfs:label 'Idle Time Threshold Minutes' ;
    rdfs:comment 'Maximum allowed idle time in minutes for vehicles within this geofence zone before triggering an alert or compliance violation.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:radiusMeters rdf:type rdf:Property ;
    rdfs:label 'Radius Meters' ;
    rdfs:comment 'Radius of the geofence zone in meters, applicable when geometry_type is circle. Null for non-circular zones.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restrictedHours rdf:type rdf:Property ;
    rdfs:label 'Restricted Hours' ;
    rdfs:comment 'Time ranges during which access to or operations within the geofence zone are restricted (e.g., \'22:00-06:00\' for noise ordinances).' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speedLimitMph rdf:type rdf:Property ;
    rdfs:label 'Speed Limit Mph' ;
    rdfs:comment 'Maximum allowed speed in miles per hour for vehicles operating within this geofence zone. Used for compliance monitoring.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:telematicsProvider rdf:type rdf:Property ;
    rdfs:label 'Telematics Provider' ;
    rdfs:comment 'Name of the telematics system provider that monitors this geofence zone (e.g., Geotab Fleet Telematics).' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneDescription rdf:type rdf:Property ;
    rdfs:label 'Zone Description' ;
    rdfs:comment 'Detailed textual description of the geofence zone, including its purpose, boundaries, and operational context.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneName rdf:type rdf:Property ;
    rdfs:label 'Zone Name' ;
    rdfs:comment 'Human-readable name or label for the geofence zone (e.g., \'Downtown Collection District\', \'Landfill Perimeter\', \'Customer Service Area 5\').' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneStatus rdf:type rdf:Property ;
    rdfs:label 'Zone Status' ;
    rdfs:comment 'Current lifecycle status of the geofence zone indicating whether it is actively monitored and enforced.' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneType rdf:type rdf:Property ;
    rdfs:label 'Zone Type' ;
    rdfs:comment 'Classification of the geofence zone based on its operational purpose (e.g., service area, facility perimeter, restricted zone, customer site, depot, transfer station).' ;
    rdfs:domain ind:GeofenceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargePermitId rdf:type rdf:Property ;
    rdfs:label 'Discharge Permit Id' ;
    rdfs:comment 'National Pollutant Discharge Elimination System (NPDES) or equivalent discharge permit identifier for this collection point.' ;
    rdfs:domain ind:CollectionPoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:actionLevelUnit rdf:type rdf:Property ;
    rdfs:label 'Action Level Unit' ;
    rdfs:comment 'Unit of measure for the action level threshold (e.g., ppm, mg/L, percent, cfm).' ;
    rdfs:domain ind:CollectionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Due Date' ;
    rdfs:comment 'Next scheduled date for equipment calibration at this collection point.' ;
    rdfs:domain ind:CollectionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depthFt rdf:type rdf:Property ;
    rdfs:label 'Depth Ft' ;
    rdfs:comment 'Depth of the collection point below ground surface measured in feet, applicable for wells and subsurface monitoring points.' ;
    rdfs:domain ind:CollectionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:envianceIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Enviance Integration Flag' ;
    rdfs:comment 'Indicates whether this collection point is integrated with the Enviance EHS system for automated compliance reporting.' ;
    rdfs:domain ind:CollectionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flowCapacityGpm rdf:type rdf:Property ;
    rdfs:label 'Flow Capacity Gpm' ;
    rdfs:comment 'Maximum flow capacity of the collection point measured in gallons per minute, applicable for leachate and stormwater collection.' ;
    rdfs:domain ind:CollectionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lelThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Lel Threshold Percent' ;
    rdfs:comment 'Lower explosive limit threshold percentage for landfill gas monitoring points, triggering alerts when exceeded.' ;
    rdfs:domain ind:CollectionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linerType rdf:type rdf:Property ;
    rdfs:label 'Liner Type' ;
    rdfs:comment 'Type of liner system associated with this collection point, relevant for leachate collection systems.' ;
    rdfs:domain ind:CollectionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointCode rdf:type rdf:Property ;
    rdfs:label 'Point Code' ;
    rdfs:comment 'Externally-known unique business identifier for the collection point, used in operational systems and reporting.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointName rdf:type rdf:Property ;
    rdfs:label 'Point Name' ;
    rdfs:comment 'Human-readable name or designation of the collection point within the landfill site.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointType rdf:type rdf:Property ;
    rdfs:label 'Point Type' ;
    rdfs:comment 'Classification of the collection point based on its primary environmental monitoring or collection function.' ;
    rdfs:domain ind:CollectionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleMethod rdf:type rdf:Property ;
    rdfs:label 'Sample Method' ;
    rdfs:comment 'Standard method or protocol used for collecting samples or readings at this collection point.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Treatment Required Flag' ;
    rdfs:comment 'Indicates whether collected material from this point requires treatment before discharge or disposal.' ;
    rdfs:domain ind:CollectionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:backgroundMonitoringFlag rdf:type rdf:Property ;
    rdfs:label 'Background Monitoring Flag' ;
    rdfs:comment 'Indicates whether this point serves as a background or upgradient reference location (true) for comparison with downgradient monitoring results.' ;
    rdfs:domain ind:MonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectionMonitoringFlag rdf:type rdf:Property ;
    rdfs:label 'Detection Monitoring Flag' ;
    rdfs:comment 'Indicates whether this point is part of the RCRA Subtitle D detection monitoring program (true) or assessment/corrective action monitoring (false).' ;
    rdfs:domain ind:MonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lelAlarmThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Lel Alarm Threshold Pct' ;
    rdfs:comment 'Percentage of Lower Explosive Limit (LEL) at which an alarm or action is triggered for landfill gas monitoring points. Typically set at 25% LEL per OSHA and EPA guidance.' ;
    rdfs:domain ind:MonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:methaneThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Methane Threshold Pct' ;
    rdfs:comment 'Methane concentration threshold (volume percent) for landfill gas monitoring compliance. Regulatory limit is typically 5% by volume at the facility boundary or 1.25% in structures.' ;
    rdfs:domain ind:MonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringSubtype rdf:type rdf:Property ;
    rdfs:label 'Monitoring Subtype' ;
    rdfs:comment 'Secondary classification providing additional detail on the monitoring point purpose (e.g., compliance well, detection well, extraction well, perimeter probe, interior probe, background station). [ENUM-REF-CANDIDATE: compliance_well|detection_well|extraction_well|perimeter_probe|interior_probe|background_station|boundary_station|meteorological_tower — promote to reference product]' ;
    rdfs:domain ind:MonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterList rdf:type rdf:Property ;
    rdfs:label 'Parameter List' ;
    rdfs:comment 'Comma-separated list of environmental parameters or analytes measured at this monitoring point (e.g., pH, conductivity, VOCs, methane, benzene, dissolved oxygen, temperature).' ;
    rdfs:domain ind:MonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageFlowRateGpm rdf:type rdf:Property ;
    rdfs:label 'Average Flow Rate Gpm' ;
    rdfs:comment 'Typical average flow rate through the outfall in gallons per minute based on historical monitoring data.' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bestManagementPractices rdf:type rdf:Property ;
    rdfs:label 'Best Management Practices' ;
    rdfs:comment 'Description of best management practices implemented to minimize pollutant discharge from this outfall.' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionDate rdf:type rdf:Property ;
    rdfs:label 'Construction Date' ;
    rdfs:comment 'Date when the outfall infrastructure was originally constructed and commissioned.' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designFlowRateGpm rdf:type rdf:Property ;
    rdfs:label 'Design Flow Rate Gpm' ;
    rdfs:comment 'Maximum design flow rate capacity of the outfall in gallons per minute as specified in engineering plans.' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dischargeCategory rdf:type rdf:Property ;
    rdfs:label 'Discharge Category' ;
    rdfs:comment 'Regulatory classification of the discharge source as point source (discrete conveyance) or non-point source (diffuse runoff).' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargeLimitationType rdf:type rdf:Property ;
    rdfs:label 'Discharge Limitation Type' ;
    rdfs:comment 'Type of effluent limitation applied to this outfall (technology-based standards, water quality-based standards, combined, or none).' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargeMethod rdf:type rdf:Property ;
    rdfs:label 'Discharge Method' ;
    rdfs:comment 'Method by which effluent is discharged from the outfall (gravity flow, pumped discharge, siphon, or overflow).' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasFlowMeter rdf:type rdf:Property ;
    rdfs:label 'Has Flow Meter' ;
    rdfs:comment 'Indicates whether the outfall is equipped with a flow measurement device for continuous or periodic flow monitoring.' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasSampler rdf:type rdf:Property ;
    rdfs:label 'Has Sampler' ;
    rdfs:comment 'Indicates whether the outfall is equipped with an automatic water quality sampling device.' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monitoringParameters rdf:type rdf:Property ;
    rdfs:label 'Monitoring Parameters' ;
    rdfs:comment 'Comma-separated list of water quality parameters required to be monitored at this outfall (e.g., pH, BOD, TSS, metals, nutrients).' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outfallName rdf:type rdf:Property ;
    rdfs:label 'Outfall Name' ;
    rdfs:comment 'Human-readable descriptive name for the outfall discharge point (e.g., North Leachate Discharge Point, East Stormwater Outfall).' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outfallNumber rdf:type rdf:Property ;
    rdfs:label 'Outfall Number' ;
    rdfs:comment 'Business identifier for the outfall as designated in NPDES permit documentation and regulatory filings. Externally-known unique code.' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outfallType rdf:type rdf:Property ;
    rdfs:label 'Outfall Type' ;
    rdfs:comment 'Classification of the outfall based on the type of discharge (leachate, stormwater runoff, groundwater seepage, surface water, combined discharge, or process water).' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Permit Effective Date' ;
    rdfs:comment 'Date when the NPDES permit for this outfall became effective and discharge authorization commenced.' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pipeDiameterInches rdf:type rdf:Property ;
    rdfs:label 'Pipe Diameter Inches' ;
    rdfs:comment 'Internal diameter of the outfall discharge pipe in inches.' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipeMaterial rdf:type rdf:Property ;
    rdfs:label 'Pipe Material' ;
    rdfs:comment 'Material composition of the outfall discharge pipe (HDPE, PVC, concrete, steel, ductile iron, or fiberglass).' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingWaterBody rdf:type rdf:Property ;
    rdfs:label 'Receiving Water Body' ;
    rdfs:comment 'Name of the surface water body, stream, river, lake, or municipal system that receives discharge from this outfall.' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingWaterClassification rdf:type rdf:Property ;
    rdfs:label 'Receiving Water Classification' ;
    rdfs:comment 'State or federal classification of the receiving water body (e.g., Class A, Class B, impaired waters, TMDL-listed).' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentSystemType rdf:type rdf:Property ;
    rdfs:label 'Treatment System Type' ;
    rdfs:comment 'Type of treatment system upstream of the outfall (e.g., leachate treatment plant, detention basin, oil-water separator, none).' ;
    rdfs:domain ind:Outfall ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableAssetClass rdf:type rdf:Property ;
    rdfs:label 'Applicable Asset Class' ;
    rdfs:comment 'Asset class or equipment type to which this task list applies (e.g., refuse truck, compactor, landfill equipment, transfer station machinery). [ENUM-REF-CANDIDATE: refuse_truck|roll_off_truck|front_loader|rear_loader|compactor|baler|excavator|dozer|wheel_loader|transfer_station_equipment|landfill_equipment|recycling_equipment|facility_hvac|facility_electrical — promote to reference product]' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableManufacturer rdf:type rdf:Property ;
    rdfs:label 'Applicable Manufacturer' ;
    rdfs:comment 'Equipment manufacturer or brand for which this task list is designed (e.g., Mack, Peterbilt, Caterpillar, John Deere). Null if task list is manufacturer-agnostic.' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableModelSeries rdf:type rdf:Property ;
    rdfs:label 'Applicable Model Series' ;
    rdfs:comment 'Specific equipment model or series for which this task list is designed. Null if task list applies across multiple models.' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTotalCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Cost' ;
    rdfs:comment 'Estimated total cost in USD for completing the task list, including labor, parts, and other direct costs.' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequencyIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Frequency Interval Days' ;
    rdfs:comment 'Standard interval in days between scheduled executions of the task list for preventive maintenance (PM) cycles. Null for corrective or on-demand task lists.' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyIntervalHours rdf:type rdf:Property ;
    rdfs:label 'Frequency Interval Hours' ;
    rdfs:comment 'Standard interval in operating hours between scheduled executions of the task list for equipment preventive maintenance based on hour meter readings. Null for non-equipment assets.' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyIntervalMiles rdf:type rdf:Property ;
    rdfs:label 'Frequency Interval Miles' ;
    rdfs:comment 'Standard interval in miles between scheduled executions of the task list for fleet preventive maintenance based on odometer readings. Null for non-fleet assets.' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskListCategory rdf:type rdf:Property ;
    rdfs:label 'Task List Category' ;
    rdfs:comment 'Business category grouping task lists by asset domain: fleet (vehicles), facility (buildings), equipment (machinery), infrastructure (utilities), safety (compliance), or environmental (waste systems).' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskListCode rdf:type rdf:Property ;
    rdfs:label 'Task List Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying the task list. Used for cross-system reference and work order documentation.' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskListName rdf:type rdf:Property ;
    rdfs:label 'Task List Name' ;
    rdfs:comment 'Human-readable name or title of the task list describing the maintenance activity or procedure.' ;
    rdfs:domain ind:TaskList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageLaborRatePerHour rdf:type rdf:Property ;
    rdfs:label 'Average Labor Rate Per Hour' ;
    rdfs:comment 'Average hourly labor rate for technicians at this work center, used for maintenance cost estimation.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backlogThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Backlog Threshold Hours' ;
    rdfs:comment 'Maximum acceptable backlog of work orders in hours before escalation is required.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Capacity Hours Per Day' ;
    rdfs:comment 'Total available labor hours per day for this work center, used for capacity planning and work order scheduling.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationRequirements rdf:type rdf:Property ;
    rdfs:label 'Certification Requirements' ;
    rdfs:comment 'Required certifications or qualifications for technicians working at this work center (e.g., DOT, EPA, OSHA).' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmmsSystemCode rdf:type rdf:Property ;
    rdfs:label 'Cmms System Code' ;
    rdfs:comment 'Work center identifier in the CMMS system (Infor EAM) for integration and work order routing.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotInspectionAuthorized rdf:type rdf:Property ;
    rdfs:label 'Dot Inspection Authorized' ;
    rdfs:comment 'Indicates whether the work center is authorized to perform DOT vehicle inspections and certifications.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyContactAvailable rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Available' ;
    rdfs:comment 'Indicates whether the work center has 24/7 emergency contact capability for critical breakdowns.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentCapabilities rdf:type rdf:Property ;
    rdfs:label 'Equipment Capabilities' ;
    rdfs:comment 'Description of specialized equipment and tools available at this work center for maintenance operations.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpWorkCenterCode rdf:type rdf:Property ;
    rdfs:label 'Erp Work Center Code' ;
    rdfs:comment 'Work center identifier in the ERP system (SAP PM) for financial integration and cost tracking.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCertified rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified' ;
    rdfs:comment 'Indicates whether the work center is certified to handle hazardous materials and waste per EPA regulations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastSafetyAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Safety Audit Date' ;
    rdfs:comment 'Date of the most recent safety audit or inspection conducted at this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextSafetyAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Safety Audit Date' ;
    rdfs:comment 'Scheduled date for the next safety audit or inspection at this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfTechnicians rdf:type rdf:Property ;
    rdfs:label 'Number Of Technicians' ;
    rdfs:comment 'Current headcount of technicians assigned to this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partsInventoryLocation rdf:type rdf:Property ;
    rdfs:label 'Parts Inventory Location' ;
    rdfs:comment 'Physical location code or identifier for the parts inventory storage area associated with this work center.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialization rdf:type rdf:Property ;
    rdfs:label 'Specialization' ;
    rdfs:comment 'Primary technical specialization or trade focus of the work center (e.g., hydraulics, electrical, diesel engine, welding).' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Utilization Target Percentage' ;
    rdfs:comment 'Target utilization percentage for the work center capacity, used for performance management.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workCenterType rdf:type rdf:Property ;
    rdfs:label 'Work Center Type' ;
    rdfs:comment 'Classification of the work center based on its primary maintenance function.' ;
    rdfs:domain ind:WorkCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetClassId rdf:type rdf:Property ;
    rdfs:label 'Asset Class Id' ;
    rdfs:comment 'Reference to the asset class or equipment type this plan applies to, enabling template-based maintenance planning across similar assets.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Class .

ind:workOrderTypeId rdf:type rdf:Property ;
    rdfs:label 'Work Order Type Id' ;
    rdfs:comment 'Reference to the type of work order that will be generated from this maintenance plan (e.g., PM inspection, lubrication, DOT inspection).' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Type .

ind:autoGenerateWorkOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Generate Work Order Flag' ;
    rdfs:comment 'Indicates whether work orders should be automatically generated by the CMMS system based on the maintenance schedule, or manually created by planners.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downtimeRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Downtime Required Flag' ;
    rdfs:comment 'Indicates whether the asset must be taken out of service to perform the maintenance, impacting operational scheduling.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequencyValue rdf:type rdf:Property ;
    rdfs:label 'Frequency Value' ;
    rdfs:comment 'Numeric value representing the interval between maintenance activities (e.g., 30 for 30 days, 5000 for 5000 miles).' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Last Execution Date' ;
    rdfs:comment 'Date when maintenance under this plan was last completed, used to calculate the next scheduled maintenance date.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meterReadingTrigger rdf:type rdf:Property ;
    rdfs:label 'Meter Reading Trigger' ;
    rdfs:comment 'For usage-based plans, the meter reading (odometer, engine hours, cycles) at which maintenance is triggered.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Date' ;
    rdfs:comment 'Calculated date when the next maintenance activity is due based on frequency and last execution date.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonRestriction rdf:type rdf:Property ;
    rdfs:label 'Season Restriction' ;
    rdfs:comment 'Seasonal constraint for when maintenance can or should be performed, relevant for weather-dependent activities or seasonal equipment.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Related Flag' ;
    rdfs:comment 'Indicates whether this maintenance is required to maintain manufacturer warranty coverage on the asset.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalEntityId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Id' ;
    rdfs:comment 'Reference to the legal entity that owns or controls this bank account.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:accountHolderName rdf:type rdf:Property ;
    rdfs:label 'Account Holder Name' ;
    rdfs:comment 'The legal name of the entity or individual who is the registered holder of the bank account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHolderTaxNumber rdf:type rdf:Property ;
    rdfs:label 'Account Holder Tax Number' ;
    rdfs:comment 'The tax identification number (EIN or SSN) of the account holder for tax reporting purposes.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountPurpose rdf:type rdf:Property ;
    rdfs:label 'Account Purpose' ;
    rdfs:comment 'The primary business purpose or function for which the bank account is used within procurement and treasury operations.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankContactEmail rdf:type rdf:Property ;
    rdfs:label 'Bank Contact Email' ;
    rdfs:comment 'The email address of the primary bank contact for account communications.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankContactName rdf:type rdf:Property ;
    rdfs:label 'Bank Contact Name' ;
    rdfs:comment 'The name of the primary contact person at the bank for this account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankContactPhone rdf:type rdf:Property ;
    rdfs:label 'Bank Contact Phone' ;
    rdfs:comment 'The phone number of the primary bank contact for account inquiries and support.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'The legal name of the financial institution holding the account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchAddress rdf:type rdf:Property ;
    rdfs:label 'Branch Address' ;
    rdfs:comment 'The complete street address of the bank branch holding the account.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchCity rdf:type rdf:Property ;
    rdfs:label 'Branch City' ;
    rdfs:comment 'The city where the bank branch is located.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchCountryCode rdf:type rdf:Property ;
    rdfs:label 'Branch Country Code' ;
    rdfs:comment 'The three-letter ISO country code where the bank branch is located.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchName rdf:type rdf:Property ;
    rdfs:label 'Branch Name' ;
    rdfs:comment 'The name of the specific bank branch where the account is held.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchPostalCode rdf:type rdf:Property ;
    rdfs:label 'Branch Postal Code' ;
    rdfs:comment 'The postal code of the bank branch location.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchState rdf:type rdf:Property ;
    rdfs:label 'Branch State' ;
    rdfs:comment 'The two-letter state code where the bank branch is located.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iban rdf:type rdf:Property ;
    rdfs:label 'Iban' ;
    rdfs:comment 'The International Bank Account Number used for international wire transfers and cross-border payments.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActiveForPayments rdf:type rdf:Property ;
    rdfs:label 'Is Active For Payments' ;
    rdfs:comment 'Indicates whether this bank account is currently enabled for outgoing payment transactions.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isActiveForReceipts rdf:type rdf:Property ;
    rdfs:label 'Is Active For Receipts' ;
    rdfs:comment 'Indicates whether this bank account is currently enabled for incoming receipt transactions.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryAccount rdf:type rdf:Property ;
    rdfs:label 'Is Primary Account' ;
    rdfs:comment 'Indicates whether this is the primary bank account for the associated legal entity or cost center.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Last Reconciliation Date' ;
    rdfs:comment 'The date when the bank account was last reconciled with bank statements.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumBalanceRequired rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Required' ;
    rdfs:comment 'The minimum account balance required to be maintained as per bank or internal policy.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:swiftCode rdf:type rdf:Property ;
    rdfs:label 'Swift Code' ;
    rdfs:comment 'The Society for Worldwide Interbank Financial Telecommunication (SWIFT) Bank Identifier Code (BIC) for international transactions.' ;
    rdfs:domain ind:BankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardedValue rdf:type rdf:Property ;
    rdfs:label 'Awarded Value' ;
    rdfs:comment 'Total monetary value awarded as a result of the sourcing event in the specified currency.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Value' ;
    rdfs:comment 'Estimated total monetary value of the sourcing event in USD.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Start Date' ;
    rdfs:comment 'Date when evaluation of supplier responses begins.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventName rdf:type rdf:Property ;
    rdfs:label 'Event Name' ;
    rdfs:comment 'Human-readable name or title of the sourcing event describing its purpose.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invitedSupplierCount rdf:type rdf:Property ;
    rdfs:label 'Invited Supplier Count' ;
    rdfs:comment 'Number of suppliers invited to participate in the sourcing event.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isMultiAward rdf:type rdf:Property ;
    rdfs:label 'Is Multi Award' ;
    rdfs:comment 'Indicates whether the sourcing event allows for multiple suppliers to be awarded (True) or single award only (False).' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReverseAuction rdf:type rdf:Property ;
    rdfs:label 'Is Reverse Auction' ;
    rdfs:comment 'Indicates whether the sourcing event is conducted as a reverse auction where suppliers compete by lowering prices in real-time (True/False).' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publishDate rdf:type rdf:Property ;
    rdfs:label 'Publish Date' ;
    rdfs:comment 'Date when the sourcing event was published and made available to suppliers.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestingDepartment rdf:type rdf:Property ;
    rdfs:label 'Requesting Department' ;
    rdfs:comment 'Business unit or department that initiated the sourcing request.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseCount rdf:type rdf:Property ;
    rdfs:label 'Response Count' ;
    rdfs:comment 'Number of supplier responses or bids received for the sourcing event.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseDeadline rdf:type rdf:Property ;
    rdfs:label 'Response Deadline' ;
    rdfs:comment 'Date and time by which suppliers must submit their responses or bids.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:savingsAmount rdf:type rdf:Property ;
    rdfs:label 'Savings Amount' ;
    rdfs:comment 'Cost savings achieved compared to baseline or estimated value, in the specified currency.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sustainabilityRequired rdf:type rdf:Property ;
    rdfs:label 'Sustainability Required' ;
    rdfs:comment 'Indicates whether sustainability or environmental compliance criteria are mandatory for supplier participation (True/False).' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carbonProjectId rdf:type rdf:Property ;
    rdfs:label 'Carbon Project Id' ;
    rdfs:comment 'Primary key for carbon_project' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualCo2eReductionMt rdf:type rdf:Property ;
    rdfs:label 'Actual Co2e Reduction Mt' ;
    rdfs:comment 'Verified annual reduction in greenhouse gas emissions measured in metric tons of carbon dioxide equivalent (CO2e) achieved by the project.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:additionalityJustification rdf:type rdf:Property ;
    rdfs:label 'Additionality Justification' ;
    rdfs:comment 'Explanation of how the project demonstrates additionality (i.e., reductions would not have occurred without the project) as required for carbon credit certification.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineMethodology rdf:type rdf:Property ;
    rdfs:label 'Baseline Methodology' ;
    rdfs:comment 'Methodology used to establish the baseline emissions scenario against which project reductions are measured.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonCreditEligible rdf:type rdf:Property ;
    rdfs:label 'Carbon Credit Eligible' ;
    rdfs:comment 'Indicates whether the project is eligible to generate tradable carbon credits or offsets under a recognized standard.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:circularEconomyIndicator rdf:type rdf:Property ;
    rdfs:label 'Circular Economy Indicator' ;
    rdfs:comment 'Indicates whether the project supports circular economy principles by recovering materials or energy from waste streams.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditsIssuedCount rdf:type rdf:Property ;
    rdfs:label 'Credits Issued Count' ;
    rdfs:comment 'Total number of carbon credits or offsets issued to date for this project by the verification body.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditsRetiredCount rdf:type rdf:Property ;
    rdfs:label 'Credits Retired Count' ;
    rdfs:comment 'Total number of carbon credits or offsets retired (used) to date from this project to claim emission reductions.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Verification Date' ;
    rdfs:comment 'Date of the most recent third-party verification or audit of the project\'s carbon reduction performance.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Next Verification Date' ;
    rdfs:comment 'Scheduled date for the next third-party verification or audit of the project\'s carbon reduction performance.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnerOrganization rdf:type rdf:Property ;
    rdfs:label 'Partner Organization' ;
    rdfs:comment 'Name of external partner organization or vendor involved in the carbon project implementation or verification (e.g., technology provider, verification body).' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCategory rdf:type rdf:Property ;
    rdfs:label 'Project Category' ;
    rdfs:comment 'High-level categorization of the project based on its carbon impact mechanism: reduction (lowering emissions), removal (sequestration), avoidance (preventing emissions), or offset (purchasing credits).' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Business identifier for the carbon project following the format: three-letter category code, four-digit sequence number, and two-letter region code (e.g., LFG-0001-US for landfill gas project).' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectInvestmentUsd rdf:type rdf:Property ;
    rdfs:label 'Project Investment Usd' ;
    rdfs:comment 'Total capital investment in US dollars allocated to the carbon project including equipment, infrastructure, and implementation costs.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Project Manager Email' ;
    rdfs:comment 'Email address of the project manager for communication and coordination.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectManagerName rdf:type rdf:Property ;
    rdfs:label 'Project Manager Name' ;
    rdfs:comment 'Name of the individual responsible for managing and overseeing the carbon project implementation and performance.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Geographic region or country where the carbon project is located using ISO 3166-1 alpha-3 country codes.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewableEnergyType rdf:type rdf:Property ;
    rdfs:label 'Renewable Energy Type' ;
    rdfs:comment 'Type of renewable energy generated or utilized by the project, if applicable.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCo2eReductionMt rdf:type rdf:Property ;
    rdfs:label 'Target Co2e Reduction Mt' ;
    rdfs:comment 'Planned annual reduction in greenhouse gas emissions measured in metric tons of carbon dioxide equivalent (CO2e) that the project aims to achieve.' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technologyDescription rdf:type rdf:Property ;
    rdfs:label 'Technology Description' ;
    rdfs:comment 'Detailed description of the technology, equipment, or methodology used in the carbon project (e.g., landfill gas collection system, CNG vehicle conversion, anaerobic digestion).' ;
    rdfs:domain ind:CarbonProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobraEligible rdf:type rdf:Property ;
    rdfs:label 'Cobra Eligible' ;
    rdfs:comment 'Indicates whether this benefit plan is eligible for COBRA continuation coverage when an employee experiences a qualifying event such as termination or reduction in hours.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:copayAmount rdf:type rdf:Property ;
    rdfs:label 'Copay Amount' ;
    rdfs:comment 'Fixed dollar amount the employee pays for specific covered services such as office visits or prescriptions. Typical for medical and dental plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageLevel rdf:type rdf:Property ;
    rdfs:label 'Coverage Level' ;
    rdfs:comment 'Defines who is covered under the benefit plan: employee only, employee plus spouse, employee plus children, or full family coverage.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependentCoverageAgeLimit rdf:type rdf:Property ;
    rdfs:label 'Dependent Coverage Age Limit' ;
    rdfs:comment 'Maximum age at which dependent children are eligible for coverage under this benefit plan. Typically 26 years for ACA-compliant health plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employeeContributionPercentage rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Percentage' ;
    rdfs:comment 'Percentage of total premium or salary that the employee contributes for this benefit plan. Null if contribution is fixed-dollar or employer-paid.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerContributionPercentage rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Percentage' ;
    rdfs:comment 'Percentage of total premium or salary that the employer contributes for this benefit plan. Used for labor cost allocation and financial reporting.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentEligibilityRule rdf:type rdf:Property ;
    rdfs:label 'Enrollment Eligibility Rule' ;
    rdfs:comment 'Business rule or criteria defining which employees are eligible to enroll in this benefit plan, such as full-time status, job classification, or tenure requirements.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAcaCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Aca Compliant' ;
    rdfs:comment 'Indicates whether this health benefit plan meets the minimum essential coverage and affordability requirements under the Affordable Care Act.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isErisaPlan rdf:type rdf:Property ;
    rdfs:label 'Is Erisa Plan' ;
    rdfs:comment 'Indicates whether this benefit plan is subject to the Employee Retirement Income Security Act (ERISA) regulations and reporting requirements.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHsaEligible rdf:type rdf:Property ;
    rdfs:label 'Is Hsa Eligible' ;
    rdfs:comment 'Indicates whether this health plan qualifies as a High Deductible Health Plan (HDHP) and is eligible for Health Savings Account (HSA) contributions.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openEnrollmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Open Enrollment End Date' ;
    rdfs:comment 'End date of the annual open enrollment period. Changes made during this period become effective at the start of the next plan year.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openEnrollmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Open Enrollment Start Date' ;
    rdfs:comment 'Start date of the annual open enrollment period when employees can enroll in, change, or cancel benefit plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outOfPocketMaximum rdf:type rdf:Property ;
    rdfs:label 'Out Of Pocket Maximum' ;
    rdfs:comment 'Maximum amount an employee will pay out-of-pocket for covered services in a plan year. After this limit, the plan pays 100% of covered expenses.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planAdministratorEmail rdf:type rdf:Property ;
    rdfs:label 'Plan Administrator Email' ;
    rdfs:comment 'Email address of the plan administrator for employee inquiries and benefits administration communication.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planAdministratorName rdf:type rdf:Property ;
    rdfs:label 'Plan Administrator Name' ;
    rdfs:comment 'Name of the individual or department responsible for administering this benefit plan, handling enrollments, and addressing employee questions.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planAdministratorPhone rdf:type rdf:Property ;
    rdfs:label 'Plan Administrator Phone' ;
    rdfs:comment 'Phone number of the plan administrator for employee inquiries and benefits support.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planCategory rdf:type rdf:Property ;
    rdfs:label 'Plan Category' ;
    rdfs:comment 'High-level grouping of benefit plans for reporting and administration purposes. Broader classification than plan type.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planNotes rdf:type rdf:Property ;
    rdfs:label 'Plan Notes' ;
    rdfs:comment 'Free-text field for additional notes, special instructions, or administrative comments about the benefit plan that do not fit in structured fields.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planYearEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan Year End Date' ;
    rdfs:comment 'End date of the plan year for benefits administration. Deductibles and out-of-pocket maximums typically reset at the start of the next plan year.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planYearStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Year Start Date' ;
    rdfs:comment 'Start date of the plan year for benefits administration, typically aligned with open enrollment periods and deductible reset dates.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Total Premium Amount' ;
    rdfs:comment 'Total premium cost per pay period for this benefit plan, including both employer and employee contributions. Used for budgeting and cost analysis.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waitingPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Waiting Period Days' ;
    rdfs:comment 'Number of days an employee must wait after hire date or eligibility date before they can enroll in this benefit plan. Zero indicates immediate eligibility.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Approval Deadline Date' ;
    rdfs:comment 'The deadline date by which supervisors must approve timesheets and payroll adjustments for this pay period.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:checkDate rdf:type rdf:Property ;
    rdfs:label 'Check Date' ;
    rdfs:comment 'The date on which paychecks or direct deposits are issued to employees for this pay period.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalizedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Finalized Timestamp' ;
    rdfs:comment 'The date and time when payroll processing was completed and paychecks were finalized for this pay period.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holidayCount rdf:type rdf:Property ;
    rdfs:label 'Holiday Count' ;
    rdfs:comment 'The number of company-recognized holidays that fall within this pay period.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isAdjustmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Adjustment Period' ;
    rdfs:comment 'Indicates whether this pay period is designated for payroll adjustments, corrections, or off-cycle payments (True/False).' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isYearEndPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Year End Period' ;
    rdfs:comment 'Indicates whether this is the final pay period of the calendar or fiscal year, requiring special year-end processing (True/False).' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opened Timestamp' ;
    rdfs:comment 'The date and time when this pay period was opened for time entry and payroll processing.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:payrollSystemCode rdf:type rdf:Property ;
    rdfs:label 'Payroll System Code' ;
    rdfs:comment 'The code or identifier used by the payroll system (Workday HCM, SAP) to reference this pay period.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodNumber rdf:type rdf:Property ;
    rdfs:label 'Period Number' ;
    rdfs:comment 'Sequential number of the pay period within the fiscal or calendar year (e.g., 1, 2, 3...26 for bi-weekly).' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processingBatchCode rdf:type rdf:Property ;
    rdfs:label 'Processing Batch Code' ;
    rdfs:comment 'The batch identifier used during payroll processing for this pay period, linking to payroll run logs.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeEntryCutoffDate rdf:type rdf:Property ;
    rdfs:label 'Time Entry Cutoff Date' ;
    rdfs:comment 'The deadline date by which employees must submit their time and attendance records for this pay period.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalDaysCount rdf:type rdf:Property ;
    rdfs:label 'Total Days Count' ;
    rdfs:comment 'The total number of calendar days in this pay period.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workingDaysCount rdf:type rdf:Property ;
    rdfs:label 'Working Days Count' ;
    rdfs:comment 'The number of standard working days (excluding weekends and holidays) within this pay period.' ;
    rdfs:domain ind:PayPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeCaseId rdf:type rdf:Property ;
    rdfs:label 'Dispute Case Id' ;
    rdfs:comment 'Reference to the billing dispute case that resulted in this refund, if applicable.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalPaymentId rdf:type rdf:Property ;
    rdfs:label 'Original Payment Id' ;
    rdfs:comment 'Reference to the original payment transaction being refunded, if applicable.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processingDate rdf:type rdf:Property ;
    rdfs:label 'Processing Date' ;
    rdfs:comment 'Date when the refund payment was initiated or sent to the payment processor.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refundNumber rdf:type rdf:Property ;
    rdfs:label 'Refund Number' ;
    rdfs:comment 'Externally-visible unique refund transaction number used for customer communication and tracking.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundReasonCode rdf:type rdf:Property ;
    rdfs:label 'Refund Reason Code' ;
    rdfs:comment 'Standardized code representing the specific business reason for the refund.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Refund Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of why the refund was issued, including any supporting context or customer communication notes.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundTransactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Transaction Timestamp' ;
    rdfs:comment 'Precise date and time when the refund transaction was recorded in the system. Primary business event timestamp.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refundType rdf:type rdf:Property ;
    rdfs:label 'Refund Type' ;
    rdfs:comment 'Classification of the refund reason: overpayment (customer paid more than owed), service_credit (service quality issue), billing_error (incorrect invoice), rate_adjustment (pricing correction), cancellation (service termination), dispute_resolution (resolved customer dispute).' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLocationId rdf:type rdf:Property ;
    rdfs:label 'Service Location Id' ;
    rdfs:comment 'Reference to the service location associated with the original service that is being refunded.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accreditationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Effective Date' ;
    rdfs:comment 'Date when the laboratory accreditation became effective or was last renewed.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accreditationExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Expiration Date' ;
    rdfs:comment 'Date when the current laboratory accreditation expires and requires renewal.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Accreditation Number' ;
    rdfs:comment 'Official accreditation certificate or registration number issued by the accrediting body.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Accreditation Status' ;
    rdfs:comment 'Current accreditation status of the laboratory indicating its certification standing with regulatory bodies.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacitySamplesPerDay rdf:type rdf:Property ;
    rdfs:label 'Capacity Samples Per Day' ;
    rdfs:comment 'Maximum number of samples the laboratory can process per day under normal operating conditions.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isPreferred rdf:type rdf:Property ;
    rdfs:label 'Is Preferred' ;
    rdfs:comment 'Flag indicating whether this laboratory is a preferred or primary testing facility for the organization.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laboratoryType rdf:type rdf:Property ;
    rdfs:label 'Laboratory Type' ;
    rdfs:comment 'Classification of the laboratory based on its primary testing and analysis focus within waste management operations.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityRating rdf:type rdf:Property ;
    rdfs:label 'Quality Rating' ;
    rdfs:comment 'Internal quality performance rating assigned to the laboratory based on accuracy, timeliness, and compliance with testing standards.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingCapabilities rdf:type rdf:Property ;
    rdfs:label 'Testing Capabilities' ;
    rdfs:comment 'Comma-separated list or description of the types of tests and analyses the laboratory is equipped and certified to perform (e.g., TCLP, VOC, metals analysis, pH testing).' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundTimeDays rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Days' ;
    rdfs:comment 'Standard number of business days required for the laboratory to complete testing and deliver results from sample receipt.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualDate rdf:type rdf:Property ;
    rdfs:label 'Actual Date' ;
    rdfs:comment 'The actual date when the sampling event was conducted. May differ from scheduled date due to operational constraints or weather conditions.' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Timestamp' ;
    rdfs:comment 'Precise date and time when the sample was collected, critical for time-sensitive analysis and regulatory compliance documentation.' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee who reviewed and approved the sampling event documentation and results.' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionRouteId rdf:type rdf:Property ;
    rdfs:label 'Collection Route Id' ;
    rdfs:comment 'Reference to the waste collection route where the sampling event occurred.' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:duplicateSampleCollected rdf:type rdf:Property ;
    rdfs:label 'Duplicate Sample Collected' ;
    rdfs:comment 'Indicates whether a duplicate sample was collected for quality control purposes.' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fieldBlankCollected rdf:type rdf:Property ;
    rdfs:label 'Field Blank Collected' ;
    rdfs:comment 'Indicates whether a field blank sample was collected to detect potential contamination during sampling.' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityControlLevel rdf:type rdf:Property ;
    rdfs:label 'Quality Control Level' ;
    rdfs:comment 'The quality control level applied to this sampling event, indicating the rigor of QA/QC procedures (Level 1: field screening, Level 2: standard analysis, Level 3: enhanced QC, Level 4: forensic-grade).' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplePreservationMethod rdf:type rdf:Property ;
    rdfs:label 'Sample Preservation Method' ;
    rdfs:comment 'The preservation technique applied to the sample to maintain its integrity during transport and storage (e.g., \'refrigerated at 4°C\', \'acidified with HNO3\', \'no preservation required\').' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleVolumeUnit rdf:type rdf:Property ;
    rdfs:label 'Sample Volume Unit' ;
    rdfs:comment 'Unit of measure for the sample volume (milliliters, liters, gallons, cubic feet, or cubic meters).' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleWeight rdf:type rdf:Property ;
    rdfs:label 'Sample Weight' ;
    rdfs:comment 'The weight of the sample collected, measured in the unit specified in sample_weight_unit. Applicable primarily for solid waste samples.' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleWeightUnit rdf:type rdf:Property ;
    rdfs:label 'Sample Weight Unit' ;
    rdfs:comment 'Unit of measure for the sample weight (grams, kilograms, pounds, or tons).' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplerCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Sampler Certification Number' ;
    rdfs:comment 'Professional certification or license number of the sampler, required for certain regulated sampling activities.' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sampler Employee Id' ;
    rdfs:comment 'Reference to the employee who physically collected the sample.' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationIso14001 rdf:type rdf:Property ;
    rdfs:label 'Certification Iso 14001' ;
    rdfs:comment 'Indicates whether the laboratory holds ISO 14001 certification for environmental management systems.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationIso45001 rdf:type rdf:Property ;
    rdfs:label 'Certification Iso 45001' ;
    rdfs:comment 'Indicates whether the laboratory holds ISO 45001 certification for occupational health and safety management systems.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardousWasteHandlerId rdf:type rdf:Property ;
    rdfs:label 'Hazardous Waste Handler Id' ;
    rdfs:comment 'EPA-issued identification number for the laboratory as a hazardous waste handler, required for laboratories that generate or handle hazardous waste.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityManagementSystem rdf:type rdf:Property ;
    rdfs:label 'Quality Management System' ;
    rdfs:comment 'Name or description of the quality management system framework implemented by the laboratory (e.g., ISO 9001, ISO/IEC 17025, NELAP QA Manual).' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeOfAccreditation rdf:type rdf:Property ;
    rdfs:label 'Scope Of Accreditation' ;
    rdfs:comment 'Detailed description of the testing methods, analytes, and matrices for which the laboratory is accredited.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualSamplingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Sampling Timestamp' ;
    rdfs:comment 'Precise date and time when the sample was physically collected in the field. This is the principal business event timestamp for the sampling event.' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ambientTemperature rdf:type rdf:Property ;
    rdfs:label 'Ambient Temperature' ;
    rdfs:comment 'Ambient air temperature at the time of sampling, measured in degrees Celsius, relevant for certain environmental monitoring requirements.' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analysisCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Analysis Completed Timestamp' ;
    rdfs:comment 'Date and time when laboratory analysis was completed and results were finalized.' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:analysisRequested rdf:type rdf:Property ;
    rdfs:label 'Analysis Requested' ;
    rdfs:comment 'Description of the analytical tests or parameter suite requested for this sample (e.g., VOCs, metals, pH, BOD, total coliform).' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceedanceDetected rdf:type rdf:Property ;
    rdfs:label 'Exceedance Detected' ;
    rdfs:comment 'Indicates whether any analytical results from this sampling event exceeded regulatory limits or action levels, triggering potential corrective action or reporting requirements.' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fieldConductivity rdf:type rdf:Property ;
    rdfs:label 'Field Conductivity' ;
    rdfs:comment 'Electrical conductivity of the sample measured in the field, in microsiemens per centimeter, used as an indicator of dissolved solids in water samples.' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldDissolvedOxygen rdf:type rdf:Property ;
    rdfs:label 'Field Dissolved Oxygen' ;
    rdfs:comment 'Dissolved oxygen concentration measured in the field, in milligrams per liter, critical for water quality assessment.' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldTemperature rdf:type rdf:Property ;
    rdfs:label 'Field Temperature' ;
    rdfs:comment 'Temperature of the sample medium measured in the field at time of collection, in degrees Celsius, required for water quality monitoring.' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdingTimeCompliant rdf:type rdf:Property ;
    rdfs:label 'Holding Time Compliant' ;
    rdfs:comment 'Indicates whether the sample was analyzed within the required holding time specified by the analytical method. Non-compliance may affect data usability.' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laboratorySampleId rdf:type rdf:Property ;
    rdfs:label 'Laboratory Sample Id' ;
    rdfs:comment 'Unique identifier assigned by the analytical laboratory to track the sample through their internal processes.' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentSamplingEventId rdf:type rdf:Property ;
    rdfs:label 'Parent Sampling Event Id' ;
    rdfs:comment 'Reference to the parent sampling event if this is a quality control sample (duplicate or split) associated with another primary sample.' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityControlType rdf:type rdf:Property ;
    rdfs:label 'Quality Control Type' ;
    rdfs:comment 'Indicates if this is a quality control sample: field blank, trip blank, equipment blank, field duplicate, matrix spike, or none (regular sample).' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedToRegulator rdf:type rdf:Property ;
    rdfs:label 'Reported To Regulator' ;
    rdfs:comment 'Indicates whether the sampling results have been submitted to the appropriate regulatory agency as required by permit or regulation.' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleContainerType rdf:type rdf:Property ;
    rdfs:label 'Sample Container Type' ;
    rdfs:comment 'Type of container used to collect and preserve the sample (e.g., glass bottle, plastic jar, Tedlar bag, stainless steel canister) as specified by analytical method requirements.' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleDepth rdf:type rdf:Property ;
    rdfs:label 'Sample Depth' ;
    rdfs:comment 'Depth at which the sample was collected, measured in feet or meters below ground surface or water surface, critical for groundwater and soil sampling.' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleDepthUnit rdf:type rdf:Property ;
    rdfs:label 'Sample Depth Unit' ;
    rdfs:comment 'Unit of measure for sample depth: feet, meters, or inches.' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sample Received Timestamp' ;
    rdfs:comment 'Date and time when the sample was received by the analytical laboratory, used to verify holding time compliance.' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:samplingType rdf:type rdf:Property ;
    rdfs:label 'Sampling Type' ;
    rdfs:comment 'Category of environmental sampling conducted: groundwater monitoring, surface water, air quality, soil contamination, leachate analysis, landfill gas emissions, stormwater runoff, or waste characterization.' ;
    rdfs:domain ind:SamplingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindings rdf:type rdf:Property ;
    rdfs:label 'Audit Findings' ;
    rdfs:comment 'Summary of findings, non-conformances, or corrective actions identified during the most recent laboratory audit.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMobileLaboratory rdf:type rdf:Property ;
    rdfs:label 'Is Mobile Laboratory' ;
    rdfs:comment 'Indicates whether the laboratory is a mobile testing unit that can be deployed to different sites.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentOrganization rdf:type rdf:Property ;
    rdfs:label 'Parent Organization' ;
    rdfs:comment 'Name of the parent company or organization that owns or operates the laboratory.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVendorStatus rdf:type rdf:Property ;
