ind:autoEscalationEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Escalation Enabled' ;
    rdfs:comment 'Indicates whether the dunning sequence automatically progresses through escalation steps without manual intervention.' ;
    rdfs:domain ind:DunningSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputePauseEnabled rdf:type rdf:Property ;
    rdfs:label 'Dispute Pause Enabled' ;
    rdfs:comment 'Indicates whether the dunning sequence automatically pauses when a customer files a billing dispute.' ;
    rdfs:domain ind:DunningSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:finalActionType rdf:type rdf:Property ;
    rdfs:label 'Final Action Type' ;
    rdfs:comment 'The ultimate collection action taken when all dunning steps are exhausted without payment resolution.' ;
    rdfs:domain ind:DunningSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaapCompliant rdf:type rdf:Property ;
    rdfs:label 'Gaap Compliant' ;
    rdfs:comment 'Indicates whether this dunning sequence aligns with GAAP revenue recognition and accounts receivable management standards.' ;
    rdfs:domain ind:DunningSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ifrsCompliant rdf:type rdf:Property ;
    rdfs:label 'Ifrs Compliant' ;
    rdfs:comment 'Indicates whether this dunning sequence aligns with IFRS revenue recognition and accounts receivable management standards.' ;
    rdfs:domain ind:DunningSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initialGracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Initial Grace Period Days' ;
    rdfs:comment 'Number of days after invoice due date before the first dunning action is triggered.' ;
    rdfs:domain ind:DunningSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legalHoldPauseEnabled rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Pause Enabled' ;
    rdfs:comment 'Indicates whether the dunning sequence automatically pauses when an account is placed under legal hold or bankruptcy protection.' ;
    rdfs:domain ind:DunningSequence ;
