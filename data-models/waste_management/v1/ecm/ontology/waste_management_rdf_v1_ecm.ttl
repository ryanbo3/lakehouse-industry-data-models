ind:methodName rdf:type rdf:Property ;
    rdfs:label 'Method Name' ;
    rdfs:comment 'Human-readable name of the payment method (e.g., Visa Credit Card, ACH Direct Debit, Paper Check, Cash).' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodType rdf:type rdf:Property ;
    rdfs:label 'Method Type' ;
    rdfs:comment 'High-level classification of the payment method instrument type.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Amount' ;
    rdfs:comment 'Minimum transaction amount allowed for this payment method, in USD. Null if no minimum applies.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingTimeDays rdf:type rdf:Property ;
