ind:refundIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Refund Issued Flag' ;
    rdfs:comment 'Indicates whether a monetary refund has been issued to the customer (True) or credit applied to account (False).' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:voidReason rdf:type rdf:Property ;
    rdfs:label 'Void Reason' ;
